	.SBTTL	PAGEEDIT.ASI;---------\\; EDITOPEN >;=========/; Dbut de l'dition d'une chane d'objets.; in	A4.L	^objet texte;	D4.L	position de la souris (y;x); out	-; mod	D7.WEDITOPEN:	PUSHM.L	D1..D4,D6,A1,A3	LOAD.L	(A6)+OSELPS,A4	; OSELPS <-- ^objet slectionn	LOAD.L	D2,D4		; D2 <-- position de la souris	LOAD.L	A3,A4	LOAD.W	D3,(A6)+OPAGE	; D3 <-- page visible	LOAD.W	D4,#-1		; D4 <-- tous les calques	LOAD.L	D6,(A6)+OOBACH	; D6 <-- canal de l'arbre des objets	CALL	_LSTA_BEGIN	; A4 <-- ^lment de base	EX.L	A3,A4		; A3 <-- ^lment pre	LOAD.L	A1,#R16"OPEN$	CALL	SUITEEXEC	; action sur tous les objets de la chane	CALL	SUITEBBOX	; refait toutes les bbox	CALL	HANDUNDOCOPY	; copie pour UNDO	SET.B	(A6)+OMAJ	; mise  jour sur disque ncessaire	CALL	SUITEIFDRAW	; indique les objets  dessiner	LOAD.L	D4,D2		; D4 <-- position de la souris	SUB.W	D4,(A6)+OAPOS+2	SWAP.W	D4	SUB.W	D4,(A6)+OAPOS+0	SWAP.W	D4	LOAD.W	D3,#KEYMGP	; D3 <-- vnement "clic de la souris"	LOAD.W	D1,#opEDITEVENT	CALL	_OBJCALLD	; donne l'vnement  l'objet	POPM.L	D1..D4,D6,A1,A3	RETOPEN$:	PUSHM.L	D1,D3,D4	LOAD.W	D3,#EDITMOVEGA	; D3 <-- donne l'angle normal	LOAD.W	D1,#opEDITMOVE	CALL	_OBJCALLD	; D4 <-- angle de rotation	JUMP',NE OROT$	TEST.L	D4		; pav tourn ?	JUMP',EQ OROT$		; non => OROT$	CALL	_LSTA_FILS	; objet dans cette page ?	JUMP',NE OROT$		; non => OROT$	TSET.B	(A4)+OobjFLAGS:#BobjEXTEND	CALL	DESSETALL	; efface le texte tourn	TCLR.B	(A4)+OobjFLAGS:#BobjEXTENDOROT$:	TSET.B	(A4)+OobjFLAGS:#BobjEDIT	CALL	_GROUPABS	; rend tous les objets absolus	LOAD.W	D3,#EDITMOVEOPEN ; D3 <-- ouverture	LOAD.W	D1,#opEDITMOVE	CALL	_OBJCALLD	; indique l'ouverture de l'dition	POPM.L	D1,D3,D4	RET;----------\\; EDITCLOSE >;==========/; Fin de l'dition d'une chane d'objets.; in	A4.L	^objet texte;	D2.W	0 => normal;		1 => annule;		2 => supprime; out	-; mod	D7.WEDITCLOSE:	PUSHM.L	D1,D3,D4,D6,A1,A3	LOAD.W	D3,#EDITNPCLRCURS	LOAD.W	D1,#opEDITNEXTPREV	CALL	_OBJCALLD	; enlve le curseur	COMP.W	D2,#2		; dtruit ?	JUMP',EQ DEL$		; oui => DEL$	TEST.W	D2		; annule ?	JUMP',NE BACK$		; oui => BACK$	CALL	HANDUNDOFLUSH	; annule le UNDO	JUMP'	UNDO$BACK$:	CALL	HANDUNDOBACK	; remet l'objet originalUNDO$:	LOAD.L	A3,A4	LOAD.W	D3,(A6)+OPAGE	; D3 <-- page visible	LOAD.W	D4,#-1		; D4 <-- tous les calques	LOAD.L	D6,(A6)+OOBACH	; D6 <-- canal de l'arbre des objets	CALL	_LSTA_BEGIN	; A4 <-- ^lment de base	EX.L	A3,A4		; A3 <-- ^lment pre	LOAD.L	A1,#R16"CLOSE$	CALL	SUITEEXEC	; action sur tous les objets de la chane	CALL	SUITEBBOX	; refait toutes les bbox	JUMP'	REFAIT$DEL$:	CALL	HANDUNDOFLUSH	; annule le UNDO	CALL	_LSTA_BBOX	; D3/D4 <-- bbox absolue	CALL	_LSTA_REMOVE	; enlve l'objet et ses fils	CALL	DESALLWDO	; redessine o tait l'objet	JUMP'	EXIT$REFAIT$:	TEST.W	(A6)+OGBBOX	; y a-t-il eu des modifications ?	JUMP',EQ EXIT$		; non => EXIT$	CALL	DESREFAIT	; refait le dessinEXIT$:	POPM.L	D1,D3,D4,D6,A1,A3	RETCLOSE$:	PUSHM.L	D1,D3,D4	TCLR.B	(A4)+OobjFLAGS:#BobjEDIT	CALL	_GROUPREL	; remet tous les objets relatifs	TEST.W	(A6)+OGBBOX	; y a-t-il eu des modifications ?	JUMP',NE CROT$		; oui => CROT$	LOAD.W	D3,#EDITMOVEGAE	; D3 <-- donne l'angle avant l'dition	LOAD.W	D1,#opEDITMOVE	CALL	_OBJCALLD	; D4 <-- angle de rotation	JUMP',NE CROT$	TEST.L	D4		; pav tourn ?	JUMP',EQ CROT$		; non => CROT$	CALL	_LSTA_FILS	; objet dans cette page ?	JUMP',NE CROT$		; non => CROT$	TSET.B	(A4)+OobjFLAGS:#BobjEXTEND	CALL	DESSETALL	; efface le texte tourn	TCLR.B	(A4)+OobjFLAGS:#BobjEXTENDCROT$:	LOAD.W	D3,#EDITMOVECLOSE ; D3 <-- fermeture	LOAD.W	D1,#opEDITMOVE	CALL	_OBJCALLD	; indique la fermeture de l'dition	POPM.L	D1,D3,D4	RET;------------\\; SUITEREMOVE >;============/; Avant la destruction d'un objet quelconque, enlve-le de la; chane si elle existe.; in	A4.L	^objet; out	-; mod	D7.WSUITEREMOVE:	PUSHM.L	D3,D4,D6,A3..A5	CALL	SUITEEXIST	; fait partie d'une chane ?	JUMP',NE EXIT$		; non => EXIT$	LOAD.L	A3,A4	LOAD.W	D3,(A6)+OPAGE	; D3 <-- page visible	LOAD.W	D4,(A6)+OCALQ	; D4 <-- calque visible	LOAD.L	D6,(A6)+OOBACH	; D6 <-- canal de l'arbre des objets	CALL	_LSTA_BEGIN	; A4 <-- ^lment de base	EX.L	A3,A4		; A3 <-- ^lment pre	CALL	SUITEIFDSP	; suite de la chane dans la mme page ?	JUMP',NE NODRAW$	; non => NODRAW$	INC.W	(A6)+OGDRAW	; il faudra tout redessinerNODRAW$:	CALL	SUITEOUT	; A5 <-- sort de la chaneEXIT$:	POPM.L	D3,D4,D6,A3..A5	RET;----------\\; SUITEDRAW >;==========/; Redessine tous les objets de la chane.; in	A4.L	^objet texte; out	-; mod	D7.WSUITEDRAW:	PUSHM.L	D3,D4,D6,A1,A3	LOAD.L	A3,A4	LOAD.W	D3,(A6)+OPAGE	; D3 <-- page visible	LOAD.W	D4,#-1		; D4 <-- tous les calques	LOAD.L	D6,(A6)+OOBACH	; D6 <-- canal de l'arbre des objets	CALL	_LSTA_BEGIN	; A4 <-- ^lment de base	EX.L	A3,A4		; A3 <-- ^lment pre	LOAD.L	A1,#R16"DRAW$	CALL	SUITEEXEC	; redessine les objets dans la page	POPM.L	D3,D4,D6,A1,A3	RETDRAW$:	CALL	_LSTA_FILS	; objet dans cette page ?	JUMP',NE DEND$		; non => DEND$	CALL	DESSETALL	; redessine l'objetDEND$:	RET;--------------\\; SUITEEDITVISU >;==============/; Dplace la partie visible (si ncessaire) pour que le curseur; soit visible.; in	A4.L	^objet texte; out	-; mod	D7.WSUITEEDITVISU:	PUSH.L	A4	CALL	SUITEOBJCURS	; A4 <-- ^objet o est le curseur	CALL'	SUITEVISU	; dplace v. pour voir le curseur	POP.L	A4	RET;----------\\; SUITEVISU >;----------/; Dplace la partie visible (si ncessaire) pour que le curseur; soit visible.; in	A4.L	^objet texte; out	-; mod	D7.WSUITEVISU:	PUSHM.L	D1..D4	CALL	SUITEIFOBJV	; objet dans cette page ?	JUMP',EQ PAGE$		; oui => PAGE$	CALL	_LSTA_PCSEARCH	; D3/D4 <-- page/calque	LOAD.W	(A6)+OPAGE,D3	LOAD.W	(A6)+OCALQ,D4	CALL	WORKPAGE	; travaille dans une nouvelle page	CALL	WORKCALQUE	; travaille dans un nouveau calque	CALL	SUITEIFDRAW	; indique les objets  dessiner	LOAD.W	D3,#EDITNPPOSCURS	LOAD.W	D1,#opEDITNEXTPREV	CALL	_OBJCALLD	; D3/D4 <-- position du curseur	JUMP,NE EXIT$	CALL	ORDONNE	LOAD.L	D1,D3	LOAD.L	D2,D4		; D1/D2 <-- position du curseur	LOAD.L	D3,(A6)+ODESY1	LOAD.L	D4,(A6)+ODESY2	; D3/D4 <-- partie visible	CALL	_CALCPMILIEU	; D4 <-- milieu de la partie visible	EX.L	D1,D3	EX.L	D2,D4	CALL	_CALCPMILIEU	; D4 <-- milieu du curseur	SUB.W	D2,D1	SUB.W	D4,D2	SWAP.W	D1	SWAP.W	D2	SWAP.W	D4	SUB.W	D2,D1	SUB.W	D4,D2;	SWAP.W	D1;	SWAP.W	D2	SWAP.W	D4	CALL	_CLIPPOS	; D4 <-- position clippe et arrondie	LOAD.L	(A6)+ODESY1,D4	CALL	_CHGCADRE	; met  jour OWDOY2/OWDOX2	INC.W	(A6)+OGDRAW	; il faudra tout redessiner	CALL	DESREFAIT	; refait le dessin	CALL	SUITESETREGLE	; remet la rgle	CALL	_MOVCADRE	; dplace ascenseurs et rgles	JUMP	EXIT$PAGE$:	LOAD.W	D3,#EDITNPPOSCURS	LOAD.W	D1,#opEDITNEXTPREV	CALL	_OBJCALLD	; D3/D4 <-- position du curseur	JUMP,NE EXIT$	CALL	ORDONNE	LOAD.L	D1,D3	LOAD.L	D2,D4		; D1/D2 <-- position du curseur	LOAD.L	D3,(A6)+ODESY1	LOAD.L	D4,(A6)+ODESY2	; D3/D4 <-- partie visible	CALL	_RECTTEST	; D7 <-- nb de points de D1/D2 inclus dans D3/D4	COMP.W	D7,#2		; est-ce que le curseur est entirement visible ?	JUMP,HS EXIT$		; oui => EXIT$	CALL	_CALCPMILIEU	; D4 <-- milieu de la partie visible	EX.L	D1,D3	EX.L	D2,D4	CALL	_CALCPMILIEU	; D4 <-- milieu du curseur	SUB.W	D2,D1	SUB.W	D4,D2	SWAP.W	D1	SWAP.W	D2	SWAP.W	D4	SUB.W	D2,D1	SUB.W	D4,D2;	SWAP.W	D1;	SWAP.W	D2	SWAP.W	D4	CALL	_CLIPPOS	; D4 <-- position clippe et arrondie	CALL	SUITECLRREGLE	; enlve la rgle	LOAD.L	D3,(A6)+ODESY1	LOAD.L	(A6)+ODESY1,D4	CALL	_CHGCADRE	; met  jour OWDOY2/OWDOX2	LOAD.L	D4,D3		; D4 <-- ancienne position	CALL	DEMOBJETS	; dessine les objets	CALL	SUITESETREGLE	; remet la rgle	CALL	_MOVCADRE	; dplace ascenseurs et rglesEXIT$:	POPM.L	D1..D4	RET;------------\\; SUITEIFDRAW >;============/; Indique  tous les objets de la chane s'ils doivent tre dessins; ou pas (s'ils sont dans la page courante).; in	A4.L	^objet texte; out	-; mod	D7.WSUITEIFDRAW:	PUSHM.L	D1,D3,D4,D6,A3,A4	LOAD.W	D3,#EDITNPCLRCURS	LOAD.W	D1,#opEDITNEXTPREV	CALL	_OBJCALLD	; enlve le curseur	LOAD.L	A3,A4	LOAD.W	D3,(A6)+OPAGE	; D3 <-- page visible	LOAD.W	D4,(A6)+OCALQ	; D4 <-- calque visible	LOAD.L	D6,(A6)+OOBACH	; D6 <-- canal de l'arbre des objets	CALL	_LSTA_BEGIN	; A4 <-- ^lment de base	EX.L	A3,A4		; A3 <-- ^lment prePREV$:	CALL	SUITEPREV	; A4 <-- ^objet prcdent	JUMP,EQ PREV$NEXT$:	CLR.W	D4		; D4 <-- dessine	CALL	_LSTA_FILS	; objet dans cette page ?	JUMP',EQ DRAW$		; oui => DRAW$	INC.W	D4		; D4 <-- dessine pasDRAW$:	LOAD.W	D3,#EDITNPNODRAW	LOAD.W	D1,#opEDITNEXTPREV	CALL	_OBJCALLD	; indique  l'objet s'il doit tre dessin	CALL	SUITENEXT	; A4 <-- ^objet suivant	JUMP,EQ NEXT$	POPM.L	D1,D3,D4,D6,A3,A4	RET;-----------\\; SUITEIFDSP >;===========/; Regarde si les autres objets de la chane sont dans la mme page.; in	A3.L	^objet pre (page);	A4.L	^objet texte; out	D7.W	erreur (si rien dans la mme page); mod	D7.WSUITEIFDSP:	PUSHM.L	A2,A4	CALL	SUITEEXIST	; fait partie d'une chane ?	JUMP',NE OTHER$		; non => OTHER$	LOAD.L	A2,A4PREV$:	CALL	SUITEPREV	; A4 <-- ^objet prcdent	JUMP,EQ PREV$NEXT$:	COMP.L	A4,A2	JUMP',EQ FILS$	CALL	_LSTA_FILS	; objet dans cette page ?	JUMP',EQ EXIT$		; oui => EXIT$FILS$:	CALL	SUITENEXT	; A4 <-- ^objet suivant	JUMP,EQ NEXT$OTHER$:	LOAD.W	D7,#1		; D7 <-- rien d'autre dans la mme pageEXIT$:	POPM.L	A2,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; SUITEIFSAME >;============/; Cherche si deux objets font partie de la mme chane.; in	A3.L	^objet 1;	A4.L	^objet 2; out	D7.W	erreur (si chanes diffrentes); mod	D7.WSUITEIFSAME:	PUSH.L	A3	CALL	SUITEEXIST	; fait partie d'une chane ?	JUMP',NE SINGLE$	; non => SINGLE$PREV$:	CALL	SUITEPREV	; A4 <-- ^objet prcdent	JUMP,EQ PREV$NEXT$:	COMP.L	A4,A3		; dans la mme chane ?	JUMP',EQ SAME$		; oui => SAME$	CALL	SUITENEXT	; A4 <-- ^objet suivant	JUMP,EQ NEXT$	JUMP'	DIFF$SINGLE$:	COMP.L	A4,A3		; dans la mme chane ?	JUMP',EQ SAME$		; oui => SAME$DIFF$:	LOAD.W	D7,#1		; D7 <-- autre chane	JUMP'	EXIT$SAME$:	CLR.W	D7		; D7 <-- mme chaneEXIT$:	POP.L	A3	TEST.W	D7		; retour EQ/NE	RET;-------------\\; SUITEOBJCURS >;=============/; Cherche l'objet d'une chane o est le curseur.; in	A4.L	^objet; out	A4.L	^objet o est le curseur; mod	D7.W, A4.LSUITEOBJCURS:	PUSHM.L	D1,D3	CALL	SUITEEXIST	; fait partie d'une chane ?	JUMP',NE EXIT$		; non => EXIT$PREV$:	CALL	SUITEPREV	; A4 <-- ^objet prcdent	JUMP,EQ PREV$NEXT$:	LOAD.W	D3,#EDITNPIFCURS	LOAD.W	D1,#opEDITNEXTPREV	CALL	_OBJCALLD	; curseur dans cet objet ?	JUMP',EQ OK$		; oui => OK$	CALL	SUITENEXT	; A4 <-- ^objet suivant	JUMP,EQ NEXT$	JUMP'	EXIT$OK$:	LOAD.L	(A6)+OSELPS,A4	; OSELPS <-- ^objet slectionnEXIT$:	POPM.L	D1,D3	RET;----------\\; SUITEBBOX >;==========/; Refait les bbox de tous les objets d'une chane.; in	A4.L	^objet; out	-; mod	D7.WSUITEBBOX:	PUSH.L	A1	LOAD.L	A1,#R16"BBOX$	CALL	SUITEEXEC	; refait toutes les bbox	POP.L	A1	RETBBOX$:	PUSHM.L	D1,D3,D4	LOAD.W	D1,#opGETBBOX	CALL	_OBJCALLD	; D3/D4 <-- bounding box	LOAD.L	(A4)+OobjBBOX1,D3	LOAD.L	(A4)+OobjBBOX2,D4	POPM.L	D1,D3,D4	RET;----------\\; SUITEEXEC >;==========/; Excute une routine pour tous les objets d'une chane EDITNEXTPREV.; in	A4.L	^objet;	A1.L	^routine  excuter; out	-; mod	D7.WSUITEEXEC:	PUSH.L	A4	CALL	SUITEEXIST	; fait partie d'une chane ?	JUMP',NE SINGLE$	; non => SINGLE$PREV$:	CALL	SUITEPREV	; A4 <-- ^objet prcdent	JUMP,EQ PREV$NEXT$:	CALL	(A1)		; excute qq chose	CALL	SUITENEXT	; A4 <-- ^objet suivant	JUMP,EQ NEXT$	JUMP'	EXIT$SINGLE$:	CALL	(A1)		; excute qq chose, juste une foisEXIT$:	POP.L	A4	RET;--------------\\; SUITESETREGLE >;==============/; Remet la rgle.; in	-; out	-; mod	D7.WSUITESETREGLE:	PUSHM.L	D1,D3	LOAD.W	D3,#EDITNPSETREGLE	LOAD.W	D1,#opEDITNEXTPREV	CALL	_OBJCALLD	; remet la rgle	POPM.L	D1,D3	RET;--------------\\; SUITECLRREGLE >;==============/; Enlve la rgle.; in	-; out	-; mod	D7.WSUITECLRREGLE:	PUSHM.L	D1,D3	LOAD.W	D3,#EDITNPCLRREGLE	LOAD.W	D1,#opEDITNEXTPREV	CALL	_OBJCALLD	; enlve la rgle	POPM.L	D1,D3	RET;-----------\\; SUITECOULE >;===========/; Fait couler tous les pavs slectionns.; in	-; out	-; mod	D7.WSUITECOULE:	PUSHM.L	A3..A5	LOAD.L	A3,#(A6)+OSSTALOOP$:	TEST.L	(A3)+OSSOBJ	; fin ?	JUMP',EQ EXIT$	TEST.L	(A3)+LSS+OSSOBJ	; fin ?	JUMP',EQ EXIT$	LOAD.L	A4,(A3)+LSS+OSSOBJ	CALL	SUITEOUT	; dfait un lien	LOAD.L	A5,(A3)+OSSOBJ;	LOAD.L	A4,(A3)+LSS+OSSOBJ	CALL	SUITEIN		; fait un lien	LOAD.L	A3,#(A3)+LSS	; A3 <-- ^suivant	JUMP	LOOP$EXIT$:	POPM.L	A3..A5	RET;------------\\; SUITELIBERE >;============/; Libre tous les pavs slectionns.; in	-; out	-; mod	D7.WSUITELIBERE:	PUSHM.L	A3..A5	LOAD.L	A3,#(A6)+OSSTALOOP$:	TEST.L	(A3)+OSSOBJ	; fin ?	JUMP',EQ EXIT$	LOAD.L	A4,(A3)+OSSOBJ	CALL	SUITEOUT	; dfait un lien	LOAD.L	A3,#(A3)+LSS	; A3 <-- ^suivant	JUMP	LOOP$EXIT$:	POPM.L	A3..A5	RET;--------\\; SUITEIN >;========/; Met un objet dans une chane EDITNEXTPREV.; in	A5.L	^objet pre;	A4.L	^objet  ajouter; out	-; mod	D7.WSUITEIN:	PUSHM.L	D1,D3,A1..A5	COMP.L	A4,A5		; deux fois le mme objet ?	JUMP,EQ EXIT$		; oui => EXIT$	LOAD.L	A2,A4		; A2 <-- ^objet  intercaler	LOAD.L	A4,A2	LOAD.W	D3,#EDITNPGNEXT	LOAD.W	D1,#opEDITNEXTPREV	CALL	_OBJCALLD	JUMP,NE EXIT$	LOAD.L	A4,A5;	LOAD.W	D3,#EDITNPGNEXT;	LOAD.W	D1,#opEDITNEXTPREV	CALL	_OBJCALLD	; A3 <-- ^objet suivant	JUMP,NE EXIT$	LOAD.L	A1,A3		; A1 <-- ^objet suivant;	LOAD.L	A4,A5	LOAD.L	A3,A2	LOAD.W	D3,#EDITNPMNEXT;	LOAD.W	D1,#opEDITNEXTPREV	CALL	_OBJCALLD	LOAD.L	A4,A2	LOAD.L	A3,A1;	LOAD.W	D3,#EDITNPMNEXT;	LOAD.W	D1,#opEDITNEXTPREV	CALL	_OBJCALLD;	LOAD.L	A4,A2	LOAD.L	A3,A5	LOAD.W	D3,#EDITNPMPREV;	LOAD.W	D1,#opEDITNEXTPREV	CALL	_OBJCALLD	COMP.L	A1,#0	JUMP',EQ NONEXT$	LOAD.L	A4,A1	LOAD.L	A3,A2;	LOAD.W	D3,#EDITNPMPREV;	LOAD.W	D1,#opEDITNEXTPREV	CALL	_OBJCALLDNONEXT$:	LOAD.L	A4,A2	LOAD.L	A3,A5	LOAD.W	D3,#EDITNPLINK;	LOAD.W	D1,#opEDITNEXTPREV	CALL	_OBJCALLD	; fusionne les textes	LOAD.L	A4,A5	LOAD.W	D3,#EDITNPMODIF;	LOAD.W	D1,#opEDITNEXTPREV	CALL	_OBJCALLD	; indique compltement changEXIT$:	POPM.L	D1,D3,A1..A5	RET;---------\\; SUITEOUT >;=========/; Sort un objet de la chane EDITNEXTPREV.; in	A4.L	^objet; out	A5.L	^objet de la chane d'o l'objet est sorti;	D7.W	erreur; mod	D7.W, A5.LSUITEOUT:	PUSHM.L	D1,D3,A1..A4	LOAD.L	A5,A4		; A5 <-- ^objet central;	LOAD.L	A4,A5	LOAD.W	D3,#EDITNPGNEXT	LOAD.W	D1,#opEDITNEXTPREV	CALL	_OBJCALLD	; A3 <-- ^objet suivant	JUMP,NE EXIT$	LOAD.L	A1,A3		; A1 <-- ^objet suivant	LOAD.L	A4,A5	LOAD.W	D3,#EDITNPGPREV;	LOAD.W	D1,#opEDITNEXTPREV	CALL	_OBJCALLD	; A3 <-- ^objet prcdent	LOAD.L	A2,A3		; A2 <-- ^objet prcdent	LOAD.W	D7,#1		; D7 <-- ne fait pas partie d'une chane !	COMP.L	A1,#0	JUMP',NE LINK$	COMP.L	A2,#0		; au moins un prcdent ou un suivant ?	JUMP,EQ EXIT$		; non => EXIT$LINK$:	COMP.L	A2,#0	JUMP',EQ PREV$	LOAD.L	A4,A2	LOAD.L	A3,A1	LOAD.W	D3,#EDITNPMNEXT;	LOAD.W	D1,#opEDITNEXTPREV	CALL	_OBJCALLDPREV$:	COMP.L	A1,#0	JUMP',EQ NEXT$	LOAD.L	A4,A1	LOAD.L	A3,A2	LOAD.W	D3,#EDITNPMPREV;	LOAD.W	D1,#opEDITNEXTPREV	CALL	_OBJCALLDNEXT$:	LOAD.L	A4,A5	LOAD.L	A3,#0	LOAD.W	D3,#EDITNPMNEXT;	LOAD.W	D1,#opEDITNEXTPREV	CALL	_OBJCALLD;	LOAD.L	A4,A5;	LOAD.L	A3,#0	LOAD.W	D3,#EDITNPMPREV;	LOAD.W	D1,#opEDITNEXTPREV	CALL	_OBJCALLD;	LOAD.L	A4,A5	LOAD.W	D3,#EDITNPUNLINK;	LOAD.W	D1,#opEDITNEXTPREV	CALL	_OBJCALLD	; spare les textes	LOAD.W	D3,#EDITNPMODIF;	LOAD.W	D1,#opEDITNEXTPREV	CALL	_OBJCALLD	; indique compltement chang	LOAD.L	A5,A2		; A5 <-- ^chane d'o l'objet est sorti	COMP.L	A5,#0	JUMP',NE REST$	LOAD.L	A5,A1REST$:	LOAD.L	A4,A5;	LOAD.W	D3,#EDITNPMODIF;	LOAD.W	D1,#opEDITNEXTPREV	CALL	_OBJCALLD	; indique compltement chang	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1,D3,A1..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; SUITEEXIST >;===========/; Regarde si un objet fait partie d'une chane EDITNEXTPREV.; in	A4.L	^objet; out	D7.W	erreur (si pas dans chane); mod	D7.WSUITEEXIST:	PUSHM.L	D1,D3,A3	LOAD.W	D3,#EDITNPGNEXT	LOAD.W	D1,#opEDITNEXTPREV	CALL	_OBJCALLD	; A3 <-- ^objet suivant	JUMP',NE EXIT$	COMP.L	A3,#0		; objet suivant existe ?	JUMP',NE EXIT$		; oui => EXIT$	LOAD.W	D3,#EDITNPGPREV;	LOAD.W	D1,#opEDITNEXTPREV	CALL	_OBJCALLD	; A3 <-- ^objet prcdent	JUMP',NE EXIT$	COMP.L	A3,#0		; objet prcdent existe ?	JUMP',NE EXIT$		; oui => EXIT$	LOAD.W	D7,#1		; D7 <-- ne fait pas partie d'une chaneEXIT$:	POPM.L	D1,D3,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; SUITENEXT >;==========/; Cherche l'objet suivant d'une chane EDITNEXTPREV.; in	A4.L	^objet; out	A4.L	^objet suivant;	D7.W	erreur; mod	D7.W, A4.LSUITENEXT:	PUSHM.L	D1,D3,A3	LOAD.W	D3,#EDITNPGNEXT	LOAD.W	D1,#opEDITNEXTPREV	CALL	_OBJCALLD	; A3 <-- ^objet suivant	JUMP',NE EXIT$	LOAD.W	D7,#1	COMP.L	A3,#0	JUMP',EQ EXIT$	LOAD.L	A4,A3		; A4 <-- ^objet suivant	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1,D3,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; SUITEPREV >;==========/; Cherche l'objet prcdent d'une chane EDITNEXTPREV.; in	A4.L	^objet; out	A4.L	^objet prcdent;	D7.W	erreur; mod	D7.W, A4.LSUITEPREV:	PUSHM.L	D1,D3,A3	LOAD.W	D3,#EDITNPGPREV	LOAD.W	D1,#opEDITNEXTPREV	CALL	_OBJCALLD	; A3 <-- ^objet prcdent	JUMP',NE EXIT$	LOAD.W	D7,#1	COMP.L	A3,#0	JUMP',EQ EXIT$	LOAD.L	A4,A3		; A4 <-- ^objet prcdent	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1,D3,A3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; SUITEIHAND >;===========/; Initialise les paramtres en fonction de la position des; deux premires poignes.; in	-; out	-; mod	D7.WSUITEIHAND:	PUSHM.L	D0..D4,A3	LOAD.L	A3,#(A6)+OSSTA	TEST.L	(A3)+OSSOBJ	; fin ?	JUMP',EQ EXIT$	TEST.L	(A3)+LSS+OSSOBJ	; fin ?	JUMP',EQ EXIT$	LOAD.L	A4,(A3)+OSSOBJ	; A4 <-- ^objet	LOAD.W	D2,(A3)+OSSPOI	; D2 <-- poigne	CALL	SUITEGHAND	; D4 <-- position (y;x)	JUMP',NE EXIT$	LOAD.L	D0,D4		; D0 <-- P0	LOAD.L	A4,(A3)+LSS+OSSOBJ ; A4 <-- ^objet	LOAD.W	D2,(A3)+LSS+OSSPOI ; D2 <-- poigne	CALL	SUITEGHAND	; D4 <-- position (y;x)	JUMP',NE EXIT$	LOAD.L	D1,D4		; D1 <-- P1	LOAD.W	D4,D1	SUB.W	D4,D0	LOAD.W	(A6)+OMOVEX,D4	SWAP.W	D0	SWAP.W	D1	LOAD.W	D4,D1	SUB.W	D4,D0	LOAD.W	(A6)+OMOVEY,D4	SWAP.W	D0	SWAP.W	D1	LOAD.W	D3,(A6)+OMOVEY	SWAP.W	D3	LOAD.W	D3,(A6)+OMOVEX	LIB	?CALCHYPO	LOAD.W	(A6)+OMOVED,D4	LOAD.L	D3,D0	LOAD.L	D4,D1	LOAD.L	D5,D0	ADD.W	D5,(A6)+OMOVED	LIB	?CALCANGLE	COMP.W	D2,#180	JUMP',LS ANG$	SUB.W	D2,#360		; D2 <-- angle ngatifANG$:	LOAD.W	(A6)+OMOVEA,D2EXIT$:	POPM.L	D0..D4,A3	RET;-----------\\; SUITEMHAND >;===========/; Dplace toutes les poignes.; in	-; out	D7.W	erreur; mod	D7.WSUITEMHAND:	PUSHM.L	D2,D3,A2,A3	LOAD.L	A2,#(A6)+OSSTA	; A2 <-- ^dpart  sur 1	LOAD.L	A3,#(A2)+LSS	; A3 <-- ^arrive sur 2	CLR.W	D2		; D2 <-- dpart immobile sur 1	LOAD.W	D3,#LSS		; D3 <-- arrive va sur 2,3,4..	TEST.B	(A6)+OMOVEF+0:#BMOVEREF-8	JUMP',BS LOOP$	LOAD.W	D2,#LSS+LSS	; D2 <-- dpart  va sur 1,3,5..	LOAD.W	D3,D2		; D3 <-- arrive va sur 2,4,6..	TEST.B	(A6)+OMOVEF+0:#BMOVE2-8	JUMP',BS LOOP$	LOAD.W	D2,#LSS		; D2 <-- dpart  va sur 1,2,3..	LOAD.W	D3,D2		; D3 <-- arrive va sur 2,3,4..LOOP$:	CLR.W	D7		; D7 <-- ok	TEST.L	(A2)+OSSOBJ	; fin ?	JUMP',EQ EXIT$	TEST.L	(A3)+OSSOBJ	; fin ?	JUMP',EQ EXIT$	CALL	SUITEXHAND	; dplace une poigne	JUMP',NE EXIT$	ADD.W	A2,D2		; A2 <-- ^suivant	ADD.W	A3,D3		; A3 <-- ^suivant	JUMP	LOOP$EXIT$:	PUSH.W	D7	TEST.W	(A6)+OGDRAW	; faudra-t-il tout redessiner ?	JUMP',EQ REFAIT$	; non => REFAIT$	CALL	DESREFAIT	; refait le dessinREFAIT$:	POP.W	D7	POPM.L	D2,D3,A2,A3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; SUITEXHAND >;-----------/; Dplace une poigne.; in	A2.L	^dpart dans OSSTA; in	A3.L	^arrive dans OSSTA; out	-; mod	D7.WSUITEXHAND:	PUSHM.L	D0..D4,A4	LOAD.L	A4,(A2)+OSSOBJ	; A4 <-- ^objet	LOAD.W	D2,(A2)+OSSPOI	; D2 <-- poigne	CALL	SUITEGHAND	; D4 <-- position (y;x)	JUMP,NE EXIT$	LOAD.L	D0,D4		; D0 <-- P0	LOAD.L	A4,(A3)+OSSOBJ	; A4 <-- ^objet	LOAD.W	D2,(A3)+OSSPOI	; D2 <-- poigne	CALL	SUITEGHAND	; D4 <-- position (y;x)	JUMP,NE EXIT$	LOAD.L	D1,D4		; D1 <-- P1	TEST.B	(A6)+OMOVEF+1:#BMOVEX-0	JUMP',BS MOVEX$	TEST.B	(A6)+OMOVEF+1:#BMOVEY-0	JUMP',BS MOVEY$	TEST.B	(A6)+OMOVEF+1:#BMOVED-0	JUMP',BS LG$	TEST.B	(A6)+OMOVEF+1:#BMOVEA-0	JUMP,BS ANGLE$	LOAD.L	D4,D0	ADD.W	D4,(A6)+OMOVEX	SWAP.W	D4	ADD.W	D4,(A6)+OMOVEY	SWAP.W	D4	JUMP	MOVE$MOVEX$:	LOAD.W	D4,D0	ADD.W	D4,(A6)+OMOVEX	JUMP	MOVE$MOVEY$:	SWAP.W	D0	SWAP.W	D4	LOAD.W	D4,D0	ADD.W	D4,(A6)+OMOVEY	SWAP.W	D4	JUMP	MOVE$LG$:	SUB.W	D1,D0	SWAP.W	D0	SWAP.W	D1	SUB.W	D1,D0	SWAP.W	D0	SWAP.W	D1	LOAD.L	D3,D1	LIB	?CALCHYPO	; D4 <-- longueur actuelle	TEST.W	D4	JUMP',EQ LG8$	LOAD.W	D2,D1	MUL.WA	D2,(A6)+OMOVED	DIV.WA	D2,D4	LOAD.W	D1,D2	SWAP.W	D1	LOAD.W	D2,D1	MUL.WA	D2,(A6)+OMOVED	DIV.WA	D2,D4	LOAD.W	D1,D2	SWAP.W	D1LG8$:	ADD.W	D1,D0	SWAP.W	D0	SWAP.W	D1	ADD.W	D1,D0	SWAP.W	D0	SWAP.W	D1	LOAD.L	D4,D1	JUMP'	MOVE$ANGLE$:	LOAD.L	D3,D1	SUB.W	D3,D0	SWAP.W	D0	SWAP.W	D3	SUB.W	D3,D0	SWAP.W	D0	SWAP.W	D3	LIB	?CALCHYPO	; D4 <-- longueur actuelle	LOAD.W	D2,D4	LOAD.L	D3,D0	LOAD.L	D4,D0	ADD.W	D4,D2	LOAD.W	D1,(A6)+OMOVEA	LIB	?CALCPSYM	; D4 <-- point tourn;	JUMP'	MOVE$MOVE$:	LOAD.W	D7,#1		; D7 <-- hors du dessin	TEST.W	D4	JUMP',NS EXIT$	COMP.W	D4,(A6)+ODESXD	JUMP',GE EXIT$	SWAP.W	D4	TEST.W	D4	JUMP',NS EXIT$	COMP.W	D4,(A6)+ODESYD	JUMP',GE EXIT$	SWAP.W	D4	LOAD.L	A4,(A3)+OSSOBJ	; A4 <-- ^objet	LOAD.W	D2,(A3)+OSSPOI	; D2 <-- poigne	CALL	SUITEPHAND	; dplace la poigneEXIT$:	POPM.L	D0..D4,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; SUITEGHAND >;-----------/; Donne la position d'une poigne d'un objet.; in	A4.L	^objet;	D2.W	poigne (0..n); out	D4.L	nouvelle position (y;x);	D7.W	erreur; mod	D4.L, D7.WSUITEGHAND:	PUSHM.L	D1,D3	LOAD.W	D1,#opHANDGET	CALL	_OBJCALLD	; D3/D4 <-- icne/position	POPM.L	D1,D3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; SUITEPHAND >;-----------/; Dplace une poigne d'un objet.; in	A4.L	^objet;	D2.W	poigne (0..n);	D4.L	nouvelle position (y;x); out	D7.W	erreur; mod	D7.WSUITEPHAND:	PUSHM.L	D1..D4,D6,A3	LOAD.L	D1,D4	TEST.W	D2		; dplace le "cdg" ?	JUMP',EQ MOVE$		; oui => MOVE$	LOAD.L	A3,A4	LOAD.W	D3,(A6)+OPAGE	; D3 <-- page visible	LOAD.W	D4,(A6)+OCALQ	; D4 <-- calque visible	LOAD.L	D6,(A6)+OOBACH	; D6 <-- canal de l'arbre des objets	CALL	_LSTA_BEGIN	; A4 <-- ^lment de base	EX.L	A3,A4		; A3 <-- ^lment pre	CALL	SUITEIFDSP	; suite de la chane dans la mme page ?	JUMP',NE MOVE$		; non => MOVE$	INC.W	(A6)+OGDRAW	; il faudra tout redessinerMOVE$:	TEST.W	(A6)+OGDRAW	; faudra-t-il tout redessiner ?	JUMP',NE CLEAR$		; oui => CLEAR$	CALL	DESCLEAR	; efface l'objetCLEAR$:	CALL	_LSTO_HEXTEND	; tend l'objet	JUMP',NE EXIT$	LOAD.L	D4,D1		; D4 <-- nouvelle position	LOAD.W	D3,#HANDMOVEOPEN	LOAD.W	D1,#opHANDMOVE	CALL	_OBJCALLD	LOAD.W	D3,#HANDMOVEBEGIN	LOAD.W	D1,#opHANDMOVE	CALL	_OBJCALLD	LOAD.W	D3,#HANDMOVEDRAG	LOAD.W	D1,#opHANDMOVE	CALL	_OBJCALLD	LOAD.W	D3,#HANDMOVEEND	LOAD.W	D1,#opHANDMOVE	CALL	_OBJCALLD	LOAD.W	D3,#HANDMOVECLOSE	LOAD.W	D1,#opHANDMOVE	CALL	_OBJCALLD	CALL	_LSTO_HCOMPACT	; compactifie l'objetEXIT$:	PUSH.W	D7	TEST.W	(A6)+OGDRAW	; faudra-t-il tout redessiner ?	JUMP',NE SET$		; oui => SET$	CALL	DESSET		; allume l'objetSET$:	POP.W	D7	POPM.L	D1..D4,D6,A3	TEST.W	D7		; retour EQ/NE	RET;------------\\; SUITESELECT >;============/; Slectionne une poigne d'un objet quelconque.; in	D4.L	position de la souris (y;x)  [obj]; out	A4.L	^objet o est la souris/nil;	D2.W	rang de la poigne (0..n,-1);	D7.W	erreur; mod	D2.L, D7.W, A4.LSUITESELECT:	PUSHM.L	D1,D3,D4,A2	PUSH.L	(A6)+OAPOS	CALL	SUITEDETECT	; A4/D2 <-- ^objet/poigne	LOAD.L	A2,A4	LOAD.W	D1,D2	LOAD.W	D2,#1		; D2 <-- open	CALL	DESISHIFT	; dessine le premier objet	LOAD.W	D2,D1	CALL	SUITESINVP	; allume une poigneLOOP$:	CALL	_SCMO		; remet la souris	LOAD.W	D2,#2		; D2 <-- shift	CALL	DESISHIFT	; fait tourner le traitill	CALL	_WAITMOVES	; attend dplacement ...	JUMP,NE END$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE LOOP$	CALL	_CONVSCROBJ	; D4 <-- position [obj]	JUMP,NE LOOP$	CALL	SUITEDETECT	; A4/D2 <-- ^objet/poigne	COMP.L	A4,A2		; toujours le mme objet ?	JUMP',EQ OBJ$		; oui => OBJ$				; non =>	EX.L	A2,A4	EX.L	D1,D2	PUSH.W	D2	LOAD.W	D2,#3		; D2 <-- close	CALL	DESISHIFT	; efface l'ancien objet	POP.W	D2	CALL	SUITESINVP	; teint l'ancienne poigne	LOAD.L	A4,A2	LOAD.W	D2,#1		; D2 <-- open	CALL	DESISHIFT	; dessine le nouvel objet	LOAD.W	D2,D1	CALL	SUITESINVP	; allume la nouvelle poigne	JUMP	LOOP$OBJ$:	COMP.W	D2,D1		; toujours la mme poigne ?	JUMP,EQ LOOP$		; oui => LOOP$	EX.L	D1,D2	CALL	SUITESINVP	; teint l'ancienne poigne	LOAD.W	D2,D1	CALL	SUITESINVP	; allume la nouvelle poigne	JUMP	LOOP$END$:	LOAD.L	A4,A2	LOAD.W	D2,#3		; D2 <-- close	CALL	DESISHIFT	; efface le dernier objet	LOAD.W	D2,D1	CALL	SUITESINVP	; teint la dernire poigne	CLR.W	D7		; D7 <-- ok	COMP.L	A4,#0	JUMP',NE EXIT$	LOAD.W	D7,#ERPAHANDENDEXIT$:	POP.L	(A6)+OAPOS	POPM.L	D1,D3,D4,A2	TEST.W	D7		; retour EQ/NE	RET;------------\\; SUITEDETECT >;------------/; Dtecte sur quel objet et quelle poigne est la souris.; in	D4.L	position de la souris (y;x)  [obj]; out	A4.L	^objet o est la souris/nil;	D2.W	rang de la poigne (0..n);	D7.W	erreur; mod	D2.L, D7.W, A4.LSUITEDETECT:	PUSHM.L	D0,D1,D3..D6,A2,A3	LOAD.L	D5,D4		; D5 <-- position [obj]	CALL	_CONVOBJSCR	; D4 <-- position [scr]	LOAD.L	D6,D4		; D6 <-- position [scr]	CALL	GETDETM	LOAD.W	D0,D4		; D0 <-- marge de dtection selon chelle	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP,NE NOTFOUND$LOOP$:	CALL	_LSTA_BBOX	; D3/D4 <-- bbox absolue	SUB.W	D3,D0	COMP.W	D5,D3	JUMP',LT NEXT$	ADD.W	D4,D0	COMP.W	D5,D4	JUMP',GE NEXT$	SWAP.W	D3	SWAP.W	D4	LOAD.L	D2,D5	SWAP.W	D2	SUB.W	D3,D0	COMP.W	D2,D3	JUMP',LT NEXT$	ADD.W	D4,D0	COMP.W	D2,D4	JUMP',GE NEXT$	LOAD.L	D4,D6		; D4 <-- position [scr]	CALL	HANDDETECT	; D2 <-- rang de la poigne	JUMP',EQ EXIT$	CLR.W	D2		; D2 <-- poigne "cgd"	LOAD.W	D1,#opEDITICOLIST	CALL	_OBJCALLD	; A2/A3 <-- ^soft-keys/^liste des icnes	JUMP',EQ EXIT$		; si objet ditable => EXIT$NEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$NOTFOUND$:	LOAD.L	A4,#0		; A4 <-- nilEXIT$:	POPM.L	D0,D1,D3..D6,A2,A3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; SUITESINVP >;-----------/; Inverse une poigne.; in	A4.L	^objet;	D2.W	rang de la poigne (0..n); out	-; mod	D7.WSUITESINVP:	PUSHM.L	D1..D4	CALL	WDOOPEN		; dessine dans la swdo	COMP.L	A4,#0		; y a-t-il un objet ?	JUMP',EQ EXIT$		; non => EXIT$	LOAD.W	D1,#opHANDGET	CALL	_OBJCALLD	; D3/D4 <-- icne/position	JUMP',NE EXIT$	LOAD.L	D3,D4		; D3 <-- centre	LOAD.W	D4,#20!2^15	; D4 <-- demi-longueur (+cercle)	LOAD.W	D2,#INVDOT	; D2 <-- mode	CALL	DRCROIX		; inverse une croixEXIT$:	CALL	WDOCLOSE	; fin du dessin dans la swdo	POPM.L	D1..D4	RET;------------\\; SUITESETALL >;============/; Allume tous les objets d'une suite.; in	-; out	-; mod	D7.WSUITESETALL:	PUSHM.L	D2,D4,A3,A4	CALL	WDOOPEN		; dessine dans la swdo	LOAD.L	A3,#(A6)+OSSTA	CLR.W	D4LOOP$:	TEST.L	(A3)+OSSOBJ	; fin ?	JUMP',EQ EXIT$	LOAD.L	A4,(A3)+OSSOBJ	; A4 <-- ^objet	LOAD.W	D2,(A3)+OSSPOI	; D2 <-- poigne	CALL	SUITESETONE	; allume un objet	LOAD.L	A3,#(A3)+LSS	; A3 <-- ^suivant	INC.W	D4		; D4 <-- rang suivant	JUMP	LOOP$EXIT$:	CALL	WDOCLOSE	; fin du dessin dans la swdo	POPM.L	D2,D4,A3,A4	RET;------------\\; SUITECLRALL >;============/; Allume tous les objets d'une suite.; in	-; out	-; mod	D7.WSUITECLRALL:	PUSHM.L	D2,D4,A3,A4	CALL	WDOOPEN		; dessine dans la swdo	LOAD.L	A3,#(A6)+OSSTA	CLR.W	D4LAST$:	TEST.L	(A3)+OSSOBJ	; fin ?	JUMP',EQ LOOP$	LOAD.L	A3,#(A3)+LSS	; A3 <-- ^suivant	INC.W	D4		; D4 <-- rang suivant	JUMP	LAST$LOOP$:	DEC.W	D4		; D4 <-- rang prcdent	JUMP',NS EXIT$	LOAD.L	A3,#(A3)-LSS	; A3 <-- ^prcdent	LOAD.L	A4,(A3)+OSSOBJ	; A4 <-- ^objet	LOAD.W	D2,(A3)+OSSPOI	; D2 <-- poigne	CALL	SUITECLRONE	; teint un objet	JUMP	LOOP$EXIT$:	CALL	WDOCLOSE	; fin du dessin dans la swdo	POPM.L	D2,D4,A3,A4	RET;------------\\; SUITESETONE >;------------/; Allume un objet d'une suite.; in	A4.L	^objet;	D4.W	rang (0..n);	D2.W	poigne (0..n); out	-; mod	D7.WSUITESETONE:	PUSHM.L	D0..D4	CALL	SUITEIFOBJV	; objet dans cette page ?	JUMP',NE EXIT$		; non => EXIT$	LOAD.W	D0,D4		; D0 <-- rang	LOAD.W	D1,#opHANDGET	CALL	_OBJCALLD	; D3/D4 <-- icne/position	JUMP',NE EXIT$	CALL	_LSTA_POS	ADD.W	D4,(A6)+OAPOS+2	SWAP.W	D4	ADD.W	D4,(A6)+OAPOS+0	SWAP.W	D4	LOAD.W	D2,D0		; D2 <-- rang	LOAD.W	D3,D0	ADD.W	D3,#ICOHANDNB	; D3 <-- icne	CALL	HANDSETONE	; allume un numro (poigne)EXIT$:	POPM.L	D0..D4	RET;------------\\; SUITECLRONE >;------------/; Eteint un objet d'une suite.; in	A4.L	^objet;	D4.W	rang (0..n);	D2.W	poigne (0..n); out	-; mod	D7.WSUITECLRONE:	PUSHM.L	D0..D4	CALL	SUITEIFOBJV	; objet dans cette page ?	JUMP',NE EXIT$		; non => EXIT$	LOAD.W	D0,D4		; D0 <-- rang	LOAD.W	D1,#opHANDGET	CALL	_OBJCALLD	; D3/D4 <-- icne/position	JUMP',NE EXIT$	CALL	_LSTA_POS	ADD.W	D4,(A6)+OAPOS+2	SWAP.W	D4	ADD.W	D4,(A6)+OAPOS+0	SWAP.W	D4	LOAD.W	D2,D0		; D2 <-- rang	LOAD.W	D3,D0	ADD.W	D3,#ICOHANDNB	; D3 <-- icne	CALL	HANDCLRONE	; teint un numro (poigne)EXIT$:	POPM.L	D0..D4	RET;--------\\; SUITENB >;========/; Donne le nombre d'objets numrots.; in	-; out	D4.W	nb d'objets numrots; mod	D4.L, D7.WSUITENB:	PUSH.L	A3	LOAD.L	A3,#(A6)+OSSTA	CLR.W	D4LOOP$:	TEST.L	(A3)+OSSOBJ	; fin ?	JUMP',EQ EXIT$	INC.W	D4		; D4 <-- un de plus	LOAD.L	A3,#(A3)+LSS	; A3 <-- ^suivant	JUMP	LOOP$EXIT$:	POP.L	A3	RET;-----------\\; SUITEFLUSH >;===========/; Vide la table des objets de la suite.; in	-; out	-; mod	D7.WSUITEFLUSH:	CLR.L	(A6)+OSSTA+OSSOBJ	RET;---------\\; SUITEADD >;=========/; Ajoute un nouvel objet dans une suite.; in	A4.L	^objet  ajouter;	D2.W	rang de la poigne; out	D7.W	erreur; mod	D7.WSUITEADD:	PUSHM.L	D3,A3	CALL	SUITETEST	; dj contenu dans la suite ?	JUMP',NE EXIT$		; oui => EXIT$	LOAD.L	A3,#(A6)+OSSTA	LOAD.W	D3,#MAXSS-1SRC$:	TEST.L	(A3)+OSSOBJ	; libre ?	JUMP',EQ INS$		; oui => INS$	LOAD.L	A3,#(A3)+LSS	; A3 <-- ^suivant	DECJ.W,NMO D3,SRC$	LOAD.W	D7,#1		; D7 <-- c'est plein	JUMP'	EXIT$INS$:	LOAD.L	(A3)+OSSOBJ,A4	LOAD.W	(A3)+OSSPOI,D2	CLR.L	(A3)+LSS+OSSOBJ	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; SUITETEST >;----------/; Regarde si un objet est dj dans une suite.; in	A4.L	^objet  ajouter;	D2.W	rang de la poigne; out	D7.W	erreur (si dj); mod	D7.WSUITETEST:	PUSH.L	A3	LOAD.L	A3,#(A6)+OSSTA	CLR.W	D7LOOP$:	TEST.L	(A3)+OSSOBJ	; fin ?	JUMP',EQ EXIT$	COMP.L	A4,(A3)+OSSOBJ	JUMP',NE NEXT$	COMP.W	D2,(A3)+OSSPOI	JUMP',EQ EXIST$NEXT$:	LOAD.L	A3,#(A3)+LSS	; A3 <-- ^suivant	JUMP	LOOP$EXIST$:	LOAD.W	D7,#1		; D7 <-- a y est djEXIT$:	POP.L	A3	TEST.W	D7		; retour EQ/NE	RET;------------\\; SUITEIFOBJV >;============/; Vrifie si un objet est visible (dans la bonne page).; in	A4.L	^objet; out	D7.W	erreur (si invisible); mod	D7.WSUITEIFOBJV:	PUSHM.L	D3,D4,D6,A3,A4	LOAD.L	A3,A4	LOAD.W	D3,(A6)+OPAGE	; D3 <-- page visible	LOAD.W	D4,(A6)+OCALQ	; D4 <-- calque visible	LOAD.L	D6,(A6)+OOBACH	; D6 <-- canal de l'arbre des objets	CALL	_LSTA_BEGIN	; A4 <-- ^lment de base	EX.L	A3,A4		; A3 <-- ^lment pre	CALL	_LSTA_FILS	; objet dans cette page ?	POPM.L	D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET	.END