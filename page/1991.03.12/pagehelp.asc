	.TITLE	PAGEHELP.ASC;	--------------------------------------;		(C) 1990 - Daniel Roux;	--------------------------------------;	Source du fichier PAGE_F.HELP	.PROC	M680002	.RADIX	10.	.HEX	.REF	SMAKY	.REF	PAGE; Commandes places dans les textes; ---------------------------------; <-1>	passe alternativement de roman <--> bold; <-2>	remplac par "l'objet slectionn" ou "les N objets slectionns"; <-3>	remplac par "a" si N=1 et par "ont" si N>1; <-4>	passe alternativement de normal <--> inverse	.LOC	0	.W	0,0,0,0	.W	TABLE$	.W	0TABLE$:	.W	ICOOCRAYON	.ASCII	"<-4> OUTIL <-4><CR>"	.ASCII	"<CR>"	.ASCII	"Le <-1>crayon<-1> dessine un <-1>nouvel objet<-1>, tant que<CR>"	.ASCII	"le bouton de gauche est maintenu press.<CR>"	.B	0	.EVEN	.W	ICOOLOUPE	.ASCII	"<-4> OUTIL <-4><CR>"	.ASCII	"<CR>"	.ASCII	"La <-1>loupe agrandit<-1> ou <-1>diminue<-1> l'endroit cliqu avec<CR>"	.ASCII	"le bouton de gauche.<CR>"	.ASCII	"<CR>"	.ASCII	"Si un rectangle est dessin en maintenant press<CR>"	.ASCII	"le bouton de gauche, c'est cette partie qui sera<CR>"	.ASCII	"agrandie !<CR>"	.B	0	.EVEN	.W	ICOOMAIN	.ASCII	"<-4> OUTIL <-4><CR>"	.ASCII	"<CR>"	.ASCII	"La <-1>main glisse<-1> la partie de la page visible,<CR>"	.ASCII	"tant que le bouton de gauche est maintenu press.<CR>"	.B	0	.EVEN	.W	ICOOEDIT	.ASCII	"<-4> OUTIL <-4><CR>"	.ASCII	"<CR>"	.ASCII	"Permet d'<-1>diter<-1> le contenu de l'objet<CR>"	.ASCII	"montr avec le bouton de gauche.<CR>"	.B	0	.EVEN	.W	ICOOFLECHE	.ASCII	"<-4> OUTIL <-4><CR>"	.ASCII	"<CR>"	.ASCII	"Permet de <-1>dplacer les poignes<-1>.<CR>"	.B	0	.EVEN	.W	ICOOOPER	.ASCII	"<-4> OUTIL <-4><CR>"	.ASCII	"<CR>"	.ASCII	"Permet de <-1>zoomer<-1>, <-1>tourner<-1> ou <-1>dformer<-1><CR>"	.ASCII	"<-2>.<CR>"	.B	0	.EVEN	.W	ICOOSUITE	.ASCII	"<-4> OUTIL <-4><CR>"	.ASCII	"<CR>"	.ASCII	"Les objets cliqus avec le bouton de gauche seront<CR>"	.ASCII	"numrots (de 1  32). Il sera ensuite possible<CR>"	.AS