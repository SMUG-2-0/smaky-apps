	.SBTTL	OPIMAGDBOX.ASI;----------\\; DBOXPREND >;==========/; Edite un nom d'image en entre (prend).; in	A4.L	^objet image; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXPREND:	PUSHM.L	D1,D2,D4,D5,A1..A5	LOAD.L	A1,A4		; A1 <-- ^objet	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX		; prpare l'ouverture de la DBOX	CLR.L	D4		; D4 <-- fanions	LOAD.B	D1,(A1)+OOBFIM	TEST.L	D1:#BIMSCAN	JUMP',BC 20$	TSET.L	D4:#1520$:	TEST.L	D1:#BIMINS	JUMP',BC 21$	TSET.L	D4:#1421$:	TEST.L	D1:#BIMLINK	JUMP',BC 22$	TSET.L	D4:#1322$:	LOAD.L	A5,#(A1)+OOBFIL	; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IOIM	LOAD.L	A4,#R16"TEXIM$	; A4 <-- ^critre de recherche (extension)	LOAD.L	A2,#R16"TDBOX_PREND	LOAD.W	D1,#DBOX_PREND	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXTM!2^BDBIOOBJ	LOAD.W	D7,#DB_POS5	PAGE_	DBOX		; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX		; prpare la fermeture de la DBOX	POP.W	D7	COMP.W	D3,#F1	JUMP',NE EXIT$	CLR.B	D1	TEST.L	D4:#14	JUMP',BC 40$	TSET.L	D1:#BIMINS40$:	TEST.L	D4:#13	JUMP',BC 41$	TSET.L	D1:#BIMLINK41$:	TEST.L	D4:#15	JUMP',BC 42$	TSET.L	D1:#BIMSCAN	TSET.L	D1:#BIMINS	TCLR.L	D1:#BIMLINK42$:	LOAD.B	(A1)+OOBFIM,D1	LOAD.B	(A0)+OFIM,D1EXIT$:	POPM.L	D1,D2,D4,D5,A1..A5	TEST.W	D7		; retour EQ/NE	RETTEXIM$:	.ASCIZ	"-"	.ASCIZ	".IMAGE"	.ASCIZ	".IMAGE"	.B	0TDBOX_PREND:	.B	LDBOX_PREND	.B	ODBLCIRCLE,14!2^7,0,1	.ASCIZ	" incruste l'image dans PAGE"	.B	ODBCR	.B	ODBLCIRCLE,13!2^7,0,1	.ASCIZ	" lien avec le fichier image"	.B	ODBCR,ODBCR2	.B	ODBSQUARE,15!2^7,0,1	.ASCIZ	" saisie avec le scanner (ScanMan)"	.B	ODBCRLDBOX_PREND = .-TDBOX_PREND-1	.EVENTDBOX_IOIM:	.ASCIZ	"PAGE"		; nom du logiciel	.ASCIZ	"Fimage"	; [M,F] nom des lments manipuls	.ASCIZ	""		; [M,F] nom du contenant	.B	0	.EVEN;---------\\; DBOXZOOM >;=========/; Demande le facteur de zoom.; in	A4.L	^objet; out	D3.W	dernire touche (F1/F0);	D2.L	nouvelles dimensions (dy;dx);	D7.W	rponse; mod	D2.L, D3.L, D7.WDBOXZOOM:	PUSHM.L	D0,D1,D4,D5,A1..A4	LOAD.W	D7,#DR_GETRESOL	PAGE_	DRAW		; D3 <-- facteurs d'chelle (P2;P1)	JUMP,NE EXIT$	LOAD.L	D0,D3		; D0 <-- rsolution	LOAD.W	D2,(A4)+OOBP3+2	SUB.W	D2,(A4)+OOBP1+2	JUMP',NC INIT2$	NEG.W	D2INIT2$:	MUL.WU	D2,D0	SWAP.W	D0	CLR.L	D1	LOAD.W	D1,D0	SR.W	D1,#1	ADD.L	D2,D1	DIV.WU	D2,D0	SWAP.W	D0	LOAD.W	D1,(A4)+OOBDIM+2	SR.W	D1,#1	ADD.W	D2,D1	AND.L	D2,#H'FFFF	DIV.WU	D2,(A4)+OOBDIM+2	TEST.W	D2	JUMP',NE INIT4$	INC.W	D2INIT4$:	COMP.W	D2,#8	JUMP',LS INIT5$	LOAD.W	D2,#8INIT5$:	CLR.L	D4	TSET.L	D4:D2	LOAD.L	A2,#R16"TDBOX_ZOOM	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.W	D7,#DB_OPEN	PAGE_	DBOX		; ouvre la DBOX	JUMP,NE EXIT$LOOP$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_ZOOM	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP',EQ ZOOM$	COMP.W	D3,#F0	JUMP',EQ CANCEL$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$ZOOM$:	LOAD.W	D1,#-1ZOOM2$:	INC.W	D1		; D1 <-- zoom (1..8)	RR.L	D4,#1	JUMP,CC ZOOM2$	LOAD.W	(A0)+OZOOM,D1	; OZOOM <-- zoom par dfaut (1..8)	SWAP.W	D0	MUL.WU	D1,D0	SWAP.W	D0	LOAD.W	D2,(A4)+OOBDIM+0	MUL.WU	D2,D1	DIV.WU	D2,D0	SWAP.W	D2	LOAD.W	D4,(A4)+OOBDIM+2	MUL.WU	D4,D1	DIV.WU	D4,D0	LOAD.W	D2,D4CANCEL$:	LOAD.W	D7,#DB_CLOSE	PAGE_	DBOX		; ferme la DBOXEXIT$:	POPM.L	D0,D1,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_ZOOM:	.W	10$-TDBOX_ZOOM	.W	20$-TDBOX_ZOOM	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Zoom de l'image en fonction"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"de l'imprimante :"	.B	ODBCR,ODBCR	.B	ODBLCIRCLE,1	.ASCIZ	" x 1"	.B	ODBTABX,12	.B	ODBLCIRCLE,5	.ASCIZ	" x 5"	.B	ODBCR	.B	ODBLCIRCLE,2	.ASCIZ	" x 2"	.B	ODBTABX,12	.B	ODBLCIRCLE,6	.ASCIZ	" x 6"	.B	ODBCR	.B	ODBLCIRCLE,3	.ASCIZ	" x 3"	.B	ODBTABX,12	.B	ODBLCIRCLE,7	.ASCIZ	" x 7"	.B	ODBCR	.B	ODBLCIRCLE,4	.ASCIZ	" x 4"	.B	ODBTABX,12	.B	ODBLCIRCLE,8	.ASCIZ	" x 8"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	"  ZOOM  "	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Zoom"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_ZOOM:	.W	F1,F2,F3,CR,0		DOKF1-TKEY_ZOOM	.W	F0,F13,F14,F15,0	DOKF0-TKEY_ZOOM	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_ZOOM	.W	0;--------\\; DOK...  >;========/DOKMGR:	LOAD.W	D3,#KEYMGR	RETDOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RET	.END