	.SBTTL	PAGEEXT.ASI; En-tte du module LIB interne; -----------------------------BMPAGE:	PAGE_	FIRST		; code du premier appel	PAGE_	LAST		; code du dernier appel	.B	0		; nombre d'installations	.FILLB	OHLREV-(.-BMPAGE),0	.B	1,0		; rvision.version	.W	0,0		; longueur	.W	(PATHLIB&H'FFFF0000)/H'10000 ; pattern de dbut	.W	PATHLIB&H'FFFF	; pattern de dbut	.FILLB	OHLNAM-(.-BMPAGE),0	.ASCII	"PAGE"		; nom du module	.FILLB	LGHLIB-(.-BMPAGE),0	.W	_PAGE_OBJCALL-BMPAGE	.W	_PAGE_DEF-BMPAGE	.W	_PAGE_DRAW-BMPAGE	.W	_PAGE_DBOX-BMPAGE	.W	_PAGE_MISC-BMPAGE	.W	_PAGE_MATH-BMPAGE	.W	_PAGE_IO-BMPAGE;--------------\\; _PAGE_OBJCALL >;==============/; in	D0.W	identificateur du module-objet;	D1.W	mthode;	+	selon mthode; out	+	selon mthode;	D7.W	erreur; mod	D7.W, +_PAGE_OBJCALL:	JUMP	_OBJCALL;----------\\; _PAGE_DEF >;==========/; in	D7.W	sous-appel;	+	selon appel; out	+	selon appel;	D7.W	erreur; mod	D7.W, +_PAGE_DEF:	COMP.W	D7,#DF_SEARCH	JUMP,EQ _DFSEARCH	COMP.W	D7,#DF_GETULIST	JUMP,EQ _DFGETULIST	LOAD.W	D7,#1		; D7 <-- erreur	RET;-----------\\; _PAGE_DRAW >;===========/; in	D7.W	sous-appel;	+	selon appel; out	+	selon appel;	D7.W	erreur; mod	D7.W, +_PAGE_DRAW:	COMP.W	D7,#DR_CHARQ	JUMP,EQ DRCHARQ	COMP.W	D7,#DR_LINE	JUMP,EQ DRLINE	COMP.W	D7,#DR_LINEM	JUMP,EQ DRLINEM	COMP.W	D7,#DR_TRAME	JUMP,EQ DRTRAME	COMP.W	D7,#DR_CROIX	JUMP,EQ DRCROIX	COMP.W	D7,#DR_CIRCLE	JUMP,EQ DRCIRCLE	COMP.W	D7,#DR_BEZIER	JUMP,EQ DRBEZIER	COMP.W	D7,#DR_RECTHV	JUMP,EQ DRRECTHV	COMP.W	D7,#DR_POLYOPEN	JUMP,EQ DRPOLYOPEN	COMP.W	D7,#DR_POLYLINE	JUMP,EQ DRPOLYLINE	COMP.W	D7,#DR_POLYCLOSE	JUMP,EQ DRPOLYCLOSE	COMP.W	D7,#DR_POLYBEZIER	JUMP,EQ DRPOLYBEZIER	COMP.W	D7,#DR_GETPGC	JUMP,EQ DRGETPGC	COMP.W	D7,#DR_CHAR	JUMP,EQ DRCHAR	COMP.W	D7,#DR_BMOPEN	JUMP,EQ DRBMOPEN	COMP.W	D7,#DR_BMCLOSE	JUMP,EQ DRBMCLOSE	COMP.W	D7,#DR_BMUPDALL	JUMP,EQ DRBMUPDALL	COMP.W	D7,#DR_BMBBOX	JUMP,EQ DRBMBBOX	COMP.W	D7,#DR_BMOPENDIM	JUMP,EQ DRBMOPENDIM	COMP.W	D7,#DR_SCOPENPLY	JUMP,EQ DRSCOPENPLY	COMP.W	D7,#DR_SCCLOSE	JUMP,EQ DRSCCLOSE	COMP.W	D7,#DR_BMOPENPLY	JUMP,EQ DRBMOPENPLY	COMP.W	D7,#DR_BMVISUPLY	JUMP,EQ DRBMVISUPLY	COMP.W	D7,#DR_BMOPENMODE	JUMP,EQ DRBMOPENMODE	COMP.W	D7,#DR_PUTICO	JUMP,EQ DRPUTICO	COMP.W	D7,#DR_WDOOPEN	JUMP,EQ WDOOPEN	COMP.W	D7,#DR_WDOCLOSE	JUMP,EQ WDOCLOSE	COMP.W	D7,#DR_WDOUOPEN	JUMP,EQ WDOUOPEN	COMP.W	D7,#DR_WDOUCLOSE	JUMP,EQ WDOUCLOSE	COMP.W	D7,#DR_COLORDEF	JUMP,EQ DRCOLORDEF	COMP.W	D7,#DR_COLORINIT	JUMP,EQ DRCOLORINIT	COMP.W	D7,#DR_GETOFTRAME	JUMP,EQ GETOFTRAME	COMP.W	D7,#DR_GETPRINT	JUMP,EQ GETPRINT	COMP.W	D7,#DR_GETRESOL	JUMP,EQ GETRESOL	COMP.W	D7,#DR_GETCOL	JUMP,EQ GETCOL	COMP.W	D7,#DR_GETDETM	JUMP,EQ GETDETM	COMP.W	D7,#DR_GETOPER	JUMP,EQ GETOPER	COMP.W	D7,#DR_GETPAGE	JUMP,EQ GETPAGE	COMP.W	D7,#DR_GETSCALE	JUMP,EQ GETSCALE	COMP.W	D7,#DR_PUTSCALE	JUMP,EQ PUTSCALE	COMP.W	D7,#DR_CHGSCALE	JUMP,EQ CHGSCALE	LOAD.W	D7,#1		; D7 <-- erreur	RET;-----------\\; _PAGE_DBOX >;===========/; in	D7.W	sous-appel;	+	selon appel; out	+	selon appel;	D7.W	erreur; mod	D7.W, +_PAGE_DBOX:	COMP.W	D7,#DB_OPEN	JUMP,EQ DBOXOPEN	COMP.W	D7,#DB_OPEN1	JUMP,EQ DBOXOPEN1	COMP.W	D7,#DB_CLOSE	JUMP,EQ DBOXCLOSE	COMP.W	D7,#DB_CLOSE1	JUMP,EQ DBOXCLOSE1	COMP.W	D7,#DB_POS5	JUMP,EQ DBOXPOS5	COMP.W	D7,#DB_POS3	JUMP,EQ DBOXPOS3	COMP.W	D7,#DB_ZEROCR	JUMP,EQ ZEROCR	COMP.W	D7,#DB_ERCALL	JUMP,EQ ERCALL	COMP.W	D7,#DB_MEMPT	JUMP,EQ DBOXMEMPT	COMP.W	D7,#DB_MEDIT	JUMP,EQ DBOXMEDIT	COMP.W	D7,#DB_AFF	JUMP,EQ DBOXAFF	COMP.W	D7,#DB_GET	JUMP,EQ DBOXGET	COMP.W	D7,#DB_PUT	JUMP,EQ DBOXPUT	COMP.W	D7,#DB_CLIC	JUMP,EQ DBOXCLIC	COMP.W	D7,#DB_MEMAFC	JUMP,EQ DBOXMEMAFC	COMP.W	D7,#DB_HLINE	JUMP,EQ DBOXHLINE	COMP.W	D7,#DB_RSK	JUMP,EQ DBOXRSK	COMP.W	D7,#DB_IMALOAD	JUMP,EQ DBOXIMALOAD	COMP.W	D7,#DB_IMASHOW	JUMP,EQ DBOXIMASHOW	COMP.W	D7,#DB_IMAKILL	JUMP,EQ DBOXIMAKILL	LOAD.W	D7,#1		; D7 <-- erreur	RET;-----------\\; _PAGE_MISC >;===========/; in	D7.W	sous-appel;	+	selon appel; out	+	selon appel;	D7.W	erreur; mod	D7.W, +_PAGE_MISC:	COMP.W	D7,#MI_CCMO	JUMP,EQ _CCMO	COMP.W	D7,#MI_SCMO	JUMP,EQ _SCMO	COMP.W	D7,#MI_WAITMOUSE	JUMP,EQ _WAITMOUSE	COMP.W	D7,#MI_NORMMOUSE	JUMP,EQ _NORMMOUSE	COMP.W	D7,#MI_MMENUS	JUMP,EQ _MMENUS	COMP.W	D7,#MI_WAITEVENT	JUMP,EQ _WAITEVENT	COMP.W	D7,#MI_TESTEVENT	JUMP,EQ _TESTEVENT	COMP.W	D7,#MI_PUTUNUM	JUMP,EQ _PUTUNUM	COMP.W	D7,#MI_GETUNUM	JUMP,EQ _GETUNUM	COMP.W	D7,#MI_PUTANUM	JUMP,EQ _PUTANUM	COMP.W	D7,#MI_GETANUM	JUMP,EQ _GETANUM	COMP.W	D7,#MI_OBJCALLD	JUMP,EQ _OBJCALLD	COMP.W	D7,#MI_GETDATA	JUMP,EQ GETDATA	COMP.W	D7,#MI_GETROOT	JUMP,EQ GETROOT	COMP.W	D7,#MI_EDITVISU	JUMP,EQ SUITEEDITVISU	LOAD.W	D7,#1		; D7 <-- erreur	RET;-----------\\; _PAGE_MATH >;===========/; in	D7.W	sous-appel;	+	selon appel; out	+	selon appel;	D7.W	erreur; mod	D7.W, +_PAGE_MATH:	COMP.W	D7,#MA_FIXMUL	JUMP,EQ _FIXMUL	COMP.W	D7,#MA_FIXDIV	JUMP,EQ _FIXDIV	COMP.W	D7,#MA_INTMUL32	JUMP,EQ _INTMUL32	COMP.W	D7,#MA_INTDIV32	JUMP,EQ _INTDIV32	COMP.W	D7,#MA_DETLINE	JUMP,EQ _DETLINE	COMP.W	D7,#MA_DETBEZIER	JUMP,EQ DETBEZIER	COMP.W	D7,#MA_SCALEP	JUMP,EQ _SCALEP	COMP.W	D7,#MA_SCALEN	JUMP,EQ _SCALEN	COMP.W	D7,#MA_OBJDRAW	JUMP,EQ _CONVOBJDRAW	COMP.W	D7,#MA_OBJSCR	JUMP,EQ _CONVOBJSCR	COMP.W	D7,#MA_SCROBJ	JUMP,EQ _CONVSCROBJ	COMP.W	D7,#MA_RECTOR	JUMP,EQ _RECTOR	COMP.W	D7,#MA_RECTAND	JUMP,EQ _RECTAND	COMP.W	D7,#MA_RECTTEST	JUMP,EQ _RECTTEST	COMP.W	D7,#MA_BBOXBEZIER	JUMP,EQ BBOXBEZIER	LOAD.W	D7,#1		; D7 <-- erreur	RET;---------\\; _PAGE_IO >;=========/; in	D7.W	sous-appel;	+	selon appel; out	+	selon appel;	D7.W	erreur; mod	D7.W, +_PAGE_IO:	COMP.W	D7,#IO_RDOPEN	JUMP,EQ _RDOPEN	COMP.W	D7,#IO_RDCLOSE	JUMP,EQ _RDCLOSEX	COMP.W	D7,#IO_RDONE	JUMP,EQ _RDONE	COMP.W	D7,#IO_RDMANY	JUMP,EQ _RDMANY	COMP.W	D7,#IO_WROPEN	JUMP,EQ _WROPEN	COMP.W	D7,#IO_WRCLOSE	JUMP,EQ _WRCLOSEX	COMP.W	D7,#IO_WRONE	JUMP,EQ _WRONE	COMP.W	D7,#IO_WRMANY	JUMP,EQ _WRMANY	COMP.W	D7,#IO_WRASSFILE	JUMP,EQ _WRASSFILE	COMP.W	D7,#IO_DICOLOAD	JUMP,EQ _DICOLOAD	COMP.W	D7,#IO_DICOSTATUS	JUMP,EQ _DICOSTATUS	COMP.W	D7,#IO_MESSGETPT	JUMP,EQ MESSGETPT	LOAD.W	D7,#1		; D7 <-- erreur	RET;--------\\; GETDATA >;--------/; Cherche le data d'un objet.; in	A4.L	^racine d'un objet; out	A4.L	^data de l'objet; mod	D7.W, A4.LGETDATA:	LOAD.L	A4,(A4)+OobjPDATA ; A4 <-- ^data de l'objet	CLR.W	D7		; retour EQ	RET;--------\\; GETROOT >;--------/; Cherche la racine du dernier objet utilis.; in	-; out	A4.L	^racine de l'objet; mod	D7.W, A4.LGETROOT:	LOAD.L	A4,(A6)+OROOT	; A4 <-- ^racine de l'objet	CLR.W	D7		; retour EQ	RET;--------\\; GETPAGE >;========/; Donne le numro de la page courante.; in	-; out	D4.W	numro de la page (0..n); mod	D4.L, D7.WGETPAGE:	LOAD.W	D4,(A6)+OPAGE	; D4 <-- page courante	CLR.W	D7		; retour EQ	RET	.END