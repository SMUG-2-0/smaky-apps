	.CHAP	OPFORMSYMB.ASI;	----------------------------------------;		(C) 1990 - Pierre Arnaud;	----------------------------------------;	Source de la partie "symboles" de l'objet GRA_FORM.OPAGE;	SYMBCHOIX,	effectue une insertion suite  un choix;	SYMBINSERT,	insre un symbole dans le texte;	SYMBXFERPG,	 appeler sur un lment qui vient d'tre charg ou copi;	SYMBKILLPG,	libre la mmoire des buffers pour poignes;	SYMBREDOPG,	refait tous les calculs;	SYMBINITPG,	initialise toutes les poignes;	INITPG,		initialise une demi poigne;	SYMBINITSIZE,	initialise la taille;	SYMBDRAW,	dessine un symbole;	SYMBTXTSIZE,	cherche la taille d'un pav de texte;	SYMBGETSIZE,	cherche la taille d'une formule;	SYMBSKIP,	saute un symbole + pavs associs;	SYMBSKIPONE,	saute un lment;	SYMBGETDESC,	rend le descripteur;	Date      Rv	Commentaire;	-------------------------------------------------------------------------------;	10/04/90  0.0	Dbut des travaux;	-------------------------------------------------------------------------------		.APC	PCVAR		.LOC	0;	Un symbole complexe est dfini dans le buffer "texte" de la;	faon suivante :OTSYID:		.BLK.8	1			; identification "symbole"OTSYNUM:	.BLK.8	1			; numro du symbole complexeOTSYPPG:	.BLK.32	1			; ^liste des poignesOTSYDX:		.BLK.16	1			; largeur totale de la formuleOTSYH1:		.BLK.16	1			; hauteur au-dessus de la baseOTSYH2:		.BLK.16	1			; hauteur au-dessous de la baseOTSYEND:	.BLK.8	2			; identification "fin de symbole"LTSY:SYBACK		= -APC				; distance  parcourir;	Si un ou plusieurs pavs de texte sont ncessaires, ils suivent;	simplement spars par des <CR>. Le terminateur <0><0> indique la;	fin extrme du buffer  ne pas dpasser.;	Les poignes une fois calcules sont reprsentes par des coordonnes [y;x];	avec x un entier positif et y positif/ngatif (ngatif=dessus)		.APC	PCCODE;------------\\;  SYMBCHOIX  >;============/; Choisit ce qu'il faut insrer en fonction du choix effectu dans la palette.; in	D2.16	choix de la palette;	A4.32	^instance; out	D7.16; mod	D7.16SYMBCHOIX:	PUSHM.32 D0..D4|A1..A4	MOVE.32	A4,A1				; A1 <-- ^instance	MOVE.32	{A5}+OCANRES,A2	MOVE.32	#RtypFORLINK,D0	CLR.32	D1	MOVE.16	D2,D1				; D1 <-- numro du lien	MOVE.32	#2**BRSGETSIZE+2**BRSGETPOINTER+2**BRSGETnoHAND,D2	RES_	GET	JUMP,NE	R8^ERR$	TEST.16	D4	JUMP,EQ	R8^ERR$	EX.32	A4,A1				; A1 <-- ^ insrer / A4 <-- ^instance	CALL	TXTINSFREE			; insre de la place libre	JUMP,NE	R8^ERR$	MOVE.32	{A4}+OOBPTXT,A2	ADD.32	{A4}+OOBPOC,A2	COMP.8	#tfSYMBBEGIN,{A1}		; symbole ?	JUMP,NE	R8^STR$	ADD.32	#LTSY,{A4}+OOBPOC	JUMP	R8^BEGIN$STR$:	ADD.32	D4,{A4}+OOBPOCBEGIN$:	SR.16	#1,D4	DEC.16	D4DO$:	MOVE.16	{A1+},{A2+}			; copie l'lment	DJ.16,NMO D4,DO$	CLR.16	{A4}+OOBINIPG			; initialise les poignesERR$:	POPM.32	D0..D4|A1..A4	TEST.16	D7	RET;-------------\\;  SYMBINSERT  >;=============/; Insre un symbole juste avant le curseur... Ce qui fait que le curseur; avance et se trouve juste aprs le symbole insr; in	A4.32	^instance;	D3.16	numro du symbole (0..255); out	D7.16	ok/erreur; mod	D7.16SYMBINSERT:	PUSHM.32 D1|D3|D4|A0|A1|A2|A3|A4	MOVE.16	#ERPAILOP,D7	COMP.16	{A5}+ONBFORDEF,D3		; cherche si existe	JUMP,GT	R8^ERR$	CLR.16	D7	MOVE.32	A5,A0				; A0 <- canal	MOVE.32	A4,A2				; A2 <- ^instance	MOVE.8	D3,D1	CALL	SYMBGETDESC			; A1 <- descripteur du symbole	MOVE.32	#MTYPCP,D1	CLR.32	D4	MOVE.8	{A1}+OSYDEFNBP,D4		; D4 <- nombre de poignes	SL.32	#2,D4				; D4 <- taille ncessaire	GESMEM	?GETMEM				; A4 <- ^mmoire pour stocker les poignes	JUMP,NE	R8^ERR$	GESMEM	?CLEARMEM			; A2 <- ^zone pour poignes	EX.32	A4,A2				; A4 <- ^instance	MOVE.32	{A4}+OOBPTXT,A3	ADD.32	{A4}+OOBPOC,A3			; A3 <- ^position d'insertion	MOVE.32	#LTSY,D4	CALL	TXTINSFREE			; insre de la place	JUMP,NE	R8^ERR$	MOVE.8	#tfSYMBBEGIN,{A3}+OTSYID	; id d'un symbole	MOVE.8	#tfSYMBEND,{A3}+OTSYEND		; id de la fin du symbole	MOVE.8	D3,{A3}+OTSYNUM			; numro du symbole	MOVE.32	A2,{A3}+OTSYPPG			; ^poignes	CALL	SYMBINITPG			; initialise les poignes	CALL	SYMBINITSIZE			; initialise la taille du symboleERR$:	POPM.32	D1|D3|D4|A0|A1|A2|A3|A4	TEST.16	D7	RET;-------------\\;  SYMBXFERPG  >;=============/; Invalide les pointeurs mmoire des poignes (aprs un "prend" et "xfer"); in	A5.32	^variables locales;	A4.32	^instance; out	-; mod	D7.16SYMBXFERPG:	PUSHM.32 D3|A3	CLR.16	D7	MOVE.32	{A4}+OOBPTXT,A3DO$:	MOVE.16	{A3+},D3			; cherche lment	JUMP,EQ	R8^ERR$	SWAP.16	D3	COMP.8	#tfSYMBBEGIN,D3	JUMP,NE	R8^DO$	CLR.32	{A3}				; met  zro le pointeur	ADD.32	#LTSY-2,A3	JUMP	R8^DO$ERR$:	POPM.32	D3|A3	TEST.16	D7	RET;-------------\\;  SYMBKILLPG  >;=============/; Rend la mmoire de tous les symboles.; in	A5.32	^variables locales;	A4.32	^instance; out	-; mod	D7.16SYMBKILLPG:	PUSHM.32 D1|D3|A3|A4	CLR.16	D7	MOVE.32	{A4}+OOBPTXT,A3	MOVE.32	#MTYPCP,D1DO$:	MOVE.16	{A3+},D3			; cherche lment	JUMP,EQ	R8^ERR$	SWAP.16	D3	COMP.8	#tfSYMBBEGIN,D3	JUMP,NE	R8^DO$	MOVE.32	{A3},A4				; A4 <-- ^mmoire	COMP.32	#0,A4	JUMP,EQ	R8^OK$	GESMEM	?GIVMEM				; libre la mmoireOK$:	CLR.32	{A3}				; met  zro le pointeur	ADD.32	#LTSY-2,A3	JUMP	R8^DO$ERR$:	POPM.32	D1|D3|A3|A4	TEST.16	D7	RET;-------------\\;  SYMBREDOPG  >;=============/; Refait le calcul des poignes & taille de tous les lments; in	A5.32	^variables locales;	A4.32	^instance; out	-; mod	D7.16SYMBREDOPG:	PUSHM.32 D3|A2|A3	CLR.16	D7	MOVE.32	{A4}+OOBPTXT,A3DO$:	MOVE.16	{A3+},D3			; cherche lment	JUMP,EQ	R8^ERR$	SWAP.16	D3	COMP.8	#tfSYMBBEGIN,D3	JUMP,NE	R8^DO$	SUB.32	#2,A3				; dfait le {A3+} effectu	MOVE.32	A3,A2	CALL	SYMBfilsREDO			; initialise les fils d'abord	EX.32	A2,A3				; A3 <-- dbut de la formule	CALL	SYMBINITPG			; initialise les poignes	CALL	SYMBINITSIZE			; initialise la taille	EX.32	A2,A3				; A3 <-- ^suite	JUMP	R8^DO$ERR$:	POPM.32	D3|A2|A3	TEST.16	D7	RET;-------------\\;  SYMBINITPG  >;=============/; Initialise les poignes. On suppose que les poignes rfres sont dj; prtes et qu'elles contiennent par consquent les coordonnes dsires.; in	A3.32	^symbole; out	{A3}	symbole initialis; mod	D7.16SYMBINITPG:	PUSHM.32 D1|D4|D6|A1|A2|A4	MOVE.8	{A3}+OTSYNUM,D1			; D1 <-- numro du symbole	CALL	SYMBGETDESC			; A1 <-- description du symbole	MOVE.32	{A3}+OTSYPPG,A4			; A4 <-- ^poignes	CLR.32	D4	MOVE.8	{A1}+OSYDEFNBP,D4		; nombre de poignes	SL.32	#2,D4				; D4 <-- taille	MOVE.32	#MTYPCP,D1	COMP.32	#0,A4	JUMP,NE	R8^CLR$				; on a dj la mmoire => ok !	GESMEM	?GETMEM				; demande un peu de mmoire	JUMP,NE	R8^ERR$				; A4 <-- ^mmoireCLR$:	GESMEM	?CLEARMEM			; plus de poigne initialise !	MOVE.32	A4,{A3}+OTSYPPG	SR.16	#2,D4				; nombre de poignes	SUB.16	#2,D4				; D4 <-- compteur	MOVE.32	#{A1}+OSYDEFLISTP,A1		; A1 <-- ^dfinition des poignes	MOVE.32	#{A4}+4,A2			; A2 <-- ^table  remplir (poigne 0 toujours [0;0])	MOVE.16	#2,D6				; D6 <-- compteurDO$:	CALL	INITPG				; initialise {A2+}.16 (c'est y)	CALL	INITPG				; initialise {A2+}.16 (c'est x)	DJ.16,NMO D4,DO$			; etc...ERR$:	POPM.32	D1|D4|D6|A1|A2|A4	TEST.16	D7	RET;---------\\;  INITPG  >;=========/; Initialise une poigne (aussi bien [x] que [y], c'est la mme chose). Lorsque l'on; a une poigne de rfrence, si elle est paire on aura [y] pris, sinon [x] !; in	A1.32	^dfinitions;	A2.32	^.16 pour la coordonne;	A3.32	^symbole;	A4.32	^liste des poignes;	D6.16	compteur; out	A1.32	^plus loin;	A2.32	^plus loin;	D6.16	suivant; mod	A1.32, A2.32, D7.16INITPG:	PUSHM.32 D0..D4	CLR.32	D0	CLR.32	D1	CLR.32	D2	MOVE.8	{A1+},D0			; D0 <-- type	MOVE.8	{A1+},D1			; D1 <-- (poigne de rfrence)*2+(0 ou 1)	MOVE.16	{A1+},D2			; D2 <-- donne	SL.16	#1,D1				; offset  la poigne de rf.	MOVE.16	{A4}+A16^{D1},D1		; D1 <-- valeur [y] ou [x] selon intrt	TCLR.32	D0:#BPGTYPVIRT			; enlve le bit "virtuel", n'a pas d'importance iciZERO$:	COMP.8	#PGTYPOSREL,D0	JUMP,NE	R8^REL$;	MOVE.16	D2,D2				; D2 <-- [d] en 256mes de [dy] de fonte par dfaut;;???	MOVE.16	{A5}+OOBDEFCHAR,D3	MOVE.16	#16,D3	CALL	GETFONTH1H2			; cherche la taille [dy] de la fonte	MOVE.16	D3,D4	SWAP.32	D3	ADD.16	D3,D4				; taille [dy]	MUL.A16	D4,D2				; change taille	SR.32	#8,D2				; D2 <-- position	ADD.16	D1,D2	MOVE.16	D2,{A2+}			; stocke la position relative  [0;0]	JUMP	ERR$REL$:	COMP.8	#PGTYPOSDIST,D0	JUMP,NE	R8^DIST$	MOVE.16	D1,D7	CLR.16	D1	MOVE.8	D2,D1	SL.16	#1,D1				; offset  la poigne de rf.	ADD.16	{A4}+A16^{D1},D7		; sauve valeur de [p2]	SR.16	#8,D2	SL.16	#1,D2	SUB.16	{A4}+A16^{D2},D7		; [p2]-[p1] = [d]	MOVE.16	D7,{A2+}	JUMP	ERR$DIST$:	COMP.8	#PGTYPANGLE,D0			; n'utiliser que pour [x] fonction de [y] !!!	JUMP,NE	R8^ANGLE$	CLR.32	D0	CLR.32	D3	CLR.32	D7	MOVE.8	{A1}-2,D3			; offset poigne de rf.	DEC.16	D3				; une de moins (chercher pour [y])	SL.16	#1,D3	MOVE.16	{A4}+A16^{D3},D7		; D7 <-- valeur [yref]	MOVE.16	{A2}-2,D3			; D3 <-- [y]	SUB.32	D7,D3				; D3 <-- [y]-[yref] = [dy]	MOVE.8	D2,D0				; D0 <-- [mul]	CONV.A8.16 D0	MUL.A16	D0,D3				; D3 <-- [dy]*[mul]	ASR.16	#8,D2				; D2 <-- [div]	DIV.A16	D2,D3				; D3 <-- [dy]*[mul]/[div] = [dx]	ADD.16	D1,D3				; D3 <-- [dx]+[yref] = [x]	MOVE.16	D3,{A2+}			; mmorise	JUMP	ERR$				; et c'est finiANGLE$:	COMP.8	#PGTYPOSCALCX,D0	JUMP,NE	R8^CALCX$	CLR.32	D4	MOVE.16	D2,D3	SR.16	#8,D3				; D3 <-- numro de l'objet intressant	CALL	SYMBnthSIZE			; D3 <-- [h1;h2], D4 <-- [dx]	CLR.32	D7	MOVE.8	D2,D7	SL.8	#4,D7	ASR.8	#4,D7				; D7 <-- facteur de multiplication	CONV.A8.16 D7	MUL.A16	D7,D4	MOVE.8	D2,D7	ASR.8	#4,D7				; D7 <-- facteur de rduction	CONV.A8.16 D7	DIV.A16	D7,D4				; D4 <-- [dx]*[mul]/[div]	ADD.16	D1,D4	MOVE.16	D4,{A2+}	JUMP	ERR$CALCX$:	COMP.8	#PGTYPOSCALCY,D0	JUMP,NE	R8^CALCY$	CLR.32	D4	MOVE.16	D2,D3	SR.16	#8,D3				; D3 <-- numro de l'objet intressant	CALL	SYMBnthSIZE			; D3 <-- [h1;h2], D4 <-- [dx]	MOVE.16	D3,D4	SWAP.32	D3	ADD.16	D3,D4				; D4 <-- [dy] de l'objet	CLR.32	D7	MOVE.8	D2,D7	SL.8	#4,D7	ASR.8	#4,D7				; D7 <-- facteur de multiplication	CONV.A8.16 D7	MUL.A16	D7,D4	MOVE.8	D2,D7	ASR.8	#4,D7				; D7 <-- facteur de rduction	CONV.A8.16 D7	DIV.A16	D7,D4				; D4 <-- [dy]*[mul]/[div]	ADD.16	D1,D4	MOVE.16	D4,{A2+}	JUMP	ERR$CALCY$:	COMP.8	#PGTYPOSCALCH2,D0	JUMP,NE	R8^CALCH2$	CLR.32	D4	MOVE.16	D2,D3	SR.16	#8,D3				; D3 <-- numro de l'objet intressant	CALL	SYMBnthSIZE			; D3 <-- [h1;h2], D4 <-- [dx]	MOVE.16	D3,D4				; D4 <-- [dy] de l'objet	CLR.32	D7	MOVE.8	D2,D7	SL.8	#4,D7	ASR.8	#4,D7				; D7 <-- facteur de multiplication	CONV.A8.16 D7	MUL.A16	D7,D4	MOVE.8	D2,D7	ASR.8	#4,D7				; D7 <-- facteur de rduction	CONV.A8.16 D7	DIV.A16	D7,D4				; D4 <-- [dy]*[mul]/[div]	ADD.16	D1,D4	MOVE.16	D4,{A2+}	JUMP	ERR$CALCH2$:	COMP.8	#PGTYPOSCALCH1,D0	JUMP,NE	R8^CALCH1$	CLR.32	D4	MOVE.16	D2,D3	SR.16	#8,D3				; D3 <-- numro de l'objet intressant	CALL	SYMBnthSIZE			; D3 <-- [h1;h2], D4 <-- [dx]	SWAP.32	D3	MOVE.16	D3,D4				; D4 <-- [dy] de l'objet	CLR.32	D7	MOVE.8	D2,D7	SL.8	#4,D7	ASR.8	#4,D7				; D7 <-- facteur de multiplication	CONV.A8.16 D7	MUL.A16	D7,D4	MOVE.8	D2,D7	ASR.8	#4,D7				; D7 <-- facteur de rduction	CONV.A8.16 D7	DIV.A16	D7,D4				; D4 <-- [dy]*[mul]/[div]	ADD.16	D1,D4	MOVE.16	D4,{A2+}	JUMP	ERR$CALCH1$:	COMP.8	#PGTYPOSMAX,D0	JUMP,NE	R8^MAX$	CLR.16	D3	MOVE.8	D2,D3	SL.16	#1,D3	MOVE.16	{A4}+A16^{D3},D3		; coordonne 1	SR.16	#8,D2	SL.16	#1,D2	MOVE.16	{A4}+A16^{D2},D2	ADD.16	D1,D2	ADD.16	D1,D3	COMP.16	D2,D3	JUMP,GT	R8^OKD3$			; prend D3 qui est le maximumOKD2$:	MOVE.16	D2,{A2+}	JUMP	ERR$OKD3$:	MOVE.16	D3,{A2+}	JUMP	ERR$MAX$:	COMP.8	#PGTYPOSMIN,D0	JUMP,NE	R8^MIN$	CLR.16	D3	MOVE.8	D2,D3	SL.16	#1,D3	MOVE.16	{A4}+A16^{D3},D3		; coordonne 1	SR.16	#8,D2	SL.16	#1,D2	MOVE.16	{A4}+A16^{D2},D2	ADD.16	D1,D2	ADD.16	D1,D3	COMP.16	D2,D3	JUMP,GT	R8^OKD2$			; prend D2 qui est le minimum	JUMP	R8^OKD3$			; sinon D3 !MIN$:	REGS	"Pas encore possible dans INITPG"ERR$:	INC.16	D6	POPM.32	D0..D4	RET;--------------\\;  SYMBnthSIZE  >;==============/; Cherche la taille du nime pav de texte.; in	D3.16	numro du pav;	A3.32	^symbole; out	D3.32	[h1;h2];	D4.16	[dx]; mod	D3.32, D4.16, D7.16SYMBnthSIZE:	PUSHM.32 D0|D1|A1|A3	PUSH.16	{A5}+ODRIMBRIC	MOVE.8	{A3}+OTSYNUM,D1	CALL	SYMBGETDESC			; A1 <-- descripteur	CLR.16	D1	MOVE.8	{A1}+OSYDEFNBP,D1	SUB.16	#1,D1				; la poigne [0;0] n'est pas dfinie	SL.16	#3,D1	MOVE.32	#{A1}+A16^{D1}+OSYDEFLISTP,A1	; A1 <-- ^liste des lments contenus	MOVE.16	D3,D1				; D1 <-- compteurDOEL$:	MOVE.16	{A1+},D0			; cherche lment	JUMP,EQ	R8^OKEL$	COMP.16	#ESYCHAR,D0	JUMP,EQ	R8^CHAR$	COMP.16	#ESYLINE,D0	JUMP,EQ	R8^LINE$	COMP.16	#ESYFILL,D0	JUMP,EQ	R8^FILL$	TEST.16	D1				; bon pav ?	JUMP,EQ	R8^BPAVE$			; oui => ok	DEC.16	D1LINE$:	ADD.A16	#2,A1				; saute ligne	JUMP	R8^DOEL$CHAR$:	ADD.A16	#LSYC,A1			; saute caractre	JUMP	R8^DOEL$FILL$:	MOVE.16	{A1+},D0			; saute remplissage	SL.16	#1,D0	ADD.A16	D0,A1	JUMP	R8^DOEL$BPAVE$:	TEST.8	{A1}+OSYPTYPE:#BSYIMBR	JUMP,BC	R8^OKEL$			; ok, pas d'imbrication !	INC.16	{A5}+ODRIMBRIC			; une de plusOKEL$:	MOVE.32	#{A3}+LTSY,A3			; ^premier pav	MOVE.16	D3,D1				; D1 <-- compteur	JUMP,EQ	R8^OK$	CLR.32	D3	CLR.32	D4SKIP$:	COMP.16	#CR,{A3}			; terminateur ?	JUMP,EQ	R8^NEXT$			; oui => pav suivant !	TEST.16	{A3}	JUMP,EQ	R8^ERR$	CALL	SKIPONE				; saute un lment	JUMP,EQ	R8^SKIP$			; suivants	JUMP	R8^ERR$				; fin => termin !NEXT$:	MOVE.16	{A3+},D0			; saute le "terminateur"	DEC.16	D1	JUMP,NE	R8^SKIP$			; passe au pav suivantOK$:	CALL	SYMBTXTSIZE			; D3 <-- [h1;h2] et D4 <-- [dx]ERR$:	POP.16	{A5}+ODRIMBRIC	POPM.32	D0|D1|A1|A3	RET;---------------\\;  SYMBfilsREDO  >;===============/; Refait le calcul des poignes des descendants; in	A3.32	^symbole; out	A3.32	^aprs le symbole; mod	A3.32, D7.16SYMBfilsREDO:	PUSHM.32 D0|D1|D3|D4|A1	MOVE.8	{A3}+OTSYNUM,D1	CALL	SYMBGETDESC			; A1 <-- descripteur	ADD.A16	#LTSY,A3			; A3 <-- ^plus loin	CLR.16	D1	MOVE.8	{A1}+OSYDEFNBP,D1	SUB.16	#1,D1				; la poigne [0;0] n'est pas dfinie	SL.16	#3,D1	MOVE.32	#{A1}+A16^{D1}+OSYDEFLISTP,A1	; A1 <-- ^liste des lments contenus	MOVE.16	D3,D1				; D1 <-- compteurDOEL$:	MOVE.16	{A1+},D0			; cherche lment	JUMP,EQ	R8^OKEL$	COMP.16	#ESYCHAR,D0	JUMP,EQ	R8^CHAR$	COMP.16	#ESYLINE,D0	JUMP,EQ	R8^LINE$	COMP.16	#ESYFILL,D0	JUMP,EQ	R8^FILL$PAVE$:	PUSH.16	{A5}+ODRIMBRIC	TEST.8	{A1}+OSYPTYPE:#BSYIMBR		; imbrique ?	JUMP,BC	R8^IPAVE$			; non => normal	INC.16	{A5}+ODRIMBRIC			; oui => un niveau de plusIPAVE$:	CALL	SYMBpavREDO			; refait le pav	POP.16	{A5}+ODRIMBRICLINE$:	ADD.A16	#2,A1				; saute ligne	JUMP	R8^DOEL$CHAR$:	ADD.A16	#LSYC,A1			; saute caractre	JUMP	R8^DOEL$FILL$:	MOVE.16	{A1+},D0			; saute remplissage	SL.16	#1,D0	ADD.A16	D0,A1	JUMP	R8^DOEL$OKEL$:	POPM.32	D0|D1|D3|D4|A1	RET;	Initialise les symboles trouvs dans le pavSYMBpavREDO:DO$:	COMP.8	#tfSYMBBEGIN,{A3}	JUMP,EQ	R8^SYMB$	TEST.16	{A3}	JUMP,EQ	R8^RET$	COMP.16	#CR,{A3+}	JUMP,NE	R8^DO$RET$:	RETSYMB$:	PUSH.32	A2	MOVE.32	A3,A2	CALL	SYMBfilsREDO			; initialise les descendants	EX.32	A2,A3	CALL	SYMBINITPG			; initialise les poignes	CALL	SYMBINITSIZE			; initialise la taille	EX.32	A2,A3	POP.32	A2	JUMP	R8^DO$				; et passe  la suite;---------------\\;  SYMBINITSIZE  >;===============/; Initialise la taille du symbole. Il suffit de chercher les coordonnes; maximales des poignes initialises.; Les poignes doivent tre initialises !!!; in	A3.32	^symbole; out	{A3}	symbole initialis; mod	D7.16SYMBINITSIZE:	PUSHM.32 D0|D1|D3|D4|D5|D6|A1|A4	MOVE.8	{A3}+OTSYNUM,D1			; D1 <-- numro du symbole	CALL	SYMBGETDESC			; A1 <-- description du symbole	MOVE.32	{A3}+OTSYPPG,A4			; A4 <-- ^poignes	ADD.A16	#4,A4				; saute la poigne [0;0]	CLR.16	D1	MOVE.8	{A1}+OSYDEFNBP,D1		; nombre de poignes	SUB.8	#2,D1				; saute [0;0]	MOVE.32	#{A1}+OSYDEFLISTP,A1		; A1 <-- ^liste des poignes	CLR.16	D4				; D4 <-- [dx]  zro	MOVE.16	#16'7FFF,D5			; D5 <-- [dy min] max.	MOVE.16	#16'8000,D6			; D6 <-- [dy max] min.DO$:	MOVE.16	{A4+},D3			; D3 <-- [y]  analyser	MOVE.32	{A1+},D0	TEST.32	D0:#31				; poigne virtuelle ?	JUMP,BS	R8^YMAX$			; oui => ne prend pas en compte	COMP.16	D3,D5	JUMP,LE	R8^YMIN$	MOVE.16	D3,D5YMIN$:	COMP.16	D3,D6	JUMP,GE	R8^YMAX$	MOVE.16	D3,D6YMAX$:	MOVE.16	{A4+},D3			; D3 <-- [x]  analyser	MOVE.32	{A1+},D0	TEST.32	D0:#31				; poigne virtuelle ?	JUMP,BS	R8^XMAX$			; oui => ne prend pas en compte	COMP.16	D3,D4	JUMP,GE	R8^XMAX$	MOVE.16	D3,D4XMAX$:	DJ.16,NMO D1,DO$	NEG.16	D5	MOVE.16	D5,{A3}+OTSYH1			; <-- [h1], c'est l'oppos de la coord. y minimale	MOVE.16	D6,{A3}+OTSYH2			; <-- [h2], c'est le dpassement par le bas maximal	MOVE.16	D4,{A3}+OTSYDX			; <-- [dx], largeur maximaleERR$:	POPM.32	D0|D1|D3|D4|D5|D6|A1|A4	TEST.16	D7	RET;-----------\\;  SYMBDRAW  >;===========/; Dessine un symbole. C'est "divinement" rcursif (L.Peter Deutsch); in	A3.32	^symbole;	A4.32	^instance;	A5.32	^variables locales;	D6.16	mode de dessin (doDRAW/doGETCURS/doGETPOS);	{A5}+ODRPOS, position pour dessiner; out	A3.32	^plus loin;	{A5}+ODRPOS, nouvelle position; mod	A3.32, D7.16SYMBDRAW:	PUSHM.32 D0..D5|A0|A1|A2	CLR.16	D7	MOVE.32	{A3}+OTSYPPG,A0			; A0 <-- liste de poignes	MOVE.8	{A3}+OTSYNUM,D1			; D1 <-- numro du symbole	CALL	SYMBGETDESC			; A1 <-- description du symbole	MOVE.16	{A3}+OTSYDX,D5			; D5 <-- [dx] du pav	ADD.A16	#LTSY,A3			; A3 <-- ^aprs la dfinition du symbole	ADD.32	#LTSY-2,{A5}+OTXCURS		; plus loin dans la recherche	CLR.16	D4	MOVE.8	{A1}+OSYDEFNBP,D4	SUB.16	#1,D4				; la poigne [0;0] n'est pas dfinie	SL.16	#3,D4	MOVE.32	#{A1}+A16^{D4}+OSYDEFLISTP,A2	; A2 <-- ^liste des lments contenus	MOVE.32	{A5}+ODRPOS,D1			; D1 <-- position pour afficher;	On peut utiliser librement D0/D2/D3/D4 dans ce qui suit.DO$:	MOVE.16	{A2+},D0			; prochain lment	JUMP,EQ	END$				; "fin" => ok !	COMP.16	#ESYLINE,D0			; ligne ?	JUMP,EQ	R8^LINE$	COMP.16	#ESYPAVE,D0			; pav ?	JUMP,EQ	PAVE$	COMP.16	#ESYFILL,D0			; remplissage ?	JUMP,EQ	FILL$	COMP.16	#ESYCHAR,D0			; caractre dform ?	JUMP,EQ	CHAR$	REGS	"Inconnu dans SymbDraw"	JUMP	END$;	Dessine une ligne dans un symbole;	---------------------------------LINE$:	CLR.16	D0	MOVE.8	{A2+},D0			; numro de la poigne 1	SL.16	#2,D0	MOVE.32	{A0}+A16^{D0},D3	ADD.32	D1,D3	CLR.16	D0	MOVE.8	{A2+},D0			; numro de la poigne 2	SL.16	#2,D0	MOVE.32	{A0}+A16^{D0},D4	ADD.32	D1,D4	MOVE.16	{A5}+ODRMODE,D2	CALL	DRAWLIGNE			; dessine la ligne	JUMP	DO$;	Dessine une surface remplie dans un symbole;	-------------------------------------------FILL$:	MOVE.16	{A2+},D2	DEC.16	D2	CALL	DRAWPOLYOPENDFILL$:	CLR.16	D0	MOVE.8	{A2+},D0			; numro de la poigne 1	SL.16	#2,D0	MOVE.32	{A0}+A16^{D0},D3	ADD.32	D1,D3	CLR.16	D0	MOVE.8	{A2+},D0			; numro de la poigne 2	SL.16	#2,D0	MOVE.32	{A0}+A16^{D0},D4	ADD.32	D1,D4	CALL	DRAWPOLYLINE			; dessine pourtour de remplissage	DJ.16,NMO D2,DFILL$	CALL	DRAWPOLYCLOSE	JUMP	DO$;	Dessine un pav dans un symbole;	-------------------------------	.APC	PCVAR	.LOC	0OPTXT$:	.BLK.32	1				; ^sur pav de texteOH1$:	.BLK.16	1				; [h1] du pavOH2$:	.BLK.16	1				; [h2] du pavODX$:	.BLK.16	1				; [dx] du pavOIMB$:	.BLK.16	1				; imbricationLOCAL$:	.APC	PCCODEPAVE$:	SUB.A16	#LOCAL$,SP			; fait de la place sur la pile..	MOVE.16	{A5}+ODRIMBRIC,{SP}+OIMB$	; imbrication	TEST.8	{A2}+OSYPTYPE:#BSYIMBR		; imbrique ?	JUMP,BC	R8^PIMBR$	INC.16	{A5}+ODRIMBRIC			; un niveau de plusPIMBR$:	MOVE.32	A3,{SP}+OPTXT$	CALL	SYMBTXTSIZE			; cherche taille du pav	MOVE.32	D3,{SP}+OH1$			; sauve [h1;h2]	MOVE.16	D4,{SP}+ODX$			; sauve [dx]	CLR.16	D0	MOVE.8	{A2}+OSYPPBASE,D0		; numro de la poigne de rfrence	SL.16	#2,D0	MOVE.32	{A0}+A16^{D0},D3		; position de dpart	ADD.32	D1,D3				; D3 <-- [y;x] du point d'origine	TEST.8	{A2}+OSYPTYPE:#BSYPUP		; push up ?	JUMP,BC	R8^PUP$				; non => suite	TEST.8	{A2}+OSYPTYPE:#BSYPDOWN		; push down ?	JUMP,BC	R8^PUP1$			; non => pousse vers le haut	MOVE.16	{SP}+OH2$,D4	ADD.16	{SP}+OH1$,D4	SR.16	#1,D4	SUB.16	{SP}+OH2$,D4	SWAP.32	D3	ADD.16	D4,D3				; baisse un peu	SWAP.32	D3	JUMP	R8^PDOWN$PUP1$:	SWAP.32	D3	SUB.16	{SP}+OH2$,D3			; fait de la place vers le haut	SWAP.32	D3PUP$:	TEST.8	{A2}+OSYPTYPE:#BSYPDOWN		; push down ?	JUMP,BC	R8^PDOWN$			; non => suite	SWAP.32	D3	ADD.16	{SP}+OH1$,D3			; fait de la place vers le bas	SWAP.32	D3PDOWN$:	TEST.8	{A2}+OSYPTYPE:#BSYPLEFT		; push left ?	JUMP,BC	R8^PLEFT$			; non => suite	TEST.8	{A2}+OSYPTYPE:#BSYPRIGHT	; push right ?	JUMP,BC	R8^PLEF1$			; non => pousse vers la gauche	MOVE.16	{SP}+ODX$,D4	SR.16	#1,D4	SUB.16	D4,D3				; centre	JUMP	R8^PRIGHT$PLEF1$:	SUB.16	{SP}+ODX$,D3			; pousse vers la gauchePLEFT$:						; pousse sinon vers la droite (automatique)PRIGHT$:	MOVE.32	D3,{A5}+ODRPOS			; position pour afficher du texte	ADD.A16	#LSYP,A2			; A2 <-- aprs df. du pav	MOVE.32	{SP}+OPTXT$,A3			; A3 <-- ^pav de texte  afficher	CALL	DRAWPAVE			; dessine, A3 aprs le pav dessin	MOVE.16	{SP}+OIMB$,{A5}+ODRIMBRIC	; nouvelle imbrication	ADD.A16	#LOCAL$,SP	CLR.16	D7	TEST.16	{A5}+OTXOK			; ok ?	JUMP,NE	ERR$				; oui => interrompt tout de suite	JUMP	DO$;	Dessine un caractre;	--------------------CHAR$:	PUSHM.32 D1|D5|A3|A4;;	MOVE.32	{A5}+ODRINST,A4;;	MOVE.16	{A4}+OOBDEFCHAR,D3;;	CALL	GETDGBM				; cherche le descripteur de la fonte par dfaut;;	JUMP,NE	ERCH$;;	MOVE.32	A3,A4				; ^sur fonte par dfaut	MOVE.32	#{A5}+OFONTTEMP,A3	MOVE.16	#16,D3	CALL	CLONEDGBM			; cre une copie personnelle du symbole	MOVE.32	{A5}+ODRINST,A4	MOVE.16	{A4}+OOBSIZE,{A3}+ODGBMCORPS	; nouvelle taille du corps;;	MOVE.16	{A4}+ODGBMCORPS,{A3}+ODGBMCORPS	; taille actuelle des symboles;;	MOVE.32	{A4}+ODGBMROTATE,{A3}+ODGBMROTATE ; rotation en degrs rels;;	MOVE.16	{A4}+ODGBMZOOMX,{A3}+ODGBMZOOMX	; zoom normal [x];;	MOVE.16	{A4}+ODGBMZOOMY,{A3}+ODGBMZOOMY	; zoom normal [y]	MOVE.16	#100,{A3}+ODGBMZOOMX		; zoom normal [x]	MOVE.16	#100,{A3}+ODGBMZOOMY		; zoom normal [y]	CALL	GETPCHASSE			; A4 <-- ^table des chasses des symboles	MOVE.8	{A2}+OSYCRANG,D3		; D3 <-- code ASCII du caractre  afficher	CLR.16	D0	MOVE.8	{A2}+OSYCPBASE,D0	SL.16	#2,D0	MOVE.32	{A0}+A16^{D0},D0		; D0 <-- coordonne de dpart [y;x]	TEST.8	{A2}+OSYCTYPE:#BSYCDX		; doit-on zoomer selon [x] ?	JUMP,BC	R8^DX$				; non => suite	CALL	GETCARLENGTH			; D4 <-- [dx] du symbole rel	CLR.32	D2	MOVE.8	{A2}+OSYCPDX,D2	SL.16	#2,D2	MOVE.32	{A0}+A16^{D2},D2		; poigne fixant la largeur	SUB.16	D0,D2				; cherche [dx] dsir	JUMP,GT	R8^DXOK$			; ngatif => rien	NEG.16	D2DXOK$:	MUL.16	#100,D2				; cherche 100 fois trop grand	DIV.16	D4,D2				; on trouve le pourcentage	MOVE.16	D2,{A3}+ODGBMZOOMX		; zoom spcial [x]DX$:	TEST.8	{A2}+OSYCTYPE:#BSYCDY		; doit-on zoomer selon [y] ?	JUMP,BC	R8^DY$				; non => suite	PUSH.16	D3.IF AdaptCharToFit	CALL	GETCARH1H2.ELSE AdaptCharToFit	MOVE.16	#16,D3	CALL	GETFONTH1H2.ENDIF AdaptCharToFit	MOVE.16	D3,D4	SWAP.32	D3	ADD.16	D3,D4				; D4 <-- [dy] total	POP.16	D3				; D3 <-- [h2;car]	CLR.32	D2	MOVE.8	{A2}+OSYCPDY,D2	SL.16	#2,D2	MOVE.32	{A0}+A16^{D2},D2		; [y;x] poigne fixant la largeur	SWAP.32	D2	SWAP.32	D0	SUB.16	D0,D2				; cherche [dy] dsir	SWAP.32	D0	TEST.16	D2	JUMP,GT	R8^DYOK$			; ngatif => rien	NEG.16	D2DYOK$:	MUL.16	#100,D2				; cherche 100 fois trop grand	DIV.16	D4,D2				; on trouve le pourcentage.if mondebugmon ?aftim.ascize "% = "push.16 d4move.16	d2,d4mon ?afx4mon ?afcrpop.16	d4.endif mondebug	MOVE.16	D2,{A3}+ODGBMZOOMY		; zoom spcial [y]DY$:	PUSH.32	D3	SWAP.32	D3				; D3 <-- [h2]	MUL.16	{A3}+ODGBMZOOMY,D3	DIV.16	#100,D3				; D3 <-- [h2] * facteur de zoom [y]	SWAP.32	D0	SUB.16	D3,D0				; D0 <-- position pour placer le caractre	SWAP.32	D0	POP.32	D3	ADD.32	D1,D0				; D0 <-- position relle	MOVE.32	A3,A4				; A4 <-- ^descripteur	MOVE.32	{A5}+ODRINST,A3	MOVE.32	{A3}+OOBA,D1			; D1 <-- angle en degrs rels	ADD.A16	#LSYC,A2			; A2 <-- ^plus loin	MOVE.32	#DR_GETPGC,D7	PAGE_	DRAW				; cherche gencar bitmap	JUMP,NE	R8^ERCH$	MOVE.32	{A5}+ODRINST,A4	MOVE.32	D0,D4	CALL	TRANSF1toDRAW			; D4 <-- [y;x] pour le dessin	MOVE.32	A3,A4				; A4 <-- gencar bitmap;	MOVE.16	D3,D3				; D3 <-- caractre	MOVE.32	{A5}+ODRRMODE,D2	MOVE.16	{A5}+ODRMODE,D2			; D2 <-- mode de dessin	COMP.16	#doDRAW,D6	JUMP,NE	R8^ERCH$	MOVE.32	#DR_CHARQ,D7	PAGE_	DRAWERCH$:	POPM.32	D1|D5|A3|A4	JUMP	DO$;	Fin de l'affichage;	------------------END$:	CLR.16	D7	ADD.16	D5,D1	MOVE.32	D1,{A5}+ODRPOSERR$:	POPM.32	D0..D5|A0|A1|A2	TEST.16	D7	RET;-----------\\;  DRAWPAVE  >;===========/; Dessine un pav de texte. C'est (parat-il) tout simple !; in	A3.32	^pav  afficher;	D6.16	mode (doDRAW/doGETCURS/doGETPOS); out	A3.32	^plus loin; mod	A3.32, D7.16DRAWPAVE:	PUSHM.32 D0|A4	CLR.16	D7	MOVE.32	{A5}+ODRINST,A4DO$:	COMP.16	#CR,{A3}			; terminateur ?	JUMP,EQ	R8^OK$				; oui => ok !	TEST.16	{A3}				; vraiment fini ?	JUMP,EQ	R8^FIN$				; oui => fin !	CALL	DRAWELEM			; dessine 1 lment	TEST.16	{A5}+OTXOK	JUMP,NE	R8^ERR$				; termine tout de suite si fini	JUMP	R8^DO$				; et reprendFIN$:	COMP.16	#doGETPOS,D6	JUMP,NE	R8^ERR$	MOVE.16	{A5}+ODRIMBRIC,{A5}+OTXIMBRIC	MOVE.16	#1,{A5}+OTXOK	JUMP	R8^ERR$OK$:	COMP.16	#doGETPOS,D6	JUMP,NE	R8^NXT$	MOVE.32	{A5}+OTXCURS,D0	COMP.32	{A4}+OOBPOC,D0	JUMP,NE	R8^NXT$	MOVE.16	{A5}+ODRIMBRIC,{A5}+OTXIMBRIC	MOVE.16	#1,{A5}+OTXOK	JUMP	R8^ERR$NXT$:	ADD.A16	#2,A3				; c'est ok !	ADD.32	#2,{A5}+OTXCURS	CLR.16	D7ERR$:	POPM.32	D0|A4	TEST.16	D7	RET;--------------\\;  SYMBTXTSIZE  >;==============/; Cherche la taille d'un pav de texte.; in	A3.32	^sur le dbut du pav de texte;	A5.32	^variables locales; out	D3.32	[h1;h2];	D4.16	[dx];	A3.32	^plus loin; mod	D3.32, D4.16, A3.32, D7.16SYMBTXTSIZE:	PUSHM.32 D0|D1|A4	CLR.32	D0				; D0 <-- [h1;h2] nuls	CLR.16	D1				; D1 <-- [dx] nulDO$:	COMP.16	#CR,{A3}			; trouv taille ?	JUMP,EQ	R8^END$				; oui => ok !	TEST.16	{A3}	JUMP,EQ	R8^FIN$	COMP.8	#tfSYMBBEGIN,{A3}		; symbole construit ?	JUMP,EQ	R8^SYMB$			; oui => ok !	CLR.16	D3	MOVE.8	{A3+},D3			; D3 <-- fonte	CALL	GETPCHASSE			; A4 <-- ^chasse	JUMP,NE	R8^ERR$	CALL	GETFONTH1H2			; D3 <-- [h1;h2] de la fonte en service	PUSH.32	D3	MOVE.8	{A3+},D3			; D3 <-- caractre	CALL	GETCARLENGTH			; D4 <-- [dx] du caractre	COMP.8	#2,D3	JUMP,NE	R8^notCADR$	SR.16	#2,D4notCADR$:	POP.32	D3;;	CALL	GETCARH1H2			; D3 <-- [h1;h2] du caractre	JUMP	R8^NEW$SYMB$:	CALL	SYMBGETSIZE			; D3/D4 <-- [h1;h2]/[dx] du symboleNEW$:	ADD.16	D4,D1				; augmente la largeur	COMP.16	D3,D0	JUMP,GE	R8^OKH2$	MOVE.16	D3,D0				; mmorise nouveau [h2]OKH2$:	SWAP.32	D0	SWAP.32	D3	COMP.16	D3,D0	JUMP,GE	R8^OKH1$			; mmorise nouveau [h1]	MOVE.16	D3,D0OKH1$:	SWAP.32	D0	JUMP	R8^DO$END$:	ADD.A16	#2,A3FIN$:	TEST.16	D0	JUMP,NE	R8^OKxH2$	MOVE.32	{A5}+ODRINST,A4	MOVE.16	#16,D3	CALL	GETFONTH1H2	MOVE.16	D3,D0OKxH2$:	SWAP.32	D0	TEST.16	D0	JUMP,NE	R8^OKxH1$	MOVE.32	{A5}+ODRINST,A4	MOVE.16	#16,D3	CALL	GETFONTH1H2	SWAP.32	D3	MOVE.16	D3,D0OKxH1$:	SWAP.32	D0	MOVE.32	D0,D3	MOVE.16	D1,D4ERR$:	POPM.32	D0|D1|A4	RET;--------------\\;  SYMBGETSIZE  >;==============/; Cherche la taille du symbole concern (point par A3); in	A3.32	^symbole; out	D3.32	[h1;h2] du symbole;	D4.16	[dx];	A3.32	^plus loin (aprs les pavs de textes); mod	D3.32, D4.16, A3.32SYMBGETSIZE:	MOVE.16	{A3}+OTSYDX,D4			; D4 <-- [dx]	MOVE.32	{A3}+OTSYH1,D3			; D3 <-- [h1;h2]	CALL	SYMBSKIP			; saute le symbole + pavs associs	RET;-----------\\;  SYMBSKIP  >;===========/; Saute le symbole + pavs associs; in	A3.32	^symbole  sauter; out	A3.32	^aprs; mod	A3.32, D7.16SYMBSKIP:	PUSHM.32 D0|D1|A1	CLR.16	D1	MOVE.8	{A3}+OTSYNUM,D1			; D1 <-- numro du symbole	CALL	SYMBGETDESC			; A1 <-- ^descripteur du symbole	ADD.A16	#LTSY,A3			; A3 <-- ^aprs le symbole	MOVE.8	{A1}+OSYDEFNBEDIT,D1		; nombre de pavs de texte  sauter	JUMP,EQ	R8^ERR$	DEC.16	D1SKIP$:	COMP.16	#CR,{A3}			; terminateur ?	JUMP,EQ	R8^NEXT$			; oui => pav suivant !	TEST.16	{A3}	JUMP,EQ	R8^ERR$	CALL	SKIPONE				; saute un lment	JUMP,EQ	R8^SKIP$			; suivants	JUMP	R8^ERR$				; fin => termin !NEXT$:	MOVE.16	{A3+},D0			; saute le "terminateur"	DJ.16,NMO D1,SKIP$			; passe au pav suivantERR$:	POPM.32	D0|D1|A1	RET;----------\\;  SKIPONE  >;==========/; Saute un lment unique.; in	A3.32	^lment; out	A3.32	^plus loin;	D7.16	ok/erreur (fin atteinte); mod	A3.32, D7.16SKIPONE:	PUSH.32 D0	MOVE.32	#ERPBIP,D7	TEST.16	{A3}				; fin atteinte ?	JUMP,EQ	R8^ERR$				; oui => erreur !	CLR.16	D7	MOVE.8	{A3},D0	COMP.8	#tfCHFONTMAX,D0			; fonte ?	JUMP,LE	R8^FONT$	COMP.8	#tfSYMBBEGIN,D0			; dbut de symbole ?	JUMP,EQ	R8^SYMB$	REGS	"Element illgal dans D0/A3 in SKIPONE."	JUMP	R8^ERR$SYMB$:	CALL	SYMBSKIP			; saute le symbole + pavs associs	JUMP	R8^ERR$FONT$:	MOVE.16	{A3+},D0			; saute un seul caractreERR$:	POP.32	D0	TEST.16	D7	RET;--------------\\;  SYMBGETDESC  >;==============/; Cherche le ^description du symbole; in	D1.8	numro du symbole;	A5.32	^variables; out	A1.32	^descripteur; mod	A1.32, D7.16SYMBGETDESC:	PUSHM.32 D1|D2|A0|A2|A4	AND.32	#16'000000FF,D1	MOVE.32	{A5}+OTYPFORDEF,A0	MOVE.32	{A5}+OCANRES,A2	MOVE.32	{A5}+ORESGET,A4			; adresse routine RES_GET	MOVE.32	#2**BRSGETPOINTER,D2		; demande que le pointeur  la dfinition	CALL	{A4}	MOVE.32	A4,A1				; A1 <-- ^description du symboleERR$:	POPM.32	D1|D2|A0|A2|A4	TEST.16	D7	RET	.END