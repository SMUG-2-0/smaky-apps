	.SBTTL	PAGEDBOXT.ASI;---------\\; DBOXOPEN >;---------/; Ouvre une dbox.; in	A2.L	table;	D2.W	mode; out	D5.L	canal;	D7.W	erreur; mod	D5.L, D7.WDBOXOPEN:	PUSH.L	D3	CALL	DBOXOPEN1	CALL	DBOXPOS3	; D3 <-- centre de la dbox	DBOX_	OPEN		; ouvre la dbox	POP.L	D3	TEST.W	D7		; retour EQ/NE	RETDBOXOPEN1:	PUSH.W	D3	CALL	SCMO		; remet la flche	CLR.W	D3	CALL	SELMO		; outil = flche	CALL	NORMMOUSE	; remet la flche	CALL	WDOOPEN2	; sauve position/dimensions swdo actuelle	POP.W	D3	RET;----------\\; DBOXCLOSE >;----------/; Ferme une dbox.; in	D5.L	canal; out	D7.W	erreur; mod	D7.WDBOXCLOSE:	DBOX_	CLOSE		; ferme la dboxDBOXCLOSE1:	PUSHM.L	D3,D7,A3	CALL	AFMENU		; refait les soft-keys	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#MMODULO	LOAD.B	(A3)+1,#1	; n'impose plus les modulos	LOAD.W	D3,#2	LIB	?STRING	CALL	WDOCLOSE2	; remet position/dimensions swdo initiale	POPM.L	D3,D7,A3	RET;---------\\; DBOXPOS5 >;---------/; Centre ventuellement les dbox selon les icnes de gauche.; in	D2.W	mode d'ouverture; out	D2.W	mode d'ouverture;	D5.L	position (y;x); mod	D2.L, D5.L, D7.WDBOXPOS5:	PUSH.L	D3	CALL	DBOXPOS3	LOAD.L	D5,D3	POP.L	D3	RET;---------\\; DBOXPOS3 >;---------/; Centre ventuellement les dbox selon les icnes de gauche.; in	D2.W	mode d'ouverture; out	D2.W	mode d'ouverture;	D3.L	position (y;x); mod	D2.L, D3.L, D7.WDBOXPOS3:	PUSH.L	A2	TEST.L	D2:#BDBPOS	; dj centre selon D3.L ?	JUMP',BS EXIT$		; oui => EXIT$	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.W	D3,(A6)+OICOPOS+0	ADD.W	D3,#ICOLY/2	SWAP.W	D3	LOAD.W	D3,(A2)+ODFDX	SR.W	D3,#1	TSET.L	D2:#BDBPOS	; D2 <-- centre selon D3.LEXIT$:	POP.L	A2	RET;--------\\; ZEROCR  >;========/; Remplace le terminateur <CR> par <0>.; Utile aprs DBOX_EDIT par exemple !; in	A3.L	^chane termine par <CR> ou <0>; out	A3.L	^chane termine par <0>; mod	-ZEROCR:	PUSH.L	A3LOOP$:	TEST.B	(A3+)	JUMP',EQ EXIT$	COMP.B	(A3)-1,#CR	JUMP,NE LOOP$	CLR.B	(A3)-1		; remplace le <CR> par <0>EXIT$:	POP.L	A3	RET;--------\\; ERCALL  >;========/; Excute un appel systme en essayant de rsoudre qq problmes.; in	D0.L	code de l'appel (par exemple #FOS?OPEN);	+ selon appel; out	+ selon appel;	D7.W	erreur (ERKSTO si annule); mod	D7.WERCALL:	PUSHM.L	D1,D2	LOAD.W	D1,#DBOX_ERCALL	; D1 <-- numro de l'appel	LOAD.W	D2,#2^BDBEXTEND	; D2 <-- mode "tendu"	DBOX_	EXTEND		; appel DBOX_ERCALL ...	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXMEMPT >;==========/; Donne le ^ la table de la dbox.; in	A2.L	^table de la dbox; out	-; mod	D7.WDBOXMEMPT:	LOAD.L	(A6)+ODBPTE,A2	; ODBPTE <-- ^table dbox	CLR.L	(A6)+ODBPTA	RET;-----------\\; DBOXMEMAFC >;===========/; Donne le ^ la routine d'affichage pour DBOXCLIC.; in	A2.L	^routine (*); out	-; mod	D7.W; Dfinition de la routine (*) :;; in	D2.W	mode (CLRDOT/SETDOT);	D5.L	canal dbox;	A5.L	^variables pour put/get; out	-; mod	D7.WDBOXMEMAFC:	LOAD.L	(A6)+ODBPTA,A2	; ODBPTA <-- ^routine	RET;----------\\; DBOXMEDIT >;==========/; Donne la bonne valeur  DBOX_MEDIT.; in	D2.W	rang (0..n);	D5.L	canal dbox; out	-; mod	D7.WDBOXMEDIT:	PUSHM.L	D2,D3,A2	LOAD.W	D3,D2	COMP.W	D3,#-1	JUMP',EQ 50$	LOAD.L	A2,(A6)+ODBPTE	; A2 <-- ^table dbox	MUL.WU	D2,#LDB	ADD.L	A2,D2	LOAD.W	D3,(A2)+ODBRED50$:	DBOX_	MEDIT	POPM.L	D2,D3,A2	RET;---------\\; DBOXCLIC >;=========/; Incrmente v. un paramtre ditable.; in	A3.L	^dbut ligne;	D2.W	rang (0..n);	D5.L	canal dbox;	A5.L	^variables pour put/get; out	D2.W	rang (0..n);	A3.L	^dbut ligne;	A4.L	^curseur dans ligne;	D7.W	erreur; mod	D2.L, D7.W, A3.L, A4.LDBOXCLIC:	PUSHM.L	D0,D1,D3,D4,A0,A2	PUSH.W	D2	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre	CALL	DBOXPUT		; mj. paramtre ditable	JUMP,NE ERROR$	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE ERROR$	SUB.W	D4,(A0)+ODFFX	JUMP,LO ERROR$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	JUMP,LO ERROR$	SWAP.W	D4	LOAD.L	D1,D4		; D1 <-- position de la souris	LOAD.L	A2,(A6)+ODBPTE	; A2 <-- ^table dbox	CLR.W	D0		; D0 <-- rangLOOP$:	COMP.W	(A2),#-1	JUMP,EQ ERROR$	TEST.W	(A2)+ODBINC	JUMP',EQ NEXT2$	LOAD.W	D2,(A2)+ODBRGC	DBOX_	GETCO	ADD.W	D4,(A0)+ODFCX	ADD.W	D4,#6	COMP.W	D1,D4	JUMP',LO NEXT2$	ADD.W	D4,#12+4	COMP.W	D1,D4	JUMP',HS NEXT2$	SWAP.W	D1	SWAP.W	D4	SUB.W	D4,#6+12	COMP.W	D1,D4	JUMP',LO NEXT1$	ADD.W	D4,#12	COMP.W	D1,D4	JUMP',LO INC$	ADD.W	D4,#12	COMP.W	D1,D4	JUMP',LO DEC$NEXT1$:	SWAP.W	D1NEXT2$:	LOAD.L	A2,#(A2)+LDB	; A2 <-- ^suivant	INC.W	D0		; D0 <-- rang suivant	JUMP	LOOP$INC$:	LOAD.W	D1,(A2)+ODBINC	; D1 <-- +incrment	JUMP'	MOD$DEC$:	LOAD.W	D1,(A2)+ODBINC	NEG.W	D1		; D1 <-- -incrment;	JUMP'	MOD$MOD$:	PUSH.L	D4	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	POP.L	D3	SUB.W	D3,#12	SWAP.W	D3	SUB.W	D3,#12+1+4	LOAD.L	D4,#H'10000*13+15	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	; allume +/-	PUSHM.L	D3,D4	CALL	DBOXCLICINC	; incrmente le paramtre	LOAD.W	D2,#20		; D2 <-- premier dlaiMLOOP$:	LOAD.W	D4,D2	NTREL	?SETTIM	LIB	?GETCAR		; attend souris ...	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP',EQ MEND$	CALL	DBOXCLICINC	; incrmente le paramtre	LOAD.W	D2,#8		; D2 <-- dlai de rptition	JUMP	MLOOP$MEND$:	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	POPM.L	D3,D4	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	; teint +/-	LOAD.W	D2,D0		; D2 <-- rang	CALL	DBOXMEDIT	ADD.L	SP,#2		; POP.W D2 bidon	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$ERROR$:	POP.W	D2	CALL	DBOXGET		; A3/A4 <-- ^dbut/ligne	LOAD.W	D7,#1		; D7 <-- erreurEXIT$:	POPM.L	D0,D1,D3,D4,A0,A2	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBOXCLICINC >;------------/; Incrmente un paramtre.; in	A2.L	^dans table dbox;	D5.L	canal dbox;	D1.W	+/- incrment;	D0.W	rang; out	A3.L	^dbut ligne;	A4.L	^curseur dans ligne; mod	D7.W, A3.L, A4.LDBOXCLICINC:	PUSHM.L	D2..D4	LOAD.W	D2,(A2)+ODBOFF	; D2 <-- offset variable	LOAD.W	D4,(A5)+(D2.W)	; D4 <-- nombre initial	COMP.B	(A2)+ODBTYP+1,#DBTYPNF	JUMP',EQ NUMF1$	COMP.B	(A2)+ODBTYP+1,#DBTYPUF	JUMP',NE NUMF2$NUMF1$:	COMP.W	D4,#-1	JUMP',NE NUMF2$	CLR.W	D4NUMF2$:	ADD.W	D4,D1		; D4 <-- +/- incrment	LOAD.W	D3,(A2)+ODBMIN	TEST.B	(A2)+ODBTYP+0:#14-8	JUMP',BC PUTNUM1$	LOAD.W	D3,(A5)+(D3.W)PUTNUM1$:	COMP.W	D4,D3	JUMP',GE PUTNUM2$	LOAD.W	D4,D3PUTNUM2$:	LOAD.W	D3,(A2)+ODBMAX	TEST.B	(A2)+ODBTYP+0:#15-8	JUMP',BC PUTNUM3$	LOAD.W	D3,(A5)+(D3.W)PUTNUM3$:	COMP.W	D4,D3	JUMP',LE PUTNUM4$	LOAD.W	D4,D3PUTNUM4$:	COMP.B	(A2)+ODBTYP+1,#DBTYPNF	JUMP',EQ NUMF3$	COMP.B	(A2)+ODBTYP+1,#DBTYPUF	JUMP',NE NUMF4$NUMF3$:	TEST.W	D4	JUMP',NE NUMF4$	DEC.W	D4		; D4 <-- -1NUMF4$:	LOAD.W	D3,D2	COMP.W	D4,(A5)+(D3.W)	JUMP',EQ EXIT$	TEST.L	(A6)+ODBPTA	JUMP',EQ CLR$	LOAD.W	D2,#CLRDOT	LOAD.L	A3,(A6)+ODBPTA	CALL	(A3)		; teint l'affichageCLR$:	LOAD.W	(A5)+(D3.W),D4	; mj. le nombre	TEST.L	(A6)+ODBPTA	JUMP',EQ SET$	LOAD.W	D2,#SETDOT	LOAD.L	A3,(A6)+ODBPTA	CALL	(A3)		; rallume l'affichageSET$:	LOAD.W	D2,D0		; D2 <-- rang	CALL	DBOXGET		; A3/A4 <-- ^dbut/ligne	PUSH.W	(A2)+ODBINC	CLR.W	(A2)+ODBINC	; pour ne pas rafficher +/- !	CALL	DBOXAFF		; affiche la nouvelle valeur	POP.W	(A2)+ODBINCEXIT$:	POPM.L	D2..D4	RET;--------\\; DBOXAFF >;========/; Affiche un paramtre ditable.; in	A3.L	^dbut ligne;	D2.W	rang (0..n);	D5.L	canal dbox; out	-; mod	D7.WDBOXAFF:	PUSHM.L	D2..D4,A0,A2..A4	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre	COMP.W	D2,#-1	JUMP,EQ EXIT$	LOAD.L	A2,(A6)+ODBPTE	; A2 <-- ^table dbox	MUL.WU	D2,#LDB	ADD.L	A2,D2	LOAD.W	D2,(A2)+ODBRGC	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A4,A3	LOAD.W	D3,#-1CNT$:	INC.W	D3		; D3 <-- nombre de caractres	TEST.B	(A4+)	JUMP,NE CNT$	COMP.W	D3,(A2)+ODBNBC	; y'a-t-il assez de place pour tout afficher ?	JUMP',HS LONG$		; non => LONG$	LIB	?AFTEXT		; affiche le texte	LOAD.W	D2,(A2)+ODBNBC	SUB.W	D2,D3	LOAD.B	D3,#MSPACE	LIB	?AFCAR	LOAD.B	D3,D2	LIB	?AFCAR		; efface la fin	JUMP'	INC$LONG$:	SUB.W	D3,(A2)+ODBNBC	ADD.W	D3,#1+1	ADD.W	A3,D3		; A3 <-- saute le dbut	LOAD.B	D3,#5!2^7	LIB	?AFCODE		; affiche "<" invers	LOAD.W	D3,(A2)+ODBNBC	SUB.W	D3,#1+1	LIB	?STRING		; affiche la fin du texte	LIB	?AFSPACEINC$:	TEST.W	(A2)+ODBINC	; +/- incrment existe ?	JUMP',EQ EXIT$		; non => EXIT$	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWMATRIX	ADD.W	D4,(A0)+ODFCX	ADD.W	D4,#5	SWAP.W	D4	SUB.W	D4,#6+12;	SWAP.W	D4	LOAD.L	(A3)+1,D4	LOAD.L	A4,#R16"MATRIX$	LOAD.L	(A3)+5,A4	LOAD.B	(A3)+9,#SETDOT	LOAD.W	D3,#10	LIB	?STRINGEXIT$:	POPM.L	D2..D4,A0,A2..A4	RETMATRIX$:	.B	16,25	.W	B'0000000100000000	.W	B'0000001010000000	.W	B'0000010001000000	.W	B'0000100000100000	.W	B'0001000000010000	.W	B'0010000000001000	.W	B'0111100000111100	.W	B'0000100100100000	.W	B'0000101110100000	.W	B'0000100100100000	.W	B'0000100000100000	.W	B'0000111111100000	.W	B'0000000000000000	.W	B'0000111111100000	.W	B'0000100000100000	.W	B'0000100000100000	.W	B'0000101110100000	.W	B'0000100000100000	.W	B'0111100000111100	.W	B'0010000000001000	.W	B'0001000000010000	.W	B'0000100000100000	.W	B'0000010001000000	.W	B'0000001010000000	.W	B'0000000100000000;--------\\; DBOXGET >;========/; Donne le contenu d'un paramtre ditable.; in	D2.W	rang (0..n);	D5.L	canal dbox;	A5.L	^variables pour put/get; out	A3.L	^dbut ligne;	A4.L	^curseur dans ligne; mod	D7.W, A3.L, A4.LDBOXGET:	PUSHM.L	D2..D4,D6,A1,A2	LOAD.L	A3,#(A6)+ODBLIN	LOAD.L	A4,A3	CLR.B	(A4)	COMP.W	D2,#-1	JUMP,EQ EXIT$	LOAD.L	A2,(A6)+ODBPTE	; A2 <-- ^table dbox	MUL.WU	D2,#LDB	ADD.L	A2,D2	LOAD.W	D2,(A2)+ODBOFF	; D2 <-- offset variable	COMP.B	(A2)+ODBTYP+1,#DBTYPN	JUMP',EQ NUM$	COMP.B	(A2)+ODBTYP+1,#DBTYPU	JUMP',EQ UNIT$	COMP.B	(A2)+ODBTYP+1,#DBTYPNS	JUMP',EQ NUMS$	COMP.B	(A2)+ODBTYP+1,#DBTYPNF	JUMP,EQ NUMF$	COMP.B	(A2)+ODBTYP+1,#DBTYPUF	JUMP,EQ UNITF$	COMP.B	(A2)+ODBTYP+1,#DBTYPUS	JUMP,EQ UNITS$	COMP.B	(A2)+ODBTYP+1,#DBTYPA	JUMP,EQ ALPHA$	JUMP	EXIT$NUM$:	CLR.L	D4	LOAD.W	D4,(A5)+(D2.W)	; D4 <-- nombre	CALL	PUTANUM		; ODBLIN <-- nombre	CLR.B	(A4)	JUMP	EXIT$UNIT$:	LOAD.W	D4,(A5)+(D2.W)	; D4 <-- nombre	CALL	PUTUNUM		; ODBLIN <-- nombre et unit	CLR.B	(A4)	JUMP	EXIT$NUMS$:	LOAD.B	D3,#'+	CLR.L	D4	LOAD.W	D4,(A5)+(D2.W)	; D4 <-- nombre	JUMP',NC NUMSP$	NEG.W	D4	LOAD.B	D3,#'-NUMSP$:	LOAD.B	(A4+),D3	; ODBLIN <-- signe (+/-)	CALL	PUTANUM		; ODBLIN <-- nombre	CLR.B	(A4)	JUMP	EXIT$NUMF$:	CLR.L	D4	LOAD.W	D4,(A5)+(D2.W)	; D4 <-- nombre	JUMP',NS NUMF2$	CALL	PUTANUM		; ODBLIN <-- nombreNUMF2$:	CLR.B	(A4)	JUMP'	EXIT$UNITF$:	LOAD.W	D4,(A5)+(D2.W)	; D4 <-- nombre	JUMP',NS UNITF2$	CALL	PUTUNUM		; ODBLIN <-- nombre et unitUNITF2$:	CLR.B	(A4)	JUMP'	EXIT$UNITS$:	LOAD.B	D3,#'+	LOAD.W	D4,(A5)+(D2.W)	; D4 <-- nombre	JUMP',NC UNITSP$	NEG.W	D4	LOAD.B	D3,#'-UNITSP$:	LOAD.B	(A4+),D3	; ODBLIN <-- signe (+/-)	CALL	PUTUNUM		; ODBLIN <-- nombre et unit	CLR.B	(A4)	JUMP'	EXIT$ALPHA$:	LOAD.L	A1,#(A5)+(D2.W)	; A1 <-- ^chaneALPHA1$:	LOAD.B	(A4+),(A1+)	; ODBLIN <-- chane	JUMP,NE ALPHA1$	DEC.L	A4;	JUMP'	EXIT$EXIT$:	POPM.L	D2..D4,D6,A1,A2	RET;--------\\; DBOXPUT >;========/; Met  jour un paramtre ditable.; in	A3.L	^dbut ligne;	D2.W	rang (0..n);	D5.L	canal dbox;	A5.L	^variables pour put/get; out	D7.W	erreur; mod	D7.WDBOXPUT:	CALL	DBOXMAJ		; met  jour	JUMP',NE EXIT$	PUSHM.L	A3,A4	CALL	DBOXGET		; A3 <-- ^paramtre	CALL	DBOXAFF		; raffiche correctement	POPM.L	A3,A4	CLR.W	D7		; D7 <-- okEXIT$:	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBOXMAJ >;--------/; Met  jour un paramtre ditable.; in	A3.L	^dbut ligne;	D2.W	rang (0..n);	D5.L	canal dbox;	A5.L	^variables pour put/get; out	D7.W	erreur; mod	D7.WDBOXMAJ:	PUSHM.L	D2..D4,D6,A2..A4	CLR.W	D7		; D7 <-- ok	COMP.W	D2,#-1	JUMP,EQ EXIT$	LOAD.L	A2,(A6)+ODBPTE	; A2 <-- ^table dbox	MUL.WU	D2,#LDB	ADD.L	A2,D2	LOAD.W	D2,(A2)+ODBOFF	; D2 <-- offset variable	COMP.B	(A2)+ODBTYP+1,#DBTYPN	JUMP',EQ NUM$	COMP.B	(A2)+ODBTYP+1,#DBTYPU	JUMP,EQ UNIT$	COMP.B	(A2)+ODBTYP+1,#DBTYPNS	JUMP,EQ NUMS$	COMP.B	(A2)+ODBTYP+1,#DBTYPNF	JUMP,EQ NUMF$	COMP.B	(A2)+ODBTYP+1,#DBTYPUF	JUMP,EQ UNITF$	COMP.B	(A2)+ODBTYP+1,#DBTYPUS	JUMP,EQ UNITS$	COMP.B	(A2)+ODBTYP+1,#DBTYPA	JUMP,EQ ALPHA$	LOAD.W	D7,#ERSYNT	; D7 <-- erreur	JUMP	EXIT$NUM$:	LOAD.L	A4,A3	CALL	GETANUM		; D4 <-- nombre	LOAD.W	D7,#ERSYNT	TEST.B	(A4)		; fin du nombre ?	JUMP,NE EXIT$		; non => EXIT$PUTNUM$:	LOAD.W	D3,(A2)+ODBMIN	TEST.B	(A2)+ODBTYP+0:#14-8	JUMP',BC PUTNUM1$	LOAD.W	D3,(A5)+(D3.W)PUTNUM1$:	COMP.W	D4,D3	JUMP',GE PUTNUM2$	LOAD.W	D4,D3PUTNUM2$:	LOAD.W	D3,(A2)+ODBMAX	TEST.B	(A2)+ODBTYP+0:#15-8	JUMP',BC PUTNUM3$	LOAD.W	D3,(A5)+(D3.W)PUTNUM3$:	COMP.W	D4,D3	JUMP',LE PUTNUM4$	LOAD.W	D4,D3PUTNUM4$:	LOAD.W	(A5)+(D2.W),D4	; mj. le nombre	CLR.W	D7		; D7 <-- ok	JUMP	EXIT$UNIT$:	LOAD.L	A4,A3	CALL	GETUNUM		; D4 <-- nombre	LOAD.W	D7,#ERSYNT	TEST.B	(A4)		; fin du nombre ?	JUMP,NE EXIT$		; non => EXIT$	JUMP	PUTNUM$NUMS$:	LOAD.L	A4,A3	LOAD.B	D3,#'-	COMP.B	D3,(A4+)	JUMP',EQ NUMS2$	LOAD.B	D3,#'+	COMP.B	D3,(A4)-1	JUMP',EQ NUMS2$	DEC.L	A4NUMS2$:	CALL	GETANUM		; D4 <-- nombre	LOAD.W	D7,#ERSYNT	TEST.B	(A4)		; fin du nombre ?	JUMP,NE EXIT$		; non => EXIT$	COMP.B	D3,#'-	JUMP,NE PUTNUM$	NEG.W	D4	JUMP	PUTNUM$NUMF$:	LOAD.L	A4,A3	LOAD.W	D4,#-1	TEST.B	(A4)	JUMP,EQ PUTNUM4$	CALL	GETANUM		; D4 <-- nombre	LOAD.W	D7,#ERSYNT	TEST.B	(A4)		; fin du nombre ?	JUMP,NE EXIT$		; non => EXIT$	JUMP	PUTNUM$UNITF$:	LOAD.L	A4,A3	LOAD.W	D4,#-1	TEST.B	(A4)	JUMP,EQ PUTNUM4$	CALL	GETUNUM		; D4 <-- nombre	LOAD.W	D7,#ERSYNT	TEST.B	(A4)		; fin du nombre ?	JUMP',NE EXIT$		; non => EXIT$	JUMP	PUTNUM$UNITS$:	LOAD.L	A4,A3	LOAD.B	D3,#'-	COMP.B	D3,(A4+)	JUMP',EQ UNITS2$	LOAD.B	D3,#'+	COMP.B	D3,(A4)-1	JUMP',EQ UNITS2$	DEC.L	A4UNITS2$:	CALL	GETUNUM		; D4 <-- nombre	LOAD.W	D7,#ERSYNT	TEST.B	(A4)		; fin du nombre ?	JUMP,NE EXIT$		; non => EXIT$	COMP.B	D3,#'-	JUMP,NE PUTNUM$	NEG.W	D4	JUMP	PUTNUM$ALPHA$:	LOAD.L	A4,#(A5)+(D2.W)	; A4 <-- ^chaneALPHA1$:	LOAD.B	(A4+),(A3+)	; mj. chane	JUMP,NE ALPHA1$	CLR.W	D7		; D7 <-- ok;	JUMP'	EXIT$EXIT$:	POPM.L	D2..D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;----------\; DBOXHLINE >;==========/; Trace une ligne horizontale dans une dbox.; in	D2.W	rang de l'objet; out	D3.L	position d'arrive; mod	D3.L, D7.WDBOXHLINE:	PUSHM.L	D2,D4,A4	LIB	?GETPDIS	; A4 <-- ^descripteur fentre	DBOX_	GETCO	CLR.W	D3	SWAP.W	D3	SUB.W	D3,#4	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,(A4)+ODFFDX	LOAD.W	D2,#SETDOT	LIB	?DRSEG	POPM.L	D2,D4,A4	RET;--------\\; DBOXRSK >;========/; Refait les soft-keys.; in	A2.L	^table DBOX; out	-; mod	D7.WDBOXRSK:	PUSHM.L	D3,A3	LOAD.W	D3,(A2)+2	LOAD.L	A3,#(A2)+(D3.W)	LIB	?AFMENU		; refait les soft-keys	POPM.L	D3,A3	RET;------------\\; DBOXIMALOAD >;============/; Charge une image en mmoire.; in	A3.L	^nom de l'image; out	A4.L	^image;	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	A4.L, D7.W, A4.LDBOXIMALOAD:	PUSHM.L	D0,D1,D3,D6,A1..A3,A5	CALL	WAITMOUSE	; souris: met le sablier	LOAD.L	A5,A3		; A5 <-- ^nom de l'image	LOAD.L	D4,#LGHIMA	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour l'en-tte	JUMP,NE EXIT$	LOAD.L	A2,A4		; A2 <-- ^en-tte	LOAD.W	D3,#2^BOPRD!2^BOPSYS ; D3 <-- mode d'ouverture	FOS	?OPEN		; ouvre l'image	JUMP,NE 84$	LOAD.L	A4,A2	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 82$	COMP.B	(A2)+OIMTYP,#H'82 ; image du LAMI ?	JUMP',NE 20$		; non => 20$				; oui =>	CLR.B	D3	LOAD.L	D4,#256	FOS	?SPOS		; saute la stupide en-tte de 256 bytes !	JUMP,NE 82$	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 82$20$:	LOAD.W	D0,(A2)+OIMDLX	; D0 <-- largeur de l'image	LOAD.W	D1,(A2)+OIMDLY	; D1 <-- hauteur de l'image	LOAD.W	D4,D0	SR.W	D4,#3	MUL.WU	D4,D1		; D4 <-- largeur*hauteur/8	ADD.L	D4,#IMLBUF	; D4 <-- rserve pour codage	PUSH.W	D1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour toute l'image	POPM.W	D1	JUMP,NE 82$	LOAD.L	A1,#(A4)+IMLBUF	; A1 <-- ^image	LOAD.L	D4,(A2)+OIMNBB	; D4 <-- longueur  lire	TEST.B	(A2)+OIMCOD	; image code ?	JUMP',NE 30$		; oui => 30$				; non =>	LOAD.L	A4,A1	FOS	?RDBYTE		; lit toute l'image dcode	JUMP,NE 80$	JUMP'	35$30$:	FOS	?RDBYTE		; lit toute l'image code	JUMP',NE 80$	LOAD.L	A3,A1	GRA_	DECOIMA		; dcode l'image ...	JUMP',NE 80$35$:	LOAD.L	A4,A1		; A4 <-- ^image	LOAD.W	D4,D1	SWAP.W	D4	LOAD.W	D4,D0		; D4 <-- dimensions de l'image	CLR.W	D7		; D7 <-- ok	JUMP'	82$80$:	PUSH.W	D7	LOAD.L	A4,#(A1)-IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'image	POP.W	D782$:	PUSH.W	D7	FOS	?CLOSE		; ferme l'image	POP.W	D784$:	PUSHM.L	D7,A4	LOAD.L	A4,A2	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend le buffer pour l'en-tete	POPM.L	D7,A4EXIT$:	POPM.L	D0,D1,D3,D6,A1..A3,A5	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBOXIMASHOW >;============/; Affiche une image dans la (sous-)fentre.; Si elle est trop petite, elle est centre au milieu de l'cran.; Si elle est trop grande, on affiche sa partie centrale.; in	A4.L	^image;	D4.L	dimensions (dy;dx);	D3.L	coin sup/gauche (y;x); out	-; mod	D7.WDBOXIMASHOW:	PUSHM.L	D0,D1,D3,D4,A3	LOAD.W	D0,D4		; D0 <-- largeur de l'image	SWAP.W	D4	LOAD.W	D1,D4		; D1 <-- hauteur de l'image	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^buffer pour DRAWRASTER	LOAD.W	(A3)+12,D3	; destination: <xx>	SWAP.W	D3	LOAD.W	(A3)+14,D3	; destination: <yy>	LOAD.W	D3,D0	SR.W	D3,#3	LOAD.W	(A3)+10,D3	; source: <ii>	CLR.W	(A3)+20		; destination: <ii>	CLR.W	(A3)+2		; source: <xx>	LOAD.W	(A3)+22,D0	; image: <dxx>	CLR.W	(A3)+4		; source: <yy>	LOAD.W	(A3)+24,D1	; image: <dyy>	LOAD.W	(A3)+0,#DRAWRASTER	LOAD.L	(A3)+6,A4	; source: <pppp>	CLR.L	(A3)+16		; destination: <pppp>	LOAD.B	(A3)+26,#SETDOT	; image: <mode>	LOAD.W	D3,#1+26	; D3 <-- longueur	LIB	?STRING		; affiche l'image	POPM.L	D0,D1,D3,D4,A3	RET;------------\\; DBOXIMAKILL >;============/; Libre la mmoire d'une image.; in	A4.L	^image; out	-; mod	-DBOXIMAKILL:	PUSHM.L	D1,D7,A4	LOAD.L	A4,#(A4)-IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'image	POPM.L	D1,D7,A4	RET; Tables; ------TDBOX_IO:	.ASCIZ	"PAGE"		; nom du logiciel	.ASCIZ	"Fpage"		; [M,F] nom des lments manipuls	.ASCIZ	""		; [M,F] nom du contenant	.B	0TDBOX_IOL:	.ASCIZ	"PAGE"		; nom du logiciel	.ASCIZ	"Fpartie de page" ; [M,F] nom des lments manipuls	.ASCIZ	""		; [M,F] nom du contenant	.B	0	.EVEN; Noms de fichiers; ----------------TEXPA:	.ASCIZ	".page"		; extension des fichiers pagesTEXLPA:	.ASCIZ	".lpage"	; extension des fichiers parties de pagesTEXIM:	.ASCIZ	".image"	; extension des fichiers imagesTEXDF:	.ASCIZ	".xcar"		; extension des fichiers df.TEXEX:	.ASCIZ	".lpage"	.ASCIZ	".image"	.B	0	.EVENDOKCR:	LOAD.W	D3,#CR	RETDOKEND:	LOAD.W	D3,#END	RETDOKOUI:	LOAD.W	D3,#'O	RETDOKNON:	LOAD.W	D3,#'N	RETDOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RETDOKF2:	LOAD.W	D3,#F2	RETDOKF3:	LOAD.W	D3,#F3	RETDOKF4:	LOAD.W	D3,#F4	RETDOKF5:	LOAD.W	D3,#F5	RETDOKF6:	LOAD.W	D3,#F6	RETDOKF7:	LOAD.W	D3,#F7	RETDOKF8:	LOAD.W	D3,#F8	RETDOKF9:	LOAD.W	D3,#F9	RETDOKF10:	LOAD.W	D3,#F10	RETDOKF11:	LOAD.W	D3,#F11	RETDOKF12:	LOAD.W	D3,#F12	RETDOKF13:	LOAD.W	D3,#F13	RETDOKF14:	LOAD.W	D3,#F14	RETDOKF15:	LOAD.W	D3,#F15	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RETDOKMGP:	LOAD.W	D3,#KEYMGP	RET	.END