	.SBTTL	PAGEZONE.ASI;------------\\; ZONEQREDUCE >;============/; Calcule une zone rduite au minimum permettant d'englober; tous les objets slectionns.; in	-; out	-; mod	D7.WZONEQREDUCE:	PUSHM.L	D1,D2	CALL	ZONEQREDP1P2	; D1/D2 <-- P1/P2	LOAD.L	(A6)+OZONB1,D1	LOAD.L	(A6)+OZONB2,D2	LOAD.L	(A6)+OZONY1,D1	LOAD.L	(A6)+OZONY2,D2	LOAD.W	(A6)+OZONX4,D1	LOAD.W	(A6)+OZONX3,D2	SWAP.W	D1	SWAP.W	D2	LOAD.W	(A6)+OZONY3,D1	LOAD.W	(A6)+OZONY4,D2	LOAD.W	D2,(A6)+OZONX1	SUB.W	D2,(A6)+OZONX2	ASR.W	D2,#1	ADD.W	D2,(A6)+OZONX2	LOAD.W	(A6)+OZONXC,D2	LOAD.W	D2,(A6)+OZONY1	SUB.W	D2,(A6)+OZONY2	ASR.W	D2,#1	ADD.W	D2,(A6)+OZONY2	LOAD.W	(A6)+OZONYC,D2	POPM.L	D1,D2	RET;-------------\\; ZONEQREDP1P2 >;=============/; Calcule une zone rduite au minimum permettant d'englober; tous les objets slectionns.; in	-; out	D1.L	P1 (y;x);	D2.L	P2 (y;x); mod	D1.L, D2.L, D7.WZONEQREDP1P2:	PUSHM.L	D3,D4,A4	PUSH.L	(A6)+OAPOS	LOAD.L	D1,#H'7FFF7FFF	LOAD.L	D2,#H'80008000	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE END$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	CALL	_LSTA_BBOXQ	; D3/D4 <-- bbox	CALL	_RECTOR		; D3/D4 <-- rectangle enblobant	LOAD.L	D1,D3	LOAD.L	D2,D4NEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$END$:	POP.L	(A6)+OAPOS	POPM.L	D3,D4,A4	RET;-------------\\; ZONEQHDETECT >;=============/; Dtecte dans quelle poigne est la souris.; in	D4.L	position de la souris (y;x)  [scr]; out	D2.W	rang de la poigne (0..n);	D7.W	erreur; mod	D2.L, D7.WZONEQHDETECT:	PUSHM.L	D3..D6	LOAD.W	D5,D4		; D5 <-- position en X	LOAD.L	D6,D4	SWAP.W	D6		; D6 <-- position en Y	CLR.W	D2		; D2 <-- rang de la poigneLOOP$:	CALL	ZONEQHPOS	; D3/D4 <-- type/position	JUMP',NE NEXT$	CALL	_CONVOBJSCR	; D4 <-- position [scr]	JUMP',NE NEXT$	SUB.W	D4,#DPOIGNEE	COMP.W	D5,D4		; trop  gauche ?	JUMP',LT NEXT$	ADD.W	D4,#DPOIGNEE*2	COMP.W	D5,D4		; trop  droite ?	JUMP',GE NEXT$	SWAP.W	D4	SUB.W	D4,#DPOIGNEE	COMP.W	D6,D4		; trop haut ?	JUMP',LT NEXT$	ADD.W	D4,#DPOIGNEE*2	COMP.W	D6,D4		; trop bas ?	JUMP',LT EXIT$NEXT$:	INC.W	D2		; D2 <-- poigne suivante	COMP.W	D2,#13	JUMP,LO LOOP$	LOAD.W	D7,#ERPAHANDENDEXIT$:	POPM.L	D3..D6	TEST.W	D7		; retour EQ/NE	RET;----------\\; ZONEQHPOS >;==========/; Donne le type et la position d'une poigne.; in	D2.W	rang (0..n); out	D3.W	type de la poigne (ICOHAND*);	D4.L	position (y;x);	D7.W	erreur; mod	D3.L, D4.L, D7.WZONEQHPOS:	LOAD.W	D7,#1		; D7 <-- poigne n'existe pas	COMP.W	(A6)+OOPER,#ICOZMIROIR	JUMP,EQ EXIT$	TEST.W	D2	JUMP,EQ CDG$	LOAD.W	D3,#ICOHANDEXT	LOAD.L	D4,(A6)+OZONY1	COMP.W	D2,#1	JUMP,EQ OK$	LOAD.L	D4,(A6)+OZONY2	COMP.W	D2,#2	JUMP,EQ OK$	LOAD.L	D4,(A6)+OZONY3	COMP.W	D2,#3	JUMP,EQ OK$	LOAD.L	D4,(A6)+OZONY4	COMP.W	D2,#4	JUMP,EQ OK$	COMP.W	(A6)+OOPER,#ICOZDEFBEZ	JUMP,NE EXIT$	LOAD.W	D3,#ICOHANDSEC	COMP.W	(A6)+OZONDFB,#ICOBVERTI	JUMP',EQ BEZH$	LOAD.L	D4,(A6)+OZONY13	COMP.W	D2,#5	JUMP',EQ OK$	LOAD.L	D4,(A6)+OZONY31	COMP.W	D2,#6	JUMP',EQ OK$	LOAD.L	D4,(A6)+OZONY24	COMP.W	D2,#9	JUMP',EQ OK$	LOAD.L	D4,(A6)+OZONY42	COMP.W	D2,#10	JUMP',EQ OK$BEZH$:	COMP.W	(A6)+OZONDFB,#ICOBHORIZ	JUMP',EQ BEZV$	LOAD.L	D4,(A6)+OZONY32	COMP.W	D2,#7	JUMP',EQ OK$	LOAD.L	D4,(A6)+OZONY23	COMP.W	D2,#8	JUMP',EQ OK$	LOAD.L	D4,(A6)+OZONY41	COMP.W	D2,#11	JUMP',EQ OK$	LOAD.L	D4,(A6)+OZONY14	COMP.W	D2,#12	JUMP',EQ OK$BEZV$:	JUMP'	EXIT$CDG$:	LOAD.L	D4,(A6)+OZONYC	LOAD.W	D3,#ICOHANDFIX	COMP.W	(A6)+OOPER,#ICOZTOURNE	JUMP',EQ OK$	LOAD.W	D3,#ICOHANDCDG;	JUMP'	OK$OK$:	CLR.W	D7		; D7 <-- poigne existeEXIT$:	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ZONEQHDRAG >;===========/; Dplace une poigne.; in	D4.L	position de la souris (y;x)  [obj];	D2.W	rang de la poigne  dplacer (0..n);	A1.L	^routine ZONEMOVED*; out	D3.L	touche;	D7.W	ok si touche presse/souris dplace; mod	D3.L, D7.WZONEQHDRAG:	PUSHM.L	D0,D1,D2,D4,A2	CALL	ZONEQCLIPB	; dbut du clipping	COMP.W	(A6)+OOPER,#ICOZZOOM	JUMP',EQ ZOOM$	COMP.W	(A6)+OOPER,#ICOZTOURNE	JUMP,EQ TOURNE$	COMP.W	(A6)+OOPER,#ICOZDEFORME	JUMP,EQ DEFORME$	COMP.W	(A6)+OOPER,#ICOZDEFBEZ	JUMP,EQ DEFBEZ$	LOAD.W	D7,#1	JUMP	EXIT$ZOOM$:	CALL	SELRECCLR	; teint la zone	TEST.W	D2	JUMP,EQ ZOOMCDG$	COMP.W	D2,#1	JUMP,EQ ZOOM1$	COMP.W	D2,#2	JUMP,EQ ZOOM2$	COMP.W	D2,#3	JUMP,EQ ZOOM3$	COMP.W	D2,#4	JUMP,EQ ZOOM4$	JUMP	ZONE$ZOOM1$:				; sup/gauche =>	TEST.B	(A6)+OZONHO	JUMP',EQ ZOOM1H$	LOAD.W	D2,(A6)+OZOOY4	SUB.W	D2,(A6)+OZOOY1	; D2 <-- dy'	LOAD.W	D1,(A6)+OZONX3	SUB.W	D1,D4		 ; D1 <-- dx	MUL.WA	D2,D1	LOAD.W	D1,(A6)+OZOOX3	SUB.W	D1,(A6)+OZOOX1	; D2 <-- dx'	DIV.WA	D2,D1		 ; D2 <-- (dy'*dx)/dx'	LOAD.W	D1,(A6)+OZONY4	SUB.W	D1,D2	SWAP.W	D4	LOAD.W	D4,D1	SWAP.W	D4ZOOM1H$:	LOAD.L	(A6)+OZONY1,D4	LOAD.W	(A6)+OZONX4,D4	SWAP.W	D4	LOAD.W	(A6)+OZONY3,D4	JUMP	ZOOMD$ZOOM3$:				; sup/droite =>	TEST.B	(A6)+OZONHO	JUMP',EQ ZOOM3H$	LOAD.W	D2,(A6)+OZOOY4	SUB.W	D2,(A6)+OZOOY1	; D2 <-- dy'	LOAD.W	D1,D4	SUB.W	D1,(A6)+OZONX1	; D1 <-- dx	MUL.WA	D2,D1	LOAD.W	D1,(A6)+OZOOX3	SUB.W	D1,(A6)+OZOOX1	; D2 <-- dx'	DIV.WA	D2,D1		 ; D2 <-- (dy'*dx)/dx'	LOAD.W	D1,(A6)+OZONY4	SUB.W	D1,D2	SWAP.W	D4	LOAD.W	D4,D1	SWAP.W	D4ZOOM3H$:	LOAD.L	(A6)+OZONY3,D4	LOAD.W	(A6)+OZONX2,D4	SWAP.W	D4	LOAD.W	(A6)+OZONY1,D4	JUMP	ZOOMD$ZOOM4$:				; inf/gauche =>	TEST.B	(A6)+OZONHO	JUMP',EQ ZOOM4H$	LOAD.W	D2,(A6)+OZOOY4	SUB.W	D2,(A6)+OZOOY1	; D2 <-- dy'	LOAD.W	D1,(A6)+OZONX3	SUB.W	D1,D4		 ; D1 <-- dx	MUL.WA	D2,D1	LOAD.W	D1,(A6)+OZOOX3	SUB.W	D1,(A6)+OZOOX1	; D2 <-- dx'	DIV.WA	D2,D1		 ; D2 <-- (dy'*dx)/dx'	ADD.W	D2,(A6)+OZONY1	SWAP.W	D4	LOAD.W	D4,D2	SWAP.W	D4ZOOM4H$:	LOAD.L	(A6)+OZONY4,D4	LOAD.W	(A6)+OZONX1,D4	SWAP.W	D4	LOAD.W	(A6)+OZONY2,D4	JUMP	ZOOMD$ZOOM2$:				; inf/droite =>	TEST.B	(A6)+OZONHO	JUMP',EQ ZOOM2H$	LOAD.W	D2,(A6)+OZOOY4	SUB.W	D2,(A6)+OZOOY1	; D2 <-- dy'	LOAD.W	D1,D4	SUB.W	D1,(A6)+OZONX1	; D1 <-- dx	MUL.WA	D2,D1	LOAD.W	D1,(A6)+OZOOX3	SUB.W	D1,(A6)+OZOOX1	; D2 <-- dx'	DIV.WA	D2,D1		 ; D2 <-- (dy'*dx)/dx'	ADD.W	D2,(A6)+OZONY1	SWAP.W	D4	LOAD.W	D4,D2	SWAP.W	D4ZOOM2H$:	LOAD.L	(A6)+OZONY2,D4	LOAD.W	(A6)+OZONX3,D4	SWAP.W	D4	LOAD.W	(A6)+OZONY4,D4;	JUMP	ZOOMD$ZOOMD$:	CALL	ZONEQCLIPE	; fin du clipping	LOAD.W	(A6)+OOPEXT,#ICOZZOOM	LOAD.L	A2,#R16"ZONERZOOM ; A2 <-- ^routine de transformation	CALL	(A1)		; zoom tous les objets	CLR.W	(A6)+OOPEXT	LOAD.W	D2,(A6)+OZONX1	SUB.W	D2,(A6)+OZONX2	ASR.W	D2,#1	ADD.W	D2,(A6)+OZONX2	LOAD.W	(A6)+OZONXC,D2	LOAD.W	D2,(A6)+OZONY1	SUB.W	D2,(A6)+OZONY2	ASR.W	D2,#1	ADD.W	D2,(A6)+OZONY2	LOAD.W	(A6)+OZONYC,D2	JUMP	ZONE3$ZOOMCDG$:	SUB.W	D4,(A6)+OZOOXC	LOAD.W	D3,(A6)+OZOOX1	ADD.W	D3,D4	LOAD.W	(A6)+OZONX1,D3	LOAD.W	D3,(A6)+OZOOX2	ADD.W	D3,D4	LOAD.W	(A6)+OZONX2,D3	LOAD.W	D3,(A6)+OZOOX3	ADD.W	D3,D4	LOAD.W	(A6)+OZONX3,D3	LOAD.W	D3,(A6)+OZOOX4	ADD.W	D3,D4	LOAD.W	(A6)+OZONX4,D3	SWAP.W	D4	SUB.W	D4,(A6)+OZOOYC	LOAD.W	D3,(A6)+OZOOY1	ADD.W	D3,D4	LOAD.W	(A6)+OZONY1,D3	LOAD.W	D3,(A6)+OZOOY2	ADD.W	D3,D4	LOAD.W	(A6)+OZONY2,D3	LOAD.W	D3,(A6)+OZOOY3	ADD.W	D3,D4	LOAD.W	(A6)+OZONY3,D3	LOAD.W	D3,(A6)+OZOOY4	ADD.W	D3,D4	LOAD.W	(A6)+OZONY4,D3	JUMP	ZOOMD$TOURNE$:	TEST.W	D2	JUMP,EQ CENTRE$	CALL	SELRECCLR	; teint la zone	COMP.W	D2,#1	JUMP',EQ TOUR1$	COMP.W	D2,#2	JUMP',EQ TOUR2$	COMP.W	D2,#3	JUMP',EQ TOUR3$	COMP.W	D2,#4	JUMP',EQ TOUR4$	JUMP	ZONE$TOUR1$:				; sup/gauche =>	LOAD.L	D3,(A6)+OZOOY1	JUMP'	TOURQ$TOUR3$:				; sup/droite =>	LOAD.L	D3,(A6)+OZOOY3	JUMP'	TOURQ$TOUR4$:				; inf/gauche =>	LOAD.L	D3,(A6)+OZOOY4	JUMP'	TOURQ$TOUR2$:				; inf/droite =>	LOAD.L	D3,(A6)+OZOOY2;	JUMP'	TOURQ$TOURQ$:	CALL	XTOURNE		; D2 <-- angle de rotation	LOAD.W	(A6)+OZONAN,D2	LOAD.L	D3,(A6)+OZOOY1	CALL	QTOURNE	LOAD.L	(A6)+OZONY1,D3	LOAD.L	D3,(A6)+OZOOY3	CALL	QTOURNE	LOAD.L	(A6)+OZONY3,D3	LOAD.L	D3,(A6)+OZOOY4	CALL	QTOURNE	LOAD.L	(A6)+OZONY4,D3	LOAD.L	D3,(A6)+OZOOY2	CALL	QTOURNE	LOAD.L	(A6)+OZONY2,D3	CALL	ZONEQCLIPE	; fin du clipping	LOAD.W	(A6)+OOPEXT,#ICOZTOURNE	LOAD.L	A2,#R16"ZONERTOURNE ; A2 <-- ^routine de transformation	CALL	(A1)		; tourne tous les objets	CLR.W	(A6)+OOPEXT	JUMP	ZONE3$CENTRE$:	LOAD.L	D1,D4	LOAD.L	D3,(A6)+OZONYC	LOAD.W	D4,#7	LOAD.W	D2,#INVDOT	CALL	DRCROIX		; teint l'ancienne croix	LOAD.L	(A6)+OZONYC,D1	LOAD.L	(A6)+OPOIMCC,D1	LOAD.L	D3,D1;	LOAD.W	D4,#7;	LOAD.W	D2,#INVDOT	CALL	DRCROIX		; allume la nouvelle croix	LOAD.W	D7,#1	JUMP	EXIT$DEFORME$:	CALL	SELRECCLR	; teint la zone	TEST.W	D2	JUMP,EQ DEFCDG$	COMP.W	D2,#1	JUMP',EQ DEF1$	COMP.W	D2,#2	JUMP',EQ DEF2$	COMP.W	D2,#3	JUMP',EQ DEF3$	COMP.W	D2,#4	JUMP',EQ DEF4$	JUMP	ZONE$DEF1$:				; sup/gauche =>	LOAD.L	(A6)+OZONY1,D4	JUMP'	DEF$DEF2$:				; inf/droite =>	LOAD.L	(A6)+OZONY2,D4	JUMP'	DEF$DEF3$:				; sup/droite =>	LOAD.L	(A6)+OZONY3,D4	JUMP'	DEF$DEF4$:				; inf/gauche =>	LOAD.L	(A6)+OZONY4,D4;	JUMP'	DEF$DEF$:	COMP.W	(A6)+OZONDF,#ICODTRAH	JUMP',EQ DEFTH$	COMP.W	(A6)+OZONDF,#ICODTRAV	JUMP,EQ DEFTV$	COMP.W	(A6)+OZONDF,#ICODPARH	JUMP,EQ DEFPH$	COMP.W	(A6)+OZONDF,#ICODPARV	JUMP,EQ DEFPV$	JUMP	DEFGO$DEFTH$:	COMP.W	D2,#4	JUMP',EQ DEFTH4$	COMP.W	D2,#3	JUMP',EQ DEFTH3$	COMP.W	D2,#2	JUMP',EQ DEFTH2$DEFTH1$:	SUB.W	D4,(A6)+OZOOX1	NEG.W	D4	ADD.W	D4,(A6)+OZOOX3	LOAD.W	(A6)+OZONX3,D4	LOAD.W	(A6)+OZONY3,(A6)+OZONY1	JUMP	DEFGO$DEFTH2$:	SUB.W	D4,(A6)+OZOOX2	NEG.W	D4	ADD.W	D4,(A6)+OZOOX4	LOAD.W	(A6)+OZONX4,D4	LOAD.W	(A6)+OZONY4,(A6)+OZONY2	JUMP	DEFGO$DEFTH3$:	SUB.W	D4,(A6)+OZOOX3	NEG.W	D4	ADD.W	D4,(A6)+OZOOX1	LOAD.W	(A6)+OZONX1,D4	LOAD.W	(A6)+OZONY1,(A6)+OZONY3	JUMP	DEFGO$DEFTH4$:	SUB.W	D4,(A6)+OZOOX4	NEG.W	D4	ADD.W	D4,(A6)+OZOOX2	LOAD.W	(A6)+OZONX2,D4	LOAD.W	(A6)+OZONY2,(A6)+OZONY4	JUMP	DEFGO$DEFTV$:	SWAP.W	D4	COMP.W	D2,#4	JUMP',EQ DEFTV4$	COMP.W	D2,#3	JUMP',EQ DEFTV3$	COMP.W	D2,#2	JUMP',EQ DEFTV2$DEFTV1$:	SUB.W	D4,(A6)+OZOOY1	NEG.W	D4	ADD.W	D4,(A6)+OZOOY4	LOAD.W	(A6)+OZONY4,D4	LOAD.W	(A6)+OZONX4,(A6)+OZONX1	JUMP	DEFGO$DEFTV2$:	SUB.W	D4,(A6)+OZOOY2	NEG.W	D4	ADD.W	D4,(A6)+OZOOY3	LOAD.W	(A6)+OZONY3,D4	LOAD.W	(A6)+OZONX3,(A6)+OZONX2	JUMP	DEFGO$DEFTV3$:	SUB.W	D4,(A6)+OZOOY3	NEG.W	D4	ADD.W	D4,(A6)+OZOOY2	LOAD.W	(A6)+OZONY2,D4	LOAD.W	(A6)+OZONX2,(A6)+OZONX3	JUMP	DEFGO$DEFTV4$:	SUB.W	D4,(A6)+OZOOY4	NEG.W	D4	ADD.W	D4,(A6)+OZOOY1	LOAD.W	(A6)+OZONY1,D4	LOAD.W	(A6)+OZONX1,(A6)+OZONX4	JUMP	DEFGO$DEFPH$:	COMP.W	D2,#4	JUMP',EQ DEFPH4$	COMP.W	D2,#3	JUMP',EQ DEFPH3$	COMP.W	D2,#2	JUMP',EQ DEFPH2$DEFPH1$:	SUB.W	D4,(A6)+OZOOX1	ADD.W	D4,(A6)+OZOOX3	LOAD.W	(A6)+OZONX3,D4	LOAD.W	(A6)+OZONY3,(A6)+OZONY1	JUMP	DEFGO$DEFPH2$:	SUB.W	D4,(A6)+OZOOX2	ADD.W	D4,(A6)+OZOOX4	LOAD.W	(A6)+OZONX4,D4	LOAD.W	(A6)+OZONY4,(A6)+OZONY2	JUMP	DEFGO$DEFPH3$:	SUB.W	D4,(A6)+OZOOX3	ADD.W	D4,(A6)+OZOOX1	LOAD.W	(A6)+OZONX1,D4	LOAD.W	(A6)+OZONY1,(A6)+OZONY3	JUMP	DEFGO$DEFPH4$:	SUB.W	D4,(A6)+OZOOX4	ADD.W	D4,(A6)+OZOOX2	LOAD.W	(A6)+OZONX2,D4	LOAD.W	(A6)+OZONY2,(A6)+OZONY4	JUMP	DEFGO$DEFPV$:	SWAP.W	D4	COMP.W	D2,#4	JUMP',EQ DEFPV4$	COMP.W	D2,#3	JUMP',EQ DEFPV3$	COMP.W	D2,#2	JUMP',EQ DEFPV2$DEFPV1$:	SUB.W	D4,(A6)+OZOOY1	ADD.W	D4,(A6)+OZOOY4	LOAD.W	(A6)+OZONY4,D4	LOAD.W	(A6)+OZONX4,(A6)+OZONX1	JUMP	DEFGO$DEFPV2$:	SUB.W	D4,(A6)+OZOOY2	ADD.W	D4,(A6)+OZOOY3	LOAD.W	(A6)+OZONY3,D4	LOAD.W	(A6)+OZONX3,(A6)+OZONX2	JUMP	DEFGO$DEFPV3$:	SUB.W	D4,(A6)+OZOOY3	ADD.W	D4,(A6)+OZOOY2	LOAD.W	(A6)+OZONY2,D4	LOAD.W	(A6)+OZONX2,(A6)+OZONX3	JUMP	DEFGO$DEFPV4$:	SUB.W	D4,(A6)+OZOOY4	ADD.W	D4,(A6)+OZOOY1	LOAD.W	(A6)+OZONY1,D4	LOAD.W	(A6)+OZONX1,(A6)+OZONX4	JUMP	DEFGO$DEFCDG$:	LOAD.L	D2,D4	SUB.W	D4,(A6)+OZONXC	ADD.W	(A6)+OZONX1,D4	ADD.W	(A6)+OZONX2,D4	ADD.W	(A6)+OZONX3,D4	ADD.W	(A6)+OZONX4,D4	SWAP.W	D4	SUB.W	D4,(A6)+OZONYC	ADD.W	(A6)+OZONY1,D4	ADD.W	(A6)+OZONY2,D4	ADD.W	(A6)+OZONY3,D4	ADD.W	(A6)+OZONY4,D4	LOAD.L	(A6)+OZONYC,D2	JUMP'	DEFGO2$DEFGO$:	LOAD.W	D2,(A6)+OZONX1	CONV.LA.WA D2	LOAD.W	D3,(A6)+OZONX2	CONV.LA.WA D3	ADD.L	D2,D3	LOAD.W	D3,(A6)+OZONX3	CONV.LA.WA D3	ADD.L	D2,D3	LOAD.W	D3,(A6)+OZONX4	CONV.LA.WA D3	ADD.L	D2,D3	ASR.L	D2,#2	LOAD.W	(A6)+OZONXC,D2	LOAD.W	D2,(A6)+OZONY1	CONV.LA.WA D2	LOAD.W	D3,(A6)+OZONY2	CONV.LA.WA D3	ADD.L	D2,D3	LOAD.W	D3,(A6)+OZONY3	CONV.LA.WA D3	ADD.L	D2,D3	LOAD.W	D3,(A6)+OZONY4	CONV.LA.WA D3	ADD.L	D2,D3	ASR.L	D2,#2	LOAD.W	(A6)+OZONYC,D2DEFGO2$:	CALL	ZONEQCLIPE	; fin du clipping	LOAD.W	(A6)+OOPEXT,#ICOZDEFORME	LOAD.L	A2,#R16"ZONERDEFORME ; A2 <-- ^routine de transformation	CALL	(A1)		; dforme tous les objets	CLR.W	(A6)+OOPEXT	JUMP	ZONE3$DEFBEZ$:	CALL	SELRECCLR	; teint la zone	TEST.W	D2	JUMP,EQ DBZCDG$	COMP.W	D2,#1	JUMP',EQ DBZ1$	COMP.W	D2,#2	JUMP,EQ DBZ2$	COMP.W	D2,#3	JUMP,EQ DBZ3$	COMP.W	D2,#4	JUMP,EQ DBZ4$	LOAD.W	D1,(A6)+OZONDFC	COMP.W	D2,#5	JUMP,EQ DBZ5$	COMP.W	D2,#6	JUMP,EQ DBZ6$	COMP.W	D2,#7	JUMP,EQ DBZ7$	COMP.W	D2,#8	JUMP,EQ DBZ8$	COMP.W	D2,#9	JUMP,EQ DBZ9$	COMP.W	D2,#10	JUMP,EQ DBZ10$	COMP.W	D2,#11	JUMP,EQ DBZ11$	COMP.W	D2,#12	JUMP,EQ DBZ12$	JUMP	ZONE$DBZ1$:				; sup/gauche =>	SUB.W	D4,(A6)+OZONX1	ADD.W	(A6)+OZONX13,D4	ADD.W	(A6)+OZONX14,D4	ADD.W	(A6)+OZONX1,D4	SWAP.W	D4	SUB.W	D4,(A6)+OZONY1	ADD.W	(A6)+OZONY13,D4	ADD.W	(A6)+OZONY14,D4	ADD.W	(A6)+OZONY1,D4	JUMP	DBZGO$DBZ2$:				; inf/droite =>	SUB.W	D4,(A6)+OZONX2	ADD.W	(A6)+OZONX23,D4	ADD.W	(A6)+OZONX24,D4	ADD.W	(A6)+OZONX2,D4	SWAP.W	D4	SUB.W	D4,(A6)+OZONY2	ADD.W	(A6)+OZONY23,D4	ADD.W	(A6)+OZONY24,D4	ADD.W	(A6)+OZONY2,D4	JUMP	DBZGO$DBZ3$:				; sup/droite =>	SUB.W	D4,(A6)+OZONX3	ADD.W	(A6)+OZONX31,D4	ADD.W	(A6)+OZONX32,D4	ADD.W	(A6)+OZONX3,D4	SWAP.W	D4	SUB.W	D4,(A6)+OZONY3	ADD.W	(A6)+OZONY31,D4	ADD.W	(A6)+OZONY32,D4	ADD.W	(A6)+OZONY3,D4	JUMP	DBZGO$DBZ4$:				; inf/gauche =>	SUB.W	D4,(A6)+OZONX4	ADD.W	(A6)+OZONX41,D4	ADD.W	(A6)+OZONX42,D4	ADD.W	(A6)+OZONX4,D4	SWAP.W	D4	SUB.W	D4,(A6)+OZONY4	ADD.W	(A6)+OZONY41,D4	ADD.W	(A6)+OZONY42,D4	ADD.W	(A6)+OZONY4,D4	JUMP	DBZGO$DBZ5$:	LOAD.L	(A6)+OZONY13,D4	LOAD.L	D3,(A6)+OZONY1	LOAD.L	D2,(A6)+OZONY3	LOAD.L	A2,#(A6)+OZONY31	CLR.W	D0		; D0 <--inverse dx	COMP.W	D1,#ICOBSYMH	JUMP,EQ DBZSEC$	LOAD.L	D2,(A6)+OZONY4	LOAD.L	A2,#(A6)+OZONY42	INC.W	D0		; D0 <--inverse dy	JUMP	DBZSEC$DBZ6$:	LOAD.L	(A6)+OZONY31,D4	LOAD.L	D3,(A6)+OZONY3	LOAD.L	D2,(A6)+OZONY1	LOAD.L	A2,#(A6)+OZONY13	CLR.W	D0		; D0 <--inverse dx	COMP.W	D1,#ICOBSYMH	JUMP,EQ DBZSEC$	LOAD.L	D2,(A6)+OZONY2	LOAD.L	A2,#(A6)+OZONY24	INC.W	D0		; D0 <--inverse dy	JUMP	DBZSEC$DBZ7$:	LOAD.L	(A6)+OZONY32,D4	LOAD.L	D3,(A6)+OZONY3	LOAD.L	D2,(A6)+OZONY2	LOAD.L	A2,#(A6)+OZONY23	LOAD.W	D0,#1		; D0 <--inverse dy	COMP.W	D1,#ICOBSYMH	JUMP,EQ DBZSEC$	LOAD.L	D2,(A6)+OZONY1	LOAD.L	A2,#(A6)+OZONY14	CLR.W	D0		; D0 <--inverse dx	JUMP	DBZSEC$DBZ8$:	LOAD.L	(A6)+OZONY23,D4	LOAD.L	D3,(A6)+OZONY2	LOAD.L	D2,(A6)+OZONY3	LOAD.L	A2,#(A6)+OZONY32	LOAD.W	D0,#1		; D0 <--inverse dy	COMP.W	D1,#ICOBSYMH	JUMP,EQ DBZSEC$	LOAD.L	D2,(A6)+OZONY4	LOAD.L	A2,#(A6)+OZONY41	CLR.W	D0		; D0 <--inverse dx	JUMP	DBZSEC$DBZ9$:	LOAD.L	(A6)+OZONY24,D4	LOAD.L	D3,(A6)+OZONY2	LOAD.L	D2,(A6)+OZONY4	LOAD.L	A2,#(A6)+OZONY42	CLR.W	D0		; D0 <--inverse dx	COMP.W	D1,#ICOBSYMH	JUMP,EQ DBZSEC$	LOAD.L	D2,(A6)+OZONY3	LOAD.L	A2,#(A6)+OZONY31	INC.W	D0		; D0 <--inverse dy	JUMP	DBZSEC$DBZ10$:	LOAD.L	(A6)+OZONY42,D4	LOAD.L	D3,(A6)+OZONY4	LOAD.L	D2,(A6)+OZONY2	LOAD.L	A2,#(A6)+OZONY24	CLR.W	D0		; D0 <--inverse dx	COMP.W	D1,#ICOBSYMH	JUMP,EQ DBZSEC$	LOAD.L	D2,(A6)+OZONY1	LOAD.L	A2,#(A6)+OZONY13	INC.W	D0		; D0 <--inverse dy	JUMP	DBZSEC$DBZ11$:	LOAD.L	(A6)+OZONY41,D4	LOAD.L	D3,(A6)+OZONY4	LOAD.L	D2,(A6)+OZONY1	LOAD.L	A2,#(A6)+OZONY14	LOAD.W	D0,#1		; D0 <--inverse dy	COMP.W	D1,#ICOBSYMH	JUMP',EQ DBZSEC$	LOAD.L	D2,(A6)+OZONY2	LOAD.L	A2,#(A6)+OZONY23	CLR.W	D0		; D0 <--inverse dx	JUMP'	DBZSEC$DBZ12$:	LOAD.L	(A6)+OZONY14,D4	LOAD.L	D3,(A6)+OZONY1	LOAD.L	D2,(A6)+OZONY4	LOAD.L	A2,#(A6)+OZONY41	LOAD.W	D0,#1		; D0 <--inverse dy	COMP.W	D1,#ICOBSYMH	JUMP',EQ DBZSEC$	LOAD.L	D2,(A6)+OZONY3	LOAD.L	A2,#(A6)+OZONY32	CLR.W	D0		; D0 <--inverse dx;	JUMP'	DBZSEC$DBZSEC$:	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- relatif depuis le point principal	SWAP.W	D3	SWAP.W	D4	COMP.W	D1,#ICOBSYMV	JUMP',EQ DBZSEC6$	NEG.W	D4		; D4 <-- -dx	TEST.W	D0	JUMP',EQ DBZSEC3$	NEG.W	D4	SWAP.W	D4	NEG.W	D4		; D4 <-- -dy	SWAP.W	D4DBZSEC3$:	COMP.W	D1,#ICOBSYMVI	JUMP',EQ DBZSEC6$	COMP.W	D1,#ICOBSYMH	JUMP,NE DBZGO$DBZSEC6$:	ADD.W	D4,D2	SWAP.W	D2	SWAP.W	D4	ADD.W	D4,D2		; D4 <-- absolu depuis le point principal	SWAP.W	D2	SWAP.W	D4	LOAD.L	(A2),D4		; dplace un deuxime point secondaire	JUMP	DBZGO$DBZCDG$:	LOAD.L	D2,D4	SUB.W	D4,(A6)+OZONXC	ADD.W	(A6)+OZONX1,D4	ADD.W	(A6)+OZONX2,D4	ADD.W	(A6)+OZONX3,D4	ADD.W	(A6)+OZONX4,D4	ADD.W	(A6)+OZONX13,D4	ADD.W	(A6)+OZONX31,D4	ADD.W	(A6)+OZONX32,D4	ADD.W	(A6)+OZONX23,D4	ADD.W	(A6)+OZONX24,D4	ADD.W	(A6)+OZONX42,D4	ADD.W	(A6)+OZONX41,D4	ADD.W	(A6)+OZONX14,D4	SWAP.W	D4	SUB.W	D4,(A6)+OZONYC	ADD.W	(A6)+OZONY1,D4	ADD.W	(A6)+OZONY2,D4	ADD.W	(A6)+OZONY3,D4	ADD.W	(A6)+OZONY4,D4	ADD.W	(A6)+OZONY13,D4	ADD.W	(A6)+OZONY31,D4	ADD.W	(A6)+OZONY32,D4	ADD.W	(A6)+OZONY23,D4	ADD.W	(A6)+OZONY24,D4	ADD.W	(A6)+OZONY42,D4	ADD.W	(A6)+OZONY41,D4	ADD.W	(A6)+OZONY14,D4	LOAD.L	(A6)+OZONYC,D2	JUMP'	DBZGO2$DBZGO$:	LOAD.W	D2,(A6)+OZONX1	CONV.LA.WA D2	LOAD.W	D3,(A6)+OZONX2	CONV.LA.WA D3	ADD.L	D2,D3	LOAD.W	D3,(A6)+OZONX3	CONV.LA.WA D3	ADD.L	D2,D3	LOAD.W	D3,(A6)+OZONX4	CONV.LA.WA D3	ADD.L	D2,D3	ASR.L	D2,#2	LOAD.W	(A6)+OZONXC,D2	LOAD.W	D2,(A6)+OZONY1	CONV.LA.WA D2	LOAD.W	D3,(A6)+OZONY2	CONV.LA.WA D3	ADD.L	D2,D3	LOAD.W	D3,(A6)+OZONY3	CONV.LA.WA D3	ADD.L	D2,D3	LOAD.W	D3,(A6)+OZONY4	CONV.LA.WA D3	ADD.L	D2,D3	ASR.L	D2,#2	LOAD.W	(A6)+OZONYC,D2	COMP.W	(A6)+OZONDFB,#ICOBVERTI	JUMP',NE DBZGO1$	CALL	ZONEQDBHOR	; ajuste les poignes secondaires horizontalesDBZGO1$:	COMP.W	(A6)+OZONDFB,#ICOBHORIZ	JUMP',NE DBZGO2$	CALL	ZONEQDBVER	; ajuste les poignes secondaires verticalesDBZGO2$:	CALL	ZONEQCLIPE	; fin du clipping	LOAD.W	(A6)+OOPEXT,#ICOZDEFBEZ	LOAD.L	A2,#R16"ZONERDEFBEZ ; A2 <-- ^routine de transformation	CALL	(A1)		; dforme tous les objets	CLR.W	(A6)+OOPEXT	JUMP'	ZONE3$ZONE$:	LOAD.W	D3,#KEYMPO	; D3 <-- souris dplace	CLR.W	D7		; D7 <-- comme si souris dplace !ZONE3$:	PUSH.W	D7	CALL	SELRECSET	; allume la zone	POP.W	D7EXIT$:	POPM.L	D0,D1,D2,D4,A2	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ZONEQDBHOR >;-----------/; Ajuste les poignes secondaires horizontales.; in	-; out	-; mod	D7.WZONEQDBHOR:	PUSH.L	D4	LOAD.W	D4,(A6)+OZONX3	SUB.W	D4,(A6)+OZONX1	ASR.W	D4,#2	ADD.W	D4,(A6)+OZONX1	LOAD.W	(A6)+OZONX13,D4	LOAD.W	D4,(A6)+OZONY3	SUB.W	D4,(A6)+OZONY1	ASR.W	D4,#2	ADD.W	D4,(A6)+OZONY1	LOAD.W	(A6)+OZONY13,D4	LOAD.W	D4,(A6)+OZONX1	SUB.W	D4,(A6)+OZONX3	ASR.W	D4,#2	ADD.W	D4,(A6)+OZONX3	LOAD.W	(A6)+OZONX31,D4	LOAD.W	D4,(A6)+OZONY1	SUB.W	D4,(A6)+OZONY3	ASR.W	D4,#2	ADD.W	D4,(A6)+OZONY3	LOAD.W	(A6)+OZONY31,D4	LOAD.W	D4,(A6)+OZONX4	SUB.W	D4,(A6)+OZONX2	ASR.W	D4,#2	ADD.W	D4,(A6)+OZONX2	LOAD.W	(A6)+OZONX24,D4	LOAD.W	D4,(A6)+OZONY4	SUB.W	D4,(A6)+OZONY2	ASR.W	D4,#2	ADD.W	D4,(A6)+OZONY2	LOAD.W	(A6)+OZONY24,D4	LOAD.W	D4,(A6)+OZONX2	SUB.W	D4,(A6)+OZONX4	ASR.W	D4,#2	ADD.W	D4,(A6)+OZONX4	LOAD.W	(A6)+OZONX42,D4	LOAD.W	D4,(A6)+OZONY2	SUB.W	D4,(A6)+OZONY4	ASR.W	D4,#2	ADD.W	D4,(A6)+OZONY4	LOAD.W	(A6)+OZONY42,D4	POP.L	D4	RET;-----------\\; ZONEQDBVER >;-----------/; Ajuste les poignes secondaires verticales.; in	-; out	-; mod	D7.WZONEQDBVER:	PUSH.L	D4	LOAD.W	D4,(A6)+OZONX2	SUB.W	D4,(A6)+OZONX3	ASR.W	D4,#2	ADD.W	D4,(A6)+OZONX3	LOAD.W	(A6)+OZONX32,D4	LOAD.W	D4,(A6)+OZONY2	SUB.W	D4,(A6)+OZONY3	ASR.W	D4,#2	ADD.W	D4,(A6)+OZONY3	LOAD.W	(A6)+OZONY32,D4	LOAD.W	D4,(A6)+OZONX3	SUB.W	D4,(A6)+OZONX2	ASR.W	D4,#2	ADD.W	D4,(A6)+OZONX2	LOAD.W	(A6)+OZONX23,D4	LOAD.W	D4,(A6)+OZONY3	SUB.W	D4,(A6)+OZONY2	ASR.W	D4,#2	ADD.W	D4,(A6)+OZONY2	LOAD.W	(A6)+OZONY23,D4	LOAD.W	D4,(A6)+OZONX1	SUB.W	D4,(A6)+OZONX4	ASR.W	D4,#2	ADD.W	D4,(A6)+OZONX4	LOAD.W	(A6)+OZONX41,D4	LOAD.W	D4,(A6)+OZONY1	SUB.W	D4,(A6)+OZONY4	ASR.W	D4,#2	ADD.W	D4,(A6)+OZONY4	LOAD.W	(A6)+OZONY41,D4	LOAD.W	D4,(A6)+OZONX4	SUB.W	D4,(A6)+OZONX1	ASR.W	D4,#2	ADD.W	D4,(A6)+OZONX1	LOAD.W	(A6)+OZONX14,D4	LOAD.W	D4,(A6)+OZONY4	SUB.W	D4,(A6)+OZONY1	ASR.W	D4,#2	ADD.W	D4,(A6)+OZONY1	LOAD.W	(A6)+OZONY14,D4	POP.L	D4	RET;-----------\\; ZONEQCLIPB >;-----------/; Dbut du clipping de la zone quelconque.; in	-; out	-; mod	D7.WZONEQCLIPB:	LOAD.L	(A6)+OZONCS+0,(A6)+OZONY1	LOAD.L	(A6)+OZONCS+4,(A6)+OZONY2	LOAD.L	(A6)+OZONCS+8,(A6)+OZONY3	LOAD.L	(A6)+OZONCS+12,(A6)+OZONY4	LOAD.W	(A6)+OZONCS+16,(A6)+OZONAN	RET;-----------\\; ZONEQCLIPE >;-----------/; Fin du clipping de la zone quelconque.; in	-; out	D7.W	erreur; mod	D7.WZONEQCLIPE:	PUSH.L	D4	LOAD.L	D4,(A6)+OZONY1	CALL'	ZONEQCLIPONE	JUMP',NE OUT$	LOAD.L	D4,(A6)+OZONY2	CALL'	ZONEQCLIPONE	JUMP',NE OUT$	LOAD.L	D4,(A6)+OZONY3	CALL'	ZONEQCLIPONE	JUMP',NE OUT$	LOAD.L	D4,(A6)+OZONY4	CALL'	ZONEQCLIPONE	JUMP',EQ EXIT$OUT$:	LOAD.L	(A6)+OZONY1,(A6)+OZONCS+0	LOAD.L	(A6)+OZONY2,(A6)+OZONCS+4	LOAD.L	(A6)+OZONY3,(A6)+OZONCS+8	LOAD.L	(A6)+OZONY4,(A6)+OZONCS+12	LOAD.W	(A6)+OZONAN,(A6)+OZONCS+16EXIT$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;-------------\\; ZONEQCLIPONE >;-------------/; Vrifie si un point dpasse des limites.; in	D4.L	point (y;x); out	D7.W	erreur; mod	D7.WZONEQCLIPONE:	PUSH.L	D4	LOAD.W	D7,#1		; D7 <-- a dpasse	COMP.W	D4,(A6)+OLIMP1+2	JUMP',LT EXIT$	COMP.W	D4,(A6)+OLIMP2+2	JUMP',GT EXIT$	SWAP.W	D4	COMP.W	D4,(A6)+OLIMP1+0	JUMP',LT EXIT$	COMP.W	D4,(A6)+OLIMP2+0	JUMP',GT EXIT$	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; ZONEQOPER >;==========/; Effectue une opration.; in	D3.W	opration (ICOxx); out	-; mod	D7.WZONEQOPER:	PUSHM.L	D0..D4,A2	COMP.W	(A6)+OOPER,#ICOZDEFORME	JUMP,EQ DEFORME$	COMP.W	(A6)+OOPER,#ICOZDEFBEZ	JUMP,EQ DEFBEZ$	CALL	ZONEMOVEB	; dbut du dplacement	CALL	ZONEQCLIPB	; dbut du clipping	COMP.W	(A6)+OOPER,#ICOZZOOM	JUMP,EQ ZOOM$	COMP.W	(A6)+OOPER,#ICOZTOURNE	JUMP,EQ TOURNE$	COMP.W	(A6)+OOPER,#ICOZMIROIR	JUMP,EQ MIROIR$	JUMP	END$ZOOM$:	LOAD.L	D1,(A6)+OZONY1	; D1 <-- coin haut/gauche	LOAD.L	D2,(A6)+OZONY2	; D2 <-- coin bas/droite	SUB.W	D2,D1	SWAP.W	D1	SWAP.W	D2	SUB.W	D2,D1	SWAP.W	D1	SWAP.W	D2	COMP.W	D3,#ICOZPLUS	JUMP',NE ZOOMPX$				; *2 en X =>	LOAD.W	D0,D2	ASR.W	D0,#1	SUB.W	D1,D0	ASL.W	D2,#1ZOOMPX$:	COMP.W	D3,#ICOZMOINS	JUMP',NE ZOOMMX$				; /2 en X =>	LOAD.W	D0,D2	ASR.W	D0,#2	ADD.W	D1,D0	ASR.W	D2,#1ZOOMMX$:	SWAP.W	D1	SWAP.W	D2	COMP.W	D3,#ICOZPLUS	JUMP',NE ZOOMPY$				; *2 en Y =>	LOAD.W	D0,D2	ASR.W	D0,#1	SUB.W	D1,D0	ASL.W	D2,#1ZOOMPY$:	COMP.W	D3,#ICOZMOINS	JUMP',NE ZOOMMY$				; /2 en Y =>	LOAD.W	D0,D2	ASR.W	D0,#2	ADD.W	D1,D0	ASR.W	D2,#1ZOOMMY$:;	SWAP.W	D1;	SWAP.W	D2	ADD.W	D2,D1	SWAP.W	D1	SWAP.W	D2	ADD.W	D2,D1;	SWAP.W	D1;	SWAP.W	D2	LOAD.L	(A6)+OZONY1,D1	LOAD.L	(A6)+OZONY2,D2	LOAD.W	(A6)+OZONX3,D2	LOAD.W	(A6)+OZONX4,D1	SWAP.W	D1	SWAP.W	D2	LOAD.W	(A6)+OZONY3,D1	LOAD.W	(A6)+OZONY4,D2;	SWAP.W	D1;	SWAP.W	D2	CALL	ZONEQCLIPE	; fin du clipping	JUMP,NE END$	LOAD.W	(A6)+OOPEXT,#ICOZZOOM	LOAD.L	A2,#R16"ZONERZOOM ; A2 <-- ^routine de transformation	CALL	ZONEMOVED	; zoom tous les objets	CLR.W	(A6)+OOPEXT	JUMP	END$TOURNE$:	LOAD.W	D2,#+90	COMP.W	D3,#ICOT90	JUMP',EQ TOURNEQ$	LOAD.W	D2,#+180	COMP.W	D3,#ICOT180	JUMP',EQ TOURNEQ$	LOAD.W	D2,#+270	COMP.W	D3,#ICOT270	JUMP,NE END$TOURNEQ$:	LOAD.W	(A6)+OZONAN,D2	LOAD.L	D3,(A6)+OZOOY1	CALL	QTOURNE	LOAD.L	(A6)+OZONY1,D3	LOAD.L	D3,(A6)+OZOOY2	CALL	QTOURNE	LOAD.L	(A6)+OZONY2,D3	LOAD.L	D3,(A6)+OZOOY3	CALL	QTOURNE	LOAD.L	(A6)+OZONY3,D3	LOAD.L	D3,(A6)+OZOOY4	CALL	QTOURNE	LOAD.L	(A6)+OZONY4,D3	CALL	ZONEQCLIPE	; fin du clipping	JUMP,NE END$	LOAD.W	(A6)+OOPEXT,#ICOZTOURNE	LOAD.L	A2,#R16"ZONERTOURNE ; A2 <-- ^routine de transformation	CALL	ZONEMOVED	; tourne tous les objets	CLR.W	(A6)+OOPEXT	JUMP	END$MIROIR$:	LOAD.L	A2,#R16"ZONERVMIROIR ; A2 <-- ^routine de transformation	COMP.W	D3,#ICOMVERT	JUMP',EQ MIROIRGO$	LOAD.L	A2,#R16"ZONERHMIROIR ; A2 <-- ^routine de transformation	COMP.W	D3,#ICOMHORIZ	JUMP,NE END$MIROIRGO$:	LOAD.W	(A6)+OOPEXT,#ICOZMIROIR	CALL	ZONEMOVED	; miroir tous les objets	CLR.W	(A6)+OOPEXT	JUMP	END$DEFORME$:	COMP.W	D3,#ICODQQ	JUMP',EQ DEFCHG$	COMP.W	D3,#ICODTRAH	JUMP',EQ DEFCHG$	COMP.W	D3,#ICODTRAV	JUMP',EQ DEFCHG$	COMP.W	D3,#ICODPARH	JUMP',EQ DEFCHG$	COMP.W	D3,#ICODPARV	JUMP,NE EXIT$DEFCHG$:	LOAD.W	(A6)+OZONDF,D3	JUMP	EXIT$DEFBEZ$:	COMP.W	D3,#ICOBQQ	JUMP',EQ DBZCHG$	COMP.W	D3,#ICOBHORIZ	JUMP',EQ DBZCHG$	COMP.W	D3,#ICOBVERTI	JUMP,NE EXIT$DBZCHG$:	LOAD.W	(A6)+OZONDFB,D3	COMP.W	(A6)+OZONDFB,#ICOBVERTI	JUMP',NE DEFBEZH$	CALL	ZONEQDBHOR	; ajuste les poignes secondaires horizontalesDEFBEZH$:	COMP.W	(A6)+OZONDFB,#ICOBHORIZ	JUMP',NE DEFBEZV$	CALL	ZONEQDBVER	; ajuste les poignes secondaires verticalesDEFBEZV$:	LOAD.W	(A6)+OOPEXT,#ICOZDEFBEZ	LOAD.L	A2,#R16"ZONERDEFBEZ ; A2 <-- ^routine de transformation	CALL	ZONEMOVED	; dforme tous les objets	CLR.W	(A6)+OOPEXT	JUMP'	EXIT$END$:	CALL	ZONEMOVEE	; fin du dplacementEXIT$:	POPM.L	D0..D4,A2	RET;----------\\; ZONERZOOM >;----------/; Zoom un point.; in	D4.L	P (y;x); out	D4.L	P'(y;x); mod	D4.L, D7.WZONERZOOM:	PUSHM.L	D1..D3	LOAD.W	D3,D4		; D3 <-- P(x)	SWAP.W	D4		; D4 <-- P(y)	LOAD.W	D1,(A6)+OZOOX2	SUB.W	D1,(A6)+OZOOX1	; D1 <-- ancienne largeur	LOAD.W	D2,(A6)+OZONX2	SUB.W	D2,(A6)+OZONX1	; D2 <-- nouvelle largeur	SUB.W	D3,(A6)+OZOOX1	MUL.WA	D3,D2	DIV.WA	D3,D1	ADD.W	D3,(A6)+OZONX1	LOAD.W	D1,(A6)+OZOOY2	SUB.W	D1,(A6)+OZOOY1	; D1 <-- ancienne hauteur	LOAD.W	D2,(A6)+OZONY2	SUB.W	D2,(A6)+OZONY1	; D2 <-- nouvelle hauteur	SUB.W	D4,(A6)+OZOOY1	MUL.WA	D4,D2	DIV.WA	D4,D1	ADD.W	D4,(A6)+OZONY1	SWAP.W	D4	LOAD.W	D4,D3		; D4 <-- P(y;x)	POPM.L	D1..D3	RET;------------\\; ZONERTOURNE >;------------/; Tourne un point.; in	D4.L	P (y;x); out	D4.L	P'(y;x); mod	D4.L, D7.WZONERTOURNE:	PUSHM.L	D2,D3	LOAD.W	D2,(A6)+OZONAN	LOAD.L	D3,D4	CALL	QTOURNE	LOAD.L	D4,D3	POPM.L	D2,D3	RET;-------------\\; ZONERHMIROIR >;-------------/; Miroir horizontal pour un point.; in	D4.L	P (y;x); out	D4.L	P'(y;x); mod	D4.L, D7.WZONERHMIROIR:	SWAP.W	D4	SUB.W	D4,(A6)+OZONY1	NEG.W	D4	ADD.W	D4,(A6)+OZONY2	SWAP.W	D4	RET;-------------\\; ZONERVMIROIR >;-------------/; Miroir vertical pour un point.; in	D4.L	P (y;x); out	D4.L	P'(y;x); mod	D4.L, D7.WZONERVMIROIR:	SUB.W	D4,(A6)+OZONX1	NEG.W	D4	ADD.W	D4,(A6)+OZONX2	RET;-------------\\; ZONERDEFORME >;-------------/; Dforme un point.; in	D4.L	P (y;x); out	D4.L	P'(y;x); mod	D4.L, D7.WZONERDEFORME:	PUSH.L	A4	LOAD.L	A4,#(A6)+OSTP	LOAD.L	(A4)+OSTPS0,(A6)+OZOOY1	LOAD.L	(A4)+OSTPS2,(A6)+OZOOY2	LOAD.L	(A4)+OSTPD0,(A6)+OZONY1	LOAD.L	(A4)+OSTPD1,(A6)+OZONY3	LOAD.L	(A4)+OSTPD2,(A6)+OZONY2	LOAD.L	(A4)+OSTPD3,(A6)+OZONY4	CALL	_STRETCH	; D4 <-- dforme un point	POP.L	A4	RET;------------\\; ZONERDEFBEZ >;------------/; Dforme selon Bzier un point.; in	D4.L	P (y;x);	D5.L	S (y;x); out	D4.L	P'(y;x);	D5.L	S'(y;x); mod	D4.L, D5.L, D7.WZONERDEFBEZ:	PUSH.L	A4	LOAD.L	A4,#(A6)+OSBP	LOAD.L	(A4)+OSBPS0,(A6)+OZOOY1	LOAD.L	(A4)+OSBPS2,(A6)+OZOOY2	LOAD.L	(A4)+OSBPD0,(A6)+OZONY1	LOAD.L	(A4)+OSBPC01,(A6)+OZONY13	LOAD.L	(A4)+OSBPC10,(A6)+OZONY31	LOAD.L	(A4)+OSBPD1,(A6)+OZONY3	LOAD.L	(A4)+OSBPC12,(A6)+OZONY32	LOAD.L	(A4)+OSBPC21,(A6)+OZONY23	LOAD.L	(A4)+OSBPD2,(A6)+OZONY2	LOAD.L	(A4)+OSBPC23,(A6)+OZONY24	LOAD.L	(A4)+OSBPC32,(A6)+OZONY42	LOAD.L	(A4)+OSBPD3,(A6)+OZONY4	LOAD.L	(A4)+OSBPC30,(A6)+OZONY41	LOAD.L	(A4)+OSBPC03,(A6)+OZONY14	CALL	_STRETCHBEZ	; D4/D5 <-- dforme deux points	POP.L	A4	RET;--------\\; XTOURNE >;--------/; Dtermine l'angle de rotation en fonction de la position; de la souris.; in	D4.L	position de la souris (y;x);	D3.L	point  tourner (y;x); out	D2.W	angle en degr; mod	D2.LXTOURNE:	PUSHM.L	D3,D5	LOAD.L	D5,D3		; D5 <-- point  tourner	LOAD.L	D3,(A6)+OZONYC	; D3 <-- centre	LIB	?CALCANGLE	; D2 <-- angle	POPM.L	D3,D5	RET;--------\\; QTOURNE >;--------/; Tourne un point d'un angle quelconque selon la; formule magique suivante :;;	x' = x*cos(a) - y*sin(a);	y' = x*sin(a) + y*cos(a);; OZONYC.L contient la coordonne du centre de symtrie.; in	D2.W	angle en degrs;	D3.L	coordonne (y;x); out	D3.L	coordonne (y;x); mod	D3.LQTOURNE:	PUSHM.L	D1,D4	LOAD.W	D1,D2		; D1 <-- angle	LOAD.L	D4,D3		; D4 <-- point  tourner	LOAD.L	D3,(A6)+OZONYC	; D3 <-- centre de symtrie	LIB	?CALCPSYM	; D4 <-- point tourn	LOAD.L	D3,D4	POPM.L	D1,D4	RET;--------------\\; ZONEQHMARKSET >;==============/; Allume les marques.; in	D2.W	poigne dplace; out	-; mod	D7.WZONEQHMARKSET:	PUSHM.L	D2..D4	CLR.L	(A6)+OPOIMCC	COMP.W	(A6)+OOPER,#ICOZTOURNE	JUMP',NE EXIT$	LOAD.L	D3,(A6)+OZONYC	CLR.W	D4	TEST.W	D2	JUMP',EQ SET$	LOAD.L	D3,(A6)+OZONY1	COMP.W	D2,#1	JUMP',EQ DRAW$	LOAD.L	D3,(A6)+OZONY2	COMP.W	D2,#2	JUMP',EQ DRAW$	LOAD.L	D3,(A6)+OZONY3	COMP.W	D2,#3	JUMP',EQ DRAW$	LOAD.L	D3,(A6)+OZONY4	COMP.W	D2,#4	JUMP',NE EXIT$DRAW$:	LOAD.L	D2,(A6)+OZONYC	SUB.W	D3,D2	SWAP.W	D2	SWAP.W	D3	SUB.W	D3,D2	SWAP.W	D2	SWAP.W	D3	LIB	?CALCHYPO	; D4 <-- rayon	LOAD.L	D3,D2SET$:	LOAD.L	(A6)+OPOIMCC,D3	LOAD.W	(A6)+OPOIMRC,D4	CALL	ZONEQHMARKINV	; allume le cercleEXIT$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;--------------\\; ZONEQHMARKCLR >;==============/; Eteint les marques.; in	-; out	-; mod	D7.WZONEQHMARKCLR:	TEST.L	(A6)+OPOIMCC	; D3 <-- centre	JUMP',EQ EXIT$	CALL'	ZONEQHMARKINV	; teint le cercleEXIT$:	RET;--------------\\; ZONEQHMARKINV >;--------------/; Inverse les marques.; in	-; out	-; mod	D7.WZONEQHMARKINV:	PUSHM.L	D2..D4	PUSH.L	(A6)+OAPOS	CLR.L	(A6)+OAPOS	CALL	WDOOPEN		; dessine dans la swdo	LIB	?AFTIM	.B	MAPTT	.B	B'10001000	; map	.B	1		; chelle	.B	0	.EVEN	LOAD.L	D3,(A6)+OPOIMCC	; D3 <-- centre	LOAD.W	D4,(A6)+OPOIMRC	; D4 <-- rayon	JUMP',EQ CROIX$	LOAD.W	D2,#INVDOT!TTTDOT	CALL	DRCIRCLE	; inverse le cercleCROIX$:	LOAD.W	D4,#7	LOAD.W	D2,#INVDOT	CALL	DRCROIX		; inverse la croix	CALL	WDOCLOSE	; fin du dessin dans la swdo	POP.L	(A6)+OAPOS	POPM.L	D2..D4	RET;-----------\\; ZONESELECT >;===========/; Slectionne tous les objets inclus dans la zone.; in	(A6)+OZONY1.L	coin zone;	(A6)+OZONY2.L	coin zone;	A1.L		^routine pour objets  exclure (*);	A4.L		^premier objet slectionn/nil; out	A4.L		^premier objet slectionn;	D7.W		erreur; mod	D7.W, A4.LZONESELECT:	PUSHM.L	D1..D5,A3	LOAD.L	A3,A4		; A3 <-- ^premier objet slectionn	LIB	?GETSHIFT	; D3 <-- touches super-shift	LOAD.B	(A6)+OSELSS,D3	CLR.W	D5		; D5 <-- nb d'objets slectionns	LOAD.L	(A6)+OZONB1,#H'7FFF7FFF	LOAD.L	(A6)+OZONB2,#H'80008000	LOAD.L	D3,(A6)+OZONY1	LOAD.L	D4,(A6)+OZONY2	COMP.L	D3,D4		; zone nulle ?	JUMP,EQ OK$		; oui => OK$	CALL	ORDONNE		; D3 en haut  gauche de D4	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP,NE END$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP,BS NEXT$	EX.L	D1,D3	EX.L	D2,D4	CALL	_LSTA_BBOXQ	; D1/D2 <-- bbox	EX.L	D1,D3	EX.L	D2,D4	CALL	_RECTTEST	; D1/D2 inclu dans D3/D4 ?	COMP.W	D7,#2		; les deux coins inclus ?	JUMP',NE NEXT$		; non => NEXT$	COMP.L	A3,#0		; y a-t-il un premier objet slectionn ?	JUMP',NE FRERE$		; oui => FRERE$	TEST.B	(A6)+OSELSS:#BKILL ; touche (KILL) enfonce ?	JUMP',BS FIRST$		; oui => FIRST$				; non =>	CALL	(A1)		; objet  exclure ?	JUMP',NE NEXT$		; oui => NEXT$FIRST$:	LOAD.L	A3,A4		; A3 <-- ^premier objet slectionn	JUMP'	SEL$FRERE$:	CALL	_LSTA_FRERE	; est-ce deux frres ?	JUMP',NE NEXT$		; non => NEXT$SEL$:	CALL	_LSTO_HEXTEND	; tend l'objet	JUMP',NE ERROR$	INC.W	D5		; D5 <-- un objet slectionn de plus	PUSHM.L	D3,D4	LOAD.L	D3,(A6)+OZONB1	LOAD.L	D4,(A6)+OZONB2	CALL	_RECTOR		; D3/D4 <-- rectangle union	LOAD.L	(A6)+OZONB1,D3	LOAD.L	(A6)+OZONB2,D4	POPM.L	D3,D4NEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$END$:	LOAD.L	D3,(A6)+OZONB1	LOAD.L	D4,(A6)+OZONB2	COMP.L	D3,#H'7FFF7FFF	JUMP',EQ OK$	CALL	DESALLWDO	; redessine toute la fentreOK$:	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$ERROR$:	PUSH.W	D7	CALL	ZONEDESELNAF	; dslectionne tout	POP.W	D7EXIT$:	LOAD.W	(A6)+OZONNS,D5	; OZONNS <-- nb d'objets slectionns	LOAD.L	A4,A3		; A4 <-- ^premier objet slectionn	POPM.L	D1..D5,A3	TEST.W	D7		; retour EQ/NE	RET;------------\\; ZONESELFILS >;============/; Slectionne tous les fils des objets dj slectionns.; in	-; out	D7.W	erreur; mod	D7.WZONESELFILS:	PUSHM.L	D4,A4	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE END$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	CALL	_LSTA_NB	; D4 <-- nb de fils	TEST.W	D4	JUMP',EQ NEXT$FILS$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP',NE END$	CALL	_LSTO_HEXTEND	; tend l'objet	JUMP',NE ERROR$	DEC.W	D4	JUMP,NE FILS$NEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$END$:	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$ERROR$:	PUSH.W	D7	CALL	ZONEDESELECT	; dslectionne tout	POP.W	D7EXIT$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------------\\; ZONEDESELFILS >;==============/; D-slectionne tous les fils des objets dj slectionns.; in	-; out	-; mod	D7.WZONEDESELFILS:	PUSHM.L	D4,A4	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	CALL	_LSTA_NB	; D4 <-- nb de fils	TEST.W	D4	JUMP',EQ NEXT$FILS$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP',NE EXIT$	CALL	_LSTO_HCOMPACT	; compactifie l'objet	DEC.W	D4	JUMP,NE FILS$NEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	POPM.L	D4,A4	RET;-------------\\; ZONEDESELECT >;=============/; Dslectionne tous les objets slectionns.; Refait correctement tout le dessin !; in	-; out	-; mod	D7.WZONEDESELECT:	PUSHM.L	D1..D4,A4	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$	LOAD.L	D3,#H'7FFF7FFF	LOAD.L	D4,#H'80008000LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	CALL	_LSTO_HCOMPACT	; compactifie l'objet	EX.L	D1,D3	EX.L	D2,D4	CALL	_LSTA_BBOXQ	; D1/D2 <-- bbox	EX.L	D1,D3	EX.L	D2,D4	CALL	_RECTOR		; D3/D4 <-- rectangle unionNEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$	COMP.L	D3,#H'7FFF7FFF	JUMP',EQ EXIT$	CALL	DESALLWDO	; redessine toute la fentreEXIT$:	POPM.L	D1..D4,A4	RET;-------------\\; ZONEDESELNAF >;=============/; Dslectionne tous les objets slectionns.; Ne redessine rien !; in	-; out	-; mod	D7.WZONEDESELNAF:	PUSH.L	A4	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	CALL	_LSTO_HCOMPACT	; compactifie l'objetNEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	POP.L	A4	RET;--------\\; ZONEABS >;========/; Rend tous les objets slectionns absolus (temporaire).; Ne pas oublier ZONEREL aprs !; in	-; out	-; mod	D7.WZONEABS:	PUSH.L	A4	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	CALL	_GROUPABS	; rend l'objet absoluNEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	POP.L	A4	RET;--------\\; ZONEREL >;========/; Rend tous les objets slectionns relatif (tat normal).; in	-; out	-; mod	D7.WZONEREL:	PUSH.L	A4	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	CALL	_GROUPREL	; rend l'objet relatifNEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	POP.L	A4	RET;------------\\; ZONEDETRUIT >;============/; Dtruit tous les objets slectionns.; in	-; out	-; mod	D7.WZONEDETRUIT:	PUSH.L	A4RELOOP$:	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	CALL	_LSTA_REMOVE	; enlve l'objet et ses fils	JUMP	RELOOP$NEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	SET.B	(A6)+OMAJ	; mise  jour sur disque ncessaire	POP.L	A4	RET;----------\\; ZONEMOVEH >;==========/; Dbut du dplacement de tous les objets slectionns.; in	D4.W	opration (ZONEMOVE*); out	D4.W	zro si dformation possible; mod	D4.L, D7.WZONEMOVEH:	PUSHM.L	D1..D3,A4	LOAD.W	D3,D4		; D3 <-- opration ZONEMOVE*	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE DEF$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	CALL	_LSTA_NB	; D4 <-- nb de fils	LOAD.W	D2,D4		; D2 <-- nb de fils	INC.W	D2		; D2 <-- compte aussi le preFILS$:	LOAD.W	D1,#opZONEMOVE	CALL	_OBJCALLD	; D4 <-- zro si dformation	JUMP',EQ OK$	CLR.W	D4		; D4 <-- possible	COMP.W	D3,#ZONEMOVEZOOM	JUMP',EQ OK$	LOAD.W	D4,#1		; D4 <-- impossibleOK$:	TEST.W	D4		; opration possible ?	JUMP',NE EXIT$		; non => EXIT$	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP',NE DEF$	DEC.W	D2	JUMP,NE FILS$	JUMP	LOOP$NEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$DEF$:	CLR.W	D4		; D4 <-- dformation possibleEXIT$:	POPM.L	D1..D3,A4	RET;----------\\; ZONEMOVEB >;==========/; Dbut du dplacement de tous les objets slectionns.; in	-; out	-; mod	D7.WZONEMOVEB:	PUSHM.L	D1..D3,A4	LOAD.L	(A6)+OZOOY1,(A6)+OZONY1	LOAD.L	(A6)+OZOOY2,(A6)+OZONY2	LOAD.L	(A6)+OZOOY3,(A6)+OZONY3	LOAD.L	(A6)+OZOOY4,(A6)+OZONY4	LOAD.L	(A6)+OZOOYC,(A6)+OZONYC	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	LOAD.L	D2,#2^BVUECLR!2^BVUEPROV!2^BVUEPROVI	CALL	DESOBJET	; teint l'intrieur de l'objet	LOAD.W	D3,#ZONEMOVEBEGIN	LOAD.W	D1,#opZONEMOVE	CALL	_OBJCALLD	; dbut du dplacementNEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	POPM.L	D1..D3,A4	RET;-----------\\; ZONEMOVEBF >;===========/; Dbut du dplacement de tous les objets slectionns.; in	-; out	-; mod	D7.WZONEMOVEBF:	PUSHM.L	D1..D3,A4	LOAD.L	(A6)+OZOOY1,(A6)+OZONY1	LOAD.L	(A6)+OZOOY2,(A6)+OZONY2	LOAD.L	(A6)+OZOOY3,(A6)+OZONY3	LOAD.L	(A6)+OZOOY4,(A6)+OZONY4	LOAD.L	(A6)+OZOOYC,(A6)+OZONYC	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	LOAD.L	D2,#2^BVUECLR!2^BVUEPROV!2^BVUEPROVI	CALL	DESOBJETF	; teint l'intrieur de l'objet et de ses fils	LOAD.W	D3,#ZONEMOVEBEGIN	LOAD.W	D1,#opZONEMOVE	CALL	_OBJCALLD	; dbut du dplacementNEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	POPM.L	D1..D3,A4	RET;-----------\\; ZONEMOVEBC >;===========/; Dbut du dplacement de tous les objets slectionns.; in	-; out	-; mod	D7.WZONEMOVEBC:	PUSHM.L	D1..D3,A4	LOAD.L	(A6)+OZOOY1,(A6)+OZONY1	LOAD.L	(A6)+OZOOY2,(A6)+OZONY2	LOAD.L	(A6)+OZOOY3,(A6)+OZONY3	LOAD.L	(A6)+OZOOY4,(A6)+OZONY4	LOAD.L	(A6)+OZOOYC,(A6)+OZONYC	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	LOAD.W	D3,#ZONEMOVEBEGIN	LOAD.W	D1,#opZONEMOVE	CALL	_OBJCALLD	; dbut du dplacementNEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	POPM.L	D1..D3,A4	RET;----------\\; ZONEMOVED >;==========/; Dplace tous les objets slectionns.; in	A2.L	^routine de transformation d'un point; out	-; mod	D7.WZONEMOVED:	PUSHM.L	D1..D3,A4	CALL	WDOOPEN		; dessine dans la swdo	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	LOAD.L	D2,#2^BVUECLR!2^BVUEPROV!2^BVUEPROVE	CALL	DESOBJET	; teint l'extrieur de l'objet	LOAD.W	D3,#ZONEMOVEDRAG	LOAD.W	D1,#opZONEMOVE	CALL	_OBJCALLD	; dplace l'objet	LOAD.L	D2,#2^BVUESET!2^BVUEPROV!2^BVUEPROVE	CALL	DESOBJET	; allume l'extrieur de l'objetNEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	CALL	WDOCLOSE	; fin du dessin dans la swdo	POPM.L	D1..D3,A4	RET;-----------\\; ZONEMOVEDM >;===========/; Dplace tous les objets slectionns, tant que la souris ne bouge pas.; in	D3.W	tat (ZONEMOVExxxx);	A2.L	^routine de transformation d'un point; out	D3.L	touche;	D7.W	ok si touche presse/souris dplace; mod	D3.L, D7.WZONEMOVEDM:	PUSHM.L	D1,D2,A4	CALL	WDOOPEN		; dessine dans la swdo	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	CLR.W	D3	CALL	_WAITMOVET	; D3 <-- souris dplace ?	JUMP',EQ EXIT$		; oui => EXIT$	LOAD.L	D2,#2^BVUECLR!2^BVUEPROV!2^BVUEPROVE	CALL	DESOBJET	; teint l'extrieur de l'objet	LOAD.W	D3,#ZONEMOVEDRAG	LOAD.W	D1,#opZONEMOVE	CALL	_OBJCALLD	; dplace l'objet	LOAD.L	D2,#2^BVUESET!2^BVUEPROV!2^BVUEPROVE	CALL	DESOBJET	; allume l'extrieur de l'objetNEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	PUSH.W	D7	CALL	WDOCLOSE	; fin du dessin dans la swdo	POP.W	D7	POPM.L	D1,D2,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ZONEMOVEDF >;===========/; Dplace tous les objets slectionns et leurs fils.; in	A2.L	^routine de transformation d'un point; out	-; mod	D7.WZONEMOVEDF:	PUSHM.L	D1..D4,A4	CALL	WDOOPEN		; dessine dans la swdo	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	LOAD.L	D2,#2^BVUECLR!2^BVUEPROV!2^BVUEPROVE	CALL	DESOBJETF	; teint l'extrieur de l'objet et de ses fils	LOAD.W	D3,#ZONEMOVEDRAG	LOAD.W	D1,#opZONEMOVE	CALL	_OBJCALLD	; dplace l'objet	CALL	_LSTA_NB	; D4 <-- nb de fils	TEST.W	D4		; y a-t-il des fils ?	JUMP',EQ SET$		; non => SET$	LOAD.W	D1,#opGETBBOX	CALL	_OBJCALLD	; D3/D4 <-- bounding box	LOAD.L	(A4)+OobjBBOX1,D3	LOAD.L	(A4)+OobjBBOX2,D4SET$:	LOAD.L	D2,#2^BVUESET!2^BVUEPROV!2^BVUEPROVE	CALL	DESOBJETF	; allume l'extrieur de l'objet et de ses filsNEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	CALL	WDOCLOSE	; fin du dessin dans la swdo	POPM.L	D1..D4,A4	RET;------------\\; ZONEMOVEDFM >;============/; Dplace tous les objets slectionns et leurs fils, tant que la souris ne bouge pas.; in	D3.W	tat (ZONEMOVExxxx);	A2.L	^routine de transformation d'un point; out	D3.L	touche;	D7.W	ok si touche presse/souris dplace; mod	D3.L, D7.WZONEMOVEDFM:	PUSHM.L	D1,D2,D4,A4	CALL	WDOOPEN		; dessine dans la swdo	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP,NE EXIT$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	CLR.W	D3	CALL	_WAITMOVET	; D3 <-- souris dplace ?	JUMP',EQ EXIT$		; oui => EXIT$	LOAD.L	D2,#2^BVUECLR!2^BVUEPROV!2^BVUEPROVE	CALL	DESOBJETF	; teint l'extrieur de l'objet et de ses fils	LOAD.W	D3,#ZONEMOVEDRAG	LOAD.W	D1,#opZONEMOVE	CALL	_OBJCALLD	; dplace l'objet	CALL	_LSTA_NB	; D4 <-- nb de fils	TEST.W	D4		; y a-t-il des fils ?	JUMP',EQ SET$		; non => SET$	LOAD.W	D1,#opGETBBOX	CALL	_OBJCALLD	; D3/D4 <-- bounding box	LOAD.L	(A4)+OobjBBOX1,D3	LOAD.L	(A4)+OobjBBOX2,D4SET$:	LOAD.L	D2,#2^BVUESET!2^BVUEPROV!2^BVUEPROVE	CALL	DESOBJETF	; allume l'extrieur de l'objet et de ses filsNEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	PUSH.W	D7	CALL	WDOCLOSE	; fin du dessin dans la swdo	POP.W	D7	POPM.L	D1,D2,D4,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ZONEMOVEDC >;===========/; Dplace tous les objets slectionns, sans afficher.; in	A2.L	^routine de transformation d'un point; out	-; mod	D7.WZONEMOVEDC:	PUSHM.L	D1,D3,A4	CALL	WDOOPEN		; dessine dans la swdo	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	LOAD.W	D3,#ZONEMOVEDRAG	LOAD.W	D1,#opZONEMOVE	CALL	_OBJCALLD	; dplace l'objetNEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	CALL	WDOCLOSE	; fin du dessin dans la swdo	POPM.L	D1,D3,A4	RET;----------\\; ZONEMOVEE >;==========/; Fin du dplacement de tous les objets slectionns.; in	-; out	-; mod	D7.WZONEMOVEE:	PUSHM.L	D1..D4,A4	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	LOAD.W	D3,#ZONEMOVEEND	LOAD.W	D1,#opZONEMOVE	CALL	_OBJCALLD	; dplace l'objet	LOAD.L	D2,#2^BVUESET!2^BVUEPROV!2^BVUEPROVI	CALL	DESOBJET	; allume l'intrieur de l'objet	LOAD.W	D1,#opGETBBOX	CALL	_OBJCALLD	; D3/D4 <-- bounding box	LOAD.L	(A4)+OobjBBOX1,D3	LOAD.L	(A4)+OobjBBOX2,D4NEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	POPM.L	D1..D4,A4	RET;-----------\\; ZONEMOVEEF >;===========/; Fin du dplacement de tous les objets slectionns.; in	-; out	-; mod	D7.WZONEMOVEEF:	PUSHM.L	D1..D4,A4	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	LOAD.W	D3,#ZONEMOVEEND	LOAD.W	D1,#opZONEMOVE	CALL	_OBJCALLD	; dplace l'objet	LOAD.L	D2,#2^BVUESET!2^BVUEPROV!2^BVUEPROVI	CALL	DESOBJETF	; allume l'intrieur de l'objet et de ses fils	LOAD.W	D1,#opGETBBOX	CALL	_OBJCALLD	; D3/D4 <-- bounding box	LOAD.L	(A4)+OobjBBOX1,D3	LOAD.L	(A4)+OobjBBOX2,D4NEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	POPM.L	D1..D4,A4	RET;-----------\\; ZONEMOVEEC >;===========/; Fin du dplacement de tous les objets slectionns.; in	-; out	-; mod	D7.WZONEMOVEEC:	PUSHM.L	D1..D4,A4	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	LOAD.W	D3,#ZONEMOVEEND	LOAD.W	D1,#opZONEMOVE	CALL	_OBJCALLD	; dplace l'objet	LOAD.W	D1,#opGETBBOX	CALL	_OBJCALLD	; D3/D4 <-- bounding box	LOAD.L	(A4)+OobjBBOX1,D3	LOAD.L	(A4)+OobjBBOX2,D4NEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	POPM.L	D1..D4,A4	RET;----------\\; ZONEMODIF >;==========/; Modifie toute une zone.; in	D3.W	identificateur (objet de dfinition); out	-; mod	D7.WZONEMODIF:	PUSHM.L	D1..D5,A4	LOAD.W	D5,D3		; D5 <-- identificateur	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	CALL	_LSTA_NB	; D4 <-- nb de fils	LOAD.W	D2,D4		; D2 <-- nb de fils	INC.W	D2		; D2 <-- compte aussi le preFILS$:	LOAD.W	D3,D5		; D3 <-- identificateur	CALL	ZONEMODIFONE	; modifie un objet	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP',NE EXIT$	DEC.W	D2	JUMP,NE FILS$	JUMP	LOOP$NEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	POPM.L	D1..D5,A4	RET;-------------\\; ZONEMODIFONE >;-------------/; Modifie un objet, sans s'occuper de ses fils.; in	A4.L	^objet;	D3.W	identificateur; out	-; mod	D7.WZONEMODIFONE:	PUSHM.L	D1..D4	LOAD.L	D2,#2^BVUECLR!2^BVUEPROV!2^BVUEPROVE!2^BVUEPROVI	CALL	DESOBJET	; teint l'objet	LOAD.W	D1,#opZONEMODIF	CALL	_OBJCALLD	; modifie trait/trame/etc.	PUSH.W	D7	LOAD.L	D2,#2^BVUESET!2^BVUEPROV!2^BVUEPROVE!2^BVUEPROVI	CALL	DESOBJET	; allume l'objet	POP.W	D7	JUMP',NE EXIT$	LOAD.W	D1,#opGETBBOX	CALL	_OBJCALLD	; D3/D4 <-- bounding box	LOAD.L	(A4)+OobjBBOX1,D3	LOAD.L	(A4)+OobjBBOX2,D4EXIT$:	POPM.L	D1..D4	RET;-----------\\; ZONEGRMAKE >;===========/; Assemble tous les objets slectionns pour faire un groupe.; En fait, on cre un pre qui adoptera tous les enfants slectionns !; in	-; out	A4.L	^pre;	D7.W	erreur; mod	D7.W, A4.LZONEGRMAKE:	PUSHM.L	D0..D4,A3	LOAD.L	A4,(A6)+OSELPS	; A4 <-- ^premier objet slectionn	LOAD.L	A3,A4		; A3 <-- ^futur frre cadet	CLR.L	D2	CALL	_LSTA_PREVP	; A4 <-- ^pre	JUMP',NE NOPERE$	CALL	_LSTA_BBOX	; D3/D4 <-- bbox du pre	LOAD.L	D2,D3NOPERE$:	LOAD.W	D0,#IDENTFGROUP	LOAD.W	D1,#opCRGETLG	CALL	_OBJCALL	; D4 <-- longueur ncessaire	JUMP,NE ERROR$	LOAD.L	A4,A3		; A4 <-- ^frre cadet	LOAD.L	A3,#0		; A3 <-- pas de pre (car A4 ^frre cadet)	CALL	_LSTA_INSERT	; A4 <-- ^objet  la tte	JUMP,NE ERROR$	LOAD.W	(A4)+OobjIDENT,D0	SET.B	(A6)+OMAJ	; mise  jour sur disque ncessaire	LOAD.L	(A6)+OAPOS,D2	CALL	WDOOPEN		; dessine dans la swdo	LOAD.W	D1,#opCRINIT	CALL	_OBJCALLD	; initialise l'objet	LOAD.W	D3,#CRMOVEOPEN	; D3 <-- dbut	LOAD.W	D1,#opCRMOVE	CALL	_OBJCALLD	; indique le dbut de la cration	LOAD.L	D4,(A6)+OZONY1	SUB.W	D4,D2	SUB.W	D4,#10*FACMMPT	SWAP.W	D2	SWAP.W	D4	SUB.W	D4,D2	SUB.W	D4,#10*FACMMPT	SWAP.W	D2	SWAP.W	D4	LOAD.W	D3,#CRMOVEBEGIN	; D3 <-- dbut;	LOAD.W	D1,#opCRMOVE	CALL	_OBJCALLD	; indique le dbut du dplacement	LOAD.L	D4,(A6)+OZONY2	SUB.W	D4,D2	ADD.W	D4,#10*FACMMPT	SWAP.W	D2	SWAP.W	D4	SUB.W	D4,D2	ADD.W	D4,#10*FACMMPT	SWAP.W	D2	SWAP.W	D4	LOAD.W	D3,#CRMOVEDRAG	; D3 <-- dplacement;	LOAD.W	D1,#opCRMOVE	CALL	_OBJCALLD	; dplace la poigne	LOAD.W	D3,#CRMOVEEND	; D3 <-- fin;	LOAD.W	D1,#opCRMOVE	CALL	_OBJCALLD	; indique la fin du dplacement	LOAD.W	D3,#CRMOVECLOSE	; D3 <-- fin;	LOAD.W	D1,#opCRMOVE	CALL	_OBJCALLD	; indique la fin de la cration	CALL	WDOCLOSE	; fin du dessin dans la swdo	CALL	_LSTO_CCOMPACT	; A4 <-- ^objet compact	LOAD.L	A3,A4		; A3 <-- ^futur preAFIRST$:	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE ERROR$ALOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC ANEXT$	CALL	_GROUPADOPT	; le pre adopte un fils	JUMP',NE ERROR$	CALL	_LSTO_HCOMPACT	; compactifie l'objet	JUMP	AFIRST$ANEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ ALOOP$	LOAD.L	A4,A3		; A4 <-- ^l'heureux pre	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$ERROR$:	PUSH.W	D7	CALL	ZONEDESELECT	; dslectionne tous les objets inclus	POP.W	D7EXIT$:	POPM.L	D0..D4,A3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ZONEGRKILL >;===========/; Spare tous les objets slectionns pour dfaire les groupes.; En fait, on tue tous les pres, et les enfants sont adopts par; les grand-pres !; in	-; out	D4.W	nombre de pre tus (0..n);	D7.W	erreur; mod	D4.L, D7.WZONEGRKILL:	PUSHM.L	D2,A4	CLR.W	D2	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE OK$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	CALL	_LSTA_NB	; D4 <-- nb de fils	TEST.W	D4		; y a-t-il des fils ?	JUMP',EQ NEXT$		; non => NEXT$	CALL	_GROUPDEAD	; dcs du pre	JUMP',NE EXIT$	INC.W	D2		; D2 <-- un mort de plusNEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	LOAD.W	D4,D2		; D4 <-- nb de pres tus	POPM.L	D2,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; ZONEGRCHG >;==========/; Change tous les objets slectionns de groupe.; in	-; out	A4.L	^nouveau pre;	D7.W	erreur (si document choisi comme pre); mod	D7.W, A4.LZONEGRCHG:	PUSHM.L	D3..D6,A1,A3	CLR.W	D5	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP',NE DOC$	CALL	_CONVSCROBJ	; D4 <-- position [obj]	JUMP',NE DOC$	LOAD.L	A1,#R16"ZONEGRCHGEX	CALL	HANDSELECT	; slectionne un pre ...	JUMP',EQ PERE$DOC$:	LOAD.W	D3,(A6)+OPAGE	; D3 <-- page visible	LOAD.W	D4,(A6)+OCALQ	; D4 <-- calque visible	LOAD.L	D6,(A6)+OOBACH	; D6 <-- canal de l'arbre des objets	CALL	_LSTA_BEGIN	; A4 <-- prend le calque comme pre !	INC.W	D5PERE$:	LOAD.L	A3,A4		; A3 <-- ^preFIRST$:	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE END$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	TEST.B	(A4)+OobjFLAGS:#BobjFLAG	JUMP',BS NEXT$	CALL	_GROUPADOPT	; le pre adopte un fils	TSET.B	(A4)+OobjFLAGS:#BobjFLAG	JUMP	FIRST$NEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$END$:	LOAD.W	D7,D5		; est-ce que le pre est le document ?	JUMP',NE DSEND$		; oui => DSEND$	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE DSEND$DSLOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC DSNEXT$	CALL	_LSTO_HCOMPACT	; compactifie l'objetDSNEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ DSLOOP$	CLR.W	D7		; D7 <-- le pre est un objet GROUPDSEND$:	LOAD.L	A4,A3		; A4 <-- ^nouveau pre	PUSH.W	D7	CALL	_GROUPKFLAG	; enlve BobjFLAG partout !	POP.W	D7	POPM.L	D3..D6,A1,A3	TEST.W	D7		; retour EQ/NE	RET;------------\\; ZONEGRCHGEX >;------------/; Teste s'il faut exclure cet objet.; in	A4.L	^objet; out	D7.W	erreur si objet  exclure; mod	D7.WZONEGRCHGEX:	PUSHM.L	D1..D4,A3,A4	PUSH.L	(A6)+OAPOS	COMP.W	(A4)+OobjIDENT,#IDENTFGROUP	JUMP',LO NOSEL$	COMP.W	(A4)+OobjIDENT,#IDENTLGROUP	JUMP',HS NOSEL$	LOAD.L	A3,A4	LOAD.L	A4,(A6)+OSELPS	CALL	_LSTA_PREVP	; A4 <-- ^pre actuel	EX.L	A3,A4	JUMP',NE NOPERE$	COMP.L	A4,A3		; est-ce le pre actuel ?	JUMP',EQ NOSEL$		; oui => NOSEL$NOPERE$:	CALL	_LSTA_BBOX	; D3/D3 <-- bbox	LOAD.L	D1,(A6)+OZONY1	LOAD.L	D2,(A6)+OZONY2	CALL	_RECTTEST	; D1/D2 inclu dans D3/D4 ?	COMP.W	D7,#2		; les deux coins inclus ?	JUMP',NE NOSEL$SEL$:	CLR.W	D7		; D7 <-- slection possible	JUMP'	EXIT$NOSEL$:	LOAD.W	D7,#1		; D7 <-- slection refuseEXIT$:	POP.L	(A6)+OAPOS	POPM.L	D1..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; ZONEADOPT >;==========/; Un calque quelconque adopte tous les objets slectionns.; in	D3.W	page (0..n);	D4.W	calque (0..n); out	-; mod	D7.WZONEADOPT:	PUSHM.L	D6,A3,A4	LOAD.L	D6,(A6)+OOBACH	CALL	_LSTA_BEGIN	; A4 <-- ^calque pre	JUMP',NE EXIT$	LOAD.L	A3,A4		; A3 <-- ^preFIRST$:	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE END$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	TSET.B	(A4)+OobjFLAGS:#BobjFLAG	JUMP',BS NEXT$	CALL	_GROUPADOPT	; le pre adopte un fils	JUMP	FIRST$NEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$END$:	LOAD.W	(A6)+OPAGE,D3	LOAD.W	(A6)+OCALQ,D4	CALL	_GROUPKFLAG	; enlve BobjFLAG dans le nouveau calque !EXIT$:	POPM.L	D6,A3,A4	RET;--------\\; HVOPEN  >;========/; Fixe le point initial pour les contraintes.; in	D4.L	point initial (y;x)  [obj]; out	-; mod	D7.WHVOPEN:	LOAD.L	(A6)+OHVFIX,D4	CALL	HVEXIST		; contrainte existe ?	JUMP',NE EXIT$		; non => EXIT$	CALL	HVINV		; allume les represEXIT$:	RET;--------\\; HVCONV  >;========/; Conversion d'un point selon les contraintes.; in	D4.L	point (y;x)  [obj]; out	D4.L	point (y;x)  [obj]; mod	D4.L, D7.WHVCONV:	PUSHM.L	D0..D3,D5	CALL	HVEXIST		; contrainte existe ?	JUMP',EQ YES$		; oui => YES$	TEST.B	(A6)+OHVSET	; repres teints ?	JUMP,F	EXIT$		; oui => EXIT$	CALL	HVINV		; teint les repres	JUMP	EXIT$YES$:	TEST.B	(A6)+OHVSET	; repres allums ?	JUMP',T CALC$		; oui => CALC$	CALL	HVINV		; allume les represCALC$:	LOAD.L	D0,(A6)+OHVFAN	; D0 <-- fanions	TEST.L	D0:#BHV090	JUMP',BC OTHER$	LOAD.W	D3,D4	SUB.W	D3,(A6)+OHVFIX+2	JUMP',NC HVX$	NEG.W	D3		; D3 <-- |dx|HVX$:	LOAD.L	D2,D4	SWAP.W	D2	SUB.W	D2,(A6)+OHVFIX+0	JUMP',NC HVY$	NEG.W	D2		; D2 <-- |dy|HVY$:	COMP.W	D3,D2	JUMP',LO VERTI$HORIZ$:	SWAP.W	D4	LOAD.W	D4,(A6)+OHVFIX+0	SWAP.W	D4	JUMP	EXIT$VERTI$:	LOAD.W	D4,(A6)+OHVFIX+2	JUMP	EXIT$OTHER$:	TEST.L	D0:#BHVAUTRE	JUMP,BC EXIT$	TEST.W	(A6)+OHVVAL	JUMP,EQ EXIT$	LOAD.L	D5,D4	LOAD.L	D3,(A6)+OHVFIX	SUB.W	D3,D4		; D3 <-- distance X depuis le centre	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4		; D3 <-- distance Y depuis le centre	SWAP.W	D3	SWAP.W	D4	LIB	?CALCHYPO	; D4 <-- loignement de la souris	LOAD.L	D3,(A6)+OHVFIX	ADD.W	D3,D4	LOAD.L	D4,D5	LOAD.L	D5,D3	LOAD.L	D3,(A6)+OHVFIX	LIB	?CALCANGLE	; D2 <-- angle	LOAD.W	D3,(A6)+OHVVAL	; D3 <-- angle fixe	LOAD.W	D4,D3	SR.W	D4,#1		; D4 <-- angle fixe /2	ADD.W	D2,D4	CONV.LA.WA D2	DIV.WU	D2,D3	MUL.WU	D2,D3	COMP.W	D2,#360	JUMP',LO ROT$	SUB.W	D2,#360ROT$:	LOAD.L	D3,(A6)+OHVFIX	LOAD.L	D4,D5	LOAD.W	D1,D2	LIB	?CALCPSYM	; D4 <-- point tournEXIT$:	POPM.L	D0..D3,D5	RET;--------\\; HVCLOSE >;========/; Termine le point initial pour les contraintes.; in	-; out	-; mod	D7.WHVCLOSE:	TEST.B	(A6)+OHVSET	; repres teints ?	JUMP',F	EXIT$		; oui => EXIT$	CALL	HVINV		; teint les represEXIT$:	RET;--------\\; HVCLR   >;========/; Eteint les repres si ncessaire.; in	-; out	-; mod	D7.WHVCLR:	CLR.B	(A6)+OHVCLR	TEST.B	(A6)+OHVSET	; repres teints ?	JUMP',F	EXIT$		; oui => EXIT$	CALL	HVINV		; teint les repres	SET.B	(A6)+OHVCLREXIT$:	RET;--------\\; HVSET   >;========/; Rallume les repres si ncessaire.; in	-; out	-; mod	D7.WHVSET:	TEST.B	(A6)+OHVCLR	; repres teints ?	JUMP',F	EXIT$		; oui => EXIT$	CALL	HVINV		; allume les represEXIT$:	RET;--------\\; HVINV   >;--------/; Inverse le repre.; in	-; out	-; mod	D7.WHVINV:	PUSHM.L	D0..D4	LOAD.L	D0,(A6)+OHVFAN	; D0 <-- fanions	TEST.L	D0:#BHVSHOW	JUMP,BC EXIT$	PUSH.L	(A6)+OAPOS	CLR.L	(A6)+OAPOS	CALL	WDOOPEN		; dessine dans la swdo	LIB	?AFTIM	.B	MAPTT	.B	B'10001000	; map	.B	1		; chelle	.B	0	.EVEN	LOAD.W	D2,#INVDOT!TTTDOT	TEST.L	D0:#BHV090	JUMP',BC OTHER$	LOAD.L	D4,(A6)+OHVFIX	CALL	_CONVOBJDRAW	; D4 <- position [scr]	LOAD.L	D1,D4	LOAD.L	D3,D1	CLR.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	LIB	?DRSEG		; trace ligne horizontale	LOAD.L	D3,D1	AND.L	D3,#H'FFFF	LOAD.W	D4,(A0)+ODFFDY	SWAP.W	D4	CLR.W	D4	LIB	?DRSEG		; trace ligne verticale	JUMP	END$OTHER$:	TEST.L	D0:#BHVAUTRE	JUMP,BC END$	TEST.W	(A6)+OHVVAL	JUMP,EQ END$	LOAD.L	D4,(A6)+OHVFIX	CALL	_CONVOBJDRAW	; D4 <- position [scr]	LOAD.L	D3,D4	LOAD.W	D4,(A0)+ODFFDX	COMP.W	D4,(A0)+ODFFDY	JUMP',HS OLG$	LOAD.W	D4,(A0)+ODFFDYOLG$:	SL.W	D4,#1	ADD.W	D4,D3	CLR.W	D1OLOOP$:	PUSHM.L	D3,D4	LIB	?CALCPSYM	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LIB	?DRSEG	POPM.L	D3,D4	ADD.W	D1,(A6)+OHVVAL	; D1 <-- angle suivant	COMP.W	D1,#360	JUMP,LO OLOOP$END$:	NOT.B	(A6)+OHVSET	CALL	WDOCLOSE	; fin du dessin dans la swdo	POP.L	(A6)+OAPOSEXIT$:	POPM.L	D0..D4	RET;--------\\; HVEXIST >;--------/; Regarde s'il existe une contrainte.; in	-; out	D7.W	erreur si n'existe pas; mod	D7.WHVEXIST:	PUSH.L	D3	COMP.L	(A6)+OHVFIX,#-1	JUMP',EQ NO$	LOAD.L	D3,(A6)+OHVFAN	; D3 <-- fanions	TEST.L	D3:#BHVNON	JUMP',BS NO$	TEST.L	D3:#BHVOUI	JUMP',BS YES$	LIB	?GETSHIFT	; D3 <-- touches super-shift	TEST.L	D3:#BCURSOR	JUMP',BC NO$YES$:	CLR.W	D7	JUMP'	EXIT$NO$:	LOAD.W	D7,#1EXIT$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET	.END