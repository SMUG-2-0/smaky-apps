	.SBTTL	PAGEMATH.ASI;--------\\; RECTAND >;========/; Effectue un "et" (intersection) entre deux rectangles.; in	D1/D2	P1/P2 rectangle A;	D3/D4	P1/P2 rectangle B; out	D3/D4	P1/P2 rectangle A & B; mod	D3.L, D4.LRECTAND:	COMP.W	D3,D1	JUMP',GE 10$	LOAD.W	D3,D110$:	COMP.W	D3,D2	JUMP',LE 12$	LOAD.W	D3,D212$:	SWAP.W	D1	SWAP.W	D2	SWAP.W	D3	COMP.W	D3,D1	JUMP',GE 14$	LOAD.W	D3,D114$:	COMP.W	D3,D2	JUMP',LE 16$	LOAD.W	D3,D216$:	SWAP.W	D1	SWAP.W	D2	SWAP.W	D3	COMP.W	D4,D1	JUMP',GE 20$	LOAD.W	D4,D120$:	COMP.W	D4,D2	JUMP',LE 22$	LOAD.W	D4,D222$:	SWAP.W	D1	SWAP.W	D2	SWAP.W	D4	COMP.W	D4,D1	JUMP',GE 24$	LOAD.W	D4,D124$:	COMP.W	D4,D2	JUMP',LE 26$	LOAD.W	D4,D226$:	SWAP.W	D1	SWAP.W	D2	SWAP.W	D4	RET;--------\\; RECTOR  >;========/; Effectue un "ou" (union) entre deux rectangles.; in	D1/D2	P1/P2 rectangle A;	D3/D4	P1/P2 rectangle B; out	D3/D4	P1/P2 rectangle A ! B; mod	D3.L, D4.LRECTOR:	COMP.W	D3,D1	JUMP',LE 20$	LOAD.W	D3,D120$:	COMP.W	D4,D2	JUMP',GE 22$	LOAD.W	D4,D222$:	SWAP.W	D1	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	COMP.W	D3,D1	JUMP',LE 40$	LOAD.W	D3,D140$:	COMP.W	D4,D2	JUMP',GE 42$	LOAD.W	D4,D242$:	SWAP.W	D1	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	RET;---------\\; RECTTEST >;=========/; Teste si un rectangle B est inclu dans un rectangle A.; in	D1/D2	P1/P2 rectangle A;	D3/D4	P1/P2 rectangle B; out	D7.W	nb de points de A inclus dans B; mod	D7.WRECTTEST:	CLR.W	D7	COMP.W	D1,D3	JUMP',LT 22$	COMP.W	D1,D4	JUMP',GE 22$	SWAP.W	D1	SWAP.W	D3	SWAP.W	D4	COMP.W	D1,D3	JUMP',LT 20$	COMP.W	D1,D4	JUMP',GE 20$	INC.W	D7		; D7 <-- D1 est inclu dans D3/D420$:	SWAP.W	D1	SWAP.W	D3	SWAP.W	D422$:	COMP.W	D2,D3	JUMP',LT 42$	COMP.W	D2,D4	JUMP',GE 42$	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	COMP.W	D2,D3	JUMP',LT 40$	COMP.W	D2,D4	JUMP',GE 40$	INC.W	D7		; D7 <-- D2 est inclu dans D3/D440$:	SWAP.W	D2	SWAP.W	D3	SWAP.W	D442$:	TEST.W	D7		; retour EQ/NE	RET;--------\\; DETLINE >;========/; Dtection fine (et lente) pour voir si la souris est dans une droite.; Pour calculer la distance entre un point et une droite, utilise la; formule suivante :;	         Ly * (Px-Dx);	l = Py - ------------ - Dy;	              Lx; Avec :;	Px/Py: position de la souris;	Dx/Dy: origine de la droite;	Lx/Ly: dimensions de la droite; Remarque :;	Si Lx < Ly => on inverse X/Y dans la formule !;	Si Lx ou Ly est nul => on accepte de toute faon; in	D2.W	marge de dtection (0..n);	D3.L	P1 (y;x);	D4.L	P2 (y;x);	D5.L	position de la souris (y;x); out	D7.W	erreur; mod	D7.WDETLINE:	PUSHM.L	D0..D6; Regarde si la souris est dans la bote qui englobe la droite.	LOAD.L	D0,D3	LOAD.L	D1,D4	COMP.W	D0,D1	JUMP',LE BOXX$	EX.L	D0,D1BOXX$:	SUB.W	D0,D2	COMP.W	D5,D0		; souris trop  gauche ?	JUMP,LT OUT$	ADD.W	D1,D2	COMP.W	D5,D1		; souris trop  droite ?	JUMP,GT OUT$	SWAP.W	D0	SWAP.W	D1	SWAP.W	D5	COMP.W	D0,D1	JUMP',LE BOXY$	EX.L	D0,D1BOXY$:	SUB.W	D0,D2	COMP.W	D5,D0		; souris trop en haut ?	JUMP,LT OUT$	ADD.W	D1,D2	COMP.W	D5,D1		; souris trop en bas ?	JUMP,GT OUT$	SWAP.W	D5; Regarde si la souris est le long de la droite.	LOAD.W	D7,D2		; D7 <-- marge de dtection	LOAD.L	D6,D5		; D6 <-- Py;Px	LOAD.W	D2,D3		; D2 <-- Dx	SWAP.W	D3		; D3 <-- Dy	SUB.W	D4,D2		; D4 <-- Lx	LOAD.L	D5,D4	SWAP.W	D5	SUB.W	D5,D3		; D5 <-- Ly	LOAD.W	D0,D4	JUMP,EQ OK$	JUMP',NC POSX$	NEG.W	D0		; D0 <-- |dX|POSX$:	LOAD.W	D1,D5	JUMP,EQ OK$	JUMP',NC POSY$	NEG.W	D1		; D1 <-- |dY|POSY$:	COMP.W	D0,D1	JUMP',LO VERT$HORIZ$:				; droite plutt horizontale =>	LOAD.W	D1,D6	SUB.W	D1,D2	MUL.WA	D1,D5	DIV.WA	D1,D4	SWAP.W	D6	SUB.W	D1,D6	SWAP.W	D6	NEG.W	D1	SUB.W	D1,D3	JUMP',NC HPOS$	NEG.W	D1HPOS$:	COMP.W	D1,D7	JUMP',LS OK$	JUMP	OUT$VERT$:				; droite plutt verticale =>	SWAP.W	D6	LOAD.W	D1,D6	SWAP.W	D6	SUB.W	D1,D3	MUL.WA	D1,D4	DIV.WA	D1,D5	SUB.W	D1,D6	NEG.W	D1	SUB.W	D1,D2	JUMP',NC VPOS$	NEG.W	D1VPOS$:	COMP.W	D1,D7	JUMP',LS OK$OUT$:	LOAD.W	D7,#ERDIOUT	; D7 <-- en dehors de la droite	JUMP'	EXIT$OK$:	CLR.W	D7		; D7 <-- le long de la droiteEXIT$:	POPM.L	D0..D6	TEST.W	D7		; retour EQ/NE	RET;------------\\; CALCPMILIEU >;============/; Calcule le point milieu d'un segment.; in	D3.L	P1 (y;x);	D4.L	P2 (y;x); out	D4.L	M (y;x); mod	D4.L, D7.WCALCPMILIEU:	SUB.W	D4,D3	ASR.W	D4,#1	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	ASR.W	D4,#1	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	RET;--------\\; STRETCH >;========/; Calcule un point "stretch" dans un quadrilatre.; in	A4.L	^paramtres (OSTP*);	D4.L	P (y;x); out	D4.L	P'(y;x); mod	D4.L, D7.WSTRETCH:	PUSHM.L	D0..D3,D5	LOAD.L	D5,D4	SWAP.W	D5	SUB.W	D4,(A4)+OSTPS0+2 ; D4 <-- X	SUB.W	D5,(A4)+OSTPS0+0 ; D5 <-- Y	LOAD.W	D0,(A4)+OSTPS2+2	SUB.W	D0,(A4)+OSTPS0+2 ; D0 <-- S2x	LOAD.W	D1,(A4)+OSTPS2+0	SUB.W	D1,(A4)+OSTPS0+0 ; D1 <-- S2y; Calcule la coordonne Y du point de sortie.;	Y' = D3y*Y/S2y + D1y*X/S2x + (D2y-D3y-D1y)*Y/S2y*X/S2x	LOAD.W	D2,(A4)+OSTPD0+0	TEST.W	D1	JUMP',EQ Y1$	LOAD.W	D3,(A4)+OSTPD3+0	SUB.W	D3,(A4)+OSTPD0+0	MUL.WA	D3,D5	DIV.WA	D3,D1	ADD.W	D2,D3Y1$:	TEST.W	D0	JUMP',EQ Y2$	LOAD.W	D3,(A4)+OSTPD1+0	SUB.W	D3,(A4)+OSTPD0+0	MUL.WA	D3,D4	DIV.WA	D3,D0	ADD.W	D2,D3Y2$:	TEST.W	D0	JUMP',EQ Y3$	TEST.W	D1	JUMP',EQ Y3$	LOAD.W	D3,(A4)+OSTPD2+0	SUB.W	D3,(A4)+OSTPD3+0	SUB.W	D3,(A4)+OSTPD1+0	ADD.W	D3,(A4)+OSTPD0+0	MUL.WA	D3,D4	DIV.WA	D3,D0	MUL.WA	D3,D5	DIV.WA	D3,D1	ADD.W	D2,D3		; D2 <-- Y'Y3$:	SWAP.W	D2; Calcule la coordonne X du point de sortie.;	X' = D3x*Y/S2y + D1x*X/S2x + (D2x-D3x-D1x)*Y/S2y*X/S2x	LOAD.W	D2,(A4)+OSTPD0+2	TEST.W	D1	JUMP',EQ X1$	LOAD.W	D3,(A4)+OSTPD3+2	SUB.W	D3,(A4)+OSTPD0+2	MUL.WA	D3,D5	DIV.WA	D3,D1	ADD.W	D2,D3X1$:	TEST.W	D0	JUMP',EQ X2$	LOAD.W	D3,(A4)+OSTPD1+2	SUB.W	D3,(A4)+OSTPD0+2	MUL.WA	D3,D4	DIV.WA	D3,D0	ADD.W	D2,D3X2$:	TEST.W	D0	JUMP',EQ X3$	TEST.W	D1	JUMP',EQ X3$	LOAD.W	D3,(A4)+OSTPD2+2	SUB.W	D3,(A4)+OSTPD3+2	SUB.W	D3,(A4)+OSTPD1+2	ADD.W	D3,(A4)+OSTPD0+2	MUL.WA	D3,D4	DIV.WA	D3,D0	MUL.WA	D3,D5	DIV.WA	D3,D1	ADD.W	D2,D3		; D2 <-- X'X3$:	LOAD.L	D4,D2	POPM.L	D0..D3,D5	RET;-----------\\; STRETCHBEZ >;===========/; Calcule les quatre points d'une courbe de Bzier "stretchs"; dans quatre courbes de Bzier.; 1)	Calcule T1 au 1/3 sur la courbe P1-S2-S2-P2;	Calcule T2 au 2/3 sur la courbe P1-S2-S2-P2;; 2)	Calcule la "projection" de tous ces points :;	P1  -->  P1';	T1  -->  T1';	T2  -->  T2';	P2  -->  P2';; 3)	Calcule S1' et S2' comme suit :;	S1' = (-5*P1'+18*T1'- 9*T2'+2*P2') /6   pour x et y;	S2' = (+2*P1'- 9*T1'+18*T2'-5*P2') /6   pour x et y; in	A4.L	^paramtres (OSBP*);	D3.L	P1 (y;x);	D4.L	S1 (y;x);	D5.L	S2 (y;x);	D6.L	P2 (y;x); out	D3.L	P1'(y;x);	D4.L	S1'(y;x);	D5.L	S2'(y;x);	D6.L	P2'(y;x); mod	D3.L, D4.L, D5.L, D6.L, D7.WSTRETCHBEZ:	PUSHM.L	D0,D1,D2,A3,A4	LOAD.L	A3,A4		; A3 <-- ^OSBP*	SUB.L	SP,#LBZ	LOAD.L	A4,SP		; A4 <-- ^variables sur le stack	LOAD.W	D2,#CHOUIA05	; D2 <-- p'tit chouia (0.5)	LOAD.W	(A4)+OBZP1X+2,D2	LOAD.W	(A4)+OBZP1Y+2,D2	LOAD.W	(A4)+OBZC1X+2,D2	LOAD.W	(A4)+OBZC1Y+2,D2	LOAD.W	(A4)+OBZC2X+2,D2	LOAD.W	(A4)+OBZC2Y+2,D2	LOAD.W	(A4)+OBZP2X+2,D2	LOAD.W	(A4)+OBZP2Y+2,D2	LOAD.L	D0,D3		; D0 <-- P1	LOAD.L	D1,D4		; D1 <-- S1; Calcule T1 au 1/3 et T2 au 2/3 de la courbe de Bzier.	LOAD.W	(A4)+OBZP1X+0,D0	SWAP.W	D0	LOAD.W	(A4)+OBZP1Y+0,D0	SWAP.W	D0	LOAD.W	(A4)+OBZC1X+0,D1	SWAP.W	D1	LOAD.W	(A4)+OBZC1Y+0,D1	SWAP.W	D1	LOAD.W	(A4)+OBZC2X+0,D5	SWAP.W	D5	LOAD.W	(A4)+OBZC2Y+0,D5	SWAP.W	D5	LOAD.W	(A4)+OBZP2X+0,D6	SWAP.W	D6	LOAD.W	(A4)+OBZP2Y+0,D6	SWAP.W	D6	LOAD.W	D4,#256*1/3	; D4 <-- au 1/3 de la courbe	CALL	__BZRPOINT	; D2/D3 <-- T1 (x;y)	SWAP.W	D2	PUSH.W	D2	SWAP.W	D3	PUSH.W	D3	LOAD.W	D4,#256*2/3	; D4 <-- au 2/3 de la courbe	CALL	__BZRPOINT	; D2/D3 <-- T2 (x;y)	SWAP.W	D2	PUSH.W	D2	SWAP.W	D3	PUSH.W	D3; Calcule P1' T1' T2' P2'.	LOAD.L	D4,D0	CALL	STRETCHBP	LOAD.L	D3,D4		; D3 <-- P1'	LOAD.L	D4,D6	CALL	STRETCHBP	LOAD.L	D6,D4		; D6 <-- P2'	POP.L	D4	CALL	STRETCHBP	LOAD.L	D5,D4		; D5 <-- T2'	POP.L	D4	CALL	STRETCHBP;	LOAD.L	D4,D4		; D4 <-- T1'; Calcule S1X'.	CLR.L	D1	LOAD.W	D2,D3	MUL.WA	D2,#5	SUB.L	D1,D2		; D1 <-- -5*P1'	LOAD.W	D2,D4	MUL.WA	D2,#18	ADD.L	D1,D2		; D1 <-- +18*T1'	LOAD.W	D2,D5	MUL.WA	D2,#9	SUB.L	D1,D2		; D1 <-- -9*T2'	LOAD.W	D2,D6	MUL.WA	D2,#2	ADD.L	D1,D2		; D1 <-- +2*P2'	DIV.WA	D1,#6	PUSH.W	D1; Calcule S2X'.	CLR.L	D1	LOAD.W	D2,D3	MUL.WA	D2,#2	ADD.L	D1,D2		; D1 <-- +2*P1'	LOAD.W	D2,D4	MUL.WA	D2,#9	SUB.L	D1,D2		; D1 <-- -9*T1'	LOAD.W	D2,D5	MUL.WA	D2,#18	ADD.L	D1,D2		; D1 <-- +18*T2'	LOAD.W	D2,D6	MUL.WA	D2,#5	SUB.L	D1,D2		; D1 <-- -5*P2'	DIV.WA	D1,#6	PUSH.W	D1; Calcule S1Y'.	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	SWAP.W	D6	CLR.L	D1	LOAD.W	D2,D3	MUL.WA	D2,#5	SUB.L	D1,D2		; D1 <-- -5*P1'	LOAD.W	D2,D4	MUL.WA	D2,#18	ADD.L	D1,D2		; D1 <-- +18*T1'	LOAD.W	D2,D5	MUL.WA	D2,#9	SUB.L	D1,D2		; D1 <-- -9*T2'	LOAD.W	D2,D6	MUL.WA	D2,#2	ADD.L	D1,D2		; D1 <-- +2*P2'	DIV.WA	D1,#6	PUSH.W	D1; Calcule S2Y'.	CLR.L	D1	LOAD.W	D2,D3	MUL.WA	D2,#2	ADD.L	D1,D2		; D1 <-- +2*P1'	LOAD.W	D2,D4	MUL.WA	D2,#9	SUB.L	D1,D2		; D1 <-- -9*T1'	LOAD.W	D2,D5	MUL.WA	D2,#18	ADD.L	D1,D2		; D1 <-- +18*T2'	LOAD.W	D2,D6	MUL.WA	D2,#5	SUB.L	D1,D2		; D1 <-- -5*P2'	DIV.WA	D1,#6	PUSH.W	D1	SWAP.W	D3;	SWAP.W	D4;	SWAP.W	D5	SWAP.W	D6; Reprend S1 et S2 sur le stack.	POP.W	D5		; D5 <-- S2Y'	SWAP.W	D5	POP.W	D4		; D4 <-- S1Y'	SWAP.W	D4	POP.W	D5		; D5 <-- S2X'	POP.W	D4		; D4 <-- S1X'	ADD.L	SP,#LBZ	POPM.L	D0,D1,D2,A3,A4	RET;----------\\; STRETCHBP >;----------/; Calcule un point "stretch" dans quatre courbes de Bzier.; in	A3.L	^paramtres (OSBP*);	A4.L	^paramtres (OBZP*);	D4.L	P (y;x); out	D4.L	P'(y;x); mod	D4.L, D7.WSTRETCHBP:	PUSHM.L	D2,D3,D5	LOAD.L	D5,D4		; D5 <-- P	LOAD.W	D4,D5	SUB.W	D4,(A3)+OSBPS0+2	MUL.WA	D4,#256	LOAD.W	D3,(A3)+OSBPS2+2	SUB.W	D3,(A3)+OSBPS0+2	DIV.WA	D4,D3		; D4 <-- 0..256 selon X	TEST.W	D4	JUMP',NC FXMIN$	CLR.W	D4FXMIN$:	COMP.W	D4,#256	JUMP',LS FXMAX$	LOAD.W	D4,#256FXMAX$:; Calcule le point le long de D0-D1.	LOAD.W	(A4)+OBZP1X+0,(A3)+OSBPD0+2	LOAD.W	(A4)+OBZP1Y+0,(A3)+OSBPD0+0	LOAD.W	(A4)+OBZC1X+0,(A3)+OSBPC01+2	LOAD.W	(A4)+OBZC1Y+0,(A3)+OSBPC01+0	LOAD.W	(A4)+OBZC2X+0,(A3)+OSBPC10+2	LOAD.W	(A4)+OBZC2Y+0,(A3)+OSBPC10+0	LOAD.W	(A4)+OBZP2X+0,(A3)+OSBPD1+2	LOAD.W	(A4)+OBZP2Y+0,(A3)+OSBPD1+0	CALL	__BZRPOINT	; D2/D3 <-- point (x;y)	PUSH.L	D2	PUSH.L	D3; Calcule le point le long de D3-D2.	LOAD.W	(A4)+OBZP1X+0,(A3)+OSBPD3+2	LOAD.W	(A4)+OBZP1Y+0,(A3)+OSBPD3+0	LOAD.W	(A4)+OBZC1X+0,(A3)+OSBPC32+2	LOAD.W	(A4)+OBZC1Y+0,(A3)+OSBPC32+0	LOAD.W	(A4)+OBZC2X+0,(A3)+OSBPC23+2	LOAD.W	(A4)+OBZC2Y+0,(A3)+OSBPC23+0	LOAD.W	(A4)+OBZP2X+0,(A3)+OSBPD2+2	LOAD.W	(A4)+OBZP2Y+0,(A3)+OSBPD2+0	CALL	__BZRPOINT	; D2/D3 <-- point (x;y)	PUSH.L	D2	PUSH.L	D3; Calcule le point le long de C03-C12.	LOAD.W	(A4)+OBZP1X+0,(A3)+OSBPC03+2	LOAD.W	(A4)+OBZP1Y+0,(A3)+OSBPC03+0	LOAD.W	D3,(A3)+OSBPC01+2	SUB.W	D3,(A3)+OSBPD0+2	ADD.W	D3,(A3)+OSBPC03+2	LOAD.W	(A4)+OBZC1X+0,D3	LOAD.W	D3,(A3)+OSBPC01+0	SUB.W	D3,(A3)+OSBPD0+0	ADD.W	D3,(A3)+OSBPC03+0	LOAD.W	(A4)+OBZC1Y+0,D3	LOAD.W	D3,(A3)+OSBPC10+2	SUB.W	D3,(A3)+OSBPD1+2	ADD.W	D3,(A3)+OSBPC12+2	LOAD.W	(A4)+OBZC2X+0,D3	LOAD.W	D3,(A3)+OSBPC10+0	SUB.W	D3,(A3)+OSBPD1+0	ADD.W	D3,(A3)+OSBPC12+0	LOAD.W	(A4)+OBZC2Y+0,D3	LOAD.W	(A4)+OBZP2X+0,(A3)+OSBPC12+2	LOAD.W	(A4)+OBZP2Y+0,(A3)+OSBPC12+0	CALL	__BZRPOINT	; D2/D3 <-- point (x;y)	PUSH.L	D2	PUSH.L	D3; Calcule le point le long de C30-C21.	LOAD.W	(A4)+OBZP1X+0,(A3)+OSBPC30+2	LOAD.W	(A4)+OBZP1Y+0,(A3)+OSBPC30+0	LOAD.W	D3,(A3)+OSBPC32+2	SUB.W	D3,(A3)+OSBPD3+2	ADD.W	D3,(A3)+OSBPC30+2	LOAD.W	(A4)+OBZC1X+0,D3	LOAD.W	D3,(A3)+OSBPC32+0	SUB.W	D3,(A3)+OSBPD3+0	ADD.W	D3,(A3)+OSBPC30+0	LOAD.W	(A4)+OBZC1Y+0,D3	LOAD.W	D3,(A3)+OSBPC23+2	SUB.W	D3,(A3)+OSBPD2+2	ADD.W	D3,(A3)+OSBPC21+2	LOAD.W	(A4)+OBZC2X+0,D3	LOAD.W	D3,(A3)+OSBPC23+0	SUB.W	D3,(A3)+OSBPD2+0	ADD.W	D3,(A3)+OSBPC21+0	LOAD.W	(A4)+OBZC2Y+0,D3	LOAD.W	(A4)+OBZP2X+0,(A3)+OSBPC21+2	LOAD.W	(A4)+OBZP2Y+0,(A3)+OSBPC21+0	CALL	__BZRPOINT	; D2/D3 <-- point (x;y)	PUSH.L	D2	PUSH.L	D3; Calcule le point P'.	LOAD.L	D4,D5	SWAP.W	D4	SUB.W	D4,(A3)+OSBPS0+0	MUL.WA	D4,#256	LOAD.W	D3,(A3)+OSBPS2+0	SUB.W	D3,(A3)+OSBPS0+0	DIV.WA	D4,D3		; D4 <-- 0..256 selon Y	TEST.W	D4	JUMP',NC FYMIN$	CLR.W	D4FYMIN$:	COMP.W	D4,#256	JUMP',LS FYMAX$	LOAD.W	D4,#256FYMAX$:	POP.L	(A4)+OBZC2Y	POP.L	(A4)+OBZC2X	POP.L	(A4)+OBZC1Y	POP.L	(A4)+OBZC1X	POP.L	(A4)+OBZP2Y	POP.L	(A4)+OBZP2X	POP.L	(A4)+OBZP1Y	POP.L	(A4)+OBZP1X	CALL	__BZRPOINT	; D2/D3 <-- point (x;y)	LOAD.L	D4,D3	SWAP.W	D2	LOAD.W	D4,D2		; D4 <-- P'	POPM.L	D2,D3,D5	RET.IF 0;----------\\; STRETCHBS >;----------/; Calcule une distance "stretche" dans quatre courbes de Bzier.; in	A4.L	^paramtres (OSBP*);	D4.L	P (y;x);	D5.L	D (dy;dx); out	D5.L	D'(dy;dx); mod	D5.L, D7.WSTRETCHBS:	PUSHM.L	D0..D3; Calcule le premier terme de dx.	LOAD.W	D3,(A4)+OSBPC01+2	SUB.W	D3,(A4)+OSBPD0+2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,D4	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D3,D2		; D3 <-- D3*(1-u)	LOAD.W	D2,(A4)+OSBPS2+0	SWAP.W	D4	SUB.W	D2,D4	SWAP.W	D4	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D3,D2		; D3 <-- D3*(1-v)	LOAD.W	D1,D3	LOAD.W	D3,(A4)+OSBPC10+2	SUB.W	D3,(A4)+OSBPD1+2	LOAD.W	D2,D4	SUB.W	D2,(A4)+OSBPS0+2	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D3,D2		; D3 <-- D3*(u)	LOAD.W	D2,(A4)+OSBPS2+0	SWAP.W	D4	SUB.W	D2,D4	SWAP.W	D4	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D3,D2		; D3 <-- D3*(1-v)	SUB.W	D1,D3	LOAD.W	D3,(A4)+OSBPC23+2	SUB.W	D3,(A4)+OSBPD2+2	LOAD.W	D2,D4	SUB.W	D2,(A4)+OSBPS0+2	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D3,D2		; D3 <-- D3*(u)	LOAD.L	D2,D4	SWAP.W	D2	SUB.W	D2,(A4)+OSBPS0+0	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D3,D2		; D3 <-- D3*(v)	SUB.W	D1,D3	LOAD.W	D3,(A4)+OSBPC32+2	SUB.W	D3,(A4)+OSBPD3+2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,D4	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D3,D2		; D3 <-- D3*(1-u)	LOAD.L	D2,D4	SWAP.W	D2	SUB.W	D2,(A4)+OSBPS0+0	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D3,D2		; D3 <-- D3*(v)	ADD.W	D1,D3	MUL.WA	D1,D5	CLR.L	D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D2,#4	DIV.WA	D1,D2; Calcule le deuxime terme de dx.	LOAD.W	D3,(A4)+OSBPC03+2	SUB.W	D3,(A4)+OSBPD0+2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,D4	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D3,D2		; D3 <-- D3*(1-u)	LOAD.W	D2,(A4)+OSBPS2+0	SWAP.W	D4	SUB.W	D2,D4	SWAP.W	D4	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D3,D2		; D3 <-- D3*(1-v)	LOAD.W	D0,D3	LOAD.W	D3,(A4)+OSBPC12+2	SUB.W	D3,(A4)+OSBPD1+2	LOAD.W	D2,D4	SUB.W	D2,(A4)+OSBPS0+2	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D3,D2		; D3 <-- D3*(u)	LOAD.W	D2,(A4)+OSBPS2+0	SWAP.W	D4	SUB.W	D2,D4	SWAP.W	D4	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D3,D2		; D3 <-- D3*(1-v)	ADD.W	D0,D3	LOAD.W	D3,(A4)+OSBPC21+2	SUB.W	D3,(A4)+OSBPD2+2	LOAD.W	D2,D4	SUB.W	D2,(A4)+OSBPS0+2	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D3,D2		; D3 <-- D3*(u)	LOAD.L	D2,D4	SWAP.W	D2	SUB.W	D2,(A4)+OSBPS0+0	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D3,D2		; D3 <-- D3*(v)	SUB.W	D0,D3	LOAD.W	D3,(A4)+OSBPC30+2	SUB.W	D3,(A4)+OSBPD3+2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,D4	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D3,D2		; D3 <-- D3*(1-u)	LOAD.L	D2,D4	SWAP.W	D2	SUB.W	D2,(A4)+OSBPS0+0	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D3,D2		; D3 <-- D3*(v)	SUB.W	D0,D3	SWAP.W	D5	MUL.WA	D0,D5	SWAP.W	D5	CLR.L	D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D2,#4	DIV.WA	D0,D2	ADD.W	D0,D1	PUSH.W	D0; Calcule le premier terme de dy.	LOAD.W	D3,(A4)+OSBPC01+0	SUB.W	D3,(A4)+OSBPD0+0	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,D4	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D3,D2		; D3 <-- D3*(1-u)	LOAD.W	D2,(A4)+OSBPS2+0	SWAP.W	D4	SUB.W	D2,D4	SWAP.W	D4	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D3,D2		; D3 <-- D3*(1-v)	LOAD.W	D1,D3	LOAD.W	D3,(A4)+OSBPC10+0	SUB.W	D3,(A4)+OSBPD1+0	LOAD.W	D2,D4	SUB.W	D2,(A4)+OSBPS0+2	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D3,D2		; D3 <-- D3*(u)	LOAD.W	D2,(A4)+OSBPS2+0	SWAP.W	D4	SUB.W	D2,D4	SWAP.W	D4	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D3,D2		; D3 <-- D3*(1-v)	SUB.W	D1,D3	LOAD.W	D3,(A4)+OSBPC23+0	SUB.W	D3,(A4)+OSBPD2+0	LOAD.W	D2,D4	SUB.W	D2,(A4)+OSBPS0+2	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D3,D2		; D3 <-- D3*(u)	LOAD.L	D2,D4	SWAP.W	D2	SUB.W	D2,(A4)+OSBPS0+0	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D3,D2		; D3 <-- D3*(v)	SUB.W	D1,D3	LOAD.W	D3,(A4)+OSBPC32+0	SUB.W	D3,(A4)+OSBPD3+0	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,D4	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D3,D2		; D3 <-- D3*(1-u)	LOAD.L	D2,D4	SWAP.W	D2	SUB.W	D2,(A4)+OSBPS0+0	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D3,D2		; D3 <-- D3*(v)	ADD.W	D1,D3	MUL.WA	D1,D5	CLR.L	D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D2,#4	DIV.WA	D1,D2; Calcule le deuxime terme de dy.	LOAD.W	D3,(A4)+OSBPC03+0	SUB.W	D3,(A4)+OSBPD0+0	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,D4	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D3,D2		; D3 <-- D3*(1-u)	LOAD.W	D2,(A4)+OSBPS2+0	SWAP.W	D4	SUB.W	D2,D4	SWAP.W	D4	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D3,D2		; D3 <-- D3*(1-v)	LOAD.W	D0,D3	LOAD.W	D3,(A4)+OSBPC12+0	SUB.W	D3,(A4)+OSBPD1+0	LOAD.W	D2,D4	SUB.W	D2,(A4)+OSBPS0+2	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D3,D2		; D3 <-- D3*(u)	LOAD.W	D2,(A4)+OSBPS2+0	SWAP.W	D4	SUB.W	D2,D4	SWAP.W	D4	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D3,D2		; D3 <-- D3*(1-v)	ADD.W	D0,D3	LOAD.W	D3,(A4)+OSBPC21+0	SUB.W	D3,(A4)+OSBPD2+0	LOAD.W	D2,D4	SUB.W	D2,(A4)+OSBPS0+2	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D3,D2		; D3 <-- D3*(u)	LOAD.L	D2,D4	SWAP.W	D2	SUB.W	D2,(A4)+OSBPS0+0	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D3,D2		; D3 <-- D3*(v)	SUB.W	D0,D3	LOAD.W	D3,(A4)+OSBPC30+0	SUB.W	D3,(A4)+OSBPD3+0	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,D4	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+2	SUB.W	D2,(A4)+OSBPS0+2	DIV.WA	D3,D2		; D3 <-- D3*(1-u)	LOAD.L	D2,D4	SWAP.W	D2	SUB.W	D2,(A4)+OSBPS0+0	MUL.WA	D3,D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D3,D2		; D3 <-- D3*(v)	SUB.W	D0,D3	SWAP.W	D5	MUL.WA	D0,D5	SWAP.W	D5	CLR.L	D2	LOAD.W	D2,(A4)+OSBPS2+0	SUB.W	D2,(A4)+OSBPS0+0	DIV.WA	D2,#4	DIV.WA	D0,D2	ADD.W	D0,D1	LOAD.W	D5,D0	SWAP.W	D5	POP.W	D5	POPM.L	D0..D3	RET.ENDIF;-------\\; FIXMUL >;=======/; in	D1.L	nombre  virgule fixe no 1;	D2.L	nombre  virgule fixe no 2; out	D0.L	nombre  virgule fixe rsultant;	VS	si dpassement de capacit (dans ce cas D0=max_fix ou min_fix selon signes); mod	D0.LFIXMUL:	PUSHM.L	D1,D2,D4,D5,D6	CALL	TOPOSITIF	LOAD.L	D4,#H'00010000	COMP.L	D1,D4		; D1 = 1.0 ?	JUMP',NE D1DIFF0$	; non => D2 = 1.0 ?	LOAD.L	D1,D2	JUMP'	MUL10$D1DIFF0$:	COMP.L	D2,D4		; D2 = 1.0 ?	JUMP',NE DIFFZERO$MUL10$:	CLR.L	D0	CLR.L	D4	LOAD.W	D4,D1	SWAP.W	D4	SWAP.W	D1	LOAD.W	D0,D1		; (D0;D4) = rsultat	JUMP'	LONGTOFIX$DIFFZERO$:	LOAD.W	D4,D2	MUL.WU	D4,D1		; D4 <-- D1.fract * D2.fract	SWAP.W	D2	LOAD.W	D5,D2	MUL.WU	D5,D1		; D5 <-- D1.fract * D2.int	SWAP.W	D1	LOAD.W	D0,D2	MUL.WU	D0,D1		; D0 <-- D1.int * D2.int	SWAP.W	D2	MUL.WU	D2,D1		; D2 <-- D1.int * D2.fract	ADD.L	D2,D5		; mid	CLR.L	D5	LOAD.W	D5,D2	SWAP.W	D5		; mid * 2**16	LOAD.W	D2,D5		; #0	SWAP.W	D2	ADD.L	D4,D5		; + low	ADDX.L	D0,D2		; mid.31..W + high + carry				; (D0;D4): rsultatLONGTOFIX$:	SWAP.W	D0	TEST.W	D0		; high word <> 0 ?	JUMP',NE SETMAX$	; oui => met la val. maximum	SWAP.W	D4	LOAD.W	D0,D4		; low res. word	TEST.L	D4		; high bit reste = 0 ?	JUMP',PL NOTROUND$	INC.L	D0		; inc res.fract	JUMP',CS SETMAX$NOTROUND$:	TEST.L	D0		; bit de signe dj mis ?	JUMP',MI SETMAX$	; ==> dbordement !	TEST.B	D6		; (VC)	JUMP',EQ EXIT$	NEG.L	D0		; met rsultat ngatif selon D1 et D2.in (VC)	JUMP'	EXIT$SETMAX$:	LOAD.L	D0,#H'00000001	RR.L	D0,#1	TEST.B	D6	JUMP',NE RTNOV$	DEC.L	D0RTNOV$:	SETV			; met le bit overflowEXIT$:	POPM.L	D1,D2,D4,D5,D6	RET;-------\\; FIXDIV >;=======/; in	D1.L	nombre  virgule fixe numrateur;	D2.L	nombre  virgule fixe dnominateur; out	D0.L	nombre  virgule fixe rsultant;	VS	si dpassement de capacit (dans ce cas D0=max_fix ou min_fix selon signes); mod	D0.LFIXDIV:	PUSHM.L	D1..D6	EX.L	D1,D2	COMP.L	D2,D1	JUMP,EQ	EQUAL$	CALL	TOPOSITIF	LOAD.L	D4,D2	TEST.L	D1		; /0 ?	JUMP',NE DODIV$		; nonOVERFLOW$:	LOAD.L	D0,#H'7FFFFFFF	TEST.B	D6		; remet ngatif si l'tait	JUMP',EQ POSOV$	INC.L	D0POSOV$:	SETV	JUMP	EXIT$DODIV$:	LOAD.L	D2,D1		; Dnom	CLR.L	D1	LOAD.L	D0,D4		; Num	CALL	INTDIV32	; Num/Denom: DIV.64 D2,(D1&D0) --> D3.L reste D4.L	JUMP,VS	OVERFLOW$	LOAD.W	D5,D3	SWAP.W	D5		; --> entier	CLR.L	D1		; reste * 2**16	SWAP.W	D4	LOAD.W	D1,D4	LOAD.L	D0,D4	CLR.W	D0	CALL	INTDIV32	; reste*2**16/ Denom	LOAD.W	D5,D3		; --> fraction	LOAD.L	D0,D5	TEST.L	D4	JUMP',PL NOROUND$	INC.L	D5	JUMP,CS	OVERFLOW$NOROUND$:	TEST.L	D5	JUMP,NS	OVERFLOW$PUTSIGN$:	TEST.B	D6		; remet ngatif si l'tait (VC)	JUMP',EQ POS$	NEG.L	D0		; (VC)POS$:	JUMP'	EXIT$EQUAL$:	LOAD.L	D0,#1	SWAP.W	D0		; (VC)EXIT$:	POPM.L	D1..D6	RETTOPOSITIF:	TEST.L	D1	SET.B,MI D6	JUMP',PL POS1$	NEG.L	D1POS1$:	TEST.L	D2	JUMP',PL POS2$	NEG.L	D2	NOT.B	D6POS2$:	RET;---------\\; INTMUL32 >;=========/; Module de multiplication 32*32 --> 64 bits (non-sign).;	-------------------;	 D1&D0 <-- D2 * D3;	-------------------; in	D2.L	multiplicande (32 bits non-sign);	D3.L	multiplicateur (32 bits non-sign); out	D1&D0.L	rsultat (64 bits non-sign); mod	D0.L, D1.LINTMUL32:	PUSHM.L D4,D5	LOAD.W	D0,D3	MUL.WU	D0,D2		; D0 low longword <-- low word * low word	SWAP.W	D2	LOAD.W	D5,D3		; D5 mid longword <-- high word * low word	MUL.WU	D5,D2	SWAP.W	D3	LOAD.W	D1,D3		; D1 high long <-- high word * high word	MUL.WU	D1,D2	SWAP.W	D2	LOAD.W	D4,D3		; D4 mid long <-- high word * low word	MUL.WU	D4,D2	SWAP.W	D3	SWAP.W	D1	ADD.L	D4,D5		; ADD.L D4,D5 avec report sur D1 si ncessessaire	CLR.W	D5	ADDX.W	D1,D5	SWAP.W	D1	ADDX.W	D1,D5	LOAD.W	D5,D1		; ADD.64 D1&D0,D4*(2^16)	SWAP.W	D5	SWAP.W	D0	LOAD.W	D5,D0	ADD.L	D5,D4	LOAD.W	D0,D5	SWAP.W	D0	SWAP.W	D5	LOAD.W	D1,D5	SWAP.W	D1	CLR.L	D5	ADDX.L	D1,D5	SWAP.W	D1	POPM.L	D4,D5	RET;---------\\; INTDIV32 >;=========/; Module de division 64/32 --> 32 bits (non-sign).;	-------------------;	 D3 <-- D1&D0 / D2;	 D4 <-- reste;	-------------------; ATTENTION: pas de test de division par zro !; in	D1&D0.L	numrateur (64 bits non-sign);	D2.L	dnominateur (32 bits non-sign); out	D3.L	rsultat (32 bits non-sign);	D4.L	reste (32 bits non-sign);	VS	overflow; mod	D3.L, D4.LINTDIV32:	PUSHM.L D0,D1	LOAD.W	D4,#32-1	; D4 <-- dcompteur de bouclesLOOP$:	SETX	RLX.L	D0	RLX.L	D1	JUMP',CS ERROR$	SUB.L	D1,D2	JUMP',HS NEXT$	ADD.L	D1,D2	TCLR.L	D0:#0		; bit 0 si rtablissementNEXT$:	DECJ.W,NMO D4,LOOP$	COMP.L	D1,D2		; reste >= diviseur ?	JUMP',HS ERROR$	LOAD.L	D3,D0		; D3 <-- quotient	LOAD.L	D4,D1		; D4 <-- reste,	 F <-- V=0	JUMP'	EXIT$ERROR$:	SETV			; F <-- V=1EXIT$:	POPM.L	D0,D1	RET	.END