	.SBTTL	OPCADRDBOX.ASI;----------\\; DBOXCOINE >;==========/; Choix pour les coins extrieurs.; in	A4.L	^objet; out	D3.L	dernire touche (F1/F4/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXCOINE:	PUSHM.L	D0..D2,D4,D5,A0..A4	LOAD.L	A0,(A5)+OPDDIS	; A0 <-- ^descripteur fentre	LOAD.L	A1,A4		; A1 <-- ^objet	LOAD.L	A2,#R16"TDBOX$	LOAD.W	D7,#DB_MEMPT	PAGE_	DBOX		; mj ^table dbox	LOAD.L	A2,#R16"DBCOINSHOWEC	LOAD.W	D7,#DB_MEMAFC	PAGE_	DBOX		; mj ^routine d'affichage	LOAD.W	(A5)+ODBP1,(A1)+OOBDE	LOAD.W	(A5)+ODBP2,(A1)+OOBCOE	CLR.L	D4		; D4 <-- fanions	LOAD.L	A2,#R16"TDBOX_COINE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.W	D7,#DB_OPEN	PAGE_	DBOX		; ouvre la DBOX	JUMP,NE EXIT$	CALL	DBCOINDRAW	; dessine la scroll-liste	CLR.W	D2AFF$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_AFF	PAGE_	DBOX		; affiche le paramtre	INC.W	D2	COMP.W	D2,#1	JUMP,LO AFF$	CLR.W	D2NLINE$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_MEDIT	PAGE_	DBOXSHOW$:	CALL	DBCOINSHOWELOOP$:	LOAD.W	D7,#MI_SCMO	PAGE_	MISC		; remet la souris	DBOX_	EDIT		; attend une action ...	LOAD.W	D7,#DB_ZEROCR	PAGE_	DBOX		; remplace <CR> par <0>	PUSH.L	A1	LOAD.L	A1,#R16"TKEY_COINE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	POP.L	A1	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F4	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#CLEAR	JUMP',EQ UNDO$	COMP.W	D3,#CR	JUMP',EQ RETURN$	COMP.W	D3,#ENTER	JUMP',EQ ENTER$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	SHOW$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,#1	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$ENTER$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	JUMP	SHOW$KEYDBOX$:			; KEYDBOX =>	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	COMP.B	D3,#100	JUMP',HS CLINE$	JUMP	LOOP$CLINE$:	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$CLIC$:	CALL	DBCOINMOVE	; dplace la scroll-liste ...	JUMP,EQ SHOW$	LOAD.W	D7,#DB_CLIC	PAGE_	DBOX	JUMP,EQ LOOP$	JUMP	BIP$OK$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	LOAD.W	(A1)+OOBDE,(A5)+ODBP1	LOAD.W	(A1)+OOBCOE,(A5)+ODBP2END$:	LOAD.W	D7,#DB_CLOSE	PAGE_	DBOX		; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A0..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	ODBP1,DBTYPU,0,2000*FACMMPT,10*FACMMPT,2^BDBGCLABEL!100,0,8+2	.W	-1TDBOX_COINE:	.W	10$-TDBOX_COINE	.W	20$-TDBOX_COINE	.W	0,010$:	.B	ODBLABEL,10	.B	ODBTEXT,0	.B	ODBTABX,16	.B	ODBTEXT	.ASCIZ	"Choix pour le cadre extrieur :"	.B	ODBCR,ODBCR	.B	ODBTABX,16	.B	ODBTEXT	.ASCIZ	"Dimension d'un coin  "	.B	ODBLABEL,100	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCR,ODBCR2	.B	ODBTABX,16	.B	ODBLABEL,12	.B	ODBTEXT,0	.B	ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBTABX,16+32	.B	ODBLABEL,13	.B	ODBTEXT,0	.B	ODBCR,ODBCR,ODBCR	.B	ODBTABX,16-3	.B	ODBLABEL,11	.B	ODBTEXT,0	.B	ODBTABX,16	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	"  D'ACCORD  "	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	"   ANNULE   "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_COINE:	.W	F1,F2,F3,0		DOKF1-TKEY_COINE	.W	F0,F13,F14,F15,0	DOKF0-TKEY_COINE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_COINE	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_COINE	.W	0;----------\\; DBOXCOINI >;==========/; Choix pour les coins intrieurs.; in	A4.L	^objet; out	D3.L	dernire touche (F1/F4/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXCOINI:	PUSHM.L	D0..D2,D4,D5,A0..A4	LOAD.L	A0,(A5)+OPDDIS	; A0 <-- ^descripteur fentre	LOAD.L	A1,A4		; A1 <-- ^objet	LOAD.L	A2,#R16"TDBOX$	LOAD.W	D7,#DB_MEMPT	PAGE_	DBOX		; mj ^table dbox	LOAD.L	A2,#R16"DBCOINSHOWIC	LOAD.W	D7,#DB_MEMAFC	PAGE_	DBOX		; mj ^routine d'affichage	LOAD.W	(A5)+ODBP1,(A1)+OOBE	LOAD.W	(A5)+ODBP2,(A1)+OOBCOI	LOAD.W	(A5)+ODBP3,(A1)+OOBDI	CLR.L	D4		; D4 <-- fanions	LOAD.L	A2,#R16"TDBOX_COINI	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.W	D7,#DB_OPEN	PAGE_	DBOX		; ouvre la DBOX	JUMP,NE EXIT$	CALL	DBCOINDRAW	; dessine la scroll-liste	CLR.W	D2AFF$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_AFF	PAGE_	DBOX		; affiche le paramtre	INC.W	D2	COMP.W	D2,#2	JUMP,LO AFF$	CLR.W	D2NLINE$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_MEDIT	PAGE_	DBOXSHOW$:	CALL	DBCOINSHOWILOOP$:	LOAD.W	D7,#MI_SCMO	PAGE_	MISC		; remet la souris	DBOX_	EDIT		; attend une action ...	LOAD.W	D7,#DB_ZEROCR	PAGE_	DBOX		; remplace <CR> par <0>	PUSH.L	A1	LOAD.L	A1,#R16"TKEY_COINI	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	POP.L	A1	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F4	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#CLEAR	JUMP',EQ UNDO$	COMP.W	D3,#CR	JUMP',EQ RETURN$	COMP.W	D3,#ENTER	JUMP',EQ ENTER$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	SHOW$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,#2	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$ENTER$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	JUMP	SHOW$KEYDBOX$:			; KEYDBOX =>	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	COMP.B	D3,#100	JUMP',HS CLINE$	JUMP	LOOP$CLINE$:	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$CLIC$:	CALL	DBCOINMOVE	; dplace la scroll-liste ...	JUMP,EQ SHOW$	LOAD.W	D7,#DB_CLIC	PAGE_	DBOX	JUMP,NE BIP$	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_MEDIT	PAGE_	DBOX	JUMP	LOOP$OK$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	LOAD.W	(A1)+OOBE,(A5)+ODBP1	LOAD.W	(A1)+OOBCOI,(A5)+ODBP2	LOAD.W	(A1)+OOBDI,(A5)+ODBP3END$:	LOAD.W	D7,#DB_CLOSE	PAGE_	DBOX		; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A0..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	ODBP3,DBTYPU,0,2000*FACMMPT,10*FACMMPT,2^BDBGCLABEL!100,0,8+2	.W	ODBP1,DBTYPU,0,2000*FACMMPT,10*FACMMPT,2^BDBGCLABEL!101,1,8+2	.W	-1TDBOX_COINI:	.W	10$-TDBOX_COINI	.W	20$-TDBOX_COINI	.W	0,010$:	.B	ODBLABEL,10	.B	ODBTEXT,0	.B	ODBTABX,16	.B	ODBTEXT	.ASCIZ	"Choix pour le cadre intrieur :"	.B	ODBCR,ODBCR	.B	ODBTABX,16	.B	ODBTEXT	.ASCIZ	"Dimension d'un coin  "	.B	ODBLABEL,100	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCR,ODBCR	.B	ODBTABX,16	.B	ODBTEXT	.ASCIZ	"Epaisseur du cadre   "	.B	ODBLABEL,101	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,101,TDBNORM	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCR,ODBCR2	.B	ODBTABX,16	.B	ODBLABEL,12	.B	ODBTEXT,0	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBTABX,16+32	.B	ODBLABEL,13	.B	ODBTEXT,0	.B	ODBCR,ODBCR,ODBCR	.B	ODBTABX,16-3	.B	ODBLABEL,11	.B	ODBTEXT,0	.B	ODBTABX,16	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	"  D'ACCORD  "	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	"   ANNULE   "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_COINI:	.W	F1,F2,F3,0		DOKF1-TKEY_COINI	.W	F0,F13,F14,F15,0	DOKF0-TKEY_COINI	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_COINI	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_COINI	.W	0;-------------\\; DBCOINSHOWEC >;-------------/; Montre le cadre choisi, pendant DB_CLIC.; in	D2.W	mode (SETDOT/CLRDOT); out	-; mod	D7.WDBCOINSHOWEC:	COMP.W	D2,#SETDOT	JUMP',EQ DBCOINSHOWE	RET;------------\\; DBCOINSHOWE >;------------/; Montre le cadre choisi.; in	-; out	-; mod	D7.WDBCOINSHOWE:	PUSHM.L	D2..D4	LOAD.W	D2,#2^BDBGCLABEL!13	DBOX_	GETCO	PUSH.L	D3	LOAD.W	D2,#2^BDBGCLABEL!12	DBOX_	GETCO	POP.L	D4	ADD.W	D4,#4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,#9	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	CALL	DRAWTESTE	; dessine le coin sup/gauche	POPM.L	D2..D4	RET;-------------\\; DBCOINSHOWIC >;-------------/; Montre le cadre choisi, pendant DB_CLIC.; in	D2.W	mode (SETDOT/CLRDOT); out	-; mod	D7.WDBCOINSHOWIC:	COMP.W	D2,#SETDOT	JUMP',EQ DBCOINSHOWI	RET;------------\\; DBCOINSHOWI >;------------/; Montre le cadre choisi.; in	-; out	-; mod	D7.WDBCOINSHOWI:	PUSHM.L	D2..D4	LOAD.W	D2,#2^BDBGCLABEL!13	DBOX_	GETCO	PUSH.L	D3	LOAD.W	D2,#2^BDBGCLABEL!12	DBOX_	GETCO	POP.L	D4	ADD.W	D4,#4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,#9	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	CALL	DRAWTESTI	; dessine le coin sup/gauche	POPM.L	D2..D4	RET;-----------\\; DBCOINDRAW >;-----------/; Dessine la scroll-liste.; in	-; out	-; mod	D7.WDBCOINDRAW:	PUSHM.L	D2..D4,A4..A6	LOAD.L	A6,A5		; A6 <-- ^variables globales	LOAD.L	A5,#(A6)+OSLVAR	; A5 <-- ^variables scroll-liste	LOAD.W	D2,#2^BDBGCLABEL!11	DBOX_	GETCO	PUSH.L	D3	LOAD.W	D2,#2^BDBGCLABEL!10	DBOX_	GETCO	POP.L	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,#16	ADD.W	D4,#20	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A5)+OSLPOS,D3	LOAD.L	(A5)+OSLDIM,D4	PUSH.W	(A0)+ODFCY	PUSH.W	(A0)+ODFC1Y	PUSH.W	(A0)+ODFC2Y	LOAD.W	(A0)+ODFCY,#30	LOAD.W	(A0)+ODFC1Y,#30	LOAD.W	(A0)+ODFC2Y,#0	SCROLL_	LDRAW		; dessine la scroll-liste vide	POP.W	(A0)+ODFC2Y	POP.W	(A0)+ODFC1Y	POP.W	(A0)+ODFCY	LOAD.W	(A5)+OSLCYN,#MAXCOIN	LOAD.W	(A5)+OSLCYS,(A6)+ODBP2	LOAD.L	A4,#R16"DBCOINCASE	LOAD.L	(A5)+OSLADA,A4	SCROLL_	LUPDATE		; dessine le contenu de la scroll-liste	POPM.L	D2..D4,A4..A6	RET;-----------\\; DBCOINCASE >;-----------/; Affiche le contenu d'une case.; in	A6.L	^variables globales;	D3.W	rang de la case (0..n);	D4.W	nb de caractres; out	D3.W	zro; mod	D3.L, D7.WDBCOINCASE:	PUSHM.L	D2,D4,A0,A5,A6	LOAD.L	A5,A6		; A5 <-- ^variables globales	LOAD.L	A6,(A5)+OPPA6	; A6 <-- ^variables de PAGE	LOAD.L	A0,(A5)+OPDDIS	; A0 <-- ^descripteur fentre	LIB	?NOBUCAR	; ?BUCAR fait par SCROLL_LUPDATE !	LOAD.L	D2,#2^16	; D2 <-- pas de rectangle	LOAD.W	D2,D3		; D2 <-- rang de la case (0..n)	TEST.B	(A0)+ODFFLG:#BFVIDI	JUMP',BC INV$	TSET.L	D2:#17		; D2 <-- affiche en inverseINV$:	LOAD.L	D3,(A0)+ODFPY	; D3 <-- position du curseur	DEC.W	D3	SWAP.W	D3	SUB.W	D3,(A5)+OSLVAR+OSLCAR+0	DEC.W	D3	SWAP.W	D3	MUL.WU	D4,(A5)+OSLVAR+OSLCAR+2	INC.W	D4	SWAP.W	D4	LOAD.W	D4,(A5)+OSLVAR+OSLCAR+0	INC.W	D4	SWAP.W	D4	CALL	DRAWTESTSL	; dessine le coin sup/gauche	POPM.L	D2,D4,A0,A5,A6	CLR.W	D3	CLR.W	D7		; retour EQ	RET;-----------\\; DBCOINMOVE >;-----------/; Dplace la scroll-liste.; in	-; out	D7.W	erreur; mod	D7.WDBCOINMOVE:	PUSHM.L	D3,D4,A5,A6	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP',NE EXIT$	SUB.W	D4,(A0)+ODFFX	JUMP',LO EXIT$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	JUMP',LO EXIT$	SWAP.W	D4	LOAD.L	A6,A5		; A6 <-- ^variables globales	LOAD.L	A5,#(A6)+OSLVAR	; A5 <-- ^variables scroll-liste	SCROLL_	LMOVE		; dplace la scroll-liste ...	JUMP',NE EXIT$	LOAD.W	(A6)+ODBP2,(A5)+OSLCYSEXIT$:	POPM.L	D3,D4,A5,A6	TEST.W	D7		; retour EQ/NE	RET.IF 0;--------\\; DRAWICO >;========/; Affiche une icne dans une dbox.; in	D2.W	rang ou label dans la dbox;	D3.W	numro de l'icne;	D5.L	canal dbox; out	-; mod	D7.WDRAWICO:	PUSHM.L	D2..D4,A3,A4	CALL	XopGETICONE	; A4 <-- ^dx,dy,matrice	JUMP',NE EXIT$	DBOX_	GETCO		; D3 <-- position	JUMP',NE EXIT$	LOAD.L	A3,#(A5)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWMATRIX	ADD.W	D3,#8*3	SWAP.W	D3	SUB.W	D3,#16	LOAD.L	(A3)+1,D3	LOAD.L	(A3)+5,A4	LOAD.B	(A3)+9,#SETDOT	LOAD.W	D3,#10	LIB	?STRING		; affiche l'icneEXIT$:	POPM.L	D2..D4,A3,A4	RET.ENDIF;--------\\; DOK...  >;========/DOKMGR:	LOAD.W	D3,#KEYMGR	RETDOKMGP:	LOAD.W	D3,#KEYMGP	RETDOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RETDOKF4:	LOAD.W	D3,#F4	RETDOKF7:	LOAD.W	D3,#F7	RETDOKF10:	LOAD.W	D3,#F10	RETDOKF13:	LOAD.W	D3,#F13	RET	.END