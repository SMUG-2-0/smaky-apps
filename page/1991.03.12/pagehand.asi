	.SBTTL	PAGEHAND.ASI;-----------\\; HANDSELECT >;===========/; Slectionne un objet avec la poigne.; in	D4.L	position de la souris (y;x);	A1.L	^routine pour objets  exclure (*); out	A4.L	^objet slectionn;	D7.W	erreur; mod	D7.W, A4.L; Routine (*) :; in	A4.L	^objet; out	D7.W	erreur si objet  exclure; mod	D7.WHANDSELECT:	PUSHM.L	D2..D4,D6,A2	PUSH.L	(A6)+OAPOS	CALL	DETOBJET	; A4 <-- ^objet montr	LOAD.L	A2,A4	LOAD.W	D2,#1		; D2 <-- open	CALL	DESISHIFT	; dessine le premier objetLOOP$:	CALL	_SCMO		; remet la souris	LOAD.W	D2,#2		; D2 <-- shift	CALL	DESISHIFT	; fait tourner le traitill	CALL	_WAITMOVES	; attend dplacement ...	JUMP,NE END$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE LOOP$	CALL	_CONVSCROBJ	; D4 <-- position [obj]	JUMP,NE LOOP$	CALL	DETOBJET	; A4 <-- ^objet montr	COMP.L	A4,A2		; toujours le mme objet ?	JUMP,EQ LOOP$		; oui => LOOP$				; non =>	EX.L	A2,A4	LOAD.W	D2,#3		; D2 <-- close	CALL	DESISHIFT	; efface l'ancien objet	LOAD.L	A4,A2	LOAD.W	D2,#1		; D2 <-- open	CALL	DESISHIFT	; dessine le nouvel objet	JUMP	LOOP$CHG$:	LOAD.L	A4,A2	LOAD.W	D2,#3		; D2 <-- close	CALL	DESISHIFT	; efface le dernier objet	LOAD.L	A4,#0	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$END$:	CALL	_NBMOUSE	; D3 <-- nombre de boutons presss	COMP.W	D3,#2	JUMP,HS CHG$	LOAD.L	A4,A2	LOAD.W	D2,#3		; D2 <-- close	CALL	DESISHIFT	; efface le dernier objet	CLR.W	D7		; D7 <-- ok	COMP.L	A4,#0	JUMP',NE EXIT$	LOAD.W	D7,#ERPAHANDENDEXIT$:	POP.L	(A6)+OAPOS	POPM.L	D2..D4,D6,A2	TEST.W	D7		; retour EQ/NE	RET;-----------\\; HANDIFSEL1 >;-----------/; Regarde s'il est possible de slectionner un objet.; Accepte si l'objet est pre, frre ou fils du premier objet slectionn.; in	A4.L	^objet slectionn; out	D7.W	erreur; mod	D7.WHANDIFSEL1:	PUSHM.L	A2..A4	PUSH.L	(A6)+OAPOS	LOAD.L	A2,A4		; A2 <-- ^objet  slectionner	LOAD.L	A3,(A6)+OSELPS	; A3 <-- ^premier objet slectionn	COMP.L	A2,A3		; est-ce le premier objet slectionn ?	JUMP',EQ NOSEL$		; oui => NOSEL$	TEST.B	(A6)+OSELSS:#BKILL ; touche (KILL) enfonce ?	JUMP',BS SEL$		; oui => SEL$;	LOAD.L	A4,A2	CALL	_LSTA_FRERE	; est-ce deux frres ?	JUMP',EQ SEL$		; oui => SEL$;	LOAD.L	A4,A2	CALL	_LSTA_PREVP	; A4 <-- ^pre	COMP.L	A4,A3		; est-ce que le premier slectionn est le pre ?	JUMP',EQ SEL$	LOAD.L	A4,A3	CALL	_LSTA_PREVP	; A4 <-- ^pre	COMP.L	A4,A2		; est-ce que l'objet  slectionner est le pre ?	JUMP',NE NOSEL$		; non => NOSEL$SEL$:	CLR.W	D7		; D7 <-- slection possible	JUMP'	EXIT$NOSEL$:	LOAD.W	D7,#1		; D7 <-- slection refuseEXIT$:	POP.L	(A6)+OAPOS	POPM.L	A2..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; HANDIFSEL2 >;-----------/; Regarde s'il est possible de slectionner un objet.; Accepte seulement si l'objet est frre du premier objet slectionn (cousins interdits).; in	A4.L	^objet slectionn; out	D7.W	erreur; mod	D7.WHANDIFSEL2:	PUSH.L	A3	CLR.W	D7		; D7 <-- slection possible	TEST.L	(A6)+OSELPS	JUMP',EQ EXIT$	LOAD.L	A3,(A6)+OSELPS	; A3 <-- ^premier objet slectionn	CALL	_LSTA_FRERE	; est-ce deux frres ?EXIT$:	POP.L	A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; HANDLIMIT >;==========/; Cherche les limites en fonction du pre d'un objet slectionn.; in	A4.L		^objet slectionn; out	(A6)+OLIMP1.L	P1 (y;x);	(A6)+OLIMP2.L	P2 (y;x); mod	D7.WHANDLIMIT:	PUSHM.L	D3,D4,A4	PUSH.L	(A6)+OAPOS	CALL	_LSTA_PREVP	; A4 <-- ^pre	JUMP',NE ALL$	CALL	_LSTA_BBOX	; D3/D4 <-- bbox du pre	LOAD.L	(A6)+OLIMP1,D3	LOAD.L	(A6)+OLIMP2,D4	JUMP',NE EXIT$ALL$:	CLR.L	(A6)+OLIMP1	LOAD.L	(A6)+OLIMP2,(A6)+ODESYDEXIT$:	POP.L	(A6)+OAPOS	POPM.L	D3,D4,A4	RET;-----------\\; EDITSELECT >;===========/; Slectionne un objet pour l'diter.; in	D4.L	position de la souris [scr];	A3.L	^objet actuel; out	A4.L	^objet slectionn;	D4.L	position slection [obj];	D7.W	erreur; mod	D4.L, D7.W, A4.LEDITSELECT:	PUSHM.L	D2..D3,A2	CALL	_CONVSCROBJ	; D4 <-- position [obj]	JUMP,NE EXIT$	CALL	DEEOBJET	; A4 <-- ^objet montr	JUMP',NE DET1$	COMP.L	A4,A3		; est-ce l'objet actuel ?	JUMP',NE DET1$		; non => DET1$	LOAD.L	A4,#0DET1$:	LOAD.L	A2,A4	LOAD.W	D2,#1		; D2 <-- open	CALL	DESISHIFT	; dessine le premier objet	LOAD.W	D3,#ICOOEDIT	CALL	_SELMO		; utilise le bon lutinLOOP$:	CALL	_SCMO		; remet la souris	LOAD.W	D2,#2		; D2 <-- shift	CALL	DESISHIFT	; fait tourner le traitill	CALL	_WAITMOVES	; attend dplacement ...	JUMP',NE END$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE LOOP$	CALL	_CONVSCROBJ	; D4 <-- position [obj]	JUMP,NE LOOP$	CALL	DEEOBJET	; A4 <-- ^objet montr	JUMP',NE DET2$	COMP.L	A4,A3		; est-ce l'objet actuel ?	JUMP',NE DET2$		; non => DET2$	LOAD.L	A4,#0DET2$:	COMP.L	A4,A2		; toujours le mme objet ?	JUMP,EQ LOOP$		; oui => LOOP$				; non =>	EX.L	A2,A4	LOAD.W	D2,#3		; D2 <-- close	CALL	DESISHIFT	; efface l'ancien objet	LOAD.L	A4,A2	LOAD.W	D2,#1		; D2 <-- open	CALL	DESISHIFT	; dessine le nouvel objet	JUMP	LOOP$END$:	LOAD.L	A4,A2	LOAD.W	D2,#3		; D2 <-- close	CALL	DESISHIFT	; efface le dernier objet	CLR.W	D7		; D7 <-- ok	COMP.L	A4,#0	JUMP',NE EXIT$	LOAD.W	D7,#ERPAHANDENDEXIT$:	POPM.L	D2..D3,A2	TEST.W	D7		; retour EQ/NE	RET;-------------\\; HANDUNDOCOPY >;=============/; Copie un objet, en tenant compte des chanes.; in	A4.L	^objet; out	D7.W	erreur; mod	D7.WHANDUNDOCOPY:	PUSHM.L	D2,D5,A4	CALL	HANDUNDOFLUSH	; annule l'objet copi	CALL	SUITEEXIST	; fait partie d'une chane ?	JUMP',NE SINGLE$	; non => SINGLE$PREV$:	CALL	SUITEPREV	; A4 <-- ^objet prcdent	JUMP,EQ PREV$	CLR.L	D5		; D5 <-- info initialeNEXT$:	LOAD.W	D2,#opCRCOPYUNDO	CALL'	HANDUNDOCOP1	; copie un objet d'une chane	JUMP',NE EXIT$	CALL	SUITENEXT	; A4 <-- ^objet suivant	JUMP,EQ NEXT$	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$SINGLE$:	LOAD.W	D2,#opCRCOPYXFER	CALL'	HANDUNDOCOP1	; copie un objet solitaireEXIT$:	POPM.L	D2,D5,A4	TEST.W	D7		; retour EQ/NE	RET;-------------\\; HANDUNDOCOP1 >;-------------/; Copie un objet, afin de pouvoir revenir  l'tat initial (undo).; in	A4.L	^objet;	D2.W	mthode opCRCOPYXFER/UNDO;	D5.L	info reue du prcdent (zro si premier); out	D5.L	info passe au suivant;	D7.W	erreur; mod	D5.L, D7.WHANDUNDOCOP1:	PUSHM.L	D0,D1,D4,D6,A2..A4	LOAD.L	D6,(A6)+ODALCH	; D6 <-- canal de la liste des datas	LOAD.L	A2,A4		; A2 <-- ^racine de l'objet  copier	LOAD.L	A3,(A2)+OobjPDATA ; A3 <-- ^data de l'objet source	LOAD.W	D0,(A2)+OobjIDENT	LOAD.W	D1,#opCRCOPYLG	CALL	_OBJCALL	; D4 <-- lg ncessaire	JUMP',NE EXIT$	LOAD.L	A4,#0	CALL	_LST_INSERT	; A4 <-- ^data pour copie objet	JUMP',NE EXIT$	LOAD.L	(A2)+OobjPCOPY,A4	LOAD.W	D1,D2		; D2 <-- mthode opCRCOPYXFER/UNDO	CALL	_OBJCALL	; (A4)++ <-- (A3)++EXIT$:	POPM.L	D0,D1,D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;-------------\\; HANDUNDOBACK >;=============/; Remplace un objet par sa copie effectue lors du HANDUNDOCOPY.; in	A4.L	^objet; out	-; mod	D7.WHANDUNDOBACK:	PUSH.L	A1	LOAD.L	A1,#R16"HANDUNDOBAC1	CALL	SUITEEXEC	POP.L	A1	RET;-------------\\; HANDUNDOBAC1 >;-------------/; Remplace un objet par sa copie effectue lors du HANDUNDOCOPY.; in	A4.L	^objet; out	-; mod	D7.WHANDUNDOBAC1:	PUSHM.L	D0,D1,D3,D4,D6,A3,A4	LOAD.L	D6,(A6)+ODALCH	; D6 <-- canal de la liste des datas	LOAD.L	A3,A4		; A3 <-- ^racine de l'objet  rcuprer	LOAD.L	A4,(A3)+OobjPDATA ; A4 <-- ^data de l'objet original	LOAD.W	D0,(A3)+OobjIDENT	LOAD.W	D1,#opCRCLOSE	CALL	_OBJCALL	; ferme l'objet	CALL	_LST_REMOVE	; enlve de la liste des datas	LOAD.L	(A3)+OobjPDATA,(A3)+OobjPCOPY	CLR.L	(A3)+OobjPCOPY	LOAD.L	A4,A3	LOAD.W	D1,#opGETBBOX	CALL	_OBJCALLD	; D3/D4 <-- bounding box	LOAD.L	(A4)+OobjBBOX1,D3	LOAD.L	(A4)+OobjBBOX2,D4	TCLR.B	(A4)+OobjFLAGS:#BobjEXTEND	TCLR.B	(A4)+OobjFLAGS:#BobjABS	POPM.L	D0,D1,D3,D4,D6,A3,A4	RET;--------------\\; HANDUNDOFLUSH >;==============/; Annule l'objet copi lors du HANDUNDOCOPY.; in	A4.L	^objet; out	-; mod	D7.WHANDUNDOFLUSH:	PUSH.L	A1	LOAD.L	A1,#R16"HANDUNDOFLU1	CALL	SUITEEXEC	POP.L	A1	RET;-------------\\; HANDUNDOFLU1 >;-------------/; Annule l'objet copi lors du HANDUNDOCOPY.; in	A4.L	^objet; out	-; mod	D7.WHANDUNDOFLU1:	PUSHM.L	D0,D1,D6,A3,A4	LOAD.L	D6,(A6)+ODALCH	; D6 <-- canal de la liste des datas	LOAD.L	A3,A4		; A3 <-- ^racine de l'objet  rcuprer	TEST.L	(A3)+OobjPCOPY	JUMP',EQ EXIT$	LOAD.L	A4,(A3)+OobjPCOPY	LOAD.W	D0,(A3)+OobjIDENT	LOAD.W	D1,#opCRCLOSE	CALL	_OBJCALL	; ferme l'objet	CALL	_LST_REMOVE	; enlve de la liste des datas	CLR.L	(A3)+OobjPCOPYEXIT$:	POPM.L	D0,D1,D6,A3,A4	RET;-----------\\; HANDUNDOEX >;===========/; Echange le data avec la copie.; in	A4.L	^objet; out	-; mod	D7.WHANDUNDOEX:	PUSH.L	D4	LOAD.L	D4,(A4)+OobjPCOPY	JUMP',EQ EXIT$	LOAD.L	(A4)+OobjPCOPY,(A4)+OobjPDATA	LOAD.L	(A4)+OobjPDATA,D4EXIT$:	POP.L	D4	RET;-----------\\; HANDDETECT >;===========/; Dtecte dans quelle poigne est la souris.; in	A4.L	^objet;	D4.L	position de la souris (y;x)  [scr]; out	D2.W	rang de la poigne (0..n,-1);	D7.W	erreur; mod	D2.L, D7.WHANDDETECT:	PUSHM.L	D1,D3..D6	LOAD.W	D5,D4		; D5 <-- position en X	LOAD.L	D6,D4	SWAP.W	D6		; D6 <-- position en Y	CLR.W	D2		; D2 <-- rang de la poigneLOOP$:	LOAD.W	D1,#opHANDGET	CALL	_OBJCALLD	; D3/D4 <-- icne/position	JUMP',EQ EXIST$	COMP.W	D7,#ERPAHANDDNE	JUMP',EQ NEXT$	LOAD.W	D2,#-1		; D2 <-- poigne inexistante	JUMP'	EXIT$EXIST$:	ADD.W	D4,(A6)+OAPOS+2	SWAP.W	D4	ADD.W	D4,(A6)+OAPOS+0	SWAP.W	D4	CALL	_CONVOBJSCR	; D4 <-- position [scr]	JUMP',NE NEXT$	SUB.W	D4,#DPOIGNEE	COMP.W	D5,D4		; trop  gauche ?	JUMP',LT NEXT$	ADD.W	D4,#DPOIGNEE*2	COMP.W	D5,D4		; trop  droite ?	JUMP',GE NEXT$	SWAP.W	D4	SUB.W	D4,#DPOIGNEE	COMP.W	D6,D4		; trop haut ?	JUMP',LT NEXT$	ADD.W	D4,#DPOIGNEE*2	COMP.W	D6,D4		; trop bas ?	JUMP',LT EXIT$NEXT$:	INC.W	D2		; D2 <-- poigne suivante	JUMP	LOOP$EXIT$:	POPM.L	D1,D3..D6	TEST.W	D7		; retour EQ/NE	RET;-----------\\; HANDSETONE >;-----------/; Allume une poigne.; Lorsque la poigne est allume, on sauve au pralable ce qui est dessous.; in	D2.W	rang de la poigne (0..n);	D3.W	icne (ICOHANDxxx);	D4.L	coordonne de la poigne (y;x); out	-; mod	D7.WHANDSETONE:	PUSHM.L	D0..D6,A1..A4	LOAD.W	D0,D3		; D0 <-- icne	SUB.W	D4,(A6)+ODESX1	SWAP.W	D4	SUB.W	D4,(A6)+ODESY1	SWAP.W	D4	CALL	_SCALEP	ADD.W	D4,#-7+15	JUMP,NS EXIT$	ADD.W	D4,#-15	COMP.W	D4,(A0)+ODFFDX	JUMP,GE EXIT$	SWAP.W	D4	ADD.W	D4,#-7+15	JUMP,NS EXIT$	ADD.W	D4,#-15	COMP.W	D4,(A0)+ODFFDY	JUMP,GE EXIT$	SWAP.W	D4	LOAD.L	D5,D4		; D5 <-- coordonne (y;x)	PUSH.L	D4	LOAD.L	D4,#H'10000*COLORFPAGE+COLORCDRAW	CALL	DRCOLORINIT	POP.L	D4	LOAD.L	A1,#(A6)+OPOIPFE	SL.W	D2,#2	ADD.W	A1,D2		; A1 <-- ^^buffer/nil	TEST.L	(A1)	JUMP',NE MEMOK$	LOAD.L	D4,#32	TEST.B	(A0)+ODFCMD	JUMP',EQ MEMGET$	SL.L	D4,#2		; D4 <-- taille *4MEMGET$:	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour sauver sous une poigne	JUMP,NE EXIT$	LOAD.L	(A1),A4MEMOK$:	CALL	_CCMO		; enlve la souris	LOAD.L	A3,#0		; A3 <-- ^source (cran)	LOAD.L	D3,D5		; D3 <-- coordonne source;	CLR.W	D5		; D5 <-- Iy source	LOAD.L	A4,(A1)		; A4 <-- ^destination (mmoire)	CLR.L	D4		; D4 <-- coordonne destination	LOAD.L	D2,#H'10000*16+16	LOAD.L	A2,A0	TEST.B	(A0)+ODFCMD	JUMP',NE SVFCOUL$	LOAD.W	D6,#2		; D6 <-- Iy destination	LOAD.W	D1,#LOADDOT	GRA_	RASTER		; sauve le fond	JUMP'	SVFEND$SVFCOUL$:	LOAD.W	D6,#2*4		; D6 <-- Iy destination	LOAD.W	D1,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	GRA_	CRASTER		; sauve le fond couleurSVFEND$:	LOAD.L	D4,D3		; D4 <-- coordonne destination	LOAD.L	A3,(A6)+OPGICO	; A3 <-- ^gencar des icnes IPP21	TCLR.L	D0:#7	JUMP',BC GENC$	LOAD.L	A3,(A6)+OPHICO	; A3 <-- ^gencar des icnes IPP22GENC$:	MUL.WU	D0,(A3)+OGCMSB	ADD.L	D0,#OGCMAT	ADD.L	A3,D0		; A3 <-- ^source (matrice)	LOAD.L	D3,#16		; D3 <-- coordonne source (pour fond)	LOAD.W	D5,#GCICX/8	; D5 <-- Iy source	LOAD.L	A4,#0		; A4 <-- ^destination (cran);	CLR.W	D6		; D6 <-- Iy destination;	LOAD.L	D2,#H'10000*16+16;	LOAD.L	A2,A0	TEST.B	(A0)+ODFCMD	JUMP',NE CLRCOUL$	LOAD.W	D1,#CLRDOT	GRA_	RASTER		; efface selon l'icne du fond	JUMP'	CLREND$CLRCOUL$:	LOAD.W	D1,#CLRDOT!2^BDSTCOUL	GRA_	CRASTER		; efface selon l'icne du fondCLREND$:	CLR.W	D3		; D3 <-- coordonne x source (pour chair)	TEST.B	(A0)+ODFCMD	JUMP',NE SETCOUL$	LOAD.W	D1,#SETDOT	GRA_	RASTER		; dessine selon l'icne de la chair	JUMP'	SETEND$SETCOUL$:	LOAD.W	D1,#SETDOT!2^BDSTCOUL	GRA_	CRASTER		; dessine selon l'icne de la chairSETEND$:EXIT$:	POPM.L	D0..D6,A1..A4	RET;-----------\\; HANDCLRONE >;-----------/; Eteint une poigne.; Lorsque la poigne est teinte, on remet simplement ce qui tait dessous.; in	D2.W	rang de la poigne (0..n);	D3.W	icne (ICOHANDxxx);	D4.L	coordonne de la poigne (y;x); out	-; mod	D7.WHANDCLRONE:	PUSHM.L	D0..D6,A1..A4	LOAD.W	D0,D3		; D0 <-- icne	SUB.W	D4,(A6)+ODESX1	SWAP.W	D4	SUB.W	D4,(A6)+ODESY1	SWAP.W	D4	CALL	_SCALEP	SUB.W	D4,#7	SWAP.W	D4	SUB.W	D4,#7	SWAP.W	D4		; D4 <-- coordonne (y;x)	LOAD.L	A1,#(A6)+OPOIPFE	SL.W	D2,#2	ADD.W	A1,D2		; A1 <-- ^^buffer/nil	TEST.L	(A1)	JUMP',EQ EXIT$	CALL	_CCMO		; enlve la souris	LOAD.L	A3,(A1)		; A3 <-- ^source (mmoire)	CLR.L	D3		; D3 <-- coordonne source	LOAD.L	A4,#0		; A4 <-- ^destination (cran);	LOAD.L	D4,D4		; D4 <-- coordonne destination;	CLR.W	D6		; D6 <-- iy destination	LOAD.L	D2,#H'10000*16+16	LOAD.L	A2,A0	TEST.B	(A0)+ODFCMD	JUMP',NE RMFCOUL$	LOAD.W	D5,#2		; D5 <-- Iy source	LOAD.W	D1,#LOADDOT	GRA_	RASTER		; remet le fond	JUMP'	RMFEND$RMFCOUL$:	LOAD.W	D5,#2*4		; D5 <-- Iy source	LOAD.W	D1,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	GRA_	CRASTER		; remet le fond couleurRMFEND$:	LOAD.L	A4,A3	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	CLR.L	(A1)EXIT$:	POPM.L	D0..D6,A1..A4	RET;------------\\; HANDSETFILS >;------------/; Allume tous les fils d'un pre.; in	A4.L	^objet pre; out	-; mod	D7.WHANDSETFILS:	PUSHM.L	D2,D4,A4	PUSH.L	(A6)+OAPOS	CALL	_LSTA_NB	; D4 <-- nb de fils	TEST.W	D4	JUMP',EQ EXIT$LOOP$:	CALL	_LSTA_NEXT	; A4 <-- ^fils suivant	JUMP',NE EXIT$	LOAD.L	D2,#2^BVUESET!2^BVUEPROV!2^BVUEPROVE!2^BVUEPROVI	CALL	DESOBJET	; allume l'objet	DEC.W	D4	JUMP,NE LOOP$EXIT$:	POP.L	(A6)+OAPOS	POPM.L	D2,D4,A4	RET;------------\\; HANDCLRFILS >;------------/; Eteint tous les fils d'un pre.; in	A4.L	^objet pre; out	-; mod	D7.WHANDCLRFILS:	PUSHM.L	D2,D4,A4	PUSH.L	(A6)+OAPOS	CALL	_LSTA_NB	; D4 <-- nb de fils	TEST.W	D4	JUMP',EQ EXIT$LOOP$:	CALL	_LSTA_NEXT	; A4 <-- ^fils suivant	JUMP',NE EXIT$	LOAD.L	D2,#2^BVUECLR!2^BVUEPROV!2^BVUEPROVE!2^BVUEPROVI	CALL	DESOBJET	; teint l'objet	DEC.W	D4	JUMP,NE LOOP$EXIT$:	POP.L	(A6)+OAPOS	POPM.L	D2,D4,A4	RET;----------\\; HANDPOSOK >;==========/; Vrifie si la position d'un objet est correcte, c'est--dire :;   -	s'il ne dpasse pas les limites de son pre;   -	s'il n'est pas plus petit que ses fils;;	+---------------------+;	|  +--------------+   |;	|  |    +-------+ |<---------  objet vrifi;	|  |    |       | |   |;	|  |    |       |<-----------  fils  (OLIMB1/B2);	|  |    |       | |   |;	|  |    +-------+ |   |<-----  pre  (OLIMP1/P2);	|  |              |   |;	|  +--------------+   |;	+---------------------+;; HANDPOSOKQ (=quick) ne recalcule pas la bbox !; in	A4.L	^objet; out	D7.W	erreur; mod	D7.WHANDPOSOK:	PUSHM.L	D1,D3,D4	LOAD.W	D1,#opGETBBOX	CALL	_OBJCALLD	; D3/D4 <-- bounding box	LOAD.L	(A4)+OobjBBOX1,D3	LOAD.L	(A4)+OobjBBOX2,D4	POPM.L	D1,D3,D4HANDPOSOKQ:	PUSHM.L	D1..D4	COMP.L	(A4)+OobjBBOX1,#H'7FFF7FFF	JUMP',EQ OK$	CALL	_LSTA_BBOX	; D3/D4 <-- bbox de l'objet	LOAD.L	D1,D3	LOAD.L	D2,D4	LOAD.L	D3,(A6)+OLIMP1	LOAD.L	D4,(A6)+OLIMP2	CALL	_RECTTEST	; D1/D2 inclu dans D3/D4 ?	COMP.W	D7,#2		; les deux coins inclus ?	JUMP',NE ERROR$		; non => ERROR$	LOAD.L	D3,D1	LOAD.L	D4,D2	LOAD.L	D1,(A6)+OLIMB1	LOAD.L	D2,(A6)+OLIMB2	JUMP',EQ OK$	CALL	_RECTTEST	; D1/D2 inclu dans D3/D4 ?	COMP.W	D7,#2		; les deux coins inclus ?	JUMP',NE ERROR$		; non => ERROR$OK$:	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$ERROR$:	LOAD.W	D7,#1		; D7 <-- position impossibleEXIT$:	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RET	.END