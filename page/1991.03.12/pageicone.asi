	.SBTTL	PAGEICONE.ASI;---------\\; MAJICONE >;=========/;---------\\; UPDICONE >;=========/; Met  jour les icnes variables.; in	A4.L	^objet (si NICOCREATE/SELECT/EDIT); out	-; mod	D7.WMAJICONE:	LOAD.W	(A6)+OICOST,#-1	; vide la table des tats des icnesUPDICONE:	PUSHM.L	D0..D4,D6,A2..A4	PUSH.L	(A6)+OAPOS	LOAD.W	D3,(A6)+OICONIV	COMP.W	D3,#NICOSELECT	JUMP,EQ SELECT$	COMP.W	D3,#NICOEDIT	JUMP,EQ EDIT$	COMP.W	D3,#NICOCREATE	JUMP,EQ CREATE$	COMP.W	D3,#NICOSUITE	JUMP,EQ SUITE$; Met  jour les icnes normales.	CALL	UPDICONEOUTIL	; allume l'outil choisi	LOAD.W	D4,#STICOGREY	LOAD.W	D3,#ICOOFLECHE	CALL	MSTICONE	; grise l'icne	LOAD.W	D3,#ICOOOPER	CALL	MSTICONE	; grise l'icne	LOAD.W	D3,#ICOOGROUPE	CALL	MSTICONE	; grise l'icne	LOAD.W	D3,#ICOOPLAN	CALL	MSTICONE	; grise l'icne	LOAD.W	D3,(A6)+OOUTIL;	COMP.W	D3,#ICOOCRAYON;	JUMP',EQ NCRAYON$	COMP.W	D3,#ICOOLOUPE	JUMP,EQ LOUPE$	COMP.W	D3,#ICOOMAIN	JUMP,EQ MAIN$	COMP.W	D3,#ICOOEDIT	JUMP',EQ NEDIT$	COMP.W	D3,#ICOOSUITE	JUMP',EQ NSUITE$NCRAYON$:	CALL	UPDICONEBASE	; met  jour les icnes de base	JUMP	EXIT$NEDIT$:	JUMP	EXIT$NSUITE$:	LOAD.W	D4,#STICOGREY	LOAD.W	D3,#ICOSRAZ	CALL	MSTICONE	; grise l'icne	LOAD.W	D3,#ICOSCOULE	CALL	MSTICONE	; grise l'icne	LOAD.W	D3,#ICOSLIBERE	CALL	MSTICONE	; grise l'icne	LOAD.W	D3,#ICOSMOVE	CALL	MSTICONE	; grise l'icne	LOAD.W	D3,#ICOSMOVEI	CALL	MSTICONE	; grise l'icne	JUMP	EXIT$; Met  jour les icnes pendant une slection.SELECT$:	CALL	UPDICONEOUTIL	; allume l'outil choisi	COMP.W	(A6)+OSELNB,#1	JUMP,NE SEL4$	LOAD.L	A4,(A6)+OSELPS	; A4 <-- ^objet	LOAD.W	D4,#STICONORM	CALL	__HANDPOSOK	; objet  la bonne place ?	JUMP',EQ SEL22$		; oui => SEL22$	LOAD.W	D4,#STICOGREYSEL22$:	LOAD.W	D3,#ICODACCORD	CALL	MSTICONE	; grise l'icne "d'accord"	LOAD.W	D3,#ICODUPLIQUE	CALL	MSTICONE	; grise l'icne "duplique"	COMP.W	(A4)+OobjIDENT,#IDENTFGROUP	JUMP',LO SEL33$	COMP.W	(A4)+OobjIDENT,#IDENTLGROUP	JUMP',HS SEL33$	LOAD.W	D4,#STICOGREY	LOAD.W	D3,#ICOGROUPMAKE	CALL	MSTICONE	; grise l'icne "assemble"	JUMP'	SEL36$SEL33$:	LOAD.W	D4,#STICOGREY	LOAD.W	D3,#ICOOCRAYON	CALL	MSTICONE	; grise l'icne "crayon"SEL36$:	LOAD.W	D1,#opHANDICOGET	CALL	UPDICONEGET	; met  jour les icnes	LOAD.W	D4,#STICONORM	LOAD.W	D3,#ICOOSUITE	CALL	MSTICONE	; dgrise l'icne "suite"	JUMP'	SEL5$SEL4$:	CALL	UPDICONESDF	; met  jour les icnes des tats	LOAD.W	D4,#STICOGREY	LOAD.W	D3,#ICOOCRAYON	CALL	MSTICONE	; grise l'icne "crayon"	LOAD.W	D3,#ICOOSUITE	CALL	MSTICONE	; grise l'icne "suite"SEL5$:	LOAD.W	D4,#STICOGREY	COMP.W	(A6)+OSELNB,#1	JUMP',NE SEL6$	LOAD.W	D1,#opEDITICOLIST	CALL	OBJCALLD	; A2/A3 <-- ^soft-keys/^icnes	JUMP',NE SEL6$	LOAD.W	D4,#STICONORMSEL6$:	LOAD.W	D3,#ICOOEDIT	CALL	MSTICONE	; grise l'icne "dite"	LOAD.W	D3,(A6)+OOUTIL;	COMP.W	D3,#ICOOCRAYON;	JUMP',EQ CRAYON$	COMP.W	D3,#ICOOLOUPE	JUMP',EQ LOUPE$	COMP.W	D3,#ICOOMAIN	JUMP',EQ MAIN$	COMP.W	D3,#ICOOFLECHE	JUMP',EQ FLECHE$	COMP.W	D3,#ICOOOPER	JUMP',EQ OPER$	COMP.W	D3,#ICOOGROUPE	JUMP,EQ GROUPE$	COMP.W	D3,#ICOOPLAN	JUMP,EQ PLAN$; Met  jour toutes les icnes pendant la cration d'un objet.CRAYON$:	CALL	UPDICONEBASE	; met  jour les icnes de base	JUMP	EXIT$; Met  jour toutes les icnes pendant le dplacement de plusieurs objets.FLECHE$:	JUMP	EXIT$; Met  jour toutes les icnes pendant d'agrandissement d'une slection.LOUPE$:	LOAD.W	D3,(A6)+OLOUPE	CALL	GSTICONE	; bon outil allum ?	COMP.W	D4,#STICOINV	JUMP,EQ EXIT$	LOAD.W	D4,#STICONORM	LOAD.W	D3,#ICOOLOUPEP	CALL	MSTICONE	; teint l'icne	LOAD.W	D3,#ICOOLOUPEM	CALL	MSTICONE	; teint l'icne	LOAD.W	D3,(A6)+OLOUPE	LOAD.W	D4,#STICOINV	CALL	MSTICONE	; allume l'icne	JUMP	EXIT$; Met  jour toutes les icnes pendant le dplacement d'une slection.MAIN$:	JUMP	EXIT$; Met  jour toutes les icnes pendant une opration sur une slection.OPER$:	LOAD.W	D3,(A6)+OOPER	COMP.W	D3,#ICOZZOOM	JUMP,EQ ZOOM$	COMP.W	D3,#ICOZTOURNE	JUMP,EQ TOURNE$	COMP.W	D3,#ICOZMIROIR	JUMP,EQ MIROIR$	COMP.W	D3,#ICOZDEFORME	JUMP,EQ DEFORME$	COMP.W	D3,#ICOZDEFBEZ	JUMP,EQ DEFBEZ$	JUMP	EXIT$; Met  jour les icnes pendant un zoom.ZOOM$:	LOAD.W	D4,#STICONORM	TEST.B	(A6)+OZONHO	JUMP',EQ ZOOM2$	LOAD.W	D4,#STICOINVZOOM2$:	LOAD.W	D3,#ICOZHOMOT	CALL	MSTICONE	; allume/teint l'icne	JUMP	OPEND$; Met  jour les icnes pendant une rotation.TOURNE$:	JUMP	OPEND$; Met  jour les icnes pendant un miroir.MIROIR$:	JUMP	OPEND$; Met  jour les icnes pendant une dformation.DEFORME$:	LOAD.W	D2,(A6)+OZONDF	; D2 <-- type de dformation	LOAD.W	D4,#STICONORM	LOAD.W	D3,#ICODQQ	COMP.W	D3,D2	JUMP',NE DEFQQ$	LOAD.W	D4,#STICOINVDEFQQ$:	CALL	MSTICONE	LOAD.W	D4,#STICONORM	LOAD.W	D3,#ICODTRAH	COMP.W	D3,D2	JUMP',NE DEFTRAH$	LOAD.W	D4,#STICOINVDEFTRAH$:	CALL	MSTICONE	LOAD.W	D4,#STICONORM	LOAD.W	D3,#ICODTRAV	COMP.W	D3,D2	JUMP',NE DEFTRAV$	LOAD.W	D4,#STICOINVDEFTRAV$:	CALL	MSTICONE	LOAD.W	D4,#STICONORM	LOAD.W	D3,#ICODPARH	COMP.W	D3,D2	JUMP',NE DEFPARH$	LOAD.W	D4,#STICOINVDEFPARH$:	CALL	MSTICONE	LOAD.W	D4,#STICONORM	LOAD.W	D3,#ICODPARV	COMP.W	D3,D2	JUMP',NE DEFPARV$	LOAD.W	D4,#STICOINVDEFPARV$:	CALL	MSTICONE	JUMP	OPEND$; Met  jour les icnes pendant une dformation.DEFBEZ$:	LOAD.W	D2,(A6)+OZONDFB	; D2 <-- type de dformation	LOAD.W	D4,#STICONORM	LOAD.W	D3,#ICOBQQ	COMP.W	D3,D2	JUMP',NE DBZQQ$	LOAD.W	D4,#STICOINVDBZQQ$:	CALL	MSTICONE	LOAD.W	D4,#STICONORM	LOAD.W	D3,#ICOBHORIZ	COMP.W	D3,D2	JUMP',NE DBZHOR$	LOAD.W	D4,#STICOINVDBZHOR$:	CALL	MSTICONE	LOAD.W	D4,#STICONORM	LOAD.W	D3,#ICOBVERTI	COMP.W	D3,D2	JUMP',NE DBZVER$	LOAD.W	D4,#STICOINVDBZVER$:	CALL	MSTICONE	LOAD.W	D2,(A6)+OZONDFC	; D2 <-- type de dformation (symtries)	LOAD.W	D4,#STICONORM	LOAD.W	D3,#ICOBSYMH	COMP.W	D3,D2	JUMP',NE DBZX$	LOAD.W	D4,#STICOINVDBZX$:	CALL	MSTICONE	LOAD.W	D4,#STICONORM	LOAD.W	D3,#ICOBSYMV	COMP.W	D3,D2	JUMP',NE DBZY$	LOAD.W	D4,#STICOINVDBZY$:	CALL	MSTICONE	LOAD.W	D4,#STICONORM	LOAD.W	D3,#ICOBSYMVI	COMP.W	D3,D2	JUMP',NE DBZXY$	LOAD.W	D4,#STICOINVDBZXY$:	CALL	MSTICONE;	JUMP'	OPEND$; Met  jour les icnes pendant une opration zoom, tourne, miroir ou dformation.OPEND$:	LOAD.W	D4,#STICONORM	COMP.W	(A6)+OOPER,#ICOZZOOM	JUMP',NE OPEND2$	LOAD.W	D4,#STICOINVOPEND2$:	LOAD.W	D3,#ICOZZOOM	CALL	MSTICONE	; allume l'icne zoom	LOAD.W	D4,#STICONORM	COMP.W	(A6)+OOPER,#ICOZTOURNE	JUMP',NE OPEND3$	LOAD.W	D4,#STICOINVOPEND3$:	LOAD.W	D3,#ICOZTOURNE	CALL	MSTICONE	; allume l'icne tourne	LOAD.W	D4,#STICONORM	COMP.W	(A6)+OOPER,#ICOZMIROIR	JUMP',NE OPEND4$	LOAD.W	D4,#STICOINVOPEND4$:	LOAD.W	D3,#ICOZMIROIR	CALL	MSTICONE	; allume l'icne miroir	LOAD.W	D4,#STICONORM	COMP.W	(A6)+OOPER,#ICOZDEFORME	JUMP',NE OPEND5$	LOAD.W	D4,#STICOINVOPEND5$:	LOAD.W	D3,#ICOZDEFORME	CALL	MSTICONE	; allume l'icne dforme	LOAD.W	D4,#STICONORM	COMP.W	(A6)+OOPER,#ICOZDEFBEZ	JUMP',NE OPEND6$	LOAD.W	D4,#STICOINVOPEND6$:	LOAD.W	D3,#ICOZDEFBEZ	CALL	MSTICONE	; allume l'icne dforme selon Bzier	TEST.B	(A6)+OZONDE	; dformation possible ?	JUMP',EQ OPEND7$	; oui => OPEND7$	LOAD.W	D4,#STICOGREY	LOAD.W	D3,#ICOZDEFORME	CALL	MSTICONE	; grise l'icne dforme selon quadrilatreOPEND7$:	TEST.B	(A6)+OZONDB	; dformation possible ?	JUMP',EQ OPEND8$	; oui => OPEND8$	LOAD.W	D4,#STICOGREY	LOAD.W	D3,#ICOZDEFBEZ	CALL	MSTICONE	; grise l'icne dforme selon BzierOPEND8$:	TEST.B	(A6)+OZONZO	; zoom possible ?	JUMP',EQ OPEND9$	; oui => OPEND9$	LOAD.W	D4,#STICOGREY	LOAD.W	D3,#ICOZZOOM	CALL	MSTICONE	; grise l'icne zoomOPEND9$:	JUMP	EXIT$; Met  jour toutes les icnes pendant le groupe d'une slection.GROUPE$:	LOAD.W	D4,#STICOINV	LOAD.W	D3,#ICOHGROUPE	CALL	MSTICONE	; allume l'icne	JUMP	EXIT$; Met  jour toutes les icnes pendant le plan d'une slection.PLAN$:	LOAD.W	D3,(A6)+OPLAN	CALL	GSTICONE	; bon outil allum ?	COMP.W	D4,#STICOINV	JUMP',EQ PLAN2$	LOAD.W	D4,#STICONORM	LOAD.W	D3,#ICOODEVANT	CALL	MSTICONE	; teint l'icne	LOAD.W	D3,#ICOODERRIERE	CALL	MSTICONE	; teint l'icne	LOAD.W	D3,(A6)+OPLAN	LOAD.W	D4,#STICOINV	CALL	MSTICONE	; allume l'icnePLAN2$:	JUMP	EXIT$; Met  jour toutes les icnes, selon la mthode "opEDITICOGET" de; l'objet captur pour l'diter.EDIT$:	CALL	UPDICONEOUTIL	; allume l'outil choisi	LOAD.W	D4,#STICOGREY	LOAD.W	D3,#ICOOCRAYON	CALL	MSTICONE	; grise l'icne	LOAD.W	D1,#opEDITICOGET	CALL	UPDICONEGET	; met  jour les icnes	LOAD.W	D3,(A6)+OOUTIL	COMP.W	D3,#ICOOLOUPE	JUMP,EQ LOUPE$	COMP.W	D3,#ICOOMAIN	JUMP,EQ MAIN$;	COMP.W	D3,#ICOOEDIT;	JUMP',EQ EEDIT$EEDIT$:	JUMP	EXIT$; Met  jour toutes les icnes, selon la mthode "opCRICOGET" de; l'objet en cours de cration.CREATE$:	CALL	UPDICONEOUTIL	; allume l'outil choisi	LOAD.W	D4,#STICOGREY	LOAD.W	D3,#ICOOEDIT	CALL	MSTICONE	; grise l'icne "dite"	LOAD.W	D3,#ICOOSUITE	CALL	MSTICONE	; grise l'icne "suite"	LOAD.W	D1,#opCRICOGET	CALL	UPDICONEGET	; met  jour les icnes	LOAD.W	D3,(A6)+OOUTIL;	COMP.W	D3,#ICOOCRAYON;	JUMP,EQ CCRAYON$	COMP.W	D3,#ICOOLOUPE	JUMP,EQ LOUPE$	COMP.W	D3,#ICOOMAIN	JUMP,EQ MAIN$CCRAYON$:	JUMP	EXIT$; Met  jour toutes les icnes, pendant une opration "suite".SUITE$:	CALL	UPDICONEOUTIL	; allume l'outil choisi	CALL	__SUITENB	; D4 <-- nb d'objets numrots	LOAD.W	D2,D4	LOAD.W	D4,#STICOGREY	LOAD.W	D3,#ICOOCRAYON	CALL	MSTICONE	; grise l'icne	TEST.W	D2	JUMP',EQ SUITE22$	LOAD.L	A4,(A6)+OSSTA+OSSOBJ ; A4 <-- ^objet	CALL	__SUITEIFOBJV	; objet dans la page visible ?	JUMP',NE SUITE22$	; non => 22$	LOAD.W	D4,#STICONORMSUITE22$:	LOAD.W	D3,#ICOOFLECHE	CALL	MSTICONE	; grise l'icne	LOAD.W	D3,#ICOOOPER	CALL	MSTICONE	; grise l'icne	LOAD.W	D3,#ICOOGROUPE	CALL	MSTICONE	; grise l'icne	LOAD.W	D3,#ICOOPLAN	CALL	MSTICONE	; grise l'icne	COMP.W	D4,#STICOGREY	JUMP',EQ SUITE23$	LOAD.W	D4,#STICOGREY	LOAD.L	A4,(A6)+OSSTA+OSSOBJ ; A4 <-- ^objet	LOAD.W	D1,#opEDITICOLIST	CALL	OBJCALLD	; A2/A3 <-- ^soft-keys/^icnes	JUMP',NE SUITE23$	LOAD.W	D4,#STICONORMSUITE23$:	LOAD.W	D3,#ICOOEDIT	CALL	MSTICONE	; grise l'icne	LOAD.W	D3,(A6)+OOUTIL	COMP.W	D3,#ICOOLOUPE	JUMP,EQ LOUPE$	COMP.W	D3,#ICOOMAIN	JUMP,EQ MAIN$	LOAD.W	D4,#STICOGREY	COMP.W	D2,#1	JUMP',LO SUITE32$	LOAD.W	D4,#STICONORMSUITE32$:	LOAD.W	D3,#ICOSLIBERE	CALL	MSTICONE	; grise l'icne	LOAD.W	D3,#ICOSRAZ	CALL	MSTICONE	; grise l'icne	LOAD.W	D4,#STICOGREY	COMP.W	D2,#2	JUMP',LO SUITE33$	LOAD.W	D4,#STICONORMSUITE33$:	LOAD.W	D3,#ICOSCOULE	CALL	MSTICONE	; grise l'icne	LOAD.W	D3,#ICOSMOVE	CALL	MSTICONE	; grise l'icne	LOAD.W	D3,#ICOSMOVEI	CALL	MSTICONE	; grise l'icne;	JUMP'	EXIT$EXIT$:	POP.L	(A6)+OAPOS	POPM.L	D0..D4,D6,A2..A4	RET;--------------\\; UPDICONEOUTIL >;--------------/; Allume le bon outil.; in	-; out	-; mod	D7.WUPDICONEOUTIL:	PUSHM.L	D1,D3,D4,A4	LOAD.W	D3,(A6)+OOUTIL	CALL	GSTICONE	; bon outil allum ?	COMP.W	D4,#STICOINV	JUMP',EQ EXIT$	LOAD.L	A4,#R16"TABLE$	LOAD.W	D4,#STICONORM	CLR.W	D1LOOP$:	LOAD.W	D3,(A4+)	JUMP',EQ NEXT$	CALL	MSTICONE	; teint l'icneNEXT$:	INC.W	D1	COMP.W	D1,#9	JUMP,LO LOOP$	LOAD.W	D3,(A6)+OOUTIL	LOAD.W	D4,#STICOINV	CALL	MSTICONE	; allume l'icneEXIT$:	POPM.L	D1,D3,D4,A4	RETTABLE$:	.W	ICOOCRAYON	.W	ICOOLOUPE	.W	ICOOMAIN	.W	ICOOFLECHE	.W	ICOOOPER	.W	ICOOEDIT	.W	ICOOGROUPE	.W	ICOOPLAN	.W	ICOOSUITE;-------------\\; UPDICONEBASE >;-------------/; Met   jour les icnes de base.; in	-; out	-; mod	D7.WUPDICONEBASE:	PUSHM.L	D0..D4,A4; Grise tous les objets inutiliss.	LOAD.W	D3,#ICOOBJET	LOAD.W	D2,#4-1	ADD.W	D2,(A6)+OICOSY	MUL.WU	D2,#3		; D2 <-- nb max d'objetsOLOOP$:	LOAD.W	D4,#STICOGREY	LOAD.W	D0,D3		; D0 <-- icne	ADD.W	D0,(A6)+OICOFO	SUB.W	D0,#ICOOBJET	; D0 <-- rang	CALL	OBJGETID	; D0 <-- identificateur	JUMP',NE ONEXT$	LOAD.W	D4,#STICONORM	COMP.W	D3,(A6)+OOBJET	JUMP',NE ONEXT$	LOAD.W	D4,#STICOINVONEXT$:	CALL	MSTICONE	; grise/dgrise/inverse un objet	INC.W	D3	DEC.W	D2	JUMP,NE OLOOP$; Grise tous les tats inutiliss.	LOAD.L	A4,#R16"NOST$	; A4 <-- ^aucun tat	LOAD.W	D0,(A6)+OOBJET	; D0 <-- icne	ADD.W	D0,(A6)+OICOFO	SUB.W	D0,#ICOOBJET	; D0 <-- rang	CALL	OBJGETID	; D0 <-- identificateur	JUMP',NE DEF$	LOAD.W	D1,#opIDENTSTATE ; D1 <-- mthode	CALL	OBJCALL		; A4 <-- ^identificateurs des tatsDEF$:	LOAD.W	D3,#ICOSTATE	LOAD.W	D2,#NBISTATE-1DLOOP$:	CALL	GSTICONE	; identificateur d'tat dj dessine ?	JUMP',EQ DNODRAW$	; oui => DNODRAW$	CALL	DESICONEONE	; dessine une icne d'tatDNODRAW$:	LOAD.W	D4,#STICOGREY	COMP.W	(A4),#-1	JUMP',EQ DNEXT$	TEST.W	(A4+)	JUMP',EQ DNEXT$	LOAD.W	D4,#STICONORMDNEXT$:	CALL	MSTICONE	; grise/dgrise un tat	INC.W	D3	DECJ.W,NMO D2,DLOOP$; Grise les flches pour parcourir les objets.	LOAD.W	D4,#STICOGREY	TEST.W	(A6)+OICOFO	JUMP',EQ UP$	LOAD.W	D4,#STICONORMUP$:	LOAD.W	D3,#ICOFUP	CALL	MSTICONE	; grise/dgrise une flche	LOAD.W	D2,#STICOGREY	CALL	OBJGETNB	; D4 <-- nombre d'objets connects	ADD.W	D4,#3-1	AND.L	D4,#H'FFFF	DIV.WU	D4,#3		; D4 <-- nb de lignes	LOAD.W	D3,#4-1	ADD.W	D3,(A6)+OICOSY	ADD.W	D4,D3	DEC.W	D4	AND.L	D4,#H'FFFF	DIV.WU	D4,D3		; D4 <-- nb de chapitres	DEC.W	D4	JUMP',LS DOWN$	MUL.WU	D4,D3	MUL.WU	D4,#3	COMP.W	D4,(A6)+OICOFO	JUMP',LS DOWN$	LOAD.W	D2,#STICONORMDOWN$:	LOAD.W	D4,D2	LOAD.W	D3,#ICOFDOWN	CALL	MSTICONE	; grise/dgrise une flche	POPM.L	D0..D4,A4	RETNOST$:	.W	-1;------------\\; UPDICONEGET >;------------/; Met  jour toutes les icnes selon une mthodes.; in	D1.W	mthode "op*ICOGET"; out	-; mod	D7.WUPDICONEGET:	PUSHM.L	D3,D4,A3,A4	LOAD.L	A4,(A6)+OSELPS	; A4 <-- ^objet	CALL	PTGICONE	; A3 <-- ^icnes de gaucheLOOP$:	LOAD.W	D3,(A3+)	COMP.W	D3,#OPIF	; fin de la table ?	JUMP',EQ EXIT$		; oui => EXIT$	COMP.W	D3,#OPIL	JUMP,EQ LOOP$	COMP.W	D3,#OPIC	JUMP,EQ LOOP$	COMP.W	D3,#OPIC13	JUMP,EQ LOOP$	LOAD.W	D3,(A3+)	; D3 <-- icne	ADD.L	A3,#2	PUSH.L	A3;	LOAD.W	D1,#op???ICOGET	CALL	OBJCALLD	; D4/A3 <-- tat de l'icne/^liste	POPM.L	A3	JUMP,NE LOOP$	CALL	MSTICONE	; modifie l'tat de l'icne	JUMP	LOOP$EXIT$:	POPM.L	D3,D4,A3,A4	RET;------------\\; UPDICONESDF >;------------/; Met  jour les icnes de dfinitions lors d'une slection.; in	-; out	-; mod	D7.WUPDICONESDF:	PUSHM.L	D0..D4,A2	LOAD.L	A2,#(A6)+OSELID	; A2 <-- ^identificateurs de dfinition	LOAD.W	D3,#ICOALLST	LOAD.W	D2,#NBISTATE-1LOOP$:	LOAD.W	D4,#STICOGREY	; D4 <-- icne grise	LOAD.W	D0,(A2+)	; D0 <-- identificateur de dfinition	JUMP',EQ NEXT$	CALL	GSTICONE	; D4 <-- identificateur d'tat dj dessine ?	JUMP',EQ NODRAW$	; oui => NODRAW$	CALL	DESICONEONE	; dessine une icne d'tatNODRAW$:	LOAD.W	D4,#STICONORM	; D4 <-- icne normaleNEXT$:	CALL	MSTICONE	; grise/dgrise un tat	INC.W	D3	DECJ.W,NMO D2,LOOP$	POPM.L	D0..D4,A2	RET;---------\\; MSTICONE >;=========/; Modifie l'tat d'une icne.; in	D3.W	icne;	D4.W	nouvel tat (STICOxxxx); out	-; mod	D7.WMSTICONE:	PUSHM.L	D2,A4	LOAD.L	A4,#(A6)+OICOST-4 ; A4 <-- ^table des tats	CLR.W	D2LOOP$:	ADD.L	A4,#4		; A4 <-- ^icne suivante	INC.W	D2	COMP.W	(A4),#-1	; fin de la table ?	JUMP,EQ NEW$		; oui => NEW$	COMP.W	D3,(A4)		; icne trouve ?	JUMP,NE LOOP$		; non => LOOP$	COMP.W	D4,(A4)+2	; tat chang ?	JUMP,EQ EXIT$		; non => EXIT$	COMP.W	(A4)+2,#STICOGREY	JUMP',NE OFULL$	CALL	FULLICONE	; dgrise l'icneOFULL$:	COMP.W	(A4)+2,#STICOINV	JUMP',NE ONORM$	CALL	INVICONE	; teint l'icneONORM$:	LOAD.W	(A4)+2,D4	; OICOST <-- nouvel tatMAJ$:	COMP.W	D4,#STICOGREY	JUMP',NE NFULL$	CALL	GREYICONE	; grise l'icneNFULL$:	COMP.W	D4,#STICOINV	JUMP',NE NNORM$	CALL	INVICONE	; allume l'icneNNORM$:	JUMP'	EXIT$NEW$:	COMP.W	D2,#MAXICONE	; table pleine ?	JUMP',HS EXIT$		; oui => EXIT$	LOAD.W	(A4+),D3	; OICOST <-- nouvelle icne	LOAD.W	(A4+),D4	; OICOST <-- nouvel tat	LOAD.W	(A4),#-1	; OICOST <-- nouveau terminateur	JUMP	MAJ$EXIT$:	POPM.L	D2,A4	RET;---------\\; KSTICONE >;=========/; Supprime l'tat d'une icne.; in	D3.W	code de l'icne; out	-; mod	D7.WKSTICONE:	PUSH.L	A4	LOAD.L	A4,#(A6)+OICOST-4 ; A4 <-- ^table des tatsLOOP$:	ADD.L	A4,#4		; A4 <-- ^icne suivante	COMP.W	(A4),#-1	; fin de la table ?	JUMP',EQ EXIT$		; oui => EXIT$	COMP.W	D3,(A4)		; icne trouve ?	JUMP,NE LOOP$		; non => LOOP$FILL$:	COMP.W	(A4),#-1	JUMP',EQ EXIT$	LOAD.W	(A4+),(A4)+4	JUMP	FILL$EXIT$:	POP.L	A4	RET;---------\\; GSTICONE >;=========/; Donne l'tat d'une icne.; in	D3.W	code de l'icne; out	D4.W	tat de l'icne (STICOxxxx);	D7.W	erreur; mod	D4.L, D7.WGSTICONE:	PUSH.L	A4	LOAD.L	A4,#(A6)+OICOST-4 ; A4 <-- ^table des tats	LOAD.W	D4,#STICONORM	; D4 <-- tat normal par dfaut	LOAD.W	D7,#1		; D7 <-- pas dans la tableLOOP$:	ADD.L	A4,#4		; A4 <-- ^icne suivante	COMP.W	(A4),#-1	; fin de la table ?	JUMP',EQ EXIT$		; oui => EXIT$	COMP.W	D3,(A4)		; icne trouve ?	JUMP,NE LOOP$		; non => LOOP$	LOAD.W	D4,(A4)+2	; D4 <-- tat	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DPLICONE >;=========/; Dplace ventuellement toutes les icnes de gauche.; in	D4.L	position de la souris (y;x); out	D7.W	ok/erreur; mod	D7.WDPLICONE:	PUSHM.L	D3,D4	LOAD.W	D7,#1	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP,NE EXIT$		; oui => EXIT$	COMP.W	D4,#MARGX+ICOLX+GCIMX ; trop  droite ?	JUMP,HS EXIT$	SWAP.W	D4	COMP.W	D4,(A0)+ODFCY	; trop haut ?	JUMP,LO EXIT$	SWAP.W	D4	CALL	DPLICONEMEM	; mmorise les icnes actuelles	JUMP,NE EXIT$LOOP$:	SWAP.W	D4	LOAD.W	D3,(A6)+OICOLY	SR.W	D3,#1	SUB.W	D4,D3		; D4 <-- la souris montre le milieu	LOAD.W	D3,#MARGY	ADD.W	D3,(A0)+ODFC1Y	ADD.W	D3,(A0)+ODFC2Y	ADD.W	D3,#2+1		; D3 <-- minimum	COMP.W	D4,D3		; trop haut ?	JUMP',GE MUP$	LOAD.W	D4,D3MUP$:	LOAD.W	D3,(A0)+ODFDY	SUB.W	D3,(A6)+OICOLY	SUB.W	D3,#6		; D3 <-- maximum	COMP.W	D4,D3		; trop bas ?	JUMP',LE MDOWN$	LOAD.W	D4,D3MDOWN$:;;?	AND.B	D4,#B'11111110	; D4 <-- doit tre pair	TSET.L	D4:#0		; D4 <-- doit tre impair	COMP.W	D4,(A6)+OICOPOS+0 ; nouvelle position ?	JUMP',EQ WAIT$		; non => WAIT$				; oui =>	JUMP',HI DOWN$UP$:	PUSH.W	D4	LOAD.W	D3,D4	ADD.W	D3,(A6)+OICOLY	SUB.W	D4,(A6)+OICOPOS+0	NEG.W	D4	CALL	CLRICONE	; efface la partie dcouverte en bas	POP.W	D4	JUMP'	MAJ$DOWN$:	PUSH.W	D4	LOAD.W	D3,(A6)+OICOPOS+0	SUB.W	D4,(A6)+OICOPOS+0	CALL	CLRICONE	; efface la partie dcouverte en haut	POP.W	D4MAJ$:	LOAD.W	(A6)+OICOPOS+0,D4	CALL	DPLICONEDRAW	; remet rapidement les icnesWAIT$:	CALL	WAITMOVE	; attend dplacement souris ...	JUMP',NE END$		; fin du dplacement => END$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE WAIT$	JUMP	LOOP$END$:	CALL	DPLICONELIB	; libre les icnes mmorises	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;------------\\; DPLICONEMEM >;------------/; Mmorise toutes les icnes dessines  gauche.; in	-; out	D7.W	erreur; mod	D7.WDPLICONEMEM:	PUSHM.L	D1..D6,A1..A4	CLR.W	D7	TEST.L	(A6)+OICOPM	; icnes dj mmorises ?	JUMP,NE EXIT$		; oui => EXIT$	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP,NE EXIT$		; oui => EXIT$ (ne mmorise jamais)	LOAD.W	D4,(A6)+OICOLY	MUL.WU	D4,#12	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour icnes	JUMP,NE EXIT$	LOAD.L	(A6)+OICOPM,A4	CALL	CCMO		; enlve la souris	LOAD.L	A3,#0		; A3 <-- ^source (dans l'cran)	LOAD.L	D3,(A6)+OICOPOS	SUB.W	D3,#GCIMX+1	SWAP.W	D3	SUB.W	D3,#GCIMY+1	SWAP.W	D3;	LOAD.L	A4,A4		; A4 <-- ^destination	CLR.L	D4	LOAD.W	D6,#12	LOAD.W	D2,(A6)+OICOLY	SWAP.W	D2	LOAD.W	D2,#ICOLX	LOAD.W	D1,#LOADDOT	LOAD.L	A2,A0		; A2 <-- ^descripteur WDO	LOAD.L	A1,(A6)+ORASTER	CALL	(A1)		; appel GRA_RASTER	CALL	SCMO		; remet la souris	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D6,A1..A4	TEST.W	D7		; retour EQ/NE	RET;-------------\\; DPLICONEDRAW >;-------------/; Remet toutes les icnes dessines  gauche, rapidement.; in	-; out	-; mod	D7.WDPLICONEDRAW:	PUSHM.L	D1..D6,A1..A4	CALL	CCMO		; enlve la souris	LOAD.L	A3,(A6)+OICOPM	; A3 <-- ^source	CLR.L	D3	LOAD.W	D5,#12	LOAD.L	A4,#0		; A4 <-- ^destination (dans cran)	LOAD.L	D4,(A6)+OICOPOS	SUB.W	D4,#GCIMX+1	SWAP.W	D4	SUB.W	D4,#GCIMY+1	SWAP.W	D4	LOAD.W	D2,(A6)+OICOLY	SWAP.W	D2	LOAD.W	D2,#ICOLX	LOAD.W	D1,#LOADDOT	LOAD.L	A2,A0		; A2 <-- ^descripteur WDO	LOAD.L	A1,(A6)+ORASTER	CALL	(A1)		; appel GRA_RASTER	CALL	SCMO		; remet la souris	POPM.L	D1..D6,A1..A4	RET;------------\\; DPLICONELIB >;------------/; Libre les icnes mmorises.; in	-; out	-; mod	D7.WDPLICONELIB:	PUSHM.L	D1,A4	TEST.L	(A6)+OICOPM	; icnes dj mmorises ?	JUMP',EQ EXIT$	LOAD.L	A4,(A6)+OICOPM	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre mmoire pour icnes	CLR.L	(A6)+OICOPMEXIT$:	POPM.L	D1,A4	RET;---------\\; DESICONE >;=========/; Dessine une liste d'icnes en colonne.; in	-; out	-; mod	D7.WDESICONE:	PUSHM.L	D0..D4,A3	LOAD.L	D4,#H'10000*COLORFDRAW+COLORCDRAW	CALL	__DRCOLORINIT	LOAD.W	D3,(A6)+OICOPOS+0	LOAD.W	D4,(A6)+OICOLY	CALL	CLRICONE	; efface toutes les icnes	LOAD.L	D4,#H'10000*COLORFIN1+COLORCIN1	CALL	__DRCOLORINIT	LOAD.W	D3,(A6)+OICOPOS+0	LOAD.W	D4,#(GCIMY+GCICY+GCIMY)*3	CALL'	DESICONERECT	PUSH.L	D4	LOAD.L	D4,#H'10000*COLORFIN2+COLORCIN2	CALL	__DRCOLORINIT	POP.L	D4	ADD.W	D3,D4	ADD.W	D3,#5	LOAD.W	D4,#(GCIMY+GCICY+GCIMY)*1	LOAD.W	D2,#4	ADD.W	D2,(A6)+OICOSY	MUL.WU	D4,D2	CALL'	DESICONERECT	PUSH.L	D4	LOAD.L	D4,#H'10000*COLORFIN3+COLORCIN3	CALL	__DRCOLORINIT	POP.L	D4	ADD.W	D3,D4	ADD.W	D3,#5	LOAD.W	D4,#(GCIMY+GCICY+GCIMY)*2	CALL'	DESICONERECT	PUSH.L	D4	LOAD.L	D4,#H'10000*COLORFIN4+COLORCIN4	CALL	__DRCOLORINIT	POP.L	D4	ADD.W	D3,D4	ADD.W	D3,#5	LOAD.W	D4,#(GCIMY+GCICY+GCIMY)*2	CALL'	DESICONERECT	LOAD.W	D0,#OPICODES	; D0 <-- dessine	LIB	?BUCAR	CALL	PTGICONE	; A3 <-- ^icnes de gauche	CALL	XXXICONE	LIB	?NOBUCAR	POPM.L	D0..D4,A3	RET;-------------\\; DESICONERECT >;-------------/; Dessine un rectangle double.; in	D3.W	position y;	D4.W	hauteur dx; out	-; mod	D7.WDESICONERECT:	PUSHM.L	D2..D4	SUB.W	D3,#GCIMY	SWAP.W	D3	LOAD.W	D3,(A6)+OICOPOS+2	SUB.W	D3,#GCIMX	DEC.W	D4	SWAP.W	D4	LOAD.W	D4,#ICOLX-3	LOAD.W	D2,#SETDOT	LIB	?DRRECT	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	ADD.W	D4,#2	SWAP.W	D4	ADD.W	D4,#2	SWAP.W	D4	LIB	?DRRECT	POPM.L	D2..D4	RET;------------\\; DESICONEONE >;============/; Dessine une icne en colonne.; in	D3.W	icne  dessiner; out	-; mod	D7.WDESICONEONE:	PUSHM.L	D0,D5,A3	LOAD.W	D0,#OPICODESONE	; D0 <-- dessine	LOAD.W	D5,D3		; D5 <-- code de l'icne	JUMP',EQ EXIT$		; nil => ne fait rien	CALL	PTGICONE	; A3 <-- ^icnes de gauche	CALL	XXXICONEEXIT$:	POPM.L	D0,D5,A3	RET;---------\\; CLRICONE >;---------/; Efface toutes les icnes de gauche.; in	D3.W	origine (y);	D4.W	hauteur (dy); out	-; mod	D7.WCLRICONE:	PUSHM.L	D2..D4	LOAD.W	D2,D4	LOAD.L	D4,#H'88228822	; D4 <-- trame pour joli cran	CALL	DRMDEF	LOAD.W	D4,D2	SUB.W	D3,#GCIMY+1	SWAP.W	D3	LOAD.W	D3,(A6)+OICOPOS+2	SUB.W	D3,#GCIMX+1	SWAP.W	D4	LOAD.W	D4,#ICOLX	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; grise toutes les icnes	POPM.L	D2..D4	RET;---------\\; MOVICONE >;=========/; Dplace une icne tant que le bouton est press.; in	D4.L	position de la souris (y;x); out	D3.W	icne o est la souris;		 :#16 si en bas;		 :#17 si  gauche;	D7.W	ok/erreur; mod	D3.L, D7.WMOVICONE:	PUSHM.L	D4,D5	CALL	DETICONE	; souris dans une icne ?	JUMP,NE EXIT$		; non => EXIT$	LOAD.L	D5,D3	JUMP'	INV$LOOP$:	CALL	SCMO		; remet la souris	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP',NE END$		; non => END$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE LOOP$	CALL	DETICONE	; D3 <-- icne o est la souris	COMP.W	D3,D5		; toujours  la mme place ?	JUMP,EQ LOOP$		; oui => LOOP$	CALL	HELPCLOSE	; restitue l'cran prcdent	EX.L	D3,D5	CALL	INVALLICONE	; teint l'ancienne icneINV$:	LOAD.L	D3,D5	CALL	INVALLICONE	; allume la nouvelle icne	CALL	HELPTEXT1	; affiche un texte d'aide	JUMP	LOOP$END$:	CALL	HELPCLOSE	; restitue l'cran prcdent	LOAD.L	D3,D5	JUMP',EQ OK$	CALL	INVALLICONE	; teint l'ancienne icne	CALL	GSTICONE	; D4 <-- tat de l'icne	COMP.W	D4,#STICOGREY	; icne grise ?	JUMP',NE OK$		; non => OK$	CLR.L	D3OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D4,D5	TEST.W	D7		; retour EQ/NE	RET;---------\\; DETICONE >;=========/; Dtecte dans quelle icne est la souris.; in	D4.L	position de la souris (y;x); out	D3.W	icne o est la souris;		 :#16 si en bas;		 :#17 si  gauche;	D7.W	ok/erreur; mod	D3.L, D7.WDETICONE:	PUSHM.L	D0,D5,A3	LOAD.W	D0,#OPICODET	; D0 <-- dtecte	LOAD.L	D5,D4		; D5 <-- position de la souris (y;x)	CALL	PTGICONE	; A3 <-- ^icnes de gauche	CALL	XXXICONE	CLR.L	D3		; D3 <-- nulle part	TEST.W	D7	JUMP',NE EXIT$	LOAD.W	D3,D5		; D3 <-- code de l'icne	TEST.B	(A6)+OICOCB	; est-on en bas ?	JUMP',F DOWN$		; non => DOWN$	TSET.L	D3:#16DOWN$:	TEST.B	(A6)+OICOCG	; est-on  gauche ?	JUMP',F LEFT$		; non => LEFT$	TSET.L	D3:#17LEFT$:EXIT$:	POPM.L	D0,D5,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; INVICONE >;=========/; Inverse une icne.; in	D3.W	icne  inverser; out	-; mod	D7.WINVICONE:	PUSHM.L	D0,D5,A3	LOAD.W	D0,#OPICOINV	; D0 <-- inverse	LOAD.W	D5,D3		; D5 <-- code de l'icne	JUMP',EQ EXIT$		; nil => ne fait rien	CALL	PTGICONE	; A3 <-- ^icnes de gauche	CALL	XXXICONEEXIT$:	POPM.L	D0,D5,A3	RET;------------\\; INVALLICONE >;============/; Inverse toute une icne.; in	D3.W	icne  inverser; out	-; mod	D7.WINVALLICONE:	PUSHM.L	D0,D5,A3	LOAD.W	D0,#OPICOINVALL	; D0 <-- inverse	LOAD.W	D5,D3		; D5 <-- code de l'icne	JUMP',EQ EXIT$		; nil => ne fait rien	CALL	PTGICONE	; A3 <-- ^icnes de gauche	CALL	XXXICONEEXIT$:	POPM.L	D0,D5,A3	RET;---------\\; POSICONE >;=========/; Donne la position d'une icne.; in	D3.W	icne; out	D3.L	position coin sup/gauche (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D7.WPOSICONE:	PUSHM.L	D0,D5,D6,A3	LOAD.W	D0,#OPICOPOS	; D0 <-- position	LOAD.W	D5,D3		; D5 <-- code de l'icne	CALL	PTGICONE	; A3 <-- ^icnes de gauche	CALL	XXXICONE	JUMP',NE EXIT$50$:	LOAD.L	D3,D5		; D3 <-- position	LOAD.L	D4,D6		; D4 <-- dimensionsEXIT$:	POPM.L	D0,D5,D6,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; GREYICONE >;==========/; Grise une icne.; in	D3.W	icne  griser; out	-; mod	D7.WGREYICONE:	PUSHM.L	D0,D5,A3	LOAD.W	D5,D3		; D5 <-- code de l'icne	JUMP',EQ EXIT$		; nil => ne fait rien	LOAD.W	D0,#OPICOGREY	; D0 <-- grise	CALL	PTGICONE	; A3 <-- ^icnes de gauche	CALL	XXXICONEEXIT$:	POPM.L	D0,D5,A3	RET;----------\\; FULLICONE >;==========/; Dgrise une icne.; in	D3.W	icne  dgriser; out	-; mod	D7.WFULLICONE:	PUSHM.L	D0,D5,A3	LOAD.W	D5,D3		; D5 <-- code de l'icne	JUMP',EQ EXIT$		; nil => ne fait rien	LOAD.W	D0,#OPICOFULL	; D0 <-- dgrise	CALL	PTGICONE	; A3 <-- ^icnes de gauche	CALL	XXXICONEEXIT$:	POPM.L	D0,D5,A3	RET;---------\\; PTGICONE >;---------/; Donne le pointeur aux icnes de gauche.; Les icnes dans ICOBU ont la structure suivante :;	+0.W	OP*	opration;	+2.W	ICO*	icne;	+4.B	TICO*	type;	+5.B	1..4	niveau pour la couleur; in	-; out	A3.L	^icnes de gauche; mod	A3.LPTGICONE:	PUSHM.L	D3,D4,A0..A2,A4	LOAD.W	D3,(A6)+OICONIV	JUMP',EQ NORM$	COMP.W	D3,#NICOCREATE	JUMP,EQ CREATE$	COMP.W	D3,#NICOSELECT	JUMP,EQ SELECT$	COMP.W	D3,#NICOEDIT	JUMP,EQ EDIT$	COMP.W	D3,#NICOSUITE	JUMP,EQ SUITE$NORM$:	LOAD.L	A0,#R16"TICONORM0	LOAD.L	A3,#R16"TICONORM3	LOAD.W	D3,(A6)+OOUTIL	COMP.W	D3,#ICOOCRAYON	JUMP,EQ CRAYON$;	COMP.W	D3,#ICOOLOUPE;	JUMP',EQ NLOUPE$	COMP.W	D3,#ICOOMAIN	JUMP',EQ NMAIN$	COMP.W	D3,#ICOOEDIT	JUMP',EQ NEDIT$	COMP.W	D3,#ICOOSUITE	JUMP',EQ NSUITE$NLOUPE$:	LOAD.L	A1,#R16"TICOLOUPE	LOAD.L	A2,#R16"TICONIL2	JUMP	ADD3$NMAIN$:	LOAD.L	A1,#R16"TICOMAIN	LOAD.L	A2,#R16"TICONIL2	JUMP	ADD3$NEDIT$:	LOAD.L	A1,#R16"TICONIL1	LOAD.L	A2,#R16"TICONIL2	JUMP	ADD3$NSUITE$:	LOAD.L	A1,#R16"TICOSUITE	LOAD.L	A2,#R16"TICOSUIT2	JUMP	ADD3$CREATE$:	LOAD.L	A0,#R16"TICOCR0	LOAD.L	A3,#R16"TICOCR3	LOAD.W	D3,(A6)+OOUTIL;	COMP.W	D3,#ICOOCRAYON;	JUMP',EQ CCRAYON$	COMP.W	D3,#ICOOLOUPE	JUMP',EQ CLOUPE$	COMP.W	D3,#ICOOMAIN	JUMP',EQ CMAIN$CCRAYON$:	LOAD.L	A1,(A6)+OICOPH	; A1 <-- ^icnes additionnelles	LOAD.L	A2,A1	JUMP	ADD1$CLOUPE$:	LOAD.L	A1,#R16"TICOLOUPE	LOAD.L	A2,(A6)+OICOPH	; A2 <-- ^icnes additionnelles	JUMP	ADD1$CMAIN$:	LOAD.L	A1,#R16"TICOMAIN	LOAD.L	A2,(A6)+OICOPH	; A2 <-- ^icnes additionnelles	JUMP	ADD1$SELECT$:	LOAD.L	A0,#R16"TICOSEL0	LOAD.L	A2,#R16"TICOSEL2	LOAD.L	A3,#R16"TICOSEL3	LOAD.W	D3,(A6)+OOUTIL;	COMP.W	D3,#ICOOCRAYON;	JUMP',EQ CRAYON$	COMP.W	D3,#ICOOLOUPE	JUMP',EQ LOUPE$	COMP.W	D3,#ICOOMAIN	JUMP',EQ MAIN$	COMP.W	D3,#ICOOFLECHE	JUMP',EQ FLECHE$	COMP.W	D3,#ICOOOPER	JUMP',EQ OPER$	COMP.W	D3,#ICOOGROUPE	JUMP',EQ GROUPE$	COMP.W	D3,#ICOOPLAN	JUMP',EQ PLAN$CRAYON$:	LOAD.L	A2,#R16"TICONORM2	LOAD.L	A1,#R16"TICONORM1	TEST.W	(A6)+OICOSY	JUMP,EQ ADD3$	LOAD.L	A1,#R16"TICONORM1S	JUMP	ADD3$FLECHE$:	LOAD.L	A1,#R16"TICOFLECHE	COMP.W	(A6)+OSELNB,#1	JUMP,NE ADD$	LOAD.L	A1,(A6)+OICOPH	; A1 <-- ^icnes additionnelles	JUMP	ADD$LOUPE$:	LOAD.L	A1,#R16"TICOLOUPE	JUMP	ADD$MAIN$:	LOAD.L	A1,#R16"TICOMAIN	JUMP	ADD$GROUPE$:	LOAD.L	A1,#R16"TICOGROUPE	JUMP	ADD$PLAN$:	LOAD.L	A1,#R16"TICOPLAN	JUMP	ADD$OPER$:	LOAD.W	D3,(A6)+OOPER;	COMP.W	D3,#ICOZZOOM;	JUMP',EQ ZOOM$	COMP.W	D3,#ICOZTOURNE	JUMP',EQ TOURNE$	COMP.W	D3,#ICOZMIROIR	JUMP',EQ MIROIR$	COMP.W	D3,#ICOZDEFORME	JUMP',EQ DEFORME$	COMP.W	D3,#ICOZDEFBEZ	JUMP',EQ DEFBEZ$ZOOM$:	LOAD.L	A1,#R16"TICOZOOM	JUMP	ADD$TOURNE$:	LOAD.L	A1,#R16"TICOTOURNE	JUMP	ADD$MIROIR$:	LOAD.L	A1,#R16"TICOMIROIR	JUMP	ADD$DEFORME$:	LOAD.L	A1,#R16"TICODEFORME	JUMP	ADD$DEFBEZ$:	LOAD.L	A1,#R16"TICODEFBEZ	JUMP	ADD$EDIT$:	LOAD.L	A0,#R16"TICOED0	LOAD.L	A3,#R16"TICOED3	LOAD.W	D3,(A6)+OOUTIL	COMP.W	D3,#ICOOLOUPE	JUMP',EQ ELOUPE$	COMP.W	D3,#ICOOMAIN	JUMP',EQ EMAIN$;	COMP.W	D3,#ICOOEDIT;	JUMP',EQ EEDIT$EEDIT$:	LOAD.L	A1,(A6)+OICOPH	; A1 <-- ^icnes additionnelles	LOAD.L	A2,A1	JUMP	ADD1$ELOUPE$:	LOAD.L	A1,#R16"TICOLOUPE	LOAD.L	A2,(A6)+OICOPH	; A2 <-- ^icnes additionnelles	JUMP	ADD1$EMAIN$:	LOAD.L	A1,#R16"TICOMAIN	LOAD.L	A2,(A6)+OICOPH	; A2 <-- ^icnes additionnelles	JUMP	ADD1$SUITE$:	LOAD.L	A0,#R16"TICOSUIT0	LOAD.L	A2,#R16"TICOSUIT2	LOAD.L	A3,#R16"TICOSUIT3	LOAD.W	D3,(A6)+OOUTIL	COMP.W	D3,#ICOOLOUPE	JUMP',EQ SLOUPE$	COMP.W	D3,#ICOOMAIN	JUMP',EQ SMAIN$;	COMP.W	D3,#ICOOSUITE;	JUMP',EQ SSUITE$SSUITE$:	LOAD.L	A1,#R16"TICOSUITE	JUMP'	ADD3$SLOUPE$:	LOAD.L	A1,#R16"TICOLOUPE	JUMP'	ADD3$SMAIN$:	LOAD.L	A1,#R16"TICOMAIN	JUMP'	ADD3$ADD$:	COMP.W	(A6)+OSELNB,#1	JUMP',NE ADD3$	LOAD.L	A2,(A6)+OICOPH	; A2 <-- ^icnes additionnellesADD1$:	LOAD.W	D3,(A2+)	COMP.W	D3,#OPIC	JUMP',EQ ADD3$	COMP.W	D3,#OPIL	JUMP,EQ ADD1$	ADD.L	A2,#2+2	JUMP	ADD1$ADD3$:	LOAD.L	A4,#(A6)+OICOBU	; A4 <-- ^buffer;	LOAD.L	A0,A0	LOAD.W	D3,#3		; D3 <-- 3 lignes	LOAD.W	D4,#1		; D4 <-- couleur 1	CALL'	PTGICONEXF	; buffer <-- outils	LOAD.W	(A4+),#OPIC	LOAD.L	A0,A1	LOAD.W	D3,#4	ADD.W	D3,(A6)+OICOSY	; D3 <-- 4 ou 7 lignes	INC.W	D4		; D4 <-- couleur 2	CALL'	PTGICONEXF	; buffer <-- objets ou sous-outils	LOAD.W	(A4+),#OPIC	LOAD.L	A0,A2	LOAD.W	D3,#2		; D3 <-- 2 lignes	INC.W	D4		; D4 <-- couleur 3	CALL'	PTGICONEXF	; buffer <-- tats	LOAD.W	(A4+),#OPIC	LOAD.L	A0,A3	LOAD.W	D3,#2		; D3 <-- 2 lignes	INC.W	D4		; D4 <-- couleur 4	CALL'	PTGICONEXF	; buffer <-- globaux	LOAD.W	(A4+),#OPIF	LOAD.L	A3,#(A6)+OICOBU	; A3 <-- ^icnes dans buffer;	JUMP'	EXIT$EXIT$:	POPM.L	D3,D4,A0..A2,A4	RET;-----------\\; PTGICONEXF >;-----------/; Transfert une ligne d'icnes.; in	A0.L	^icnes source;	A4.L	^icnes destination;	D3.W	nb de lignes (1..n);	D4.W	niveau pour la couleur (1..4); out	A0.L	^plus loin;	A4.L	^plus loin; mod	D3.L, A0.L, A4.LPTGICONEXF:	COMP.W	(A0),#OPITD	JUMP',NE LOOP$	INC.W	D3		; D3 <-- deux demi-lignes  compter !LOOP$:	COMP.W	(A0),#OPITD	JUMP',NE LINE$	LOAD.W	(A4+),(A0+)	; buffer <-- OPITD	LOAD.W	(A4+),(A0+)	; buffer <-- ICOxxx	LOAD.B	(A4+),(A0)+1	; buffer <-- TICOxxx	ADD.L	A0,#2	LOAD.B	(A4+),D4	; buffer <-- niveau couleur	LOAD.W	(A4+),(A0+)	; buffer <-- OPIC13	JUMP'	NEXT$LINE$:	LOAD.W	(A4+),(A0+)	; buffer <-- OPxx	COMP.W	(A0)-2,#OPIL	JUMP',EQ NEXT$	LOAD.W	(A4+),(A0+)	; buffer <-- ICOxxx	LOAD.B	(A4+),(A0)+1	; buffer <-- TICOxxx	ADD.L	A0,#2	LOAD.B	(A4+),D4	; buffer <-- niveau couleur	JUMP	LINE$NEXT$:	DEC.W	D3		; encore une ligne ?	JUMP,NE LOOP$		; oui => LOOP$	RET;---------\\; XXXICONE >;---------/; Dessine une liste d'icnes en colonne.; in	A3.L	^liste;	D0.W	opration (OPICOxxx);	D5.L	position de la souris (si dtecte);	D5.W	code de l'icne (si inverse/position); out	D5.W	icne o est la souris (si dtecte);	D5.L	coordonne (si position);	D6.L	dimensions (si position);	D7.W	ok/erreur (si dtecte ou inverse); mod	D5.L, D7.WXXXICONE:	PUSHM.L	D1..D4,A3	LOAD.L	D4,(A6)+OICOPOS	LOAD.L	D3,D4	CLR.W	D2		; D2 <-- gencar du texte10$:	COMP.W	(A3),#OPIF	; fin de la table ?	JUMP,EQ 80$	COMP.W	(A3),#OPIL	; va  la ligne suivante ?	JUMP,EQ 40$	COMP.W	(A3),#OPIC	; va  la ligne suivante ?	JUMP,EQ 45$	COMP.W	(A3),#OPIC13	; va  la ligne suivante ?	JUMP,EQ 46$	COMP.W	D0,#OPICODESONE	JUMP',EQ 18$	COMP.W	D0,#OPICODET	JUMP,EQ 30$	COMP.W	D0,#OPICOINV	JUMP,EQ 35$	COMP.W	D0,#OPICOINVALL	JUMP,EQ 35$	COMP.W	D0,#OPICOPOS	JUMP,EQ 35$	COMP.W	D0,#OPICOGREY	JUMP,EQ 35$	JUMP'	20$18$:	COMP.W	D5,(A3)+2	JUMP',NE 24$20$:				; dessine/dgrise =>	LOAD.B	D1,#GCICT	COMP.W	(A3)+2,#ICOOBJET	JUMP',HS 22$	COMP.W	(A3)+2,#128	JUMP',LO 22$	INC.B	D122$:	COMP.B	D2,D1		; utilise toujours le mme gencar ?	JUMP',EQ 24$		; oui => 24$	LOAD.B	D2,D1	COMP.B	D2,#GCICT+1	JUMP',EQ 23$	LIB	?AFTIM	.B	USEGC,GCICF,GCICS,GCICT	.B	0	.EVEN	JUMP'	24$23$:	LIB	?AFTIM	.B	USEGC,GCICF,GCICS,GCICT+1	.B	0	.EVEN24$:	CALL	XXXONEICONE	; dessine une icne	COMP.W	D0,#OPICODESONE	JUMP',NE 25$	TEST.W	D7	JUMP,EQ 80$25$:	ADD.L	A3,#6	JUMP	10$30$:				; dtecte =>	CALL	XXXONEICONE	; dtecte si dans cette icne ?	JUMP,NE 25$		; non => 25$	LOAD.W	D5,(A3)+2	; D5 <-- code de l'icne	JUMP'	80$35$:				; inverse/position =>	CALL	XXXONEICONE	; inverse cette icne ?	JUMP,NE 25$		; non => 25$	JUMP'	80$40$:				; grand interligne =>	SWAP.W	D3	ADD.W	D3,#GCICY+GCIMY*242$:	SWAP.W	D3	LOAD.L	D4,D3	ADD.L	A3,#2	JUMP	10$45$:				; petit interligne =>	SWAP.W	D3	ADD.W	D3,#5	JUMP	42$46$:				; interligne d'un seul point =>	SWAP.W	D3	ADD.W	D3,#13	JUMP	42$80$:	COMP.W	D0,#OPICODES	; dessine ?	JUMP',EQ 85$		; oui => 85$	COMP.W	D0,#OPICODESONE	; dessine un ?	JUMP',EQ 85$		; oui => 85$	COMP.W	D0,#OPICOFULL	; dgrise ?	JUMP',NE EXIT$		; non => EXIT$85$:	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.EVENEXIT$:	POPM.L	D1..D4,A3	TEST.W	D7		; retour EQ/NE	RET;------------\\; XXXONEICONE >;------------/; Dessine/dtecte/inverse une icne.; in	A3.L	^lment dans table;	D4.L	coordonne coin sup/gauche;	D0.W	opration (OPICOxxx);	D5.L	position de la souris (si dtecte);	D5.W	code de l'icne (si inverse/position/grise/dgrise); out	D4.L	coordonne suivante;	D5.L	coordonne coin (si position);	D6.L	dimensions (si position);	D7.W	ok/erreur (si dtecte ou inverse); mod	D4.L, D5.L, D6.L, D7.WXXXONEICONE:	PUSHM.L	D1..D3	LOAD.L	D1,D4		; D1 <-- coin	LOAD.L	D3,D4	SUB.W	D3,#GCIMX	SWAP.W	D3	SUB.W	D3,#GCIMY	SWAP.W	D3	LOAD.W	D4,#GCICY+GCIMY*2	SWAP.W	D4	LOAD.W	D4,#GCICX/2+GCIMX*2	COMP.W	(A3)+0,#OPIS	JUMP',EQ CASE$	ADD.W	D4,#GCICX/2+GCIMX*2	COMP.W	(A3)+0,#OPID	JUMP',EQ CASE$	ADD.W	D4,#GCICX/2+GCIMX*2	COMP.W	(A3)+0,#OPITD	JUMP',NE CASE$	SWAP.W	D4	LOAD.W	D4,#13	SWAP.W	D4CASE$:	COMP.W	D0,#OPICODESONE	JUMP',EQ DRAW1$	COMP.W	D0,#OPICODET	JUMP,EQ DET$	COMP.W	D0,#OPICOINV	JUMP,EQ INV$	COMP.W	D0,#OPICOINVALL	JUMP,EQ INV$	COMP.W	D0,#OPICOPOS	JUMP,EQ POS$	COMP.W	D0,#OPICOGREY	JUMP,EQ GREY$	COMP.W	D0,#OPICOFULL	JUMP,EQ FULL$	JUMP'	DRAW$DRAW1$:	LOAD.W	D7,#ERDIOUT	COMP.W	D5,(A3)+2	JUMP,NE OK$DRAW$:				; dessine =>	COMP.W	(A3)+2,#ICOVIDE	JUMP,EQ OK$	CALL	XXXONECOLOR	; initialise les bonnes couleurs	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	PUSH.L	D4	CLR.L	D4	CALL	DRMDEF	POP.L	D4	PUSHM.L	D3,D4	PUSHM.L	D3,D4	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	POPM.L	D3,D4	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; rectangle autour icne	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	ADD.W	D4,#2	SWAP.W	D4	ADD.W	D4,#2	SWAP.W	D4	LIB	?DRRECT		; double l'paisseur	LOAD.L	D3,D1		; D3 <-- coin	SUB.W	D3,#4	COMP.W	(A3)+0,#OPIS	JUMP',EQ DRPOS$	ADD.W	D3,#GCIMX+4	COMP.W	(A3)+0,#OPID	JUMP',EQ DRPOS$	ADD.W	D3,#14DRPOS$:	COMP.W	(A3)+0,#OPITD	JUMP',EQ DRDEMI$	COMP.W	(A3)+2,#ICOOBJET	JUMP,HS DROBJ$	SWAP.W	D3	ADD.W	D3,#GCICY-GCICB	SWAP.W	D3	LIB	?SETCURS	LOAD.W	D3,(A3)+2	; D3 <-- code	AND.B	D3,#H'7F	LIB	?AFCODE	POPM.L	D3,D4	CALL	DESACTION	; dessine ventuellement une action	CLR.W	D7		; D7 <-- ok	JUMP	OK$DRDEMI$:	SWAP.W	D3	ADD.W	D3,#GCICY-GCICB-2	SWAP.W	D3	LIB	?SETCURS	LIB	?AFTIM	.B	MODCAR,SETDOT!PENDOT,0	.EVEN	LOAD.W	D3,(A3)+2	; D3 <-- code	AND.B	D3,#H'7F	LIB	?AFCODE	LIB	?AFTIM	.B	MODCAR,SETDOT,0	.EVEN	POPM.L	D3,D4	CLR.W	D7		; D7 <-- ok	JUMP	OK$DROBJ$:	LOAD.L	D4,D3		; D4 <-- coin sup/gauche	LOAD.W	D3,(A3)+2	; D3 <-- code	CALL	DESICOOBJ	; dessine l'icone de l'objet	POPM.L	D3,D4	CALL	DESACTION	; dessine ventuellement une action	CLR.W	D7		; D7 <-- ok	JUMP	OK$DET$:				; dtecte =>	LOAD.W	D7,#ERDIOUT	LOAD.W	D2,D5	SUB.W	D2,D3		; souris trop  gauche ?	JUMP,LO OK$	COMP.W	D2,D4		; souris trop  droite ?	JUMP,HS OK$	SET.B	(A6)+OICOCG	; on est  gauche	SR.W	D4,#1	COMP.W	D2,D4	JUMP',LO DET2$	CLR.B	(A6)+OICOCG	; on est  droiteDET2$:	SWAP.W	D3	SWAP.W	D4	LOAD.L	D2,D5	SWAP.W	D2	SUB.W	D2,D3		; souris trop en haut ?	JUMP,LO OK$	COMP.W	D2,D4		; souris trop en bas ?	JUMP,HS OK$	CLR.B	(A6)+OICOCB	; on est en haut	SR.W	D4,#1	COMP.W	D2,D4	JUMP',LO DET4$	SET.B	(A6)+OICOCB	; on est en basDET4$:	CLR.W	D7		; D7 <-- dans l'icone	JUMP	OK$INV$:				; inverse =>	LOAD.W	D7,#ERDIOUT	COMP.W	D5,(A3)+2	JUMP,NE OK$	CALL	XXXONECOLOR	; initialise les bonnes couleurs	PUSHM.L	D3,D4	LOAD.W	D3,(A3)+2	; D3 <-- code de l'icne	CALL	GSTICONE	; D4 <-- tat de l'icne	COMP.W	D4,#STICOGREY	; icne grise ?	JUMP',EQ INV22$	LOAD.L	D4,#-1		; D4 <-- trame pour inverser	JUMP'	INV23$INV22$:;;?	LOAD.L	D4,#H'00550055	; D4 <-- trame pour griser	LOAD.L	D4,#H'88228822	; D4 <-- trame pour griserINV23$:	CALL	DRMDEF	POPM.L	D3,D4	LOAD.W	D2,#1	COMP.W	D0,#OPICOINVALL	JUMP',EQ INV3$	INC.W	D2INV3$:	ADD.W	D3,D2	SWAP.W	D3	ADD.W	D3,D2	SWAP.W	D3	SUB.W	D4,D2	SUB.W	D4,D2	SWAP.W	D4	SUB.W	D4,D2	SUB.W	D4,D2	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	CLR.W	D7	JUMP	OK$POS$:				; position =>	LOAD.W	D7,#ERDIOUT	COMP.W	D5,(A3)+2	JUMP,NE OK$	LOAD.L	D5,D3		; D5 <-- position	LOAD.L	D6,D4		; D6 <-- dimensions	CLR.W	D7	JUMP	OK$GREY$:				; grise =>	LOAD.W	D7,#ERDIOUT	COMP.W	D5,(A3)+2	JUMP,NE OK$	CALL	XXXONECOLOR	; initialise les bonnes couleurs	PUSH.L	D4;;?	LOAD.L	D4,#H'55AA55AA	load.l	d4,#H'88228822	; D4 <-- trame pour joli cran	CALL	DRMDEF	POP.L	D4	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	SUB.W	D4,#2	SWAP.W	D4	SUB.W	D4,#2	SWAP.W	D4;;?	LOAD.W	D2,#CLRDOT	load.w	d2,#setdot	LIB	?DRTRAME	; grise toute l'icne	CLR.W	D7	JUMP	OK$FULL$:				; dgrise =>	LOAD.W	D7,#ERDIOUT	COMP.W	D5,(A3)+2	JUMP,EQ DRAW$;	JUMP	OK$OK$:	LOAD.L	D4,D1	ADD.W	D4,#GCICX/2+GCIMX*2	COMP.W	(A3)+0,#OPIS	JUMP',EQ EXIT$	ADD.W	D4,#GCICX/2+GCIMX*2	COMP.W	(A3)+0,#OPID	JUMP',EQ EXIT$	ADD.W	D4,#GCICX/2+GCIMX*2EXIT$:	POPM.L	D1..D3	TEST.W	D7		; retour EQ/NE	RET;------------\\; XXXONECOLOR >;------------/; Utilise les bonnes couleurs pour une icne (chair et fond).; in	A3.L	^lment dans table; out	-; mod	D7.WXXXONECOLOR:	PUSHM.L	D3,D4	CLR.W	D3	LOAD.B	D3,(A3)+5	; D3 <-- niveau couleur (1..4)	DEC.B	D3	SL.B	D3,#1		; D3 <-- niveau couleur (0,2,4,6)	LOAD.W	D4,D3	ADD.W	D4,#COLORFIN1	; D4 <-- couleur de fond	SWAP.W	D4	LOAD.W	D4,D3	ADD.W	D4,#COLORCIN1	; D4 <-- couleur de chair	CALL	__DRCOLORINIT	; utilise les bonnes couleurs	POPM.L	D3,D4	RET;----------\\; DESACTION >;----------/; Dessine ventuellement une action.; in	A3.L	^OPID/OPIS et code;	D3.L	origine rectangle;	D4.L	dimensions rectangle; out	-; mod	D7.WDESACTION:	PUSHM.L	D2..D4,A3,A4	LOAD.B	D2,(A3)+4	AND.B	D2,#H'F0	; D2 <-- type de l'icne	JUMP,EQ EXIT$	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	SUB.W	D4,#8		; D4 <-- action  droite	LOAD.L	A4,#R16"DIAL$	COMP.B	D2,#TICODIAL	JUMP',EQ 20$	LOAD.L	A4,#R16"DOWN$	COMP.B	D2,#TICODOWN	JUMP',EQ 20$	LOAD.L	A4,#R16"EFFET$	COMP.B	D2,#TICOEFFET	JUMP',EQ 20$	LOAD.L	A4,#R16"CHANGE$	COMP.B	D2,#TICOCHANGE	JUMP',NE EXIT$	CLR.W	D4		; D4 <-- action  gauche20$:	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWMATRIX	ADD.W	D3,D4	SWAP.W	D3	LOAD.L	(A3)+1,D3	; <xx> et <yy>	LOAD.L	(A3)+5,A4	; <pppp>	LOAD.B	(A3)+9,#INVDOT	; <m>	LOAD.W	D3,#10	LIB	?STRING		; dessine le motifEXIT$:	POPM.L	D2..D4,A3,A4	RETDIAL$:	.B	8,24	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00110110	.B	B'00110110	.B	B'00000000DOWN$:	.B	8,24	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00001000	.B	B'00001000	.B	B'00001000	.B	B'00111110	.B	B'00011100	.B	B'00001000	.B	B'00000000EFFET$:	.B	8,24	.B	B'00111111	.B	B'00011111	.B	B'00011111	.B	B'00001111	.B	B'00001111	.B	B'00000111	.B	B'00000111	.B	B'00000011	.B	B'00000011	.B	B'00000001	.B	B'00000001	.B	B'00000000	.B	B'00000000	.B	B'00000001	.B	B'00000001	.B	B'00000011	.B	B'00000011	.B	B'00000111	.B	B'00000111	.B	B'00001111	.B	B'00001111	.B	B'00011111	.B	B'00011111	.B	B'00111111CHANGE$:	.B	8,24	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00010000	.B	B'00110000	.B	B'01111110	.B	B'00110000	.B	B'00010000	.B	B'00000000	.EVEN;----------\\; DESICOOBJ >;==========/; Dessine l'icone d'un objet.; in	D3.W	icne;	D4.L	coin sup/gauche (y;x); out	-; mod	D7.WDESICOOBJ:	PUSHM.L	D0..D4,A3,A4	LOAD.W	D2,D3		; D2 <-- icne	TEST.L	D3:#BICOINTERNAL	JUMP,BS INTERNAL$	COMP.W	D3,#ICOALLST	JUMP',HS ALLST$	COMP.W	D3,#ICOSTATE	JUMP',HS STATE$OBJET$:	LOAD.W	D0,D3		; D0 <-- icne	ADD.W	D0,(A6)+OICOFO	SUB.W	D0,#ICOOBJET	; D0 <-- rang	CALL	OBJGETID	; D0 <-- identificateur	JUMP,NE EXIT$	LOAD.W	D3,#ICOIOBJET	; D3 <-- numro de l'icone	JUMP	DRAW$STATE$:	SUB.W	D3,#ICOSTATE	; D3 <-- 0..n	LOAD.W	D0,(A6)+OOBJET	; D0 <-- icne	ADD.W	D0,(A6)+OICOFO	SUB.W	D0,#ICOOBJET	; D0 <-- rang	CALL	OBJGETID	; D0 <-- identificateur	JUMP,NE EXIT$	LOAD.W	D1,#opIDENTSTATE ; D1 <-- mthode	CALL	OBJCALL		; A4 <-- ^identificateurs des tats	JUMP,NE EXIT$STATE2$:	DEC.W	D3	JUMP',NS STATE3$	COMP.W	(A4+),#-1	JUMP,NE STATE2$	JUMP	EXIT$STATE3$:	LOAD.W	D0,(A4)		; D0 <-- identificateur	JUMP,EQ EXIT$	COMP.W	D0,#-1	JUMP,EQ EXIT$	LOAD.W	D3,#ICOIOBJET	; D3 <-- numro de l'icone	JUMP'	DRAW$ALLST$:	SUB.W	D3,#ICOALLST	; D3 <-- 0..n	SL.W	D3,#1	LOAD.L	A3,#(A6)+OSELID	; A3 <-- ^identificateurs de dfinition	LOAD.W	D0,(A3)+(D3.W)	; D0 <-- identificateur de dfinition	JUMP,EQ EXIT$	LOAD.W	D3,#ICOIOBJET	; D3 <-- numro de l'icone	JUMP'	DRAW$INTERNAL$:	LOAD.W	D0,(A6)+OICOID	; D0 <-- identificateur;	JUMP'	DRAW$DRAW$:	TEST.L	D3:#BICOINTERNAL	JUMP',BS MATRIX$	EX.L	D3,D4	SWAP.W	D3	ADD.W	D3,#GCICY-GCICB	SWAP.W	D3	LIB	?SETCURS	EX.L	D3,D4	AND.B	D3,#H'7F	LIB	?AFCODE	JUMP'	EXIT$MATRIX$:	LOAD.L	A4,(A6)+OSELPS	; A4 <-- ^objet (si poignes)	LOAD.L	A4,(A4)+OobjPDATA ; A4 <-- ^data de l'objet	LOAD.W	D1,#opGETICONE	; D1 <-- mthode	CALL	OBJCALL		; A4 <-- ^dx,dy,icne	JUMP',NE EXIT$	COMP.B	(A4)+0,#26	; largeur des chantillons PEN/TRAME ?	JUMP',NE MATX$		; non => MATX$	DEC.W	D4		; D4 <-- un point plus  gauche !MATX$:	CLR.W	D3	LOAD.B	D3,(A4)+1	; D3 <-- hauteur de l'icne	SUB.W	D3,#20	ASR.W	D3,#1	SWAP.W	D4	SUB.W	D4,D3;	SWAP.W	D4	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWMATRIX;	SWAP.W	D4	LOAD.L	(A3)+1,D4	; <xx> et <yy>	LOAD.L	(A3)+5,A4	; <pppp>	LOAD.B	(A3)+9,#LOADDOT	; <m>	LOAD.W	D3,#10	LIB	?STRING		; dessine l'icne;	JUMP'	EXIT$EXIT$:	POPM.L	D0..D4,A3,A4	RET	.END