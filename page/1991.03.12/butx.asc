	.TITLE	BUTX.ASC	.PROC	M680002	.REF	SMAKY	.REF	BUTX; Table des positions sauves; ---------------------------MAXSP	=	10		; nb max de positions sauvables	.LOC	0OSPPOS:	.BLKB	4		; position du curseurOSPBTP:	.BLKB	4		; ^bloc o est le curseurOSPBTR:	.BLKB	2		; position relative dans le blocLSP:; Descripteur d'un buffer de texte; --------------------------------	.LOC	0ODTPTB:	.BLKB	4		; ^premier bloc de texteODTPOS:	.BLKB	4		; position du curseurODTNBC:	.BLKB	4		; nb total de caractres contenusODTBTP:	.BLKB	4		; ^bloc o est le curseurODTBTR:	.BLKB	2		; position relative du curseurODTMSK1:.BLKB	4		; masque 1ODTMSK2:.BLKB	4		; masque 2ODTINF1:.BLKB	4		; info 1ODTINF2:.BLKB	4		; info 2ODTTSP:	.BLKB	LSP*MAXSP	; table des positions sauvesLDT:; Descripteur d'un bloc de texte; ------------------------------	.LOC	0OBTNEXT:.BLKB	4		; ^bloc suivantOBTPREV:.BLKB	4		; ^bloc prcdentOBTLMAX:.BLKB	2		; lg maximaleOBTLUSE:.BLKB	2		; lg utiliseOBTINF1:.BLKB	4		; info 1 des caractres contenusOBTINF2:.BLKB	4		; info 2 des caractres contenusLBT:	.LOC	0OCHBUTX:.BLKB	4LGVAR:	.LOC	0START:	LOAD.L	A6,#R16"VAR	LOAD.L	A3,#R16"NMBUTX	LOAD.W	D3,#BUTX_FIRST	LIB_	OPEN		; charge le module BUTX	JUMP,NE ERFAT	LOAD.W	(A6)+OCHBUTX,D1	BUTX_	OPEN		; D6 <-- canalLOOP:	LIB	?AFTIM	.ASCII	"<CR>(I)nsre, (D)etruit, (A)vance, (R)ecule, (M)odifie, "	.ASCIZ	"(S)etpos, (P)os, (C)ontenu, (V)isu ? "	.EVEN	LIB	?GETCAR	LIB	?MINMAJ	LIB	?AFCODE	COMP.W	D3,#'I	JUMP,EQ DOINS	COMP.W	D3,#'D	JUMP,EQ DODEL	COMP.W	D3,#'A	JUMP,EQ DOAV	COMP.W	D3,#'R	JUMP,EQ DOREC	COMP.W	D3,#'M	JUMP,EQ DOMOD	COMP.W	D3,#'S	JUMP,EQ DOSETPOS	COMP.W	D3,#'P	JUMP,EQ DOPOS	COMP.W	D3,#'C	JUMP,EQ DOCONT	COMP.W	D3,#'V	JUMP,EQ DOVISU	COMP.W	D3,#END	JUMP,EQ FINIBIP:	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOPDOINS:	LIB	?AFTIM	.ASCIZ	"<CR>Caractre : "	.EVEN	LIB	?GETCAR	LIB	?AFCODE	LOAD.B	D2,D3	LIB	?AFTIM	.ASCIZ	"<CR>Info 1 : "	.EVEN	LIB	?GETHEX	COMP.W	D3,#CR	JUMP,NE BIP	LOAD.L	D1,D4	LIB	?AFTIM	.ASCIZ	"Info 2 : "	.EVEN	LIB	?GETHEX	COMP.W	D3,#CR	JUMP,NE BIP	LOAD.L	D5,D4	LOAD.L	D4,D1	LOAD.B	D3,D2	BUTX_	INSERT	JUMP,NE BIP	JUMP	LOOPDODEL:	BUTX_	DELETE	JUMP,NE BIP	CALL	AFCAR	JUMP	LOOPDOAV:	BUTX_	AVANCE	JUMP,NE BIP	CALL	AFCAR	JUMP	LOOPDOREC:	BUTX_	RECULE	JUMP,NE BIP	CALL	AFCAR	JUMP	LOOPDOMOD:	LIB	?AFTIM	.ASCIZ	"<CR>Info 1 : "	.EVEN	LIB	?GETHEX	COMP.W	D3,#CR	JUMP,NE BIP	LOAD.L	D1,D4	LIB	?AFTIM	.ASCIZ	"Info 2 : "	.EVEN	LIB	?GETHEX	COMP.W	D3,#CR	JUMP,NE BIP	LOAD.L	D5,D4	LIB	?AFTIM	.ASCIZ	"Masque 1 : "	.EVEN	LIB	?GETHEX	COMP.W	D3,#CR	JUMP,NE BIP	LOAD.L	D2,D4	LIB	?AFTIM	.ASCIZ	"Masque 2 : "	.EVEN	LIB	?GETHEX	COMP.W	D3,#CR	JUMP,NE BIP	LOAD.L	D3,D4	LOAD.L	D4,D1	BUTX_	INFOMASK	LIB	?AFTIM	.ASCIZ	"Nb de caractres : "	.EVEN	LIB	?GETDEC	COMP.W	D3,#CR	JUMP,NE BIP	BUTX_	MODINFO	JUMP,NE BIP	JUMP	LOOPDOSETPOS:	LIB	?AFTIM	.ASCIZ	"<CR>Nouvelle position : "	.EVEN	LIB	?GETDEC	COMP.W	D3,#CR	JUMP,NE BIP	BUTX_	SETPOS	JUMP,NE BIP	JUMP	LOOPDOPOS:	LOAD.L	A4,D6	LIB	?AFTIM	.ASCIZ	"<CR>NBC="	.EVEN	LOAD.L	D4,(A4)+ODTNBC	LIB	?AFX8	LIB	?AFTIM	.ASCIZ	" POS="	.EVEN	LOAD.L	D4,(A4)+ODTPOS	LIB	?AFX8	LIB	?AFTIM	.ASCIZ	"  BTP="	.EVEN	LOAD.L	D4,(A4)+ODTBTP	LIB	?AFX8	LIB	?AFTIM	.ASCIZ	" BTR="	.EVEN	LOAD.W	D4,(A4)+ODTBTR	LIB	?AFX4	LIB	?AFTIM	.ASCIZ	"  PTB="	.EVEN	LOAD.L	D4,(A4)+ODTPTB	LIB	?AFX8	JUMP	LOOPDOCONT:	LIB	?AFCR	LOAD.L	A4,D6	LOAD.L	A4,(A4)+ODTPTBLOOP$:	LOAD.L	A3,#(A4)+LBT	LOAD.W	D4,(A4)+OBTLUSE	JUMP,EQ END$CAR$:	LOAD.B	D3,(A3+)	LIB	?AFCODE	DEC.W	D4	JUMP,NE CAR$END$:	LOAD.B	D3,#'|	LIB	?AFCAR	TEST.L	(A4)+OBTNEXT	JUMP,EQ LOOP	LOAD.L	A4,(A4)+OBTNEXT	JUMP	LOOP$DOVISU:	LOAD.L	A4,D6	LOAD.L	A4,(A4)+ODTPTBLOOP$:	LIB	?AFTIM	.ASCIZ	"<CR>^="	.EVEN	LOAD.L	D4,A4	LIB	?AFX8	LIB	?AFTIM	.ASCIZ	" NEXT="	.EVEN	LOAD.L	D4,(A4)+OBTNEXT	LIB	?AFX8	LIB	?AFTIM	.ASCIZ	" PREV="	.EVEN	LOAD.L	D4,(A4)+OBTPREV	LIB	?AFX8	LIB	?AFTIM	.ASCIZ	"   LUSE="	.EVEN	LOAD.W	D4,(A4)+OBTLUSE	LIB	?AFX4	LIB	?AFTIM	.ASCIZ	" INFO1="	.EVEN	LOAD.L	D4,(A4)+OBTINF1	LIB	?AFX8	LIB	?AFTIM	.ASCIZ	" INFO2="	.EVEN	LOAD.L	D4,(A4)+OBTINF2	LIB	?AFX8	TEST.L	(A4)+OBTNEXT	JUMP,EQ LOOP	LOAD.L	A4,(A4)+OBTNEXT	JUMP	LOOP$FINI:	BUTX_	CLOSE	LOAD.W	D1,(A6)+OCHBUTX	LIB_	CLOSE		; libre le module BUTXERFAT:	EXITAFCAR:	LIB	?AFCR	LIB	?AFCODE	LIB	?AFSPACE	LIB	?AFX8	LIB	?AFSPACE	EX.L	D4,D5	LIB	?AFX8	LIB	?AFSPACE	EX.L	D4,D5	RETNMBUTX:	.ASCIZ	"BUTX"	.EVENVAR:	.FILLB	LGVAR,0	.END	START