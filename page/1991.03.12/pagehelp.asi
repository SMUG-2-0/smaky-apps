	.SBTTL	PAGEHELP.ASI;-----------\\; HELPACTION >;===========/; Indique la fonction de toutes les icnes montres.; in	-; out	-; mod	D7.WHELPACTION:	PUSHM.L	D2..D4	TEST.L	(A6)+OPHELP	; fichier d'aide charg ?	JUMP,EQ EXIT$		; non => EXIT$	PUSH.L	(A6)+OWDOY1	PUSH.L	(A6)+OWDOY2	CLR.L	(A6)+OWDOY1	; ne tient pas compte de la position de la souris !	LOAD.L	(A6)+OWDOY2,#H'7FFF7FFF	LOAD.W	D3,#ICOOAIDE	CALL	SELMO		; utilise le bon lutin	POP.L	(A6)+OWDOY2	POP.L	(A6)+OWDOY1	LOAD.W	D3,#-1	CALL	HELPTEXTNIL	; affiche le texte	LOAD.W	D2,D3	JUMP'	MOVE$LOOP$:	CALL	SCMO		; remet la souris	LIB	?GETKEY		; attend dplacement souris ...	TEST.L	D3:#BKPSEUDO	JUMP,BS LOOP$	COMP.W	D3,#KEYMPO	JUMP',NE END$MOVE$:	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE LOOP$	CALL	HELPDET		; D3 <-- icne montre	COMP.W	D3,D2		; est-on toujours dans la mme icne ?	JUMP,EQ LOOP$		; oui => LOOP$	CALL	HELPCLOSE	; restitue l'cran prcdent	EX.L	D2,D3	CALL	HELPINV		; teint l'ancienne	LOAD.W	D3,D2	CALL	HELPINV		; allume la nouvelle	CALL	HELPTEXTNIL	; affiche le texte	JUMP	LOOP$END$:	LOAD.W	D3,D2	CALL	HELPINV		; teint la dernireEXIT$:	CALL	HELPCLOSE	; restitue l'cran (si oubli)	POPM.L	D2..D4	RET;------------\\; HELPTEXTNIL >;============/; Affiche le texte d'aide d'une icne dans la fentre.; S'il n'y a pas d'icne, affiche "Montrez une icne ..." !; in	D3.W	icne; out	-; mod	D7.WHELPTEXTNIL:	PUSHM.L	D3,D4,A3	CALL	HELPSEARCH	; A3 <-- ^texte	CALL	HELPPOS		; D3/D4 <-- position/dimensions	JUMP',NE CENTRE$	ADD.W	D3,D4	ADD.W	D3,#4	SWAP.W	D3	SWAP.W	D4	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	JUMP'	AFF$CENTRE$:	LOAD.L	D3,(A0)+ODFDY	SR.W	D3,#1	SUB.W	D3,#100	SWAP.W	D3	SR.W	D3,#1	SWAP.W	D3AFF$:	CALL	HELPAFF		; affiche le texte	POPM.L	D3,D4,A3	RET;----------\\; HELPTEXT1 >;==========/;---------\\; HELPTEXT >;=========/; Affiche le texte d'aide d'une icne dans la fentre.; in	D3.W	icne; out	-; mod	D7.WHELPTEXT1:	TEST.B	(A6)+ODEF+1:#BDEFHELP-0	JUMP',BS HELPTEXT	RETHELPTEXT:	PUSHM.L	D3,D4,A3	TEST.L	(A6)+OPHELP	; fichier d'aide charg ?	JUMP',EQ EXIT$		; non => EXIT$	TEST.W	D3	JUMP',EQ EXIT$	CALL	HELPSEARCH	; A3 <-- ^texte	CALL	HELPPOS		; D3/D4 <-- position/dimensions	JUMP',NE EXIT$	ADD.W	D3,D4	ADD.W	D3,#4	SWAP.W	D3	SWAP.W	D4	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	CALL	HELPAFF		; affiche le texteEXIT$:	POPM.L	D3,D4,A3	RET;--------\\; HELPAFF >;--------/; Affiche le texte d'aide d'une icne dans la fentre.; in	D3.L	position (y;x);	A3.L	^texte; out	D7.W	erreur; mod	D7.WHELPAFF:	PUSHM.L	D0..D4,A3,A4; Calcule la position des 5 points de la "flche".	LOAD.L	(A6)+OHP0,D3	; OHP0 <-- pointe de la flche	LOAD.L	D2,D3	CALL	HELPNBXY	; D4 <-- ny;nx	LOAD.W	D3,D4	MUL.WU	D3,(A0)+ODFCX	ADD.W	D3,#10+10	; D3 <-- largeur	SWAP.W	D4	MUL.WU	D4,(A0)+ODFCY	ADD.W	D4,#10+10	; D4 <-- hauteur	SR.W	D4,#1	SWAP.W	D2	ADD.W	D2,D4	ADD.W	D2,#5	COMP.W	D2,(A0)+ODFDY	JUMP',LO MAXY$	LOAD.W	D2,(A0)+ODFDYMAXY$:	SUB.W	D2,#5	SUB.W	D2,D4	SUB.W	D2,D4	SUB.W	D2,#5	JUMP',NC MINY$	CLR.W	D2MINY$:	ADD.W	D2,#5	LOAD.W	(A6)+OHP1+0,D2	LOAD.W	(A6)+OHP2+0,D2	ADD.W	D2,D4	ADD.W	D2,D4	LOAD.W	(A6)+OHP3+0,D2	LOAD.W	(A6)+OHP4+0,D2	SWAP.W	D2	ADD.W	D2,#20	LOAD.W	(A6)+OHP1+2,D2	LOAD.W	(A6)+OHP4+2,D2	ADD.W	D2,D3	LOAD.W	(A6)+OHP2+2,D2	LOAD.W	(A6)+OHP3+2,D2; Affiche la flche en effaant dessous puis en mettant un cadre.	CALL	HELPOPEN	; sauve l'cran	LOAD.L	D4,#H'10000*COLORFHELP+COLORCHELP	CALL	__DRCOLORINIT	CLR.L	D4	CALL	DRMDEF		; trame pour effacer	PUSH.L	(A6)+OAPOS	PUSH.L	(A6)+ODESY1	PUSH.W	(A6)+OSCALE	CLR.L	(A6)+OAPOS	CLR.L	(A6)+ODESY1	CLR.W	(A6)+OSCALE	CALL	__DRPOLYOPEN	JUMP,NE COUT$	LOAD.L	D3,(A6)+OHP0	LOAD.L	D4,(A6)+OHP1	CALL	__DRPOLYLINE	JUMP,NE COUT$	LOAD.L	D3,D4	LOAD.L	D4,(A6)+OHP2	CALL	__DRPOLYLINE	JUMP,NE COUT$	LOAD.L	D3,D4	LOAD.L	D4,(A6)+OHP3	CALL	__DRPOLYLINE	JUMP,NE COUT$	LOAD.L	D3,D4	LOAD.L	D4,(A6)+OHP4	CALL	__DRPOLYLINE	JUMP,NE COUT$	LOAD.L	D3,D4	LOAD.L	D4,(A6)+OHP0	CALL	__DRPOLYLINE	JUMP,NE COUT$	LOAD.W	D2,#CLRDOT	CALL	__DRPOLYCLOSE	; efface l'intrieur	JUMP',NE COUT$	LOAD.W	D2,#SETDOT	LOAD.L	D3,(A6)+OHP0	LOAD.L	D4,(A6)+OHP1	CALL	__DRLINE	LOAD.L	D3,D4	LOAD.L	D4,(A6)+OHP2	CALL	__DRLINE	LOAD.L	D3,D4	LOAD.L	D4,(A6)+OHP3	CALL	__DRLINE	LOAD.L	D3,D4	LOAD.L	D4,(A6)+OHP4	CALL	__DRLINE	LOAD.L	D3,D4	LOAD.L	D4,(A6)+OHP0	CALL	__DRLINE	; dessine le cadre	CLR.W	D7COUT$:	POP.W	(A6)+OSCALE	POP.L	(A6)+ODESY1	POP.L	(A6)+OAPOS	TEST.W	D7	JUMP,NE EXIT$; Affiche le texte dans la flche.	LOAD.B	(A0)+ODFMCA,#SETDOT!PENDOT ; dessine seulement la chair	LOAD.L	D4,#-1	CALL	DRMDEF		; trame pour inverser	LOAD.L	D1,(A6)+OHP1	ADD.W	D1,#10	SWAP.W	D1	ADD.W	D1,#10	ADD.W	D1,(A0)+ODFC1Y	SWAP.W	D1	CLR.W	D0		; D0 <-- style roman et normal	LOAD.L	A4,A3LOOP$:	LOAD.L	(A0)+ODFPY,D1	; met le curseur au dbut de la ligneLOOP2$:	LOAD.L	A3,A4		; A3 <-- ^dbut  afficher	CLR.W	D3		; D3 <-- nb de caractres  afficherCNT$:	LOAD.B	D4,(A4)	JUMP',EQ CNT2$	INC.L	A4	COMP.B	D4,#CR	JUMP',EQ CNT2$	COMP.B	D4,#-1	JUMP',EQ CNT2$	COMP.B	D4,#-4	JUMP',EQ CNT2$	INC.W	D3		; D3 <-- un caractre de plus	JUMP	CNT$CNT2$:	TEST.W	D3	JUMP,EQ SPEC$	LOAD.L	D2,(A0)+ODFPY	; D2 <-- position dbut de la ligne	LIB	?STRING		; affiche une ligne	TEST.L	D0:#0		; affiche en bold ?	JUMP',BC CADRE$		; non => CADRE$				; oui =>	PUSH.L	(A0)+ODFPY	INC.W	D2	LOAD.L	(A0)+ODFPY,D2	; positionne avec un dcalage en X de 1	LIB	?STRING		; affiche en gras	POP.L	(A0)+ODFPYCADRE$:	TEST.L	D0:#1		; affiche en inverse ?	JUMP',BC SPEC$		; non => SPEC$				; oui =>	PUSH.L	D4	LOAD.L	D3,D2	SWAP.W	D3	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,#3	SWAP.W	D3	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	ADD.W	D4,#3	SWAP.W	D4	LOAD.W	D4,(A0)+ODFPX	SUB.W	D4,D3	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	; inverse tout le texte affich	POP.L	D4SPEC$:	TEST.B	D4		; encore qq chose ?	JUMP',EQ END$		; non => END$	COMP.B	D4,#-1		; commande roman/bold ?	JUMP',EQ BOLD$		; oui => BOLD$	COMP.B	D4,#-4		; commande normal/inv ?	JUMP',NE NLINE$		; non => NLINE$	TNOT.L	D0:#1		; D0 <-- passe de normal  invBOLD$:	TNOT.L	D0:#0		; D0 <-- passe de roman  bold	JUMP	LOOP2$NLINE$:	SWAP.W	D1	ADD.W	D1,(A0)+ODFCY	; D1 <-- position dbut ligne suivante	SWAP.W	D1	JUMP	LOOP$END$:	LOAD.B	(A0)+ODFMCA,#LOADDOT!PENDOT ; dessine seulement la chair	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; HELPNBXY >;---------/; Calcule le nombre de lignes/colonnes dans le texte donn en entre.; in	A3.L	^texte; out	D4.L	nb de lignes/colonnes (ny;nx); mod	D4.L, D7.WHELPNBXY:	PUSHM.L	D2,D3,A3	LOAD.L	D4,#H'FFFF0000	; D4 <-- (dy;dx)CNTY$:	ADD.L	D4,#H'10000	; D4 <-- une ligne de plus (+dy)	CLR.W	D2CNTX$:	LOAD.B	D3,(A3+)	JUMP,NS CNTX$		; ignore les AFINV, AFDIR, etc.	JUMP',EQ CNT3$	INC.W	D2		; D2 <-- une colonne de plus (+dx)	COMP.B	D3,#CR	JUMP,NE CNTX$	DEC.W	D2CNT3$:	COMP.W	D4,D2	JUMP',HS CNT4$	LOAD.W	D4,D2		; D4 <-- ligne la plus large (>dx)CNT4$:	TEST.B	D3	JUMP,NE CNTY$	POPM.L	D2,D3,A3	RET;---------\\; HELPOPEN >;---------/; Sauve une partie de l'cran.; in	-; out	D7.W	erreur; mod	D7.WHELPOPEN:	PUSHM.L	D1..D6,A2..A4	LOAD.W	D2,(A6)+OHP2+2	SUB.W	D2,(A6)+OHP0+2	INC.W	D2		; D2 <-- largeur	LOAD.W	D4,D2	ADD.W	D4,#16-1	SR.W	D4,#3+1	SL.W	D4,#1	TEST.B	(A0)+ODFCMD	JUMP',EQ NOCOUL$	SL.W	D4,#2		; D4 <-- largeur *4NOCOUL$:	LOAD.W	D6,D4		; D6 <-- largeur en bytes	SWAP.W	D2	LOAD.W	D2,(A6)+OHP4+0	SUB.W	D2,(A6)+OHP1+0	INC.W	D2		; D2 <-- hauteur	MUL.WU	D4,D2	SWAP.W	D2	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire	JUMP',NE EXIT$	LOAD.L	(A6)+OHPSAV,A4	CALL	CCMO		; enlve la souris	LOAD.L	D3,(A6)+OHP1	LOAD.W	D3,(A6)+OHP0+2	; D3 <-- position source	LOAD.L	A3,#0		; A3 <-- ^source (dans l'cran)	CLR.L	D4	LOAD.L	A2,A0	TEST.B	(A0)+ODFCMD	JUMP',NE COUL$	LOAD.W	D1,#LOADDOT	GRA_	RASTER		; sauve l'cran	JUMP'	OK$COUL$:	LOAD.W	D1,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	GRA_	CRASTER		; sauve l'cran couleurOK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; HELPCLOSE >;----------/; Restitue l'cran.; in	-; out	-; mod	D7.WHELPCLOSE:	PUSHM.L	D1..D6,A2..A4	TEST.L	(A6)+OHPSAV	; y a-t-il qq chose de sauv ?	JUMP,EQ EXIT$		; non => EXIT$	CALL	CCMO		; enlve la souris	LOAD.W	D2,(A6)+OHP4+0	SUB.W	D2,(A6)+OHP1+0	INC.W	D2		; D2 <-- hauteur	SWAP.W	D2	LOAD.W	D2,(A6)+OHP2+2	SUB.W	D2,(A6)+OHP0+2	INC.W	D2		; D2 <-- largeur	LOAD.W	D5,D2	ADD.W	D5,#16-1	SR.W	D5,#3+1	SL.W	D5,#1		; D5 <-- largeur en bytes	TEST.B	(A0)+ODFCMD	JUMP',EQ NOCOUL$	SL.W	D5,#2		; D5 <-- largeur *4NOCOUL$:	CLR.L	D3	LOAD.L	A3,(A6)+OHPSAV	LOAD.L	D4,(A6)+OHP1	LOAD.W	D4,(A6)+OHP0+2	; D4 <-- position destination	LOAD.L	A4,#0		; A4 <-- ^destination (dans l'cran)	LOAD.L	A2,A0	TEST.B	(A0)+ODFCMD	JUMP',NE COUL$	LOAD.W	D1,#LOADDOT	GRA_	RASTER		; restitue l'cran	JUMP'	GIVE$COUL$:	LOAD.W	D1,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	GRA_	CRASTER		; restitue l'cran couleurGIVE$:	LOAD.L	A4,(A6)+OHPSAV	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	CLR.L	(A6)+OHPSAV	; y'a plus rien de sauv !EXIT$:	POPM.L	D1..D6,A2..A4	RET;--------\\; HELPDET >;========/; Dtecte dans quelle icne est la souris.; in	D4.L	position de la souris (y;x); out	D3.W	icne;	D7.W	erreur; mod	D3.L, D7.WHELPDET:	PUSHM.L	D4,A5	CALL	DETICONE	; D3 <-- icne de gauche	JUMP',NE OUT$	CALL	GSTICONE	; D4 <-- tat de l'icne	COMP.W	D4,#STICOGREY	; icne grise ?	JUMP',NE OK$		; non => OK$OUT$:	LOAD.W	D3,#-1	LOAD.W	D7,#1		; D7 <-- pas trouv	JUMP'	EXIT$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D4,A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; HELPINV >;========/; Inverse une icne.; in	D3.W	icne; out	-; mod	D7.WHELPINV:	COMP.W	D3,#-1	JUMP',EQ EXIT$	CALL	INVALLICONE	; inverse l'icneEXIT$:	RET;--------\\; HELPPOS >;========/; Inverse une icne.; in	D3.W	icne; out	D3.L	position (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D7.WHELPPOS:	COMP.W	D3,#-1	JUMP',EQ OUT$	CALL	GSTICONE	; D4 <-- tat de l'icne	COMP.W	D4,#STICOGREY	; icne grise ?	JUMP',EQ OUT$		; oui => OUT$	CALL	POSICONE	; D3/D4 <-- position/dimensions	JUMP'	EXIT$OUT$:	LOAD.W	D7,#1EXIT$:	TEST.W	D7		; retour EQ/NE	RET;-----------\\; HELPSEARCH >;===========/; Cherche le texte correspondant  une icne.; in	D3.W	icne; out	A3.L	^texte correspondant; mod	D7.W, A3.LHELPSEARCH:	PUSHM.L	D0..D4,A4	COMP.W	D3,#ICOOBJET+0	JUMP',LO INIT2$	COMP.W	D3,#ICOOBJET+NBIOBJET	JUMP,LO OBJET$INIT2$:	COMP.W	D3,#ICOSTATE+0	JUMP',LO INIT3$	COMP.W	D3,#ICOSTATE+NBISTATE	JUMP,LO STATE$INIT3$:	COMP.W	D3,#ICOALLST+0	JUMP',LO INIT4$	COMP.W	D3,#ICOALLST+NBISTATE	JUMP,LO ALLST$INIT4$:; Cherche le texte d'une icne standard.	TEST.L	(A6)+OPHELP	JUMP',EQ OTHER$	LOAD.L	A3,(A6)+OPHELP	; A3 <-- ^fichier d'aide	LOAD.W	D4,(A3)+8	; D4 <-- ^relatif	ADD.W	A3,D4		; A3 <-- ^dbut de la tableLOOP$:	LOAD.W	D4,(A3+)	JUMP',EQ OTHER$	COMP.W	D3,D4	JUMP,EQ OK$NEXT$:	TEST.B	(A3+)		; A3 <-- ^texte suivant	JUMP,NE NEXT$	LOAD.L	D4,A3	TEST.L	D4:#0	JUMP,BC LOOP$	INC.L	A3		; A3 <-- saute le .EVEN	JUMP	LOOP$OTHER$:	TEST.W	(A6)+OICONIV	JUMP',NE SELECT$	LOAD.W	D0,(A6)+OOBJET	ADD.W	D0,(A6)+OICOFO	SUB.W	D0,#ICOOBJET	CALL	OBJGETID	; D0 <-- identificateur de l'objet	JUMP,NE ERROR$	JUMP	OBJX$SELECT$:	LOAD.L	A4,(A6)+OSELPS	; A4 <-- ^objet slectionn	LOAD.W	D0,(A4)+OobjIDENT ; D0 <-- identificateur de l'objet	JUMP	OBJX$; Cherche le texte d'un objet.OBJET$:	LOAD.W	D0,D3	ADD.W	D0,(A6)+OICOFO	SUB.W	D0,#ICOOBJET	; D0 <-- rang	CALL	OBJGETID	; D0 <-- identificateur	JUMP,NE ERROR$	JUMP	OBJI$; Cherche le texte d'une dfinition.STATE$:	SUB.W	D3,#ICOSTATE	; D3 <-- 0..n	LOAD.W	D0,(A6)+OOBJET	ADD.W	D0,(A6)+OICOFO	SUB.W	D0,#ICOOBJET	CALL	OBJGETID	; D0 <-- identificateur de l'objet	JUMP,NE ERROR$	LOAD.W	D1,#opIDENTSTATE ; D1 <-- mthode	CALL	OBJCALL		; A4 <-- ^identificateurs des tats	JUMP,NE ERROR$STATE2$:	DEC.W	D3	JUMP',NS STATE3$	COMP.W	(A4+),#-1	JUMP,NE STATE2$	JUMP'	ERROR$STATE3$:	LOAD.W	D0,(A4)		; D0 <-- identificateur	JUMP',EQ ERROR$	COMP.W	D0,#-1	JUMP',EQ ERROR$	JUMP'	OBJI$; Cherche le texte d'une dfinition.ALLST$:	LOAD.W	D0,D3	SUB.W	D0,#ICOALLST	; D0 <-- 0..n	SL.W	D0,#1	LOAD.L	A4,#(A6)+OSELID	; A4 <-- ^identificateurs de dfinition	LOAD.W	D0,(A4)+(D0.W)	; D0 <-- identificateur de dfinition	JUMP',EQ ERROR$OBJI$:	LOAD.W	D3,#ICOIOBJET	; D3 <-- numro de l'iconeOBJX$:	LOAD.W	D1,#opICOHELP	; D1 <-- mthode	CALL	OBJCALL		; A3 <-- ^texte d'aide	JUMP',EQ OK$ERROR$:	LOAD.L	A3,#R16"TXERR$	; A3 <-- ^texte si rien trouv d'autreOK$:	CALL	HELPXFER	; A3 <-- ^texte dans OIOTM	POPM.L	D0..D4,A4	RETTXERR$:	.ASCII	"<-1>Montrez une icne<-1><CR>"	.ASCII	"avec la souris ...<CR>"	.B	0	.EVEN;---------\\; HELPXFER >;---------/; Transfert le texte en effectuant les remplacements suivants :;; <-1>	passe alternativement de roman <--> bold; <-2>	remplac par "l'objet slectionn" ou "les N objets slectionns"; <-3>	remplac par "a" si N=1 et par "ont" si N>1; <-4>	passe alternativement de normal <--> inverse; in	A3.L	^texte; out	A3.L	^texte dans OIOTM; mod	D7.W, A3.LHELPXFER:	PUSHM.L	D3,D4,A2,A4	LOAD.L	A4,#(A6)+OIOTM	CLR.B	(A4+)		; pour permettre de reculer sans dborder !LOOP$:	LOAD.B	D3,(A3+)	JUMP,EQ END$	JUMP',NS SPEC$ONE$:	LOAD.B	(A4+),D3	JUMP	LOOP$SPEC$:	COMP.B	D3,#-3	JUMP,EQ COM3$	COMP.B	D3,#-2	JUMP,NE ONE$COM2$:	LOAD.L	A2,A4	LOAD.B	D4,#'L		; D4 <-- majusculeLAST$:	LOAD.B	D3,(-A2)	JUMP',EQ PUT$	JUMP,NS LAST$	COMP.B	D3,#SPACE	JUMP,EQ LAST$	COMP.B	D3,#CR	JUMP,EQ LAST$	COMP.B	D3,#'.		; dernier caractre = "." ?	JUMP',EQ PUT$		; oui => PUT$ (majuscule)	COMP.B	D3,#-4	JUMP',EQ PUT$	LOAD.B	D4,#'l		; D4 <-- minusculePUT$:	LOAD.B	(A4+),D4	LOAD.L	A2,#R16"TXSEL1$	COMP.W	(A6)+OICONIV,#NICOSELECT	JUMP',NE FIX$	CLR.L	D4	LOAD.W	D4,(A6)+OSELNB	; D4 <-- nombre d'objets slectionns	COMP.W	D4,#1	JUMP',LS FIX$	LOAD.B	(A4+),#'e	LOAD.B	(A4+),#'s	LOAD.B	(A4+),#SPACE	CALL	PUTANUM	LOAD.L	A2,#R16"TXSELN$FIX$:	LOAD.B	(A4+),(A2+)	JUMP,NE FIX$	DEC.L	A4	JUMP	LOOP$COM3$:	COMP.W	(A6)+OICONIV,#NICOSELECT	JUMP',NE COM3A$	COMP.W	(A6)+OSELNB,#1	; un seul objet slectionn ?	JUMP',LS COM3A$	LOAD.B	(A4+),#'o	LOAD.B	(A4+),#'n	LOAD.B	(A4+),#'t	JUMP	LOOP$COM3A$:	LOAD.B	(A4+),#'a	JUMP	LOOP$END$:	CLR.B	(A4)	LOAD.L	A3,#(A6)+OIOTM+1	POPM.L	D3,D4,A2,A4	RETTXSEL1$:.ASCIZ	"'objet slectionn"TXSELN$:.ASCIZ	" objets slectionns"	.EVEN;---------\\; HELPLOAD >;=========/; Charge le fichier d'aide si ncessaire.; in	-; out	D7.W	erreur; mod	D7.WHELPLOAD:	PUSHM.L	D3,D4,A3,A4	TEST.L	(A6)+OPHELP	; fichier dj charg ?	JUMP',NE OK$		; oui => OK$	LOAD.L	A3,#R16"NMHELP	LOAD.L	D3,#2^BEXNHEAD	FOS	?CLOAD		; A4/D4 <-- ^fichier/lg	JUMP',NE EXIT$	LOAD.L	(A6)+OPHELP,A4OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; HELPUNLOAD >;===========/; Dcharge le fichier d'aide si ncessaire.; in	-; out	-; mod	D7.WHELPUNLOAD:	PUSH.L	A3	TEST.L	(A6)+OPHELP	; fichier charg ?	JUMP',EQ EXIT$		; non => EXIT$	LOAD.L	A3,#R16"NMHELP	FOS	?CUNLOAD	; dcharge le fichier	CLR.L	(A6)+OPHELPEXIT$:	POP.L	A3	RETNMHELP:	.ASCIZ	"PAGE_F.HELP"	.EVEN	.END