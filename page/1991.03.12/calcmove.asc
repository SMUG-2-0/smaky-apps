	.TITLE	CALCMOVE.ASC	.PROC	M680002	.REF	SMAKYCHOUIA	=	H'8000	.LOC	0START:	LOAD.L	D0,#H'10000*100+100	LOAD.L	D1,#H'10000*100+600	LOAD.L	D2,#H'10000*300+700	CALL	CALCMOVE	CALL	SHOWD0D1	LOAD.L	D0,D2	LOAD.L	D1,D3	CALL	SHOWD0D1	EXITERROR:	LIB	?AFTIM	.ASCIZ	"-- OVERFLOW --"	.EVEN	EXITSHOWD0D1:	PUSHM.L	D2..D4	LOAD.L	D3,D0	LOAD.L	D4,D1	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRSEG	POPM.L	D2..D4	RETAFFD0:	PUSHM.L	D0..D7	TEST.L	D0	JUMP',NC 20$	NEG.L	D0	LOAD.B	D3,#'-	LIB	?AFCAR20$:	LOAD.L	D4,D0	CLR.W	D4	SWAP.W	D4	LOAD.W	D2,#2^BAFDCM	LOAD.W	D3,#5	LIB	?AFDEC	LOAD.B	D3,#'.	LIB	?AFCAR	LOAD.L	D4,D0	AND.L	D4,#H'FFFF	DIV.WU	D4,#66	AND.L	D4,#H'FFFF	LOAD.W	D2,#2^BAFDALL	LOAD.W	D3,#3	LIB	?AFDEC	LIB	?AFCR	POPM.L	D0..D7	RET;---------\\; CALCMOVE >;---------/; Calcule le point C situ  l'intersection de d2 et d3, sachant que :;	d1 passe par A et B;	d2 passe par A et C;	d3 passe par C et D;	d1 est parallle  d3.;	d2 est perpendiculaire  d1 et d3.;	  | A    d1      B;	--o------------o----;	  |;	d2|;	  | C      d3          D;	--o------------------o----;	  |;;             Ax*P' - Dx*P + Dy - Ay;	Cx = ------------------------;	               P'-P;;	Cy = (Cx-Ax)*P' + Ay;;	        By - Ay;	P  = + ---------  (pente de d1 et d3);	        Bx - Ax;;	        Bx - Ax;	P' = - ---------  (pente de d2);	        By - Ay; in	D0.L	A (y;x);	D1.L	B (y;x);	D2.L	D (y;x); out	D3.L	C (y;x); mod	D3.LCALCMOVE:	PUSHM.L	D0..D2,D4..D7,A0,A1	LOAD.L	D5,D0		; D5 <-- Ay;Ax	LOAD.L	D6,D1		; D6 <-- By;Bx	LOAD.L	D7,D2		; D7 <-- Dy;Bx	LOAD.W	D3,D6	SUB.W	D3,D5		; D3 <-- Bx-Ax	SWAP.W	D3	LOAD.W	D3,#CHOUIA	SWAP.W	D6	LOAD.W	D4,D6	SWAP.W	D6	SWAP.W	D5	SUB.W	D4,D5		; D4 <-- By-Ay	SWAP.W	D5	SWAP.W	D4	LOAD.W	D4,#CHOUIA	LOAD.L	D1,D4	LOAD.L	D2,D3	CALL	FIXDIV	JUMP,VS OVER$	LOAD.L	A0,D0		; A0 <-- P	LOAD.L	D1,D3	LOAD.L	D2,D4	CALL	FIXDIV	JUMP,VS OVER$	NEG.L	D0	LOAD.L	A1,D0		; A1 <-- P'	LOAD.W	D1,D5	SWAP.W	D1	LOAD.W	D1,#CHOUIA	LOAD.L	D2,A1	CALL	FIXMUL		; D0 <-- Ax*P'	JUMP,VS OVER$	LOAD.L	D3,D0	LOAD.W	D1,D7	SWAP.W	D1	LOAD.W	D1,#CHOUIA	LOAD.L	D2,A0	CALL	FIXMUL		; D0 <-- Dx*P	JUMP,VS OVER$	SUB.L	D3,D0	LOAD.L	D0,D5	LOAD.W	D0,#CHOUIA	; D0 <-- Ay	SUB.L	D3,D0	LOAD.L	D0,D7	LOAD.W	D0,#CHOUIA	; D0 <-- Dy	ADD.L	D3,D0	LOAD.L	D1,D3		; D1 <-- (Ax*P')-(Dx*P)-Ay+Dy	LOAD.L	D2,A1	SUB.L	D2,A0		; D2 <-- P'-P	CALL	FIXDIV		; D0 <-- Cx	JUMP,VS OVER$	LOAD.L	D3,D0	LOAD.W	D1,D5	SWAP.W	D1	LOAD.W	D1,#CHOUIA	; D1 <-- Ax	SUB.L	D1,D3		; D1 <-- Ax-Cx	NEG.L	D1		; D1 <-- Cx-Ax	LOAD.L	D2,A1	CALL	FIXMUL		; D0 <-- (Cx-Ax)*P'	JUMP,VS OVER$	LOAD.L	D1,D5	LOAD.W	D1,#CHOUIA	; D1 <-- Ay	ADD.L	D0,D1		; D0 <-- Cy	SWAP.W	D0	LOAD.W	D3,D0	SWAP.W	D3	JUMP'	EXIT$OVER$:	LOAD.W	D3,D6	SUB.W	D3,D5		; D3 <-- Bx-Ax	JUMP',NC POSX$	NEG.W	D3POSX$:	SWAP.W	D5	SWAP.W	D6	LOAD.W	D4,D6	SUB.W	D4,D5		; D4 <-- By-Ay	JUMP',NC POSY$	NEG.W	D3POSY$:	SWAP.W	D6	SWAP.W	D5	COMP.W	D3,D4	JUMP',LO VERT$HORIZ$:	LOAD.L	D3,D7	LOAD.W	D3,D5	JUMP'	EXIT$VERT$:	LOAD.L	D3,D5	LOAD.W	D3,D7;	JUMP'	EXIT$EXIT$:	POPM.L	D0..D2,D4..D7,A0,A1	RET;-------\\; FIXMUL >;=======/; in	D1.L	nombre  virgule fixe no 1;	D2.L	nombre  virgule fixe no 2; out	D0.L	nombre  virgule fixe rsultant;	VS	si dpassement de capacit (dans ce cas D0=max_fix ou min_fix selon signes); mod	D0.LFIXMUL:	PUSHM.L	D1,D2,D4,D5,D6	CALL	TOPOSITIF	LOAD.L	D4,#H'00010000	COMP.L	D1,D4		; D1 = 1.0 ?	JUMP,NE	D1DIFF0$	; non => D2 = 1.0 ?	LOAD.L	D1,D2	JUMP	MUL10$D1DIFF0$:	COMP.L	D2,D4		; D2 = 1.0 ?	JUMP,NE	DIFFZERO$MUL10$:	CLR.L	D0	CLR.L	D4	LOAD.W	D4,D1	SWAP.W	D4	SWAP.W	D1	LOAD.W	D0,D1		; (D0;D4) = rsultat	JUMP	LONGTOFIX$DIFFZERO$:	LOAD.W	D4,D2	MUL.WU	D4,D1		; D4 <-- D1.fract * D2.fract	SWAP.W	D2	LOAD.W	D5,D2	MUL.WU	D5,D1		; D5 <-- D1.fract * D2.int	SWAP.W	D1	LOAD.W	D0,D2	MUL.WU	D0,D1		; D0 <-- D1.int * D2.int	SWAP.W	D2	MUL.WU	D2,D1		; D2 <-- D1.int * D2.fract	ADD.L	D2,D5		; mid	CLR.L	D5	LOAD.W	D5,D2	SWAP.W	D5		; mid * 2**16	LOAD.W	D2,D5		; #0	SWAP.W	D2	ADD.L	D4,D5		; + low	ADDX.L	D0,D2		; mid.31..W + high + carry				; (D0;D4): rsultatLONGTOFIX$:	SWAP.W	D0	TEST.W	D0		; high word <> 0 ?	JUMP,NE	SETMAX$		; oui => met la val. maximum	SWAP.W	D4	LOAD.W	D0,D4		; low res. word	TEST.L	D4		; high bit reste = 0 ?	JUMP,PL	NOTROUND$	INC.L	D0		; inc res.fract	JUMP,CS	SETMAX$NOTROUND$:	TEST.L	D0		; bit de signe dj mis ?	JUMP,MI	SETMAX$		; ==> dbordement !	TEST.B	D6		; (VC)	JUMP,EQ	EXIT$	NEG.L	D0		; met rsultat ngatif selon D1 et D2.in (VC)	JUMP	EXIT$SETMAX$:	LOAD.L	D0,#H'00000001	RR.L	D0,#1	TEST.B	D6	JUMP,NE	RTNOV$	DEC.L	D0RTNOV$:	SETV			; met le bit overflowEXIT$:	POPM.L	D1,D2,D4,D5,D6	RET;-------\\; FIXDIV >;=======/; in	D1.L	nombre  virgule fixe numrateur;	D2.L	nombre  virgule fixe dnominateur; out	D0.L	nombre  virgule fixe rsultant;	VS	si dpassement de capacit (dans ce cas D0=max_fix ou min_fix selon signes); mod	D0.LFIXDIV:	PUSHM.L	D1..D6	EX.L	D1,D2	COMP.L	D2,D1	JUMP,EQ	EQUAL$	CALL	TOPOSITIF	LOAD.L	D4,D2	TEST.L	D1		; /0 ?	JUMP,NE	DODIV$		; nonOVERFLOW$:	LOAD.L	D0,#H'7FFFFFFF	TEST.B	D6		; remet ngatif si l'tait	JUMP,EQ	POSOV$	INC.L	D0POSOV$:	SETV	JUMP	EXIT$DODIV$:	LOAD.L	D2,D1		; Dnom	CLR.L	D1	LOAD.L	D0,D4		; Num	CALL	INTDIV32	; Num/Denom: DIV.64 D2,(D1&D0) --> D3.L reste D4.L	JUMP,VS	OVERFLOW$	LOAD.W	D5,D3	SWAP.W	D5		; --> entier	CLR.L	D1		; reste * 2**16	SWAP.W	D4	LOAD.W	D1,D4	LOAD.L	D0,D4	CLR.W	D0	CALL	INTDIV32	; reste*2**16/ Denom	LOAD.W	D5,D3		; --> fraction	LOAD.L	D0,D5	TEST.L	D4	JUMP,PL	NOROUND$	INC.L	D5	JUMP,CS	OVERFLOW$NOROUND$:	TEST.L	D5	JUMP,NS	OVERFLOW$PUTSIGN$:	TEST.B	D6		; remet ngatif si l'tait (VC)	JUMP,EQ	POS$	NEG.L	D0		; (VC)POS$:	JUMP	EXIT$EQUAL$:	LOAD.L	D0,#1	SWAP.W	D0		; (VC)EXIT$:	POPM.L	D1..D6	RETTOPOSITIF:	TEST.L	D1	SET.B,MI D6	JUMP,PL	POS1$	NEG.L	D1POS1$:	TEST.L	D2	JUMP,PL	POS2$	NEG.L	D2	NOT.B	D6POS2$:	RET;---------\\; INTDIV32 >;=========/; Module de division 64/32 --> 32 bits (non-sign).;	-------------------;	 D3 <-- D1&D0 / D2;	 D4 <-- reste;	-------------------; ATTENTION: pas de test de division par zro !; in	D1&D0.L	numrateur (64 bits non-sign);	D2.L	dnominateur (32 bits non-sign); out	D3.L	rsultat (32 bits non-sign);	D4.L	reste (32 bits non-sign);	VS	overflow; mod	D3.L, D4.LINTDIV32:	PUSHM.L D0,D1	LOAD.W	D4,#32-1	; D4 <-- dcompteur de bouclesLOOP$:	SETX	RLX.L	D0	RLX.L	D1	JUMP',CS ERROR$	SUB.L	D1,D2	JUMP',HS NEXT$	ADD.L	D1,D2	TCLR.L	D0:#0		; bit 0 si rtablissementNEXT$:	DECJ.W,NMO D4,LOOP$	COMP.L	D1,D2		; reste >= diviseur ?	JUMP',HS ERROR$	LOAD.L	D3,D0		; D3 <-- quotient	LOAD.L	D4,D1		; D4 <-- reste,	 F <-- V=0	JUMP'	EXIT$ERROR$:	SETV			; F <-- V=1EXIT$:	POPM.L	D0,D1	RET	.END	START