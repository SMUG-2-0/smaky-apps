 = [pav0.y]*1/2 + p0.y	.8	PGTYPOSCALCX,0*2+1,0,1+(1*16)	; [x] = [pav0.x]*1/1 + p0.x	.8	PGTYPOSCALCH2,1*2+0,1,1+(1*16)	; [y] = [pav1.y]*1/1 + p1.y	.8	PGTYPOSCALCX,1*2+1,1,1+(1*16)	; [x] = [pav1.x]*1/1 + p1.x	.8	PGTYPOSCALCY,0*2+0,0,16'2F	; [y] = -[pav0.y]*1/2 + p0.y	.8.8.16	PGTYPOSREL,1*2+1,0		; [x] = p1.x	.8	PGTYPOSCALCH1,3*2+0,2,16'1F	; [y] = -[pav2.y]*1/1 + p1.y	.8	PGTYPOSCALCX,3*2+1,2,16'11	; [x] = [pav2.x]*1/1 + p1.x	.16.8.8	ESYPAVE,0,2**BSYPRIGHT	.16.8.8	ESYPAVE,1,2**BSYPRIGHT+2**BSYIMBR	.16.8.8	ESYPAVE,3,2**BSYPRIGHT+2**BSYIMBR	.16	ESYEND	DATAOFF	EXPIND	DATAON	FRACTION	.8	10				; nombre de poignes	.8	3				; nombre d'lments	.8	2				; nombre de pavs	.EVEN	.8.8.16	PGTYPOSREL,	0*2+0,0			; [0]	.8	PGTYPOSCALCX,	0*2+1,0,16'11		; taille [dx] du pav 0	.8.8.16	PGTYPOSREL,	0*2+0,0			; [0]	.8	PGTYPOSCALCX,	0*2+1,1,16'11		; taille [dx] du pav 1	.8	PGTYPOSMAX+2**BPGTYPVIRT,0*2+0,1*2+1,2*2+1 ; maximum des poignes [1] et [2] selon [x] (virtuel)	.8	PGTYPANGLE,	0*2+1,2,1		; prend la moiti de [y] selon [x] !;	(4) Dbut de la barre de fraction :	.8.8.16	PGTYPOSREL,	0*2+0,-72		; monte un bout (64/256 de [dy] de symbole)	.8.8.16	PGTYPOSREL,	0*2+1,64		; fait un peu de place;	(5) Fin de la barre de fraction :	.8.8.16	PGTYPOSREL,	4*2+0,0			; idem que pg 4	.8	PGTYPOSDIST,	4*2+1,0*2+0,3*2+0	; longueur ncessaire	.8.8.16	PGTYPOSREL,	5*2+0,0			; idem que pg 5	.8.8.16	PGTYPOSREL,	5*2+1,64		; un peu plus loin;	(7) Point milieu :	.8.8.16	PGTYPOSREL,	4*2+0,0			; idem que pg 4	.8.8.16	PGTYPOSREL,	3*2+1,64		; cherche le milieu;	(8) Poigne du haut extrme	.8	PGTYPOSCALCY,	7*2+0,0,16'F1		; haut (soustraire)	.8.8.16	PGTYPOSREL,	7*2+1,0	.8	PGTYPOSCALCY,	7*2+0,1,16'11		; bas (ajouter)	.8.8.16	PGTYPOSREL,	7*2+1,0	.16.8.8	ESYLINE,4,5				; barre de fraction	.16.8.8	ESYPAVE,7,2**BSYPUP+2**BSYPLEFT+2**BSYPRIGHT	.16.8.8	ESYPAVE,7,2**BSYPDOWN+2**BSYPLEFT+2**BSYPRIGHT	.16	ESYEND	DATAOFF	FRACTION	DATAON	EXPOSANT	.8	3,2,2	