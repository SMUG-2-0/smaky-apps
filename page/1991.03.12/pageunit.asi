	.SBTTL	PAGEUNIT.ASI;	Par dfinition, un point interne [obj] mesure 0.02mm, quelque soit l'imprimante.;	;	        Xpt;	Xmm = ------;	        50;	;	           Xpt;	Xin = ------------;	        50 * 25.4;	;	           Xpt;	Xdi = -------------;	       50 * 0.3759;	;	        6 * Xpt;	Xpi = -----------;	       50 * 25.4;	;	             Xpt;	Xci = ------------------;	       12 * 50 * 0.3759;	;	Une coordonne est code sur 16 bits signs. Dans la page, les;	nombres doivent tre positifs. Il en rsulte les limites suivantes :;	;	0 < Xpt < 2^15;	0 < Xmm < 655.36;	0 < Xin < 25.8;	;	Donc, la plus grande dimension est de 655mm ou 25.8in !;	;	Choix de la rsolution  utiliser pour l'affichage  l'chelle 100% :;	;	SMAKY       pt    mm    pt/mm;	------------------------------;	SM324.x    864   230     3.76;	SM324.y   1024   300     3.41   moyenne = 3.59;	;	SM100.x    640   220     2.91;	SM100.y    400   142     2.82   moyenne = 2.87;	;	;	SCALE  pt/mm     SM324   SM100;	-------------------------------;	 +4   200.00     5600%   7200%;	 +3   150.00     4200%   5400%;	 +2   100.00     2800%   3600%;	  0    50.00     1400%   1800%   <---  [scr] = [obj];	 -2    25.00      700%    900%;	 -3    12.50      467%    600%;	 -4    12.50      350%    450%;	 -6     8.33      233%    300%;	 -8     6.25      175%    225%;	-12     4.17      117%    150%;	-14     3.57      100%    129%   <---  100% sur SMAKY 324;	-16     3.13       88%    113%;	-18     2.78       78%    100%   <---  100% sur SMAKY 100;	-24     2.08       58%     75%;	-32     1.56       44%     56%;	-48     1.04       29%     38%;	-64     0.78       22%     28%;--------\\; PUTUNUM >;========/; Met un nombre avec des units dans un buffer.; in	D4.W	nombre [obj];	A4.L	^buffer; out	A4.L	^plus loin; mod	D7.W, A4.LPUTUNUM:	PUSHM.L	D1..D4	LOAD.W	D3,(A6)+OUNIT	; D3 <-- unit par dfaut	CALL	CONVOBJUNIT	; D4 <-- nombre BCD	LOAD.W	D1,D3		; D1 <-- unit	LIB	?BCDBIN		; D4 <-- valeur en binaire	LOAD.L	D2,#500	COMP.W	D1,#UNITMM	JUMP',EQ RND$	COMP.W	D1,#UNITCM	JUMP',EQ RND$	COMP.W	D1,#UNITIN	JUMP',EQ RND$	COMP.W	D1,#UNITDI	JUMP',EQ RND$	COMP.W	D1,#UNITPI	JUMP',EQ RND$	COMP.W	D1,#UNITCI	JUMP',EQ RND$	CLR.L	D2RND$:	ADD.L	D4,D2	LIB	?BINBCD		; D4 <-- valeur en BCD	LOAD.L	D2,#H'10000*2+3	COMP.W	D1,#UNITMM	JUMP',EQ ILOOP$	LOAD.L	D2,#H'10000*3+2	COMP.W	D1,#UNITCM	JUMP',EQ ILOOP$;	LOAD.L	D2,#H'10000*3+2	COMP.W	D1,#UNITIN	JUMP',EQ ILOOP$	LOAD.L	D2,#H'10000*1+4	COMP.W	D1,#UNITDI	JUMP',EQ ILOOP$	LOAD.L	D2,#H'10000*2+3	COMP.W	D1,#UNITPI	JUMP',EQ ILOOP$;	LOAD.L	D2,#H'10000*2+3	COMP.W	D1,#UNITCI	JUMP',EQ ILOOP$	LOAD.L	D2,#H'10000*0+8ILOOP$:	RL.L	D4,#4		; D4 <-- pousse d'un digit	LOAD.B	D3,D4	AND.B	D3,#H'0F	; D3 <-- 0..9	JUMP',NE IPUT$		; si 1..9 => IPUT$	COMP.B	D2,#1		; dernier digit ?	JUMP',EQ IPUT$		; oui => IPUT$	TEST.L	D2:#10		; zro significatif ?	JUMP',BC ISKIP$		; non => ISKIP$IPUT$:	ADD.B	D3,#'0		; D3 <-- '0..'9	LOAD.B	(A4+),D3	TSET.L	D2:#10ISKIP$:	DEC.B	D2	JUMP,NE	ILOOP$	SWAP.W	D2		; D2 <-- nb digits partie fractionnaire	TEST.W	D2	JUMP',EQ FEND$	LOAD.L	D3,#H'F0000000	COMP.W	D2,#1	JUMP',EQ FPUT$	LOAD.L	D3,#H'FF000000	COMP.W	D2,#2	JUMP',EQ FPUT$	LOAD.L	D3,#H'FFF00000;	COMP.W	D2,#3;	JUMP',EQ FPUT$FPUT$:	AND.L	D4,D3	JUMP',EQ FEND$	LOAD.B	(A4+),#'.	; buffer <-- "."FLOOP$:	CLR.B	D4	TEST.L	D4		; reste de la partie dcimale nul ?	JUMP',EQ FEND$		; oui => FEND$	RL.L	D4,#4		; D4 <-- pousse d'un digit	LOAD.B	D3,D4;	AND.B	D3,#H'0F	; D3 <-- 0..9	ADD.B	D3,#'0		; D3 <-- '0..'9	LOAD.B	(A4+),D3	DEC.B	D2	JUMP,NE	FLOOP$FEND$:	LOAD.W	D3,D1	CALL	PUTUNIT		; buffer <-- unit	POPM.L	D1..D4	RET;--------\\; GETUNUM >;========/; Donne un nombre avec des units.; in	A4.L	^dans buffer; out	A4.L	^plus loin;	D4.W	nombre [obj]; mod	D4.L, D7.W, A4.LGETUNUM:	PUSHM.L	D1..D3	CLR.L	D4		; D4 <-- futur nombre BCD	CLR.L	D2		; D2 <-- nb dcimales + flagsLOOP$:	LOAD.B	D3,(A4+)	COMP.B	D3,#'.	JUMP',EQ FRAC$	COMP.B	D3,#',	JUMP',EQ FRAC$	SUB.B	D3,#'0	JUMP',LO END$	COMP.B	D3,#9		; D3 <-- 0..9	JUMP',HI END$	SL.L	D4,#4		; D4 <-- pousse d'un digit (4 bits)	OR.B	D4,D3		; D4 <-- met le nouveau digit	TEST.L	D2:#16		; "." rencontr ?	JUMP,BC LOOP$		; non => LOOP$	INC.B	D2		; D2 <-- une dcimale de plus	JUMP	LOOP$FRAC$:	TSET.L	D2:#16		; D2 <-- "." rencontr	JUMP	LOOP$END$:	DEC.L	A4	CALL	GETUNIT		; D3 <-- unit	TEST.W	D3		; une unit trouve ?	JUMP',NE DEF$		; oui => DEF$	LOAD.W	D3,(A6)+OUNIT	; D3 <-- unit par dfautDEF$:	LOAD.W	D1,#5		; D1 <-- nb de dcimales si "mm"	COMP.W	D3,#UNITMM	JUMP',EQ UNIT$	LOAD.W	D1,#6		; D1 <-- nb de dcimales si "cm"	COMP.W	D3,#UNITCM	JUMP',EQ UNIT$;	LOAD.W	D1,#6		; D1 <-- nb de dcimales si "in"	COMP.W	D3,#UNITIN	JUMP',EQ UNIT$	LOAD.W	D1,#4		; D1 <-- nb de dcimales si "di"	COMP.W	D3,#UNITDI	JUMP',EQ UNIT$	LOAD.W	D1,#5		; D1 <-- nb de dcimales si "pi"	COMP.W	D3,#UNITPI	JUMP',EQ UNIT$;	LOAD.W	D1,#5		; D1 <-- nb de dcimales si "ci"	COMP.W	D3,#UNITCI	JUMP',EQ UNIT$	CLR.W	D1		; D1 <-- nb de dcimales si rienUNIT$:	SUB.W	D1,D2		; D1 <-- nb de dcimales manquantes	JUMP',EQ EXIT$	JUMP',NS TOO$	SL.W	D1,#2		; D4 <-- *4 (car 4 bits/digit)	SL.L	D4,D1		; D4 <-- comble les dcimales manquantes	JUMP'	EXIT$TOO$:	NEG.W	D1	SL.W	D1,#2		; D4 <-- *4 (car 4 bits/digit)	SR.L	D4,D1		; D4 <-- enlve les dcimales superfluesEXIT$:	CALL	CONVUNITOBJ	; D4 <-- valeur [obj]	POPM.L	D1..D3	RET;------------\\; CONVOBJUNIT >;------------/; Conversion d'une valeur objet --> unit quelconque.; La valeur BCD est compose de 8 digits comme suit :;;	|---|---|---|---|---|---|---|---|;	| 1 | 2 | 3 | 4 | 5 | 6 | 7 | 8 |  <--  D4.L;	|---|---|---|---|---|---|---|---|;;	 <--------------i-------------->   si rien;	 <----i----> <--f--> <----t---->   si "mm";	 <--i--> <----f----> <----t---->   si "cm";	 <--i--> <----f----> <----t---->   si "in";	 <------i------> <f> <----t---->   si "di";	 <----i----> <--f--> <----t---->   si "pi";	 <----i----> <--f--> <----t---->   si "ci";;	i:	partie entire;	f:	partie fractionnaire visible;	t:	partie fractionnaire invisible; in	D3.W	unit voulue (UNITxx);	D4.W	valeur entire [obj]; out	D4.L	valeur BCD [unit]; mod	D4.L, D7.WCONVOBJUNIT:	COMP.W	D3,#UNITMM	JUMP',EQ MM$	COMP.W	D3,#UNITCM	JUMP',EQ CM$	COMP.W	D3,#UNITIN	JUMP',EQ IN$	COMP.W	D3,#UNITDI	JUMP',EQ DI$	COMP.W	D3,#UNITPI	JUMP',EQ PI$	COMP.W	D3,#UNITCI	JUMP',EQ CI$	AND.L	D4,#H'FFFF	JUMP'	EXIT$MM$:	MUL.WU	D4,#2000	; 2000.0 = 10^5/50	JUMP'	EXIT$CM$:	MUL.WU	D4,#2000	; 2000.0 = 10^6/500	JUMP'	EXIT$IN$:	MUL.WU	D4,#787		; 787.40 = 10^6/(50*25.4)	JUMP'	EXIT$DI$:	MUL.WU	D4,#532		; 532.06 = 10^4/(50*0.3759)	JUMP'	EXIT$PI$:	MUL.WU	D4,#472		; 472.44 = 10^5*6/(50*25.4)	JUMP'	EXIT$CI$:	MUL.WU	D4,#443		; 443.38 = 10^5/(12*50*0.3759);	JUMP'	EXIT$EXIT$:	LIB	?BINBCD		; D4 <-- 8 digits BCD	RET;------------\\; CONVUNITOBJ >;------------/; Conversion d'une valeur unit quelconque --> objet.; in	D3.W	unit voulue (UNITxx);	D4.L	valeur BCD [unit]; out	D4.W	valeur entire [obj]; mod	D4.L, D7.WCONVUNITOBJ:	LIB	?BCDBIN		; D4 <-- valeur binaire	COMP.W	D3,#UNITMM	JUMP',EQ MM$	COMP.W	D3,#UNITCM	JUMP',EQ CM$	COMP.W	D3,#UNITIN	JUMP',EQ IN$	COMP.W	D3,#UNITDI	JUMP',EQ DI$	COMP.W	D3,#UNITPI	JUMP',EQ PI$	COMP.W	D3,#UNITCI	JUMP',EQ CI$	JUMP'	EXIT$MM$:	ADD.L	D4,#2000/2	DIV.WU	D4,#2000	JUMP'	EXIT$CM$:	ADD.L	D4,#2000/2	DIV.WU	D4,#2000	JUMP'	EXIT$IN$:	ADD.L	D4,#787/2	DIV.WU	D4,#787	JUMP'	EXIT$DI$:	ADD.L	D4,#532/2	DIV.WU	D4,#532	JUMP'	EXIT$PI$:	ADD.L	D4,#472/2	DIV.WU	D4,#472	JUMP'	EXIT$CI$:	ADD.L	D4,#443/2	DIV.WU	D4,#443;	JUMP'	EXIT$EXIT$:	RET;--------\\; PUTUNIT >;--------/; Met une unit dans le buffer.; in	D3.W	unit (UNITxx);	A4.L	^dans buffer; out	A4.L	^plus loin; mod	D7.W, A4.LPUTUNIT:	PUSH.L	A3	LOAD.L	A3,#R16"TAUNIT-4LOOP$:	ADD.L	A3,#4		; A3 <-- ^suivant	TEST.W	(A3)		; fin de la table ?	JUMP',EQ EXIT$		; oui => EXIT$	COMP.W	D3,(A3)	JUMP,NE LOOP$	LOAD.B	(A4+),(A3)+2	; buffer <-- premier caractre	LOAD.B	(A4+),(A3)+3	; buffer <-- deuxime caractreEXIT$:	POP.L	A3	RET;--------\\; GETUNIT >;--------/; Donne une unit.; in	A4.L	^dans buffer; out	A4.L	^plus loin;	D3.W	unit; mod	D3.L, D7.W, A4.LGETUNIT:	PUSHM.L	D1,D2,A3	LOAD.B	D3,(A4)	LIB	?MINMAJ	LOAD.B	D1,D3		; D1 <-- premire lettre	LOAD.B	D3,(A4)+1	LIB	?MINMAJ	LOAD.B	D2,D3		; D2 <-- deuxime lettre	CLR.W	D3		; D3 <-- rien trouv	COMP.B	D1,#'A	JUMP',LO EXIT$	COMP.B	D1,#'Z	JUMP',HI EXIT$	ADD.B	D1,#'a-'A	COMP.B	D2,#'A	JUMP',LO EXIT$	COMP.B	D2,#'Z	JUMP',HI EXIT$	ADD.B	D2,#'a-'A	LOAD.L	A3,#R16"TAUNIT-4LOOP$:	ADD.L	A3,#4		; A3 <-- ^suivant	TEST.W	(A3)		; fin de la table ?	JUMP',EQ EXIT$		; oui => EXIT$	COMP.B	D1,(A3)+2	; premire lettre trouve ?	JUMP,NE LOOP$		; non => LOOP$	COMP.B	D2,(A3)+3	; deuxime lettre trouve ?	JUMP,NE LOOP$		; non => LOOP$	LOAD.W	D3,(A3)		; D3 <-- unit	ADD.L	A4,#2		; A4 <-- saute les deux lettresEXIT$:	POPM.L	D1,D2,A3	RETTAUNIT:	.W	UNITMM	.ASCII	"mm"	.W	UNITCM	.ASCII	"cm"	.W	UNITIN	.ASCII	"in"	.W	UNITDI	.ASCII	"di"	.W	UNITPI	.ASCII	"pi"	.W	UNITCI	.ASCII	"ci"	.W	UNITPT	.ASCII	"pt"	.W	0;--------\\; PUTANUM >;========/; Met un nombre dcimal dans un buffer.; in	D4.L	nombre;	A4.L	^dans buffer; out	A4.L	^plus loin; mod	A4.LPUTANUM:	PUSHM.L	D2,D3,D4	LIB	?BINBCD		; D4 <-- nombre BCD	LOAD.W	D2,#8		; D2 <-- nb digits + flags10$:	RL.L	D4,#4		; D4 <-- pousse d'un digit	LOAD.B	D3,D4	AND.B	D3,#H'0F	; D3 <-- 0..9	JUMP',NE 40$		; si 1..9 => 40$	COMP.B	D2,#1		; dernier digit ?	JUMP',EQ 40$		; oui => 40$	TEST.L	D2:#10		; zro significatif ?	JUMP',BC 50$		; non => 50$40$:	ADD.B	D3,#'0		; D3 <-- '0..'9	LOAD.B	(A4+),D3	TSET.L	D2:#1050$:	DEC.B	D2	JUMP,NE	10$	POPM.L	D2,D3,D4	RET;--------\\; GETANUM >;========/; Donne un nombre dcimal.; in	A4.L	^dans buffer; out	A4.L	^plus loin;	D4.L	nombre; mod	D4.L, A4.LGETANUM:	PUSHM.L	D2,D3	CLR.L	D4		; D4 <-- futur nombre10$:	CLR.L	D3	LOAD.B	D3,(A4+)	COMP.B	D3,#'0	JUMP',LO 50$	COMP.B	D3,#'9	JUMP',HI 50$	SUB.B	D3,#'0		; D3 <-- 0..9	SL.L	D4,#1	LOAD.L	D2,D4	SL.L	D4,#2	ADD.L	D4,D2		; D4 <-- pousse d'un digit (*10)	ADD.L	D4,D3		; D4 <-- ajoute nouveau digit	JUMP	10$50$:	DEC.L	A4		; D4 <-- ^terminateur	POPM.L	D2,D3	RET;-----------\\; CONVSCROBP >;===========/; Conversion d'une coordonne cran --> objet, selon le pas.; in	D4.L	coordonne cran (y;x); out	D4.L	coordonne objet (y;x);	D7.W	erreur; mod	D4.L, D7.WCONVSCROBP:	CALL	CONVSCROBJ	; D4 <-- coordonne [ojb];	CALL	CONVPAS;	RET;--------\\; CONVPAS >;========/; Conversion d'une coordonne cran --> selon le pas.; in	D4.L	coordonne objet (y;x); out	D4.L	coordonne objet (y;x) selon le pas; mod	D4.L, D7.WCONVPAS:	TEST.B	(A6)+OCOLFA+3:#BCOLMAGN-0	JUMP',BC NOCOL$	PUSHM.L	D2,D3,A4	SWAP.W	D4	LOAD.W	D2,#8		; D2 <-- marge de dtection	LOAD.W	D3,(A6)+ODESMS	; D3 <-- haut des colonnes	CALL	CONVPASSPEC	; D4 <-- position magntique	LOAD.W	D3,(A6)+ODESYD	SUB.W	D3,(A6)+ODESMI	; D3 <-- bas des colonnes	CALL	CONVPASSPEC	; D4 <-- position magntique	SWAP.W	D4	LOAD.W	D2,#2		; D2 <-- marge de dtectionCRELOOP$:	LOAD.L	A4,#(A6)+OCOLPX	; A4 <-- ^positions en X des colonnesCLOOP$:	LOAD.W	D3,(A4+)	COMP.W	D3,#-1	JUMP',EQ CNEXT$	CALL	CONVPASSPEC	; D4 <-- position magntique	JUMP',EQ CEND$	JUMP	CLOOP$CNEXT$:	SL.W	D2,#1		; D2 <-- augmente la marge de dtection	COMP.W	D2,#8	JUMP,LS CRELOOP$CEND$:	POPM.L	D2,D3,A4	CLR.W	D7		; D7 <-- okNOCOL$:	TEST.B	(A6)+OGRID+3:#BGRIDPAX-0	JUMP',BC EXIT$	PUSHM.L	D1..D3	LOAD.W	D2,(A6)+OPAS	JUMP',EQ NOPAS$	LOAD.W	D1,D2	SR.W	D1,#1	LOAD.W	D3,D4	ADD.W	D3,D1	CONV.LA.WA D3	DIV.WA	D3,D2	MUL.WA	D3,D2	LOAD.W	D4,D3		; D4 <-- position arrondie en X	SWAP.W	D4	LOAD.W	D3,D4	ADD.W	D3,D1	CONV.LA.WA D3	DIV.WA	D3,D2	MUL.WA	D3,D2	LOAD.W	D4,D3		; D4 <-- position arrondie en Y	SWAP.W	D4NOPAS$:	POPM.L	D1..D3EXIT$:	TEST.W	D7		; retour EQ/NE	RET;------------\\; CONVPASSPEC >;------------/; in	D2.W	marge de dplacement [scr];	D3.W	position exacte;	D4.W	valeur; out	D4.W	valeur v. dplace;	D7.W	erreur; mod	D4.W <-- !, D7.WCONVPASSPEC:	PUSHM.L	D0,D1	LOAD.W	D0,D3	LOAD.W	D1,D4	EX.L	D4,D0	CALL	SCALEP		; D0 <-- position exacte [scr]	EX.L	D4,D0	EX.L	D4,D1	CALL	SCALEP		; D1 <-- valeur [scr]	EX.L	D4,D1	LOAD.W	D7,#1		; D7 <-- pas de dplacement	SUB.W	D0,D2	COMP.W	D1,D0	JUMP',LT EXIT$	ADD.W	D0,D2	ADD.W	D0,D2	COMP.W	D1,D0	JUMP',GE EXIT$	LOAD.W	D4,D3	CLR.W	D7		; D7 <-- valeur dplaceEXIT$:	POPM.L	D0,D1	TEST.W	D7		; retour EQ/NE	RET;-----------\\; CONVSCROBJ >;===========/; Conversion d'une coordonne cran --> objet.; in	D4.L	coordonne cran (y;x); out	D4.L	coordonne objet (y;x);	D7.W	erreur; mod	D4.L, D7.WCONVSCROBJ:	CLR.W	D7		; D7 <-- ok	COMP.W	D4,(A6)+OWDOX2	JUMP',LT 20$	LOAD.W	D7,#ERDIOUT20$:	SUB.W	D4,(A6)+OWDOX1	JUMP',GE 22$	LOAD.W	D7,#ERDIOUT22$:	SWAP.W	D4	COMP.W	D4,(A6)+OWDOY2	JUMP',LT 30$	LOAD.W	D7,#ERDIOUT30$:	SUB.W	D4,(A6)+OWDOY1	JUMP',GE 32$	LOAD.W	D7,#ERDIOUT32$:	SWAP.W	D4	PUSH.W	D7	CALL	SCALEN	POP.W	D7	ADD.W	D4,(A6)+ODESX1	SWAP.W	D4	ADD.W	D4,(A6)+ODESY1	SWAP.W	D4	COMP.W	D4,(A6)+ODESXD	JUMP',LT 40$	LOAD.W	D4,(A6)+ODESXD	DEC.W	D4	LOAD.W	D7,#ERDIOUT40$:	SWAP.W	D4	COMP.W	D4,(A6)+ODESYD	JUMP',LT 42$	LOAD.W	D4,(A6)+ODESYD	DEC.W	D4	LOAD.W	D7,#ERDIOUT42$:	SWAP.W	D4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; CONVOBJSCR >;===========/; Conversion d'une coordonne objet --> cran.; in	D4.L	coordonne objet (y;x); out	D4.L	coordonne cran (y;x);	D7.W	erreur; mod	D4.L, D7.WCONVOBJSCR:	CLR.W	D7		; D7 <-- ok	COMP.W	D4,(A6)+ODESX2	JUMP',LT 20$	LOAD.W	D7,#ERDIOUT20$:	SUB.W	D4,(A6)+ODESX1	JUMP',GE 22$	LOAD.W	D7,#ERDIOUT22$:	SWAP.W	D4	COMP.W	D4,(A6)+ODESY2	JUMP',LT 30$	LOAD.W	D7,#ERDIOUT30$:	SUB.W	D4,(A6)+ODESY1	JUMP',GE 32$	LOAD.W	D7,#ERDIOUT32$:	SWAP.W	D4	PUSH.W	D7	CALL	SCALEP	POP.W	D7	ADD.W	D4,(A6)+OWDOX1	SWAP.W	D4	ADD.W	D4,(A6)+OWDOY1	SWAP.W	D4	TEST.W	D7		; retour EQ/NE	RET;------------\\; CONVOBJDRAW >;============/; Conversion d'une coordonne objet --> cran pour dessiner.; in	D4.L	coordonne objet (y;x); out	D4.L	coordonne cran (y;x);	D7.W	erreur; mod	D4.L, D7.WCONVOBJDRAW:	ADD.W	D4,(A6)+OAPOS+2	SUB.W	D4,(A6)+ODESX1	SWAP.W	D4	ADD.W	D4,(A6)+OAPOS+0	SUB.W	D4,(A6)+ODESY1	SWAP.W	D4	JUMP	SCALEP;-------\\; SCALEN >;=======/; Tient compte de l'chelle ngativement.; in	D4.L	(y;x); out	D4.L	(y;x) plus petit si n:1;	D7.W	erreur; mod	D4.L, D7.WSCALEN:	TEST.B	(A6)+OIFPPS	; impression PostScript en cours ?	JUMP,T	PPS$		; oui => PPS$	TEST.B	(A6)+OIFPRI	; impression en cours ?	JUMP,T	SCALENP		; oui => SCALENP	PUSHM.L	D2,D3	CLR.W	D7		; D7 <-- ok	LOAD.W	D2,(A6)+OSCALE	; D2 <-- chelle	JUMP,EQ EXIT$	JUMP',NC POS$	NEG.W	D2		; D2 <-- |chelle|	LOAD.W	D3,D4	MUL.WA	D3,D2	LOAD.W	D4,D3		; D4 <-- x	TEST.L	D3	JUMP',NC OVX1$	NEG.L	D3OVX1$:	AND.L	D3,#H'FFFF8000	JUMP',EQ OVX2$	LOAD.W	D7,#ERPOVER	; D7 <-- overflowOVX2$:	SWAP.W	D4	LOAD.W	D3,D4	MUL.WA	D3,D2	LOAD.W	D4,D3		; D4 <-- y	SWAP.W	D4	TEST.L	D3	JUMP',NC OVY1$	NEG.L	D3OVY1$:	AND.L	D3,#H'FFFF8000	JUMP',EQ OVY2$	LOAD.W	D7,#ERPOVER	; D7 <-- overflowOVY2$:	JUMP'	EXIT$POS$:	LOAD.W	D3,D4	JUMP',NC POSX$	SUB.W	D3,D2	INC.W	D3POSX$:	CONV.LA.WA D3	DIV.WA	D3,D2	LOAD.W	D4,D3		; D4 <-- x	SWAP.W	D4	LOAD.W	D3,D4	JUMP',NC POSY$	SUB.W	D3,D2	INC.W	D3POSY$:	CONV.LA.WA D3	DIV.WA	D3,D2	LOAD.W	D4,D3		; D4 <-- y	SWAP.W	D4EXIT$:	POPM.L	D2,D3	TEST.W	D7		; retour EQ/NE	RETPPS$:	CLR.W	D7		; D7 <-- ok	RETSCALENP:	PUSH.L	D3	LOAD.W	D3,D4	MUL.WA	D3,(A6)+OSCAP2X	DIV.WA	D3,(A6)+OSCAP1X	LOAD.W	D4,D3		; D4 <-- x	SWAP.W	D4	LOAD.W	D3,D4	MUL.WA	D3,(A6)+OSCAP2Y	DIV.WA	D3,(A6)+OSCAP1Y	LOAD.W	D4,D3		; D4 <-- y	SWAP.W	D4	POP.L	D3	CLR.W	D7		; retour EQ	RET;-------\\; SCALEP >;=======/; Tient compte de l'chelle positivement.; in	D4.L	(y;x); out	D4.L	(y;x) plus grand si n:1;	D7.W	erreur; mod	D4.L, D7.WSCALEP:	TEST.B	(A6)+OIFPPS	; impression PostScript en cours ?	JUMP,T	PPS$		; oui => PPS$	TEST.B	(A6)+OIFPRI	; impression en cours ?	JUMP,T	SCALEPP		; oui => SCALEPP	PUSHM.L	D2,D3	CLR.W	D7		; D7 <-- ok	LOAD.W	D2,(A6)+OSCALE	; D2 <-- chelle	JUMP,EQ EXIT$	JUMP',NS NEG$	LOAD.W	D3,D4	MUL.WA	D3,D2	LOAD.W	D4,D3		; D4 <-- x	TEST.L	D3	JUMP',NC OVX1$	NEG.L	D3OVX1$:	AND.L	D3,#H'FFFF8000	JUMP',EQ OVX2$	LOAD.W	D7,#ERPOVER	; D7 <-- overflowOVX2$:	SWAP.W	D4	LOAD.W	D3,D4	MUL.WA	D3,D2	LOAD.W	D4,D3		; D4 <-- y	SWAP.W	D4	TEST.L	D3	JUMP',NC OVY1$	NEG.L	D3OVY1$:	AND.L	D3,#H'FFFF8000	JUMP',EQ OVY2$	LOAD.W	D7,#ERPOVER	; D7 <-- overflowOVY2$:	JUMP'	EXIT$NEG$:	NEG.W	D2		; D2 <-- |chelle|	LOAD.W	D3,D4	JUMP',NC NEGX$	SUB.W	D3,D2	INC.W	D3NEGX$:	CONV.LA.WA D3	DIV.WA	D3,D2	LOAD.W	D4,D3		; D4 <-- x	SWAP.W	D4	LOAD.W	D3,D4	JUMP',NC NEGY$	SUB.W	D3,D2	INC.W	D3NEGY$:	CONV.LA.WA D3	DIV.WA	D3,D2	LOAD.W	D4,D3		; D4 <-- y	SWAP.W	D4EXIT$:	POPM.L	D2,D3	TEST.W	D7		; retour EQ/NE	RETPPS$:	CLR.W	D7		; D7 <-- ok	RETSCALEPP:	PUSH.L	D3	LOAD.W	D3,D4	MUL.WA	D3,(A6)+OSCAP1X	DIV.WA	D3,(A6)+OSCAP2X	LOAD.W	D4,D3		; D4 <-- x	SWAP.W	D4	LOAD.W	D3,D4	MUL.WA	D3,(A6)+OSCAP1Y	DIV.WA	D3,(A6)+OSCAP2Y	LOAD.W	D4,D3		; D4 <-- y	SWAP.W	D4	POP.L	D3	CLR.W	D7		; retour EQ	RET;----------\\; SCALEPBIG >;==========/; Tient compte de l'chelle positivement.; in	D4.W	valeur; out	D4.L	valeur plus grande si n:1; mod	D4.L, D7.WSCALEPBIG:	PUSH.W	D2	LOAD.W	D2,(A6)+OSCALE	; D2 <-- chelle	JUMP',EQ MASK$	JUMP',NS NEG$	MUL.WA	D4,D2	JUMP'	EXIT$NEG$:	NEG.W	D2		; D2 <-- |chelle|	TEST.W	D4	JUMP',NC NEGX$	SUB.W	D4,D2	INC.W	D4NEGX$:	CONV.LA.WA D4	DIV.WA	D4,D2MASK$:	CONV.LA.WA D4EXIT$:	POP.W	D2	RET	.END