	.SBTTL	MPAGEMISC;-------\\; RACINE >;=======/; Calcule la racine carre d'un nombre entier.; in	D3.L	n; out	D4.W	racine(n); mod	D4.L, D7.WRACINE:	PUSHM.L	D0..D3,A3	LOAD.L	A3,#R16"TABLE$10$:	ADD.L	A3,#6	COMP.L	D3,(A3)	JUMP,HI 10$	LOAD.W	D0,(A3)-2	; D0 <-- Bi	LOAD.W	D1,(A3)+4	; D1 <-- Bs20$:	COMP.W	D0,D1		; borne infrieure = borne suprieure ?	JUMP',EQ 80$		; oui => 80$	DEC.W	D1	COMP.W	D0,D1		; borne infrieure ~ borne suprieure ?	JUMP',EQ 80$		; oui => 80$	INC.W	D1	LOAD.W	D2,D1	SUB.W	D2,D0	SR.W	D2,#1	ADD.W	D2,D0		; D2=Bx <-- Bi+(Bs-Bi)/2	LOAD.W	D4,D2	MUL.WU	D4,D4		; D4 <-- Bx^2	COMP.L	D4,D3		; Bx^2 = n  ?	JUMP',EQ 70$	JUMP',HI 40$	LOAD.W	D0,D2		; D0=Bi <-- Bx	JUMP	20$40$:	LOAD.W	D1,D2		; D1=Bs <-- Bx	JUMP	20$70$:	LOAD.W	D1,D280$:	CLR.L	D4	LOAD.W	D4,D1		; D4 <-- racine carre	POPM.L	D0..D3,A3	RETTABLE$:	.L	0	.W	0	.L	1	.W	1	.L	10	.W	3	.L	100	.W	10	.L	1000	.W	31	.L	10000	.W	100	.L	100000	.W	316	.L	1000000	.W	1000	.L	10000000	.W	3162	.L	100000000	.W	10000	.L	-1	.W	-1;--------\\; DRMDEF  >;========/; Dfini la demi-trame super-rapidement.; ATTENTION:	Le fait d'crire directement dans le descripteur;		de la fentre fait que la trame est inverse !; in	D4.L	demi-trame; out	-; mod	D7.WDRMDEF:	LOAD.L	(A0)+ODFTRA+0,D4	LOAD.L	(A0)+ODFTRA+4,D4	CLR.L	(A0)+ODFTPM	; annule XTRAME	RET;--------\\; HVDOT   >;========/; Trace une ligne de la grille.; in	D3.L	coordonne initiale (y;x);	D4.L	incrment (dy;dx);	D2.W	nb de points (1..n); out	-; mod	D7.WHVDOT:	PUSHM.L	D1,D3,D4,A1,A2	EX.L	D3,D4	LOAD.W	D1,#SETDOT	LOAD.L	A2,A0		; A2 <-- ^descripteur	LOAD.L	A1,(A6)+OHVDOT	; A1 <-- adresse routine	CALL	(A1)		; GRA_HVDOT	POPM.L	D1,D3,D4,A1,A2	RET;--------\\; IFMOUSE >;========/; Donne la position de la souris dans la swdo.; in	-; out	D4.L	position de la souris (y;x);	D7.W	erreur; mod	D4.L, D7.WIFMOUSE:	PUSH.L	D3	LIB	?IFMOUSE	JUMP',NE 90$	ADD.W	D4,(A6)+OLUPX	SUB.W	D4,(A0)+ODFFX	JUMP',HS 20$	CLR.W	D4	LOAD.W	D7,#ERDIOUT20$:	SWAP.W	D4	ADD.W	D4,(A6)+OLUPY	SUB.W	D4,(A0)+ODFFY	JUMP',HS 30$	CLR.W	D4	LOAD.W	D7,#ERDIOUT30$:	SWAP.W	D490$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;--------\\; CCMO    >;========/; Enlve la souris.; in	-; out	-; mod	D7.WCCMO:	PUSH.W	D3	TEST.B	(A6)+OCCMO	JUMP',T 90$	LOAD.B	D3,#AFCCMO	LIB	?AFCAR	SET.B	(A6)+OCCMO90$:	POP.W	D3	RET;--------\\; SCMO    >;========/; Remet la souris.; in	-; out	-; mod	D7.WSCMO:	PUSH.W	D3	TEST.B	(A6)+OCCMO	JUMP',F 90$	LOAD.B	D3,#AFSCMO	LIB	?AFCAR	CLR.B	(A6)+OCCMO90$:	POP.W	D3	RET;----------\\; OPEDISMAT >;==========/; Modifie le descripteur de la fentre pour pouvoir dessiner; directement dans la matrice principale.; in	A4.L	^matrice o dessiner;	D4.L	dimensions (dy;dx); out	-; mod	D7.WOPEDISMAT:	PUSH.L	D4	CALL	CCMO		; enlve la souris	LOAD.L	(A6)+OSDDIS+ODFABS,(A0)+ODFABS	LOAD.W	(A6)+OSDDIS+ODFIIX,(A0)+ODFIIX	LOAD.W	(A6)+OSDDIS+ODFIIY,(A0)+ODFIIY	LOAD.L	(A6)+OSDDIS+ODFY,(A0)+ODFY	LOAD.L	(A6)+OSDDIS+ODFDY,(A0)+ODFDY	LOAD.L	(A6)+OSDDIS+ODFFY,(A0)+ODFFY	LOAD.L	(A6)+OSDDIS+ODFFDY,(A0)+ODFFDY	LOAD.L	(A6)+OSDDIS+ODFWBY,(A0)+ODFWBY	LOAD.L	(A6)+OSDDIS+ODFWEY,(A0)+ODFWEY;;?	LOAD.W	(A6)+OSDDIS+ODFTTC,(A0)+ODFTTC	LOAD.L	(A0)+ODFABS,A4	CLR.L	(A0)+ODFY	LOAD.L	(A0)+ODFDY,D4	CLR.L	(A0)+ODFFY	LOAD.L	(A0)+ODFFDY,D4	CLR.L	(A0)+ODFWBY	LOAD.L	(A0)+ODFWEY,D4	LOAD.W	(A0)+ODFIIX,#1	ADD.W	D4,#16-1	AND.B	D4,#B'11110000	SR.W	D4,#3	LOAD.W	(A0)+ODFIIY,D4	POP.L	D4	RET;----------\\; CLODISMAT >;==========/; Modifie le descripteur de la fentre pour pouvoir de nouveau; dessiner dans l'cran.; in	-; out	-; mod	D7.WCLODISMAT:	LOAD.L	(A0)+ODFABS,(A6)+OSDDIS+ODFABS	LOAD.W	(A0)+ODFIIX,(A6)+OSDDIS+ODFIIX	LOAD.W	(A0)+ODFIIY,(A6)+OSDDIS+ODFIIY	LOAD.L	(A0)+ODFY,(A6)+OSDDIS+ODFY	LOAD.L	(A0)+ODFDY,(A6)+OSDDIS+ODFDY	LOAD.L	(A0)+ODFFY,(A6)+OSDDIS+ODFFY	LOAD.L	(A0)+ODFFDY,(A6)+OSDDIS+ODFFDY	LOAD.L	(A0)+ODFWBY,(A6)+OSDDIS+ODFWBY	LOAD.L	(A0)+ODFWEY,(A6)+OSDDIS+ODFWEY;;?	LOAD.W	(A0)+ODFTTC,(A6)+OSDDIS+ODFTTC	RET;----------\\; OPEDITMAT >;==========/; Modifie le descripteur de la fentre pour pouvoir dessiner; directement dans la matrice principale.; in	A4.L	^matrice o dessiner;	D4.L	dimensions (dy;dx); out	-; mod	D7.WOPEDITMAT:	PUSH.L	D4	CALL	CCMO		; enlve la souris	LOAD.L	(A6)+OTDDIS+ODFABS,(A0)+ODFABS	LOAD.W	(A6)+OTDDIS+ODFIIX,(A0)+ODFIIX	LOAD.W	(A6)+OTDDIS+ODFIIY,(A0)+ODFIIY	LOAD.L	(A6)+OTDDIS+ODFY,(A0)+ODFY	LOAD.L	(A6)+OTDDIS+ODFDY,(A0)+ODFDY	LOAD.L	(A6)+OTDDIS+ODFFY,(A0)+ODFFY	LOAD.L	(A6)+OTDDIS+ODFFDY,(A0)+ODFFDY	LOAD.L	(A6)+OTDDIS+ODFWBY,(A0)+ODFWBY	LOAD.L	(A6)+OTDDIS+ODFWEY,(A0)+ODFWEY;;?	LOAD.W	(A6)+OTDDIS+ODFTTC,(A0)+ODFTTC	LOAD.L	(A0)+ODFABS,A4	CLR.L	(A0)+ODFY	LOAD.L	(A0)+ODFDY,D4	CLR.L	(A0)+ODFFY	LOAD.L	(A0)+ODFFDY,D4	CLR.L	(A0)+ODFWBY	LOAD.L	(A0)+ODFWEY,D4	LOAD.W	(A0)+ODFIIX,#1	ADD.W	D4,#16-1	AND.B	D4,#B'11110000	SR.W	D4,#3	LOAD.W	(A0)+ODFIIY,D4	POP.L	D4	RET;----------\\; CLODITMAT >;==========/; Modifie le descripteur de la fentre pour pouvoir de nouveau; dessiner dans l'cran.; in	-; out	-; mod	D7.WCLODITMAT:	LOAD.L	(A0)+ODFABS,(A6)+OTDDIS+ODFABS	LOAD.W	(A0)+ODFIIX,(A6)+OTDDIS+ODFIIX	LOAD.W	(A0)+ODFIIY,(A6)+OTDDIS+ODFIIY	LOAD.L	(A0)+ODFY,(A6)+OTDDIS+ODFY	LOAD.L	(A0)+ODFDY,(A6)+OTDDIS+ODFDY	LOAD.L	(A0)+ODFFY,(A6)+OTDDIS+ODFFY	LOAD.L	(A0)+ODFFDY,(A6)+OTDDIS+ODFFDY	LOAD.L	(A0)+ODFWBY,(A6)+OTDDIS+ODFWBY	LOAD.L	(A0)+ODFWEY,(A6)+OTDDIS+ODFWEY;;?	LOAD.W	(A0)+ODFTTC,(A6)+OTDDIS+ODFTTC	RET;--------\\; MINMAJ  >;========/; in	D3.B	caractre; out	D3.B	caractre majuscule; mod	D3.BMINMAJ:	TEST.L	D3:#7		; code "supplmentaire" ?	JUMP',NE 20$		; oui => 20$	COMP.B	D3,#SPACE-2	; lettre accentue ?	JUMP',LO 50$		; oui => 50$	COMP.B	D3,#'a	JUMP',LO 20$	COMP.B	D3,#'z		; minuscule non accentue ?	JUMP',HI 20$		; non => 20$	SUB.B	D3,#'a-'A	; oui => transforme20$:	RET50$:	COMP.B	D3,#'	JUMP,LO 20$	PUSH.W	D0	SUB.B	D3,#'	CLR.W	D0	LOAD.B	D0,D3	LOAD.B	D3,(PC)+(D0)+TABLE$ ; D3 <-- lettre majuscule	POP.W	D0	RETTABLE$:	.B	'U 'A 'A 'E 'E 'E 'E 'I 'I 'O 'U 'U 'A 'O 'C	.EVEN	.END