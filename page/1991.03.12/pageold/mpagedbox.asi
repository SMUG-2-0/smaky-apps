	.SBTTL	MPAGEDBOX;-----------\\; _PAGE_DBOX >;===========/; ; in	D7.W	numro du sous-appel;	?	selon appel; out	?	selon appel; mod	?	selon appel_PAGE_DBOX:	COMP.W	D7,#DBOX_PEN	JUMP,EQ DBOXPEN	COMP.W	D7,#DBOX_TRAME	JUMP,EQ DBOXTRAME	COMP.W	D7,#DBOX_TXJUST	JUMP,EQ DBOXTXJUST	COMP.W	D7,#DBOX_TXITL	JUMP,EQ DBOXTXITL	COMP.W	D7,#DBOX_TXITC	JUMP,EQ DBOXTXITC	RET;--------\\; DBOXPEN >;========/; Choisi et/ou modifie un pinceau  utiliser.; in	-; out	D3.L	dernire touche (F1/F0);	D4.W	nb de pinceaux modifis;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXPEN:	PUSHM.L	D0..D2,D5,D6,A0..A4	LOAD.W	D6,(A6)+OSLPEN	; D6 <-- pinceau slectionn	LIB	?GETPDIS	LOAD.L	A0,A4		; A0 <-- ^descripteur fentre	LOAD.L	A2,#R16"TDBOX_PEN	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE EXIT$	CLR.B	(A6)+ODBRTR	; n'dite pas des trames	CALL	DBRDESCADRE	; dessine les cadres des rectangles	CLR.W	D0	LOAD.W	D1,#NBRX*NBRY	LOAD.W	D2,#SETDOT	CALL	DBRDESPENS	; dessine tous les pinceaux	LOAD.W	D0,D6	CALL	DBRINV		; inverse le rectangle slectionn	CLR.W	D0		; D0 <-- nb de pinceaux modifisLOOP$:	CALL	SCMO		; remet la souris	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_PEN	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ USE$	COMP.W	D3,#F4	JUMP,EQ MODIF$	COMP.W	D3,#F7	JUMP,EQ PREND$	COMP.W	D3,#F9	JUMP,EQ SAUVE$	COMP.W	D3,#F0	JUMP,EQ END$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$CLIC$:	CALL	DBRSEL		; slectionne un nouveau rectangle	JUMP,NE BIP$	COMP.W	D3,#KEYMGP	JUMP,EQ USE$	COMP.W	D3,#KEYMMP	JUMP,EQ USE$	COMP.W	D3,#KEYMDP	JUMP,EQ USE$	JUMP	LOOP$MODIF$:	CALL	DBOXMODPEN	; modifie un pinceau ...	PUSH.W	D7	LOAD.L	A2,#R16"TDBOX_PEN	CALL	DBOXRSK		; refait les soft-keys	POP.W	D7	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	PUSH.W	D0	LOAD.W	D0,D6	LOAD.W	D1,#1	LOAD.W	D2,#CLRDOT	CALL	DBRDESPENS	; dessine le pinceau modifi	POP.W	D0	CALL	DBOXIFPEN	; pinceau modifi ?	JUMP,EQ LOOP$		; non => LOOP$	INC.W	D0		; D0 <-- un pinceau de plus modifi	JUMP	LOOP$PREND$:	CALL	PENPREND	; prend les pinceaux ...	PUSH.W	D7	LOAD.L	A2,#R16"TDBOX_PEN	CALL	DBOXRSK		; refait les soft-keys	POP.W	D7	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	LOAD.W	D0,D6	CALL	DBRINV		; teint le rectangle slectionn	CLR.W	D0	LOAD.W	D1,#NBRX*NBRY	LOAD.W	D2,#SETDOT	CALL	DBRDESPENS	; dessine tous les pinceaux	LOAD.W	D0,D6	CALL	DBRINV		; allume le rectangle slectionn	LOAD.W	D0,#NBRX*NBRY	; D0 <-- tous les pinceaux modifis	JUMP	LOOP$SAUVE$:	CALL	PENSAUVE	; sauve les pinceaux ...	PUSH.W	D7	LOAD.L	A2,#R16"TDBOX_PEN	CALL	DBOXRSK		; refait les soft-keys	POP.W	D7	JUMP,NE BIP$	JUMP	LOOP$USE$:	LOAD.W	(A6)+OSLPEN,D6	; mj le pinceau slectionnEND$:	LOAD.W	D4,D0		; D4 <-- nb de pinceaux modifis	DBOX_	CLOSE		; ferme la DBOXEXIT$:	POPM.L	D0..D2,D5,D6,A0..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_PEN:	.W	10$-TDBOX_PEN	.W	20$-TDBOX_PEN	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Choix du trait :"	.B	ODBCR,ODBCR2	.B	ODBLABEL,100	.B	ODBTEXT,0	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBTABX,60	.B	ODBLABEL,101	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" UTILISE "	.B	ODBBOX,0,F4,TDBMEV	.ASCIZ	" MODIFIE "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F7,TDBNORM	.ASCIZ	" PREND "	.B	ODBBOX,0,F9,TDBNORM	.ASCIZ	" SAUVE "	.B	ODBTABX,60-10	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Utilise"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Modifie"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Prend       Sauve"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_PEN:	.W	F1,F2,F3,0		DOKF1-TKEY_PEN	.W	F4,F5,F6,0		DOKF4-TKEY_PEN	.W	F7,0			DOKF7-TKEY_PEN	.W	F9,0			DOKF9-TKEY_PEN	.W	F0,F13,F14,F15,0	DOKF0-TKEY_PEN	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_PEN	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_PEN	.W	0;----------\\; DBOXIFPEN >;----------/; Regarde quels sont les pinceaux modifis.; in	D6.W	pinceau modifi; out	D7.W	EQ => rien n'a t mis  jour;		NE => mise  jour ncessaire; mod	D7.WDBOXIFPEN:	PUSHM.L	D3,A3,A4	LOAD.L	A3,#(A6)+OUSE	LOAD.L	A4,(A3)+OLNEXT	CLR.W	D3		; D3 <-- nb de modifs20$:	COMP.L	A4,A3		; fin de la liste ?	JUMP',EQ 80$		; oui => 80$	COMP.W	D6,(A4)+OOPEN	; utilise le pinceau modifi ?	JUMP',NE 60$		; non => 60$				; oui =>	CALL	DETINIT		; mj. les paramtres de dtection	INC.W	D3		; D3 <-- une modif de plus60$:	LOAD.L	A4,(A4)+OLNEXT	; A4 <-- ^suivant	JUMP	20$80$:	LOAD.W	D7,D3		; D7 <-- nb de modifs	POPM.L	D3,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXMODPEN >;===========/; Modifie un pinceau.; in	D6.W	pinceau  modifier; out	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXMODPEN:	PUSHM.L	D0..D2,D4..D6,A1..A4	MUL.WU	D6,#LDPEN	LOAD.L	A4,#(A6)+OTAPEN	ADD.L	A4,D6	LOAD.W	(A6)+ODBPLX,(A4)+OPENLX	LOAD.W	(A6)+ODBPLY,(A4)+OPENLY	LOAD.L	(A6)+ODBPT1,(A4)+OPENT1	LOAD.L	(A6)+ODBPT3,(A4)+OPENT3	LOAD.L	(A6)+ODBPT5,(A4)+OPENT5	LOAD.L	D4,(A4)+OPENFA	; D4 <-- fanions	JUMP',NE DEF$	LOAD.L	D4,#2^BPENCE!2^BPENCODEF$:	LOAD.L	A2,#R16"TDBOX$	LOAD.L	(A6)+ODBPTE,A2	; ODBPTE <-- ^table dbox	LOAD.L	A2,#R16"TDBOX_MODPEN	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE EXIT$	LOAD.W	D2,#2^BDBGCLABEL!200	CALL	DBOXHLINE	LOAD.W	D2,#2^BDBGCLABEL!201	CALL	DBOXHLINE	CLR.W	D2AFF$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXAFF		; affiche le paramtre	INC.W	D2	COMP.W	D2,#8	JUMP,LO AFF$	CALL	DBMPFORM	; mj dbox selon forme	CALL	DBMPTT		; mj dbox selon type de trait	CLR.W	D2NLINE$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXMEDITTEST$:	CALL	DBMPTEST	; affiche le trait obtenuLOOP$:	CALL	SCMO		; remet la souris	DBOX_	EDIT		; attend une action ...	CALL	ZEROCR		; remplace <CR> par <0>	LOAD.L	A1,#R16"TKEY_MODPEN	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ ENTER$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#UNDO	JUMP,EQ UNDO$	COMP.W	D3,#CLEAR	JUMP,EQ UNDO$	COMP.W	D3,#CR	JUMP,EQ RETURN$	COMP.W	D3,#ENTER	JUMP,EQ ENTER$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	CALL	DBOXPUT	JUMP,NE BIP$	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,#1	JUMP',NE RETURN2$	TEST.L	D4:#BPENEL	JUMP',BS RETURN2$	TEST.L	D4:#BPENRE	JUMP',BS RETURN2$	INC.W	D2		; D2 <-- saute le paramtre "hauteur"RETURN2$:	LOAD.W	D1,#2	TEST.L	D4:#BPENTT	JUMP',BC RETURN4$	LOAD.W	D1,#2+6RETURN4$:	COMP.W	D2,D1	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$ENTER$:	CALL	DBOXPUT	JUMP,NE BIP$	JUMP	TEST$KEYDBOX$:			; KEYDBOX =>	CALL	DBOXPUT	JUMP,NE BIP$	COMP.B	D3,#100	JUMP,HS CLINE$	LOAD.L	D1,#H'FFFFFF00	COMP.B	D3,#8	JUMP',LO SET$	RL.L	D1,#8	COMP.B	D3,#16	JUMP',LO SET$	RL.L	D1,#8	COMP.B	D3,#24	JUMP',LO SET$	RL.L	D1,#8SET$:	AND.L	D4,D1	TSET.L	D4:D3	COMP.B	D3,#BPENCE	JUMP',EQ FORME$	COMP.B	D3,#BPENCA	JUMP',EQ FORME$	COMP.B	D3,#BPENEL	JUMP',EQ FORME$	COMP.B	D3,#BPENRE	JUMP',EQ FORME$	COMP.B	D3,#BPENCO	JUMP',EQ TT$	COMP.B	D3,#BPENTT	JUMP',EQ TT$	CLR.W	D2	JUMP	NLINE$FORME$:	CALL	DBMPFORM	; mj dbox selon forme	CLR.W	D2	JUMP	NLINE$TT$:	CALL	DBMPTT		; mj dbox selon type de trait	LOAD.W	D2,#2	TEST.L	D4:#BPENTT	JUMP,BS NLINE$	CLR.W	D2	JUMP	NLINE$CLINE$:	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$OK$:	CALL	DBOXPUT	JUMP,NE BIP$	LOAD.L	A4,#(A6)+OTAPEN	ADD.L	A4,D6	CALL	DBMPPUT		; OPENxx <-- ODBPxxEND$:	DBOX_	CLOSE		; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4..D6,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	ODBPLX,DBTYPN,2^BDBGCLABEL!100,0,7+2	.W	ODBPLY,DBTYPN,2^BDBGCLABEL!101,1,7+2	.W	ODBPT1,DBTYPN,2^BDBGCLABEL!102,2,7+2	.W	ODBPT2,DBTYPN,2^BDBGCLABEL!103,3,7+2	.W	ODBPT3,DBTYPN,2^BDBGCLABEL!104,4,7+2	.W	ODBPT4,DBTYPN,2^BDBGCLABEL!105,5,7+2	.W	ODBPT5,DBTYPN,2^BDBGCLABEL!106,6,7+2	.W	ODBPT6,DBTYPN,2^BDBGCLABEL!107,7,7+2;---------\\; DBMPFORM >;---------/; Met  jour la dbox selon la forme du pinceau.; in	D4.L	fanions; out	-; mod	D7.WDBMPFORM:	PUSHM.L	D1..D4,A3	LOAD.L	D1,D4		; D1 <-- fanions	LOAD.L	A3,#R16"TXCE$	TEST.L	D1:#BPENCE	JUMP',BS 20$	LOAD.L	A3,#R16"TXCA$	TEST.L	D1:#BPENCA	JUMP',BS 20$	LOAD.L	A3,#R16"TXXY$20$:	LOAD.W	D2,#2^BDBGCLABEL!20	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTEXT		; affiche "Diamtre", "Ct" ou "Largeur"	INC.W	D2	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTEXT		; affiche "   " ou "Hauteur"	LOAD.W	D2,#2^BDBGCLABEL!2^BDBGCGREY!101	TEST.L	D1:#BPENCE	JUMP',BS 40$	TEST.L	D1:#BPENCA	JUMP',BS 40$	LOAD.W	D2,#2^BDBGCLABEL!2^BDBGCFULL!10140$:	DBOX_	GETCO	TEST.L	D1:#BPENCE	JUMP',BS 60$	TEST.L	D1:#BPENCA	JUMP',BS 60$	LOAD.W	(A6)+ODBPLY,(A6)+ODBPLX	LOAD.W	D2,#1	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXAFF		; affiche le paramtre "hauteur" selon "largeur"60$:	POPM.L	D1..D4,A3	RETTXCE$:	.ASCIZ	"Diamtre:"	.ASCIZ	"         "TXCA$:	.ASCIZ	"Ct:    "	.ASCIZ	"         "TXXY$:	.ASCIZ	"Largeur: "	.ASCIZ	"Hauteur: "	.EVEN;-------\\; DBMPTT >;-------/; Met  jour la dbox selon le type de trait.; in	D4.L	fanions; out	-; mod	D7.WDBMPTT:	PUSHM.L	D1..D4,A3,A4	LOAD.L	D1,D4		; D1 <-- fanions	LOAD.W	D2,#2^BDBGCLABEL!2^BDBGCGREY!102	TEST.L	D1:#BPENTT	JUMP',BC 20$	LOAD.W	D2,#2^BDBGCLABEL!2^BDBGCFULL!10220$:	DBOX_	GETCO		; grise/dgrise les trait/trou	INC.B	D2	COMP.B	D2,#102+6+1	JUMP,LO 20$	TEST.L	D1:#BPENTT	JUMP',BC 90$	LOAD.W	D2,#260$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXAFF		; affiche le paramtre	INC.W	D2	COMP.W	D2,#8	JUMP,LO 60$90$:	POPM.L	D1..D4,A3,A4	RET;---------\\; DBMPTEST >;---------/; Affiche un petit trait de test.; in	D4.L	fanions; out	-; mod	D7.WDBMPTEST:	PUSHM.L	D1..D5,A3,A4	LOAD.L	A4,#(A6)+OTAPEN+(LDPEN*NBRX*NBRY)	CALL	DBMPPUT		; OPENxx <-- ODBPxx	LOAD.L	D2,D5	LIB	?GETWDO		; D3/D4 <-- pos/dim sous-fentre actuelle	PUSH.L	D3	PUSH.L	D4	LOAD.L	D5,D2	CLR.L	D4	CALL	DRMDEF		; trame pour effacer	LOAD.W	D2,#2^BDBGCLABEL!31	DBOX_	GETCO	SWAP.W	D3	ADD.W	D3,#4	SWAP.W	D3	PUSH.L	D3	LOAD.W	D2,#2^BDBGCLABEL!30	DBOX_	GETCO	POP.L	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; dessine le pourtour	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface l'intrieur	ADD.W	D3,(A0)+ODFFX	SWAP.W	D3	ADD.W	D3,(A0)+ODFFY;	SWAP.W	D3	SWAP.W	D4	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DIMWDO	LOAD.L	(A3)+1,D3	LOAD.L	(A3)+5,D4	LOAD.W	D3,#9	LIB	?STRING		; dessine dans une sous-fentre !	CLR.L	D3		; D3 <-- origine dans sous-fentre	SWAP.W	D4		; D4 <-- dimensions	LOAD.W	D2,#SETDOT	; D2 <-- mode	LOAD.W	D1,#NBRX*NBRY	; D1 <-- numro du pinceau bidon	CALL	MATPEN		; utilise le pinceau bidon	SWAP.W	D3	SWAP.W	D4	LOAD.W	D1,D4	SR.W	D1,#1	LOAD.W	D3,D1	CLR.W	D4	SWAP.W	D4	SWAP.W	D3	ADD.W	D3,D1	SUB.W	D4,D1	SUB.W	D4,D1	LIB	?DRSEG		; dessine le trait	POP.L	D4	POP.L	D3	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DIMWDO	SWAP.W	D3	LOAD.L	(A3)+1,D3	SWAP.W	D4	LOAD.L	(A3)+5,D4	LOAD.W	D3,#9	LIB	?STRING		; remet la sous-fentre initiale	POPM.L	D1..D5,A3,A4	RET;--------\\; DBMPPUT >;--------/; Met  jour les paramtres d'un pinceau.; in	A4.L	^pinceau;	D4.L	fanions; out	-; mod	D7.WDBMPPUT:	PUSH.L	D3	LOAD.W	D3,(A6)+ODBPLX	JUMP',NE 20$	INC.W	D320$:	LOAD.W	(A4)+OPENLX,D3	LOAD.W	D3,(A6)+ODBPLY	JUMP',NE 30$	INC.W	D330$:	LOAD.W	(A4)+OPENLY,D3	LOAD.L	(A4)+OPENT1,(A6)+ODBPT1	LOAD.L	(A4)+OPENT3,(A6)+ODBPT3	LOAD.L	(A4)+OPENT5,(A6)+ODBPT5	LOAD.L	(A4)+OPENFA,D4	TEST.L	D4:#BPENEL	JUMP',BS 50$	TEST.L	D4:#BPENRE	JUMP',BS 50$	LOAD.W	(A4)+OPENLY,(A4)+OPENLX50$:	POP.L	D3	RETTDBOX_MODPEN:	.W	10$-TDBOX_MODPEN	.W	20$-TDBOX_MODPEN	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"    Pinceau:"	.B	ODBTABX,33+1	.B	ODBLABEL,20	.B	ODBTEXT,0	.B	ODBTABX,33+11+1	.B	ODBLABEL,21	.B	ODBTEXT,0	.B	ODBCR	.B	ODBLCIRCLE,BPENCE!2^6!2^7,KEYDBOX/H'100,BPENCE	.ASCIZ	" circulaire"	.B	ODBTABX,15	.B	ODBLCIRCLE,BPENEL!2^6!2^7,KEYDBOX/H'100,BPENEL	.ASCIZ	" elliptique"	.B	ODBCR2	.B	ODBTABX,33	.B	ODBLABEL,100	.B	ODBCLINE,(7+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBLABEL,101	.B	ODBCLINE,(7+2)!2^7,KEYDBOX/H'100,101,TDBNORM	.B	ODBCR2	.B	ODBLCIRCLE,BPENCA!2^6!2^7,KEYDBOX/H'100,BPENCA	.ASCIZ	" carr"	.B	ODBTABX,15	.B	ODBLCIRCLE,BPENRE!2^6!2^7,KEYDBOX/H'100,BPENRE	.ASCIZ	" rectangulaire"	.B	ODBCR	.B	ODBLABEL,200	.B	ODBTEXT,0	.B	ODBCR	.B	ODBLCIRCLE,BPENCO!2^6!2^7,KEYDBOX/H'100,BPENCO	.ASCIZ	" trait continu"	.B	ODBCR	.B	ODBLCIRCLE,BPENTT!2^6!2^7,KEYDBOX/H'100,BPENTT	.ASCIZ	" trait pointill"	.B	ODBCR,ODBCR2	.B	ODBLABEL,108	.B	ODBTEXT	.ASCIZ	"  Trait:     Trou:      Trait:     Trou:      Trait:     Trou:"		;          ;          ;          ;          ;          ;          ;	.B	ODBCR,ODBCR2	.B	ODBLABEL,102	.B	ODBCLINE,(7+2)!2^7,KEYDBOX/H'100,102,TDBNORM	.B	ODBLABEL,103	.B	ODBCLINE,(7+2)!2^7,KEYDBOX/H'100,103,TDBNORM	.B	ODBLABEL,104	.B	ODBCLINE,(7+2)!2^7,KEYDBOX/H'100,104,TDBNORM	.B	ODBLABEL,105	.B	ODBCLINE,(7+2)!2^7,KEYDBOX/H'100,105,TDBNORM	.B	ODBLABEL,106	.B	ODBCLINE,(7+2)!2^7,KEYDBOX/H'100,106,TDBNORM	.B	ODBLABEL,107	.B	ODBCLINE,(7+2)!2^7,KEYDBOX/H'100,107,TDBNORM	.B	ODBCR	.B	ODBLABEL,201	.B	ODBTEXT,0	.B	ODBCR	.B	ODBTABX,33	.B	ODBLABEL,30	.B	ODBTEXT,0	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	ODBTABX,33+32	.B	ODBLABEL,31	.B	ODBTEXT,0	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_MODPEN:	.W	F1,F2,F3,0		DOKF1-TKEY_MODPEN	.W	F0,F13,F14,F15,0	DOKF0-TKEY_MODPEN	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_MODPEN	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_MODPEN	.W	0;----------\\; DBOXTRAME >;==========/; Choisi et/ou modifie une trame  utiliser.; in	-; out	D3.L	dernire touche (F1/F0);	D4.W	nb de trames modifies;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXTRAME:	PUSHM.L	D0..D2,D5,D6,A0..A4	LOAD.W	D6,(A6)+OSLTRA	; D6 <-- trame slectionne	LIB	?GETPDIS	LOAD.L	A0,A4		; A0 <-- ^descripteur fentre	LOAD.L	A2,#R16"TDBOX_TRA	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE EXIT$	SET.B	(A6)+ODBRTR	; dite des trames	CALL	DBRDESCADRE	; dessine les cadres des rectangles	CLR.W	D0	LOAD.W	D1,#NBRX*NBRY	LOAD.W	D2,#SETDOT	CALL	DBRDESTRAS	; dessine toutes les trames	LOAD.W	D0,D6	CALL	DBRINV		; inverse le rectangle slectionn	CLR.W	D0		; D0 <-- nb de trames modifiesLOOP$:	CALL	SCMO		; remet la souris	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_TRA	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ USE$	COMP.W	D3,#F4	JUMP,EQ MODIF$	COMP.W	D3,#F7	JUMP,EQ PREND$	COMP.W	D3,#F9	JUMP,EQ SAUVE$	COMP.W	D3,#F0	JUMP,EQ END$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$CLIC$:	CALL	DBRSEL		; slectionne un nouveau rectangle	JUMP,NE BIP$	COMP.W	D3,#KEYMGP	JUMP,EQ USE$	COMP.W	D3,#KEYMMP	JUMP,EQ USE$	COMP.W	D3,#KEYMDP	JUMP,EQ USE$	JUMP	LOOP$MODIF$:	CALL	DBOXMODTRAME	; modifie une trame ...	PUSH.W	D7	LOAD.L	A2,#R16"TDBOX_TRA	CALL	DBOXRSK		; refait les soft-keys	POP.W	D7	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	PUSH.W	D0	LOAD.W	D0,D6	LOAD.W	D1,#1	LOAD.W	D2,#CLRDOT	CALL	DBRDESTRAS	; dessine la trame modifie	POP.W	D0	CALL	DBOXIFTRAME	; trame modifie ?	JUMP,EQ LOOP$		; non => LOOP$	INC.W	D0		; D0 <-- une trame de plus modifie	JUMP	LOOP$PREND$:	CALL	TRAPREND	; prend les trames ...	PUSH.W	D7	LOAD.L	A2,#R16"TDBOX_TRA	CALL	DBOXRSK		; refait les soft-keys	POP.W	D7	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	LOAD.W	D0,D6	CALL	DBRINV		; teint le rectangle slectionn	CLR.W	D0	LOAD.W	D1,#NBRX*NBRY	LOAD.W	D2,#SETDOT	CALL	DBRDESTRAS	; dessine toutes les trames	LOAD.W	D0,D6	CALL	DBRINV		; allume le rectangle slectionn	LOAD.W	D0,#NBRX*NBRY	; D0 <-- toutes les trames modifies	JUMP	LOOP$SAUVE$:	CALL	TRASAUVE	; sauve les trames ...	PUSH.W	D7	LOAD.L	A2,#R16"TDBOX_TRA	CALL	DBOXRSK		; refait les soft-keys	POP.W	D7	JUMP,NE BIP$	JUMP	LOOP$USE$:	LOAD.W	(A6)+OSLTRA,D6	; mj la trame slectionneEND$:	LOAD.W	D4,D0		; D4 <-- nb de trames modifies	DBOX_	CLOSE		; ferme la DBOXEXIT$:	POPM.L	D0..D2,D5,D6,A0..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_TRA:	.W	10$-TDBOX_TRA	.W	20$-TDBOX_TRA	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Choix de la trame :"	.B	ODBCR,ODBCR2	.B	ODBLABEL,100	.B	ODBTEXT,0	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBTABX,60	.B	ODBLABEL,101	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" UTILISE "	.B	ODBBOX,0,F4,TDBMEV	.ASCIZ	" MODIFIE "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F7,TDBNORM	.ASCIZ	" PREND "	.B	ODBBOX,0,F9,TDBNORM	.ASCIZ	" SAUVE "	.B	ODBTABX,60-10	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Utilise"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Modifie"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Prend       Sauve"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_TRA:	.W	F1,F2,F3,0		DOKF1-TKEY_TRA	.W	F4,F5,F6,0		DOKF4-TKEY_TRA	.W	F7,0			DOKF7-TKEY_TRA	.W	F9,0			DOKF9-TKEY_TRA	.W	F0,F13,F14,F15,0	DOKF0-TKEY_TRA	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_TRA	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_TRA	.W	0;------------\\; DBOXIFTRAME >;------------/; Regarde quelles sont les trames modifies.; in	D6.W	trame modifie; out	D7.W	EQ => rien n'a t mis  jour;		NE => mise  jour ncessaire; mod	D7.WDBOXIFTRAME:	PUSHM.L	D3,D4,A3,A4	LOAD.L	A3,#(A6)+OUSE	LOAD.L	A4,(A3)+OLNEXT	CLR.W	D3		; D3 <-- nb de modifs20$:	COMP.L	A4,A3		; fin de la liste ?	JUMP',EQ 80$		; oui => 80$	LOAD.L	D4,(A4)+OOFOND	TEST.L	D4:#BFDOBT	JUMP',BS 60$	TEST.L	D4:#BFDOBO	JUMP',BS 60$	TEST.L	D4:#BFDONO	JUMP',BS 60$	TEST.L	D4:#BFDRBO	JUMP',BS 60$	COMP.W	D6,(A4)+OOTRAM	; utilise la trame modifie ?	JUMP',NE 60$		; non => 60$				; oui =>	LOAD.W	(A4)+OOFSCA,#-1	; faudra refaire les matrices	INC.W	D3		; D3 <-- une modif de plus60$:	LOAD.L	A4,(A4)+OLNEXT	; A4 <-- ^suivant	JUMP	20$80$:	LOAD.W	D7,D3		; D7 <-- nb de modifs	POPM.L	D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-------------\\; DBOXMODTRAME >;=============/; Modifie une trame.; in	D6.W	trame  modifier; out	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXMODTRAME:	PUSHM.L	D0..D2,D4..D6,A1..A4	MUL.WU	D6,#LDTRA	LOAD.L	A4,#(A6)+OTATRA	ADD.L	A4,D6	LOAD.W	(A6)+ODBTGP,(A4)+OTRAGP	LOAD.W	(A6)+ODBTDI,(A4)+OTRADI	LOAD.W	(A6)+ODBTI1,(A4)+OTRAI1	LOAD.W	(A6)+ODBTD1,(A4)+OTRAD1	LOAD.W	(A6)+ODBTE1,(A4)+OTRAE1	LOAD.W	(A6)+ODBTE2,(A4)+OTRAE2	LOAD.L	D4,(A4)+OTRAFA	; D4 <-- fanions	JUMP',NE DEF$	LOAD.L	D4,#2^BTRAGR!2^BTRAPC!2^BTRA1X!2^BTRADHDEF$:	LOAD.L	A2,#R16"TDBOX$	LOAD.L	(A6)+ODBPTE,A2	; ODBPTE <-- ^table dbox	LOAD.L	A2,#R16"TDBOX_MODTRA	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE EXIT$	LOAD.W	D2,#2^BDBGCLABEL!201	CALL	DBOXHLINE	LOAD.W	D2,#2^BDBGCLABEL!200	CALL	DBOXHLINE	PUSH.L	D4	LOAD.L	D4,D3	CLR.W	D4	LOAD.W	D3,(A0)+ODFCX	MUL.WU	D3,#15	LOAD.W	D2,#SETDOT	LIB	?DRSEG	POP.L	D4	CLR.W	D2AFF$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXAFF		; affiche le paramtre	INC.W	D2	COMP.W	D2,#6	JUMP,LO AFF$	CALL	DBMTTT		; mj dbox selon type de trameXLINE$:	CLR.W	D2	TEST.L	D4:#BTRAGR	JUMP',BS NLINE$	LOAD.W	D2,#2NLINE$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXMEDITTEST$:	CALL	DBMTTEST	; affiche le trait obtenuLOOP$:	CALL	SCMO		; remet la souris	DBOX_	EDIT		; attend une action ...	CALL	ZEROCR		; remplace <CR> par <0>	LOAD.L	A1,#R16"TKEY_MODTRA	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ ENTER$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#UNDO	JUMP,EQ UNDO$	COMP.W	D3,#CLEAR	JUMP,EQ UNDO$	COMP.W	D3,#CR	JUMP,EQ RETURN$	COMP.W	D3,#ENTER	JUMP,EQ ENTER$	COMP.W	D3,#'+	JUMP,EQ PLUS$	COMP.W	D3,#'-	JUMP,EQ MOINS$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	CALL	DBOXPUT	JUMP,NE BIP$	INC.W	D2		; D2 <-- paramtre suivant	LOAD.L	A3,(A6)+ODBTPT	ADD.W	A3,D2	ADD.W	A3,D2RETURN2$:	LOAD.W	D1,(A3+)	COMP.B	D1,#100	JUMP,LO XLINE$	TEST.L	D1:#BDBGCGREY	JUMP,BC NLINE$	INC.W	D2		; D2 <-- paramtre suivant	JUMP	RETURN2$ENTER$:	CALL	DBOXPUT	JUMP,NE BIP$	JUMP	TEST$PLUS$:	TEST.L	D4:#BTRAGR	JUMP,BC BIP$	CALL	DBOXPUT	JUMP,NE BIP$	LOAD.W	D1,#3	TEST.L	D4:#BTRAPC	JUMP',BS PLUS2$	LOAD.W	D1,#5PLUS2$:	LOAD.W	D3,(A6)+ODBTGP	ADD.W	D3,D1	COMP.W	D3,#100	JUMP',LS PLUS3$	LOAD.W	D3,#100PLUS3$:	LOAD.W	(A6)+ODBTGP,D3	CLR.W	D2	JUMP	NLINE$MOINS$:	TEST.L	D4:#BTRAGR	JUMP,BC BIP$	CALL	DBOXPUT	JUMP,NE BIP$	LOAD.W	D1,#3	TEST.L	D4:#BTRAPC	JUMP',BS MOINS2$	LOAD.W	D1,#5MOINS2$:	LOAD.W	D3,(A6)+ODBTGP	SUB.W	D3,D1	JUMP',NC MOINS3$	CLR.W	D3MOINS3$:	LOAD.W	(A6)+ODBTGP,D3	CLR.W	D2	JUMP	NLINE$KEYDBOX$:			; KEYDBOX =>	CALL	DBOXPUT	JUMP,NE BIP$	COMP.B	D3,#100	JUMP,HS CLINE$	COMP.B	D3,#BTRAQC	JUMP,EQ TEST$	COMP.B	D3,#BTRAD2	JUMP',EQ SET2$	LOAD.L	D1,#H'FFFFFF00	COMP.B	D3,#8	JUMP',LO SET$	RL.L	D1,#8	COMP.B	D3,#16	JUMP',LO SET$	RL.L	D1,#8	COMP.B	D3,#24	JUMP',LO SET$	RL.L	D1,#8SET$:	TSET.L	D1:#BTRAQC	TSET.L	D1:#BTRAD2	AND.L	D4,D1	TSET.L	D4:D3SET2$:	CALL	DBMTTT		; mj dbox selon type de trame	JUMP	XLINE$CLINE$:	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$OK$:	CALL	DBOXPUT	JUMP,NE BIP$	LOAD.L	A4,#(A6)+OTATRA	ADD.L	A4,D6	CALL	DBMTPUT		; OTRAxx <-- ODBTxxEND$:	DBOX_	CLOSE		; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4..D6,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	ODBTGP,DBTYPN,2^BDBGCLABEL!100,0,3+2	.W	ODBTDI,DBTYPN,2^BDBGCLABEL!101,1,7+2	.W	ODBTI1,DBTYPN,2^BDBGCLABEL!102,2,3+2	.W	ODBTD1,DBTYPN,2^BDBGCLABEL!103,3,7+2	.W	ODBTE1,DBTYPN,2^BDBGCLABEL!104,4,7+2	.W	ODBTE2,DBTYPN,2^BDBGCLABEL!105,5,7+2;-------\\; DBMTTT >;-------/; Met  jour la dbox selon le type de trame.; in	D4.L	fanions; out	-; mod	D7.WDBMTTT:	PUSHM.L	D1..D4,A2..A4	LOAD.L	D1,D4		; D1 <-- fanions	TEST.L	D1:#BTRAHA	JUMP',BS 15$	LOAD.L	A2,#R16"TABLE1$	TEST.L	D1:#BTRAPC	JUMP',BS 20$	LOAD.L	A2,#R16"TABLE2$	JUMP'	20$15$:	LOAD.L	A2,#R16"TABLE3$	TEST.L	D1:#BTRAD2	JUMP',BC 20$	LOAD.L	A2,#R16"TABLE4$20$:	LOAD.L	(A6)+ODBTPT,A2	LOAD.L	A3,A222$:	LOAD.W	D2,(A3+)	JUMP',EQ 30$	DBOX_	GETCO		; grise/dgrise un objet	JUMP	22$30$:	LOAD.W	D2,(A2+)	JUMP',EQ 40$	SUB.B	D2,#100	JUMP,LO 30$	TEST.L	D2:#BDBGCGREY	JUMP,BS 30$	AND.W	D2,#H'00FF	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXAFF		; affiche le paramtre	JUMP	30$40$:	POPM.L	D1..D4,A2..A4	RETTABLE1$:	.W	2^BDBGCLABEL!2^BDBGCFULL!100	.W	2^BDBGCLABEL!2^BDBGCGREY!101	.W	2^BDBGCLABEL!2^BDBGCGREY!102	.W	2^BDBGCLABEL!2^BDBGCGREY!103	.W	2^BDBGCLABEL!2^BDBGCGREY!104	.W	2^BDBGCLABEL!2^BDBGCGREY!105	.W	2^BDBGCLABEL!2^BDBGCFULL!40	.W	2^BDBGCLABEL!2^BDBGCFULL!41	.W	2^BDBGCLABEL!2^BDBGCFULL!42	.W	2^BDBGCLABEL!2^BDBGCFULL!43	.W	2^BDBGCLABEL!2^BDBGCFULL!44	.W	2^BDBGCLABEL!2^BDBGCFULL!45	.W	2^BDBGCLABEL!2^BDBGCFULL!46	.W	2^BDBGCLABEL!2^BDBGCFULL!47	.W	2^BDBGCLABEL!2^BDBGCGREY!48	.W	2^BDBGCLABEL!2^BDBGCGREY!49	.W	2^BDBGCLABEL!2^BDBGCGREY!60	.W	2^BDBGCLABEL!2^BDBGCGREY!61	.W	2^BDBGCLABEL!2^BDBGCGREY!62	.W	2^BDBGCLABEL!2^BDBGCGREY!63	.W	2^BDBGCLABEL!2^BDBGCGREY!64	.W	2^BDBGCLABEL!2^BDBGCGREY!65	.W	2^BDBGCLABEL!2^BDBGCGREY!66	.W	2^BDBGCLABEL!2^BDBGCGREY!67	.W	2^BDBGCLABEL!2^BDBGCGREY!68	.W	0TABLE2$:	.W	2^BDBGCLABEL!2^BDBGCFULL!100	.W	2^BDBGCLABEL!2^BDBGCFULL!101	.W	2^BDBGCLABEL!2^BDBGCGREY!102	.W	2^BDBGCLABEL!2^BDBGCGREY!103	.W	2^BDBGCLABEL!2^BDBGCGREY!104	.W	2^BDBGCLABEL!2^BDBGCGREY!105	.W	2^BDBGCLABEL!2^BDBGCFULL!40	.W	2^BDBGCLABEL!2^BDBGCFULL!41	.W	2^BDBGCLABEL!2^BDBGCFULL!42	.W	2^BDBGCLABEL!2^BDBGCFULL!43	.W	2^BDBGCLABEL!2^BDBGCGREY!44	.W	2^BDBGCLABEL!2^BDBGCGREY!45	.W	2^BDBGCLABEL!2^BDBGCFULL!46	.W	2^BDBGCLABEL!2^BDBGCFULL!47	.W	2^BDBGCLABEL!2^BDBGCFULL!48	.W	2^BDBGCLABEL!2^BDBGCFULL!49	.W	2^BDBGCLABEL!2^BDBGCGREY!60	.W	2^BDBGCLABEL!2^BDBGCGREY!61	.W	2^BDBGCLABEL!2^BDBGCGREY!62	.W	2^BDBGCLABEL!2^BDBGCGREY!63	.W	2^BDBGCLABEL!2^BDBGCGREY!64	.W	2^BDBGCLABEL!2^BDBGCGREY!65	.W	2^BDBGCLABEL!2^BDBGCGREY!66	.W	2^BDBGCLABEL!2^BDBGCGREY!67	.W	2^BDBGCLABEL!2^BDBGCGREY!68	.W	0TABLE3$:	.W	2^BDBGCLABEL!2^BDBGCGREY!100	.W	2^BDBGCLABEL!2^BDBGCGREY!101	.W	2^BDBGCLABEL!2^BDBGCFULL!102	.W	2^BDBGCLABEL!2^BDBGCFULL!103	.W	2^BDBGCLABEL!2^BDBGCFULL!104	.W	2^BDBGCLABEL!2^BDBGCGREY!105	.W	2^BDBGCLABEL!2^BDBGCGREY!40	.W	2^BDBGCLABEL!2^BDBGCGREY!41	.W	2^BDBGCLABEL!2^BDBGCGREY!42	.W	2^BDBGCLABEL!2^BDBGCGREY!43	.W	2^BDBGCLABEL!2^BDBGCGREY!44	.W	2^BDBGCLABEL!2^BDBGCGREY!45	.W	2^BDBGCLABEL!2^BDBGCGREY!46	.W	2^BDBGCLABEL!2^BDBGCGREY!47	.W	2^BDBGCLABEL!2^BDBGCGREY!48	.W	2^BDBGCLABEL!2^BDBGCGREY!49	.W	2^BDBGCLABEL!2^BDBGCFULL!60	.W	2^BDBGCLABEL!2^BDBGCFULL!61	.W	2^BDBGCLABEL!2^BDBGCFULL!62	.W	2^BDBGCLABEL!2^BDBGCFULL!63	.W	2^BDBGCLABEL!2^BDBGCGREY!64	.W	2^BDBGCLABEL!2^BDBGCGREY!65	.W	2^BDBGCLABEL!2^BDBGCGREY!66	.W	2^BDBGCLABEL!2^BDBGCGREY!67	.W	2^BDBGCLABEL!2^BDBGCGREY!68	.W	0TABLE4$:	.W	2^BDBGCLABEL!2^BDBGCGREY!100	.W	2^BDBGCLABEL!2^BDBGCGREY!101	.W	2^BDBGCLABEL!2^BDBGCFULL!102	.W	2^BDBGCLABEL!2^BDBGCFULL!103	.W	2^BDBGCLABEL!2^BDBGCFULL!104	.W	2^BDBGCLABEL!2^BDBGCFULL!105	.W	2^BDBGCLABEL!2^BDBGCGREY!40	.W	2^BDBGCLABEL!2^BDBGCGREY!41	.W	2^BDBGCLABEL!2^BDBGCGREY!42	.W	2^BDBGCLABEL!2^BDBGCGREY!43	.W	2^BDBGCLABEL!2^BDBGCGREY!44	.W	2^BDBGCLABEL!2^BDBGCGREY!45	.W	2^BDBGCLABEL!2^BDBGCGREY!46	.W	2^BDBGCLABEL!2^BDBGCGREY!47	.W	2^BDBGCLABEL!2^BDBGCGREY!48	.W	2^BDBGCLABEL!2^BDBGCGREY!49	.W	2^BDBGCLABEL!2^BDBGCFULL!60	.W	2^BDBGCLABEL!2^BDBGCFULL!61	.W	2^BDBGCLABEL!2^BDBGCFULL!62	.W	2^BDBGCLABEL!2^BDBGCFULL!63	.W	2^BDBGCLABEL!2^BDBGCFULL!64	.W	2^BDBGCLABEL!2^BDBGCFULL!65	.W	2^BDBGCLABEL!2^BDBGCFULL!66	.W	2^BDBGCLABEL!2^BDBGCFULL!67	.W	2^BDBGCLABEL!2^BDBGCFULL!68	.W	0;---------\\; DBMTTEST >;---------/; Affiche une petite trame de test.; in	D4.L	fanions; out	-; mod	D7.WDBMTTEST:	PUSHM.L	D1..D4,A4	LOAD.L	A4,#(A6)+OTATRA+(LDTRA*NBRX*NBRY)	CALL	DBMTPUT		; OTRAxx <-- ODBTxx	LOAD.W	D2,#2^BDBGCLABEL!31	DBOX_	GETCO	SWAP.W	D3	ADD.W	D3,#4	SWAP.W	D3	PUSH.L	D3	LOAD.W	D2,#2^BDBGCLABEL!30	DBOX_	GETCO	POP.L	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; dessine le pourtour	LOAD.W	D2,#LOADDOT	; D2 <-- mode	LOAD.W	D1,#NBRX*NBRY	; D1 <-- numro de la trame bidon	CALL	MATTRAME	; utilise la trame bidon	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LIB	?DRTRAME	; dessine la trame	CLR.L	D4	CALL	DRMDEF	POPM.L	D1..D4,A4	RET;--------\\; DBMTPUT >;--------/; Met  jour les paramtres d'une trame.; in	A4.L	^trame;	D4.L	fanions; out	-; mod	D7.WDBMTPUT:	PUSH.L	D3	LOAD.W	D3,(A6)+ODBTGP	COMP.W	D3,#100	JUMP',LS 20$	LOAD.W	D3,#10020$:	LOAD.W	(A4)+OTRAGP,D3	LOAD.W	D3,(A6)+ODBTDI	JUMP',NE 30$	INC.W	D330$:	LOAD.W	(A4)+OTRADI,D3	LOAD.W	D3,(A6)+ODBTI1	COMP.W	D3,#180	JUMP',LS 40$	LOAD.W	D3,#18040$:	LOAD.W	(A4)+OTRAI1,D3	LOAD.W	D3,(A6)+ODBTD1	JUMP',NE 50$	INC.W	D350$:	LOAD.W	(A4)+OTRAD1,D3	LOAD.W	D3,(A6)+ODBTE1	COMP.W	D3,(A6)+OTRAD1	JUMP',LS 60$	LOAD.W	D3,(A6)+OTRAD160$:	LOAD.W	(A4)+OTRAE1,D3	LOAD.W	D3,(A6)+ODBTE2	COMP.W	D3,(A6)+OTRAD1	JUMP',LS 70$	LOAD.W	D3,(A6)+OTRAD170$:	LOAD.W	(A4)+OTRAE2,D3	LOAD.L	(A4)+OTRAFA,D4	POP.L	D3	RETTDBOX_MODTRA:	.W	10$-TDBOX_MODTRA	.W	20$-TDBOX_MODTRA	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"   Trame :"	.B	ODBTABX,17	.B	ODBLABEL,40	.B	ODBLCIRCLE,BTRAPC!2^6!2^7,KEYDBOX/H'100,BTRAPC	.ASCIZ	" gris"	.B	ODBTABX,17+24	.B	ODBLABEL,41	.B	ODBBOX,0,'-,TDBNORM	.ASCIZ	"-"	.B	ODBTABX,17+24+2	.B	ODBLABEL,100	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTABX,17+24+2+6	.B	ODBLABEL,42	.B	ODBBOX,0,'+,TDBNORM	.ASCIZ	"+"	.B	ODBLABEL,43	.B	ODBTEXT	.ASCIZ	"%"	.B	ODBTABX,17+24+2+6+2+5	.B	ODBLABEL,44	.B	ODBLCIRCLE,BTRA1X!2^6!2^7,KEYDBOX/H'100,BTRA1X	.ASCIZ	" 1x"	.B	ODBCR	.B	ODBTABX,17	.B	ODBLABEL,46	.B	ODBLCIRCLE,BTRAGC!2^6!2^7,KEYDBOX/H'100,BTRAGC	.ASCIZ	" points carrs"	.B	ODBTABX,17+24+2+6+2+5	.B	ODBLABEL,45	.B	ODBLCIRCLE,BTRA2X!2^6!2^7,KEYDBOX/H'100,BTRA2X	.ASCIZ	" 2x"	.B	ODBCR2	.B	ODBLCIRCLE,BTRAGR!2^6!2^7,KEYDBOX/H'100,BTRAGR	.ASCIZ	" points"	.B	ODBCR2	.B	ODBTABX,17	.B	ODBLABEL,47	.B	ODBLCIRCLE,BTRAGO!2^6!2^7,KEYDBOX/H'100,BTRAGO	.ASCIZ	" points ronds"	.B	ODBTABX,17+18	.B	ODBLABEL,48	.B	ODBTEXT	.ASCIZ	"grain "	.B	ODBLABEL,101	.B	ODBCLINE,(7+2)!2^7,KEYDBOX/H'100,101,TDBNORM	.B	ODBCR2	.B	ODBLCIRCLE,BTRAHA!2^6!2^7,KEYDBOX/H'100,BTRAHA	.ASCIZ	" lignes"	.B	ODBCR2	.B	ODBTABX,17	.B	ODBLABEL,49	.B	ODBSQUARE,BTRAQC!2^7,KEYDBOX/H'100,BTRAQC	.ASCIZ	" quinconce"	.B	ODBCR	.B	ODBLABEL,200	.B	ODBTEXT,0	.B	ODBCR,ODBCR2	.B	ODBLABEL,60	.B	ODBTEXT	.ASCIZ	"Inclinaison "	.B	ODBLABEL,102	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,102,TDBNORM	.B	ODBLABEL,61	.B	ODBTEXT	.ASCIZ	"  Distance "	.B	ODBLABEL,103	.B	ODBCLINE,(7+2)!2^7,KEYDBOX/H'100,103,TDBNORM	.B	ODBTABX,43	.B	ODBLABEL,62	.B	ODBTEXT	.ASCIZ	"Epaisseur "	.B	ODBLABEL,104	.B	ODBCLINE,(7+2)!2^7,KEYDBOX/H'100,104,TDBNORM	.B	ODBCR,ODBCR	.B	ODBLABEL,63	.B	ODBSQUARE,BTRAD2!2^7,KEYDBOX/H'100,BTRAD2	.ASCIZ	" 2me ligne"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBLABEL,64	.B	ODBLCIRCLE,BTRADH!2^6!2^7,KEYDBOX/H'100,BTRADH	.ASCIZ	" -"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBLABEL,65	.B	ODBLCIRCLE,BTRADO!2^6!2^7,KEYDBOX/H'100,BTRADO	.ASCIZ	" \"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBLABEL,66	.B	ODBLCIRCLE,BTRADV!2^6!2^7,KEYDBOX/H'100,BTRADV	.ASCIZ	" |"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBLABEL,67	.B	ODBLCIRCLE,BTRADI!2^6!2^7,KEYDBOX/H'100,BTRADI	.ASCIZ	" /"	.B	ODBTABX,43	.B	ODBLABEL,68	.B	ODBTEXT	.ASCIZ	"Epaisseur "	.B	ODBLABEL,105	.B	ODBCLINE,(7+2)!2^7,KEYDBOX/H'100,105,TDBNORM	.B	ODBCR	.B	ODBLABEL,201	.B	ODBTEXT,0	.B	ODBCR	.B	ODBTABX,31	.B	ODBLABEL,30	.B	ODBTEXT,0	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	ODBTABX,31+32	.B	ODBLABEL,31	.B	ODBTEXT,0	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_MODTRA:	.W	F1,F2,F3,0		DOKF1-TKEY_MODTRA	.W	F0,F13,F14,F15,0	DOKF0-TKEY_MODTRA	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_MODTRA	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_MODTRA	.W	0;-------\\; DBRSEL >;-------/; Slectionne un nouveau rectangle.; in	D6.W	rectangle slectionn (0..n); out	D6.W	nouveau rectangle (0..n);	D3.L	touche presse;	D7.W	erreur; mod	D3.L, D6.L, D7.WDBRSEL:	PUSHM.L	D0,D4	CALL	DBRDET		; est-on dans un rectangle ?	JUMP',NE 90$		; non => 90$	EX.L	D0,D6	CALL	DBRINV		; efface l'ancien	LOAD.W	D0,D6	CALL	DBRINV		; allume le nouveau20$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris bouge ?	JUMP',NE 80$		; non => 80$	CALL	DBRDET		; D0 <-- rectangle o est la souris	JUMP,NE 20$	COMP.W	D0,D6		; toujours dans le mme ?	JUMP,EQ 20$		; oui => 20$				; non =>	EX.L	D0,D6	CALL	DBRINV		; efface l'ancien	LOAD.W	D0,D6	CALL	DBRINV		; allume le nouveau	JUMP	20$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,D4	TEST.W	D7		; retour EQ/NE	RET;-------\\; DBRDET >;-------/; Dtecte dans quel rectangle est la souris.; in	-; out	D0.W	rectangle (0..n);	D7.W	erreur; mod	D0.L, D7.WDBRDET:	PUSHM.L	D1..D4	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP',NE 90$	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la matrice	SUB.W	D4,(A0)+ODFFX	; D4 <-- pos relative dans swdo	JUMP',LO 90$	SUB.W	D4,(A6)+ODBRPX	; D4 <-- pos relative dans rectangle	JUMP',LO 90$	CLR.L	D0	LOAD.W	D0,D4	DIV.WU	D0,(A6)+ODBRLX	; D0 <-- coordonne X	COMP.W	D0,#NBRX	JUMP',HS 90$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	; D4 <-- pos relative dans swdo	JUMP',LO 90$	SUB.W	D4,(A6)+ODBRPY	; D4 <-- pos relative dans rectangle	JUMP',LO 90$	CLR.L	D1	LOAD.W	D1,D4	DIV.WU	D1,(A6)+ODBRLY	; D1 <-- coordonne Y	COMP.W	D1,#NBRY	JUMP',HS 90$	MUL.WU	D1,#NBRX	ADD.W	D0,D1		; D0 <-- no du rectangle	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RET;-------\\; DBRINV >;-------/; Inverse un rectangle.; in	D0.W	no du rectangle (0..n); out	-; mod	D7.WDBRINV:	PUSHM.L	D2..D4	LOAD.L	D4,#-1	CALL	DRMDEF	LOAD.W	D2,#INVDOT	CALL	DBRPOS	JUMP',NE 90$	PUSHM.L	D3,D4	ADD.W	D3,#2	SWAP.W	D3	ADD.W	D3,#2	SWAP.W	D3	SUB.W	D4,#3	SWAP.W	D4	SUB.W	D4,#3	SWAP.W	D4;;?	DEC.W	D3;;?	SWAP.W	D3;;?	DEC.W	D3;;?	SWAP.W	D3;;?	ADD.W	D4,#3;;?	SWAP.W	D4;;?	ADD.W	D4,#3;;?	SWAP.W	D4	LIB	?DRTRAME	; inverse un rectangle	POPM.L	D3,D4	TEST.B	(A6)+ODBRTR	; dite les trames ?	JUMP',F 90$		; non => 90$				; oui =>	ADD.W	D3,#6	SWAP.W	D3	ADD.W	D3,#6	SWAP.W	D3	SUB.W	D4,#(6*2)-1	SWAP.W	D4	SUB.W	D4,#(6*2)-1	SWAP.W	D4	LIB	?DRTRAME	; inverse l'emplacement90$:	POPM.L	D2..D4	RET;-----------\\; DBRDESPENS >;-----------/; Dessine un ou plusieurs pinceaux.; in	D0.W	premier pinceau;	D1.W	nombre de pinceaux;	D2.W	mode; out	-; mod	D7.WDBRDESPENS:	PUSHM.L	D0..D5,A3	PUSH.W	(A6)+OSCALE	CLR.W	(A6)+OSCALE	; dessine  l'chelle 1:1	LIB	?GETWDO		; D3/D4 <-- pos/dim sous-fentre actuelle20$:	CALL	DBRDESPEN	; dessine un pinceau	INC.W	D0	DEC.W	D1	JUMP,NE 20$	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DIMWDO	SWAP.W	D3	LOAD.L	(A3)+1,D3	SWAP.W	D4	LOAD.L	(A3)+5,D4	LOAD.W	D3,#9	LIB	?STRING		; remet la sous-fentre initiale	POP.W	(A6)+OSCALE	POPM.L	D0..D5,A3	RET;----------\\; DBRDESPEN >;----------/; Dessine un pinceau dans un rectangle.; in	D0.W	numro du rectangle;	D2.W	mode;	D3.L	position sous-fentre; out	-; mod	D7.WDBRDESPEN:	PUSHM.L	D1..D5,A3,A4	LOAD.W	D1,D2		; D1 <-- mode	LOAD.L	D5,D3	CLR.L	D4	LOAD.W	D2,#CLRDOT	COMP.W	D1,D2	JUMP',NE 20$	DEC.L	D4	LOAD.W	D2,#SETDOT20$:	CALL	DRMDEF	CALL	DBRPOS	JUMP,NE 90$	ADD.W	D3,#3	ADD.W	D3,D5	SWAP.W	D5	SWAP.W	D3	ADD.W	D3,#3	ADD.W	D3,D5;	SWAP.W	D3	SUB.W	D4,#5	SWAP.W	D4	SUB.W	D4,#5;	SWAP.W	D4	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DIMWDO	LOAD.L	(A3)+1,D3	LOAD.L	(A3)+5,D4	LOAD.W	D3,#9	LIB	?STRING		; dessine dans une sous-fentre !	CLR.L	D3		; D3 <-- origine dans sous-fentre	SWAP.W	D4		; D4 <-- dimensions	LIB	?DRMATRIX	; efface l'emplacement	LOAD.W	D2,D1		; D2 <-- mode	LOAD.W	D1,D0		; D1 <-- numro du pinceau	CALL	MATPEN		; utilise le bon pinceau	ADD.W	D3,#(8/2)+1	SUB.W	D4,#8+1	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,#(8/2)+0	SUB.W	D4,#8+1	ADD.W	D3,D4		; droite dans le sens "/"	NEG.W	D4	SWAP.W	D3	SWAP.W	D4	LIB	?DRSEG		; dessine le trait90$:	POPM.L	D1..D5,A3,A4	RET;-----------\\; DBRDESTRAS >;-----------/; Dessine une ou plusieurs trames.; in	D0.W	premire trame;	D1.W	nombre de trames;	D2.W	mode; out	-; mod	D7.WDBRDESTRAS:	PUSHM.L	D0,D1,D4	PUSH.W	(A6)+OSCALE	CLR.W	(A6)+OSCALE	; dessine  l'chelle 1:120$:	CALL	DBRDESTRA	; dessine une trame	INC.W	D0	DEC.W	D1	JUMP,NE 20$	CLR.L	D4	CALL	DRMDEF	POP.W	(A6)+OSCALE	POPM.L	D0,D1,D4	RET;----------\\; DBRDESTRA >;----------/; Dessine une trame dans un rectangle.; in	D0.W	numro du rectangle; out	-; mod	D7.WDBRDESTRA:	PUSHM.L	D1..D4	CALL	DBRPOS	JUMP,NE 90$	ADD.W	D3,#6	SWAP.W	D3	ADD.W	D3,#6	SWAP.W	D3	SUB.W	D4,#(6*2)-1	SWAP.W	D4	SUB.W	D4,#(6*2)-1	SWAP.W	D4	LOAD.W	D2,#LOADDOT	; D2 <-- mode	LOAD.W	D1,D0		; D1 <-- numro de la trame	CALL	MATTRAME	; utilise la bonne trame	LIB	?DRTRAME	; dessine la trame90$:	POPM.L	D1..D4	RET;-------\\; DBRPOS >;-------/; Donne la position et les dimensions d'un rectangle.; in	D0.W	no du rectangle (0..n); out	D3.L	coin sup/gauche (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D7.WDBRPOS:	PUSHM.L	D0,D1	LOAD.W	D7,#1		; D7 <-- erreur	COMP.W	D0,#NBRX*NBRY	JUMP',HS 90$	AND.L	D0,#H'FFFF	DIV.WU	D0,#NBRX	LOAD.W	D1,D0		; D1 <-- Y	SWAP.W	D0		; D0 <-- X	MUL.WU	D1,(A6)+ODBRLY	ADD.W	D1,(A6)+ODBRPY	MUL.WU	D0,(A6)+ODBRLX	ADD.W	D0,(A6)+ODBRPX	LOAD.W	D3,D1	SWAP.W	D3	LOAD.W	D3,D0	LOAD.L	D4,(A6)+ODBRLY	; D4 <-- dimensions	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,D1	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBRDESCADRE >;------------/; Dessine les rectangles pour entourer la palette; de trames ou de pinceaux.; in	-; out	-; mod	D7.WDBRDESCADRE:	PUSHM.L	D0..D4	LOAD.W	D2,#2^BDBGCLABEL!100	DBOX_	GETCO	SWAP.W	D3	SUB.W	D3,#16	SWAP.W	D3	LOAD.L	(A6)+ODBRPY,D3	LOAD.W	D2,#2^BDBGCLABEL!101	DBOX_	GETCO	CLR.L	D4	LOAD.W	D4,D3	SUB.W	D4,(A6)+ODBRPX	DIV.WU	D4,#NBRX	LOAD.W	(A6)+ODBRLX,D4	MUL.WU	D4,#NBRX	SUB.W	D4,(A0)+ODFFDX	NEG.W	D4	SR.W	D4,#1	LOAD.W	(A6)+ODBRPX,D4	CLR.W	D3	SWAP.W	D3	SUB.W	D3,(A6)+ODBRPY	DIV.WU	D3,#NBRY	LOAD.W	(A6)+ODBRLY,D3	LOAD.L	D3,(A6)+ODBRPY	LOAD.L	D4,(A6)+ODBRLY	LOAD.W	D2,#SETDOT	; D2 <-- mode de dessin	LOAD.W	D1,#NBRY-1	; D1 <-- compteur vertical30$:	PUSHM.L	D3,D4	LOAD.W	D0,#NBRX-1	; D0 <-- compteur horizontal40$:	LIB	?DRRECT		; dessine rectangle	ADD.W	D3,D4		; D3 <-- X suivant	DECJ.W,NMO D0,40$	POPM.L	D3,D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4		; D3 <-- Y suivant	SWAP.W	D4	SWAP.W	D3	DECJ.W,NMO D1,30$	POPM.L	D0..D4	RET;-----------\\; DBOXTXJUST >;===========/; Choix de l'interligne.; in	D4.L	interligne; out	D4.L	interligne;	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXTXJUST:	PUSHM.L	D0..D2,D5,D6,A1..A4	LOAD.L	A2,#R16"TDBOX$	LOAD.L	(A6)+ODBPTE,A2	; ODBPTE <-- ^table dbox	CLR.W	D3	LOAD.B	D3,D4	LOAD.W	(A6)+ODBPLX,D3	LOAD.W	D3,D4	SR.W	D3,#8	LOAD.W	(A6)+ODBPLY,D3	LOAD.L	A2,#R16"TDBOX_TXJUST	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE EXIT$	CLR.W	D2AFF$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXAFF		; affiche le paramtre	INC.W	D2	COMP.W	D2,#2	JUMP,LO AFF$	CLR.W	D2NLINE$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXMEDITLOOP$:	CALL	SCMO		; remet la souris	DBOX_	EDIT		; attend une action ...	CALL	ZEROCR		; remplace <CR> par <0>	LOAD.L	A1,#R16"TKEY_TXJUST	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#UNDO	JUMP,EQ UNDO$	COMP.W	D3,#CLEAR	JUMP,EQ UNDO$	COMP.W	D3,#CR	JUMP,EQ RETURN$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	CALL	DBOXPUT	JUMP,NE BIP$	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,#2	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$KEYDBOX$:			; KEYDBOX =>	CALL	DBOXPUT	JUMP,NE BIP$	COMP.B	D3,#100	JUMP',HS CLINE$	JUMP	LOOP$CLINE$:	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$OK$:	CALL	DBOXPUT	JUMP,NE BIP$	LOAD.B	D4,(A6)+ODBPLY+1	RL.W	D4,#8	LOAD.B	D4,(A6)+ODBPLX+1END$:	DBOX_	CLOSE		; ferme la DBOXEXIT$:	POPM.L	D0..D2,D5,D6,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	ODBPLX,DBTYPN,2^BDBGCLABEL!100,0,3+2	.W	ODBPLY,DBTYPN,2^BDBGCLABEL!101,1,3+2TDBOX_TXJUST:	.W	10$-TDBOX_TXJUST	.W	20$-TDBOX_TXJUST	.W	0,010$:	.B	ODBLCIRCLE,BTXJUA	.ASCIZ	" align"	.B	ODBTABX,20	.B	ODBTEXT	.ASCIZ	"cales rparties "	.B	ODBLABEL,100	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTEXT	.ASCIZ	"% dans les mots"	.B	ODBCR	.B	ODBLCIRCLE,BTXJUD	.ASCIZ	" drapeau  droite"	.B	ODBCR	.B	ODBLCIRCLE,BTXJUG	.ASCIZ	" drapeau  gauche"	.B	ODBCR	.B	ODBLCIRCLE,BTXJUC	.ASCIZ	" centr"	.B	ODBCR,ODBCR	.B	ODBSQUARE,BTXJUM	.ASCIZ	" divisions"	.B	ODBTABX,20	.B	ODBTEXT	.ASCIZ	"partie vide ne dpassant pas"	.B	ODBLABEL,101	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,101,TDBNORM	.B	ODBTEXT	.ASCIZ	"%"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"   dans les mots"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_TXJUST:	.W	F1,F2,F3,0		DOKF1-TKEY_TXJUST	.W	F0,F13,F14,F15,0	DOKF0-TKEY_TXJUST	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_TXJUST	.W	0;----------\\; DBOXTXITL >;==========/; Choix de l'interligne.; in	D4.L	interligne; out	D4.L	interligne;	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXTXITL:	PUSHM.L	D0..D2,D5,D6,A1..A4	LOAD.L	A2,#R16"TDBOX$	LOAD.L	(A6)+ODBPTE,A2	; ODBPTE <-- ^table dbox	LOAD.W	(A6)+ODBPLX,D4	LOAD.L	A2,#R16"TDBOX_TXITL	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE EXIT$	CLR.W	D2	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXMEDITLOOP$:	CALL	SCMO		; remet la souris	DBOX_	EDIT		; attend une action ...	CALL	ZEROCR		; remplace <CR> par <0>	LOAD.L	A1,#R16"TKEY_TXITL	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#UNDO	JUMP,EQ UNDO$	COMP.W	D3,#CLEAR	JUMP,EQ UNDO$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$OK$:	CALL	DBOXPUT	JUMP,NE BIP$	LOAD.W	D4,(A6)+ODBPLXEND$:	DBOX_	CLOSE		; ferme la DBOXEXIT$:	POPM.L	D0..D2,D5,D6,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	ODBPLX,DBTYPN,2^BDBGCLABEL!100,0,7+2TDBOX_TXITL:	.W	10$-TDBOX_TXITL	.W	20$-TDBOX_TXITL	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Valeur de l'interligne "	.B	ODBLABEL,100	.B	ODBCLINE,(7+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBCR,ODBCR	.B	ODBLCIRCLE,BTXILF	.ASCIZ	" interligne fixe"	.B	ODBCR	.B	ODBLCIRCLE,BTXILE	.ASCIZ	" interligne extensible"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_TXITL:	.W	F1,F2,F3,0		DOKF1-TKEY_TXITL	.W	F0,F13,F14,F15,0	DOKF0-TKEY_TXITL	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_TXITL	.W	0;----------\\; DBOXTXITC >;==========/; Choix de l'intercaractre.; in	D4.L	intercaractre; out	D4.L	intercaractre;	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXTXITC:	PUSHM.L	D0..D2,D5,D6,A1..A4	LOAD.L	A2,#R16"TDBOX$	LOAD.L	(A6)+ODBPTE,A2	; ODBPTE <-- ^table dbox	LOAD.W	(A6)+ODBPLX,D4	LOAD.L	A2,#R16"TDBOX_TXITC	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	OPEN		; ouvre la DBOX	JUMP,NE EXIT$	CLR.W	D2	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXMEDITLOOP$:	CALL	SCMO		; remet la souris	DBOX_	EDIT		; attend une action ...	CALL	ZEROCR		; remplace <CR> par <0>	LOAD.L	A1,#R16"TKEY_TXITC	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#UNDO	JUMP,EQ UNDO$	COMP.W	D3,#CLEAR	JUMP,EQ UNDO$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$OK$:	CALL	DBOXPUT	JUMP,NE BIP$	LOAD.W	D4,(A6)+ODBPLXEND$:	DBOX_	CLOSE		; ferme la DBOXEXIT$:	POPM.L	D0..D2,D5,D6,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	ODBPLX,DBTYPN,2^BDBGCLABEL!100,0,7+2TDBOX_TXITC:	.W	10$-TDBOX_TXITC	.W	20$-TDBOX_TXITC	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Valeur de l'intercaractre "	.B	ODBLABEL,100	.B	ODBCLINE,(7+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBCR,ODBCR	.B	ODBLCIRCLE,BTXICP	.ASCIZ	" caractres espacs"	.B	ODBCR	.B	ODBLCIRCLE,BTXICM	.ASCIZ	" caractres serrs"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_TXITC:	.W	F1,F2,F3,0		DOKF1-TKEY_TXITC	.W	F0,F13,F14,F15,0	DOKF0-TKEY_TXITC	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_TXITC	.W	0;----------\\; DBOXMEDIT >;==========/; Donne la bonne valeur  DBOX_MEDIT.; in	D2.W	rang (0..n);	D5.L	canal dbox; out	-; mod	D7.WDBOXMEDIT:	PUSHM.L	D2,D3,A2	LOAD.W	D3,D2	COMP.W	D3,#-1	JUMP',EQ 50$	LOAD.L	A2,(A6)+ODBPTE	; A2 <-- ^table dbox	MUL.WU	D2,#LDB	ADD.L	A2,D2	LOAD.W	D3,(A2)+ODBRED50$:	DBOX_	MEDIT	POPM.L	D2,D3,A2	RET;--------\\; DBOXAFF >;========/; Affiche un paramtre ditable.; in	A3.L	^dbut ligne;	D2.W	rang (0..n);	D5.L	canal dbox; out	-; mod	D7.WDBOXAFF:	PUSHM.L	D2..D4,A2..A4	COMP.W	D2,#-1	JUMP',EQ 90$	LOAD.L	A2,(A6)+ODBPTE	; A2 <-- ^table dbox	MUL.WU	D2,#LDB	ADD.L	A2,D2	LOAD.W	D2,(A2)+ODBRGC	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A4,A3	LIB	?AFTEXT		; affiche le texte	LOAD.L	D2,A3	SUB.L	D2,A4		; D2 <-- nb de caractres affichs	SUB.W	D2,(A2)+ODBNBC	NEG.W	D2	JUMP',NS 90$	LOAD.B	D3,#MSPACE	LIB	?AFCAR	LOAD.B	D3,D2	LIB	?AFCAR		; efface la fin90$:	POPM.L	D2..D4,A2..A4	RET;--------\\; DBOXGET >;========/; Donne le contenu d'un paramtre ditable.; in	D2.W	rang (0..n);	D5.L	canal dbox; out	A3.L	^dbut ligne;	A4.L	^curseur dans ligne; mod	D7.W, A3.L, A4.LDBOXGET:	PUSHM.L	D2..D4,D6,A1,A2	LOAD.L	A3,#(A6)+ODBLIN	LOAD.L	A4,A3	CLR.B	(A4)	COMP.W	D2,#-1	JUMP,EQ EXIT$	LOAD.L	A2,(A6)+ODBPTE	; A2 <-- ^table dbox	MUL.WU	D2,#LDB	ADD.L	A2,D2	LOAD.W	D2,(A2)+ODBOFF	; D2 <-- offset variable	COMP.W	(A2)+ODBTYP,#DBTYPN	JUMP,EQ NUM$	COMP.W	(A2)+ODBTYP,#DBTYPA	JUMP,EQ ALPHA$	JUMP	EXIT$NUM$:	CLR.L	D4	LOAD.W	D4,(A6)+(D2.W)	; D4 <-- nombre	JUMP',NS NUM2$	CALL	PUTANUM		; ODBLIN <-- nombreNUM2$:	CLR.B	(A4)	JUMP	EXIT$ALPHA$:	LOAD.L	A1,#(A6)+(D2.W)	; A1 <-- ^chaneALPHA1$:	LOAD.B	(A4+),(A1+)	; ODBLIN <-- chane	JUMP,NE ALPHA1$	DEC.L	A4;	JUMP	EXIT$EXIT$:	POPM.L	D2..D4,D6,A1,A2	RET;--------\\; DBOXPUT >;========/; Met  jour un paramtre ditable.; in	A3.L	^dbut ligne;	D2.W	rang (0..n);	D5.L	canal dbox; out	D7.W	erreur; mod	D7.WDBOXPUT:	CALL	DBOXMAJ		; met  jour	JUMP',NE 90$	PUSHM.L	A3,A4	CALL	DBOXGET		; A3 <-- ^paramtre	CALL	DBOXAFF		; raffiche correctement	POPM.L	A3,A4	CLR.W	D7		; D7 <-- ok90$:	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBOXMAJ >;--------/; Met  jour un paramtre ditable.; in	A3.L	^dbut ligne;	D2.W	rang (0..n);	D5.L	canal dbox; out	D7.W	erreur; mod	D7.WDBOXMAJ:	PUSHM.L	D2..D4,D6,A2..A4	CLR.W	D7		; D7 <-- ok	COMP.W	D2,#-1	JUMP,EQ EXIT$	LOAD.L	A2,(A6)+ODBPTE	; A2 <-- ^table dbox	MUL.WU	D2,#LDB	ADD.L	A2,D2	LOAD.W	D2,(A2)+ODBOFF	; D2 <-- offset variable	COMP.W	(A2)+ODBTYP,#DBTYPN	JUMP,EQ NUM$	COMP.W	(A2)+ODBTYP,#DBTYPA	JUMP,EQ ALPHA$	LOAD.W	D7,#ERSYNT	; D7 <-- erreur	JUMP	EXIT$NUM$:	LOAD.L	A4,A3	LOAD.W	D4,#-1	TEST.B	(A4)	JUMP',EQ NUM2$	CALL	GETANUM		; D4 <-- nombre	LOAD.W	D7,#ERSYNT	TEST.B	(A4)		; fin du nombre ?	JUMP,NE EXIT$		; non => EXIT$NUM2$:	LOAD.W	(A6)+(D2.W),D4	; mj. le nombre	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$ALPHA$:	LOAD.L	A4,#(A6)+(D2.W)	; A4 <-- ^chaneALPHA1$:	LOAD.B	(A4+),(A3+)	; mj. chane	JUMP,NE ALPHA1$	CLR.W	D7		; D7 <-- ok;	JUMP'	EXIT$EXIT$:	POPM.L	D2..D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; PUTANUM >;--------/; Met un nombre dcimal dans un buffer.; in	D4.L	nombre;	A4.L	^dans buffer; out	A4.L	^plus loin; mod	A4.LPUTANUM:	PUSHM.L	D2,D3,D4	LIB	?BINBCD		; D4 <-- nombre BCD	LOAD.W	D2,#8		; D2 <-- nb digits + flags10$:	RL.L	D4,#4		; D4 <-- pousse d'un digit	LOAD.B	D3,D4	AND.B	D3,#H'0F	; D3 <-- 0..9	JUMP',NE 40$		; si 1..9 => 40$	COMP.B	D2,#1		; dernier digit ?	JUMP',EQ 40$		; oui => 40$	TEST.L	D2:#10		; zro significatif ?	JUMP',BC 50$		; non => 50$40$:	ADD.B	D3,#'0		; D3 <-- '0..'9	LOAD.B	(A4+),D3	TSET.L	D2:#1050$:	DEC.B	D2	JUMP,NE	10$	POPM.L	D2,D3,D4	RET;--------\\; GETANUM >;--------/; Donne un nombre dcimal.; in	A4.L	^dans buffer; out	A4.L	^plus loin;	D4.L	nombre; mod	D4.L, A4.LGETANUM:	PUSHM.L	D2,D3	CLR.L	D4		; D4 <-- futur nombre10$:	CLR.L	D3	LOAD.B	D3,(A4+)	COMP.B	D3,#'0	JUMP',LO 50$	COMP.B	D3,#'9	JUMP',HI 50$	SUB.B	D3,#'0		; D3 <-- 0..9	SL.L	D4,#1	LOAD.L	D2,D4	SL.L	D4,#2	ADD.L	D4,D2		; D4 <-- pousse d'un digit (*10)	ADD.L	D4,D3		; D4 <-- ajoute nouveau digit	JUMP	10$50$:	DEC.L	A4		; D4 <-- ^terminateur	POPM.L	D2,D3	RET;--------\\; ERCALL  >;========/; Excute un appel systme en essayant de rsoudre qq problmes.; in	D0.L	code de l'appel (par exemple #FOS?OPEN);	+ selon appel; out	+ selon appel;	D7.W	erreur (ERKSTO si annule); mod	D7.WERCALL:	PUSHM.L	D1,D2	LOAD.W	D1,#DBOX_ERCALL	; D1 <-- numro de l'appel	LOAD.W	D2,#2^BDBEXTEND	; D2 <-- mode "tendu"	DBOX_	EXTEND		; appel DBOX_ERCALL ...	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET;--------\\; ZEROCR  >;========/; Remplace le terminateur <CR> par <0>.; Utile aprs LIB,?EDIT par exemple !; in	A3.L	^chane termine par <CR> ou <0>; out	A3.L	^chane termine par <0>; mod	-ZEROCR:	PUSH.L	A320$:	TEST.B	(A3+)	JUMP',EQ 90$	COMP.B	(A3)-1,#CR	JUMP,NE 20$	CLR.B	(A3)-1		; remplace le <CR> par <0>90$:	POP.L	A3	RET;----------\\; DBOXHLINE >;==========/; Trace une ligne horizontale dans une dbox.; in	D2.W	rang de l'objet; out	D3.L	position d'arrive; mod	D3.L, D7.WDBOXHLINE:	PUSHM.L	D2,D4	DBOX_	GETCO	CLR.W	D3	SWAP.W	D3	SUB.W	D3,#4	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	LOAD.W	D2,#SETDOT	LIB	?DRSEG	POPM.L	D2,D4	RET;--------\\; DBOXRSK >;========/; Refait les soft-keys.; in	A2.L	^table DBOX; out	-; mod	D7.WDBOXRSK:	PUSHM.L	D3,A3	LOAD.W	D3,(A2)+2	LOAD.L	A3,#(A2)+(D3.W)	LIB	?AFMENU		; refait les soft-keys	POPM.L	D3,A3	RET;--------\\; DOK...  >;========/DOKMGP:	LOAD.W	D3,#KEYMGP	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RETDOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RETDOKF2:	LOAD.W	D3,#F2	RETDOKF3:	LOAD.W	D3,#F3	RETDOKF4:	LOAD.W	D3,#F4	RETDOKF5:	LOAD.W	D3,#F5	RETDOKF6:	LOAD.W	D3,#F6	RETDOKF7:	LOAD.W	D3,#F7	RETDOKF8:	LOAD.W	D3,#F8	RETDOKF9:	LOAD.W	D3,#F9	RETDOKF10:	LOAD.W	D3,#F10	RETDOKF11:	LOAD.W	D3,#F11	RETDOKF12:	LOAD.W	D3,#F12	RETDOKF13:	LOAD.W	D3,#F13	RETDOKF14:	LOAD.W	D3,#F14	RETDOKF15:	LOAD.W	D3,#F15	RET	.END