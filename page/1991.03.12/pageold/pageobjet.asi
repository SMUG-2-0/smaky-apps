	.SBTTL	PAGEOBJET;********************;; TRAIT A MAIN LEVEE ;;********************;DRAWTM:	CALL	OPEWDO		; dessine dans la swdo	TEST.B	(A6)+OVUE+3:#BVUFIL-0 ; vue en fil de fer ?	JUMP',BS NOPEN$		; oui => NOPEN$	LOAD.W	D2,#SETDOT	LOAD.W	D1,(A6)+OSLPEN	; D1 <-- numro du pinceau	LOAD.W	D7,#DESS_USEPEN	PAGE_	DESS		; dfinit le bon pinceau avec traitillNOPEN$:	LOAD.L	A4,#(A6)+OBUTML	; A4 <-- ^buffer pour coordonnes	CLR.W	D1		; D1 <-- nb de coordonnes	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE END$	PUSH.L	(A6)+OWPOS	CLR.L	(A6)+OWPOS	LOAD.W	D7,#DET_POINTP	PAGE_	DET		; D3 <-- point o est la souris	POP.L	(A6)+OWPOS	TEST.W	D7	JUMP,NE END$	LOAD.L	(A4+),D3	; buffer <-- premier pointLOOP$:	CALL	_WAITMOVE	; attend dplacement ...	JUMP,NE END$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE LOOP$	PUSH.L	(A6)+OWPOS	CLR.L	(A6)+OWPOS	LOAD.W	D7,#DET_POINTP	PAGE_	DET		; D3 <-- point o est la souris	POP.L	(A6)+OWPOS	TEST.W	D7	JUMP,NE LOOP$	LOAD.L	(A4+),D3	; buffer <-- point suivant	LOAD.L	D4,D3	LOAD.L	D3,(A4)-8	SUB.W	D3,(A6)+OPPOS+2	SUB.W	D4,(A6)+OPPOS+2	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,(A6)+OPPOS+0	SUB.W	D4,(A6)+OPPOS+0	SWAP.W	D3	SWAP.W	D4	LOAD.W	D7,#DET_SCALEP	PAGE_	DET		; D3 <-- plus grand (si n:1)	EX.L	D3,D4	LOAD.W	D7,#DET_SCALEP	PAGE_	DET		; D4 <-- plus grand (si n:1)	EX.L	D4,D3	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LIB	?DRSEG		; trace un bout de trait  main leve	TSET.L	D2:#BNCTDOT	; D2 <-- plus de rz du traitill	INC.W	D1		; D1 <-- une coordonne de plus	COMP.W	D1,#(LBUTML/4)-2	JUMP,LO LOOP$END$:	CALL	CLOWDO		; fin du dessin dans la swdo	TEST.W	D1		; dessin qq chose ?	JUMP,EQ BIP		; non => BIP	COMP.W	D1,#(LBUTML/4)-2	JUMP,HS ERROR$	INC.W	D1		; D1 <-- compte le premier point	LOAD.W	D4,D1	MUL.WU	D4,#4	ADD.W	D4,#OOTMPTS	LOAD.W	D2,#ICOTM	CALL	CREEOBJET	; A4 <-- ^objet	JUMP',NE ERROR$	LOAD.W	(A4)+OOTMNBP,D1	LOAD.L	A3,#(A4)+OOTMPTS	LOAD.L	A2,#(A6)+OBUTML	DEC.W	D1XFER$:	LOAD.L	(A3+),(A2+)	DECJ.W,NMO D1,XFER$	LOAD.W	D7,#DET_INIT	PAGE_	DET		; mj. les paramtres de dtection	LOAD.L	D4,(A4)+OOFOND	TEST.L	D4:#BFDOBT	JUMP',BS REFAIT4$	TEST.L	D4:#BFDRTT	JUMP',BS REFAIT$	TEST.L	D4:#BFDRTO	JUMP',BS REFAIT$	TEST.L	D4:#BFDRBO	JUMP',BC REFAIT2$REFAIT$:	PUSH.L	(A4)+OOFOND	LOAD.L	(A4)+OOFOND,#2^BFDOBT	LOAD.W	D7,#DESS_CLEAR	PAGE_	DESS		; efface l'objet	POP.L	(A4)+OOFONDREFAIT2$:	LOAD.W	D7,#DESS_SET	PAGE_	DESS		; dessine l'objet dfinitif	JUMP	LOOPREFAIT4$:	TEST.B	(A6)+OVUE+3:#BVUFIL-0 ; vue en fil de fer ?	JUMP,BS REFAIT2$	; oui => REFAIT2$	JUMP	LOOPERROR$:	CLR.L	(A6)+OPLDIM	LOAD.W	D7,#DESS_OBJETS	PAGE_	DESS		; dessine les objets	JUMP	BIP;***************;;    DROITE     ;;***************;DRAWDR:	LOAD.W	D7,#DET_POINTP	PAGE_	DET		; D3 <-- point o est la souris	JUMP,NE BIP	LOAD.W	D4,#LGODR	LOAD.W	D2,#ICODR	CALL	CREEOBJET	; A4 <-- ^objet	JUMP,NE BIP	LOAD.L	(A4)+OOFOND,#2^BFDOBT	LOAD.L	(A4)+OODRPOS,D3;	CLR.L	(A4)+OODRDIM	LOAD.L	(A4)+OODRTYP,(A6)+ODRTYP	JUMP	DRAWNORMAL;***************;;    FLECHE     ;;***************;DRAWFL:	LOAD.W	D7,#DET_POINTP	PAGE_	DET		; D3 <-- point o est la souris	JUMP,NE BIP	LOAD.W	D4,#LGOFL	LOAD.W	D2,#ICOFL	CALL	CREEOBJET	; A4 <-- ^objet	JUMP,NE BIP	LOAD.L	(A4)+OOFLPOS,D3;	CLR.L	(A4)+OOFLDIM	LOAD.L	(A4)+OOFLTYP,(A6)+OFLTYP	JUMP	DRAWNORMAL;*********************;;   RECTANGLE DROIT   ;;*********************;DRAWRD:	LOAD.W	D7,#DET_POINTP	PAGE_	DET		; D3 <-- point o est la souris	JUMP,NE BIP	LOAD.W	D4,#LGORD	LOAD.W	D2,#ICORD	CALL	CREEOBJET	; A4 <-- ^objet	JUMP,NE BIP	LOAD.L	(A4)+OORDPOS,D3;	CLR.L	(A4)+OORDDIM	LOAD.L	(A4)+OORDTYP,(A6)+ORDTYP;	CLR.W	(A4)+OORDRAY	JUMP	DRAWNORMAL;*********************;;  RECTANGLE ARRONDI  ;;*********************;DRAWRA:	LOAD.W	D7,#DET_POINTP	PAGE_	DET		; D3 <-- point o est la souris	JUMP,NE BIP	LOAD.W	D4,#LGORA	LOAD.W	D2,#ICORA	CALL	CREEOBJET	; A4 <-- ^objet	JUMP,NE BIP	LOAD.L	(A4)+OORAPOS,D3;	CLR.L	(A4)+OORADIM	LOAD.L	(A4)+OORATYP,(A6)+ORATYP	LOAD.W	(A4)+OORARAY,(A6)+ORARAY	JUMP	DRAWNORMAL;***************;;   POLYGONE    ;;***************;DRAWPO:	LOAD.W	D7,#DET_POINTP	PAGE_	DET		; D3 <-- point o est la souris	JUMP,NE BIP	LOAD.W	D4,#LGOPO	LOAD.W	D2,#ICOPO	CALL	CREEOBJET	; A4 <-- ^objet	JUMP,NE BIP	LOAD.L	(A4)+OOPOPOS,D3;	CLR.L	(A4)+OOPODIM	LOAD.L	(A4)+OOPOTYP,(A6)+OPOTYP	JUMP	DRAWNORMAL;***************;;    CERCLE     ;;***************;DRAWCE:	LOAD.W	D7,#DET_POINTP	PAGE_	DET		; D3 <-- point o est la souris	JUMP,NE BIP	LOAD.W	D4,#LGOCE	LOAD.W	D2,#ICOCE	CALL	CREEOBJET	; A4 <-- ^objet	JUMP,NE BIP	LOAD.L	(A4)+OOCEPOS,D3;	CLR.L	(A4)+OOCEDIM	LOAD.L	(A4)+OOCETYP,(A6)+OCETYP	JUMP	DRAWNORMAL;***************;;    ELLIPSE    ;;***************;DRAWEL:	LOAD.W	D7,#DET_POINTP	PAGE_	DET		; D3 <-- point o est la souris	JUMP,NE BIP	LOAD.W	D4,#LGOEL	LOAD.W	D2,#ICOEL	CALL	CREEOBJET	; A4 <-- ^objet	JUMP,NE BIP	LOAD.L	(A4)+OOELPOS,D3;	CLR.L	(A4)+OOELDIM	LOAD.L	(A4)+OOELTYP,(A6)+OELTYP	JUMP	DRAWNORMAL;***************;;      ARC      ;;***************;DRAWAR:	LOAD.W	D7,#DET_POINTP	PAGE_	DET		; D3 <-- point o est la souris	JUMP,NE BIP	LOAD.W	D4,#LGOAR	LOAD.W	D2,#ICOAR	CALL	CREEOBJET	; A4 <-- ^objet	JUMP,NE BIP	LOAD.L	(A4)+OOARPOS,D3;	CLR.L	(A4)+OOARDIM	LOAD.L	(A4)+OOARTYP,(A6)+OARTYP	LOAD.W	(A4)+OOARANG,(A6)+OARANG	JUMP	DRAWNORMAL;***************;;    TEXTE      ;;***************;DRAWTX:	LOAD.W	D7,#DET_POINTP	PAGE_	DET		; D3 <-- point o est la souris	JUMP,NE BIP	LOAD.W	D4,#LGOTX	LOAD.W	D2,#ICOTX	CALL	CREEOBJET	; A4 <-- ^objet	JUMP,NE BIP	LOAD.L	(A4)+OOTXPOS,D3;	CLR.L	(A4)+OOTXDIM	LOAD.L	(A4)+OOTXJUS,(A6)+OTXJUS	LOAD.L	(A4)+OOTXITL,(A6)+OTXITL	LOAD.L	(A4)+OOTXITC,(A6)+OTXITC	JUMP	DRAWNORMALDRAWNORMAL:	LOAD.W	D2,#INVDOT!2^BMDCRE ; D2 <-- mode provisoire + crationLOOP$:	CALL	_WAITMOVE	; attend dplacement ...	JUMP',NE END$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE LOOP$	LOAD.W	D7,#DET_POINTP	PAGE_	DET		; D3 <-- point o est la souris	JUMP,NE LOOP$	SUB.W	D3,(A4)+OODRPOS+2	SWAP.W	D3	SUB.W	D3,(A4)+OODRPOS+0	SWAP.W	D3	COMP.L	D3,(A4)+OODRDIM	JUMP,EQ LOOP$	LOAD.W	D7,#DESS_OBJET	PAGE_	DESS		; efface l'ancien l'objet	LOAD.L	(A4)+OODRDIM,D3	LOAD.W	D7,#DESS_OBJET	PAGE_	DESS		; dessine le nouvel objet	JUMP	LOOP$END$:	TEST.L	(A4)+OODRDIM	; objet existe ?	JUMP',EQ KILL$		; non => KILL$	LOAD.W	D7,#DESS_OBJET	PAGE_	DESS		; efface l'objet provisoire	LOAD.W	D7,#DET_INIT	PAGE_	DET		; mj. les paramtres de dtection	COMP.W	(A4)+OOOBJ,#ICOTX	JUMP,EQ POIGNEE2	LOAD.W	D7,#DESS_SET	PAGE_	DESS		; dessine l'objet dfinitif	JUMP	LOOPKILL$:	LOAD.W	D7,#BASE_REMOVE	PAGE_	BASE		; supprime l'objet	JUMP	LOOP;***************;;    COURBE     ;;***************;DRAWSP:	LOAD.B	(A6)+OXICO,#NIVSPLINE ; dbut du dessin d'une courbe	CALL	DESICONE	; dessine les icnes de gauche	CALL	MAJICONE	; mj. les icnes variables	CALL	_AFMENU		; refait les soft-keys	LOAD.L	A1,#(A6)+OSPLPT	LOAD.L	(A1)+0,#-1	; OSPLPT <-- termine la table des points	LOAD.L	(A1)+4,#-1	LOAD.L	(A1)+8,#-1	CLR.W	D0	JUMP	CCLIC$		; met dj le premier pointCLOOP$:	CALL	_SCMO		; remet la souris	CALL	FULLGREYICONE	; (d)grise qq icnes	LOAD.B	D3,#ICOSPLADD	CALL	_SELMO		; utilise le lutin flche	CALL	_WAITMOVE	; attend dplacement souris ...	COMP.W	D3,#KEYMGR	JUMP,EQ CLOOP$	COMP.W	D3,#KEYMMR	; bouton relch ?	JUMP,EQ CLOOP$		; oui => CLOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ CLOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CCLIC$	COMP.W	D3,#KEYMMP	JUMP,EQ CMENU$	COMP.W	D3,#KEYMDP	JUMP,EQ CCLIC$	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,EQ CMOVE$	COMP.W	D3,#F0	JUMP,EQ MODIF2$	COMP.W	D3,#F0+SHIFT	JUMP,EQ MODIF2$	COMP.W	D3,#END	JUMP,EQ MODIF2$	COMP.W	D3,#ENTER	JUMP,EQ MODIF2$	COMP.W	D3,#UNDO	; annule ?	JUMP,EQ ERR2$CBIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; signal que a va plus !	JUMP	CLOOP$CMOVE$:				; souris dplace =>	CALL	SPLAFXY		; affiche X= et Y= dans les informations	JUMP	CLOOP$CMENU$:	CALL	MENUICONE	; menu des icnes de gauche ...	JUMP,NE CBIP$	TEST.B	D3	JUMP,EQ CLOOP$	JUMP	CICONE$CCLIC$:				; ajoute un point =>	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE CBIP$	CALL	MOVGICONE	; souris dans les icnes ?	JUMP',EQ CICONE$	; oui => CICONE$	PUSH.L	A1	LOAD.L	A1,#R16"ASCINV$	CALL	DOMASCENSEUR	; agit dans ascenseurs selon souris	POPM.L	A1	JUMP,EQ CLOOP$	LOAD.W	D7,#DET_POINTP	PAGE_	DET		; D3 <-- point o est la souris	JUMP,NE CBIP$	LOAD.L	D4,D3	COMP.W	D0,#MAXSPLINE-2	; encore de la place ?	JUMP,HS CBIP$		; non => CBIP$	PUSH.L	A1	CALL	SPLDET		; est-on sur un point dj mis ?	POP.L	A1	JUMP,EQ MODIF1$		; oui => MODIF1$	LOAD.L	(A1+),D4	; OSPLPT <-- un point	LOAD.L	(A1),#-1	; OSPLPT <-- termine la table des points	INC.W	D0		; D0 <-- numro de la poigne suivante	LOAD.W	D2,#SETDOT	CALL	SPLINVP		; montre le point	JUMP	CLOOP$CICONE$:	CLR.W	D4	COMP.B	D3,#ICOSPLINEO	JUMP',EQ CMODE$	INC.W	D4	COMP.B	D3,#ICOSPLINEF	JUMP',EQ CMODE$	COMP.B	D3,#ICOFLAGS	JUMP,EQ CFLAGS$	COMP.B	D3,#ICODACCORD	JUMP',EQ MODIF2$	COMP.B	D3,#ICOANNULE	JUMP,EQ ERR2$	JUMP	CBIP$CMODE$:	COMP.B	D4,(A6)+OSPLOF	JUMP,EQ CLOOP$	PUSH.W	D3	LOAD.B	D3,#ICOSPLINEO	TEST.B	(A6)+OSPLOF	JUMP',EQ CMODE2$	LOAD.B	D3,#ICOSPLINEFCMODE2$:	CALL	INVICONE	; teint l'ancien mode	POP.W	D3	LOAD.B	(A6)+OSPLOF,D4	CALL	INVICONE	; allume le nouveau mode	JUMP	CLOOP$CFLAGS$:;;?	CALL	DBOXFLAGS	; change le mode ...;;?	JUMP,NE CBIP$	JUMP	CLOOP$MODIF1$:	LOAD.B	(A6)+OSPLOF,#1MODIF2$:	CALL	SPLOPEN		; A3 <-- ^table des droites, D6 <-- canal	JUMP',NE ERR2$	CALL	SPLMI		; dessine la spline provisoire	LOAD.L	A4,#0		; A4 <-- insre  la fin (devant)	CALL	SPLINSOBJ	; A4 <-- cre l'objet spline	JUMP',NE ERR1$	TSET.B	(A4)+OOFLG:#BOOSEL	CALL	SPLMI		; efface le spline provisoire	LOAD.W	D2,#CLRDOT	CALL	SPLINVC		; efface tous les points montrs	CALL	SPLCLOSE	; ferme la table des droites	JUMP	POIGNEE2ERR1$:				; erreur grve =>	PUSH.W	D7	CALL	SPLMI		; efface le spline provisoire	CALL	SPLCLOSE	; ferme la table des droites	POP.W	D7ERR2$:	PUSH.W	D7	LOAD.W	D2,#CLRDOT	CALL	SPLINVC		; efface tous les points montrs	CLR.B	(A6)+OXICO	; fin de la courbe	CALL	REMICONE	; remet les icnes  gauche	CALL	_AFMENU		; refait les soft-keys	POP.W	D7	JUMP,EQ LOOP	JUMP	ERRORASCINV$:	PUSH.W	D2	INC.B	(A6)+OPOICNT	LOAD.W	D2,#CLRDOT	TEST.B	(A6)+OPOICNT:#0	JUMP',BS 20$	LOAD.W	D2,#SETDOT20$:	CALL	SPLINVC		; allume/teint tous les points montrs	POP.W	D2	RET;****************;;  LIGNE BRISEE  ;;****************;DRAWLB:	LOAD.B	(A6)+OXICO,#NIVLINEB ; dbut du dessin d'une ligne brise	CALL	DESICONE	; dessine les icnes de gauche	CALL	MAJICONE	; mj. les icnes variables	CALL	_AFMENU		; refait les soft-keys	LOAD.L	A1,#(A6)+OSPLPT	LOAD.L	(A1)+0,#-1	; OSPLPT <-- termine la table des points	LOAD.L	(A1)+4,#-1	LOAD.L	(A1)+8,#-1	CLR.W	D0	JUMP	CCLIC$		; met dj le premier pointCLOOP$:	CALL	_SCMO		; remet la souris	CALL	FULLGREYICONE	; (d)grise qq icnes	LOAD.B	D3,#ICOSPLADD	CALL	_SELMO		; utilise le lutin flche	CALL	_WAITMOVE	; attend dplacement souris ...	COMP.W	D3,#KEYMGR	JUMP,EQ CLOOP$	COMP.W	D3,#KEYMMR	; bouton relch ?	JUMP,EQ CLOOP$		; oui => CLOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ CLOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CCLIC$	COMP.W	D3,#KEYMMP	JUMP,EQ CMENU$	COMP.W	D3,#KEYMDP	JUMP,EQ CCLIC$	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,EQ CMOVE$	COMP.W	D3,#F0	JUMP,EQ MODIF2$	COMP.W	D3,#F0+SHIFT	JUMP,EQ MODIF2$	COMP.W	D3,#END	JUMP,EQ MODIF2$	COMP.W	D3,#ENTER	JUMP,EQ MODIF2$	COMP.W	D3,#UNDO	; annule ?	JUMP,EQ ERR2$CBIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; signal que a va plus !	JUMP	CLOOP$CMOVE$:				; souris dplace =>	CALL	SPLAFXY		; affiche X= et Y= dans les informations	JUMP	CLOOP$CMENU$:	CALL	MENUICONE	; menu des icnes de gauche ...	JUMP,NE CBIP$	TEST.B	D3	JUMP,EQ CLOOP$	JUMP	CICONE$CCLIC$:				; ajoute un point =>	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE CBIP$	CALL	MOVGICONE	; souris dans les icnes ?	JUMP',EQ CICONE$	; oui => CICONE$	PUSH.L	A1	LOAD.L	A1,#R16"ASCINV$	CALL	DOMASCENSEUR	; agit dans ascenseurs selon souris	POPM.L	A1	JUMP,EQ CLOOP$	LOAD.W	D7,#DET_POINTP	PAGE_	DET		; D3 <-- point o est la souris	JUMP,NE CBIP$	LOAD.L	D4,D3	COMP.W	D0,#MAXLINEB-2	; encore de la place ?	JUMP,HS CBIP$		; non => CBIP$	PUSH.L	A1	CALL	SPLDET		; est-on sur un point dj mis ?	POP.L	A1	JUMP,EQ MODIF1$		; oui => MODIF1$	INC.W	D0		; D0 <-- numro de la poigne suivante	LOAD.W	D2,#CLRDOT	CALL	SPLINVC		; efface tous les points montrs	CALL	LBINVC		; efface la ligne brise	LOAD.L	(A1+),D4	; OSPLPT <-- un point	LOAD.L	(A1),#-1	; OSPLPT <-- termine la table des points	CALL	LBINVC		; dessine la ligne brise	LOAD.W	D2,#SETDOT	CALL	SPLINVC		; dessine tous les points montrs	JUMP	CLOOP$CICONE$:	CLR.W	D4	COMP.B	D3,#ICOLINEBO	JUMP',EQ CMODE$	INC.W	D4	COMP.B	D3,#ICOLINEBF	JUMP',EQ CMODE$	COMP.B	D3,#ICOFLAGS	JUMP,EQ CFLAGS$	COMP.B	D3,#ICODACCORD	JUMP',EQ MODIF2$	COMP.B	D3,#ICOANNULE	JUMP,EQ ERR2$	JUMP	CBIP$CMODE$:	COMP.B	D4,(A6)+OLIBOF	JUMP,EQ CLOOP$	PUSH.W	D3	LOAD.B	D3,#ICOLINEBO	TEST.B	(A6)+OLIBOF	JUMP',EQ CMODE2$	LOAD.B	D3,#ICOLINEBFCMODE2$:	CALL	INVICONE	; teint l'ancien mode	POP.W	D3	LOAD.B	(A6)+OLIBOF,D4	CALL	INVICONE	; allume le nouveau mode	JUMP	CLOOP$CFLAGS$:;;?	CALL	DBOXFLAGS	; change le mode ...;;?	JUMP,NE CBIP$	JUMP	CLOOP$MODIF1$:	LOAD.B	(A6)+OLIBOF,#1MODIF2$:	LOAD.L	A4,#0		; A4 <-- insre  la fin (devant)	CALL	LBINSOBJ	; A4 <-- cre l'objet ligne brise	JUMP',NE ERR2$	TSET.B	(A4)+OOFLG:#BOOSEL	LOAD.W	D2,#CLRDOT	CALL	SPLINVC		; efface tous les points montrs	CALL	LBINVC		; efface la ligne brise	JUMP	POIGNEE2ERR2$:	PUSH.W	D7	LOAD.W	D2,#CLRDOT	CALL	SPLINVC		; efface tous les points montrs	CALL	LBINVC		; efface la ligne brise	CLR.B	(A6)+OXICO	; fin de la courbe	CALL	REMICONE	; remet les icnes  gauche	CALL	_AFMENU		; refait les soft-keys	POP.W	D7	JUMP,EQ LOOP	JUMP	ERRORASCINV$:	PUSH.W	D2	INC.B	(A6)+OPOICNT	TEST.B	(A6)+OPOICNT:#0	JUMP',BS 40$	CALL	LBINVC		; dessine la ligne brise	LOAD.W	D2,#SETDOT	CALL	SPLINVC		; allume tous les points montrs	JUMP'	90$40$:	LOAD.W	D2,#CLRDOT	CALL	SPLINVC		; teint tous les points montrs	CALL	LBINVC		; efface la ligne brise90$:	POP.W	D2	RET;***************;;     LOUPE     ;;***************;LOUPE:	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP	LOAD.W	D7,#DET_POINTP	PAGE_	DET		; D3 <-- point o est la souris	JUMP,NE BIP	LOAD.L	D4,D3	LIB	?GETSHIFT	; D3 <-- touches super-shift	TEST.L	D3:#BCURSOR	JUMP',BS 50$				; loupe (+) =>	LOAD.W	D3,(A6)+OSCALE	JUMP',EQ 34$	JUMP',NS 30$	SL.W	D3,#1	JUMP'	70$30$:	ASR.W	D3,#1	COMP.W	D3,#-1	JUMP',NE 70$	CLR.W	D3	JUMP'	70$34$:	LOAD.W	D3,#2	JUMP'	70$50$:				; loupe (-) =>	LOAD.W	D3,(A6)+OSCALE	JUMP',EQ 64$	JUMP',NS 60$	SR.W	D3,#1	COMP.W	D3,#+1	JUMP',NE 70$	CLR.W	D3	JUMP'	70$60$:	ASL.W	D3,#1	JUMP'	70$64$:	LOAD.W	D3,#-270$:	LOAD.W	(A6)+OSCALE,D3	CALL	DESINFSC	; affiche l'chelle	LOAD.W	D7,#DET_INITSC	PAGE_	DET		; init selon nouvelle chelle	CLR.L	(A6)+OPLDIM	LOAD.W	D7,#DESS_OBJETS	PAGE_	DESS		; dessine les objets	CALL	MAJCADRE	; mj le cadre (rgles et ascenseurs)	JUMP	LOOP;***************;;      MAIN     ;;***************;MAIN:	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP	LOAD.L	D0,D4		; D0 <-- position initiale	LOAD.W	D4,(A6)+OWDIM+2	ADD.W	D4,#16-1	SR.W	D4,#4	SL.W	D4,#1	MUL.WU	D4,(A6)+OWDIM+0	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- demande mmoire pour matrice	JUMP,NE BIP	LOAD.L	A5,A4		; A5 <-- ^mmoire30$:	CALL	MAINSAVE	; matrice <-- contenu de l'cran32$:	CALL	_SCMO		; remet la souris	CALL	_WAITMOVE	; attend dplacement ...	JUMP',NE 50$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE 32$	LOAD.L	D3,D4	SUB.W	D4,D0	SWAP.W	D4	SWAP.W	D0	SUB.W	D4,D0	SWAP.W	D4	SWAP.W	D0	CALL	MAINMAJ		; met  jour l'cran	LOAD.L	D0,D3	JUMP	30$50$:	LOAD.L	A4,A5	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la matrice	CALL	MAJCADRE	; mj le cadre (rgles et ascenseurs)	JUMP	LOOP;--------\\; MAINMAJ >;--------/; Met  jour l'cran aprs avoir boug la main.; in	D4.L	+/- dplacement (dy;dx);	A5.L	^matrice; out	-; mod	D7.WMAINMAJ:	PUSHM.L	D0..D6,A1..A4	LOAD.L	D3,D4	COMP.W	D7,#DET_SCALEP	PAGE_	DET		; D3 <-- plus grand (si n:1)	LOAD.L	D4,(A6)+OPPOS	SUB.W	D4,D3	JUMP',NC 10$	CLR.W	D410$:	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	JUMP',NC 12$	CLR.W	D412$:;	SWAP.W	D3	SWAP.W	D4	LOAD.L	D3,(A6)+OPPOS	LOAD.L	(A6)+OPPOS,D4	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	COMP.W	D7,#DET_SCALEN	PAGE_	DET		; D3 <-- plus petit (si n:1)	LOAD.L	D0,D3	LOAD.L	D4,D3	CLR.L	D3		; D3 <-- position source	LOAD.L	D2,(A6)+OWDIM	; D2 <-- dimensions	TEST.W	D4	JUMP',NS 22$	SUB.W	D2,D4	JUMP'	24$22$:	NEG.W	D4	SUB.W	D2,D4	LOAD.W	D3,D4	CLR.W	D424$:	ADD.W	D4,(A6)+OWPOS+2	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	TEST.W	D4	JUMP',NS 26$	SUB.W	D2,D4	JUMP'	28$26$:	NEG.W	D4	SUB.W	D2,D4	LOAD.W	D3,D4	CLR.W	D428$:	ADD.W	D4,(A6)+OWPOS+0	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	CALL	_CCMO		; enlve la souris	LOAD.L	A3,A5		; A3 <-- ^source	LOAD.W	D5,(A6)+OWDIM+2	ADD.W	D5,#16-1	SR.W	D5,#4	SL.W	D5,#1		; D5 <-- Iy source	LOAD.L	A4,#0		; A4 <-- destination dans l'cran	LOAD.W	D1,#LOADDOT	; D1 <-- mode	LOAD.L	A2,A0	LOAD.L	A1,(A6)+ORASTER	CALL	(A1)		; cran <-- matrice	LOAD.W	D4,D0	TEST.W	D4	JUMP,EQ 48$	JUMP,NS 40$	PUSH.L	(A6)+OWPOS	PUSH.L	(A6)+OWDIM	PUSH.L	(A6)+OPPOS	PUSH.L	(A6)+OSDIM	LOAD.W	(A6)+OWDIM+2,D4	CLR.L	(A6)+OPLDIM	LOAD.W	D7,#DESS_OBJETS	PAGE_	DESS		; dessine les objets	POP.L	(A6)+OSDIM	POP.L	(A6)+OPPOS	POP.L	(A6)+OWDIM	POP.L	(A6)+OWPOS	JUMP	48$40$:	PUSH.L	(A6)+OWPOS	PUSH.L	(A6)+OWDIM	PUSH.L	(A6)+OPPOS	PUSH.L	(A6)+OSDIM	NEG.W	D4	LOAD.W	D3,(A6)+OWPOS+2	ADD.W	D3,(A6)+OWDIM+2	SUB.W	D3,D4	LOAD.W	(A6)+OWPOS+2,D3	LOAD.W	(A6)+OWDIM+2,D4	LOAD.W	D3,D4	COMP.W	D7,#DET_SCALEP	PAGE_	DET		; D3 <-- plus grand (si n:1)	LOAD.W	D4,D3	LOAD.W	D3,(A6)+OPPOS+2	ADD.W	D3,(A6)+OSDIM+2	SUB.W	D3,D4	LOAD.W	(A6)+OPPOS+2,D3	LOAD.W	(A6)+OSDIM+2,D4	CLR.L	(A6)+OPLDIM	LOAD.W	D7,#DESS_OBJETS	PAGE_	DESS		; dessine les objets	POP.L	(A6)+OSDIM	POP.L	(A6)+OPPOS	POP.L	(A6)+OWDIM	POP.L	(A6)+OWPOS48$:	LOAD.L	D4,D0	SWAP.W	D4	TEST.W	D4	JUMP,EQ 58$	JUMP,NS 50$	PUSH.L	(A6)+OWPOS	PUSH.L	(A6)+OWDIM	PUSH.L	(A6)+OPPOS	PUSH.L	(A6)+OSDIM	LOAD.W	(A6)+OWDIM+0,D4	CLR.L	(A6)+OPLDIM	LOAD.W	D7,#DESS_OBJETS	PAGE_	DESS		; dessine les objets	POP.L	(A6)+OSDIM	POP.L	(A6)+OPPOS	POP.L	(A6)+OWDIM	POP.L	(A6)+OWPOS	JUMP	58$50$:	PUSH.L	(A6)+OWPOS	PUSH.L	(A6)+OWDIM	PUSH.L	(A6)+OPPOS	PUSH.L	(A6)+OSDIM	NEG.W	D4	LOAD.W	D3,(A6)+OWPOS+0	ADD.W	D3,(A6)+OWDIM+0	SUB.W	D3,D4	LOAD.W	(A6)+OWPOS+0,D3	LOAD.W	(A6)+OWDIM+0,D4	LOAD.W	D3,D4	COMP.W	D7,#DET_SCALEP	PAGE_	DET		; D3 <-- plus grand (si n:1)	LOAD.W	D4,D3	LOAD.W	D3,(A6)+OPPOS+0	ADD.W	D3,(A6)+OSDIM+0	SUB.W	D3,D4	LOAD.W	(A6)+OPPOS+0,D3	LOAD.W	(A6)+OSDIM+0,D4	CLR.L	(A6)+OPLDIM	LOAD.W	D7,#DESS_OBJETS	PAGE_	DESS		; dessine les objets	POP.L	(A6)+OSDIM	POP.L	(A6)+OPPOS	POP.L	(A6)+OWDIM	POP.L	(A6)+OWPOS58$:	POPM.L	D0..D6,A1..A4	RET;---------\\; MAINSAVE >;---------/; Sauve le contenu de la fentre dans la matrice.; in	A5.L	^matrice; out	-; mod	D7.WMAINSAVE:	PUSHM.L	D1..D6,A1..A4	CALL	_CCMO		; enlve la souris	LOAD.L	D3,(A6)+OWPOS	; D3 <-- position source	LOAD.L	A3,#0		; A3 <-- source dans l'cran	CLR.L	D4		; D4 <-- position destination	LOAD.L	A4,A5		; A4 <-- ^destination	LOAD.W	D6,(A6)+OWDIM+2	ADD.W	D6,#16-1	SR.W	D6,#4	SL.W	D6,#1		; D6 <-- Iy destination	LOAD.L	D2,(A6)+OWDIM	; D2 <-- dimensions	LOAD.W	D1,#LOADDOT	; D1 <-- mode	LOAD.L	A2,A0	LOAD.L	A1,(A6)+ORASTER	CALL	(A1)		; matrice <-- contenu de l'cran	POPM.L	D1..D6,A1..A4	RET;----------\\; CREEOBJET >;==========/; Cre un objet selon le crayon/pinceau et la trame slectionne.; in	D2.W	type de l'objet (ICOxx);	D4.W	longueur de l'objet; out	A4.L	^objet;	D7.W	erreur; mod	D7.W, A4.LCREEOBJET:	PUSHM.L	D2..D4	LOAD.W	D3,D2	CLR.W	D2		; D2 <-- mode normal	LOAD.W	D7,#BASE_INSERT	PAGE_	BASE		; A4 <-- ^objet	JUMP',NE 90$	LOAD.W	(A4)+OOPEN,(A6)+OSLPEN	LOAD.W	(A4)+OOTRAM,(A6)+OSLTRA	LOAD.L	(A4)+OOFOND,(A6)+OMFOND90$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; SPLINSOBJ >;==========/; Cre un objet spline, d'aprs la table des droites.; in	A3.L		^table des droites;	A4.L		^objet avant lequel insrer/nil;	(A6)+OSPLPT	table des points;	(A6)+OSPLNC.W	nb de points calculs;	(A6)+OOUTIL.B	outil;	(A6)+OSLPEN.W	numro du pinceau;	(A6)+OSLTRA.W	numro de la trame;	(A6)+OMFOND.L	mode pour le fond;	(A6)+OSPLOF.B	mode ouvert/ferm; out	A4.L		^objet spline;	D7.W		erreur; mod	D7.W, A4.LSPLINSOBJ:	PUSHM.L	D1..D5,A2,A3	LOAD.W	D4,(A6)+OSPLNC	INC.W	D4	MUL.WU	D4,#4	ADD.W	D4,#OOSPPTC	LOAD.W	D3,#ICOSP	LOAD.W	D2,#1		; D2 <-- mode avec A4.L	LOAD.W	D7,#BASE_INSERT	PAGE_	BASE		; A4 <-- ^objet	JUMP,NE 90$	LOAD.W	(A4)+OOPEN,(A6)+OSLPEN	LOAD.W	(A4)+OOTRAM,(A6)+OSLTRA	LOAD.L	(A4)+OOFOND,(A6)+OMFOND	LOAD.B	(A4)+OOSPMOF,(A6)+OSPLOF	LOAD.W	D4,(A6)+OSPLNC	INC.W	D4	LOAD.W	(A4)+OOSPNBC,D4	LOAD.L	A2,#(A4)+OOSPPTC ; A2 <-- ^o mettre les points calculs	LOAD.L	D3,(A3+)	; D3 <-- 1er point	LOAD.L	(A2+),D3	LOAD.L	D4,(A3+)	; D4 <-- 2me point	JUMP'	36$30$:	LOAD.L	D5,(A3+)	; D5 <-- 3me point	COMP.L	D5,#-1	JUMP',EQ 38$	PUSHM.L	D3,D4	LOAD.L	D3,D4	LOAD.L	D4,D5	CALL	SPLPENTE	; D2 <-- nouvelle pente	POPM.L	D3,D4	COMP.W	D2,D1		; toujours la mme pente ?	JUMP',NE 34$		; non => 34$	LOAD.L	D4,D5		; D4 <-- avance le 2me point	JUMP	30$34$:	LOAD.L	(A2+),D4	LOAD.L	D3,D4		; D3 <-- 1er point	LOAD.L	D4,D5		; D4 <-- 2me point36$:	CALL	SPLPENTE	; D2 <-- nouvelle pente	LOAD.W	D1,D2		; D1 <-- pente de dpart	JUMP	30$38$:	LOAD.L	(A2+),D4	LOAD.L	A3,#(A6)+OSPLPT	; A3 <-- ^table des points	LOAD.L	A2,#(A4)+OOSPPTF ; A2 <-- ^o mettre les points fixes	CLR.W	(A4)+OOSPNBF40$:	LOAD.L	D4,(A3+)	COMP.L	D4,#-1	JUMP',EQ 44$	LOAD.L	(A2+),D4	INC.W	(A4)+OOSPNBF	JUMP	40$44$:	LOAD.W	D7,#DET_INITQ	PAGE_	DET		; mj. les paramtres de dtection	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D5,A2,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; LBINSOBJ  >;==========/; Cre un objet ligne brise, d'aprs la table des droites.; in	A3.L		^table des droites;	A4.L		^objet avant lequel insrer/nil;	(A6)+OSPLPT	table des points;	(A6)+OOUTIL.B	outil;	(A6)+OSLPEN.W	numro du pinceau;	(A6)+OSLTRA.W	numro de la trame;	(A6)+OMFOND.L	mode pour le fond;	(A6)+OLIBOF.B	mode ouvert/ferm; out	A4.L		^objet spline;	D7.W		erreur; mod	D7.W, A4.LLBINSOBJ:	PUSHM.L	D1..D5,A2,A3	LOAD.L	A3,#(A6)+OSPLPT	LOAD.W	D4,#-110$:	INC.W	D4		; D4 <-- nb de points	COMP.L	(A3+),#-1	JUMP,NE 10$	MUL.WU	D4,#4	ADD.W	D4,#OOLBPTS	LOAD.W	D3,#ICOLB	LOAD.W	D2,#1		; D2 <-- mode avec A4.L	LOAD.W	D7,#BASE_INSERT	PAGE_	BASE		; A4 <-- ^objet	JUMP,NE 90$	LOAD.W	(A4)+OOPEN,(A6)+OSLPEN	LOAD.W	(A4)+OOTRAM,(A6)+OSLTRA	LOAD.L	(A4)+OOFOND,(A6)+OMFOND	LOAD.B	(A4)+OOLBMOF,(A6)+OLIBOF	LOAD.L	A3,#(A6)+OSPLPT	; A3 <-- ^table des points	LOAD.L	A2,#(A4)+OOLBPTS ; A2 <-- ^o mettre les points	CLR.W	(A4)+OOLBNBP40$:	LOAD.L	D4,(A3+)	COMP.L	D4,#-1	JUMP',EQ 44$	LOAD.L	(A2+),D4	INC.W	(A4)+OOLBNBP	JUMP	40$44$:	LOAD.W	D7,#DET_INITQ	PAGE_	DET		; mj. les paramtres de dtection	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D5,A2,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; SPLOPEN >;========/; Calcul les segments de droites pour suivre le spline.; in	(A6)+OSPLPT	table des points; out	A3.L		^table des droites;	D6.L		canal spline;	D7.W		erreur; mod	D6.L, D7.W, A3.LSPLOPEN:	PUSHM.L	D3,A1,A4	TEST.B	(A6)+OSPLOF	; spline ouvert ?	JUMP',NE 30$				; spline ouvert =>	CLR.W	D7		; D7 <-- ok	CLR.L	D6		; D6 <-- "canal" impossible	LOAD.L	A4,#(A6)+OSPLPT	; A4 <-- ^table des points	COMP.L	(A4)+8,#-1	; seulement 2 points ?	JUMP',EQ 80$		; oui => 80$	JUMP'	40$30$:				; spline ferm =>	LOAD.L	A1,#(A6)+OSPLPT	; A1 <-- ^table des points35$:	COMP.L	(A1+),#-1	JUMP,NE	35$	LOAD.L	(A1)-4,(A6)+OSPLPT ; ferme la boucle	LOAD.L	(A1)+0,#-1	; et remet le terminateur40$:	LOAD.L	A3,#(A6)+OSPLPT	; A3 <-- ^table des points	LOAD.W	D3,#8		; D3 <-- prend un point sur huit !	SPLINE_	OPEN		; A4 <-- ^points, D6 <-- canal	TEST.B	(A6)+OSPLOF	; spline ouvert ?	JUMP',EQ 80$		; oui => 80$	LOAD.L	(A1)-4,#-1	; non => r-ouvre la boucle80$:	LOAD.L	A3,A4		; A3 <-- ^table des droites	POPM.L	D3,A1,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; SPLMI   >;========/; Montre les segments de droites pour suivre le spline.; in	A3.L		^table des droites; out	(A6)+OSPLNC.W	nb de points calculs;	D7.W		erreur; mod	D7.WSPLMI:	PUSHM.L	D1..D5,A3	CALL	OPEWDO		; dessine dans la swdo	CLR.W	(A6)+OSPLNC	LOAD.W	D7,#ERDIOUT	; D7 <-- erreur (pas assez de points)	LOAD.L	D4,(A3+)	COMP.L	D4,#-1	JUMP,EQ 90$	LOAD.L	D3,D4		; D3 <-- 1er point	LOAD.L	D4,(A3+)	COMP.L	D4,#-1	JUMP,EQ 90$	JUMP'	50$30$:	LOAD.L	D5,(A3+)	; D5 <-- 3me point	COMP.L	D5,#-1	JUMP',EQ 60$	PUSHM.L	D3,D4	LOAD.L	D3,D4	LOAD.L	D4,D5	CALL	SPLPENTE	; D2 <-- nouvelle pente	POPM.L	D3,D4	COMP.W	D2,D1		; toujours la mme pente ?	JUMP',NE 40$		; non => 40$	LOAD.L	D4,D5		; D4 <-- avance le 2me point	JUMP	30$40$:	CALL	SPLMIEL		; montre une droite	INC.W	(A6)+OSPLNC	LOAD.L	D3,D4		; D3 <-- 1er point	LOAD.L	D4,D5		; D4 <-- 2me point50$:	CALL	SPLPENTE	LOAD.W	D1,D2		; D1 <-- pente de dpart	JUMP	30$60$:	CALL	SPLMIEL		; montre une droite	INC.W	(A6)+OSPLNC90$:	PUSH.W	D7	CALL	CLOWDO		; fin du dessin dans la swdo	POP.W	D7	POPM.L	D1..D5,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; SPLPENTE >;---------/; Calcul un coeficient proportionnel  la pente d'une droite.; in	D3.L	dpart;	D4.L	arrive; out	D2.W	"pente"; mod	D2.WSPLPENTE:	PUSHM.L	D1,D3	LOAD.W	D2,D4	SUB.W	D2,D3		; D2 <-- dx	LOAD.L	D1,D4	SWAP.W	D1	SWAP.W	D3	SUB.W	D1,D3		; D1 <-- dy	ASL.W	D1,#1		; D1 <-- dy*2	JUMP',NE 50$	INC.W	D150$:	MUL.WA	D2,#64	DIV.WA	D2,D1		; D2 <-- pente*32	POPM.L	D1,D3	RET;---------\\; SPLMIEL  >;---------/; Montre/insre une droite.; in	D3.L	coordonne (y;x) dpart;	D4.L	coordonne (y;x) arrive; out	-; mod	D7.WSPLMIEL:	PUSHM.L	D2..D4	COMP.L	D3,D4		; droite de longueur nulle ?	JUMP',EQ 90$		; oui => 90$	SUB.W	D3,(A6)+OPPOS+2	SUB.W	D4,(A6)+OPPOS+2	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,(A6)+OPPOS+0	SUB.W	D4,(A6)+OPPOS+0	SWAP.W	D3	SWAP.W	D4	LOAD.W	D7,#DET_SCALEP	PAGE_	DET		; D3 <-- plus grand (si n:1)	EX.L	D3,D4	LOAD.W	D7,#DET_SCALEP	PAGE_	DET		; D4 <-- plus grand (si n:1)	EX.L	D4,D3	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRSEG90$:	POPM.L	D2..D4	RET;---------\\; SPLCLOSE >;=========/; Ferme la table des droites.; in	D6.L	canal spline; out	-; mod	D7.WSPLCLOSE:	TEST.L	D6		; "canal" spcial ?	JUMP',EQ 90$		; oui => 90$	SPLINE_	CLOSE		; non => libre mmoire pour spline90$:	RET;--------\\; SPLDET  >;========/; Cherche le point montr par la souris.; in	D4.L	position de la souris; out	A1.L	^point dtect;	D7.W	erreur; mod	D7.W, A1.LSPLDET:	PUSHM.L	D0,D3	LOAD.L	D3,D4		; D4 <-- x souris	SWAP.W	D3		; D3 <-- y souris	LOAD.L	A1,#(A6)+OSPLPT-4	LOAD.W	D7,#110$:	ADD.L	A1,#4		; A1 <-- ^point suivant	COMP.L	(A1),#-1	; fin de la table ?	JUMP',EQ 90$		; oui => 90$	LOAD.W	D0,(A1)+2	; D0 <-- x point	SUB.W	D0,#DPOIGNEE	COMP.W	D4,D0	JUMP,LO	10$	ADD.W	D0,#DPOIGNEE*2	COMP.W	D4,D0	JUMP,HS	10$	LOAD.W	D0,(A1)+0	; D0 <-- y point	SUB.W	D0,#DPOIGNEE	COMP.W	D3,D0	JUMP,LO	10$	ADD.W	D0,#DPOIGNEE*2	COMP.W	D3,D0	JUMP,HS	10$	CLR.W	D7		; D7 <-- trouv90$:	POPM.L	D0,D3	TEST.W	D7		; retour EQ/NE	RET;--------\\; SPLADD  >;========/; Ajoute le point montr par la souris.; Cherche l'endroit optimal en calculant la distance entre Pa; et tous les points de la liste.; in	D4.L	point  ajouter Pa(y;x);	D3.W	nb max de points (MAXxxxxx); out	D7.W	erreur; mod	D7.WSPLADD:	PUSHM.L	D0..D5,A3,A4	LOAD.L	D0,D4		; D0 <-- Pa(y;x)	LOAD.W	D7,#ERDIOUT	LOAD.L	A4,#(A6)+OSPLPT	CLR.W	D410$:	INC.W	D4	COMP.L	(A4+),#-1	JUMP,NE 10$	COMP.W	D4,D3	JUMP,HS 90$	LOAD.L	A4,#(A6)+OSPLPT	LOAD.W	D2,#-1		; D2 <-- distance minimale20$:	LOAD.L	D3,(A4+)	COMP.L	D3,#-1	JUMP,EQ 40$	SUB.W	D3,D0	SWAP.W	D3	SWAP.W	D0	SUB.W	D3,D0	SWAP.W	D3	SWAP.W	D0	LIB	?CALCHYPO	; D4 <-- distance Pa-Pn	LOAD.W	D5,D4	LOAD.L	D3,(A4)	COMP.L	D3,#-1	JUMP',NE 30$	TEST.B	(A6)+OSPLOF	; spline ouvert ?	JUMP',EQ 40$	LOAD.L	D3,(A6)+OSPLPT30$:	SUB.W	D3,D0	SWAP.W	D3	SWAP.W	D0	SUB.W	D3,D0	SWAP.W	D3	SWAP.W	D0	LIB	?CALCHYPO	; D4 <-- distance Pa-Pn+1	ADD.W	D4,D5	COMP.W	D2,D4	JUMP,LS 20$	LOAD.W	D2,D4		; D2 <-- distance minimale	LOAD.L	A3,A4		; A3 <-- ^o insrer	JUMP	20$40$:	LOAD.L	A4,A3	CLR.W	D442$:	INC.W	D4	COMP.L	(A4+),#-1	JUMP,NE 42$44$:	LOAD.L	(A4),(A4)-4	SUB.L	A4,#4	DEC.W	D4	JUMP,NE 44$	LOAD.L	(A4),D0	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D5,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; SPLKILL >;========/; Supprime le point montr par la souris.; in	A1.L	^point  supprimer; out	-; mod	-SPLKILL:	PUSH.L	A110$:	LOAD.L	(A1)+0,(A1)+4	ADD.L	A1,#4	COMP.L	(A1),#-1	JUMP,NE	10$	POP.L	A1	RET;--------\\; LBINVC  >;========/; Inverse une ligne brise en construction.; in	-; out	-; mod	D7.WLBINVC:	PUSHM.L	D2..D4,A3	CALL	OPEWDO		; dessine dans la swdo	LOAD.W	D2,#INVDOT	LOAD.L	A3,#(A6)+OSPLPT20$:	LOAD.L	D3,(A3+)	COMP.L	D3,#-1	JUMP',EQ 80$	LOAD.L	D4,(A3)	COMP.L	D4,#-1	JUMP',EQ 80$	SUB.W	D3,(A6)+OPPOS+2	SUB.W	D4,(A6)+OPPOS+2	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,(A6)+OPPOS+0	SUB.W	D4,(A6)+OPPOS+0	SWAP.W	D3	SWAP.W	D4	LOAD.W	D7,#DET_SCALEP	PAGE_	DET		; D3 <-- plus grand (si n:1)	EX.L	D3,D4	LOAD.W	D7,#DET_SCALEP	PAGE_	DET		; D4 <-- plus grand (si n:1)	EX.L	D4,D3	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LIB	?DRSEG		; trace un bout de ligne brise	JUMP	20$80$:	CALL	CLOWDO		; fin du dessin dans la swdo	POPM.L	D2..D4,A3	RET;--------\\; SPLINVC >;========/; Allume ou teint tous les points avant le dessin d'un spline.; in	D2.W	mode (SETDOT/CLRDOT); out	-; mod	D7.WSPLINVC:	PUSHM.L	D0,D4,A4	CALL	OPEWDO		; dessine dans la swdo	LOAD.L	A4,#(A6)+OSPLPT	CLR.W	D010$:	COMP.L	(A4),#-1	; dernier point ?	JUMP',EQ 80$		; oui => 80$				; non =>	LOAD.L	D4,(A4+)	; D4 <-- coordonne d'un point	INC.W	D0	CALL	SPLINVP		; allume/teint la poigne	JUMP	10$80$:	CALL	CLOWDO		; fin du dessin dans la swdo	POPM.L	D0,D4,A4	RET;--------\\; SPLINVP >;========/; Inverse un point avant le dessin d'un spline.; in	D4.L	coordonne (y;x) dans le dessin;	D2.W	mode (SETDOT/CLRDOT);	D0.W	numro de la poigne; out	-; mod	D7.WSPLINVP:	PUSH.L	D3	CALL	OPEWDO		; dessine dans la swdo	LOAD.L	D3,D4	CALL	INVPOIGNEE	; allume/teint une poigne	CALL	CLOWDO		; fin du dessin dans la swdo	POP.L	D3	RET;--------\\; SPLAFXY >;========/; Affiche la position de la souris.; in	-; out	-; mod	D7.WSPLAFXY:	PUSHM.L	D3,D4	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP',NE 20$	CALL	_RGMOUSE	; dessine la position dans les rgles	LOAD.W	D7,#DET_POINTP	PAGE_	DET		; D3 <-- point o est la souris	JUMP',EQ 30$20$:	LOAD.L	D3,#-1		; D3 <-- on est pas dans l'aire de dessin30$:	COMP.L	D3,(A6)+OLASTXY	JUMP',EQ 90$	LOAD.L	(A6)+OLASTXY,D3	CALL	DESINFXY	; affiche X= et Y= dans les informations90$:	POPM.L	D3,D4	RET	.END