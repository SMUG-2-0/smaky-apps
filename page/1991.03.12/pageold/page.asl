	.TITLE	PAGE.ASL;	--------------------------------------;		(C) 1988 - Daniel Roux;	--------------------------------------;	Source du module SMA_PAGE.LIB;	Date		Amliorations; --------------------------------------------------------------------------	.PROC	M680002		; mnmonics CALM 2	.RADIX	10.		; base 10 par dfaut	.HEX			; listing en hexadcimal	.REF	SMAKY	.REF	MODULES	.REF	PAGEDATEPRO	=	0		; 1 => protection selon date !; --------------------------------------------------------------------------XPEN	=	H'D5		; trame quelconqueXTRAME	=	H'D6		; pinceau quelconqueXMAPTT	=	H'D7		; traitill quelconque	.LOC	LGDIS7ODFPPM:	.BLKL	1		; pinceau: ^matriceODFPPO:	.BLKW	2		; pinceau: position (y;x)ODFPDI:	.BLKW	2		; pinceau: dimensions (dy;dx)ODFPII:	.BLKW	1		; pinceau: incrment ligneODFPTO:	.BLKW	1		; pinceau: origine traitillODFPT1:	.BLKW	1		; pinceau: trait 1ODFPT2:	.BLKW	1		; pinceau: trou  1ODFPT3:	.BLKW	1		; pinceau: trait 2ODFPT4:	.BLKW	1		; pinceau: trou  2ODFPT5:	.BLKW	1		; pinceau: trait 3ODFPT6:	.BLKW	1		; pinceau: trou  3ODFPT7:	.BLKW	1		; pinceau: trait 4ODFPT8:	.BLKW	1		; pinceau: trou  4	.BLKB	8		; pinceau: rserveODFTPM:	.BLKL	1		; trame: ^matriceODFTPO:	.BLKW	2		; trame: position (y;x)ODFTDI:	.BLKW	2		; trame: dimensions (dy;dx)ODFTII:	.BLKW	1		; trame: incrment ligne	.BLKB	8		; trame: rserveLGDIS8:; --------------------------------------------------------------------------; Constantes; ----------MAJREV	=	1		; rvisionMINREV	=	0		; versionKEYDBOX	=	H'7E00	.REV	MAJREV,MINREV	.TEXT	"(C) Daniel ROUX et EPSITEC-system sa"; Descripteur pour une ligne ditable dans une DBOX; -------------------------------------------------	.LOC	0ODBOFF:	.BLKB	2		; offset variableODBTYP:	.BLKB	2		; type DBTYPN =  0			;  nombre entier DBTYPA =  1			;  chane alphanumriqueODBRGC:	.BLKB	2		; rang pour DBOX_GETCOODBRED:	.BLKB	2		; rang pour DBOX_MEDITODBNBC:	.BLKB	2		; nb de caractresLDB:; En-tte du module LIB; ---------------------	.LOC	0	PAGE_	FIRST		; code du premier appel	PAGE_	LAST		; code du dernier appel	.B	0		; nombre d'installations	.FILLB	(OHLREV-.),0	.B	1,0		; rvision.version	.W	0,END_PAGE	; longueur	.W	(PATHLIB&H'FFFF0000)/H'10000 ; pattern de dbut	.W	PATHLIB&H'FFFF	; pattern de dbut	.FILLB	(OHLNAM-.),0	.ASCII	"PAGE"		; nom du module	.FILLB	(LGHLIB-.),0	.W	_PAGE_INIT	.W	__PAGE_BASE	.W	_PAGE_DESS	.W	_PAGE_DET	.W	_PAGE_DBOX	.W	_PAGE_IO	.W	_PAGE_TEXT;-----------\\; _PAGE_INIT >;===========/; in	-; out	D7.W	erreur; mod	D7.W_PAGE_INIT:	PUSHM.L	D3,D4,A3	LOAD.W	D3,#GRA_RASTER	LIB_	GETAD	JUMP,NE 90$	LOAD.L	(A6)+ORASTER,A3	LOAD.W	D3,#GRA_HVDOT	LIB_	GETAD	JUMP,NE 90$	LOAD.L	(A6)+OHVDOT,A3.IF DATEPRO	LIB	?GETSHIFT	TEST.L	D3:#BPROGRA	JUMP,BS 90$	LIB	?RDCLOCK	; D4 <-- |w|j|m|a|	LOAD.W	D3,D4		; D3 <--     |m|a|	CLR.B	D3		; D3 <--     |m|-|	SWAP.W	D4		; D4 <-- |m|a|w|j|	AND.L	D4,#H'00FF00FF	; D4 <-- |-|a|-|j|	OR.W	D4,D3		; D4 <-- |-|a|m|j|	COMP.L	D4,#DATELOW	JUMP',LO 85$	COMP.L	D4,#DATEHIGH	JUMP',LS 90$85$:	LOAD.L	A3,#R16"FILE$	LOAD.L	D3,#DEFATT	FOS	?CHATR	FOS	?DELETE		; sabotage ...	LOAD.W	D7,#ERSYNT.ENDIF90$:	POPM.L	D3,D4,A3	TEST.W	D7		; retour EQ/NE	RETFILE$:	.ASCIZ	"#:SMA_PAGE.LIB"	.EVEN	.INS	MPAGEDESSIN.ASI	.INS	MPAGEDESINI.ASI	.INS	MPAGEDRAW.ASI	.INS	MPAGEMATRIX.ASI	.INS	MPAGETRAME.ASI	.INS	MPAGEDBOX.ASI	.INS	MPAGEIO.ASI_CCMO:		JUMP	CCMO_HVDOT:		JUMP	HVDOT_DRMDEF:	JUMP	DRMDEF_CALCPPCM:	JUMP	CALCPPCM__PAGE_BASE:	JUMP	_PAGE_BASE	.INS	MPAGEEDIT.ASI	.INS	MPAGETEXT.ASI	.INS	MPAGEREGLE.ASI	.INS	MPAGESELECT.ASI	.INS	MPAGEDETECT.ASI	.INS	MPAGEDETINI.ASI	.INS	MPAGEMATH.ASI	.INS	MPAGEBASE.ASI	.INS	MPAGEMISC.ASIEND_PAGE:	.END