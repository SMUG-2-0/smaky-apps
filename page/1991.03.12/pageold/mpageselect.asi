	.SBTTL	MPAGESELECT;--------\\; SELOPEN >;========/; Slectionne tous les objets inclus dans un rectangle.; Tous ces objets sont raffichs en inverse !; in	A4.L	^objet rectangle de slection (pas dans la liste);	D4.L	position initiale (y;x); out	D3.W	nb d'objets inclus;	D7.W	erreur; mod	D3.L, D7.WSELOPEN:	PUSHM.L	D0,D1,D2,D4,D5,A3,A4	SUB.L	SP,#8		; SP <-- ^variables locales	LOAD.L	D5,D4		; D5 <-- position initiale	LOAD.W	D3,(A4)+OORDPOS+0	LOAD.W	D4,(A4)+OORDDIM+0	JUMP',NC 10$	NEG.W	D4	SUB.W	D3,D410$:	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,(A4)+OORDPOS+2	LOAD.W	D4,(A4)+OORDDIM+2	JUMP',NC 12$	NEG.W	D4	SUB.W	D3,D412$:	ADD.W	D4,D3	LOAD.L	(SP)+0,#H'7FFF7FFF ; init min (y;x)	CLR.L	(SP)+4		; init max (y;x)	CLR.W	D0		; D0 <-- nb d'objets slectionns	LOAD.L	A3,#(A6)+OUSE	LOAD.L	A4,(A3)+OLPREV20$:	COMP.L	A4,A3		; dbut de la liste ?	JUMP,EQ 70$		; oui => 70$	LOAD.L	D1,(A4)+OODPOS	LOAD.L	D2,(A4)+OODDIM	COMP.W	D3,D1		; trop  gauche ?	JUMP,GE 61$	ADD.W	D1,D2	COMP.W	D4,D1		; trop  droite ?	JUMP,LT 61$	SWAP.W	D1	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	COMP.W	D3,D1		; trop haut ?	JUMP,GE 60$	ADD.W	D1,D2	COMP.W	D4,D1		; trop bas ?	JUMP,LT 60$	LOAD.L	D1,(A4)+OODPOS	LOAD.L	D2,(A4)+OODDIM	COMP.W	D1,(SP)+2	JUMP',GE 40$	LOAD.W	(SP)+2,D140$:	ADD.W	D1,D2	COMP.W	D1,(SP)+6	JUMP',LE 41$	LOAD.W	(SP)+6,D141$:	SWAP.W	D1	SWAP.W	D2	COMP.W	D1,(SP)+0	JUMP',GE 42$	LOAD.W	(SP)+0,D142$:	ADD.W	D1,D2	COMP.W	D1,(SP)+4	JUMP',LE 43$	LOAD.W	(SP)+4,D143$:	LOAD.W	D2,#CLRDOT	CALL	DESOBJET	; efface l'objet	TSET.B	(A4)+OOFLG:#BOOSEL	TCLR.B	(A4)+OOFLG:#BOOSKP	LOAD.L	(A4)+OODPOS,D5	; OODPOS <-- position initiale !	INC.W	D0		; D0 <-- un objet de plus slectionn60$:	SWAP.W	D3	SWAP.W	D461$:	LOAD.L	A4,(A4)+OLPREV	; A4 <-- ^prcdent	JUMP	20$70$:	LOAD.W	D7,#ERDIOUT	TEST.W	D0		; au moins un objet slectionn ?	JUMP',EQ 90$		; non => 90$	LOAD.L	D1,(SP)+0	LOAD.L	D2,(SP)+4	SUB.W	D2,D1	SWAP.W	D1	SWAP.W	D2	SUB.W	D2,D1	SWAP.W	D1	SWAP.W	D2	PUSH.L	(A6)+OWPOS	PUSH.L	(A6)+OWDIM	PUSH.L	(A6)+OPPOS	PUSH.L	(A6)+OSDIM	LOAD.L	A4,#(A6)+OBUDIS	; A4 <-- ^objert bidon	LOAD.L	(A4)+OODPOS,D1	LOAD.L	(A4)+OODDIM,D2	CALL	DWOOBJET	; dimensione la fentre selon objets	CALL	OPEWDO		; dessine dans la swdo	LOAD.L	A4,#(A6)+OUSE	LOAD.L	A4,(A4)+OLNEXT	; A4 <-- ^premier objet	CALL	MAJOBJETS	CALL	CLOWDO		; fin du dessin dans la swdo	POP.L	(A6)+OSDIM	POP.L	(A6)+OPPOS	POP.L	(A6)+OWDIM	POP.L	(A6)+OWPOS	CLR.W	D7		; D7 <-- ok90$:	LOAD.W	D3,D0		; D3 <-- nb d'objets slectionns	ADD.L	SP,#8		; ajuste le stack	POPM.L	D0,D1,D2,D4,D5,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-------\\; SELINV >;=======/; Inverse tous les objets slectionns.; in	-; out	-; mod	D7.WSELINV:	PUSHM.L	D2,A3,A4	CALL	OPEWDO		; dessine dans la swdo	LOAD.L	A3,#(A6)+OUSE	LOAD.L	A4,(A3)+OLPREV20$:	COMP.L	A4,A3		; dbut de la liste ?	JUMP',EQ 70$		; oui => 70$	TEST.B	(A4)+OOFLG:#BOOSEL	JUMP',BC 60$	TEST.B	(A4)+OOFLG:#BOOSKP	JUMP',BS 60$	LOAD.W	D2,#INVDOT	CALL	DESOBJET	; inverse un objet60$:	LOAD.L	A4,(A4)+OLPREV	; A4 <-- ^prcdent	JUMP	20$70$:	CALL	CLOWDO		; fin du dessin dans la swdo	POPM.L	D2,A3,A4	RET;--------\\; SELMOVE >;========/; Dplace l'objet suivant slectionn.; in	D4.L	nouvelle position (y;x);	A3.L	^dernier objet dplac/nil; out	A3.L	^objet dplac;	D7.W	erreur (si rien dplac); mod	D7.W, A3.LSELMOVE:	PUSHM.L	D2..D4,A4	LOAD.L	D3,D4		; D3 <-- nouvelle position (y;x)	LOAD.L	A4,A3		; A4 <-- ^dernier objet dplac	LOAD.L	A3,#(A6)+OUSE	COMP.L	A4,#0	JUMP',NE 10$	LOAD.L	A4,(A3)+OLNEXT	; A4 <-- ^premier objet10$:	LOAD.W	D7,#ERDIOUT	; D7 <-- rien dplac20$:	COMP.L	A4,A3		; fin de la liste ?	JUMP',EQ 80$		; oui => 80$	TEST.B	(A4)+OOFLG:#BOOSEL	JUMP',BC 60$	TEST.B	(A4)+OOFLG:#BOOSKP	JUMP',BS 60$	LOAD.L	D4,D3		; D4 <-- nouvelle position	SUB.W	D4,(A4)+OODPOS+2	SWAP.W	D4	SUB.W	D4,(A4)+OODPOS+0 ; D4 <-- +/- dplacement	SWAP.W	D4	TEST.L	D4	JUMP',EQ 60$	LOAD.W	D2,#INVDOT	CALL	DESOBJET	; efface un objet	CALL	MOVOBJET	; dplace un objet	LOAD.L	(A4)+OODPOS,D3;	LOAD.W	D2,#INVDOT	CALL	DESOBJET	; allume un objet	CLR.W	D7		; D7 <-- un objet dplac	JUMP'	80$60$:	LOAD.L	A4,(A4)+OLNEXT	; A4 <-- ^suivant	JUMP	20$80$:	LOAD.L	A3,A4		; A3 <-- ^objet dplac	POPM.L	D2..D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; SELWORD >;========/; Modifie un word  tous les objets slectionns.; in	D4.W	nouveau word;	D3.W	offset; out	-; mod	D7.WSELWORD:	PUSHM.L	D2,A3,A4	LOAD.L	A3,#(A6)+OUSE	LOAD.L	A4,(A3)+OLNEXT	; A4 <-- ^premier objet20$:	COMP.L	A4,A3		; fin de la liste ?	JUMP',EQ 90$		; oui => 90$	TEST.B	(A4)+OOFLG:#BOOSEL	JUMP',BC 60$	TEST.B	(A4)+OOFLG:#BOOSKP	JUMP',BS 60$	COMP.W	D4,(A4)+(D3.W)	; y a-t-il un changement ?	JUMP',EQ 60$		; non => 60$				; oui =>	LOAD.W	D2,#INVDOT	CALL	DESOBJET	; efface l'objet invers	LOAD.W	(A4)+(D3.W),D4	LOAD.W	D2,#INVDOT	CALL	DESOBJET	; rallume l'objet invers60$:	LOAD.L	A4,(A4)+OLNEXT	; A4 <-- ^suivant	JUMP	20$90$:	POPM.L	D2,A3,A4	RET;---------\\; SELCLOSE >;=========/; D-slectionne tous les objets slectionns.; in	-; out	-; mod	D7.WSELCLOSE:	PUSHM.L	D1..D4,A3,A4	SUB.L	SP,#8		; SP <-- ^variables locales	LOAD.L	A3,#(A6)+OUSE	LOAD.L	A4,(A3)+OLPREV20$:	COMP.L	A4,A3		; dbut de la liste ?	JUMP',EQ 26$		; oui => 26$	TEST.B	(A4)+OOFLG:#BOOSEL	JUMP',BC 24$	LOAD.W	D2,#INVDOT	CALL	DESOBJET	; efface un objet invers24$:	LOAD.L	A4,(A4)+OLPREV	; A4 <-- ^prcdent	JUMP	20$26$:	LOAD.L	(SP)+0,#H'7FFF7FFF ; init min (y;x)	CLR.L	(SP)+4		; init max (y;x)	LOAD.L	A3,#(A6)+OUSE	LOAD.L	A4,(A3)+OLPREV30$:	COMP.L	A4,A3		; dbut de la liste ?	JUMP,EQ 70$		; oui => 70$	TCLR.B	(A4)+OOFLG:#BOOSEL	JUMP,BC 60$	TCLR.B	(A4)+OOFLG:#BOOSKP	CALL	DETINIT		; ajuste pour les dtections	LOAD.L	D1,(A4)+OODPOS	LOAD.L	D2,(A4)+OODDIM	COMP.W	D1,(SP)+2	JUMP',GE 40$	LOAD.W	(SP)+2,D140$:	ADD.W	D1,D2	COMP.W	D1,(SP)+6	JUMP',LE 41$	LOAD.W	(SP)+6,D141$:	SWAP.W	D1	SWAP.W	D2	COMP.W	D1,(SP)+0	JUMP',GE 42$	LOAD.W	(SP)+0,D142$:	ADD.W	D1,D2	COMP.W	D1,(SP)+4	JUMP',LE 43$	LOAD.W	(SP)+4,D143$:60$:	LOAD.L	A4,(A4)+OLPREV	; A4 <-- ^prcdent	JUMP	30$70$:	LOAD.L	D1,(SP)+0	LOAD.L	D2,(SP)+4	SUB.W	D2,D1	SWAP.W	D1	SWAP.W	D2	SUB.W	D2,D1	SWAP.W	D1	SWAP.W	D2	PUSH.L	(A6)+OWPOS	PUSH.L	(A6)+OWDIM	PUSH.L	(A6)+OPPOS	PUSH.L	(A6)+OSDIM	LOAD.L	A4,#(A6)+OBUDIS	; A4 <-- ^objert bidon	LOAD.L	(A4)+OODPOS,D1	LOAD.L	(A4)+OODDIM,D2	CALL	DWOOBJET	; dimensione la fentre selon objets	CALL	OPEWDO		; dessine dans la swdo	LOAD.L	A4,#(A6)+OUSE	LOAD.L	A4,(A4)+OLNEXT	; A4 <-- ^premier objet	CALL	MAJOBJETS	CALL	CLOWDO		; fin du dessin dans la swdo	POP.L	(A6)+OSDIM	POP.L	(A6)+OPPOS	POP.L	(A6)+OWDIM	POP.L	(A6)+OWPOS	ADD.L	SP,#8		; ajuste le stack	POPM.L	D1..D4,A3,A4	RET;---------\\; MOVOBJET >;=========/; Dplace un objet.; in	A4.L	^objet;	D4.L	+/- dplacement (dy;dx); out	-; mod	D7.WMOVOBJET:	PUSHM.L	D3,A3	LOAD.W	D3,(A4)+OOOBJ	COMP.W	D3,#ICOTM	JUMP,EQ TML$	COMP.W	D3,#ICOSP	JUMP,EQ SPLINE$	COMP.W	D3,#ICOLB	JUMP,EQ LINEB$	COMP.W	D3,#ICODR	JUMP',EQ LINE$	COMP.W	D3,#ICOFL	JUMP',EQ LINE$	COMP.W	D3,#ICORD	JUMP',EQ RECT$	COMP.W	D3,#ICORA	JUMP',EQ RECT$	COMP.W	D3,#ICOPO	JUMP',EQ CIRC$	COMP.W	D3,#ICOCE	JUMP',EQ CIRC$	COMP.W	D3,#ICOEL	JUMP',EQ CIRC$	COMP.W	D3,#ICOAR	JUMP',EQ CIRC$	COMP.W	D3,#ICOIM	JUMP',EQ IMAGE$	COMP.W	D3,#ICOTX	JUMP',EQ TEXT$	JUMP	EXIT$LINE$:RECT$:CIRC$:IMAGE$:TEXT$:	SWAP.W	D4	ADD.W	(A4)+OODRPOS+0,D4	SWAP.W	D4	ADD.W	(A4)+OODRPOS+2,D4	JUMP	EXIT$TML$:	LOAD.L	A3,#(A4)+OOTMPTS ; A3 <-- ^premier point	LOAD.W	D3,(A4)+OOTMNBP	; D3 <-- nb de points	DEC.W	D3TML2$:	SWAP.W	D4	ADD.W	(A3+),D4	SWAP.W	D4	ADD.W	(A3+),D4	DECJ.W,NMO D3,TML2$	JUMP	EXIT$SPLINE$:	LOAD.L	A3,#(A4)+OOSPPTC ; A3 <-- ^premier point	LOAD.W	D3,(A4)+OOSPNBC	; D3 <-- nb de points	DEC.W	D3SPLINE2$:	SWAP.W	D4	ADD.W	(A3+),D4	SWAP.W	D4	ADD.W	(A3+),D4	DECJ.W,NMO D3,SPLINE2$	LOAD.L	A3,#(A4)+OOSPPTF ; A3 <-- ^premier point	LOAD.W	D3,(A4)+OOSPNBF	; D3 <-- nb de points	DEC.W	D3SPLINE3$:	SWAP.W	D4	ADD.W	(A3+),D4	SWAP.W	D4	ADD.W	(A3+),D4	DECJ.W,NMO D3,SPLINE3$	JUMP	EXIT$LINEB$:	LOAD.L	A3,#(A4)+OOLBPTS ; A3 <-- ^premier point	LOAD.W	D3,(A4)+OOLBNBP	; D3 <-- nb de points	DEC.W	D3LINEB2$:	SWAP.W	D4	ADD.W	(A3+),D4	SWAP.W	D4	ADD.W	(A3+),D4	DECJ.W,NMO D3,LINEB2$;	JUMP	EXIT$EXIT$:	POPM.L	D3,A3	TEST.W	D7		; retour EQ/NE	RET	.END