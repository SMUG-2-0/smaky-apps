	.SBTTL	MPAGEDESINI;--------\\; DESINIT >;========/; Initialise le masque ventuel pour pouvoir dessiner le fond.; in	A4.L	^objet quelconque; out	D7.W	erreur; mod	D7.WDESINIT:	PUSHM.L	D1..D6,A3..A5	COMP.W	(A4)+OOOBJ,#ICOIM	JUMP',NE 10$	CALL	DESINITIMZOOM	; construit la matrice zoome10$:	LOAD.L	A5,A4		; A5 <-- ^objet	CLR.W	D7		; D7 <-- ok	LOAD.W	D4,(A5)+OOFSCA	COMP.W	D4,(A6)+OSCALE	JUMP,EQ 90$	LOAD.W	(A5)+OOFSCA,(A6)+OSCALE; Filtre les objets qui n'ont jamais de matrices de fond.	COMP.W	(A5)+OOOBJ,#ICODR	JUMP,EQ 90$	COMP.W	(A5)+OOOBJ,#ICORD	JUMP,EQ 90$	COMP.W	(A5)+OOOBJ,#ICORA	JUMP,EQ 90$	COMP.W	(A5)+OOOBJ,#ICOTX	JUMP,EQ 90$; Libre les matrices ventuelles.	TEST.L	(A5)+OOFPM	; matrice existe ?	JUMP',EQ 20$		; non => 20$	LOAD.L	A4,(A5)+OOFPM	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la matrice de fond	CLR.L	(A5)+OOFPM20$:	TEST.L	(A5)+OOFPT	; matrice existe ?	JUMP',EQ 30$		; non => 30$	LOAD.L	A4,(A5)+OOFPT	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la matrice de trame	CLR.L	(A5)+OOFPT; Filtre les objets qui n'ont pas de matrices de fond dans une; condition particulire.30$:	TEST.B	(A6)+OVUE+3:#BVUFIL-0 ; vue en fil de fer ?	JUMP,BS 90$		; oui => 90$	LOAD.L	D4,(A5)+OOFOND	TEST.L	D4:#BFDOBT	JUMP,BS 90$	COMP.W	(A5)+OOOBJ,#ICOAR	JUMP',NE 32$	LOAD.L	D4,(A5)+OOARTYP	TEST.L	D4:#BARTRA	; tranche de gteau ?	JUMP,BC 90$		; non => 90$32$:	COMP.W	(A5)+OOOBJ,#ICOFL	JUMP',NE 40$	LOAD.L	D4,(A5)+OOFLTYP	TEST.L	D4:#BFLF2	; forme triangulaire ?	JUMP,BC 90$		; non => 90$; Construit la matrice de fond si ncessaire.40$:	LOAD.L	D3,(A5)+OODDIM	CALL	DETSCALEP	; D3 <-- plus grand (si n:1)	LOAD.W	D4,D3	ADD.W	D4,#2+16-1	AND.B	D4,#B'11110000	SR.W	D4,#3	SWAP.W	D3	ADD.W	D3,#2	MUL.WU	D4,D3	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; rserve la matrice de fond	JUMP,NE 90$	GESMEM	?CLEARMEM	; met toute la matrice  zro	LOAD.L	(A5)+OOFPM,A4	; OOFPM <-- ^matrice	LOAD.L	D3,(A5)+OODDIM	CALL	DETSCALEP	; D3 <-- plus grand (si n:1)	LOAD.L	D4,D3	ADD.W	D4,#2	SWAP.W	D4	ADD.W	D4,#2	SWAP.W	D4	CALL	OPEDISMAT	; dessine dans la matrice	PUSH.L	(A6)+OWPOS	PUSH.L	(A6)+OWDIM	PUSH.L	(A6)+OPPOS	PUSH.L	(A6)+OSDIM	CLR.L	(A6)+OWPOS	LOAD.L	(A6)+OWDIM,D4	LOAD.L	D4,(A5)+OODDIM	ADD.W	D4,#2	SWAP.W	D4	ADD.W	D4,#2	SWAP.W	D4	LOAD.L	(A6)+OSDIM,D4	LOAD.L	D4,(A5)+OODPOS	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.L	(A6)+OPPOS,D4	PUSH.B	(A5)+OOFLG	PUSH.W	(A5)+OOPEN	PUSH.L	(A5)+OOFOND	TCLR.B	(A5)+OOFLG:#BOOSEL	CLR.W	(A5)+OOPEN	; utilise le crayon	LOAD.L	(A5)+OOFOND,#2^BFDOBT	LOAD.L	A4,A5		; A4 <-- ^objet	LOAD.W	D2,#SETDOT!2^BMDNMSK	CALL	DESOBJET	; dessine l'objet dans la matrice	LOAD.L	D4,#-1	CALL	DRMDEF		; trame toute noire	LOAD.L	A3,#(A6)+OBUDIS	LOAD.B	(A3)+0,#AFFILLA	; rempli tout	LOAD.B	(A3)+1,#DRAWFILLO	CLR.L	(A3)+2	LOAD.B	(A3)+6,#DRAWFILLC	LOAD.B	(A3)+7,#AFFILLT	; teste si dbordement	LOAD.W	D3,#1+6+1	LIB	?STRING	LOAD.L	A4,A5		; A4 <-- ^objet	LOAD.W	D2,#CLRDOT!2^BMDNMSK	CALL	DESOBJET	; efface l'objet dans la matrice	POP.L	(A5)+OOFOND	POP.W	(A5)+OOPEN	POP.B	(A5)+OOFLG	POP.L	(A6)+OSDIM	POP.L	(A6)+OPPOS	POP.L	(A6)+OWDIM	POP.L	(A6)+OWPOS	CALL	CLODISMAT	; fin du dessin dans la matrice; Construit la matrice de trame si ncessaire.	LOAD.L	D4,(A5)+OOFOND	TEST.L	D4:#BFDOBO	JUMP,BS 80$	TEST.L	D4:#BFDONO	JUMP,BS 80$	TEST.L	D4:#BFDRBO	JUMP,BS 80$	LOAD.L	D3,(A5)+OODDIM	CALL	DETSCALEP	; D3 <-- plus grand (si n:1)	LOAD.W	D4,D3	ADD.W	D4,#2+16-1	AND.B	D4,#B'11110000	SR.W	D4,#3	SWAP.W	D3	ADD.W	D3,#2	MUL.WU	D4,D3	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; rserve la matrice de fond	JUMP,NE 90$	LOAD.L	(A5)+OOFPT,A4	; OOFPT <-- ^matrice	LOAD.L	D3,(A5)+OODDIM	CALL	DETSCALEP	; D3 <-- plus grand (si n:1)	LOAD.L	D4,D3	ADD.W	D4,#2	SWAP.W	D4	ADD.W	D4,#2	SWAP.W	D4	CALL	OPEDISMAT	; dessine dans la matrice	LOAD.W	D1,(A5)+OOTRAM	CALL	MATTRAME	; dfinit la trame	LOAD.L	D3,(A5)+OODDIM	CALL	DETSCALEP	; D3 <-- plus grand (si n:1)	LOAD.L	D4,D3	ADD.W	D4,#2	SWAP.W	D4	ADD.W	D4,#2	SWAP.W	D4	CLR.L	D3	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; trame toute la matrice	CALL	CLODISMAT	; fin du dessin dans la matrice	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWRASTER	CLR.L	(A3)+1	LOAD.L	(A3)+5,(A5)+OOFPM	LOAD.W	D3,(A5)+OODDIM+2	CALL	DETSCALEP	; D3 <-- plus grand (si n:1)	ADD.W	D3,#2+16-1	AND.B	D3,#B'11110000	SR.W	D3,#3	LOAD.W	(A3)+9,D3	CLR.L	(A3)+11	LOAD.L	(A3)+15,(A5)+OOFPT	LOAD.W	(A3)+19,D3	SWAP.W	D4	LOAD.L	(A3)+21,D4	LOAD.B	(A3)+25,#CLRDOT	LOAD.W	D3,#26	LIB	?STRING		; efface le trop plein de la trame	LOAD.L	D4,(A5)+OOFOND	TEST.L	D4:#BFDOTO	JUMP',BS 80$	TEST.L	D4:#BFDRTO	JUMP',BS 80$	LOAD.L	A4,(A5)+OOFPM	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la matrice de fond	CLR.L	(A5)+OOFPM80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D6,A3..A5	TEST.W	D7		; retour EQ/NE	RET;--------------\\; DESINITIMZOOM >;--------------/; Calcule la matrice zoome pour un objet image.; in	A4.L	^objet image; out	D7.W	erreur; mod	D7.WDESINITIMZOOM:	PUSHM.L	D1..D4,A0,A4,A5	LOAD.L	A5,A4		; A5 <-- ^objet	TEST.L	(A5)+OOIMPMZ	JUMP',EQ 20$	LOAD.L	A4,(A5)+OOIMPMZ	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la matrice zoome	CLR.L	(A5)+OOIMPMZ20$:	CLR.W	D7		; D7 <-- ok	LOAD.L	D3,(A5)+OOIMDIM	TEST.W	D3	JUMP',NC 30$	NEG.W	D330$:	SWAP.W	D3	TEST.W	D3	JUMP',NC 31$	NEG.W	D331$:	SWAP.W	D3	CALL	DETSCALEP	; D3 <-- plus grand (si n:1)	COMP.L	D3,(A5)+OOIMLGY	; exactement les mmes dimensions ?	JUMP,EQ 90$		; oui => 90$	LOAD.L	D2,D3	LOAD.W	D4,D3	ADD.W	D4,#16-1	AND.B	D4,#B'11110000	SR.W	D4,#3	LOAD.W	(A5)+OOIMZIX,D4	SWAP.W	D3	MUL.WU	D4,D3	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; rserve la matrice zoome	JUMP,NE 90$	GESMEM	?CLEARMEM	; met toute la matrice  zro	LOAD.L	(A5)+OOIMPMZ,A4	; OOIMPMZ <-- ^matrice zoome	LOAD.L	A0,#(A6)+OSTRETCH ; A0 <-- ^variables pour stretch	LOAD.L	A4,#(A5)+OOIMMAT	LOAD.L	(A0)+OSTRSPT,A4	LOAD.W	(A0)+OSTRSDX,(A5)+OOIMIIX	CLR.L	(A0)+OSTRS0	LOAD.L	(A0)+OSTRS2,(A5)+OOIMLGY	LOAD.L	(A0)+OSTRDPT,(A5)+OOIMPMZ	LOAD.W	(A0)+OSTRDDX,(A5)+OOIMZIX	CLR.L	(A0)+OSTRD0	LOAD.L	(A0)+OSTRD1,D2	LOAD.L	(A0)+OSTRD2,D2	LOAD.L	(A0)+OSTRD3,D2	CLR.W	(A0)+OSTRD1+0	CLR.W	(A0)+OSTRD3+2	ST_	RECT		; hop, moteur !	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D4,A0,A4,A5	TEST.W	D7		; retour EQ/NE	RET	.END