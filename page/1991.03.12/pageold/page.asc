	.TITLE	PAGE.ASC;	--------------------------------------;		(C) 1988 - Daniel Roux;	--------------------------------------;	Source du programme PAGE;	Date		Amliorations; ---------------------------------------------------------------------------------------------; 1.0	27.10.88	dbut des travaux	.PROC	M680002	.RADIX	10.	.HEX	.REF	SMAKY	.REF	MODULES	.REF	PAGE	.REF	COLORSDATEPRO	=	0		; 1 => protection selon date !; --------------------------------------------------------------------------XPEN	=	H'D5		; trame quelconqueXTRAME	=	H'D6		; pinceau quelconqueXMAPTT	=	H'D7		; traitill quelconque	.LOC	LGDIS7ODFPPM:	.BLKL	1		; pinceau: ^matriceODFPPO:	.BLKW	2		; pinceau: position (y;x)ODFPDI:	.BLKW	2		; pinceau: dimensions (dy;dx)ODFPII:	.BLKW	1		; pinceau: incrment ligneODFPTO:	.BLKW	1		; pinceau: origine traitillODFPT1:	.BLKW	1		; pinceau: trait 1ODFPT2:	.BLKW	1		; pinceau: trou  1ODFPT3:	.BLKW	1		; pinceau: trait 2ODFPT4:	.BLKW	1		; pinceau: trou  2ODFPT5:	.BLKW	1		; pinceau: trait 3ODFPT6:	.BLKW	1		; pinceau: trou  3ODFPT7:	.BLKW	1		; pinceau: trait 4ODFPT8:	.BLKW	1		; pinceau: trou  4	.BLKB	8		; pinceau: rserveODFTPM:	.BLKL	1		; trame: ^matriceODFTPO:	.BLKW	2		; trame: position (y;x)ODFTDI:	.BLKW	2		; trame: dimensions (dy;dx)ODFTII:	.BLKW	1		; trame: incrment ligne	.BLKB	8		; trame: rserveLGDIS8:; --------------------------------------------------------------------------	.REV	PAGEREV,PAGEVERS	.CODE	800,11,B'1111,600,2000,300,2000,2,'N,'E,'F,11	.TEXT	"(C)  Daniel ROUX et EPSITEC-system sa"; Constantes; ----------LBUTML	=	1000		; lg max de OBUTMLLBUFILE	=	50		; lg max d'un nom de fichierMAXPOIGNEE=	MAXLINEB+2	; nb max de poignesDPOIGNEE=	5		; dimension d'une poigneNBZONE	=	10		; nb max de zonesDASC	=	10		; dplacement avec les flches des ascenseursKEYICO	=	H'7E00		; "touche" spciale icne; Positions dans les informations; -------------------------------POSXY	=	13		; position pour afficher X= et Y=POSSCALE=	13+12		; position pour afficher 1:1POSPAS	=	13+12+5		; position pour afficher P=32POSFILE	=	13+12+5+5	; position pour afficher "fichier"; Couleurs; --------COBJET	=	COLOR_DEOBJET&H'07CMODE	=	COLOR_DEMODE&H'07COUTIL	=	COLOR_DEOUTIL&H'07CMODIF	=	COLOR_DEMODIF&H'07; Types des icnes; ----------------TMISC	=	H'04		; icne avec "divers"TDIAL	=	H'10*1		; dialogueTMENU	=	H'10*2		; menuTDOWN	=	H'10*3		; retour d'un niveauTEFFET	=	H'10*4		; effet immdiat; Modes pour divers; -----------------BMDEF	=	0		; dfinition de l'objetMDEF	=	2^BMDEF; Niveaux pour les modes; ----------------------NIVSPLINE =	1		; cration d'une courbeNIVLINEB =	2		; cration d'une ligne briseNIVDEFORME =	3		; dformation (zoom, tourne, miroir, dforme, etc.)NIVPOIGNEE =	4		; poignesNIVHELP =	9		; aide; Fanions pour les entres/sorties; --------------------------------BDBAUTO	=	15		; mode de sauvetage automatiqueBDBDEF	=	14		; sauve les dfinitionsBDBNMAJ	=	13		; touche (MET A JOUR) grise; Fanions pour ODEF; -----------------BDEFPG	=	0		; points graphiquesBDEFMM	=	1		; millimtresBDEFICO	=	8		; utilise les icnesBDEFASC	=	9		; utilise les ascenseursBDEFREG	=	10		; utilise les rglesBDEFMDC	=	16		; mmorise la dernire caseBDEFZOOM=	17		; zoom gnralBDEFFILL=	18		; remplissage jusque dans les bords; Icnes; ------ICOLX	=	96		; largeur des icnes de gaucheICOLY	=	310		; hauteur des icnes de gaucheMARGX	=	8		; marge autour du cadre en XMARGY	=	8		; marge autour du cadre en YIS	=	1		; icne simple (largeur = GCICX/2)ID	=	2		; icne double (largeur = GCICX)IL	=	3		; passe  la ligneIC	=	4		; cale interligneIF	=	5		; finOPICODES=	1		; opration dans les icnes: dessineOPICODET=	2		; opration dans les icnes: dtecteOPICOINV=	3		; opration dans les icnes: inverseOPICOINVALL=	4		; opration dans les icnes: inverse toutOPICOPOS=	5		; opration dans les icnes: positionOPICOGREY=	6		; opration dans les icnes: griseOPICOFULL=	7		; opration dans les icnes: dgriseOPICONORM=	8		; opration dans les icnes: normalOPICOMISC=	9		; opration dans les icnes: divers; Poignes; --------BPOIHG	=	0		; poigne sup/gaucheBPOIHD	=	1		; poigne sup/droiteBPOIBG	=	2		; poigne inf/gaucheBPOIBD	=	3		; poigne inf/droiteBPOICE	=	4		; poigne centrale; En-tte d'un fichier .IMAGE; ---------------------------	.LOC	0OIMTYP:	.BLKB	1		; H'01 = indique type imageOIMCOD:	.BLKB	1		; H'00 = indique pas de codageOIMBIP:	.BLKB	1		; H'01 = 1 bit par pointOIMDIR:	.BLKB	1		; H'02 = coord. X-Y comme cranOIMDLX:	.BLKB	2		; largeur image en pointsOIMDLY:	.BLKB	2		; hauteur image en pointsOIMNBB:	.BLKB	4		; nb de byte pour l'image	.BLKB	20		; rserveLGHIMA:; Variables; ---------	.LOC	0	.BLKB	LGVARP		; variables du module PAGEOCHPAGE:.BLKB	2		; canal module PAGEOCHDBOX:.BLKB	2		; canal module DBOXOCHDGENC:.BLKB	2		; canal module DGENCOCHLIST:.BLKB	2		; canal module LISTOCHSCROLL:.BLKB	2		; canal module SCROLLOCHCOUPE:.BLKB	2		; canal module COUPEOCHSPLINE:.BLKB	2		; canal module SPLINEOCHSTRETCH:.BLKB 2		; canal module STRETCHOCHPRINTA:.BLKB	2		; canal du module PRINTAOCAPRINT:.BLKB	4		; canal du interne PRINTOPLCOM:	.BLKB	4		; ^ligne de commandeOPDDIS:	.BLKB	4		; ^descripteur de la fentreOBUTML:	.BLKB	LBUTML		; buffer pour trait  main leveOMACHINE:.BLKB	1		; type de la machine (SMAKY8/SMAKY100)	.EVENOLUMAM:	.BLKB	200		; matrice(s) du lutin de la sourisOLUMAN:	.BLKB	200		; matrice(s) du lutin de la sourisOLUTIN:	.BLKB	1		; no lutin de la sourisOLUFLG:	.BLKB	1		; flags pour le lutin BLUMAN	=  0			;  0 => OLUMAM, 1 => OLUMAN	.EVENOMPACR:	.BLKB	LMM*8		; mmenu: paramtre crochetOMPATX:	.BLKB	LMM*8		; mmenu: paramtre texteOPOIPFE:.BLKB	MAXPOIGNEE*4	; poignes: ^buffers pour les fondsOPOICNT:.BLKB	1		; poignes: compteur pour allumer/teindre	.EVENOPOIPM1:.BLKB	4		; poignes: ^matrice 1OPOIPM2:.BLKB	4		; poignes: ^matrice 2ONOZO:	.BLKB	2		; no de la zone visibleOPICO:	.BLKB	4		; ^matrice des icnes de gaucheODICO:	.BLKB	4		; position des icnes de gaucheOTICO:	.BLKB	256/8		; tables des icnes grises (bits)OXICO:	.BLKB	1		; type des icnes de gauche (NIVxxx)OYICO:	.BLKB	1		; sous-type (ICO...)OBICO:	.BLKB	1		; indique si clic haut/bas dans icneOGICO:	.BLKB	1		; indique si clic gauche/droite dans icneOMXICO:	.BLKB	1		; indique si clic dfinitions possibleOMDICO:	.BLKB	1		; indique si clic dfinitions dans icne	.EVENOORECT:	.BLKB	LGORD		; objet rectangle pour slectionsODDNB:	.BLKB	2		; nombre d'objets inclusODDOP:	.BLKB	1		; dplace/duplique: opration (ICODEPLACE, etc.)	.EVENOCERAY:	.BLKB	2		; cercle: rayon  afficherOCEANG:	.BLKB	2		; cercle: angle  afficherOMAJ:	.BLKB	1		; 1 => mise  jour ncessaireOLOUTIL:.BLKB	1		; loupe: dernier outilOLOBJET:.BLKB	1		; loupe: dernier objet	.EVENOBARC:	.BLKB	10		; buffer pour l'arc en ASCIIOSPLPT:	.BLKB	4*MAXLINEB	; points pour spline/ligne briseOSPLNC:	.BLKB	2		; nb de points calculsOSPLOF:	.BLKB	1		; ouvert/ferm (spline)OLIBOF:	.BLKB	1		; ouvert/ferm (ligne brise)OSPLOP:	.BLKB	1		; opration (ICOSPLxxx)	.EVENOSTRHV:	.BLKB	1		; horizontal/verticalOSTRHO:	.BLKB	1		; homottieOSTRDF:	.BLKB	1		; type de dformationOSTRRO:	.BLKB	1		; sens de la rotation	.EVENOTXOPO:	.BLKB	4		; texte: ancienne positionOTXODI:	.BLKB	4		; texte: anciennes dimensionsORPOS:	.BLKB	4		; rectangle: positionORDIM:	.BLKB	4		; rectangle: dimensionsOASVER:	.BLKB	LSCVAR		; variables de l'ascenseur verticalOASHOR:	.BLKB	LSCVAR		; variables de l'ascenseur horizontalORGVAR:	.BLKB	LRGVAR		; variables des rglesOLASTXY:.BLKB	4		; dernire position X= et Y= afficheOBUNAME:.BLKB	LBUFILE		; nom du dessin en mmoireOAJNAME:.BLKB	LBUFILE		; ajoute: nom du fichierOBUHIMA:.BLKB	LGHIMA		; en-tte d'un fichier .imageOSTPRI:	.BLKB	LGPRI0		; status de l'imprimanteOFACX:	.BLKB	2		; facteur rduction en XOFACY:	.BLKB	2		; facteur rduction en YOMMX:	.BLKB	2		; nb de 1/10 de um pour un point en XOMMY:	.BLKB	2		; nb de 1/10 de um pour un point en YLGVAR:; Programme; ---------	.LOC	0	JUMP	START; Noms des modules; ----------------NMPAGE:		.ASCIZ	"PAGE"NMDBOX:		.ASCIZ	"DBOX"NMDGENC:	.ASCIZ	"DGENC"NMLIST:		.ASCIZ	"LIST"NMSCROLL:	.ASCIZ	"SCROLL"NMCOUPE:	.ASCIZ	"COUPE"NMSPLINE:	.ASCIZ	"SPLINE"NMSTRETCH:	.ASCIZ	"STRETCH"NMPRINTA:	.ASCIZ	"PRINTA"; Erreurs fatales; ---------------TXERFATREV:	.ASCIZ	"La rvision du systme est incompatible"TXERFATMEM:	.ASCIZ	"Problme avec la mmoire"TXERFATGRA:	.ASCIZ	"Module GRA incompatible"TXERFATTXT:	.ASCIZ	"Erreur avec le gencar NEF11"TXERFATICO:	.ASCIZ	"Erreur avec le gencar IPP21"TXERFATICO1:	.ASCIZ	"Erreur avec le gencar IPP22"; Noms des fichiers par dfaut; ----------------------------NMFPEN:		.ASCIZ	"DEF.PPAGE"NMFTRA:		.ASCIZ	"DEF.TPAGE"	.EVENSTART:	LIB	?OPELIB	LOAD.W	D3,#2	LIB	?MOUSE	CALL	_WAITMOUSE	; met le sablier	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour variables	JUMP,NE ERFAT1	GESMEM	?CLEARMEM	; met TOUTES les variables  zro	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	(A6)+OPLCOM,A3	; mm ^ligne de commande	LOAD.B	(A6)+OGCLIST,#-1	NTREL	?GETMACHINE	; D4/A3 <-- paramtres	RL.L	D4,#8		; D4 <-- type de la machine	LOAD.B	(A6)+OMACHINE,D4	LOAD.L	A3,#R16"TXERFATREV	LOAD.W	D4,#H'AAAA	LIB	?GETREV		; D4 <-- rvision du systme	COMP.W	D4,#H'AAAA	; vielle librairie ?	JUMP,EQ ERFAT2		; oui => ERFAT2	COMP.W	D4,#H'100*5+8	; est-ce au moins 5.8 ?	JUMP,LO ERFAT2		; non => ERFAT2	LIB	?GETPDIS	LOAD.L	A0,A4		; A0 <-- ^descripteur de la fentre	LOAD.L	A3,#R16"NMPAGE	LOAD.W	D3,#PAGE_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHPAGE,D1	LOAD.L	A3,#R16"NMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDBOX,D1	LOAD.L	A3,#R16"NMDGENC	LOAD.W	D3,#DGENC_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDGENC,D1	LOAD.L	A3,#R16"NMLIST	LOAD.W	D3,#LIST_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHLIST,D1	LOAD.L	A3,#R16"NMSCROLL	LOAD.W	D3,#SCROLL_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHSCROLL,D1	PAGE_	INIT	JUMP,NE ERFAT2	LOAD.L	A3,#R16"NMCOUPE	LOAD.W	D3,#COUPE_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHCOUPE,D1	LOAD.L	A3,#R16"NMSPLINE	LOAD.W	D3,#SPLINE_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHSPLINE,D1	LOAD.L	A3,#R16"NMSTRETCH	LOAD.W	D3,#ST_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHSTRETCH,D1	LOAD.L	A3,#R16"NMPRINTA	LOAD.W	D3,#PRINTA_FIRST	LIB_	OPEN	JUMP',NE 30$	LOAD.W	(A6)+OCHPRINTA,D1	CLR.L	D3	PRINTA_	OPEN	JUMP,NE ERFAT2	LOAD.L	(A6)+OCAPRINT,A230$:	CALL	_RDSTPRINT	; lit le status de l'imprimante	JUMP,NE ERFAT2	LOAD.L	A3,#R16"TXERFATREV	LOAD.L	D4,#100000	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour listes	JUMP,NE ERFAT2	LOAD.W	D7,#BASE_INIT	PAGE_	BASE		; initialise les listes	LIB	?AFTIM	.B	NOCURS		; pas de curseur	.B	NOEFLI		; pas de EFLI automatique	.B	TRUNC		; tronque les lignes trop longues	.B	MODGRA,GRACLIP	; graphique avec clipping	.B	MMODULO,1	; n'impose plus les modulos	.B	0	.EVEN	LOAD.L	A3,#R16"TXERFATICO	LIB	?AFTIM	.B	LOADGC,GCICF,GCICS,GCICT	.B	0	.EVEN	JUMP,NE ERFAT2	LIB	?AFTIM	.B	USEGC,GCICF,GCICS,GCICT	.B	0	.EVEN	LOAD.L	(A6)+OPGICO,(A0)+ODFPGC	LOAD.L	A3,#R16"TXERFATICO1	LIB	?AFTIM	.B	LOADGC,GCICF,GCICS,GCICT+1	.B	0	.EVEN	JUMP,NE ERFAT2	LIB	?AFTIM	.B	USEGC,GCICF,GCICS,GCICT+1	.B	0	.EVEN	LOAD.L	(A6)+OPHICO,(A0)+ODFPGC	LOAD.L	A3,#R16"TXERFATTXT	LIB	?AFTIM	.B	LOADGC,GCTXF,GCTXS,GCTXT	.B	0	.EVEN	JUMP,NE ERFAT2	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.EVEN	LOAD.L	A4,#(A6)+OBUGC	TSET.B	(A4)+OGCFLG:#BGCPROT	LOAD.B	(A4)+OGCF,#GCTXF	LOAD.B	(A4)+OGCS,#GCTXS	LOAD.B	(A4)+OGCT,#GCTXT	LOAD.L	A3,#(A4)+OGCTIT	LOAD.B	(A3+),#'F	LOAD.B	(A3+),#'o	LOAD.B	(A3+),#'n	LOAD.B	(A3+),#'d	LOAD.L	A2,A0	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A3,#(A6)+OBUGC	DGENC_	NEW		; charge le gencar "Fond"	LOAD.B	(A6)+OOUTIL,#ICOCRAYON	LOAD.B	(A6)+OOBJET,#ICOTM	LOAD.B	(A6)+OSELECT,#ICOZONE	LOAD.L	(A6)+ODEF,#2^BDEFPG!2^BDEFICO!2^BDEFASC!2^BDEFREG!2^BDEFMDC;	CLR.W	(A6)+OSCALE	LOAD.B	(A6)+OSTRRO,#ICOTOURNEP;	CLR.B	(A6)+OSPLOF;	CLR.B	(A6)+OLIBOF	LOAD.W	(A6)+OPAS,#8	LOAD.L	(A6)+OFLAGS,#2^BFLPAN!2^BFLMU4!2^BFLGRN	LOAD.L	(A6)+OVUE,#2^BVUDEF	LOAD.L	(A6)+OMFOND,#2^BFDOBT	LOAD.L	(A6)+OOLMOD,#2^0	LOAD.L	(A6)+OOMMOD,#2^0	LOAD.L	(A6)+OMZMOD,#2^0	LOAD.L	(A6)+OMCMOD,#2^0	LOAD.L	(A6)+OMPMOD,#2^0	LOAD.L	(A6)+ODRTYP,#2^BDRQQ	LOAD.L	(A6)+OFLTYP,#2^BFLQQ!2^BFLE2i!2^BFLL16!2^BFLA27!2^BFLF1;	LOAD.L	(A6)+ORDTYP,#;	CLR.W	(A6)+ORDRAY;	LOAD.L	(A6)+ORATYP,#	LOAD.W	(A6)+ORARAY,#8	LOAD.L	(A6)+OPOTYP,#2^BPOMRAY!2^BPO3	LOAD.L	(A6)+OCETYP,#2^BCEMRAY	LOAD.L	(A6)+OELTYP,#2^BELMRAY	LOAD.L	(A6)+OARTYP,#2^BARCE!2^BARQ!2^BARARC	LOAD.W	(A6)+OARANG,#90	LOAD.L	(A6)+OTXJUS,#2^BTXJUA+H'100*10	LOAD.L	(A6)+OTXITL,#2^BTXILE+10	LOAD.L	(A6)+OTXITC,#2^BTXICP+0	LOAD.L	(A6)+OAJFAN,#2^15	CLR.L	(A6)+OPPOS	LOAD.L	(A6)+OPDIM,#H'10000*5000+5000	LOAD.L	A3,#R16"NMFPEN	LOAD.W	D7,#IO_RPEN	PAGE_	IO		; lit les pinceaux par dfaut	LOAD.L	A3,#R16"NMFTRA	LOAD.W	D7,#IO_RTRAME	PAGE_	IO		; lit les trames par dfaut	CALL	_AFMENU		; affiche les soft-keysREFAIT:	CALL	CALCADRE	; qq calculs pour le cadre	CALL	DESWDO		; dessine la fentre	CALL	DESCADRE	; dessine le cadre	CLR.L	(A6)+OPLDIM	LOAD.W	D7,#DESS_OBJETS	PAGE_	DESS		; dessine les objetsLOOP:	CALL	_SCMO		; remet la souris	CALL	FULLGREYICONE	; (d)grise qq icnes	CALL	_NORMMOUSE	; enlve le sablier20$:	LOAD.B	D3,(A6)+OOUTIL	JUMP',NE 22$	LOAD.B	D3,(A6)+OOBJET22$:	CALL	_SELMO		; utilise le bon lutin	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP',NE 62$	CALL	_RGMOUSE	; dessine la position dans les rgles	LOAD.W	D7,#DET_POINT	PAGE_	DET		; D3 <-- point o est la souris	JUMP',EQ 64$62$:	LOAD.L	D3,#-1		; D3 <-- on est pas dans l'aire de dessin64$:	COMP.L	D3,(A6)+OLASTXY	JUMP',EQ 70$	LOAD.L	(A6)+OLASTXY,D3	CALL	DESINFXY	; affiche X= et Y= dans les informations70$:	LIB	?GETKEY		; attend clavier/souris ...	TEST.L	D3:#BKPSEUDO	; touche presse normale ?	JUMP',BC 74$		; oui => 74$	TEST.L	D3:#BKRELEAS	; changement de touches super-shift ?	JUMP,BS 70$		; non => 70$	JUMP	20$		; oui => 20$74$:	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,EQ 20$		; oui => 20$EXECUTE:	COMP.W	D3,#F0+SHIFT	JUMP',LO 10$	COMP.W	D3,#F15+SHIFT	JUMP',HI 10$	SUB.W	D3,#SHIFT	; (SHIFT-Fn) --> (Fn)10$:	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC	COMP.W	D3,#KEYMMP	JUMP,EQ CLIC	COMP.W	D3,#KEYMDP	JUMP,EQ CLIC	LOAD.L	A1,#0	CALL	DOKASCENSEUR	; agit dans ascenseurs selon touche	JUMP,EQ LOOP	COMP.W	D3,#KEYICO+ICOECHELLE	JUMP,EQ MODIFECHELLE	COMP.W	D3,#KEYICO+ICOMVUE	JUMP,EQ MODIFVUE	COMP.W	D3,#KEYICO+ICOFLAGS	JUMP,EQ MODIFFLAGS	COMP.W	D3,#KEYICO+ICOPDEF	JUMP,EQ MODIFPDEF	COMP.W	D3,#KEYICO+ICOTDEF	JUMP,EQ MODIFTDEF	COMP.W	D3,#KEYICO+ICOFDEF	JUMP,EQ MODIFFDEF	COMP.W	D3,#F0	JUMP,EQ QUITTE	COMP.W	D3,#END	JUMP,EQ QUITTE	COMP.W	D3,#F1	JUMP,EQ _PREND	COMP.W	D3,#H'100*(2^BSHOW)+DEFINE	JUMP,EQ _PREND	COMP.W	D3,#F2	JUMP,EQ _AJOUTE	COMP.W	D3,#F3	JUMP,EQ _SAUVE	COMP.W	D3,#H'100*(2^BCOPY)+DEFINE	JUMP,EQ _SAUVE	COMP.W	D3,#F4	JUMP,EQ MODIFDEF	COMP.W	D3,#F7	JUMP,EQ SCALEM	COMP.W	D3,#F8	JUMP,EQ SCALE1	COMP.W	D3,#F9	JUMP,EQ SCALEP	COMP.W	D3,#F14	JUMP,EQ _EFFACE	COMP.W	D3,#H'100*(2^BPROGRA)+'R	JUMP,EQ REFAIT	COMP.W	D3,#H'100*(2^BPROGRA)+'r	JUMP,EQ REFAIT	COMP.W	D3,#H'100*(2^BPROGRA)+'D	JUMP,EQ DEBUG	COMP.W	D3,#H'100*(2^BPROGRA)+'d	JUMP,EQ DEBUGBIP:	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOPERROR:	TEST.W	D7	JUMP,EQ LOOP	COMP.W	D7,#ERKSTO	JUMP,EQ LOOP	CALL	DBOXERROR	; affiche l'erreur ...	JUMP	LOOPMODIFECHELLE:	CALL	DBOXECHELLE	; demande l'chelle ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	JUMP	SCALEXMODIFVUE:	CALL	DBOXVUE		; demande la vue ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	LOAD.L	A3,#(A6)+OUSE	LOAD.L	A4,(A3)+OLNEXT50$:	COMP.L	A4,A3		; fin de la liste ?	JUMP',EQ 52$		; oui => 52$	LOAD.W	D7,#DET_INIT	PAGE_	DET		; ajuste pour les dtections	LOAD.L	A4,(A4)+OLNEXT	; A4 <-- ^suivant	JUMP	50$52$:	CLR.L	(A6)+OPLDIM	LOAD.W	D7,#DESS_OBJETS	PAGE_	DESS		; dessine les objets	JUMP	LOOPMODIFFLAGS:	CALL	DBOXFLAGS	; demande les flags ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	CLR.L	(A6)+OPLDIM	LOAD.W	D7,#DESS_OBJETS	PAGE_	DESS		; redessine les objets	JUMP	LOOPMODIFDEF:	CALL	DBOXDEF	JUMP,NE ERROR	JUMP	LOOPMODIFPDEF:	CALL	DBOXPDEF	; utilise/modifie un pinceau ...	JUMP,NE ERROR	TEST.W	D4	JUMP',EQ 40$	CLR.L	(A6)+OPLDIM	LOAD.W	D7,#DESS_OBJETS	PAGE_	DESS		; redessine tous les objets40$:	COMP.W	D3,#F1	JUMP,NE LOOP	CALL	DESPDEF		; dessine l'icne du pinceau	JUMP	LOOPMODIFTDEF:	CALL	DBOXTDEF	; utilise/modifie une trame ...	JUMP,NE ERROR	TEST.W	D4	JUMP',EQ 40$	CLR.L	(A6)+OPLDIM	LOAD.W	D7,#DESS_OBJETS	PAGE_	DESS		; redessine tous les objets40$:	COMP.W	D3,#F1	JUMP,NE LOOP	CALL	DESTDEF		; dessine l'icne de la trame	JUMP	LOOPMODIFFDEF:	CALL	DBOXFOND	; choix du fond ...	JUMP,NE ERROR	JUMP	LOOPSCALEM:	LOAD.W	D4,(A6)+OSCALE	DEC.W	D4	COMP.W	D4,#+1	JUMP',NE 20$	DEC.W	D420$:	COMP.W	D4,#-1	JUMP',NE 30$	DEC.W	D430$:	LOAD.W	(A6)+OSCALE,D4	JUMP'	SCALEXSCALE1:	TEST.W	(A6)+OSCALE	JUMP,EQ BIP	CLR.W	(A6)+OSCALE	JUMP'	SCALEXSCALEP:	LOAD.W	D4,(A6)+OSCALE	INC.W	D4	COMP.W	D4,#-1	JUMP',NE 20$	INC.W	D420$:	COMP.W	D4,#+1	JUMP',NE 30$	INC.W	D430$:	LOAD.W	(A6)+OSCALE,D4;	JUMP'	SCALEXSCALEX:	CALL	DESINFSC	; affiche l'chelle	LOAD.L	D4,(A6)+OPPOS	LOAD.L	D3,(A6)+OSDIM	SR.W	D3,#1	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SR.W	D3,#1	ADD.W	D4,D3;	SWAP.W	D3	SWAP.W	D4	LOAD.W	D7,#DET_INITSC	PAGE_	DET		; init selon nouvelle chelle	CLR.L	(A6)+OPLDIM	LOAD.W	D7,#DESS_OBJETS	PAGE_	DESS		; dessine les objets	CALL	MAJCADRE	; mj le cadre (rgles et ascenseurs)	JUMP	LOOPCLIC:	LOAD.W	D2,D3		; D2 <-- bouton press	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP; Traite le cas o la souris est dans un ascenseur.	LOAD.L	A1,#0	CALL	DOMASCENSEUR	; agit dans ascenseurs selon souris	JUMP,EQ LOOP; Traite le cas o la souris est dans une icne.	COMP.W	D2,#KEYMGP	JUMP',NE 20$	CALL	MOVGICONE	; souris dans une icne ?	JUMP,EQ CLICGICONE	; oui => CLICGICONE20$:	COMP.W	D2,#KEYMDP	JUMP',NE 30$	CALL	MOVDICONE	; souris dans une icne ?	JUMP,EQ CLICDICONE	; oui => CLICDICONE30$:	CALL	DPLICONE	; dplace toutes les icnes ?	JUMP,EQ LOOP		; oui => LOOP	LOAD.W	D3,D2		; D3 <-- bouton press	COMP.W	D3,#KEYMGP	JUMP,EQ OUTIL	COMP.W	D3,#KEYMMP;;?	JUMP,EQ MILIEU	COMP.W	D3,#KEYMDP	JUMP,EQ ENTOURE	JUMP	BIPCLICGICONE:	COMP.B	D3,#ICOVZONE	JUMP,EQ	PRESSKEY	COMP.B	D3,#ICOCALQUE	JUMP,EQ	PRESSKEY	COMP.B	D3,#ICOPDEF	JUMP,EQ	PRESSKEY	COMP.B	D3,#ICOTDEF	JUMP,EQ	PRESSKEY	COMP.B	D3,#ICOFDEF	JUMP,EQ	PRESSKEY	COMP.B	D3,#ICOECHELLE	JUMP,EQ	PRESSKEY	COMP.B	D3,#ICOMVUE	JUMP,EQ	PRESSKEY	COMP.B	D3,#ICOFLAGS	JUMP,EQ	PRESSKEY	COMP.B	D3,#ICOIM	JUMP,EQ	_AJOUTE	COMP.B	D3,#ICOVIDE	JUMP,EQ BIP	COMP.B	D3,#ICOMAIN	JUMP,EQ MAINNEW	COMP.B	D3,#ICOPLOUPE	JUMP,EQ LOUPENEW	COMP.B	D3,#ICOOBJET	JUMP,LO OBJETNEW	COMP.B	D3,#ICOOUTIL	JUMP,LO OUTILNEW	COMP.B	D3,#ICOSELECT	JUMP,LO SELECTNEW	JUMP	PRESSKEYCLICDICONE:	TEST.B	(A6)+OMDICO	JUMP,F	BIP	COMP.B	D3,#ICOPLOUPE	JUMP,EQ OL$	COMP.B	D3,#ICOMAIN	JUMP,EQ OM$	COMP.B	D3,#ICOZONE	JUMP,EQ MZ$	COMP.B	D3,#ICOCROCHET	JUMP,EQ MC$	COMP.B	D3,#ICOPOIGNEE	JUMP,EQ MP$	COMP.B	D3,#ICODR	JUMP,EQ DR$	COMP.B	D3,#ICOFL	JUMP,EQ FL$	COMP.B	D3,#ICORA	JUMP,EQ RA$	COMP.B	D3,#ICOPO	JUMP,EQ PO$	COMP.B	D3,#ICOCE	JUMP,EQ CE$	COMP.B	D3,#ICOEL	JUMP,EQ EL$	COMP.B	D3,#ICOAR	JUMP,EQ AR$	JUMP	OBJETNEWOL$:	CALL	DBOXOLDEF	JUMP,NE ERROR	COMP.W	D3,#CR	JUMP,NE LOOP	LOAD.B	D3,#ICOPLOUPE	JUMP	OUTILNEWOM$:	CALL	DBOXOMDEF	JUMP,NE ERROR	COMP.W	D3,#CR	JUMP,NE LOOP	LOAD.B	D3,#ICOMAIN	JUMP	OUTILNEWMZ$:	CALL	DBOXMZDEF	JUMP,NE ERROR	COMP.W	D3,#CR	JUMP,NE LOOP	LOAD.B	D3,#ICOZONE	JUMP	SELECTNEWMC$:	CALL	DBOXMCDEF	JUMP,NE ERROR	COMP.W	D3,#CR	JUMP,NE LOOP	LOAD.B	D3,#ICOCROCHET	JUMP	SELECTNEWMP$:	CALL	DBOXMPDEF	JUMP,NE ERROR	COMP.W	D3,#CR	JUMP,NE LOOP	LOAD.B	D3,#ICOPOIGNEE	JUMP	SELECTNEWDR$:	CALL	DBOXDRDEF	JUMP,NE ERROR	COMP.W	D3,#CR	JUMP,NE LOOP	LOAD.B	D3,#ICODR	JUMP	OBJETNEWFL$:	CALL	DBOXFLDEF	JUMP,NE ERROR	COMP.W	D3,#CR	JUMP,NE LOOP	LOAD.B	D3,#ICOFL	JUMP	OBJETNEWRA$:	CALL	DBOXRADEF	JUMP,NE ERROR	COMP.W	D3,#CR	JUMP,NE LOOP	LOAD.B	D3,#ICORA	JUMP	OBJETNEWPO$:	CALL	DBOXPODEF	JUMP,NE ERROR	COMP.W	D3,#CR	JUMP,NE LOOP	LOAD.B	D3,#ICOPO	JUMP	OBJETNEWCE$:	CALL	DBOXCEDEF	JUMP,NE ERROR	COMP.W	D3,#CR	JUMP,NE LOOP	LOAD.B	D3,#ICOCE	JUMP	OBJETNEWEL$:	CALL	DBOXELDEF	JUMP,NE ERROR	COMP.W	D3,#CR	JUMP,NE LOOP	LOAD.B	D3,#ICOEL	JUMP	OBJETNEWAR$:	CALL	DBOXARDEF	JUMP,NE ERROR	COMP.W	D3,#CR	JUMP,NE LOOP	LOAD.B	D3,#ICOAR	JUMP	OBJETNEWMAINNEW:	TEST.W	(A6)+OASVER+OSCHTV	JUMP,NE OUTILNEW	TEST.W	(A6)+OASHOR+OSCHTV	JUMP,NE OUTILNEW	JUMP	BIP		; si aucun ascenseur => BIPLOUPENEW:	COMP.B	D3,(A6)+OOUTIL	JUMP,EQ BIP	LOAD.B	(A6)+OLOUTIL,(A6)+OOUTIL	LOAD.B	(A6)+OLOBJET,(A6)+OOBJET;	JUMP'	OUTILNEWOUTILNEW:			; change d'outil =>	COMP.B	D3,(A6)+OOUTIL	JUMP,EQ LOOP	PUSH.W	D3	LOAD.B	D3,(A6)+OOUTIL	CALL	INVICONE	; teint l'ancien outil	POP.W	D3	LOAD.B	(A6)+OOUTIL,D3	CALL	INVICONE	; allume le nouvel outil	COMP.B	D3,#ICOMAIN	JUMP',EQ 30$	COMP.B	D3,#ICOPLOUPE	JUMP',NE 50$30$:				; loupe/main =>	LOAD.B	D3,(A6)+OOBJET	CALL	INVICONE	; teint l'ancien objet	CLR.B	(A6)+OOBJET	JUMP	LOOP50$:	LOAD.B	D3,(A6)+OOBJET	; y'a-t-il un objet slectionn ?	JUMP',EQ 60$		; non => 60$	COMP.B	D3,#ICOBN	JUMP,NE LOOP60$:	LOAD.B	D3,#ICOTM	JUMP	OBJETNEW	; utilise l'objet traitOUTILNIL:			; y'a plus d'outil =>	TEST.B	(A6)+OOUTIL	JUMP,EQ LOOP	LOAD.B	D3,(A6)+OOUTIL	CALL	INVICONE	; teint l'ancien outil	CLR.B	(A6)+OOUTIL	JUMP	LOOPOBJETNEW:			; change d'objet =>	COMP.B	D3,(A6)+OOBJET	JUMP,EQ BIP	PUSH.W	D3	LOAD.B	D3,(A6)+OOBJET	CALL	INVICONE	; teint l'ancien objet	POP.W	D3	LOAD.B	(A6)+OOBJET,D3	CALL	INVICONE	; allume le nouvel objet	COMP.B	D3,#ICOBN	JUMP,EQ OUTILNIL	LOAD.B	D3,(A6)+OOUTIL	COMP.B	D3,#ICOMAIN	JUMP',EQ 50$	COMP.B	D3,#ICOPLOUPE	JUMP',EQ 50$	TEST.B	D3	JUMP,NE LOOP50$:	LOAD.B	D3,#ICOCRAYON	JUMP	OUTILNEW	; utilise l'outil crayonSELECTNEW:	COMP.B	D3,(A6)+OSELECT	JUMP,EQ LOOP	PUSH.W	D3	LOAD.B	D3,(A6)+OSELECT	CALL	INVICONE	; teint l'ancienne slection	POP.W	D3	LOAD.B	(A6)+OSELECT,D3	CALL	INVICONE	; allume la nouvelle slection	JUMP	LOOPPRESSKEY:			; clic icne => touche presse	AND.W	D3,#H'FF	OR.W	D3,#KEYICO	; D3 <-- code "touche" presse	JUMP	EXECUTEOUTIL:	LOAD.B	D3,(A6)+OOUTIL	; D3 <-- outil	COMP.B	D3,#ICOMAIN	JUMP,EQ MAIN	COMP.B	D3,#ICOPLOUPE	JUMP,EQ LOUPE	LOAD.B	D3,(A6)+OOBJET	; D3 <-- objet	COMP.B	D3,#ICOTM	JUMP,EQ DRAWTM	COMP.B	D3,#ICOSP	JUMP,EQ DRAWSP	COMP.B	D3,#ICODR	JUMP,EQ DRAWDR	COMP.B	D3,#ICOLB	JUMP,EQ DRAWLB	COMP.B	D3,#ICOFL	JUMP,EQ DRAWFL	COMP.B	D3,#ICORD	JUMP,EQ DRAWRD	COMP.B	D3,#ICORA	JUMP,EQ DRAWRA	COMP.B	D3,#ICOPO	JUMP,EQ DRAWPO	COMP.B	D3,#ICOCE	JUMP,EQ DRAWCE	COMP.B	D3,#ICOEL	JUMP,EQ DRAWEL	COMP.B	D3,#ICOAR	JUMP,EQ DRAWAR	COMP.B	D3,#ICOTX	JUMP,EQ DRAWTX;;?	COMP.B	D3,#ICOIM;;?	JUMP,EQ DRAWIM;;?	COMP.B	D3,#ICOBN;;?	JUMP,EQ DRAWBN	JUMP	BIPQUITTE:	CALL	DBOXQUITTE	; faut-il quitter ?	JUMP,NE ERFAT	COMP.W	D3,#F1	JUMP,NE LOOP	JUMP	ERFATDEBUG:	LIB	?AFTIM	.B	EOP	.B	0	.EVENLOOP$:	LIB	?AFTIM	.ASCIZ	"<CR>(A)joute, (E)nlve, (U)tiliss, (L)ibres, (END) ? "	.EVEN	LIB	?GETCAR	LIB	?MINMAJ	COMP.W	D3,#END	JUMP,EQ REFAIT	COMP.W	D3,#'A	JUMP,EQ AJOUTE$	COMP.W	D3,#'E	JUMP,EQ ENLEVE$	LOAD.L	A4,#(A6)+OUSE	COMP.W	D3,#'U	JUMP,EQ VISUALISE$	LOAD.L	A4,#(A6)+OFREE	COMP.W	D3,#'L	JUMP,EQ VISUALISE$	JUMP	LOOP$AJOUTE$:	LIB	?AFTIM	.ASCIZ	"<CR>Longueur = "	.EVEN	LIB	?GETHEX	CLR.W	D2		; D2 <-- ajoute  la fin de la liste	LOAD.W	D7,#BASE_INSERT	PAGE_	BASE	JUMP,NE ERROR$	LIB	?AFTIM	.ASCIZ	"Pointeur = "	.EVEN	LOAD.L	D4,A4	LIB	?AFX8	JUMP	LOOP$ENLEVE$:	LIB	?AFTIM	.ASCIZ	"<CR>Pointeur = "	.EVEN	LIB	?GETHEX	LOAD.L	A4,D4	LOAD.W	D7,#BASE_REMOVE	PAGE_	BASE	JUMP	LOOP$VISUALISE$:	LIB	?AFCR	LOAD.L	A3,A410$:	LOAD.L	A3,(A3)+OLNEXT	COMP.L	A3,A4	JUMP,EQ LOOP$	LIB	?AFTIM	.ASCIZ	"<CR>Pointeur = "	.EVEN	LOAD.L	D4,A3	LIB	?AFX8	LIB	?AFTIM	.ASCIZ	"    Longueur = "	.EVEN	LOAD.W	D4,(A3)+OLLG	LIB	?AFX4	JUMP	10$ERROR$:	LIB	?AFTIM	.ASCIZ	"<CR>Erreur ..."	.EVEN	JUMP	LOOP$ERFAT:	LOAD.W	D1,(A6)+OCHPAGE	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHDGENC	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHLIST	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSCROLL	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHCOUPE	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSPLINE	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSTRETCH	LIB_	CLOSE	TEST.L	(A6)+OCAPRINT	JUMP',EQ 50$	LOAD.L	A2,(A6)+OCAPRINT	PRINTA_	CLOSE	LOAD.W	D1,(A6)+OCHPRINTA	LIB_	CLOSE50$:ERFAT1:	LIB	?CLOLIB	FOS	?STOPERFAT3:	LOAD.L	A3,A1		; A3 <-- ^messageERFAT2:	PUSH.W	D7	LIB	?AFTIM	.B	NOCURS,CR,CR	.ASCIZ	"ERREUR FATALE: "	.EVEN	LIB	?AFTEXT		; affiche le message	LIB	?AFCR	POP.W	D7	JUMP',EQ 50$	LIB	?AFERROR	; affiche l'erreur	LIB	?AFCR50$:	LIB	?GETCAR		; attend une touche ...	JUMP	ERFAT	.INS	PAGEOBJET.ASI	.INS	PAGEMODIF.ASI	.INS	PAGEDETECT.ASI	.INS	PAGEICONE.ASI	.INS	PAGECADRE.ASI_WAITMOUSE:	JUMP	WAITMOUSE_NORMMOUSE:	JUMP	NORMMOUSE_IFMOUSE:	JUMP	IFMOUSE_RGMOUSE:	JUMP	RGMOUSE_SELMO:		JUMP	SELMO_SCMO:		JUMP	SCMO_CCMO:		JUMP	CCMO_AFMENU:	JUMP	AFMENU_RDSTPRINT:	JUMP	RDSTPRINT_PREND:		JUMP	PREND_AJOUTE:	JUMP	AJOUTE_SAUVE:		JUMP	SAUVE_EFFACE:	JUMP	EFFACE_WAITMOVE:	JUMP	WAITMOVE_LOOP:		JUMP	LOOP_REFAIT:	JUMP	REFAIT_ERROR:		JUMP	ERROR	.INS	PAGEDBOX.ASI	.INS	PAGEDBOXT.ASI	.INS	PAGEIO.ASI	.INS	PAGEMISC.ASI	.INS	PAGETAB2.ASI	.END	START