	.SBTTL	PAGEDBOX;----------\\; DBOXSAUVE >;==========/; Edite un nom de fichier en sortie.; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F4/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXSAUVE:	PUSHM.L	D1,D2,D4,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"TEXPA	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_SAUVE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1	TSET.L	D3:#BDBIONMAJ	; D3 <-- touche (MET A JOUR) grise	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	CALL	DBOXCLOSE190$:	POPM.L	D1,D2,D4,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXCREATE >;===========/; Cre un fichier ".PAGE".; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXCREATE:	PUSHM.L	D0..D2,D4,D5,A2..A410$:	CALL	DBOXSAUVE	; demande le nom ...	JUMP,NE 90$	COMP.W	D3,#F0	JUMP,EQ	90$	LOAD.L	D2,#DEFATT	; D2 <-- attributs par dfaut20$:	LOAD.L	D3,D2		; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	LOAD.L	D0,#FOS?CREATE	CALL	ERCALL		; cre le fichier	JUMP,EQ	70$		; ok => 70$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE	90$		; non => 90$				; oui =>	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	JUMP',NE 90$	CALL	DBOXCLOSE1	; remet les soft-keys	COMP.W	D3,#'O	JUMP,NE 10$	LOAD.L	A4,#(A6)+OBUDIS	LOAD.L	D0,#FOS?ARGS	CALL	ERCALL		; demande les arguments du fichier	JUMP',NE 90$	LOAD.L	D2,(A4)+OBAATT	; D2 <-- arguments du fichier	LOAD.L	D0,#FOS?DELETE	CALL	ERCALL		; dtruit le fichier	JUMP',NE 90$	JUMP	20$70$:	LOAD.W	D3,#F1		; D3 <-- (RETURN)	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D2,D4,D5,A2..A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBOXEXTRAIT >;============/; Edite un nom de fichier en sortie (extraction).; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXEXTRAIT:	PUSHM.L	D1,D2,D4,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"TEXPA	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_EXTRAIT; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	CALL	DBOXCLOSE190$:	POPM.L	D1,D2,D4,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXPREND >;==========/; Edite un nom de fichier en entre (prend).; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXPREND:	PUSHM.L	D1,D2,D4,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"TEXPA	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_PREND	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	CALL	DBOXCLOSE190$:	POPM.L	D1,D2,D4,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXAJOUTE >;===========/; Edite un nom de fichier en entre (ajoute).; in	A3.L	^nom du fichier;	D4.L	fanions; out	D3.W	dernire touche (F1/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXAJOUTE:	PUSHM.L	D1,D2,D5,A2..A5	CALL	DBOXOPEN1	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A2,#R16"TDBOX_AJOUTE	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"TEXAJ	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_AJOUTE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOOBJ!2^BDBIOEXTM	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	CALL	DBOXCLOSE190$:	POPM.L	D1,D2,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBOXPRENDTX >;============/; Edite un nom de texte en entre.; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXPRENDTX:	PUSHM.L	D1,D2,D4,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IOTX	LOAD.L	A4,#R16"TEXTX	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_PREND	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1!2^BDBIOFULL	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	CALL	DBOXCLOSE1	POPM.L	D1,D2,D4,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-------------\\; DBOXAJOUTETX >;=============/; Edite un nom de texte en entre.; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXAJOUTETX:	PUSHM.L	D1,D2,D4,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IOTX	LOAD.L	A4,#R16"TEXTX	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_AJOUTE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1!2^BDBIOFULL	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	CALL	DBOXCLOSE1	POPM.L	D1,D2,D4,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBOXSAUVETX >;============/; Edite un nom de texte en entre.; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXSAUVETX:	PUSHM.L	D1,D2,D4,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IOTX	LOAD.L	A4,#R16"TEXTX	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_SAUVE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1!2^BDBIOFULL	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	CALL	DBOXCLOSE1	POPM.L	D1,D2,D4,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;--------------\\; DBOXEXTRAITTX >;==============/; Edite un nom de texte en entre.; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXEXTRAITTX:	PUSHM.L	D1,D2,D4,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IOTX	LOAD.L	A4,#R16"TEXTX	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_EXTRAIT ; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1!2^BDBIOFULL	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	CALL	DBOXCLOSE1	POPM.L	D1,D2,D4,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-------------\\; DBOXCREATETX >;=============/; Cre un fichier texte.; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXCREATETX:	PUSHM.L	D0..D2,D4,D5,A2..A410$:	CALL	DBOXSAUVETX	; demande le nom ...	JUMP,NE 90$	COMP.W	D3,#F0	JUMP,EQ	90$	LOAD.L	D2,#DEFATT	; D2 <-- attributs par dfaut20$:	LOAD.L	D3,D2		; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	LOAD.L	D0,#FOS?CREATE	CALL	ERCALL		; cre le fichier	JUMP,EQ	70$		; ok => 70$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE	90$		; non => 90$				; oui =>	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	JUMP',NE 90$	CALL	DBOXCLOSE1	; remet les soft-keys	COMP.W	D3,#'O	JUMP,NE 10$	LOAD.L	A4,#(A6)+OBUDIS	LOAD.L	D0,#FOS?ARGS	CALL	ERCALL		; demande les arguments du fichier	JUMP',NE 90$	LOAD.L	D2,(A4)+OBAATT	; D2 <-- arguments du fichier	LOAD.L	D0,#FOS?DELETE	CALL	ERCALL		; dtruit le fichier	JUMP',NE 90$	JUMP	20$70$:	LOAD.W	D3,#F1		; D3 <-- (RETURN)	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D2,D4,D5,A2..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXSAVE >;=========/; Sauve le dessin selon le choix de l'utilisateur.; in	D0.W	mode (0=quitte, 1=nouveau texte); out	D7.W	0	=> ok, on peut quitter;		1	=> (ANNULE), donc on reste;		autre	=> erreur grve; mod	D7.WDBOXSAVE:	PUSHM.L	D1..D5,A2..A5	TEST.B	(A6)+OMAJ	; mise  jour ncessaire ?	JUMP,F	80$		; non => 80$ (quitte, snif)				; oui =>	LOAD.L	A3,#(A6)+OUSE	COMP.L	A3,(A3)+OLNEXT	; liste vide ?	JUMP',NE 10$		; non => 10$				; oui =>	CLR.B	(A6)+OMAJ	; fait comme si dessin  jour	JUMP	80$10$:	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	CLR.L	D3	LOAD.W	D3,(A6)+ONOZO	INC.B	D3		; D3 <-- numro de la page  afficher	COMP.B	D3,#NBZONE	JUMP',NE 20$	CLR.B	D320$:	TEST.B	D0	JUMP',NE 25$	TSET.L	D3:#BDBIOQUIT	; D3 <-- texte "avant de quitter"25$:	LOAD.L	A5,#(A6)+OBUNAME; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_MAJ	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	CALL	DBOXCLOSE1	COMP.W	D3,#F0		; ANNULE ?	JUMP',EQ 85$	COMP.W	D3,#F4		; NON ?	JUMP',EQ 80$	OR.W	D2,D4		; D2 <-- met aussi les fanions (pour BDBDEF);;?	CALL	SAUVETOUT	; sauve tout sur disque (in D2.W !)	JUMP'	90$80$:	CLR.W	D7		; D7 <-- quitte	JUMP'	90$85$:	LOAD.W	D7,#1		; D7 <-- reste90$:	POPM.L	D1..D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXQUITTE >;===========/; Demande si l'on veut quitter DESSIN.; in	-; out	D3.W	dernire touche (F1/F4);	D7.W	erreur; mod	D3.L, D7.WDBOXQUITTE:	PUSHM.L	D1,D2,D4,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_QUITTE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	CLR.L	D3	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	CALL	DBOXCLOSE190$:	POPM.L	D1,D2,D4,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXEFFACE >;===========/; Demande s'il faut effacer le dessin.; in	-; out	D3.W	dernire touche (F1/F4);	D7.W	erreur; mod	D3.L, D7.WDBOXEFFACE:	PUSHM.L	D1,D2,D4,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	CLR.L	D3	LOAD.W	D3,(A6)+ONOZO	INC.B	D3		; D3 <-- numro de la page  afficher	COMP.B	D3,#NBZONE	JUMP',NE 20$	CLR.B	D320$:	LOAD.L	A5,#(A6)+OBUNAME; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_EFFACE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	CALL	DBOXCLOSE1	POPM.L	D1,D2,D4,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBOXECHELLE >;============/; Demande l'chelle.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXECHELLE:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.W	D3,#ICOECHELLE	CALL	INVALLICONE	; allume l'icne	LOAD.L	A2,#R16"TDBOX_ECHELLE	LOAD.W	D2,#2^BDBSAV	LOAD.L	D4,#B'01	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	EX.L	D3,D4	LOAD.L	A3,#(A6)+OBUDIS	LOAD.L	A4,A3	LOAD.W	D4,(A6)+OSCALE	JUMP',NE 10$	INC.W	D410$:	JUMP',NC 12$	NEG.W	D4	LOAD.L	D3,#B'1012$:	CALL	PUTANUM	CLR.B	(A4)	EX.L	D4,D320$:	DBOX_	EDIT		; attend action ...	CALL	ZEROCR	LOAD.L	A1,#R16"TKEY_ECHELLE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1	JUMP,EQ 60$	COMP.W	D3,#F0	JUMP,EQ 80$25$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$60$:	PUSHM.L	D4,A4	LOAD.L	A4,A3	CALL	GETANUM	LOAD.W	D2,D4	POPM.L	D4,A4	COMP.W	D2,#1	JUMP',NE 62$	DEC.W	D262$:	TEST.L	D4:#1	JUMP',BC 63$	NEG.W	D263$:	LOAD.W	(A6)+OSCALE,D280$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOX90$:	PUSHM.L	D3,D7	LOAD.W	D3,#ICOECHELLE	CALL	INVALLICONE	; teint l'icne	POPM.L	D3,D7	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBOXVUE >;========/; Demande la vue.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXVUE:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.W	D3,#ICOMVUE	CALL	INVALLICONE	; allume l'icne	LOAD.L	A2,#R16"TDBOX_VUE	LOAD.W	D2,#2^BDBSAV	LOAD.L	D4,(A6)+OVUE	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$20$:	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_VUE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1	JUMP',EQ 60$	COMP.W	D3,#F0	JUMP',EQ 80$25$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$60$:	LOAD.L	(A6)+OVUE,D480$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOX90$:	PUSHM.L	D3,D7	LOAD.W	D3,#ICOMVUE	CALL	INVALLICONE	; teint l'icne	POPM.L	D3,D7	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXFLAGS >;==========/; Demande le pas et la grille.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXFLAGS:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.W	D3,#ICOFLAGS	CALL	INVALLICONE	; allume l'icne	LOAD.L	A2,#R16"TDBOX_FLAGS	LOAD.W	D2,#2^BDBSAV	LOAD.L	D4,(A6)+OFLAGS	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	PUSH.L	D4	LOAD.L	A3,#(A6)+OBUDIS	LOAD.L	A4,A3	LOAD.W	D4,(A6)+OPAS	CALL	PUTANUM	CLR.B	(A4);	POP.L	D4;	PUSH.L	D4	LOAD.W	D2,#SETDOT	LOAD.W	D3,(A0)+ODFCX	MUL.WU	D3,#23+1-1	LOAD.W	D4,(A0)+ODFCY	MUL.WU	D4,#7	SUB.W	D4,#5	SWAP.W	D4	LIB	?DRSEG	LOAD.W	D3,(A0)+ODFCY	MUL.WU	D3,#7	SUB.W	D3,#5	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	LIB	?DRSEG	LOAD.W	D3,(A0)+ODFCY	MUL.WU	D3,#11	SUB.W	D3,#5	SWAP.W	D3	LIB	?DRSEG	POP.L	D420$:	DBOX_	EDIT		; attend action ...	CALL	ZEROCR	LOAD.L	A1,#R16"TKEY_FLAGS	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1	JUMP,EQ 60$	COMP.W	D3,#F0	JUMP,EQ 80$	COMP.W	D3,#'-	JUMP,EQ 30$	COMP.W	D3,#'+	JUMP,EQ 30$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYICO	JUMP,EQ 50$25$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$30$:	LOAD.W	D1,#2	TEST.L	D4:#BFLMU2	JUMP',BS 32$	LOAD.W	D1,#3	TEST.L	D4:#BFLMU3	JUMP',BS 32$	LOAD.W	D1,#4	TEST.L	D4:#BFLMU4	JUMP',BS 32$	LOAD.W	D1,#5	TEST.L	D4:#BFLMU5	JUMP',BS 32$	LOAD.W	D1,#6	TEST.L	D4:#BFLMU6	JUMP',BS 32$	LOAD.W	D1,#832$:	PUSH.L	D4	PUSH.L	A4	LOAD.L	A4,A3	CALL	GETANUM		; D4 <-- pas actuel	POP.L	A4	COMP.W	D3,#'-	JUMP',NE 33$	NEG.W	D133$:	ADD.W	D4,D1		; D4 <-- pas suivant	COMP.W	D4,#2	JUMP',LT 38$	COMP.W	D4,#99	JUMP',GT 38$	LOAD.L	A4,A3	CALL	PUTANUM	CLR.B	(A4)38$:	POP.L	D4	AND.L	D4,#H'FFFFFF00	TSET.L	D4:#BFLPAX	JUMP	20$50$:	LOAD.L	D1,#H'FFFFFF00	COMP.B	D3,#8	JUMP',LO 52$	LOAD.L	D1,#H'FFFF00FF	COMP.B	D3,#16	JUMP',LO 52$	LOAD.L	D1,#H'FF00FFFF;	COMP.B	D3,#24;	JUMP',LO 52$;	LOAD.L	D1,#H'00FFFFFF52$:	AND.L	D4,D1		; D4 <-- teint toute la range	TSET.L	D4:D3		; D4 <-- allume juste le bon	JUMP	20$60$:	PUSHM.L	D4,A4	LOAD.L	A4,A3	CALL	GETANUM	LOAD.W	D2,D4	POPM.L	D4,A4	COMP.W	D2,#2	JUMP,LO 25$	COMP.W	D2,#99	JUMP,HI 25$	LOAD.W	(A6)+OPAS,D2	LOAD.L	(A6)+OFLAGS,D4	CALL	DBOXCLOSE	; ferme la DBOX	CALL	DESINFPA	; affiche le pas	CLR.W	D7		; D7 <-- ok	JUMP'	90$80$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOX90$:	PUSHM.L	D3,D7	LOAD.W	D3,#ICOFLAGS	CALL	INVALLICONE	; teint l'icne	POPM.L	D3,D7	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXTDEF >;=========/; Dfini une trame quelconque.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXTDEF:	LOAD.W	D3,#ICOTDEF	CALL	INVALLICONE	; allume l'icne	CALL	DBOXOPEN1	; prpare la souris	LOAD.W	D7,#DBOX_TRAME	PAGE_	DBOX		; utilise/modifie une trame ...	CALL	DBOXCLOSE1	; refait les soft-keys	PUSHM.L	D3,D7	LOAD.W	D3,#ICOTDEF	CALL	INVALLICONE	; teint l'icne	POPM.L	D3,D7	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXPDEF >;=========/; Dfini un pinceau quelconque.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXPDEF:	LOAD.W	D3,#ICOPDEF	CALL	INVALLICONE	; allume l'icne	CALL	DBOXOPEN1	; prpare la souris	LOAD.W	D7,#DBOX_PEN	PAGE_	DBOX		; utilise/modifie un pinceau ...	CALL	DBOXCLOSE1	; refait les soft-keys	PUSHM.L	D3,D7	LOAD.W	D3,#ICOPDEF	CALL	INVALLICONE	; teint l'icne	POPM.L	D3,D7	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBOXDEF >;========/; Change les dfinitions gnrales.; in	-; out	D7.W	erreur; mod	D7.WDBOXDEF:	PUSHM.L	D0..D5,A1..A4	LOAD.L	A2,#R16"TDBOX_DEFINE	LOAD.W	D2,#2^BDBSAV	LOAD.L	D4,(A6)+ODEF	; D4 <-- fanions	TCLR.L	D4:#BDEFZOOM	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	LOAD.L	D2,D4		; D2 <-- fanions	LOAD.L	D4,(A6)+OPDIM	; D4 <-- dimensions (y;x)10$:	TEST.L	D2:#BDEFMM	; unit "millimtre" ?	JUMP',BC 12$		; non => 12$	LOAD.L	D1,D4	CALL	CONVPMX		; D4 <-- largeur [mm]	EX.L	D4,D1	SWAP.W	D4	CALL	CONVPMY		; D4 <-- hauteur [mm]	SWAP.W	D4	LOAD.W	D4,D112$:	LOAD.L	A3,#(A6)+OBUDIS	LOAD.L	A4,A3	CALL	PUTANUM	LOAD.B	(A4+),#SPACE	LOAD.B	(A4+),#'x	; sparateur	LOAD.B	(A4+),#SPACE	SWAP.W	D4	CALL	PUTANUM	CLR.B	(A4)		; terminateur20$:	LOAD.L	D0,D2		; D0 <-- anciens fanions	LOAD.L	D4,D2		; D4 <-- fanions	DBOX_	EDIT		; attend action ...	LOAD.L	D2,D4		; D2 <-- fanions	LOAD.L	A1,#R16"TKEY_DEFINE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#CR	JUMP,EQ 60$	COMP.W	D3,#END	JUMP,EQ 80$	COMP.W	D3,#FNCT	JUMP',EQ 30$	COMP.W	D3,#DEFINE	JUMP',EQ 35$	COMP.W	D3,#UNDO	JUMP',EQ 40$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYICO	JUMP,EQ 50$25$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$30$:				; ECRAN =>	LOAD.L	D4,(A6)+OWDIM	JUMP	10$35$:				; PAGE =>	CALL	WAITMOUSE	; souris: met le sablier	CALL	RDSTPRINT	; lit le status de l'imprimante ...	CALL	NORMMOUSE	; souris: remet la flche	CLR.L	D4	LOAD.W	D4,(A6)+OSTPRI+OPRHTP	SUB.W	D4,(A6)+OSTPRI+OPRMGS	SUB.W	D4,(A6)+OSTPRI+OPRMGI;;?	SUB.W	D4,(A6)+OSTPRI+OPRITL ; <<<<<<<<<< A SUPPRIMER, VOIR AVEC FK <<<<<<<<<<	DIV.WU	D4,(A6)+OFACY	SWAP.W	D4	CLR.L	D3	LOAD.W	D3,(A6)+OSTPRI+OPRLGP	DIV.WU	D3,(A6)+OFACX	LOAD.W	D4,D3	JUMP	10$40$:				; UNDO =>	LOAD.L	A4,A3	CLR.B	(A4)		; vide toute la ligne	JUMP	20$50$:				; changement d'unit =>	LOAD.B	D1,D3	LOAD.L	D2,D0		; D2 <-- anciens fanions	PUSH.L	D1	CALL	DBDEFPUT	; D3/D4 <-- largeur/hauteur	POPM.L	D1	JUMP,NE 25$	TCLR.L	D2:#BDEFMM	TCLR.L	D2:#BDEFPG	TSET.L	D2:D1		; D2 <-- allume le bon fanion	SWAP.W	D4	LOAD.W	D4,D3		; D4 <-- nouvelle dimensions (y;x)	JUMP	10$60$:				; D'ACCORD =>	LOAD.L	D0,(A6)+ODEF	XOR.L	D0,D2		; D0 <-- fanions modifis	TCLR.L	D2:#BDEFZOOM	LOAD.L	(A6)+ODEF,D2	CALL	DBDEFPUT	; D3/D4 <-- largeur/hauteur	JUMP,NE 25$	CALL	DBOXCLOSE	; ferme la DBOX	TEST.W	D1		; dimensions modifies ?	JUMP',NE 74$		; oui => 74$	TEST.L	D0:#BDEFICO	JUMP',BS 73$	TEST.L	D0:#BDEFASC	JUMP',BS 74$	TEST.L	D0:#BDEFREG	JUMP',BS 74$	CLR.W	D7	JUMP	90$73$:				; montre/cache les icnes =>	CALL	CCMO		; enlve la souris	CALL	CALCADRE	CALL	DESWDO	LOAD.W	D4,(A6)+OSCALE;;?	CALL	CALSCALE	; calcul selon nouvelles dimensions	CALL	DESCADRE	LOAD.W	D7,#DESS_OBJETS	PAGE_	DESS		; dessine les objets	CLR.W	D7		; D7 <-- ok	JUMP'	90$74$:				; montre/cache les ascenseurs =>	CALL	CALCADRE	LOAD.W	D4,(A6)+OSCALE;;?	CALL	CALSCALE	; calcul selon nouvelles dimensions	CALL	DESCADRE	LOAD.W	D7,#DESS_OBJETS	PAGE_	DESS		; dessine les objets	CLR.W	D7		; D7 <-- ok	JUMP'	90$80$:				; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOX90$:	POPM.L	D0..D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBDEFPUT >;---------/; Met  jour les valeurs.; in	D2.L	fanions;	A3.L	^ligne en dition; out	D3.W	largeur;	D4.W	hauteur;	D1.W	0 => valeurs pas modifies;	D7.W	erreur (syntaxe); mod	D1.L, D3.L, D4.L, D7.WDBDEFPUT:	PUSHM.L	D2,A4	CLR.W	D1	LOAD.L	A4,A3		; A4 <-- ^1er nombre	CALL	GETANUM		; D4 <-- largeur	TEST.L	D2:#BDEFMM	JUMP',BC 10$	CALL	CONVMPX		; D4 <-- largeur [pg]10$:	COMP.W	D4,#8	JUMP',HS 20$	LOAD.W	D4,#820$:	AND.B	D4,#B'11111000	; D4 <-- modulo 8 en X !	COMP.W	D4,(A6)+OPDIM+2	; idem ?	JUMP',EQ 30$		; oui => 30$	INC.W	D1		; non => signal30$:	LOAD.W	D7,#1		; D7 <-- erreur de syntaxe	LOAD.B	D3,(A4+)	; D3 <-- sparateur	JUMP',EQ 90$	COMP.B	D3,#CR	JUMP',EQ 90$	COMP.B	D3,#'0	JUMP,LO	30$	COMP.B	D3,#'9	JUMP,HI	30$	DEC.L	A4		; A4 <-- ^2me nombre	LOAD.W	D3,D4		; D3 <-- largeur	CALL	GETANUM		; D4 <-- hauteur	TEST.L	D2:#BDEFMM	JUMP',BC 50$	PUSH.W	D3	CALL	CONVMPY		; D4 <-- hauteur [pg]	POP.W	D350$:	COMP.W	D4,#8	JUMP',HS 60$	LOAD.W	D4,#860$:	AND.B	D4,#B'11111110	; D4 <-- modulo 2 en Y !	COMP.W	D4,(A6)+OPDIM+0	; idem ?	JUMP',EQ 70$		; oui => 70$	INC.W	D1		; non => signal70$:	CLR.W	D7		; D7 <-- ok	LOAD.B	D2,(A4+)	JUMP',EQ 90$	COMP.B	D2,#CR	JUMP',EQ 90$	COMP.B	D2,#SPACE	JUMP,EQ 70$	LOAD.W	D7,#1		; D7 <-- erreur de syntaxe90$:	POPM.L	D2,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; PUTANUM >;--------/; Met un nombre dcimal dans un buffer.; in	D4.W	nombre;	A4.L	^dans buffer; out	A4.L	^plus loin; mod	A4.LPUTANUM:	PUSHM.L	D2,D3,D4	AND.L	D4,#H'FFFF	; D4 <-- nombre binaire	LIB	?BINBCD		; D4 <-- nombre BCD	LOAD.W	D2,#8		; D2 <-- nb digits + flags10$:	RL.L	D4,#4		; D4 <-- pousse d'un digit	LOAD.B	D3,D4	AND.B	D3,#H'0F	; D3 <-- 0..9	JUMP',NE 40$		; si 1..9 => 40$	COMP.B	D2,#1		; dernier digit ?	JUMP',EQ 40$		; oui => 40$	TEST.L	D2:#10		; zro significatif ?	JUMP',BC 50$		; non => 50$40$:	ADD.B	D3,#'0		; D3 <-- '0..'9	LOAD.B	(A4+),D3	TSET.L	D2:#1050$:	DEC.B	D2	JUMP,NE	10$	POPM.L	D2,D3,D4	RET;--------\\; GETANUM >;--------/; Donne un nombre dcimal.; in	A4.L	^dans buffer; out	A4.L	^plus loin;	D4.L	nombre; mod	D4.L, A4.LGETANUM:	PUSH.L	D3	CLR.L	D4		; D4 <-- futur nombre10$:	CLR.L	D3	LOAD.B	D3,(A4+)	COMP.B	D3,#'0	JUMP',LO 50$	COMP.B	D3,#'9	JUMP',HI 50$	SUB.B	D3,#'0		; D3 <-- 0..9	MUL.WU	D4,#10		; D4 <-- pousse d'un digit	ADD.L	D4,D3		; D4 <-- ajoute nouveau digit	JUMP	10$50$:	DEC.L	A4		; D4 <-- ^terminateur	POP.L	D3	RET;---------\\; DBOXFOND >;=========/; Dbox pour choisir le fond des objets.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXFOND:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.W	D3,#ICOFDEF	CALL	INVALLICONE	; allume l'icne	LOAD.L	A2,#R16"TDBOX_FOND	LOAD.L	D4,(A6)+OMFOND	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	PUSH.L	D4	LOAD.W	D2,#SETDOT	LOAD.W	D3,(A0)+ODFCX	MUL.WU	D3,#28+1	LOAD.W	D4,(A0)+ODFCY	MUL.WU	D4,#13	SUB.W	D4,#5	SWAP.W	D4	LIB	?DRSEG	LOAD.W	D3,(A0)+ODFCY	MUL.WU	D3,#3	SUB.W	D3,#5	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	LIB	?DRSEG	LOAD.W	D3,(A0)+ODFCY	MUL.WU	D3,#7	SUB.W	D3,#5	SWAP.W	D3	LIB	?DRSEG	LOAD.W	D3,(A0)+ODFCY	MUL.WU	D3,#11	SUB.W	D3,#5	SWAP.W	D3	LIB	?DRSEG	LOAD.W	D3,(A0)+ODFCY	MUL.WU	D3,#13	SUB.W	D3,#5	SWAP.W	D3	LIB	?DRSEG	POP.L	D420$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_FOND	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#CR		; D'ACCORD ?	JUMP',EQ 60$	COMP.W	D3,#END		; ANNULE ?	JUMP',EQ 80$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$60$:	LOAD.L	(A6)+OMFOND,D480$:	CALL	DBOXCLOSE	; ferme la DBOX90$:	PUSHM.L	D3,D7	LOAD.W	D3,#ICOFDEF	CALL	INVALLICONE	; teint l'icne	POPM.L	D3,D7	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXOLDEF >;==========/; Dbox pour choisir le mode de l'outil loupe.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXOLDEF:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.W	D3,#ICOPLOUPE	CALL	INVALLICONE	; allume l'icne	LOAD.L	D4,(A6)+OOLMOD	LOAD.L	A2,#R16"TDBOX_OLDEF	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_OLDEF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#CR		; D'ACCORD ?	JUMP',EQ 70$	COMP.W	D3,#END		; ANNULE ?	JUMP',EQ 80$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$70$:	LOAD.L	(A6)+OOLMOD,D480$:	CALL	DBOXCLOSE	; ferme la DBOX90$:	PUSHM.L	D3,D7	LOAD.W	D3,#ICOPLOUPE	CALL	INVALLICONE	; teint l'icne	POPM.L	D3,D7	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXOMDEF >;==========/; Dbox pour choisir le mode de l'outil main.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXOMDEF:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.W	D3,#ICOMAIN	CALL	INVALLICONE	; allume l'icne	LOAD.L	D4,(A6)+OOMMOD	LOAD.L	A2,#R16"TDBOX_OMDEF	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_OMDEF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#CR		; D'ACCORD ?	JUMP',EQ 70$	COMP.W	D3,#END		; ANNULE ?	JUMP',EQ 80$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$70$:	LOAD.L	(A6)+OOMMOD,D480$:	CALL	DBOXCLOSE	; ferme la DBOX90$:	PUSHM.L	D3,D7	LOAD.W	D3,#ICOMAIN	CALL	INVALLICONE	; teint l'icne	POPM.L	D3,D7	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXMZDEF >;==========/; Dbox pour choisir le mode des modifications de zones.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXMZDEF:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.W	D3,#ICOZONE	CALL	INVALLICONE	; allume l'icne	LOAD.L	D4,(A6)+OMZMOD	LOAD.L	A2,#R16"TDBOX_MZDEF	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_MZDEF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#CR		; D'ACCORD ?	JUMP',EQ 70$	COMP.W	D3,#END		; ANNULE ?	JUMP',EQ 80$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$70$:	LOAD.L	(A6)+OMZMOD,D480$:	CALL	DBOXCLOSE	; ferme la DBOX90$:	PUSHM.L	D3,D7	LOAD.W	D3,#ICOZONE	CALL	INVALLICONE	; teint l'icne	POPM.L	D3,D7	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXMCDEF >;==========/; Dbox pour choisir le mode des modifications avec le crochet.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXMCDEF:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.W	D3,#ICOCROCHET	CALL	INVALLICONE	; allume l'icne	LOAD.L	D4,(A6)+OMCMOD	LOAD.L	A2,#R16"TDBOX_MCDEF	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_MCDEF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#CR		; D'ACCORD ?	JUMP',EQ 70$	COMP.W	D3,#END		; ANNULE ?	JUMP',EQ 80$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$70$:	LOAD.L	(A6)+OMCMOD,D480$:	CALL	DBOXCLOSE	; ferme la DBOX90$:	PUSHM.L	D3,D7	LOAD.W	D3,#ICOCROCHET	CALL	INVALLICONE	; teint l'icne	POPM.L	D3,D7	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXMPDEF >;==========/; Dbox pour choisir le mode des modifications avec les poignes.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXMPDEF:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.W	D3,#ICOPOIGNEE	CALL	INVALLICONE	; allume l'icne	LOAD.L	D4,(A6)+OMPMOD	LOAD.L	A2,#R16"TDBOX_MPDEF	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_MPDEF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#CR		; D'ACCORD ?	JUMP',EQ 70$	COMP.W	D3,#END		; ANNULE ?	JUMP',EQ 80$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$70$:	LOAD.L	(A6)+OMPMOD,D480$:	CALL	DBOXCLOSE	; ferme la DBOX90$:	PUSHM.L	D3,D7	LOAD.W	D3,#ICOPOIGNEE	CALL	INVALLICONE	; teint l'icne	POPM.L	D3,D7	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXDRDEF >;==========/; Dbox pour choisir le mode pour les droites.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXDRDEF:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.W	D3,#ICODR	CALL	INVALLICONE	; allume l'icne	LOAD.L	D4,(A6)+ODRTYP	LOAD.L	A2,#R16"TDBOX_DRDEF	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_DRDEF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#CR		; D'ACCORD ?	JUMP',EQ 70$	COMP.W	D3,#END		; ANNULE ?	JUMP',EQ 80$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$70$:	LOAD.L	(A6)+ODRTYP,D480$:	CALL	DBOXCLOSE	; ferme la DBOX90$:	PUSHM.L	D3,D7	LOAD.W	D3,#ICODR	CALL	INVALLICONE	; teint l'icne	POPM.L	D3,D7	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXFLDEF >;==========/; Dbox pour choisir le mode pour les flches.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXFLDEF:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.W	D3,#ICOFL	CALL	INVALLICONE	; allume l'icne	LOAD.L	D4,(A6)+OFLTYP	LOAD.L	A2,#R16"TDBOX_FLDEF	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	PUSH.L	D4	LOAD.W	D2,#SETDOT	LOAD.W	D3,(A0)+ODFCX	MUL.WU	D3,#13+1	LOAD.W	D4,(A0)+ODFCY	MUL.WU	D4,#11	SUB.W	D4,#5	SWAP.W	D4	LIB	?DRSEG	LOAD.W	D3,(A0)+ODFCX	MUL.WU	D3,#13+12+1	LIB	?DRSEG	LOAD.W	D3,(A0)+ODFCX	MUL.WU	D3,#13+12+10+1	LIB	?DRSEG	LOAD.W	D3,(A0)+ODFCX	MUL.WU	D3,#13+12+10+10+1	LIB	?DRSEG	LOAD.L	D3,D4	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	LIB	?DRSEG	POP.L	D420$:	PUSH.L	D4	LOAD.L	D1,D4		; D1 <-- type	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	LOAD.W	D2,#100!2^BDBGCLABEL	DBOX_	GETCO		; D3/D4 <-- coordonnes dbut/fin	SWAP.W	D3	SUB.W	D3,#2	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,#2	SWAP.W	D4	PUSHM.L	D3,D4	SUB.W	D3,#32	SWAP.W	D3	SUB.W	D3,#32	SWAP.W	D3	ADD.W	D4,#32	SWAP.W	D4	ADD.W	D4,#32	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface l'ancienne	POPM.L	D3,D4	TEST.L	D1:#BFLE1e	JUMP',BS 21$	TEST.L	D1:#BFLE2e	JUMP',BC 22$21$:	ADD.W	D3,#32	SUB.W	D4,#3222$:	LOAD.W	D2,#SETDOT	PUSH.W	(A6)+OSCALE	CLR.W	(A6)+OSCALE	; met l'chelle 1:1	LOAD.W	D7,#DESS_XFLECHE	PAGE_	DESS		; dessine la flche	POP.W	(A6)+OSCALE	POP.L	D425$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_FLDEF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	25$		; oui => 25$	COMP.W	D3,#CR		; D'ACCORD ?	JUMP,EQ 70$	COMP.W	D3,#END		; ANNULE ?	JUMP,EQ 80$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYICO	JUMP',EQ 50$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	25$50$:	LOAD.L	D1,#-1-(2^BFLF1!2^BFLF2)	COMP.B	D3,#BFLF1	JUMP',HS 52$	LOAD.L	D1,#-1-(2^BFLA45!2^BFLA27!2^BFLA14!2^BFLA7)	COMP.B	D3,#BFLA45	JUMP',HS 52$	LOAD.L	D1,#-1-(2^BFLL4!2^BFLL8!2^BFLL16!2^BFLL32)	COMP.B	D3,#BFLL4	JUMP',HS 52$	LOAD.L	D1,#-1-(2^BFLE2i!2^BFLE1i!2^BFLE2e!2^BFLE1e)	COMP.B	D3,#BFLE2i	JUMP',HS 52$	LOAD.L	D1,#-1-(2^BFLQQ!2^BFLHVO!2^BFLHV)52$:	AND.L	D4,D1		; D4 <-- teint toute la range	TSET.L	D4:D3		; D4 <-- allume juste le bon	JUMP	20$70$:	LOAD.L	(A6)+OFLTYP,D480$:	CALL	DBOXCLOSE	; ferme la DBOX90$:	PUSHM.L	D3,D7	LOAD.W	D3,#ICOFL	CALL	INVALLICONE	; teint l'icne	POPM.L	D3,D7	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXRADEF >;==========/; Dbox pour choisir le mode pour les rectangles arrondis.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXRADEF:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.W	D3,#ICORA	CALL	INVALLICONE	; allume l'icne	CLR.L	D4	LOAD.W	D2,#9	LOAD.W	D3,(A6)+ORARAY	COMP.W	D3,#4	JUMP',EQ 10$	INC.W	D2	COMP.W	D3,#8	JUMP',EQ 10$	INC.W	D2	COMP.W	D3,#12	JUMP',EQ 10$	INC.W	D2;	COMP.W	D3,#16;	JUMP',EQ 10$10$:	TSET.L	D4:D2	LOAD.L	A2,#R16"TDBOX_RADEF	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_RADEF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#CR		; D'ACCORD ?	JUMP,EQ 60$	COMP.W	D3,#END		; ANNULE ?	JUMP,EQ 80$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$60$:	LOAD.W	D2,#4	TEST.L	D4:#9	JUMP',BS 62$	LOAD.W	D2,#8	TEST.L	D4:#10	JUMP',BS 62$	LOAD.W	D2,#12	TEST.L	D4:#11	JUMP',BS 62$	LOAD.W	D2,#16;	TEST.L	D4:#12;	JUMP',BS 62$62$:	LOAD.W	(A6)+ORARAY,D280$:	CALL	DBOXCLOSE	; ferme la DBOX90$:	PUSHM.L	D3,D7	LOAD.W	D3,#ICORA	CALL	INVALLICONE	; teint l'icne	POPM.L	D3,D7	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXPODEF >;==========/; Dbox pour choisir le mode pour les polygones.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXPODEF:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.W	D3,#ICOPO	CALL	INVALLICONE	; allume l'icne	LOAD.L	D4,(A6)+OPOTYP	LOAD.L	A2,#R16"TDBOX_PODEF	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	PUSH.L	D4	LOAD.W	D2,#SETDOT	LOAD.W	D3,(A0)+ODFCY	MUL.WU	D3,#5	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	LIB	?DRSEG	LOAD.W	D3,(A0)+ODFCY	MUL.WU	D3,#12	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	LIB	?DRSEG	POP.L	D420$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_PODEF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#CR		; D'ACCORD ?	JUMP,EQ 70$	COMP.W	D3,#END		; ANNULE ?	JUMP,EQ 80$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYICO	JUMP',EQ 50$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$50$:	LOAD.L	D1,#H'FFFFFF00	COMP.B	D3,#8	JUMP',LO 52$	LOAD.L	D1,#H'FFFFF0FF	COMP.B	D3,#12	JUMP',LO 52$	LOAD.L	D1,#H'FFFF0FFF	COMP.B	D3,#16	JUMP',LO 52$	LOAD.L	D1,#H'FF00FFFF;	COMP.B	D3,#24;	JUMP',LO 52$;	LOAD.L	D1,#H'00FFFFFF52$:	AND.L	D4,D1		; D4 <-- teint toute la range	TSET.L	D4:D3		; D4 <-- allume juste le bon	JUMP	20$70$:	LOAD.L	(A6)+OPOTYP,D480$:	CALL	DBOXCLOSE	; ferme la DBOX90$:	PUSHM.L	D3,D7	LOAD.W	D3,#ICOPO	CALL	INVALLICONE	; teint l'icne	POPM.L	D3,D7	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXCEDEF >;==========/; Dbox pour choisir le mode pour les cercles.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXCEDEF:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.W	D3,#ICOCE	CALL	INVALLICONE	; allume l'icne	LOAD.L	D4,(A6)+OCETYP	LOAD.L	A2,#R16"TDBOX_CEDEF	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_CEDEF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#CR		; D'ACCORD ?	JUMP,EQ 70$	COMP.W	D3,#END		; ANNULE ?	JUMP,EQ 80$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$70$:	LOAD.L	(A6)+OCETYP,D480$:	CALL	DBOXCLOSE	; ferme la DBOX90$:	PUSHM.L	D3,D7	LOAD.W	D3,#ICOCE	CALL	INVALLICONE	; teint l'icne	POPM.L	D3,D7	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXELDEF >;==========/; Dbox pour choisir le mode pour les ellipses.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXELDEF:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.W	D3,#ICOEL	CALL	INVALLICONE	; allume l'icne	LOAD.L	D4,(A6)+OELTYP	LOAD.L	A2,#R16"TDBOX_ELDEF	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_ELDEF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#CR		; D'ACCORD ?	JUMP,EQ 70$	COMP.W	D3,#END		; ANNULE ?	JUMP,EQ 80$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$70$:	LOAD.L	(A6)+OELTYP,D480$:	CALL	DBOXCLOSE	; ferme la DBOX90$:	PUSHM.L	D3,D7	LOAD.W	D3,#ICOEL	CALL	INVALLICONE	; teint l'icne	POPM.L	D3,D7	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXARDEF >;==========/; Dbox pour choisir le mode pour les arcs.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXARDEF:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.W	D3,#ICOAR	CALL	INVALLICONE	; allume l'icne	LOAD.L	D4,(A6)+OARTYP	LOAD.L	A2,#R16"TDBOX_ARDEF	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	90$	PUSH.L	D4	LOAD.W	D2,#SETDOT	LOAD.W	D3,(A0)+ODFCX	MUL.WU	D3,#20+1	LOAD.W	D4,(A0)+ODFCY	MUL.WU	D4,#8	SUB.W	D4,#5	SWAP.W	D4	LIB	?DRSEG	LOAD.W	D3,(A0)+ODFCX	MUL.WU	D3,#40+1	LIB	?DRSEG	LOAD.L	D3,D4	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	LIB	?DRSEG;	POP.L	D4;	PUSH.L	D4	LOAD.L	A3,#(A6)+OBARC	LOAD.L	A4,A3	LOAD.W	D4,(A6)+OARANG	CALL	PUTANUM	CLR.B	(A4)	POP.L	D4	JUMP	60$20$:	CLR.W	D3	TEST.L	D4:#BARQ	JUMP',BS 22$	DEC.W	D322$:	DBOX_	MEDIT	DBOX_	EDIT		; attend une action ...	CALL	ZEROCR	LOAD.L	A1,#R16"TKEY_ARDEF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#CR		; D'ACCORD ?	JUMP,EQ 70$	COMP.W	D3,#END		; ANNULE ?	JUMP,EQ 80$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYICO	JUMP',EQ 50$30$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$50$:	LOAD.L	D1,#H'FFFFFF00	COMP.B	D3,#8	JUMP',LO 52$	LOAD.L	D1,#H'FFFFF0FF	COMP.B	D3,#12	JUMP',LO 52$	LOAD.L	D1,#H'FFFF0FFF	COMP.B	D3,#16	JUMP',LO 52$	LOAD.L	D1,#H'FF00FFFF;	COMP.B	D3,#24;	JUMP',LO 52$;	LOAD.L	D1,#H'00FFFFFF52$:	AND.L	D4,D1		; D4 <-- teint toute la range	TSET.L	D4:D3		; D4 <-- allume juste le bon60$:	CLR.W	D7		; D7 <-- grise	TEST.L	D4:#BAREL	JUMP',BS 65$	INC.W	D7		; D7 <-- dgrise65$:	LOAD.L	D0,#H'FF00FFFF	LOAD.W	D1,#BAR2	LOAD.W	D2,#BARQ	CALL	DBADGRISE	; grise/dgrise "[] degrs"	CLR.W	D7		; D7 <-- grise	TEST.L	D4:#BARQ	JUMP',BC 66$	INC.W	D7		; D7 <-- dgrise66$:	LOAD.L	D0,#H'FFFF0FFF	LOAD.W	D1,#-1	LOAD.W	D2,#BARARC	CALL	DBADGRISE	; grise/dgrise "arc"	LOAD.L	D0,#H'FFFF0FFF	LOAD.W	D1,#-1	LOAD.W	D2,#BARTRA	CALL	DBADGRISE	; grise/dgrise "tranche"	TEST.W	D7	JUMP',EQ 67$	TEST.L	D4:#BARARC	JUMP',BS 67$	TEST.L	D4:#BARTRA	JUMP',BS 67$	TSET.L	D4:#BARARC67$:	JUMP	20$70$:	LOAD.L	(A6)+OARTYP,D4	LOAD.L	A4,A3	CALL	GETANUM		; D4 <-- arc quelconque	CONV.LA.WA D4	DIV.WA	D4,#360	SWAP.W	D4	LOAD.W	(A6)+OARANG,D480$:	CALL	DBOXCLOSE	; ferme la DBOX90$:	PUSHM.L	D3,D7	LOAD.W	D3,#ICOAR	CALL	INVALLICONE	; teint l'icne	POPM.L	D3,D7	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBADGRISE >;----------/; Grise ou dgrise une paire de labels.; in	D7.W	0	-->  grise;		autre	-->  dgrise;	D0.L	masque pour teindre;	D1.W	bit  allumer (-1 si aucun);	D2.W	bit  griser/dgriser;	D4.L	fanions; out	D4.L	fanions; mod	D4.LDBADGRISE:	PUSH.W	D7	TEST.W	D7	JUMP',EQ 50$				; dgrise =>	PUSHM.L	D2..D4	OR.W	D2,#2^BDBGCLABEL!2^BDBGCFULL	DBOX_	GETCO	ADD.W	D2,#100	DBOX_	GETCO	POPM.L	D2..D4	JUMP'	90$50$:				; grise =>	PUSHM.L	D2..D4	OR.W	D2,#2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	ADD.W	D2,#100	DBOX_	GETCO	POPM.L	D2..D4	TCLR.L	D4:D2		; D4 <-- teint le bit	JUMP',BC 90$	AND.L	D4,D0		; D4 <-- teint qq bits	COMP.W	D1,#-1	JUMP',EQ 90$	TSET.L	D4:D1		; D4 <-- rallume umn bit90$:	POP.W	D7	RET;-----------\\; DBOXTXJUST >;===========/; Dialogue pour le mode de justification.; in	D4.L	mode; out	D4.L	mode;	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXTXJUST:	LOAD.B	D3,#ICOJUST	CALL	INVALLICONE	; allume l'icne	CALL	DBOXOPEN1	; prpare la souris	LOAD.W	D7,#DBOX_TXJUST	PAGE_	DBOX	PUSHM.L	D3,D7	CALL	DBOXCLOSE1	; refait les soft-keys	LOAD.B	D3,#ICOJUST	CALL	INVALLICONE	; teint l'icne	POPM.L	D3,D7	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXTXITL >;==========/; Dialogue pour l'interligne.; in	D4.L	mode; out	D4.L	mode;	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXTXITL:	LOAD.B	D3,#ICOITL	CALL	INVALLICONE	; allume l'icne	CALL	DBOXOPEN1	; prpare la souris	LOAD.W	D7,#DBOX_TXITL	PAGE_	DBOX	PUSHM.L	D3,D7	CALL	DBOXCLOSE1	; refait les soft-keys	LOAD.B	D3,#ICOITL	CALL	INVALLICONE	; teint l'icne	POPM.L	D3,D7	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXTXITC >;==========/; Dialogue pour l'intercaractre.; in	D4.L	mode; out	D4.L	mode;	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXTXITC:	LOAD.B	D3,#ICOITC	CALL	INVALLICONE	; allume l'icne	CALL	DBOXOPEN1	; prpare la souris	LOAD.W	D7,#DBOX_TXITC	PAGE_	DBOX	PUSHM.L	D3,D7	CALL	DBOXCLOSE1	; refait les soft-keys	LOAD.B	D3,#ICOITC	CALL	INVALLICONE	; teint l'icne	POPM.L	D3,D7	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXGENCAR >;===========/; Dialogue pour la DBOX des gencars.; in	-; out	D7.W	erreur; mod	D7.WDBOXGENCAR:	PUSHM.L	D0..D5,A2..A5	LOAD.B	D3,#ICOGGDEF	CALL	INVALLICONE	; allume l'icne	CALL	DBOXOPEN1	; prpare la souris10$:	LOAD.L	D4,(A6)+OFAGC	; D4 <-- fanions	LOAD.L	A4,#(A6)+OBUGC	; A4 <-- ^buffer des gencars	LOAD.L	A5,#(A6)+OGCLIST; A5 <-- ^liste des gencars sur disque	LOAD.W	D5,#MAXGENC*3	; D5 <-- lg pour la liste	LOAD.L	D1,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	CALL	DBOXPOS3	; D3 <-- centre de la dbox	DGENC_	MODIF		; modifie un/qq gencar(s) ...	JUMP',NE 90$	LOAD.L	(A6)+OFAGC,D4	; mm. derniers fanions utiliss	COMP.W	D3,#F1		; MODIFIE ?	JUMP,EQ 10$	COMP.W	D3,#F4		; SUPPRIME ?	JUMP',NE 90$	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A3,#(A6)+OBUGC	DGENC_	KILL		; libre le gencar	JUMP	10$90$:	PUSH.W	D7	CALL	DBOXCLOSE1	; refait les soft-keys	LOAD.B	D3,#ICOGGDEF	CALL	INVALLICONE	; teint l'icne	POP.W	D7	POPM.L	D0..D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXERROR >;==========/; Affiche une erreur.; in	D7.W	erreur; out	-; mod	D7.WDBOXERROR:	PUSHM.L	D2	PUSH.W	D7	CALL	DBOXOPEN1	; prpare la souris	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	CALL	DBOXCLOSE1	; refait les soft-keys90$:	POPM.L	D2	TEST.W	D7		; retour EQ/NE	RET	.END