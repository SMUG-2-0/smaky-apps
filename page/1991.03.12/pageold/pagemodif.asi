	.SBTTL	PAGEMODIF;***************;;    ENTOURE    ;;***************;ENTOURE:	COMP.B	(A6)+OSELECT,#ICOZONE	JUMP,NE CROCHET	CLR.B	D3	CALL	SELMO		; souris = flche	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE BIP	LOAD.W	D7,#DET_POINT	PAGE_	DET		; D3 <-- point o est la souris	JUMP,NE BIP	LOAD.L	A4,#(A6)+OORECT	; A4 <-- ^buffer pour objet temporaire	LOAD.W	(A4)+OOOBJ,#ICORD	LOAD.L	(A4)+OOFOND,#2^BFDOBT	LOAD.L	(A4)+OORDPOS,D3	CLR.L	(A4)+OORDDIM	CLR.W	(A4)+OOPEN	CLR.W	(A4)+OORDRAY	CLR.L	(A4)+OORDTYP	LOAD.W	D2,#1		; D2 <-- open	LOAD.W	D7,#DESS_ISHIFT	PAGE_	DESS		; dessine le premier rectangleRECT$:	LOAD.W	D2,#2		; D2 <-- shift	LOAD.W	D7,#DESS_ISHIFT	PAGE_	DESS		; fait tourner le traitill	CALL	WAITMOVES	; attend dplacement ...	JUMP',NE MENU$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE RECT$	LOAD.W	D7,#DET_POINT	PAGE_	DET		; D3 <-- point o est la souris	JUMP,NE RECT$	SUB.W	D3,(A4)+OORDPOS+2	SWAP.W	D3	SUB.W	D3,(A4)+OORDPOS+0 ; D3 <-- dimensions	SWAP.W	D3	COMP.L	D3,(A4)+OORDDIM	; dimensions changes ?	JUMP,EQ RECT$		; non => RECT$				; oui =>	LOAD.W	D2,#3		; D2 <-- close	LOAD.W	D7,#DESS_ISHIFT	PAGE_	DESS		; efface l'ancien rectangle	LOAD.L	(A4)+OORDDIM,D3	LOAD.W	D2,#1		; D2 <-- open	LOAD.W	D7,#DESS_ISHIFT	PAGE_	DESS		; dessine le nouveau rectangle	JUMP	RECT$MENU$:	LOAD.W	D2,#3		; D2 <-- close	LOAD.W	D7,#DESS_ISHIFT	PAGE_	DESS		; efface le dernier rectangle	LOAD.L	D4,(A4)+OORDPOS	; D4 <-- position initiale	LOAD.W	D7,#DET_SELOPEN	PAGE_	DET		; slectionne tous les objets inclus	JUMP,NE BIP	LOAD.W	(A6)+ODDNB,D3	; ODDNB <-- nb d'objets inclus	LOAD.W	D7,#DET_SELINV	PAGE_	DET		; allume tous les objets inclus	LOAD.W	D2,#1		; D2 <-- open	LOAD.W	D7,#DESS_ISHIFT	PAGE_	DESS		; dessine le nouveau rectangle	LOAD.L	A5,A4	LOAD.L	A3,#R16"TMMDDD	LOAD.L	A4,#(A6)+OMPACR	; A4 <-- ^paramtres	CLR.L	(A4)+LMM*0+OMMINA	CLR.L	(A4)+LMM*1+OMMINA	CLR.L	(A4)+LMM*2+OMMINA	CLR.L	(A4)+LMM*3+OMMINA	CLR.L	(A4)+LMM*4+OMMINA	TSET.B	(A4)+LMM*3+OMMINA+3:#2 ; grise la case "fond"	TSET.B	(A4)+LMM*4+OMMINA+3:#2 ; grise la case "fond.."	TSET.B	(A4)+LMM*3+OMMINA+3:#3 ; grise la case "objet"	TSET.B	(A4)+LMM*4+OMMINA+3:#3 ; grise la case "objet.."	CALL	MMENUS		; choix selon mmenus ...	EX.L	A4,A5	LOAD.W	D4,(A5)+LMM*0+OMMSEL	DEC.W	D4	JUMP,EQ DETRUIT$	CLR.L	D1	DEC.W	D4	JUMP,EQ DEPLACE	DEC.W	D4	JUMP,EQ DUPLIQUE	DEC.W	D4	JUMP,EQ OPER$	DEC.W	D4	JUMP,EQ PLAN$	DEC.W	D4	JUMP,EQ MODIF$	DEC.W	D4	JUMP,EQ DIAL$LOOP$:	LOAD.W	D2,#3		; D2 <-- close	LOAD.W	D7,#DESS_ISHIFT	PAGE_	DESS		; efface le dernier rectangle	LOAD.W	D7,#DET_SELCLOSE	PAGE_	DET		; d-slectionne tous les objets inclus	JUMP	LOOPBIP$:	LOAD.W	D2,#3		; D2 <-- close	LOAD.W	D7,#DESS_ISHIFT	PAGE_	DESS		; efface le dernier rectangle	LOAD.W	D7,#DET_SELCLOSE	PAGE_	DET		; d-slectionne tous les objets inclus	JUMP	BIPDETRUIT$:	PUSH.L	A4DETR1$:	LOAD.L	A3,#(A6)+OUSE	LOAD.L	A4,(A3)+OLNEXTDETR2$:	COMP.L	A4,A3		; fin de la liste ?	JUMP',EQ DETR7$		; oui => DETR7$	TCLR.B	(A4)+OOFLG:#BOOSEL	JUMP',BC DETR6$	LOAD.W	D2,#INVDOT	LOAD.W	D7,#DESS_OBJET	PAGE_	DESS		; efface l'objet	LOAD.W	D7,#BASE_REMOVE	PAGE_	BASE		; enlve de la base de donnes	JUMP	DETR1$DETR6$:	LOAD.L	A4,(A4)+OLNEXT	; A4 <-- ^suivant	JUMP	DETR2$DETR7$:	POP.L	A4	LOAD.W	D2,#3		; D2 <-- close	LOAD.W	D7,#DESS_ISHIFT	PAGE_	DESS		; efface le dernier rectangle	JUMP	LOOPOPER$:	JUMP	LOOP$PLAN$:	LOAD.W	D4,(A5)+LMM*2+OMMSEL	TEST.W	D4	JUMP,EQ LAST$	DEC.W	D4	JUMP,EQ FIRST$	JUMP	LOOP$MODIF$:	LOAD.W	D4,(A5)+LMM*3+OMMSEL	TEST.W	D4	JUMP,EQ MTRAIT$	DEC.W	D4	JUMP,EQ MTRAME$	JUMP	LOOP$DIAL$:	LOAD.W	D4,(A5)+LMM*4+OMMSEL	TEST.W	D4	JUMP,EQ DTRAIT$	DEC.W	D4	JUMP,EQ DTRAME$	JUMP	LOOP$LAST$:	PUSH.L	A4	LOAD.L	A3,#(A6)+OUSE	LOAD.L	A4,(A3)+OLPREVLAST2$:	COMP.L	A4,A3		; dbut de la liste ?	JUMP',EQ LAST5$		; oui => LAST5$	TEST.B	(A4)+OOFLG:#BOOSEL	JUMP',BC LAST4$	TEST.B	(A4)+OOFLG:#BOOSKP	JUMP',BS LAST4$	LOAD.W	D7,#BASE_LAST	PAGE_	BASE		; met  la fin de la liste	TSET.B	(A4)+OOFLG:#BOOSKPLAST4$:	LOAD.L	A4,(A4)+OLPREV	; A4 <-- ^prcdent	JUMP	LAST2$LAST5$:	POP.L	A4	JUMP	LOOP$FIRST$:	PUSH.L	A4	LOAD.L	A3,#(A6)+OUSE	LOAD.L	A4,(A3)+OLNEXTFIRST2$:	COMP.L	A4,A3		; fin de la liste ?	JUMP',EQ FIRST5$	; oui => FIRST5$	TEST.B	(A4)+OOFLG:#BOOSEL	JUMP',BC FIRST4$	TEST.B	(A4)+OOFLG:#BOOSKP	JUMP',BS FIRST4$	LOAD.W	D7,#BASE_FIRST	PAGE_	BASE		; met  la fin de la liste	TSET.B	(A4)+OOFLG:#BOOSKPFIRST4$:	LOAD.L	A4,(A4)+OLNEXT	; A4 <-- ^prcdent	JUMP	FIRST2$FIRST5$:	POP.L	A4	JUMP	LOOP$MTRAIT$:	LOAD.W	D4,(A6)+OSLPEN	LOAD.W	D3,#OOPEN	JUMP	CHANGE$MTRAME$:	LOAD.W	D4,(A6)+OSLTRA	LOAD.W	D3,#OOTRAM	JUMP	CHANGE$DTRAIT$:	PUSH.W	(A6)+OSLPEN	CALL	DBOXPDEF	; choix de la trame ...	LOAD.W	D4,(A6)+OSLPEN	POP.W	(A6)+OSLPEN	TEST.W	D7	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	LOAD.W	D3,#OOPEN	JUMP	CHANGE$DTRAME$:	PUSH.W	(A6)+OSLTRA	CALL	DBOXTDEF	; choix de la trame ...	LOAD.W	D4,(A6)+OSLTRA	POP.W	(A6)+OSLTRA	TEST.W	D7	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	LOAD.W	D3,#OOTRAM	JUMP	CHANGE$CHANGE$:	LOAD.W	D7,#DET_SELWORD	PAGE_	DET		; modifie tous les objets inclus	JUMP	LOOP$;***************;;    CROCHET    ;;***************;CROCHET:	LOAD.B	D3,(A6)+OSELECT	CALL	SELMO		; souris = crochet/poigne	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE BIP	LOAD.W	D7,#DET_DETECT	PAGE_	DET		; A4 <-- ^objet montr	LOAD.L	A3,A4	LOAD.W	D2,#1		; D2 <-- open	LOAD.W	D7,#DESS_ISHIFT	PAGE_	DESS		; dessine le premier objetMOVE2$:	LOAD.W	D2,#2		; D2 <-- shift	LOAD.W	D7,#DESS_ISHIFT	PAGE_	DESS		; fait tourner le traitill	CALL	WAITMOVES	; attend dplacement ...	JUMP',NE MOVE8$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE MOVE2$	LOAD.W	D7,#DET_DETECT	PAGE_	DET		; A4 <-- ^objet montr	COMP.L	A4,A3		; toujours le mme objet ?	JUMP,EQ MOVE2$		; oui => MOVE2$				; non =>	EX.L	A3,A4	LOAD.W	D2,#3		; D2 <-- close	LOAD.W	D7,#DESS_ISHIFT	PAGE_	DESS		; efface l'ancien objet	LOAD.L	A4,A3	LOAD.W	D2,#1		; D2 <-- open	LOAD.W	D7,#DESS_ISHIFT	PAGE_	DESS		; dessine le nouvel objet	JUMP	MOVE2$MOVE8$:	LOAD.L	A4,A3	LOAD.W	D2,#3		; D2 <-- close	LOAD.W	D7,#DESS_ISHIFT	PAGE_	DESS		; efface le dernier objet	COMP.L	A4,#0	JUMP,EQ BIP	COMP.B	(A6)+OSELECT,#ICOPOIGNEE	JUMP,EQ POIGNEE	LOAD.W	D7,#DESS_CLEAR	PAGE_	DESS		; efface l'objet	LOAD.W	D7,#DESS_IRECT	PAGE_	DESS		; dessine l'objet captur	LOAD.L	A5,A4	LOAD.L	A3,#R16"TMMDDD	LOAD.L	A4,#(A6)+OMPACR	; A4 <-- ^paramtres	CLR.L	(A4)+LMM*0+OMMINA	CLR.L	(A4)+LMM*1+OMMINA	CLR.L	(A4)+LMM*2+OMMINA	CLR.L	(A4)+LMM*3+OMMINA	CLR.L	(A4)+LMM*4+OMMINA	TSET.B	(A4)+LMM*3+OMMINA+3:#2 ; grise la case "fond"	TSET.B	(A4)+LMM*4+OMMINA+3:#2 ; grise la case "fond.."	COMP.W	(A5)+OOOBJ,#ICODR	JUMP',EQ GREY10$	TCLR.B	(A4)+LMM*3+OMMINA+3:#2 ; dgrise la case "fond"	TCLR.B	(A4)+LMM*4+OMMINA+3:#2 ; dgrise la case "fond.."GREY10$:	TSET.B	(A4)+LMM*3+OMMINA+3:#3 ; grise la case "objet"	TSET.B	(A4)+LMM*4+OMMINA+3:#3 ; grise la case "objet.."	COMP.W	(A5)+OOOBJ,#ICOTM	JUMP',EQ GREY11$	COMP.W	(A5)+OOOBJ,#ICOSP	JUMP',EQ GREY11$	COMP.W	(A5)+OOOBJ,#ICOLB	JUMP',EQ GREY11$	COMP.W	(A5)+OOOBJ,#ICORD	JUMP',EQ GREY11$	COMP.W	(A5)+OOOBJ,#ICOIM	JUMP',EQ GREY11$	TCLR.B	(A4)+LMM*3+OMMINA+3:#3 ; dgrise la case "objet"	TCLR.B	(A4)+LMM*4+OMMINA+3:#3 ; dgrise la case "objet.."GREY11$:	COMP.W	(A5)+OOOBJ,#ICOTM	JUMP',EQ GREY12$	COMP.W	(A5)+OOOBJ,#ICOSP	JUMP',EQ GREY12$	COMP.W	(A5)+OOOBJ,#ICOLB	JUMP',EQ GREY12$	COMP.W	(A5)+OOOBJ,#ICOFL	JUMP',EQ GREY12$	COMP.W	(A5)+OOOBJ,#ICORD	JUMP',EQ GREY12$	COMP.W	(A5)+OOOBJ,#ICORA	JUMP',EQ GREY12$	COMP.W	(A5)+OOOBJ,#ICOPO	JUMP',EQ GREY12$	COMP.W	(A5)+OOOBJ,#ICOCE	JUMP',EQ GREY12$	COMP.W	(A5)+OOOBJ,#ICOEL	JUMP',EQ GREY12$	COMP.W	(A5)+OOOBJ,#ICOAR	JUMP',EQ GREY12$	COMP.W	(A5)+OOOBJ,#ICOIM	JUMP',EQ GREY12$	COMP.W	(A5)+OOOBJ,#ICOTX	JUMP',EQ GREY12$	TSET.B	(A4)+LMM*3+OMMINA+3:#1 ; grise la case "trame"	TSET.B	(A4)+LMM*4+OMMINA+3:#1 ; grise la case "trame.."GREY12$:	TSET.B	(A4)+LMM*3+OMMINA+3:#0 ; grise la case "trait"	TSET.B	(A4)+LMM*4+OMMINA+3:#0 ; grise la case "trait.."	COMP.W	(A5)+OOOBJ,#ICOIM	JUMP',EQ GREY13$	COMP.W	(A5)+OOOBJ,#ICOTX	JUMP',EQ GREY13$	TCLR.B	(A4)+LMM*3+OMMINA+3:#0 ; dgrise la case "trait"	TCLR.B	(A4)+LMM*4+OMMINA+3:#0 ; dgrise la case "trait.."GREY13$:	LOAD.W	D4,(A6)+OSLPEN	COMP.W	D4,(A5)+OOPEN	JUMP',NE GREY22$	TSET.B	(A4)+LMM*3+OMMINA+3:#0 ; grise la case "trait"GREY22$:	LOAD.W	D4,(A5)+OOTRAM	COMP.W	D4,(A6)+OSLTRA	JUMP',NE GREY3$	TSET.B	(A4)+LMM*3+OMMINA+3:#1 ; grise la case "trame"GREY3$:	EX.L	A4,A5	CALL	IFNEWOBJET	EX.L	A5,A4	JUMP',EQ GREY4$	TSET.B	(A4)+LMM*3+OMMINA+3:#2 ; grise la case "objet"GREY4$:	CALL	MMENUS		; choix selon mmenus ...	EX.L	A4,A5	LOAD.W	D4,(A5)+LMM*0+OMMSEL	DEC.W	D4	JUMP,EQ DETRUIT$	CLR.W	D3		; D3 <-- dplace	DEC.W	D4	JUMP,EQ DEPLDUPL$	INC.W	D3		; D3 <-- duplique	DEC.W	D4	JUMP,EQ DEPLDUPL$	DEC.W	D4	JUMP,EQ OPER$	DEC.W	D4	JUMP,EQ PLAN$	DEC.W	D4	JUMP,EQ MODIF$	DEC.W	D4	JUMP,EQ DIAL$LOOP$:	LOAD.W	D7,#DESS_IRECT	PAGE_	DESS		; efface l'objet capturLOOP2$:	LOAD.W	D7,#DESS_SET	PAGE_	DESS		; redessine l'objet	JUMP	LOOPBIP$:	LOAD.W	D7,#DESS_IRECT	PAGE_	DESS		; efface l'objet capturBIP2$:	LOAD.W	D7,#DESS_SET	PAGE_	DESS		; redessine l'objet	JUMP	BIPREFAIT$:	LOAD.W	D7,#DET_INIT	PAGE_	DET		; ajuste pour les dtections	LOAD.W	D7,#DESS_SET	PAGE_	DESS		; redessine l'objet	JUMP	LOOPOPER$:	LOAD.W	D4,(A5)+LMM*1+OMMSEL	JUMP	LOOP$PLAN$:	LOAD.W	D4,(A5)+LMM*2+OMMSEL	TEST.W	D4	JUMP,EQ LAST$	DEC.W	D4	JUMP,EQ FIRST$	JUMP	LOOP$MODIF$:	LOAD.W	D4,(A5)+LMM*3+OMMSEL	TEST.W	D4	JUMP,EQ MTRAIT$	DEC.W	D4	JUMP,EQ MTRAME$	DEC.W	D4	JUMP,EQ MFOND$	DEC.W	D4	JUMP,EQ MOBJET$	JUMP	LOOP$DIAL$:	LOAD.W	D4,(A5)+LMM*4+OMMSEL	TEST.W	D4	JUMP,EQ DTRAIT$	DEC.W	D4	JUMP,EQ DTRAME$	DEC.W	D4	JUMP,EQ DFOND$	DEC.W	D4	JUMP,EQ DOBJET$	JUMP	LOOP$DETRUIT$:	LOAD.W	D7,#DESS_IRECT	PAGE_	DESS		; efface l'objet captur	LOAD.W	D7,#BASE_REMOVE	PAGE_	BASE		; enlve de la base de donnes	JUMP	LOOPDEPLDUPL$:	LOAD.W	D0,D3		; D0 <-- dplace/duplique	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE BIP$	LOAD.W	D7,#DET_POINTP	PAGE_	DET		; D3 <-- point o est la souris	JUMP,NE BIP$	SWAP.W	D3	LOAD.W	D1,(A4)+OODPOS+0	ADD.W	D1,(A4)+OODDIM+0	SUB.W	D1,D3	SWAP.W	D3	SWAP.W	D1	LOAD.W	D1,(A4)+OODPOS+2	ADD.W	D1,(A4)+OODDIM+2	SUB.W	D1,D3	LOAD.W	(A6)+ODDNB,#1	; ODDNB <-- un objet inclu	LOAD.W	D7,#DESS_IRECT	PAGE_	DESS		; efface l'objet captur	LOAD.L	A3,A4	LOAD.L	A4,#(A6)+OORECT	; A4 <-- ^buffer pour objet temporaire	LOAD.W	(A4)+OOOBJ,#ICORD	LOAD.L	(A4)+OOFOND,#2^BFDOBT	LOAD.L	(A4)+OORDPOS,(A3)+OODPOS	LOAD.L	(A4)+OORDDIM,(A3)+OODDIM	CLR.W	(A4)+OOPEN	CLR.W	(A4)+OORDRAY	CLR.L	(A4)+OORDTYP	LOAD.W	D2,#1		; D2 <-- open	LOAD.W	D7,#DESS_ISHIFT	PAGE_	DESS		; dessine le premier rectangle	LOAD.W	D7,#DET_SELINV	PAGE_	DET		; allume l'objet inclu	TEST.W	D0	JUMP,EQ	DEPLACE	JUMP	DUPLIQUEMTRAIT$:	LOAD.W	D7,#DESS_IRECT	PAGE_	DESS		; efface l'objet captur	LOAD.W	(A4)+OOPEN,(A6)+OSLPEN	JUMP	REFAIT$MTRAME$:	LOAD.W	D7,#DESS_IRECT	PAGE_	DESS		; efface l'objet captur	LOAD.W	(A4)+OOTRAM,(A6)+OSLTRA	JUMP	REFAIT$MFOND$:	LOAD.W	D7,#DESS_IRECT	PAGE_	DESS		; efface l'objet captur	LOAD.L	(A4)+OOFOND,(A6)+OMFOND	LOAD.W	(A4)+OOFSCA,#-1	; faudra refaire les matrices de fond	JUMP	REFAIT$MOBJET$:	LOAD.W	D7,#DESS_IRECT	PAGE_	DESS		; efface l'objet captur	LOAD.W	D3,(A4)+OOOBJ	COMP.W	D3,#ICODR	JUMP',EQ MDR$	COMP.W	D3,#ICOFL	JUMP',EQ MFL$	COMP.W	D3,#ICORA	JUMP',EQ MRA$	COMP.W	D3,#ICOPO	JUMP',EQ MPO$	COMP.W	D3,#ICOCE	JUMP',EQ MCE$	COMP.W	D3,#ICOEL	JUMP',EQ MEL$	COMP.W	D3,#ICOAR	JUMP',EQ MAR$	JUMP	BIP2$MDR$:	LOAD.L	(A4)+OODRTYP,(A6)+ODRTYP	JUMP	REFAIT$MFL$:	LOAD.L	(A4)+OOFLTYP,(A6)+OFLTYP	JUMP	REFAIT$MRA$:	LOAD.L	(A4)+OORATYP,(A6)+ORATYP	LOAD.W	(A4)+OORARAY,(A6)+ORARAY	JUMP	REFAIT$MPO$:	LOAD.L	(A4)+OOPOTYP,(A6)+OPOTYP	JUMP	REFAIT$MCE$:	LOAD.L	(A4)+OOCETYP,(A6)+OCETYP	JUMP	REFAIT$MEL$:	LOAD.L	(A4)+OOELTYP,(A6)+OELTYP	JUMP	REFAIT$MAR$:	LOAD.L	(A4)+OOARTYP,(A6)+OARTYP	LOAD.W	(A4)+OOARANG,(A6)+OARANG	JUMP	REFAIT$DTRAIT$:	PUSH.W	(A6)+OSLPEN	LOAD.W	(A6)+OSLPEN,(A4)+OOPEN	CALL	DBOXPDEF	; choix de la trame ...	LOAD.W	D4,(A6)+OSLPEN	POP.W	(A6)+OSLPEN	TEST.W	D7	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	LOAD.W	D7,#DESS_IRECT	PAGE_	DESS		; efface l'objet captur	LOAD.W	(A4)+OOPEN,D4	JUMP	REFAIT$DTRAME$:	PUSH.W	(A6)+OSLTRA	LOAD.W	(A6)+OSLTRA,(A4)+OOTRAM	CALL	DBOXTDEF	; choix de la trame ...	LOAD.W	D4,(A6)+OSLTRA	POP.W	(A6)+OSLTRA	TEST.W	D7	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	LOAD.W	D7,#DESS_IRECT	PAGE_	DESS		; efface l'objet captur	LOAD.W	(A4)+OOTRAM,D4	JUMP	REFAIT$DFOND$:	PUSH.L	(A6)+OMFOND	LOAD.L	(A6)+OMFOND,(A4)+OOFOND	CALL	DBOXFOND	; choix du fond ...	LOAD.L	D4,(A6)+OMFOND	POP.L	(A6)+OMFOND	TEST.W	D7	JUMP,NE BIP$	COMP.W	D3,#CR	JUMP,NE LOOP$	LOAD.W	D7,#DESS_IRECT	PAGE_	DESS		; efface l'objet captur	LOAD.L	(A4)+OOFOND,D4	LOAD.W	(A4)+OOFSCA,#-1	; faudra refaire les matrices de fond	JUMP	REFAIT$DOBJET$:	LOAD.W	D3,(A4)+OOOBJ	COMP.W	D3,#ICODR	JUMP,EQ DDR$	COMP.W	D3,#ICOFL	JUMP,EQ DFL$	COMP.W	D3,#ICORA	JUMP,EQ DRA$	COMP.W	D3,#ICOPO	JUMP,EQ DPO$	COMP.W	D3,#ICOCE	JUMP,EQ DCE$	COMP.W	D3,#ICOEL	JUMP,EQ DEL$	COMP.W	D3,#ICOAR	JUMP,EQ DAR$	JUMP	BIP$DDR$:	PUSH.L	(A6)+ODRTYP	LOAD.L	(A6)+ODRTYP,(A4)+OODRTYP	CALL	DBOXDRDEF	LOAD.L	D4,(A6)+ODRTYP	POP.L	(A6)+ODRTYP	TEST.W	D7	JUMP,NE BIP$	COMP.W	D3,#CR	JUMP,NE LOOP$	LOAD.W	D7,#DESS_IRECT	PAGE_	DESS		; efface l'objet captur	LOAD.L	(A4)+OODRTYP,D4	JUMP	REFAIT$DFL$:	PUSH.L	(A6)+OFLTYP	LOAD.L	(A6)+OFLTYP,(A4)+OOFLTYP	CALL	DBOXFLDEF	LOAD.L	D4,(A6)+OFLTYP	POP.L	(A6)+OFLTYP	TEST.W	D7	JUMP,NE BIP$	COMP.W	D3,#CR	JUMP,NE LOOP$	LOAD.W	D7,#DESS_IRECT	PAGE_	DESS		; efface l'objet captur	LOAD.L	(A4)+OOFLTYP,D4	JUMP	REFAIT$DRA$:	PUSH.L	(A6)+ORATYP	PUSH.W	(A6)+ORARAY	LOAD.L	(A6)+ORATYP,(A4)+OORATYP	LOAD.W	(A6)+ORARAY,(A4)+OORARAY	CALL	DBOXRADEF	LOAD.L	D4,(A6)+ORATYP	LOAD.W	D2,(A6)+ORARAY	POP.W	(A6)+ORARAY	POP.L	(A6)+ORATYP	TEST.W	D7	JUMP,NE BIP$	COMP.W	D3,#CR	JUMP,NE LOOP$	LOAD.W	D7,#DESS_IRECT	PAGE_	DESS		; efface l'objet captur	LOAD.L	(A4)+OORATYP,D4	LOAD.W	(A4)+OORARAY,D2	JUMP	REFAIT$DPO$:	PUSH.L	(A6)+OPOTYP	LOAD.L	(A6)+OPOTYP,(A4)+OOPOTYP	CALL	DBOXPODEF	LOAD.L	D4,(A6)+OPOTYP	POP.L	(A6)+OPOTYP	TEST.W	D7	JUMP,NE BIP$	COMP.W	D3,#CR	JUMP,NE LOOP$	LOAD.W	D7,#DESS_IRECT	PAGE_	DESS		; efface l'objet captur	LOAD.L	(A4)+OOPOTYP,D4	JUMP	REFAIT$DCE$:	PUSH.L	(A6)+OCETYP	LOAD.L	(A6)+OCETYP,(A4)+OOCETYP	CALL	DBOXCEDEF	LOAD.L	D4,(A6)+OCETYP	POP.L	(A6)+OCETYP	TEST.W	D7	JUMP,NE BIP$	COMP.W	D3,#CR	JUMP,NE LOOP$	LOAD.W	D7,#DESS_IRECT	PAGE_	DESS		; efface l'objet captur	LOAD.L	(A4)+OOCETYP,D4	JUMP	REFAIT$DEL$:	PUSH.L	(A6)+OELTYP	LOAD.L	(A6)+OELTYP,(A4)+OOELTYP	CALL	DBOXELDEF	LOAD.L	D4,(A6)+OELTYP	POP.L	(A6)+OELTYP	TEST.W	D7	JUMP,NE BIP$	COMP.W	D3,#CR	JUMP,NE LOOP$	LOAD.W	D7,#DESS_IRECT	PAGE_	DESS		; efface l'objet captur	LOAD.L	(A4)+OOELTYP,D4	JUMP	REFAIT$DAR$:	PUSH.L	(A6)+OARTYP	PUSH.W	(A6)+OARANG	LOAD.L	(A6)+OARTYP,(A4)+OOARTYP	LOAD.W	(A6)+OARANG,(A4)+OOARANG	CALL	DBOXARDEF	LOAD.L	D4,(A6)+OARTYP	LOAD.W	D2,(A6)+OARANG	POP.W	(A6)+OARANG	POP.L	(A6)+OARTYP	TEST.W	D7	JUMP,NE BIP$	COMP.W	D3,#CR	JUMP,NE LOOP$	LOAD.W	D7,#DESS_IRECT	PAGE_	DESS		; efface l'objet captur	LOAD.L	(A4)+OOARTYP,D4	LOAD.W	(A4)+OOARANG,D2	JUMP	REFAIT$LAST$:	LOAD.W	D7,#BASE_LAST	PAGE_	BASE		; met  la fin de la liste	LOAD.W	D7,#DESS_IRECT	PAGE_	DESS		; efface l'objet captur	LOAD.W	D7,#DESS_SET	PAGE_	DESS		; redessine l'objet	JUMP	LOOPFIRST$:	LOAD.W	D7,#BASE_FIRST	PAGE_	BASE		; met au dbut de la liste	LOAD.W	D7,#DESS_IRECT	PAGE_	DESS		; efface l'objet captur	LOAD.W	D7,#DESS_SET	PAGE_	DESS		; redessine l'objet	JUMP	LOOPDUPLIQUE:	PUSH.L	A4	LOAD.W	D3,(A6)+ODDNB	; D3 <-- nb d'objets inclus	LOAD.L	A3,#(A6)+OUSE	LOAD.L	A4,(A3)+OLNEXTDUPL2$:	COMP.L	A4,A3		; fin de la liste ?	JUMP,EQ DUPL7$		; oui => DUPL7$	TEST.B	(A4)+OOFLG:#BOOSEL	JUMP,BC DUPL6$	PUSH.L	A3	LOAD.W	D7,#BASE_DUPLICATA	PAGE_	BASE		; effectue un double	POPM.L	A3;;?	JUMP,NE 		<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<< A FAIRE !!!!!!!!!!!!	TSET.B	(A4)+OOFLG:#BOOSKP	LOAD.W	D7,#DET_INIT	PAGE_	DET		; ajuste pour les dtections	LOAD.W	D2,#INVDOT	LOAD.W	D7,#DESS_OBJET	PAGE_	DESS		; efface l'objet	DEC.W	D3		; D3 <-- un objet de plus dupliquDUPL6$:	LOAD.L	A4,(A4)+OLNEXT	; A4 <-- ^suivant	TEST.W	D3		; encore objet(s) inclu(s) ?	JUMP,NE DUPL2$		; oui => DUPL2$DUPL7$:	POP.L	A4DEPLACE:	LOAD.W	D4,(A6)+OPAS	CLR.L	D3	LOAD.W	D3,(A4)+OORDPOS+0	ADD.W	D3,(A4)+OORDDIM+0	DIV.WU	D3,D4	SWAP.W	D3	SUB.W	D3,D4	NEG.W	D3	LOAD.W	D0,D3		; D0 <-- dcalage pour pas selon Y	SWAP.W	D0	CLR.L	D3	LOAD.W	D3,(A4)+OORDPOS+2	ADD.W	D3,(A4)+OORDDIM+2	DIV.WU	D3,D4	SWAP.W	D3	SUB.W	D3,D4	NEG.W	D3	LOAD.W	D0,D3		; D0 <-- dcalage pour pas selon X	LOAD.L	A3,#0		; A3 <-- dplace le premier objetDEPL1$:	LOAD.L	D4,(A4)+OORDPOS	; D4 <-- nouvelle position	LOAD.W	D7,#DET_SELMOVE	PAGE_	DET		; dplace un objet inclu	JUMP',EQ DEPL2$	LOAD.W	D2,#2		; D2 <-- shift	LOAD.W	D7,#DESS_ISHIFT	PAGE_	DESS		; fait tourner le traitillDEPL2$:	CALL	WAITMOVES	; attend dplacement ...	JUMP,NE DEPL5$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE DEPL1$	LOAD.W	D7,#DET_POINT	PAGE_	DET		; D3 <-- point o est la souris	JUMP,NE DEPL1$	ADD.W	D3,D1	SWAP.W	D3	SWAP.W	D1	ADD.W	D3,D1	SWAP.W	D3	SWAP.W	D1	ADD.W	D3,D0	SWAP.W	D3	SWAP.W	D0	ADD.W	D3,D0	SWAP.W	D3	SWAP.W	D0	LOAD.W	D7,#DET_RNDPAS	PAGE_	DET		; D3 <-- arrondi selon le pas	SUB.W	D3,D0	SWAP.W	D3	SWAP.W	D0	SUB.W	D3,D0	SWAP.W	D3	SWAP.W	D0	SUB.W	D3,(A4)+OORDDIM+2	JUMP',NC DEPL31$	CLR.W	D3DEPL31$:	COMP.W	D3,(A6)+OPDIM+2	JUMP',LE DEPL32$	LOAD.W	D3,(A6)+OPDIM+2DEPL32$:	SWAP.W	D3	SUB.W	D3,(A4)+OORDDIM+0 ; D3 <-- position	JUMP',NC DEPL33$	CLR.W	D3DEPL33$:	COMP.W	D3,(A6)+OPDIM+0	JUMP',LE DEPL34$	LOAD.W	D3,(A6)+OPDIM+0DEPL34$:	SWAP.W	D3	COMP.L	D3,(A4)+OORDPOS	; position change ?	JUMP,EQ DEPL1$		; non => DEPL1$				; oui =>	LOAD.W	D2,#3		; D2 <-- close	LOAD.W	D7,#DESS_ISHIFT	PAGE_	DESS		; efface l'ancien rectangle	LOAD.L	(A4)+OORDPOS,D3	LOAD.W	D2,#1		; D2 <-- open	LOAD.W	D7,#DESS_ISHIFT	PAGE_	DESS		; dessine le nouveau rectangle	LOAD.L	A3,#0		; A3 <-- dplace le premier objet	JUMP	DEPL2$DEPL5$:	LOAD.L	D4,(A4)+OORDPOS	; D4 <-- nouvelle position	LOAD.W	D7,#DET_SELMOVE	PAGE_	DET		; dplace un objet inclu	JUMP,EQ DEPL5$	LOAD.W	D2,#3		; D2 <-- close	LOAD.W	D7,#DESS_ISHIFT	PAGE_	DESS		; efface le dernier rectangle	LOAD.W	D7,#DET_SELCLOSE	PAGE_	DET		; d-slectionne tous les objets inclus	JUMP	LOOP;***************;;    POIGNEE    ;;***************;POIGNEE:	LOAD.W	D7,#DESS_CLEAR	PAGE_	DESS		; efface l'objetPOIGNEE2:	LOAD.B	(A6)+OXICO,#NIVPOIGNEE ; dbut de l'opration	LOAD.B	(A6)+OYICO,(A4)+OOOBJ+1	LOAD.B	(A6)+OSPLOP,#ICOSPLMOV	CALL	PGOSAVE		; sauve l'cran	LOAD.W	D2,#INVDOT	LOAD.W	D7,#DESS_OBJET	PAGE_	DESS		; dessine l'objet en inverse	LOAD.W	D2,#SETDOT	CALL	PGOINV		; allume les poignes	CALL	DESICONE	; dessine les icnes de gauche	CALL	MAJICONE	; mj. les icnes variables	CALL	AFMENU		; refait les soft-keysLOOP$:	CALL	SCMO		; remet la souris	CALL	FULLGREYICONE	; (d)grise qq icnes	COMP.B	(A6)+OYICO,#ICOTX	JUMP',EQ LOOP4$LOOP2$:	LOAD.B	D3,(A6)+OSPLOP	CALL	SELMO		; utilise le bon lutin	CALL	WAITMOVE	; attend dplacement souris ...	COMP.W	D3,#KEYMPO	JUMP,EQ LOOP2$	JUMP	KEY$LOOP4$:	LOAD.W	D7,#TEXT_ICURSOR	PAGE_	TEXT		; met le curseurLOOP5$:	LOAD.B	D3,(A6)+OSPLOP	CALL	SELMO		; utilise le bon lutin	LOAD.W	D4,#20	CALL	WAITMOVED	; attend dplacement souris ...	JUMP',NE LOOP6$	COMP.W	D3,#KEYMPO	JUMP,EQ LOOP5$	LOAD.W	D7,#TEXT_ICURSOR	PAGE_	TEXT		; enlve le curseur	JUMP	KEY$LOOP6$:	LOAD.W	D7,#TEXT_ICURSOR	PAGE_	TEXT		; enlve le curseurLOOP7$:	LOAD.B	D3,(A6)+OSPLOP	CALL	SELMO		; utilise le bon lutin	LOAD.W	D4,#12	CALL	WAITMOVED	; attend dplacement souris ...	JUMP',NE LOOP4$	COMP.W	D3,#KEYMPO	JUMP,EQ LOOP7$;	JUMP	KEY$KEY$:	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#KEYMMP	JUMP,EQ CLIC$	COMP.W	D3,#KEYMDP	JUMP,EQ CLIC$	COMP.W	D3,#F0	JUMP,EQ REFAIT$	COMP.W	D3,#F0+SHIFT	JUMP,EQ REFAIT$	COMP.W	D3,#END	JUMP,EQ REFAIT$	COMP.W	D3,#F1	JUMP,EQ PREND$	COMP.W	D3,#F2	JUMP,EQ AJOUTE$	COMP.W	D3,#F3	JUMP,EQ SAUVE$	COMP.B	(A6)+OYICO,#ICOTX	JUMP',EQ EDIT$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOP$ERROR$:	CALL	DBOXERROR	; affiche l'erreur ...	JUMP	LOOP$EDIT$:	LOAD.W	D7,#TEXT_EDIT	PAGE_	TEXT	JUMP,NE BIP$MAJ$:	CALL	PGOUPDATE	; affiche l'objet	JUMP	LOOP$SAVE$:	COMP.B	(A6)+OYICO,#ICOTX	JUMP,NE LOOP$	CALL	ASCINV$		; efface l'objet slectionn	CALL	PGOSAVE		; sauve l'cran	CALL	ASCINV$		; allume l'objet slectionn	JUMP	LOOP$CLIC$:	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE BIP$	CALL	MOVGICONE	; souris dans une icne ?	JUMP,EQ ICONE$	LOAD.L	A1,#R16"ASCINV$	CALL	DOMASCENSEUR	; agit dans ascenseurs selon souris	JUMP,EQ SAVE$	COMP.B	(A6)+OSPLOP,#ICOSPLADD	JUMP,EQ ADD$	COMP.B	(A6)+OSPLOP,#ICOSPLSUB	JUMP,EQ SUB$	COMP.B	(A6)+OSPLOP,#ICOTXCURS	JUMP,EQ TXCURS$	COMP.B	(A6)+OSPLOP,#ICOTXDDD	JUMP,EQ TXDDD$	COMP.B	(A6)+OSPLOP,#ICOTXTABM	JUMP,EQ TXTAB$	COMP.B	(A6)+OSPLOP,#ICOTXTABD	JUMP,EQ TXTAB$	COMP.B	(A6)+OSPLOP,#ICOTXTABG	JUMP,EQ TXTAB$	COMP.B	(A6)+OSPLOP,#ICOTXTABC	JUMP,EQ TXTAB$	COMP.B	(A6)+OSPLOP,#ICOTXTABN	JUMP,EQ TXTAB$	CALL	PGODETECT	; D0 <-- poigne o est la souris	JUMP,NE BIP$	LOAD.W	D2,#CLRDOT	CALL	PGOINV		; teint les poignes	CALL	PGOBEGIN	; dbut du dplacement	CALL	SCMO		; remet la souris	LOAD.L	D2,#-1MOVE2$:	CALL	WAITMOVE	; attend dplacement souris ...	JUMP',NE MOVE8$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE MOVE2$	LOAD.W	D7,#DET_POINTP	PAGE_	DET		; D3 <-- point o est la souris	JUMP,NE MOVE2$	COMP.L	D3,D2		; position change ?	JUMP,EQ MOVE2$		; non => MOVE2$	LOAD.L	D2,D3	CALL	PGOMOVE		; dplace l'objet	JUMP	MOVE2$MOVE8$:	CALL	PGOEND		; fin du dplacement	JUMP,NE MENU$	LOAD.W	D2,#SETDOT	CALL	PGOINV		; allume les poignes	JUMP	LOOP$ADD$:	CALL	PGODETECT	; D0 <-- poigne o est la souris	JUMP,EQ BIP$	LOAD.W	D7,#DET_POINTP	PAGE_	DET		; D3 <-- point o est la souris	JUMP,NE BIP$	LOAD.W	D2,#CLRDOT	CALL	PGOINV		; teint les poignes	LOAD.L	D0,D3		; D0 <-- position du point  crer	JUMP	MOVE8$SUB$:	CALL	PGODETECT	; D0 <-- poigne o est la souris	JUMP,NE BIP$	TEST.W	D0	JUMP,EQ BIP$	LOAD.W	D2,#CLRDOT	CALL	PGOINV		; teint les poignes	JUMP	MOVE8$TXCURS$:	LOAD.W	D7,#TEXT_PCURSOR	PAGE_	TEXT		; positionne le curseur dans le pav	JUMP,NE BIP$	JUMP	LOOP$TXDDD$:	LOAD.W	D7,#TEXT_DZONE	PAGE_	TEXT		; D4/D5 <-- zone mise en vidence	JUMP,NE BIP$	COMP.L	D4,D5		; zone nulle ?	JUMP,EQ BIP$		; oui => BIP$	LOAD.L	A5,A4	LOAD.L	A3,#R16"TMMDDDTX	LOAD.L	A4,#(A6)+OMPATX	; A4 <-- ^paramtres	CLR.L	(A4)+LMM*0+OMMINA	CLR.L	(A4)+LMM*1+OMMINA	CLR.L	(A4)+LMM*2+OMMINA	CLR.L	(A4)+LMM*3+OMMINA	CLR.L	(A4)+LMM*4+OMMINA	TSET.B	(A4)+LMM*0+OMMINA+3:#2 ; grise la case "dplace"	TSET.B	(A4)+LMM*0+OMMINA+3:#3 ; grise la case "duplique"	CALL	MMENUS		; choix selon mmenus ...	EX.L	A4,A5	LOAD.W	D2,(A5)+LMM*0+OMMSEL	COMP.W	D2,#1	JUMP',EQ TXOPER$	COMP.W	D2,#2	JUMP',EQ TXOPER$	COMP.W	D2,#3	JUMP',EQ TXOPER$	LOAD.W	D3,(A5)+LMM*1+OMMSEL	COMP.W	D2,#4	JUMP',EQ TXOPER$	LOAD.W	D3,(A5)+LMM*2+OMMSEL	COMP.W	D2,#5	JUMP',EQ TXOPER$	LOAD.W	D3,(A5)+LMM*3+OMMSEL	COMP.W	D2,#6	JUMP',EQ TXOPER$	LOAD.W	D3,(A5)+LMM*4+OMMSEL	COMP.W	D2,#7	JUMP',EQ TXOPER$	LOAD.W	D3,(A5)+LMM*5+OMMSEL	COMP.W	D2,#8	JUMP',EQ TXOPER$	JUMP'	TXLOOP$TXOPER$:	LOAD.W	D7,#TEXT_OPMOUSE	PAGE_	TEXT	JUMP',NE TXBIP$	JUMP	MAJ$TXBIP$:	LOAD.W	D7,#TEXT_EZONE	PAGE_	TEXT		; efface la zone dans D4/D5	JUMP	BIP$TXLOOP$:	LOAD.W	D7,#TEXT_EZONE	PAGE_	TEXT		; efface la zone dans D4/D5	JUMP	LOOP$TXTAB$:	CLR.W	D3	LOAD.B	D3,(A6)+OSPLOP	LOAD.W	D7,#TEXT_RGMOVE	PAGE_	TEXT		; ajoute/supprime un tabulateur	JUMP,NE BIP$	JUMP	MAJ$ICONE$:	CLR.W	D7	COMP.B	D3,#ICOSPLMOV	JUMP,EQ OPER$	COMP.B	D3,#ICOSPLADD	JUMP,EQ OPER$	COMP.B	D3,#ICOSPLSUB	JUMP,EQ OPER$	COMP.B	D3,#ICOTXCURS	JUMP,EQ OPER$	COMP.B	D3,#ICOTXDDD	JUMP,EQ OPER$	COMP.B	D3,#ICOTXTABM	JUMP,EQ OPER$	COMP.B	D3,#ICOTXTABD	JUMP,EQ OPER$	COMP.B	D3,#ICOTXTABG	JUMP,EQ OPER$	COMP.B	D3,#ICOTXTABC	JUMP,EQ OPER$	COMP.B	D3,#ICOTXTABN	JUMP,EQ OPER$	CLR.W	D4		; D4 <-- ouvert	COMP.B	D3,#ICOSPLINEO	JUMP,EQ OF$	COMP.B	D3,#ICOLINEBO	JUMP,EQ OF$	INC.W	D4		; D4 <-- ferm	COMP.B	D3,#ICOSPLINEF	JUMP,EQ OF$	COMP.B	D3,#ICOLINEBF	JUMP,EQ OF$	COMP.B	D3,#ICOHOMOT	JUMP,EQ HOMOT$	COMP.B	D3,#ICOINIT4	JUMP,EQ INIT$	COMP.B	D3,#ICOJUST	JUMP,EQ TXJUST$	COMP.B	D3,#ICOITL	JUMP,EQ TXITL$	COMP.B	D3,#ICOITC	JUMP,EQ TXITC$	COMP.B	D3,#ICOGGDEF	JUMP,EQ TXGENC$	COMP.B	D3,#ICOHORIZ	JUMP,EQ BLOQUE$	COMP.B	D3,#ICOVERTI	JUMP,EQ BLOQUE$	COMP.B	D3,#ICOFLAGS	JUMP,EQ FLAGS$	COMP.B	D3,#ICODEVANT	JUMP,EQ LAST$	COMP.B	D3,#ICODERRIERE	JUMP,EQ FIRST$	COMP.B	D3,#ICOPOUBELLE	JUMP,EQ DETRUIT$	COMP.B	D3,#ICODACCORD	JUMP,EQ REFAIT$	JUMP	BIP$OPER$:	COMP.B	D3,(A6)+OSPLOP	JUMP,EQ BIP$	LOAD.W	D2,#CLRDOT	CALL	PGOINV		; teint les poignes	PUSH.W	D3	LOAD.B	D3,(A6)+OSPLOP	LOAD.W	D7,#TEXT_RGIDRAW	PAGE_	TEXT		; teint les rgles	CALL	INVICONE	; teint l'ancienne opration	POP.W	D3	LOAD.B	(A6)+OSPLOP,D3	CALL	INVICONE	; allume la nouvelle opration	LOAD.W	D7,#TEXT_RGIDRAW	PAGE_	TEXT		; allume les rgles	LOAD.W	D2,#SETDOT	CALL	PGOINV		; allume les poignes	JUMP	LOOP$OF$:	COMP.B	(A6)+OYICO,#ICOSP	JUMP',EQ OFSP$	COMP.B	(A6)+OYICO,#ICOLB	JUMP,EQ OFLB$	JUMP	BIP$OFSP$:	COMP.B	D4,(A4)+OOSPMOF	; y a-t-il un changement ?	JUMP,EQ BIP$		; non => BIP$	PUSH.W	D3	LOAD.B	D3,#ICOSPLINEO	TEST.B	(A4)+OOSPMOF	JUMP',EQ OFSP2$	LOAD.B	D3,#ICOSPLINEFOFSP2$:	CALL	INVICONE	; teint l'ancienne icne	POP.W	D3	CALL	INVICONE	; allume la nouvelle	LOAD.W	D2,#CLRDOT	CALL	PGOINV		; teint les poignes	LOAD.B	(A4)+OOSPMOF,D4	PUSH.B	(A6)+OSPLOP	CLR.B	(A6)+OSPLOP	CALL	PGOEND		; modifie spline/ligne brise	POP.B	(A6)+OSPLOP	TEST.W	D7	JUMP,NE MENU$	LOAD.W	D2,#SETDOT	CALL	PGOINV		; allume les poignes	JUMP	LOOP$OFLB$:	COMP.B	D4,(A4)+OOLBMOF	; y a-t-il un changement ?	JUMP,EQ BIP$		; non => BIP$	PUSH.W	D3	LOAD.B	D3,#ICOLINEBO	TEST.B	(A4)+OOLBMOF	JUMP',EQ OFLB2$	LOAD.B	D3,#ICOLINEBFOFLB2$:	CALL	INVICONE	; teint l'ancienne icne	POP.W	D3	CALL	INVICONE	; allume la nouvelle	LOAD.W	D2,#CLRDOT	CALL	PGOINV		; teint les poignes	LOAD.W	D2,#INVDOT	LOAD.W	D7,#DESS_OBJET	PAGE_	DESS		; teint l'objet	LOAD.B	(A4)+OOLBMOF,D4	PUSH.B	(A6)+OSPLOP	CLR.B	(A6)+OSPLOP	CALL	PGOEND		; modifie spline/ligne brise	POP.B	(A6)+OSPLOP	TEST.W	D7	JUMP,NE MENU$	LOAD.W	D2,#INVDOT	LOAD.W	D7,#DESS_OBJET	PAGE_	DESS		; allume l'objet	LOAD.W	D2,#SETDOT	CALL	PGOINV		; allume les poignes	JUMP	LOOP$TXJUST$:	LOAD.L	D4,(A4)+OOTXJUS	CALL	DBOXTXJUST	; demande le mode de justification ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	LOAD.L	(A4)+OOTXJUS,D4	LOAD.L	(A6)+OTXJUS,D4	JUMP	MAJ$TXITL$:	LOAD.L	D4,(A4)+OOTXITL	CALL	DBOXTXITL	; demande l'interligne ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	LOAD.L	(A4)+OOTXITL,D4	LOAD.L	(A6)+OTXITL,D4	JUMP	MAJ$TXITC$:	LOAD.L	D4,(A4)+OOTXITC	CALL	DBOXTXITC	; demande l'intercaractre ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	LOAD.L	(A4)+OOTXITC,D4	LOAD.L	(A6)+OTXITC,D4	JUMP	MAJ$TXGENC$:	CALL	DBOXGENCAR	; choix du caractre ...	JUMP,NE BIP$	JUMP	MAJ$HOMOT$:	LOAD.B	D3,#ICOHOMOT	CALL	INVICONE	; inverse le mode	LOAD.B	D3,#ICOHOMOT	TEST.B	(A6)+OSTRHO	JUMP',EQ HOMOT2$	CLR.B	D3HOMOT2$:	LOAD.B	(A6)+OSTRHO,D3	JUMP	LOOP$INIT$:	COMP.W	(A4)+OOOBJ,#ICOIM	JUMP,NE LOOP$	LOAD.W	D2,#CLRDOT	CALL	PGOINV		; teint les poignes	LOAD.W	D2,#INVDOT	LOAD.W	D7,#DESS_OBJET	PAGE_	DESS		; teint l'image	LOAD.L	(A4)+OOIMDIM,(A4)+OOIMLGY	LOAD.W	D7,#DESS_INITIMZOOM	PAGE_	DESS		; calcule la matrice zoome	LOAD.W	D2,#INVDOT	LOAD.W	D7,#DESS_OBJET	PAGE_	DESS		; allume l'image	LOAD.W	D2,#SETDOT	CALL	PGOINV		; allume les poignes	LOAD.W	D7,#DET_INITQ	PAGE_	DET		; ajuste pour les dtections	JUMP	LOOP$BLOQUE$:	COMP.B	D3,(A6)+OSTRHV	JUMP',EQ DEBLOQUE$	PUSH.W	D3	LOAD.B	D3,(A6)+OSTRHV	CALL	INVICONE	; teint l'ancien mode	POP.W	D3	LOAD.B	(A6)+OSTRHV,D3	CALL	INVICONE	; allume le nouveau mode	JUMP	LOOP$DEBLOQUE$:	CALL	INVICONE	CLR.B	(A6)+OSTRHV	JUMP	LOOP$FLAGS$:	CALL	DBOXFLAGS	; demande les flags ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	CALL	ASCINV$		; efface l'objet slectionn	CLR.L	(A6)+OPLDIM	LOAD.W	D7,#DESS_OBJETS	PAGE_	DESS		; redessine les objets	CALL	ASCINV$		; allume l'objet slectionn	JUMP	LOOP$PREND$:	COMP.B	(A6)+OYICO,#ICOTX	JUMP,NE BIP$PREND2$:	LOAD.L	A3,#(A6)+OTXNAM	CALL	DBOXPRENDTX	; demande le nom ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	LOAD.W	D7,#IO_RTEXT	PAGE_	IO		; lit le texte	JUMP,EQ MAJ$	CALL	DBOXERROR	; affiche l'erreur ...	JUMP	PREND2$AJOUTE$:	COMP.B	(A6)+OYICO,#ICOTX	JUMP,NE BIP$AJOUTE2$:	LOAD.L	A3,#(A6)+OTXNAM	CALL	DBOXAJOUTETX	; demande le nom ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	LOAD.W	D7,#IO_RTEXT	PAGE_	IO		; lit le texte	JUMP,EQ MAJ$	CALL	DBOXERROR	; affiche l'erreur ...	JUMP	AJOUTE2$SAUVE$:	COMP.B	(A6)+OYICO,#ICOTX	JUMP,NE BIP$SAUVE2$:	LOAD.L	A3,#(A6)+OTXNAM	CALL	DBOXCREATETX	; demande le nom ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	LOAD.W	D7,#IO_WTEXT	PAGE_	IO		; crit le texte	JUMP,EQ MAJ$	CALL	DBOXERROR	; affiche l'erreur ...	JUMP	SAUVE2$LAST$:	LOAD.W	D7,#BASE_LAST	PAGE_	BASE		; met  la fin de la liste	JUMP'	REFAIT$FIRST$:	LOAD.W	D7,#BASE_FIRST	PAGE_	BASE		; met au dbut de la liste	JUMP'	REFAIT$DETRUIT$:	LOAD.W	D2,#CLRDOT	CALL	PGOINV		; teint les poignes	LOAD.B	D3,(A6)+OSPLOP	LOAD.W	D7,#TEXT_RGIDRAW	PAGE_	TEXT		; teint les rgles	LOAD.W	D2,#INVDOT	LOAD.W	D7,#DESS_OBJET	PAGE_	DESS		; teint l'objet	LOAD.W	D7,#BASE_REMOVE	PAGE_	BASE		; enlve de la base de donnes	JUMP'	MENU$REFAIT$:	PUSH.W	D7	LOAD.W	D2,#CLRDOT	CALL	PGOINV		; teint les poignes	LOAD.B	D3,(A6)+OSPLOP	LOAD.W	D7,#TEXT_RGIDRAW	PAGE_	TEXT		; teint les rgles	LOAD.W	D2,#INVDOT	LOAD.W	D7,#DESS_OBJET	PAGE_	DESS		; efface l'objet en inverse	LOAD.W	(A4)+OOFSCA,#-1	; faudra refaire les matrices de fond	LOAD.W	D7,#DESS_SET	PAGE_	DESS		; redessine l'objet	POP.W	D7MENU$:	PUSH.W	D7	CALL	PGOFREE		; libre les matrices	CLR.B	(A6)+OXICO	; fin de la dformation	CALL	REMICONE	; remet les icnes  gauche	CALL	AFMENU		; refait les soft-keys	POP.W	D7	JUMP,NE ERROR	JUMP	LOOPASCINV$:	PUSHM.L	D2,D3	INC.B	(A6)+OPOICNT	TEST.B	(A6)+OPOICNT:#0	JUMP',BS 40$	LOAD.W	D2,#INVDOT	LOAD.W	D7,#DESS_OBJET	PAGE_	DESS		; allume  l'objet	LOAD.B	D3,(A6)+OSPLOP	LOAD.W	D7,#TEXT_RGIDRAW	PAGE_	TEXT		; allume les rgles	LOAD.W	D2,#SETDOT	CALL	PGOINV		; allume les poignes	JUMP'	90$40$:	LOAD.W	D2,#CLRDOT	CALL	PGOINV		; teint les poignes	LOAD.B	D3,(A6)+OSPLOP	LOAD.W	D7,#TEXT_RGIDRAW	PAGE_	TEXT		; teint les rgles	LOAD.W	D2,#INVDOT	LOAD.W	D7,#DESS_OBJET	PAGE_	DESS		; teint l'objet90$:	POPM.L	D2,D3	RETTMMDDD:	.ASCIZ	" "	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODETRUIT	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  dtruit"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODEPLACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	"  dplace  "	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOMOVE	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODUPLIQUE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	"  duplique "	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOMOVE	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.B	-1	.BW	-2,OPER$-TMMDDD	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODIVERS	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  opration"	.BW	-2,PLAN$-TMMDDD	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOPLAN	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  plan"	.B	-1	.BW	-2,MODIF$-TMMDDD	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOMMODIF	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  modifie"	.BW	-2,DIAL$-TMMDDD	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODMODIF	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  modifie.."	.B	0OPER$:	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOZOOM	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  zoom.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOTOURNE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  tourne.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOMIROIR	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  miroir.."	.B	0PLAN$:	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODEVANT	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  devant"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODERRIERE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  derrire"	.B	0MODIF$:	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOMTRAIT	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  trait "	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOMTRAME	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  trame"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOMFOND	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  fond"	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOMOBJET	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  objet"	.B	0DIAL$:	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODTRAIT	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  trait.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODTRAME	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  trame.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODFOND	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  fond.."	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODOBJET	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  objet.."	.B	0TMMDDDTX:	.ASCIZ	" "	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODETRUIT	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  dtruit"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODEPLACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  dplace"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODUPLIQUE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  duplique"	.B	-1	.BW	-2,-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT+1	.B	ICOTXCAR&H'7F	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  caractre"	.BW	-2,SOUL$-TMMDDDTX	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT+1	.B	ICOTXSOUL&H'7F	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  soulign"	.BW	-2,EXP$-TMMDDDTX	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT+1	.B	ICOTXEXIN&H'7F	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  exposant"	.BW	-2,COUL$-TMMDDDTX	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT+1	.B	ICOTXCOUL&H'7F	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  couleur"	.B	-1	.BW	-2,MINMAJ$-TMMDDDTX	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT+1	.B	ICOTXMIMA&H'7F	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  transforme"	.B	0SOUL$:	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT+1	.B	ICOTXSNOR&H'7F	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  normal "	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT+1	.B	ICOTXSSOU&H'7F	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  soulign "	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT+1	.B	ICOTXSBIF&H'7F	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  biff "	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT+1	.B	ICOTXSSUR&H'7F	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  surlign "	.B	0EXP$:	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT+1	.B	ICOTXENOR&H'7F	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  normal "	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT+1	.B	ICOTXEEXP&H'7F	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  exposant "	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT+1	.B	ICOTXEIND&H'7F	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  indice "	.B	0COUL$:	.ASCIZ	" noir "	.B	-1	.ASCIZ	" rouge "	.ASCIZ	" vert "	.ASCIZ	" bleu "	.ASCIZ	" violet "	.ASCIZ	" jaune "	.ASCIZ	" brun "	.ASCIZ	" blanc "	.B	0MINMAJ$:	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT+1	.B	ICOTXMMIN&H'7F	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  minuscules "	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT+1	.B	ICOTXMMAJ&H'7F	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  majuscules "	.B	0	.EVEN;-----------\\; IFNEWOBJET >;===========/; Regarde si un objet correspond exactement aux dfinitions standards.; in	A4.L	^objet; out	D7.W	erreur; mod	D7.WIFNEWOBJET:	PUSH.L	D4	CLR.W	D7		; D7 <-- y'a qq chose  faire	LOAD.W	D4,(A4)+OOOBJ	COMP.W	D4,#ICODR	JUMP',EQ DR$	COMP.W	D4,#ICOFL	JUMP',EQ FL$	COMP.W	D4,#ICORA	JUMP',EQ RA$	COMP.W	D4,#ICOPO	JUMP',EQ PO$	COMP.W	D4,#ICOCE	JUMP',EQ CE$	COMP.W	D4,#ICOEL	JUMP',EQ EL$	COMP.W	D4,#ICOAR	JUMP,EQ AR$	JUMP	IDEM$DR$:	LOAD.L	D4,(A4)+OODRTYP	COMP.L	D4,(A6)+ODRTYP	JUMP',NE EXIT$	JUMP	IDEM$FL$:	LOAD.L	D4,(A4)+OOFLTYP	COMP.L	D4,(A6)+OFLTYP	JUMP',NE EXIT$	JUMP	IDEM$RA$:	LOAD.L	D4,(A4)+OORATYP	COMP.L	D4,(A6)+ORATYP	JUMP',NE EXIT$	LOAD.W	D4,(A4)+OORARAY	COMP.W	D4,(A6)+ORARAY	JUMP',NE EXIT$	JUMP'	IDEM$PO$:	LOAD.L	D4,(A4)+OOPOTYP	COMP.L	D4,(A6)+OPOTYP	JUMP',NE EXIT$	JUMP'	IDEM$CE$:	LOAD.L	D4,(A4)+OOCETYP	COMP.L	D4,(A6)+OCETYP	JUMP',NE EXIT$	JUMP'	IDEM$EL$:	LOAD.L	D4,(A4)+OOELTYP	COMP.L	D4,(A6)+OELTYP	JUMP',NE EXIT$	JUMP'	IDEM$AR$:	LOAD.L	D4,(A4)+OOARTYP	COMP.L	D4,(A6)+OARTYP	JUMP',NE EXIT$	LOAD.W	D4,(A4)+OOARANG	COMP.W	D4,(A6)+OARANG	JUMP',NE EXIT$;	JUMP'	IDEM$IDEM$:	LOAD.W	D7,#1		; D7 <-- y'a rien  faireEXIT$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET	.END