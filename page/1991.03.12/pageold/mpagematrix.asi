	.SBTTL	MPAGEMATRIX;----------\\; MATPENDIM >;==========/; Donne les demi-dimensions du pinceau d'un objet.; in	A4.L	^objet; out	D0.L	demi-dimensions du pinceau; mod	D0.LMATPENDIM:	PUSH.L	A3	LOAD.L	D0,#H'10000*1+1	TEST.B	(A6)+OVUE+3:#BVUFIL-0 ; vue en fil de fer ?	JUMP',BS 90$		; oui => 90$	LOAD.L	A3,#(A6)+OTAPEN	LOAD.W	D0,(A4)+OOPEN	MUL.WU	D0,#LDPEN	LOAD.L	D0,(A3)+(D0.L)+OPENLY ; D0 <-- dimensions	SR.W	D0,#1	INC.W	D0	SWAP.W	D0	SR.W	D0,#1	INC.W	D0	SWAP.W	D090$:	POP.L	A3	RET;--------\\; MATPEN  >;========/; Utilise la bonne matrice pour le pinceau.; in	D1.W	numro du pinceau;	D2.W	mode initial; out	D2.W	mode v. avec pinceau; mod	D2.L, D7.WMATPEN:	PUSHM.L	D1,D3,D4,A3,A4	TEST.L	D2:#BMDNMSK	JUMP,BS 90$	TEST.L	(A6)+OPTPEN	JUMP',EQ 20$	PUSH.W	D1	LOAD.L	A4,(A6)+OPTPEN	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	CLR.L	(A6)+OPTPEN	POP.W	D120$:	LOAD.L	A3,#(A6)+OTAPEN	MUL.WU	D1,#LDPEN	ADD.L	A3,D1		; A3 <-- ^pinceau	LOAD.L	D3,(A3)+OPENLY	; D3 <-- dimensions	CALL	DETSCALEP	; D3 <-- plus grand si n:1	LOAD.L	D4,D3	TEST.W	D4		; largeur nulle ?	JUMP',NE 30$	INC.W	D430$:	SWAP.W	D4	TEST.W	D4		; hauteur nulle ?	JUMP',NE 32$	INC.W	D432$:	SWAP.W	D4	LOAD.L	D3,(A3)+OPENFA	; D3 <-- fanions	CALL	MATPENCREATE	; A4 <-- ^matrice	JUMP,NE 90$	LOAD.L	(A6)+OPTPEN,A4	CALL	MATPENUSE	; utilise le pinceau	OR.W	D2,#PENDOT	TEST.B	(A3)+OPENFA+2:#BPENTT-8	JUMP',BC 90$	LOAD.L	A4,A3		; A4 <-- ^pinceau	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#XMAPTT	CLR.W	(A3)+1		; <oo>	LOAD.L	D3,(A4)+OPENT1	CALL	DETSCALEP	; D3 <-- plus grand si n:1	LOAD.L	(A3)+3,D3	; <p1> et <v1>	LOAD.L	D3,(A4)+OPENT3	CALL	DETSCALEP	; D3 <-- plus grand si n:1	LOAD.L	(A3)+7,D3	; <p2> et <v2>	LOAD.L	D3,(A4)+OPENT5	CALL	DETSCALEP	; D3 <-- plus grand si n:1	LOAD.L	(A3)+11,D3	; <p3> et <v3>	CLR.L	(A3)+15		; <p4> et <v4>	LOAD.W	D3,#19	LIB	?STRING		; utilise le pinceau	OR.W	D2,#TTTDOT90$:	POPM.L	D1,D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; MATPENUSE >;----------/; Utilise un pinceau.; in	D4.L	dimensions (dy;dx);	A4.L	^matrice; out	-; mod	D7.WMATPENUSE:	PUSHM.L	D3,D4,A3	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#XPEN	CLR.L	(A3)+1		; <xx> et <yy>	LOAD.L	(A3)+5,A4	; <pppp>	LOAD.W	D3,D4	ADD.W	D3,#16-1	SR.W	D3,#4		; D3 <-- largeur en words	SL.W	D3,#1		; D3 <-- largeur en bytes	LOAD.W	(A3)+9,D3	; <ii>	SWAP.W	D4	LOAD.L	(A3)+11,D4	; <dx> et <dy>	LOAD.W	D3,#15	LIB	?STRING		; utilise le pinceau	POPM.L	D3,D4,A3	RET;-------------\\; MATPENCREATE >;-------------/; Cre la matrice d'un pinceau.; in	D4.L	dimensions (dy;dx);	D3.W	fanions; out	A4.L	^matrice;	D7.W	erreur; mod	D7.W, A4.LMATPENCREATE:	PUSHM.L	D0..D4,A3	LOAD.W	D0,D4		; D0 <-- dx	LOAD.L	D2,D4	SWAP.W	D2		; D2 <-- dy	LOAD.W	D4,D0		; D4 <-- dx	ADD.W	D4,#16-1	SR.W	D4,#4		; D4 <-- largeur en words	SL.W	D4,#1		; D4 <-- largeur en bytes	MUL.WU	D4,D2		; D4 <-- nb de bytes ncessaires	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour matrice	JUMP,NE 90$	GESMEM	?CLEARMEM	; met toute la matrice  zro	LOAD.W	D4,D2	SWAP.W	D4	LOAD.W	D4,D0		; D4 <-- dimensions	CALL	OPEDITMAT	; dessine dans la matrice (T)	LOAD.L	D4,#-1	CALL	DRMDEF		; trame toute noire	TEST.L	D3:#BPENCA	JUMP',BS 40$	TEST.L	D3:#BPENRE	JUMP',BS 40$				; pinceau circulaire/elliptique =>	COMP.W	D0,#5	JUMP',LO 40$	COMP.W	D2,#5	JUMP',LO 40$	LOAD.W	D4,D2	SR.W	D4,#1	SWAP.W	D4	LOAD.W	D4,D0	SR.W	D4,#1		; D4 <-- demi-dimensions	LOAD.L	D3,D4	LOAD.W	D1,#-1		; D1 <-- tous les octants	LOAD.W	D2,#SETDOT	LIB	?DRELLIPSE	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWFILLO	SWAP.W	D3	LOAD.L	(A3)+1,D3	LOAD.B	(A3)+5,#DRAWFILLC	LOAD.W	D3,#6	LIB	?STRING		; rempli l'intrieur de l'ellipse	JUMP'	80$40$:				; pinceau carr/rectangulaire =>	CLR.L	D3	LOAD.W	D4,D2	SWAP.W	D4	LOAD.W	D4,D0		; D4 <-- dimensions	LOAD.W	D2,#SETDOT	LIB	?DRTRAME	; dessine le pinceau rectangulaire80$:	CALL	CLODITMAT	; fin du dessin dans la matrice (T)	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D4,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; MATTRAME >;=========/; Utilise la bonne matrice pour la trame.; in	D1.W	numro de la trame; out	-; mod	D7.WMATTRAME:	PUSHM.L	D1,D3,D4,A3,A4	TEST.L	(A6)+OPTTRA	JUMP',EQ 20$	PUSH.W	D1	LOAD.L	A4,(A6)+OPTTRA	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	CLR.L	(A6)+OPTTRA	POP.W	D120$:	LOAD.L	A3,#(A6)+OTATRA	MUL.WU	D1,#LDTRA	ADD.L	A3,D1		; A3 <-- ^trame	CALL	MATTRACREATE	; A4 <-- ^matrice	JUMP',NE 90$	LOAD.L	(A6)+OPTTRA,A4	CALL	MATTRAUSE	; utilise la trame90$:	POPM.L	D1,D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; MATTRAUSE >;----------/; Utilise une trame.; in	D4.L	dimensions (dy;dx);	A4.L	^matrice; out	-; mod	D7.WMATTRAUSE:	PUSHM.L	D3,D4,A3	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#XTRAME	CLR.L	(A3)+1		; <xx> et <yy>	LOAD.L	(A3)+5,A4	; <pppp>	LOAD.W	D3,D4	ADD.W	D3,#16-1	SR.W	D3,#4		; D3 <-- largeur en words	SL.W	D3,#1		; D3 <-- largeur en bytes	LOAD.W	(A3)+9,D3	; <ii>	SWAP.W	D4	LOAD.L	(A3)+11,D4	; <dx> et <dy>	LOAD.L	D3,(A6)+OPIPOS	CALL	DETSCALEP	; D3 <-- plus grand si n:1	NEG.W	D3	SWAP.W	D3	NEG.W	D3	LOAD.L	(A3)+15,D3	; <ox> et <oy>	LOAD.W	D3,#19	LIB	?STRING		; utilise la trame	POPM.L	D3,D4,A3	RET;-------------\\; MATTRACREATE >;-------------/; Cre la matrice d'une trame.; in	A3.L	^trame; out	D4.L	dimensions (dy;dx);	A4.L	^matrice;	D7.W	erreur; mod	D4.L, D7.W, A4.LMATTRACREATE:	PUSHM.L	D0..D3,A2,A3	CALL	MATTRADIM	; D4 <-- dimensions de la trame	LOAD.L	D1,D4	SWAP.W	D1		; D1 <-- dy	LOAD.W	D0,D4		; D0 <-- dx;	LOAD.W	D4,D0		; D4 <-- dx	ADD.W	D4,#16-1	SR.W	D4,#4		; D4 <-- largeur en words	SL.W	D4,#1		; D4 <-- largeur en bytes	MUL.WU	D4,D1		; D4 <-- nb de bytes ncessaires	PUSH.L	D1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour matrice	POPM.L	D1	JUMP,NE 90$	GESMEM	?CLEARMEM	; met toute la matrice  zro	LOAD.W	D4,D1	SWAP.W	D4	LOAD.W	D4,D0		; D4 <-- dimensions	CALL	OPEDITMAT	; dessine dans la matrice (T)	LOAD.L	D4,#-1	CALL	DRMDEF		; trame toute noire	LOAD.L	D3,(A3)+OTRAFA	; D3 <-- fanions	TEST.L	D3:#BTRAGR	JUMP,BC 40$	TEST.L	D3:#BTRAPC	JUMP,BC 30$				; petite trame grise =>	CALL	MATTRACRGREY.IF 0	LOAD.L	(A6)+OSTRETCH+OSTRSPT,A2	LOAD.W	(A6)+OSTRETCH+OSTRSDX,#1	CLR.L	(A6)+OSTRETCH+OSTRS0	LOAD.L	(A6)+OSTRETCH+OSTRS2,#H'10000*7+7	LOAD.L	(A6)+OSTRETCH+OSTRDPT,A4	LOAD.W	(A6)+OSTRETCH+OSTRDDX,(A0)+ODFIIY	CLR.L	(A6)+OSTRETCH+OSTRD0	CLR.W	(A6)+OSTRETCH+OSTRD1+0	CLR.W	(A6)+OSTRETCH+OSTRD3+2	LOAD.W	D4,#8	TEST.L	D3:#BTRA2X	JUMP',BC 26$	SL.W	D4,#126$:	LOAD.W	(A6)+OSTRETCH+OSTRD1+2,D4	LOAD.W	(A6)+OSTRETCH+OSTRD4+0,D4	LOAD.W	(A6)+OSTRETCH+OSTRD2+2,D4	LOAD.W	(A6)+OSTRETCH+OSTRD2+0,D4	PUSH.L	A0	LOAD.L	A0,#(A6)+OSTRETCH	ST_	RECT	POP.L	A0.ENDIF	JUMP	80$30$:				; grosse trame grise =>	LIB	?AFTIM	.B	MODGRA,GRAROUND	; graphique cylindrique	.B	0	.EVEN	LOAD.W	D2,(A3)+OTRAGP	CALL	MATTRACRBIG	JUMP	80$40$:				; trame hachure =>	LIB	?AFTIM	.B	MODGRA,GRAROUND	; graphique cylindrique	.B	0	.EVEN	LOAD.W	D2,(A3)+OTRAI1	LOAD.W	D3,(A3)+OTRAE1	CALL	DETSCALEP	; D3 <-- plus grand si n:1	CALL	MATTRACRLINE	LOAD.L	D3,(A3)+OTRAFA	; D3 <-- fanions	TEST.L	D3:#BTRAD2	JUMP',BC 80$	LOAD.W	D2,#135	TEST.L	D3:#BTRADI	JUMP',BS 44$	LOAD.W	D2,#90	TEST.L	D3:#BTRADV	JUMP',BS 44$	LOAD.W	D2,#45	TEST.L	D3:#BTRADO	JUMP',BS 44$	CLR.W	D244$:	LOAD.W	D3,(A3)+OTRAE2	CALL	DETSCALEP	; D3 <-- plus grand si n:1	CALL	MATTRACRLINE;	JUMP'	80$80$:	LIB	?AFTIM	.B	MODGRA,GRACLIP	; graphique avec clipping	.B	0	.EVEN	CALL	CLODITMAT	; fin du dessin dans la matrice (T)	LOAD.W	D4,D1	SWAP.W	D4	LOAD.W	D4,D0		; D4 <-- dimensions	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D3,A2,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; MATTRADIM >;----------/; Calcule les dimensions d'une trame.; in	A3.L	^trame; out	D4.L	dimensions (dy;dx); mod	D4.L, D7.WMATTRADIM:	PUSHM.L	D1..D3	LOAD.L	D1,(A3)+OTRAFA	; D1 <-- fanions	TEST.L	D1:#BTRAHA	JUMP,BS 50$				; trame grise =>	TEST.L	D1:#BTRAPC	JUMP',BS 30$	LOAD.W	D3,(A3)+OTRADI	CALL	DETSCALEP	; D3 <-- plus grand si n:1	TEST.W	D3		; largeur nulle ?	JUMP',NE 20$	INC.W	D320$:	TEST.L	D1:#BTRAQC	JUMP',BC 22$	SL.W	D3,#122$:	LOAD.W	D4,D3		; D4 <-- dy	SWAP.W	D4	LOAD.W	D4,D3		; D4 <-- dx	JUMP	80$30$:	LOAD.W	D3,#8	TEST.L	D1:#BTRA2X	JUMP',BC 32$	SL.W	D3,#132$:	LOAD.W	D4,D3		; D4 <-- dy	SWAP.W	D4	LOAD.W	D4,D3		; D4 <-- dx	JUMP	80$50$:				; trame hachure =>	LOAD.W	D3,(A3)+OTRAD1	CALL	DETSCALEP	; D3 <-- plus grand si n:1	MUL.WA	D3,#10000	LOAD.L	D4,D3	LOAD.W	D1,(A3)+OTRAI1	LIB	?CALCSIN	; D2 <-- 10000*SIN(I1)	TEST.W	D2	JUMP',EQ 60$	DIV.WA	D3,D2	TEST.W	D3	JUMP',NC 54$	NEG.W	D354$:	LIB	?CALCCOS	; D2 <-- 10000*COS(I1)	TEST.W	D2	JUMP',EQ 60$	DIV.WA	D4,D2	TEST.W	D4	JUMP',NC 56$	NEG.W	D456$:	SWAP.W	D4	LOAD.W	D4,D3	JUMP'	80$60$:	LOAD.W	D3,(A3)+OTRAD1	CALL	DETSCALEP	; D3 <-- plus grand si n:1	LOAD.W	D4,D3	SWAP.W	D4	LOAD.W	D4,D3;	JUMP'	80$80$:	TEST.W	D4	JUMP',NE 85$	INC.W	D485$:	SWAP.W	D4	TEST.W	D4	JUMP',NE 86$	INC.W	D486$:	SWAP.W	D4	POPM.L	D1..D3	RET;-------------\\; MATTRACRGREY >;-------------/; Gnre une trame grise.; in	A3.L	^trame; out	-; mod	D7.WMATTRACRGREY:	PUSHM.L	D1..D4,A3,A4	LOAD.L	D3,(A3)+OTRAFA	; D3 <-- fanions	LOAD.W	D4,(A3)+OTRAGP	MUL.WU	D4,#32	DIV.WU	D4,#100	COMP.W	D4,#32	JUMP',LS 20$	LOAD.W	D4,#3220$:	MUL.WU	D4,#8	LOAD.L	A4,#R16"TATRAMEG	ADD.L	A4,D4		; A4 <-- ^trame 8x8	LOAD.L	A3,(A0)+ODFABS	; A3 <-- ^dans la matrice	TEST.L	D3:#BTRA2X	JUMP',BS 40$	LOAD.W	D3,#8-130$:	LOAD.B	(A3),(A4+)	ADD.W	A3,(A0)+ODFIIY	DECJ.W,NMO D3,30$	JUMP	90$40$:	LOAD.W	D3,#8-142$:	LOAD.B	D2,(A4+)	LOAD.W	D1,#8-143$:	SL.W	D4,#2	RL.B	D2,#1	JUMP',CC 44$	OR.B	D4,#B'1144$:	DECJ.W,NMO D1,43$	LOAD.W	(A3),D4	ADD.W	A3,(A0)+ODFIIY	LOAD.W	(A3),D4	ADD.W	A3,(A0)+ODFIIY	DECJ.W,NMO D3,42$90$:	POPM.L	D1..D4,A3,A4	RET;------------\\; MATTRACRBIG >;------------/; Gnre une trame avec des gros points carrs ou ronds.; in	D0.W	largeur;	D1.W	hauteur;	D2.W	intensit (0..100);	D3.L	fanions	; out	-; mod	D7.WMATTRACRBIG:	PUSHM.L	D0..D4	TEST.W	D2		; trame de 0% ?	JUMP,EQ 90$	COMP.W	D2,#100		; trame de 100% ?	JUMP',EQ 10$	TEST.L	D3:#BTRAQC	JUMP,BS 40$	TEST.L	D3:#BTRAGO	JUMP',BS 20$10$:				; points carrs aligns =>	TCLR.L	D3:#BTRAGO	TSET.L	D3:#BTRAGC	CLR.L	D4	CALL	MATTRACRDOT	JUMP	90$20$:				; points ronds aligns =>	COMP.W	D2,#66	JUMP',HI 24$	CLR.L	D4	CALL	MATTRACRDOT	LOAD.W	D3,D1	SR.W	D3,#1	SWAP.W	D3	LOAD.W	D3,D0	SR.W	D3,#1	CALL	MATTRACRFILL	JUMP	90$24$:	SUB.W	D2,#100	NEG.W	D2	CLR.L	D4	CALL	MATTRACRDOT	LOAD.W	D3,D1	SR.W	D3,#1	SWAP.W	D3	LOAD.W	D3,D0	SR.W	D3,#1	CALL	MATTRACRFILL	CALL	MATTRACRINV	JUMP	90$40$:	TEST.L	D3:#BTRAGO	JUMP,BS 60$				; points carrs en quinconces =>	COMP.W	D2,#50	JUMP',HI 44$	SL.W	D2,#1	SR.W	D0,#1	SR.W	D1,#1	CLR.L	D4	CALL	MATTRACRDOT	LOAD.W	D4,D1	SWAP.W	D4	LOAD.W	D4,D0	CALL	MATTRACRDOT	JUMP	90$44$:	SUB.W	D2,#100	NEG.W	D2	SL.W	D2,#1	SR.W	D0,#1	SR.W	D1,#1	CLR.L	D4	LOAD.W	D4,D0	CALL	MATTRACRDOT	LOAD.W	D4,D1	SWAP.W	D4	CLR.W	D4	CALL	MATTRACRDOT	SL.W	D0,#1	SL.W	D1,#1	CALL	MATTRACRINV	JUMP	90$60$:				; points ronds en quinconces =>	COMP.W	D2,#50	JUMP',HI 64$	SL.W	D2,#1	SR.W	D0,#1	SR.W	D1,#1	CLR.L	D4	CALL	MATTRACRDOT	LOAD.W	D4,D1	SWAP.W	D4	LOAD.W	D4,D0	CALL	MATTRACRDOT	CLR.L	D3	CALL	MATTRACRFILL	LOAD.W	D3,D1	SL.W	D3,#1	DEC.W	D3	SWAP.W	D3	LOAD.W	D3,D0	SL.W	D3,#1	DEC.W	D3	CALL	MATTRACRFILL	LOAD.W	D3,D1	SR.W	D3,#1	SWAP.W	D3	LOAD.W	D3,D0	SR.W	D3,#1	ADD.W	D3,D0	CALL	MATTRACRFILL	LOAD.W	D3,D1	SR.W	D3,#1	ADD.W	D3,D1	SWAP.W	D3	LOAD.W	D3,D0	SR.W	D3,#1	CALL	MATTRACRFILL	SL.W	D0,#1	SL.W	D1,#1	CALL	MATTRACRINV	JUMP	90$64$:	SUB.W	D2,#100	NEG.W	D2	SL.W	D2,#1	SR.W	D0,#1	SR.W	D1,#1	CLR.L	D4	CALL	MATTRACRDOT	LOAD.W	D4,D1	SWAP.W	D4	LOAD.W	D4,D0	CALL	MATTRACRDOT	CLR.L	D3	CALL	MATTRACRFILL	LOAD.W	D3,D1	SL.W	D3,#1	DEC.W	D3	SWAP.W	D3	LOAD.W	D3,D0	SL.W	D3,#1	DEC.W	D3	CALL	MATTRACRFILL	LOAD.W	D3,D1	SR.W	D3,#1	SWAP.W	D3	LOAD.W	D3,D0	SR.W	D3,#1	ADD.W	D3,D0	CALL	MATTRACRFILL	LOAD.W	D3,D1	SR.W	D3,#1	ADD.W	D3,D1	SWAP.W	D3	LOAD.W	D3,D0	SR.W	D3,#1	CALL	MATTRACRFILL;	JUMP	90$90$:	POPM.L	D0..D4	RET;------------\\; MATTRACRDOT >;------------/; Dessine un point rond/carr dans la matrice de la trame.; in	D0.W	largeur;	D1.W	hauteur;	D2.W	intensit (0..100);	D3.L	fanions	;	D4.L	origine (y,x); out	-; mod	D7.WMATTRACRDOT:	PUSHM.L	D0..D6	LOAD.L	D5,D3		; D5 <-- fanions	LOAD.L	D6,D4		; D6 <-- origine	LOAD.W	D3,D0	MUL.WU	D3,D1	MUL.WU	D3,D2	DIV.WU	D3,#100	AND.L	D3,#H'FFFF	CALL	RACINE		; D4 <-- racine(l*h*i/100)	TEST.W	D4	JUMP,EQ 90$	TEST.L	D5:#BTRAGC	; gros points carrs ?	JUMP,BS 50$		; oui => 50$	COMP.W	D4,#5		; diamtre trs petit ?	JUMP',LO 40$		; oui => 40$				; non =>	MUL.WU	D4,#1000	DIV.WU	D4,#1571	; D4 <-- D4/(PI/2)	SWAP.W	D6	LOAD.W	D3,D1	SR.W	D3,#1	ADD.W	D3,D6	SWAP.W	D3	SWAP.W	D6	LOAD.W	D3,D0	SR.W	D3,#1	ADD.W	D3,D6	LOAD.W	D2,#SETDOT	LIB	?DRCERCLE	JUMP'	90$40$:	LOAD.W	D3,D4	SWAP.W	D4	LOAD.W	D4,D3	LOAD.W	D2,D4	SR.W	D2,#1	SWAP.W	D6	LOAD.W	D3,D1	SR.W	D3,#1	ADD.W	D3,D6	SUB.W	D3,D2	SWAP.W	D3	SWAP.W	D6	LOAD.W	D3,D0	SR.W	D3,#1	ADD.W	D3,D6	SUB.W	D3,D2	LOAD.W	D2,#SETDOT	LIB	?DRTRAME	JUMP'	90$50$:	LOAD.W	D3,D4	SWAP.W	D4	LOAD.W	D4,D3	LOAD.L	D3,D6	LOAD.W	D2,#SETDOT	LIB	?DRTRAME;	JUMP'	90$90$:	POPM.L	D0..D6	RET;-------------\\; MATTRACRFILL >;-------------/; Rempli un cercle.; (*)	La routine de remplissage DRAWFILLO ne travaille pas correctement;	si la largeur n'est pas modulo 8. C'est pourquoi il faut arrondir;	la largeur au multiple de 8 suprieur, puis tracer une droite;	verticale pour dlimiter !!!; in	D3.L	point o remplir; out	-; mod	D7.WMATTRACRFILL:	PUSHM.L	D1..D4,A3	LOAD.L	D1,D3	LOAD.W	D4,(A0)+ODFFDX	AND.B	D4,#B'111	JUMP',EQ 30$	LOAD.W	D4,(A0)+ODFFDX	CLR.L	D3	LOAD.W	D3,D4	ADD.W	D4,#8-1	AND.B	D4,#B'11111000	LOAD.W	(A0)+ODFFDX,D4	LOAD.W	D4,(A0)+ODFFDY	SWAP.W	D4	CLR.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRSEG		; voir (*)30$:	LOAD.L	A3,#(A6)+OBUDIS	LOAD.B	(A3)+0,#AFFILLA	; rempli tout	LOAD.B	(A3)+1,#DRAWFILLO	SWAP.W	D1	LOAD.L	(A3)+2,D1	LOAD.B	(A3)+6,#DRAWFILLC	LOAD.B	(A3)+7,#AFFILLT	; teste si dbordement	LOAD.W	D3,#1+6+1	LIB	?STRING		; rempli	POPM.L	D1..D4,A3	RET;------------\\; MATTRACRINV >;------------/; Inverse toute la matrice.; in	D0.W	largeur;	D1.W	hauteur; out	-; mod	D7.WMATTRACRINV:	PUSHM.L	D2..D4	LOAD.W	D4,D1	SWAP.W	D4	LOAD.W	D4,D0	CLR.L	D3	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	POPM.L	D2..D4	RET;-------------\\; MATTRACRLINE >;-------------/; Dessine une ligne (hachure) dans la matrice de la trame.; in	D0.W	largeur;	D1.W	hauteur;	D2.W	angle;	D3.W	paisseur; out	-; mod	D7.WMATTRACRLINE:	PUSHM.L	D0..D5	PUSHM.L	D1,D2	LOAD.W	D5,D3		; D5 <-- paisseur	LOAD.W	D1,D2	COMP.W	D2,#45	JUMP',LS 10$	LOAD.W	D1,#90	SUB.W	D1,D2	COMP.W	D2,#90	JUMP',LS 10$	LOAD.W	D1,#135	SUB.W	D1,D2	COMP.W	D2,#135	JUMP',LS 10$	LOAD.W	D1,#180	SUB.W	D1,D210$:	LIB	?CALCCOS	; D2 <-- 10000*COS(D1)	MUL.WA	D5,#10000	DIV.WA	D5,D2	TEST.W	D5	JUMP',NE 15$	INC.W	D515$:	POPM.L	D1,D2	CLR.L	D3	LOAD.W	D4,D1	SWAP.W	D4	LOAD.W	D4,D0		; D4 <-- dimensions	TEST.W	D2	JUMP',EQ 30$	COMP.W	D2,#180	JUMP',EQ 32$	COMP.W	D2,#90	JUMP',EQ 32$	JUMP',LO 40$	LOAD.W	D3,D4	DEC.W	D3	NEG.W	D4	JUMP'	40$30$:	AND.L	D4,#H'FFFF	JUMP'	40$32$:	CLR.W	D4;	JUMP'	40$40$:	PUSH.L	D3	LOAD.W	D2,#SETDOT	LIB	?DRSEG		; dessine une hachure	POP.L	D3	LOAD.W	D0,D4	JUMP',NC 50$	NEG.W	D050$:	LOAD.L	D1,D4	SWAP.W	D1	LOAD.L	D2,#H'10000*1+0	COMP.W	D0,D1	JUMP',HS 52$	LOAD.L	D2,#H'10000*0+152$:	ADD.L	D3,D2	DEC.W	D5	JUMP,NE 40$	POPM.L	D0..D5	RET	.END