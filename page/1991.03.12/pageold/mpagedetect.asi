	.SBTTL	MPAGEDETECT;----------\\; _PAGE_DET >;==========/; ; in	D7.W	numro du sous-appel;	?	selon appel; out	?	selon appel; mod	?	selon appel_PAGE_DET:	COMP.W	D7,#DET_POINT	JUMP,EQ DETPOINT	COMP.W	D7,#DET_POINTP	JUMP,EQ DETPOINTP	COMP.W	D7,#DET_RNDPAS	JUMP,EQ DETRNDPAS	COMP.W	D7,#DET_SCALEN	JUMP,EQ DETSCALEN	COMP.W	D7,#DET_SCALEP	JUMP,EQ DETSCALEP	COMP.W	D7,#DET_INIT	JUMP,EQ DETINIT	COMP.W	D7,#DET_INITQ	JUMP,EQ DETINITQ	COMP.W	D7,#DET_INITSC	JUMP,EQ DETINITSC	COMP.W	D7,#DET_DETECT	JUMP,EQ DETECT	COMP.W	D7,#DET_SELOPEN	JUMP,EQ SELOPEN	COMP.W	D7,#DET_SELINV	JUMP,EQ SELINV	COMP.W	D7,#DET_SELMOVE	JUMP,EQ SELMOVE	COMP.W	D7,#DET_SELWORD	JUMP,EQ SELWORD	COMP.W	D7,#DET_SELCLOSE	JUMP,EQ SELCLOSE	COMP.W	D7,#DET_MOVOBJET	JUMP,EQ MOVOBJET	RET;-------\\; DETECT >;=======/; Dtecte dans quel objet est la souris, en parcourant la liste depuis; la fin pour prendre d'abord les objets qui sont "dessus".; in	D4.L	point o est la souris; out	A4.L	^objet trouv;	D7.W	erreur; mod	D7.W, A4.LDETECT:	PUSHM.L	D1..D4,A3	CALL	DETPOINT	; D3 <-- point o est la souris	JUMP,NE 80$	LOAD.L	D4,D3		; D3 <-- position en X	SWAP.W	D4		; D4 <-- position en Y	LOAD.L	A3,#(A6)+OUSE	LOAD.L	A4,(A3)+OLPREV20$:	COMP.L	A4,A3		; dbut de la liste ?	JUMP',EQ 80$		; oui => 80$	LOAD.L	D1,(A4)+OODPOS	LOAD.L	D2,(A4)+OODDIM	SUB.W	D1,(A6)+OLDET2	ADD.W	D2,(A6)+OLDET	COMP.W	D3,D1		; trop  gauche ?	JUMP',LT 60$	ADD.W	D1,D2	COMP.W	D3,D1		; trop  droite ?	JUMP',GE 60$	SWAP.W	D1	SWAP.W	D2	SUB.W	D1,(A6)+OLDET2	ADD.W	D2,(A6)+OLDET	COMP.W	D4,D1		; trop haut ?	JUMP',LT 60$	ADD.W	D1,D2	COMP.W	D4,D1		; trop bas ?	JUMP',GE 60$	CALL	DETOBJET	; dtection fine	JUMP',EQ 90$60$:	LOAD.L	A4,(A4)+OLPREV	; A4 <-- ^prcdent	JUMP	20$80$:	LOAD.L	A4,#0	LOAD.W	D7,#ERDIOUT	; D7 <-- pas trouv90$:	POPM.L	D1..D4,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; DETOBJET >;---------/; Dtection fine (et lente) pour voir si la souris est dans un objet.; in	A4.L	^objet;	D3.W	position en X; 	D4.W	position en Y; out	D7.W	erreur; mod	D7.WDETOBJET:	COMP.W	(A4)+OOOBJ,#ICOTM	JUMP,EQ DETTM	COMP.W	(A4)+OOOBJ,#ICOSP	JUMP,EQ DETSP	COMP.W	(A4)+OOOBJ,#ICOLB	JUMP,EQ DETLB	COMP.W	(A4)+OOOBJ,#ICODR	JUMP,EQ DETDRFL	COMP.W	(A4)+OOOBJ,#ICOFL	JUMP,EQ DETDRFL	COMP.W	(A4)+OOOBJ,#ICORD	JUMP,EQ DETRDRA	COMP.W	(A4)+OOOBJ,#ICORA	JUMP,EQ DETRDRA	COMP.W	(A4)+OOOBJ,#ICOPO	JUMP,EQ DETPO	COMP.W	(A4)+OOOBJ,#ICOCE	JUMP,EQ DETCE	COMP.W	(A4)+OOOBJ,#ICOEL	JUMP,EQ DETEL	COMP.W	(A4)+OOOBJ,#ICOAR	JUMP,EQ DETAR	COMP.W	(A4)+OOOBJ,#ICOIM	JUMP,EQ DETIM	CLR.W	D7		; D7 <-- ok	RET;------\\; DETTM >;------/; Dtection fine (et lente) pour voir si la souris est dans un trait  main leve.; in	A4.L	^objet;	D3.W	position en X; 	D4.W	position en Y; out	D7.W	erreur; mod	D7.WDETTM:	PUSHM.L	D0,A3	LOAD.L	A3,#(A4)+OOTMPTS ; A3 <-- ^premier point	LOAD.W	D0,(A4)+OOTMNBP	; D0 <-- nb de points	CALL	DETPOINTS	POPM.L	D0,A3	TEST.W	D7		; retour EQ/NE	RET;------\\; DETSP >;------/; Dtection fine (et lente) pour voir si la souris est dans une spline.; in	A4.L	^objet;	D3.W	position en X; 	D4.W	position en Y; out	D7.W	erreur; mod	D7.WDETSP:	PUSHM.L	D0,A3	LOAD.L	A3,#(A4)+OOSPPTC ; A3 <-- ^premier point	LOAD.W	D0,(A4)+OOSPNBC	; D0 <-- nb de points	CALL	DETPOINTS	POPM.L	D0,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; DETPOINTS >;----------/; Dtection fine (et lente) pour voir si la souris est dans une liste de points.; in	A4.L	^objet;	D3.W	position en X; 	D4.W	position en Y; out	D7.W	erreur; mod	D7.WDETPOINTS:	PUSHM.L	D0..D5,A3	CALL	DETMASK		; est-on dans le contour ?	JUMP,EQ 90$		; oui => 90$	CLR.W	D7		; D7 <-- dans la droite	SUB.W	D0,#1+130$:	LOAD.L	D1,(A3+)	LOAD.L	D2,(A3)	COMP.W	D1,D2	JUMP',LE 40$	LOAD.W	D5,D1	LOAD.W	D1,D2		; EX.W D1,D2	LOAD.W	D2,D540$:	SUB.W	D1,(A6)+OLDET	ADD.W	D2,(A6)+OLDET	COMP.W	D3,D1	JUMP',LT 50$	COMP.W	D3,D2	JUMP',GE 50$	SWAP.W	D1	SWAP.W	D2	COMP.W	D1,D2	JUMP',LE 42$	EX.L	D1,D242$:	SUB.W	D1,(A6)+OLDET	ADD.W	D2,(A6)+OLDET	COMP.W	D4,D1	JUMP',LT 50$	COMP.W	D4,D2	JUMP',LT 90$50$:	DECJ.W,NMO D0,30$	LOAD.W	D7,#ERDIOUT	; D7 <-- en dehors de la droite90$:	POPM.L	D0..D5,A3	TEST.W	D7		; retour EQ/NE	RET;------\\; DETLB >;------/; Dtection fine (et lente) pour voir si la souris est dans une ligne brise.; in	A4.L	^objet;	D3.W	position en X; 	D4.W	position en Y; out	D7.W	erreur; mod	D7.WDETLB:	PUSHM.L	D2..D5,A3	CALL	DETMASK		; est-on dans le contour ?	JUMP,EQ 90$		; oui => 90$	LOAD.W	D5,D4	SWAP.W	D5	LOAD.W	D5,D3		; D5 <-- point de dtection	LOAD.L	A3,#(A4)+OOLBPTS ; A3 <-- ^premier point	LOAD.W	D2,(A4)+OOLBNBP	; D2 <-- nb de points	SUB.W	D2,#1+130$:	LOAD.L	D3,(A3+)	LOAD.L	D4,(A3)	CALL	DETSEGMENT	; dans ce segment ?	JUMP',EQ 90$	DECJ.W,NMO D2,30$	TEST.B	(A4)+OOLBMOF	JUMP',EQ 80$	LOAD.L	D3,(A3)	LOAD.L	D4,(A4)+OOLBPTS	CALL	DETSEGMENT	; dans le segment de fermeture ?	JUMP',EQ 90$80$:	LOAD.W	D7,#ERDIOUT	; D7 <-- en dehors de la droite90$:	POPM.L	D2..D5,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; DETDRFL >;--------/; Dtection fine (et lente) pour voir si la souris est dans une droite.; Pour calculer la distance entre un point et une droite, utilise la; formule suivante :;	         Ly * (Px-Dx);	l = Py - ------------ - Dy;	              Lx; Avec :;	Px/Py: point donne en entre dans D3/D4;	Dx/Dy: origine de la droite;	Lx/Ly: dimensions de la droite; Remarque :;	Si Lx < Ly => on inverse X/Y dans la formule !;	Si Lx ou Ly est nul => on accepte de toute faon; in	A4.L	^objet;	D3.W	position en X; 	D4.W	position en Y; out	D7.W	erreur; mod	D7.WDETDRFL:	PUSHM.L	D1,D2	CALL	DETMASK		; est-on dans le contour ?	JUMP,EQ 90$		; oui => 90$	CLR.W	D7		; D7 <-- dans la droite	LOAD.W	D1,(A4)+OODRDIM+2	JUMP,EQ 90$	JUMP',NC 10$	NEG.W	D1		; D1 <-- |dX|10$:	LOAD.W	D2,(A4)+OODRDIM+0	JUMP,EQ 90$	JUMP',NC 12$	NEG.W	D2		; D2 <-- |dY|12$:	COMP.W	D1,D2	JUMP',LO 50$				; droite plutt horizontale =>	LOAD.W	D2,D3	SUB.W	D2,(A4)+OODRPOS+2	MUL.WA	D2,(A4)+OODRDIM+0	DIV.WA	D2,(A4)+OODRDIM+2	SUB.W	D2,D4	NEG.W	D2	SUB.W	D2,(A4)+OODRPOS+0	JUMP',NC 30$	NEG.W	D230$:	COMP.W	D2,(A6)+OLDET	JUMP',LS 90$	JUMP	80$50$:				; droite plutt verticale =>	LOAD.W	D2,D4	SUB.W	D2,(A4)+OODRPOS+0	MUL.WA	D2,(A4)+OODRDIM+2	DIV.WA	D2,(A4)+OODRDIM+0	SUB.W	D2,D3	NEG.W	D2	SUB.W	D2,(A4)+OODRPOS+2	JUMP',NC 60$	NEG.W	D260$:	COMP.W	D2,(A6)+OLDET	JUMP',LS 90$80$:	LOAD.W	D7,#ERDIOUT	; D7 <-- en dehors de la droite90$:	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET;--------\\; DETRDRA >;--------/; Dtection fine (et lente) pour voir si la souris est dans un rectangle.; Si le rectangle est transparent, on ne peut tre que sur les bords !; in	A4.L	^objet;	D3.W	position en X; 	D4.W	position en Y; out	D7.W	erreur; mod	D7.WDETRDRA:	PUSHM.L	D1,D2	CLR.W	D7	LOAD.L	D1,(A4)+OOFOND	TEST.L	D1:#BFDOBO	JUMP,BS 90$	TEST.L	D1:#BFDONO	JUMP,BS 90$	TEST.L	D1:#BFDOTO	JUMP,BS 90$	TEST.L	D1:#BFDRTO	JUMP,BS 90$	TEST.L	D1:#BFDRBO	JUMP,BS 90$	LOAD.L	D1,(A4)+OORAPOS	LOAD.L	D2,(A4)+OORADIM	TEST.W	D2	JUMP',NC 30$	NEG.W	D2	SUB.W	D1,D230$:	ADD.W	D1,(A6)+OLDET2	SUB.W	D2,(A6)+OLDET	COMP.W	D3,D1		; trop  gauche ?	JUMP',LT 90$	ADD.W	D1,D2	COMP.W	D3,D1		; trop  droite ?	JUMP',GE 90$	SWAP.W	D1	SWAP.W	D2	TEST.W	D2	JUMP',NC 32$	NEG.W	D2	SUB.W	D1,D232$:	ADD.W	D1,(A6)+OLDET2	SUB.W	D2,(A6)+OLDET	COMP.W	D4,D1		; trop haut ?	JUMP',LT 90$	ADD.W	D1,D2	COMP.W	D4,D1		; trop bas ?	JUMP',GE 90$	LOAD.W	D7,#ERDIOUT90$:	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET;------\\; DETPO >;------/; Dtection fine (et lente) pour voir si la souris est dans un polygone.; in	A4.L	^objet;	D3.W	position en X; 	D4.W	position en Y; out	D7.W	erreur; mod	D7.WDETPO:	PUSHM.L	D0..D6,A3	CALL	DETMASK		; est-on dans le contour ?	JUMP,EQ 90$		; oui => 90$	LOAD.W	D0,D4	SWAP.W	D0	LOAD.W	D0,D3		; D0 <-- position (y;x)	LOAD.L	D6,(A4)+OOPOTYP	; D6 <-- mode	LOAD.W	D1,#3	TEST.L	D6:#BPO3	JUMP',BS 50$	INC.W	D1	TEST.L	D6:#BPO4	JUMP',BS 50$	INC.W	D1	TEST.L	D6:#BPO5	JUMP',BS 50$	INC.W	D1	TEST.L	D6:#BPO6	JUMP',BS 50$	ADD.W	D1,#2	TEST.L	D6:#BPO8	JUMP',BS 50$	ADD.W	D1,#2;	TEST.L	D6:#BPO10;	JUMP',BS 50$50$:	SWAP.W	D1		; D1 <-- nb de cts	LOAD.W	D1,(A4)+OOPOAND	; D1 <-- angle de dpart	LOAD.L	D3,(A4)+OOPOCEN	; D3 <-- centre (y;x)	LOAD.W	D4,(A4)+OOPORAY	; D4 <-- Ry	SWAP.W	D4	LOAD.W	D4,(A4)+OOPORAY	; D4 <-- Rx	LOAD.L	A3,#(A6)+OBUDIS	CALL	CALPOLYGONE	; OBUDIS <-- coordonnes52$:	LOAD.L	D3,(A3+)	LOAD.L	D4,(A3+)	LOAD.L	D1,D3	OR.L	D1,D4	JUMP',EQ 85$	LOAD.L	D5,D0	CALL	DETSEGMENT	; dans ce segment ?	JUMP',EQ 90$		; oui => 90$	JUMP	52$85$:	LOAD.W	D7,#ERDIOUT90$:	POPM.L	D0..D6,A3	TEST.W	D7		; retour EQ/NE	RET;------\\; DETCE >;------/; Dtection fine (et lente) pour voir si la souris est dans un cercle.; in	A4.L	^objet;	D3.W	position en X; 	D4.W	position en Y; out	D7.W	erreur; mod	D7.WDETCE:	PUSHM.L	D3..D5	CALL	DETMASK		; est-on dans le contour ?	JUMP',EQ 90$		; oui => 90$	LOAD.W	D5,D4	SWAP.W	D5	LOAD.W	D5,D3		; D5 <-- point de dtection (y;x)	LOAD.L	D3,(A4)+OOCECEN	; D3 <-- centre	LOAD.W	D4,(A4)+OOCERAY	; D4 <-- rayon	CALL	DETCERCLE90$:	POPM.L	D3..D5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DETCERCLE >;----------/; Dtection fine (et lente) pour voir si la souris est dans un cercle.; in	D3.L	centre (y;x);	D4.W	rayon (r);	D5.L	point de dtection (y;x); out	D7.W	erreur; mod	D7.WDETCERCLE:	PUSHM.L	D2..D5	LOAD.W	D2,D4		; D2 <-- rayon du cercle	LOAD.L	D4,D5	CALL	CALCRAYON	; D5 <-- rayon du point de dtection	LOAD.W	D7,#ERDIOUT	SUB.W	D2,(A6)+OLDET	COMP.W	D5,D2	JUMP',LT 90$	ADD.W	D2,(A6)+OLDET	ADD.W	D2,(A6)+OLDET	COMP.W	D5,D2	JUMP',GE 90$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D5	TEST.W	D7		; retour EQ/NE	RET;------\\; DETEL >;------/; Dtection fine (et lente) pour voir si la souris est dans une ellipse.; in	A4.L	^objet;	D3.W	position en X; 	D4.W	position en Y; out	D7.W	erreur; mod	D7.WDETEL:	PUSHM.L	D3..D6	CALL	DETMASK		; est-on dans le contour ?	JUMP',EQ 90$		; oui => 90$	LOAD.W	D5,D4	SWAP.W	D5	LOAD.W	D5,D3		; D5 <-- point de dtection (y;x)	LOAD.L	D3,(A4)+OOELCEN	; D3 <-- centre	LOAD.L	D4,(A4)+OOELDIM	; D4 <-- rayons	LOAD.L	D6,(A4)+OOELTYP	TEST.L	D6:#BELMDIA	JUMP',BC 40$	ASR.W	D4,#1		; D4 <-- Rx/2	SWAP.W	D4	ASR.W	D4,#1		; D4 <-- Ry/2	SWAP.W	D440$:	CALL	DETELLIPSE90$:	POPM.L	D3..D6	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DETELLIPSE >;-----------/; Dtection fine (et lente) pour voir si la souris est dans une ellipse.; in	D3.L	centre (y;x);	D4.L	rayons (ry;dx);	D5.L	point de dtection (y;x); out	D7.W	erreur; mod	D7.WDETELLIPSE:	PUSHM.L	D1..D5	LOAD.W	D1,D4		; D1 <-- Rx	JUMP',NC 20$	NEG.W	D1		; D1 <-- |Rx|20$:	LOAD.L	D2,D4	SWAP.W	D2		; D2 <-- Ry	TEST.W	D2	JUMP',NC 22$	NEG.W	D2		; D2 <-- |Ry|22$:	SUB.W	D5,D3	LOAD.W	D4,D5	MUL.WA	D4,D2	DIV.WA	D4,D1	LOAD.W	D5,D4	ADD.W	D5,D3	LOAD.L	D4,D5	CALL	CALCRAYON	; D5 <-- rayon	LOAD.W	D7,#ERDIOUT	SUB.W	D2,(A6)+OLDET	COMP.W	D5,D2	JUMP',LT 90$	ADD.W	D2,(A6)+OLDET	ADD.W	D2,(A6)+OLDET	COMP.W	D5,D2	JUMP',GE 90$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D5	TEST.W	D7		; retour EQ/NE	RET;------\\; DETAR >;------/; Dtection fine (et lente) pour voir si la souris est dans un arc.; in	A4.L	^objet;	D3.W	position en X; 	D4.W	position en Y; out	D7.W	erreur; mod	D7.WDETAR:	PUSHM.L	D0..D6	CALL	DETMASK		; est-on dans le contour ?	JUMP,EQ 90$		; oui => 90$	LOAD.W	D0,D4	SWAP.W	D0	LOAD.W	D0,D3		; D0 <-- position (y;x)	LOAD.L	D6,(A4)+OOARTYP	; D6 <-- mode	TEST.L	D6:#BARQ	JUMP',BS 30$	LOAD.L	D3,(A4)+OOARPOS	; D3 <-- centre	LOAD.L	D5,D0	TEST.L	D6:#BAREL	JUMP',BS 20$	LOAD.W	D4,(A4)+OOARRAY	CALL	DETCERCLE	; dans l'arc de cercle ?	JUMP	90$20$:	LOAD.L	D4,(A4)+OOARDIM	CALL	DETELLIPSE	; dans l'arc d'ellipse ?	JUMP	90$30$:	LOAD.L	D3,(A4)+OOARPOS	; D3 <-- centre	LOAD.L	D4,D0	CALL	CALCRAYON	; D5 <-- rayon	LOAD.W	D4,(A4)+OOARRAY	SUB.W	D4,(A6)+OLDET	COMP.W	D5,D4	JUMP,LT 35$	ADD.W	D4,(A6)+OLDET	ADD.W	D4,(A6)+OLDET	COMP.W	D5,D4	JUMP,GE 35$	LOAD.L	D3,(A4)+OOARPOS	LOAD.L	(A6)+OCCERC,D3	ADD.W	D3,(A4)+OOARRAY	LOAD.L	D4,D0	CALL	XTOURNE		; D2 <-- angle o est D0	LOAD.W	D5,D2	LOAD.W	D1,(A4)+OOARAND	LOAD.W	D2,(A4)+OOARANG	SR.W	D2,#1	SUB.W	D1,D2		; D1 <-- angle de dpart	JUMP',NC 32$	ADD.W	D1,#36032$:	LOAD.W	D2,D1	ADD.W	D2,(A4)+OOARANG	; D2 <-- angle d'arrive	COMP.W	D2,#360	JUMP',LO 33$	SUB.W	D2,#36033$:	COMP.W	D1,D2	JUMP',HS 34$	COMP.W	D5,D1	JUMP',LO 35$	COMP.W	D5,D2	JUMP',HI 35$	JUMP	80$34$:	COMP.W	D5,D1	JUMP,HS 80$	COMP.W	D5,D2	JUMP,LS 80$35$:	TEST.L	D6:#BARQ	; arc quelconque ?	JUMP,BC 85$		; non => 85$	TEST.L	D6:#BARTRA	; tranche de gteau ?	JUMP,BC 85$		; non => 85$				; oui =>	LOAD.W	D1,(A4)+OOARAND	LOAD.W	D2,(A4)+OOARANG	SR.W	D2,#1	SUB.W	D1,D2		; D1 <-- angle de dpart	JUMP',NC 37$	ADD.W	D1,#36037$:	LOAD.L	D3,(A4)+OOARPOS	LOAD.W	D4,(A4)+OOARRAY	SWAP.W	D4	LOAD.W	D4,(A4)+OOARRAY	LIB	?CALCPELLI	LOAD.L	D4,D5	LOAD.L	D5,D0	CALL	DETSEGMENT	JUMP,EQ 90$	ADD.W	D1,(A4)+OOARANG	; D1 <-- angle d'arrive	COMP.W	D1,#360	JUMP',LO 38$	SUB.W	D1,#36038$:;	LOAD.L	D3,(A4)+OOARPOS	LOAD.W	D4,(A4)+OOARRAY	SWAP.W	D4	LOAD.W	D4,(A4)+OOARRAY	LIB	?CALCPELLI	LOAD.L	D4,D5	LOAD.L	D5,D0	CALL	DETSEGMENT	JUMP'	90$80$:	CLR.W	D7		; D7 <-- ok	JUMP'	90$85$:	LOAD.W	D7,#ERDIOUT90$:	POPM.L	D0..D6	TEST.W	D7		; retour EQ/NE	RET;------\\; DETIM >;------/; Dtection fine (et lente) pour voir si la souris est dans une image.; in	A4.L	^objet;	D3.W	position en X; 	D4.W	position en Y; out	D7.W	erreur; mod	D7.WDETIM:	PUSHM.L	D1..D6,A3	CALL	DETMASK		; est-on dans le contour ?	JUMP,EQ 90$		; oui => 90$	LOAD.W	D1,(A4)+OOIMPOS+2	LOAD.W	D2,(A4)+OOIMDIM+2	JUMP',NC 20$	NEG.W	D2	SUB.W	D1,D220$:	SUB.W	D3,D1	LOAD.W	D5,(A6)+OLDET	ADD.W	D5,(A6)+OLDET	; D5 <-- largeur	SUB.W	D3,(A6)+OLDET	; D3 <-- origine en X	JUMP',NC 21$	ADD.W	D5,D3	CLR.W	D321$:	SUB.W	D2,D3	COMP.W	D5,D2	JUMP',LS 22$	LOAD.W	D5,D222$:	CALL	DETSCALEP	; D3 <-- plus grand (si n:1)	LOAD.W	D1,(A4)+OOIMPOS+0	LOAD.W	D2,(A4)+OOIMDIM+0	JUMP',NC 23$	NEG.W	D2	SUB.W	D1,D223$:	SUB.W	D4,D1	LOAD.W	D6,(A6)+OLDET	ADD.W	D6,(A6)+OLDET	; D6 <-- hauteur	SUB.W	D4,(A6)+OLDET	; D4 <-- origine en Y	JUMP',NC 24$	ADD.W	D6,D4	CLR.W	D424$:	SUB.W	D2,D4	COMP.W	D6,D2	JUMP',LS 25$	LOAD.W	D6,D225$:	EX.L	D3,D4	CALL	DETSCALEP	; D4 <-- plus grand (si n:1)	EX.L	D4,D3	LOAD.L	A3,#(A4)+OOIMMAT ; A3 <-- ^matrice de l'image	LOAD.W	D1,(A4)+OOIMIIX	TEST.L	(A4)+OOIMPMZ	JUMP',EQ 30$	LOAD.L	A3,(A4)+OOIMPMZ ; A3 <-- ^matrice de l'image zoome	LOAD.W	D1,(A4)+OOIMZIX30$:	LOAD.W	D2,D4	MUL.WU	D2,D1	ADD.L	A3,D2		; A3 <-- ^selon Y	LOAD.W	D2,D3	SR.W	D2,#3	ADD.W	A3,D2		; A3 <-- ^selon X	NOT.B	D3	AND.B	D3,#B'111	DEC.W	D5		; D5 <-- -1  cause NMO	DEC.W	D6		; D6 <-- -1  cause NMO40$:	PUSHM.L	D3,D5,A3	LOAD.B	D2,(A3+)50$:	TEST.L	D2:D3		; point allum ?	JUMP',BS 80$		; oui => 80$	DEC.B	D3	JUMP',NC 54$	LOAD.B	D3,#7	LOAD.B	D2,(A3+)54$:	DECJ.W,NMO D5,50$	POPM.L	D3,D5,A3	ADD.W	A3,D1	DECJ.W,NMO D6,40$	LOAD.W	D7,#ERDIOUT	JUMP'	90$80$:	POPM.L	D3,D5,A3	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D6,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; DETMASK >;--------/; Regarde si l'on est  l'intrieur du coutour.; in	A4.L	^objet;	D3.W	position en X; 	D4.W	position en Y; out	D7.W	erreur; mod	D7.WDETMASK:	PUSHM.L	D2..D4,A3	LOAD.W	D7,#ERDIOUT	TEST.L	(A4)+OOFPM	; matrice de fond existe ?	JUMP,EQ 90$		; non => 90$	SUB.W	D3,(A4)+OODPOS+2	SUB.W	D4,(A4)+OODPOS+0	SWAP.W	D3	LOAD.W	D3,D4	SWAP.W	D3	CALL	DETSCALEP	; D3 <-- plus grand (si n:1)	LOAD.L	D4,D3	SWAP.W	D4	INC.W	D3	INC.W	D4	LOAD.L	A3,(A4)+OOFPM	; A3 <-- ^matrice de fond	LOAD.W	D2,(A4)+OODDIM+2	EX.L	D3,D2	CALL	DETSCALEP	; D2 <-- plus grand (si n:1)	EX.L	D2,D3	ADD.W	D2,#2+16-1	AND.B	D2,#B'11110000	SR.W	D2,#3	MUL.WU	D2,D4	ADD.L	A3,D2		; A3 <-- ^selon Y	LOAD.W	D2,D3	SR.W	D2,#3	ADD.W	A3,D2		; A3 <-- ^selon X	LOAD.B	D2,D3	NOT.B	D2	TEST.B	(A3):D2		; point allum ?	JUMP',BS 90$		; oui => 90$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D4,A3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DETSEGMENT >;-----------/; Regarde si un point P5 est sur un segment de droite P3-P4.; Utilise la mme formule que DETDROITE !; in	D3.L	origine droite (y;x);	D4.L	arrive droite (y;x);	D5.L	point de dtection (y;x); out	D7.W	erreur; mod	D7.WDETSEGMENT:	PUSHM.L	D1..D6	CLR.W	D7		; D7 <-- dans la droite	LOAD.L	D6,D5		; D5 <-- Dx	SWAP.W	D6		; D6 <-- Dy; Regarde si le point D(y;x) est dans le rectangle englobant; la droite.	LOAD.L	D1,D3	LOAD.L	D2,D4	COMP.W	D1,D2	JUMP',LE 10$	EX.L	D1,D210$:	SUB.W	D1,(A6)+OLDET	ADD.W	D2,(A6)+OLDET	COMP.W	D5,D1		; trop  gauche ?	JUMP,LT 80$	COMP.W	D5,D2		; trop  droite ?	JUMP,GE 80$	SWAP.W	D1	SWAP.W	D2	COMP.W	D1,D2	JUMP',LE 12$	EX.L	D1,D212$:	SUB.W	D1,(A6)+OLDET	ADD.W	D2,(A6)+OLDET	COMP.W	D6,D1		; trop haut ?	JUMP,LT 80$	COMP.W	D6,D2		; trop bas ?	JUMP,GE 80$; Regarde si le point D(y;x) est sur la droite.	SUB.W	D4,D3		; D4 <-- dX	LOAD.W	D1,D4	JUMP,EQ 90$	JUMP',NC 20$	NEG.W	D1		; D1 <-- |dX|20$:	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- dY	LOAD.W	D2,D4	JUMP,EQ 90$	JUMP',NC 22$	NEG.W	D2		; D2 <-- |dY|22$:	SWAP.W	D3	SWAP.W	D4	COMP.W	D1,D2	JUMP',LO 50$				; droite plutt horizontale =>	LOAD.W	D2,D5	SUB.W	D2,D3	SWAP.W	D4	MUL.WA	D2,D4	SWAP.W	D4	DIV.WA	D2,D4	SUB.W	D2,D6	NEG.W	D2	SWAP.W	D3	SUB.W	D2,D3	SWAP.W	D3	TEST.W	D2	JUMP',NC 30$	NEG.W	D230$:	COMP.W	D2,(A6)+OLDET	JUMP',LS 90$	JUMP'	80$50$:				; droite plutt verticale =>	LOAD.W	D2,D6	SWAP.W	D3	SUB.W	D2,D3	SWAP.W	D3	MUL.WA	D2,D4	SWAP.W	D4	DIV.WA	D2,D4	SWAP.W	D4	SUB.W	D2,D5	NEG.W	D2	SUB.W	D2,D3	JUMP',NC 60$	NEG.W	D260$:	COMP.W	D2,(A6)+OLDET	JUMP',LS 90$80$:	LOAD.W	D7,#ERDIOUT	; D7 <-- en dehors de la droite90$:	POPM.L	D1..D6	TEST.W	D7		; retour EQ/NE	RET;----------\\; DETINITSC >;==========/; Initialise aprs un changement d'chelle.; in	D4.L	centre de la partie visible (y;x) [pi]; out	-; mod	D7.WDETINITSC:	PUSHM.L	D1..D4	LOAD.L	D3,(A6)+OWDIM	; D3 <-- dimensions [pe]	LOAD.W	D1,(A6)+OSCALE	; D1 <-- chelle	JUMP',EQ 40$	JUMP',NC 30$	NEG.W	D1		; D1 <-- |chelle|	LOAD.W	D2,D3	MUL.WA	D2,D1	LOAD.W	D3,D2		; D3 <-- x	SWAP.W	D3	LOAD.W	D2,D3	MUL.WA	D2,D1	LOAD.W	D3,D2		; D3 <-- y	SWAP.W	D3	JUMP'	40$30$:	LOAD.W	D2,D3	ADD.W	D2,D1	DEC.W	D2	CONV.LA.WA D2	DIV.WA	D2,D1	LOAD.W	D3,D2		; D3 <-- x	SWAP.W	D3	LOAD.W	D2,D3	ADD.W	D2,D1	DEC.W	D2	CONV.LA.WA D2	DIV.WA	D2,D1	LOAD.W	D3,D2		; D3 <-- y	SWAP.W	D340$:	LOAD.L	(A6)+OSDIM,D3	; OSDIM <-- dimensions [pi]	SR.W	D3,#1	SUB.W	D4,D3	JUMP',NC 50$	CLR.W	D450$:	LOAD.W	D3,(A6)+OPDIM+2	SUB.W	D3,(A6)+OSDIM+2	COMP.W	D4,D3	JUMP',LE 52$	LOAD.W	D4,D352$:	SWAP.W	D3	SWAP.W	D4	SR.W	D3,#1	SUB.W	D4,D3	JUMP',NC 54$	CLR.W	D454$:	LOAD.W	D3,(A6)+OPDIM+0	SUB.W	D3,(A6)+OSDIM+0	COMP.W	D4,D3	JUMP',LE 56$	LOAD.W	D4,D356$:	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A6)+OPPOS,D4	LOAD.W	D3,#LDET	CALL	DETSCALEN	; D3 <-- plus petit (si n:1)	TEST.W	D3	JUMP',NE 70$	INC.W	D370$:	LOAD.W	(A6)+OLDET,D3	SR.W	D3,#1	LOAD.W	(A6)+OLDET2,D3	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DETPOINTP >;==========/; Donne la position dans la page en fonction de la position de la souris,; en tenant compte du pas.; Units :	[pi]	points internes;		[pe]	points dans l'crans; in	D4.L	position de la souris (y;x) [pe]; out	D3.L	position dans la page (y;x) [pi];	D7.W	erreur; mod	D3.L, D7.WDETPOINTP:	CALL	DETPOINT	JUMP',NE 90$	CALL	DETRNDPAS90$:	TEST.W	D7		; retour EQ/NE	RET;----------\\; DETRNDPAS >;==========/; Arrondi une position selon le pas.; in	D3.L	position (y;x); out	D3.L	position (y;x) arrondie selon le pas; mod	D3.LDETRNDPAS:	PUSHM.L	D2,D4,D5	LOAD.L	D4,(A6)+OFLAGS	TEST.L	D4:#BFLPAX	JUMP',BC 90$	LOAD.W	D4,(A6)+OPAS	JUMP',EQ 90$	LOAD.W	D5,D4	SR.W	D5,#1	CLR.L	D2	LOAD.W	D2,D3	ADD.W	D2,D5	DIV.WU	D2,D4	MUL.WU	D2,D4	LOAD.W	D3,D2	SWAP.W	D3	CLR.L	D2	LOAD.W	D2,D3	ADD.W	D2,D5	DIV.WU	D2,D4	MUL.WU	D2,D4	LOAD.W	D3,D2	SWAP.W	D390$:	POPM.L	D2,D4,D5	RET;---------\\; DETPOINT >;=========/; Donne la position dans la page en fonction de la position de la souris,; sans tenir compte du pas.; in	D4.L	position de la souris (y;x) [pe]; out	D3.L	position dans la page (y;x) [pi];	D7.W	erreur; mod	D3.L, D7.WDETPOINT:	LOAD.W	D7,#ERDIOUT	; D7 <-- en dehors	LOAD.L	D3,D4	SUB.W	D3,(A6)+OWPOS+2	JUMP',LO 90$	COMP.W	D3,(A6)+OWDIM+2	JUMP',HS 90$	SWAP.W	D3	SUB.W	D3,(A6)+OWPOS+0	JUMP',LO 90$	COMP.W	D3,(A6)+OWDIM+0	JUMP',HS 90$	SWAP.W	D3	CALL	DETSCALEN	; D3 <-- plus petit (si n:1)	ADD.W	D3,(A6)+OPPOS+2	SWAP.W	D3	ADD.W	D3,(A6)+OPPOS+0	SWAP.W	D3	CLR.W	D7		; D7 <-- ok90$:	TEST.W	D7		; retour EQ/NE	RET;----------\\; DETSCALEN >;==========/; Tient compte de l'chelle ngativement.; in	D3.L	(y;x); out	D3.L	(y;x) plus petit si n:1; mod	D3.LDETSCALEN:	PUSHM.L	D1,D2	LOAD.W	D1,(A6)+OSCALE	; D1 <-- chelle	JUMP',EQ 90$	JUMP',NC 50$	NEG.W	D1		; D1 <-- |chelle|	LOAD.W	D2,D3	MUL.WA	D2,D1	LOAD.W	D3,D2		; D3 <-- x	SWAP.W	D3	LOAD.W	D2,D3	MUL.WA	D2,D1	LOAD.W	D3,D2		; D3 <-- y	SWAP.W	D3	JUMP'	90$50$:	LOAD.W	D2,D3	CONV.LA.WA D2	DIV.WA	D2,D1	LOAD.W	D3,D2		; D3 <-- x	SWAP.W	D3	LOAD.W	D2,D3	CONV.LA.WA D2	DIV.WA	D2,D1	LOAD.W	D3,D2		; D3 <-- y	SWAP.W	D390$:	POPM.L	D1,D2	RET;----------\\; DETSCALEP >;==========/; Tient compte de l'chelle positivement.; in	D3.L	(y;x); out	D3.L	(y;x) plus grand si n:1; mod	D3.LDETSCALEP:	PUSHM.L	D1,D2	LOAD.W	D1,(A6)+OSCALE	; D1 <-- chelle	JUMP',EQ 90$	JUMP',NS 50$	LOAD.W	D2,D3	MUL.WA	D2,D1	LOAD.W	D3,D2		; D3 <-- x	SWAP.W	D3	LOAD.W	D2,D3	MUL.WA	D2,D1	LOAD.W	D3,D2		; D3 <-- y	SWAP.W	D3	JUMP'	90$50$:	NEG.W	D1		; D1 <-- |chelle|	LOAD.W	D2,D3	CONV.LA.WA D2	DIV.WA	D2,D1	LOAD.W	D3,D2		; D3 <-- x	SWAP.W	D3	LOAD.W	D2,D3	CONV.LA.WA D2	DIV.WA	D2,D1	LOAD.W	D3,D2		; D3 <-- y	SWAP.W	D390$:	POPM.L	D1,D2	RET	.END