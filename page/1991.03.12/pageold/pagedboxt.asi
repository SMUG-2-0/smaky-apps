	.SBTTL	PAGEDBOXT;---------\\; DBOXOPEN >;---------/; Ouvre une dbox.; in	A2.L	table;	D2.W	mode; out	D5.L	canal;	D7.W	erreur; mod	D5.L, D7.WDBOXOPEN:	PUSH.L	D3	CALL	DBOXOPEN1	CALL	DBOXPOS3	; D3 <-- centre de la dbox	DBOX_	OPEN		; ouvre la dbox	POP.L	D3	TEST.W	D7		; retour EQ/NE	RETDBOXOPEN1:	PUSH.W	D3	CALL	ERGMOUSE	; efface les flches dans les rgles	CLR.B	D3	CALL	SELMO		; outil = flche	CALL	SCMO		; remet la flche	CALL	NORMMOUSE	; remet la flche	POP.W	D3	RET;----------\\; DBOXCLOSE >;----------/; Ferme une dbox.; in	D5.L	canal; out	D7.W	erreur; mod	D7.WDBOXCLOSE:	PUSH.W	D7	DBOX_	CLOSE		; ferme la dbox	POP.W	D7DBOXCLOSE1:	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	LIB	?AFTIM	.B	MMODULO,1	; n'impose plus les modulos	.B	0	.EVEN	POP.W	D7	RET;---------\\; DBOXPOS5 >;---------/; Centre ventuellement les dbox selon les icnes de gauche.; in	D2.W	mode d'ouverture; out	D2.W	mode d'ouverture;	D5.L	position (y;x); mod	D2.L, D5.L, D7.WDBOXPOS5:	PUSH.L	D3	CALL	DBOXPOS3	LOAD.L	D5,D3	POP.L	D3	RET;---------\\; DBOXPOS3 >;---------/; Centre ventuellement les dbox selon les icnes de gauche.; in	D2.W	mode d'ouverture; out	D2.W	mode d'ouverture;	D3.L	position (y;x); mod	D2.L, D3.L, D7.WDBOXPOS3:	TEST.B	(A6)+ODEF+3:#BDEFICO ; utilise les icnes ?	JUMP',BC 90$		; non => 90$				; oui =>	LOAD.W	D3,(A6)+ODICO+0	ADD.W	D3,#ICOLY/2	SWAP.W	D3	LOAD.W	D3,(A0)+ODFDX	SR.W	D3,#1	TSET.L	D2:#BDBPOS	; D2 <-- centre selon D3.L90$:	RET;--------\\; ZEROCR  >;========/; Remplace le terminateur <CR> par <0>.; Utile aprs DBOX_EDIT par exemple !; in	A3.L	^chane termine par <CR> ou <0>; out	A3.L	^chane termine par <0>; mod	-ZEROCR:	PUSH.L	A320$:	TEST.B	(A3+)	JUMP',EQ 90$	COMP.B	(A3)-1,#CR	JUMP,NE 20$	CLR.B	(A3)-1		; remplace le <CR> par <0>90$:	POP.L	A3	RET;--------\\; ERCALL  >;========/; Excute un appel systme en essayant de rsoudre qq problmes.; in	D0.L	code de l'appel (par exemple #FOS?OPEN);	+ selon appel; out	+ selon appel;	D7.W	erreur (ERKSTO si annule); mod	D7.WERCALL:	PUSHM.L	D1,D2	LOAD.W	D1,#DBOX_ERCALL	; D1 <-- numro de l'appel	LOAD.W	D2,#2^BDBEXTEND	; D2 <-- mode "tendu"	DBOX_	EXTEND		; appel DBOX_ERCALL ...	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET; Tables; ------TDBOX_AJOUTE:	.B	LDBOX_AJOUTE	.B	ODBLCIRCLE,15!2^7,0,1	.ASCIZ	" ajoute des objets  (.PAGE)"	.B	ODBCR	.B	ODBLCIRCLE,14!2^7,0,1	.ASCIZ	" ajoute une image   (.IMAGE)"	.B	ODBCR	.B	ODBLCIRCLE,13!2^7,0,1	.ASCIZ	" ajoute un texte    (.TEXT)"	.B	ODBCRLDBOX_AJOUTE	=	.-TDBOX_AJOUTE-1	.EVENTDBOX_ECHELLE:	.W	10$-TDBOX_ECHELLE	.W	20$-TDBOX_ECHELLE	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Nouvelle chelle :  "	.B	ODBCLINE,2+2	.B	ODBCR,ODBCR,ODBCR	.B	ODBLCIRCLE,0	.ASCIZ	" agrandissement (n:1)"	.B	ODBCR	.B	ODBLCIRCLE,1	.ASCIZ	" rduction      (1:n)"	.B	ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	"  ANNULE  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_ECHELLE:	.W	F1,F2,F3,CR,0		DOKF1-TKEY_ECHELLE	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_ECHELLE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_ECHELLE	.W	0TDBOX_VUE:	.W	10$-TDBOX_VUE	.W	20$-TDBOX_VUE	.W	0,010$:	.B	ODBLCIRCLE,BVUDEF	.ASCIZ	" vue relle"	.B	ODBCR	.B	ODBLCIRCLE,BVUMIX	.ASCIZ	" vue mixte"	.B	ODBCR	.B	ODBLCIRCLE,BVUFIL	.ASCIZ	" vue en fil de fer"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	"  ANNULE  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	