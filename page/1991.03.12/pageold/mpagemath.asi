	.SBTTL	MPAGEMATHPASTOURNE =	20		; valeur minimale pour n=(360*p)+p;---------\\; CALCPPCM >;=========/; Calcule la plus petite valeur commune entre deux valeurs diffrentes.; in	D3.W	valeur;	D4.W	valeur; out	D4.W	plus petit commun multiple;	D7.W	erreur; mod	D4.L, D7.WCALCPPCM:	PUSHM.L	D1..D3	CLR.W	D7		; D7 <-- ok	COMP.W	D3,D4	JUMP',EQ 90$	JUMP',LO 20$	EX.L	D3,D420$:	CLR.L	D2	LOAD.W	D2,D4	DIV.WU	D2,D3	SWAP.W	D2	TEST.W	D2	JUMP',EQ 90$	LOAD.W	D1,D3	LOAD.W	D2,D430$:	ADD.W	D3,D132$:	COMP.W	D3,D4	JUMP',EQ 90$	JUMP,LO 30$	ADD.W	D4,D2	COMP.W	D4,#100	JUMP,LO 32$	LOAD.W	D7,#190$:	POPM.L	D1..D3	TEST.W	D7		; retour EQ/NE	RET;----------\\; PYTHAGORE >;----------/; Calcul les coordonnes du point P7(x;y) en fonction du point P4(x;y); et de la longueur l sur l'hypotnuse.;		         o P4(x;y);		        /|;		       / |;		      /  |;		     /   |;		    o P7(x;y);		   /|    |;		l / |    |;		 /  |    |;		o---------;	     P3(x;y)  l'origine, donc (0;0); in	D0.W	+   l;	D1.W	+/- P4(x);	D2.W	+/- P4(y); out	D1.W	+/- P7(x);	D2.W	+/- P7(y); mod	D1.L, D2.LPYTHAGORE:	PUSHM.L	D0,D3..D7	CLR.W	D7		; D7 <-- clear flags	TEST.W	D1	JUMP',NC 10$	NEG.W	D1		; D1 <-- |P4(x)|	TSET.L	D7:#110$:	TEST.W	D2	JUMP',NC 15$	NEG.W	D2		; D2 <-- |P4(y)|	TSET.L	D7:#215$:	TEST.W	D1	JUMP',EQ 50$	TEST.W	D2	JUMP',EQ 55$	LOAD.W	D5,D0		; D5 <-- P7(x) suppos (trop grand)	MUL.WA	D0,D0		; D0 <-- l^2	COMP.W	D1,D2	JUMP',HS 20$	EX.L	D1,D2		; D1 > D2	TSET.L	D7:#020$:	LOAD.W	D6,D5	MUL.WU	D6,D2	DIV.WU	D6,D1		; D6 <-- P7(y) selon P4	LOAD.W	D3,D5	MUL.WU	D3,D3		; D3 <-- P7(x)^2	LOAD.W	D4,D6	MUL.WU	D4,D4		; D4 <-- P7(y)^2	ADD.W	D3,D4		; D3 <-- P7(x)^2 + P7(y)^2	COMP.W	D3,D0		; mme carr que le carr de "l" ?	JUMP',LS 30$		; oui => 30$				; encore trop grand =>	DEC.W	D5		; diminue P7(x) suppos	JUMP,NE	20$		; et recommence si non nul30$:	TEST.L	D7:#0	JUMP',BC 60$	EX.L	D5,D6	JUMP'	60$50$:				; "l" vertical =>	CLR.W	D5		; D5 <-- P7(x)	LOAD.W	D6,D0		; D6 <-- P7(y)	JUMP'	60$55$:				; "l" horizontal =>	LOAD.W	D5,D0		; D5 <-- P7(x)	CLR.W	D6		; D6 <-- P7(y)60$:	LOAD.W	D1,D5	LOAD.W	D2,D6	TEST.L	D7:#1	JUMP',BC 80$	NEG.W	D180$:	TEST.L	D7:#2	JUMP',BC 85$	NEG.W	D285$:	POPM.L	D0,D3..D7	RET;-----------\\; INCLDROITE >;-----------/; Modifie ventuellement l'inclinaison d'une droite.; in	D3.L	coordonne d'un coin;	D4.L	coordonne coin oppos;	D1.L	type (BDRxxxx/BFLxxxx); out	D4.L	coordonne coin oppos; mod	D4.L, D7.WINCLDROITE:	PUSHM.L	D0..D3,D5,D6	TEST.L	D1:#BDRHV	JUMP,BS 50$	TEST.L	D1:#BDRHVO	JUMP,BC 90$				; ANGLE 0/45/90 =>	CLR.L	D6		; D6 <-- flags	COMP.W	D4,D3	JUMP',GE 10$	SUB.W	D4,D3	NEG.W	D4	ADD.W	D4,D3	TSET.L	D6:#1		; D6 <-- coordonne X permute10$:	SWAP.W	D3	SWAP.W	D4	COMP.W	D4,D3	JUMP',GE 12$	SUB.W	D4,D3	NEG.W	D4	ADD.W	D4,D3	TSET.L	D6:#2		; D6 <-- coordonne Y permute12$:	SWAP.W	D3	SWAP.W	D4	LOAD.L	D0,D3		; D0 <-- origine	LOAD.L	D1,D4		; D1 <-- arrive	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	LIB	?CALCHYPO	; D4 <-- longueur de la droite	LOAD.L	D3,D0		; D3 <-- origine	LOAD.L	D5,D0	ADD.W	D5,D4	LOAD.L	D4,D1	LIB	?CALCANGLE	; D2 <-- angle (0..360)	LOAD.L	D3,D0	LOAD.L	D4,D1	COMP.W	D2,#360*15/16	JUMP',HS 20$	COMP.W	D2,#360*1/16	JUMP',LS 20$	COMP.W	D2,#360*3/16	JUMP',HS 22$				; 22..67 degrs =>	LOAD.L	D4,D5	LOAD.W	D1,#45	LIB	?CALCPSYM	; D4 <-- arrive tourne	JUMP'	30$20$:				; 0..22 degrs =>	SWAP.W	D3	SWAP.W	D4	LOAD.W	D4,D3	SWAP.W	D4	SWAP.W	D3	JUMP'	30$22$:				; 67..90 degrs =>	LOAD.W	D4,D3;	JUMP'	30$30$:	TEST.L	D6:#1		; coordonne X permute ?	JUMP',BC 32$		; non => 32$	SUB.W	D4,D3	SUB.W	D4,D3	NEG.W	D432$:	SWAP.W	D3	SWAP.W	D4	TEST.L	D6:#2		; coordonne Y permute ?	JUMP',BC 34$		; non => 34$	SUB.W	D4,D3	SUB.W	D4,D3	NEG.W	D434$:	SWAP.W	D3	SWAP.W	D4	JUMP	90$50$:				; ANGLE 0/90 =>	LOAD.W	D0,D4	SUB.W	D0,D3	JUMP',NC 52$	NEG.W	D0		; D0 <-- |dX|52$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D1,D4	SUB.W	D1,D3	JUMP',NC 53$	NEG.W	D1		; D1 <-- |dY|53$:	SWAP.W	D4	SWAP.W	D3	COMP.W	D0,D1	JUMP',HS 55$				; droite verticale =>	LOAD.W	D4,D3	JUMP'	90$55$:				; droite horizontale =>	SWAP.W	D3	SWAP.W	D4	LOAD.W	D4,D3	SWAP.W	D4	SWAP.W	D390$:	POPM.L	D0..D3,D5,D6	RET;----------\\; CALCRAYON >;==========/; Calcule le rayon d'un cercle.; in	D3.L	origine (y;x);	D4.L	arrive (y;x); out	D5.W	rayon; mod	D5.L, D7.WCALCRAYON:	PUSHM.L	D3,D4	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	LIB	?CALCHYPO	; D4 <-- hypothnuse	LOAD.W	D5,D4	POPM.L	D3,D4	RET;--------\\; XTOURNE >;--------/; Dtermine l'angle de rotation en fonction de la position; de la souris.; in	D4.L	position de la souris (y;x);	D3.L	point  tourner (y;x); out	D2.W	angle en degr; mod	D2.LXTOURNE:	PUSHM.L	D3,D5	LOAD.L	D5,D3		; D5 <-- point  tourner	LOAD.L	D3,(A6)+OCCERC	; D3 <-- centre	LIB	?CALCANGLE	; D2 <-- angle	POPM.L	D3,D5	RET;--------\\; QTOURNE >;--------/; Tourne un point d'un angle quelconque selon la; formule magique suivante :;;	x' = x*cos(a) - y*sin(a);	y' = x*sin(a) + y*cos(a);; OCCERC.L contient la coordonne du centre de symtrie.; in	D2.W	angle en degrs;	D3.L	coordonne (y;x); out	D3.L	coordonne (y;x); mod	D3.LQTOURNE:	PUSHM.L	D1,D4	LOAD.W	D1,D2		; D1 <-- angle	LOAD.L	D4,D3		; D4 <-- point  tourner	LOAD.L	D3,(A6)+OCCERC	; D3 <-- centre de symtrie	LIB	?CALCPSYM	; D4 <-- point tourn	LOAD.L	D3,D4	POPM.L	D1,D4	RET	.END