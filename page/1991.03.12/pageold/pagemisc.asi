	.SBTTL	PAGEMISC;----------\\; WAITPRESS >;----------/; Attend une pression d'une touche ou d'un bouton.; in	-; out	D3.L	touche presse; mod	D3.L, D7.WWAITPRESS:	PUSH.L	D410$:	LIB	?GETKEY		; attend souris ...	TEST.L	D3:#BKPSEUDO	; touche presse normale ?	JUMP,BS 10$		; non => 10$	COMP.W	D3,#KEYMPO	; dplacement ?	JUMP',NE 90$		; non => 90$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE 10$	CALL	RGMOUSE		; dessine la position dans les rgles	JUMP	10$90$:	POP.L	D4	RET;----------\\; WAITMOVES >;----------/; Attend les dplacements de la souris, mme si elle ne bouge pas.; in	-; out	D3.L	touche presse;	D7.W	EQ si souris dplace; mod	D3.L, D7.WWAITMOVES:	PUSH.L	D4	CLR.W	D4	NTREL	?SETTIM		; met timeout nul (trs trs court)	CALL	WAITMOVE	; attend dplacement souris ...	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM		; remet timeout infini	POP.W	D7	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; WAITMOVED >;----------/; Attend un dplacement de la souris.; in	D4.W	dlai;	A4.L	^objet; out	D3.L	touche presse;	D7.W	NE si timeout; mod	D3.L, D7.WWAITMOVED:	NTREL	?SETTIM		; met timeout10$:	LIB	?GETKEY		; attend souris ...	JUMP',NE 20$		; si timeout => 20$	TEST.L	D3:#BKPSEUDO	; touche presse normale ?	JUMP',BC 90$		; oui => 90$	TEST.L	D3:#BKRELEAS	; changement de touches super-shift ?	JUMP',BS 10$		; non => 10$	LOAD.W	D3,#KEYMGR	JUMP'	90$20$:	LOAD.W	D3,#KEYMPO	; D3 <-- dplacement90$:	PUSHM.L	D4,D7	LOAD.W	D4,#-1	NTREL	?SETTIM		; remet timeout infini	POPM.L	D4,D7	TEST.W	D7		; retour EQ/NE	RET;---------\\; WAITMOVE >;---------/; Attend un dplacement de la souris.; in	-; out	D3.L	touche presse;	D7.W	EQ si souris dplace; mod	D3.L, D7.WWAITMOVE:10$:	LIB	?GETKEY		; attend souris ...	JUMP',NE 20$		; si timeout => 20$	TEST.L	D3:#BKPSEUDO	; touche presse normale ?	JUMP',BC 30$		; oui => 30$	JUMP	10$20$:	LOAD.W	D3,#KEYMPO	; D3 <-- dplacement	CLR.W	D7		; D7 <-- souris bouge	JUMP'	90$30$:	LOAD.W	D7,#1		; D7 <-- fin du dplacement	COMP.W	D3,#KEYMGP	JUMP',EQ 90$	COMP.W	D3,#KEYMMP	JUMP',EQ 90$	COMP.W	D3,#KEYMDP	JUMP',EQ 90$	COMP.W	D3,#KEYMGR	JUMP',EQ 90$	COMP.W	D3,#KEYMMR	JUMP',EQ 90$	COMP.W	D3,#KEYMDR	JUMP',EQ 90$	CLR.W	D7		; D7 <-- souris bouge90$:	TEST.W	D7		; retour EQ/NE	RET;--------\\; MMENUS  >;========/; Appel un mmenu hirarchique, avec mmorisation ventuelle de la case.; in	A3.L	^mmenu;	A4.L	^table des paramtres; out	D7.W	erreur; mod	D7.WMMENUS:	PUSHM.L	D3..D5,A2..A5	LOAD.L	A5,A4		; A5 <-- ^paramtres	LOAD.L	A4,A3		; A4 <-- ^mmenu	LOAD.L	A3,#(A6)+OBUDIS	LOAD.B	(A3)+0,#MMODULO	CLR.B	(A3)+1	LOAD.W	D3,#2	LIB	?STRING		; impose les modulos	CALL	SCMO		; remet la souris	CLR.B	D3	CALL	SELMO		; outil = flche	CALL	IFMOUSE		; D4 <-- position de la souris	TEST.B	(A6)+ODEF+1:#BDEFMDC-16	JUMP',BS 20$	CLR.W	(A5)+(LMM*0)+OMMSEL ; slectionne la premire case20$:	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^buffer pour construire m-menu	LOAD.L	A2,A3	CALL	MENUBUF		; buffer <-- menu principal	CALL	MENUAJUST	; buffer <-- tous les sous-(sous-)menus	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^mmenu	LOAD.L	A4,A5		; A4 <-- ^paramtres	CLR.L	D5		; D5 <-- mode	LIB	?MMENUS		; attend selon choix	PUSH.W	D7	CALL	PMOUSE		; remet la souris o elle tait	LOAD.W	D4,#2	NTREL	?DELMS		; attend le positionnement !	LIB	?AFTIM	.B	MMODULO,1	; n'impose plus les modulos	.B	0	.EVEN	POP.W	D7	POPM.L	D3..D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; MENUAJUST >;----------/; Ajuste les pointeurs relatifs du menu pre qui vient d'tre; mis dans le buffer.; in	A2.L	^dbut du menu pre;	A3.L	^buffer;	A4.L	^mmenu; out	A3.L	^plus loin;	A4.L	^plus loin; mod	D7.W, A3.L, A4.LMENUAJUST:	PUSHM.L	D3,D4,A1,A2	LOAD.L	A1,A220$:	TEST.B	(A2)		; fin du mmenu ?	JUMP,EQ 90$		; oui => 90$30$:	LOAD.B	D3,(A2+)	JUMP,EQ 20$	COMP.B	D3,#-2	JUMP,NE 30$				; ^sous-menu =>	LOAD.B	D3,(A2+)	SL.W	D3,#8	LOAD.B	D3,(A2+)	; D3 <-- ^relatif	LOAD.L	D4,A3	SUB.L	D4,A1	LOAD.B	(A2)-1,D4	RR.W	D4,#8	LOAD.B	(A2)-2,D4	; buffer <-- ^relatif au sous-menu	RR.W	D4,#8	PUSH.L	A2	PUSH.L	A3	TEST.W	D3		; .BW -2,-n  ?	JUMP',NS 50$		; oui => 50$				; non =>	CALL	MENUBUF		; buffer <-- sous-menu	JUMP'	52$50$:	CALL	MENUSPEC	; buffer <-- sous-menu52$:	POP.L	A2	CALL	MENUAJUST	; paf, rcursif !!!	POP.L	A2	JUMP	30$90$:	POPM.L	D3,D4,A1,A2	RET;--------\\; MENUBUF >;--------/; Met un mmenu dans un buffer.; in	A3.L	^buffer;	A4.L	^mmenu; out	A3.L	^plus loin;	A4.L	^plus loin; mod	D7.W, A3.L, A4.LMENUBUF:	PUSH.W	D310$:	TEST.B	(A4)		; fin du mmenu ?	JUMP',EQ 80$20$:	LOAD.B	D3,(A4+)	LOAD.B	(A3+),D3	; buffer <-- .ASCIZ	JUMP,EQ 10$	COMP.B	D3,#-2	JUMP,NE	20$	LOAD.B	(A3+),(A4+)	; buffer <-- <^rel-high>	LOAD.B	(A3+),(A4+)	; buffer <-- <^rel-low>	JUMP	20$80$:	INC.L	A4	CLR.B	(A3+)		; buffer <-- terminateur	POP.W	D3	RET;---------\\; MENUSPEC >;---------/; Met un mmenu spcial dans un buffer.; in	D3.W	type du menu spcial (-);	D4.W	^relatif;	A2.L	^pour mj. ^relatif;	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LMENUSPEC:	PUSHM.L	D2..D4,A1,A2,A4	COMP.W	D3,#-1	JUMP',EQ 20$	JUMP	90$; Construit le sous-menu des caractres.20$:	LOAD.L	A1,A2	PUSH.L	A3	LOAD.L	A4,#(A6)+OBUGC	; A4 <-- ^buffer des gencars	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	DGENC_	MENU		; buffer <-- sous-menu des gencars	INC.L	A3		; A3 <-- saute le zro terminateur	POP.L	A422$:	INC.W	D4	COMP.B	(A4+),#-1	; A4 <-- saute la premire case vide	JUMP,NE 22$	LOAD.B	(A1)-1,D4	RR.W	D4,#8	LOAD.B	(A1)-2,D4	; buffer <-- ajuste le ^relatif;	JUMP	90$90$:	POPM.L	D2..D4,A1,A2,A4	RET;--------\\; RGMOUSE >;========/; Dessine la position de la souris dans les rgles.; in	D4.L	position de la souris; out	-; mod	D7.WRGMOUSE:	PUSHM.L	D2..D4,A5	TEST.B	(A6)+ODEF+2:#BDEFREG-8 ; rgles prsentes ?	JUMP',BC 90$		; non => 90$				; oui =>	LOAD.L	A5,#(A6)+ORGVAR	LOAD.L	D2,D4		; D2 <-- position (y;x)	CLR.L	D4		; D4 <-- efface les flches	LOAD.W	D3,(A5)+ORGHPO+2	COMP.W	D2,D3		; trop  gauche ?	JUMP',LO 60$	ADD.W	D3,(A5)+ORGHLG	COMP.W	D2,D3		; trop  droite ?	JUMP',HS 60$	SWAP.W	D2	LOAD.W	D3,(A5)+ORGVPO+0	COMP.W	D2,D3		; trop en haut ?	JUMP',LO 60$	ADD.W	D3,(A5)+ORGVLG	COMP.W	D2,D3		; trop en bas ?	JUMP',HS 60$	SWAP.W	D2	LOAD.L	D4,D2		; D4 <-- position (y;x)60$:	SCROLL_	RMOUSE		; dplace les flches dans les rgles90$:	POPM.L	D2..D4,A5	RET;---------\\; ERGMOUSE >;=========/; Efface la position de la souris dans les rgles.; in	-; out	-; mod	D7.WERGMOUSE:	PUSHM.L	D4,A5	LOAD.L	A5,#(A6)+ORGVAR	CLR.L	D4		; D4 <-- efface	SCROLL_	RMOUSE		; efface les flches dans les rgles	POPM.L	D4,A5	RET;--------\\; IFMOUSE >;========/; Donne la position de la souris dans la swdo.; in	-; out	D4.L	position de la souris (y;x);	D7.W	erreur; mod	D4.L, D7.WIFMOUSE:	PUSH.L	D3	LIB	?IFMOUSE	JUMP',NE 90$	ADD.W	D4,(A6)+OLUPX	SUB.W	D4,(A0)+ODFFX	JUMP',HS 20$	CLR.W	D4	LOAD.W	D7,#ERDIOUT20$:	SWAP.W	D4	ADD.W	D4,(A6)+OLUPY	SUB.W	D4,(A0)+ODFFY	JUMP',HS 30$	CLR.W	D4	LOAD.W	D7,#ERDIOUT30$:	SWAP.W	D490$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;--------\\; PMOUSE  >;========/; Positionne la souris en (y;x).; in	D4.L	nouvelle position y;x; out	-; mod	D7.WPMOUSE:	LIB	?PMOUSE		; positionne la souris	RET;--------\\; CCMO    >;========/; Enlve la souris.; in	-; out	-; mod	D7.WCCMO:	PUSH.W	D3	TEST.B	(A6)+OCCMO	JUMP',T 90$	LOAD.B	D3,#AFCCMO	LIB	?AFCAR	SET.B	(A6)+OCCMO90$:	POP.W	D3	RET;--------\\; SCOMO   >;========/; Remet l'outil slectionn et la souris.; in	-; out	-; mod	D7.WSCOMO:	PUSH.W	D3	LOAD.B	D3,(A6)+OOUTIL	CALL	SELMO		; utilise le bon lutin	CALL	SCMO		; remet la souris	POP.W	D3	RET;--------\\; SCMO    >;========/; Remet la souris.; in	-; out	-; mod	D7.WSCMO:	PUSH.W	D3	TEST.B	(A6)+OCCMO	JUMP',F 90$	LOAD.B	D3,#AFSCMO	LIB	?AFCAR	CLR.B	(A6)+OCCMO90$:	POP.W	D3	RET;--------\\; SELMO   >;--------/; Slectionne un nouveau lutin pour la souris.; in	D3.B	outil en fonction; out	-; mod	D7.WSELMO:	PUSHM.L	D1..D5,A2..A5	LOAD.L	A3,#R16"00$	LOAD.B	D2,D3	CLR.B	D3		; D3 <-- pas d'outil; Vrifie si la souris est dans la zone de dessin.; Si non, n'utilise pas l'outil slectionn.	LOAD.L	D1,#-1		; D1 <-- hors de la fentre	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP',NE 10$	LOAD.L	D1,D4	SUB.W	D4,(A6)+OWPOS+2	JUMP',LO 10$	COMP.W	D4,(A6)+OWDIM+2	JUMP',HS 10$	SWAP.W	D4	SUB.W	D4,(A6)+OWPOS+0	JUMP',LO 10$	COMP.W	D4,(A6)+OWDIM+0	JUMP',HS 10$	LOAD.B	D3,D2		; D3 <-- outil slectionn10$:	TEST.B	(A3)+0		; fin de la table ?	JUMP',EQ 15$	COMP.B	D3,(A3)+0	; outil trouv ?	JUMP',EQ 15$	ADD.L	A3,#5		; A3 <-- ^suivant dans table	JUMP	10$15$:	CLR.W	D3	LOAD.B	D3,(A3)+1	; D3 <-- code de l'icne	COMP.B	D3,#ICOCLOUPEP	JUMP',NE 16$	PUSH.W	D3	LIB	?GETSHIFT	LOAD.W	D4,D3		; D4 <-- touches super-shift	POP.W	D3	TEST.L	D4:#BCURSOR	JUMP',BC 16$	LOAD.B	D3,#ICOCLOUPEM16$:	LOAD.B	(A6)+OLUPX+1,(A3)+3	LOAD.B	(A6)+OLUPY+1,(A3)+4	COMP.B	D3,(A6)+OLUTIN	; toujours le mme outil ?	JUMP,EQ 90$		; oui => 90$	LOAD.B	(A6)+OLUTIN,D3	LOAD.L	A2,#(A6)+OLUMAM	TNOT.B	(A6)+OLUFLG:#BLUMAN	JUMP',BC 17$	LOAD.L	A2,#(A6)+OLUMAN17$:	LOAD.L	A4,#0		; A4 <-- utilise la flche normale	LOAD.L	A5,#0		; A5 <-- matrice fond automatique	TEST.B	D3	JUMP',EQ 50$	TEST.B	(A3)+2	JUMP',NE 30$20$:	CALL	CMOUTIL		; A4/A5 <-- ^dx,dy,matrice de l'outil	JUMP'	50$30$:	CALL	CMOUTILFOND	; A4/A5 <-- ^dx,dy,matrice chair/fond;	JUMP'	50$50$:	NTREL	?GETPRIO	LOAD.W	D5,D4		; D5 <-- priorit actuelle	LOAD.W	D4,#1	NTREL	?SETPRIO	; met une trs forte priorit	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWPMOUSE	LOAD.L	(A3)+1,A4	; <ssss> matrice chair	LOAD.L	(A3)+5,A5	; <cccc> matrice fond	LOAD.W	D3,#9	LIB	?STRING	COMP.L	D1,#-1		; hors de la fentre ?	JUMP,EQ 70$		; oui => 70$				; non =>	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE 70$	SUB.W	D4,D1	JUMP',NC 60$	NEG.W	D4		; D4 <-- |dplacement horizontal|60$:	COMP.W	D4,#30		; souris beaucoup bouge "entre temps" ?	JUMP',HS 70$		; oui => 70$ (crac, pas de positionnement !!!)	LOAD.L	D4,D1	SUB.W	D4,(A6)+OLUPX	SWAP.W	D4	SUB.W	D4,(A6)+OLUPY	SWAP.W	D4	CALL	PMOUSE		; positionne pour ne pas bouger la "pointe"70$:	LOAD.W	D4,D5	NTREL	?SETPRIO	; remet la priorit initiale	LOAD.W	D4,#2	NTREL	?DELMS		; attend le changement/positionnement !90$:	POPM.L	D1..D5,A2..A5	RET00$:	.B	ICOCRAYON,ICOCCRAYON,0			1+0,1+20	.B	ICOMAIN,ICOCMAIN,ICOFMAIN		8,10	.B	ICOPLOUPE,ICOCLOUPEP,0			6,6	.B	ICOCROCHET,ICOCROCHET,0			15,14	.B	ICOPOIGNEE,ICOPOIGNEE,0			10,11	.B	ICOTX,ICOCTEXTE,0			1,1	.B	ICOBN,ICOCBLOC,ICOFBLOC			1,1	.B	ICOAJOUTE,ICOCAJOUTE,0			1,1	.B	ICOSPLMOV,ICOCSPLMOV,0			0,0	.B	ICOSPLADD,ICOCSPLADD,0			0,0	.B	ICOSPLSUB,ICOCSPLSUB,0			0,0	.B	ICOTXCURS,ICOTXCURS,0			11,10	.B	ICOTXTABM,ICOCSPLMOV,0			0,0	.B	ICOTXTABD,ICOTXTABD,0			15,10	.B	ICOTXTABG,ICOTXTABG,0			15,10	.B	ICOTXTABC,ICOTXTABC,0			11,10	.B	ICOTXTABN,ICOTXTABN,0			11,10	.B	0,0,0					0,0	.EVEN;--------\\; CMOUTIL >;--------/; Construit la matrice d'un outil quelconque d'aprs; une icne contenue dans IPP21/22.; La matrice construite possde un point de plus de tous; les cts, pour permettre un calcul correct de la matrice; automatique de fond.; in	D3.W	code de l'icne;	A2.L	^buffer pour matrice; out	A4.L	^dx,dy,matrice chair;	A5.L	^dx,dy,matrice fond; mod	D7.W, A4.L, A5.LCMOUTIL:	PUSHM.L	D1..D4,A1,A3	LOAD.L	A1,(A6)+OPGICO	; A1 <-- ^gencar des icnes IPP21	TCLR.L	D3:#7	JUMP',BC 20$	LOAD.L	A1,(A6)+OPHICO	; A1 <-- ^gencar des icnes IPP2220$:	LOAD.L	A3,#(A6)+OBUDIS	LOAD.W	(A3)+0,#DRAWRASTER	CLR.L	(A3)+2		; source: <xx> et <yy>	LOAD.L	A4,A1		; A4 <-- ^gencar des icnes	LOAD.W	D4,(A4)+OGCMSB	MUL.WU	D4,D3	ADD.L	D4,#OGCMAT	ADD.L	A4,D4		; A4 <-- ^bonne matrice	LOAD.L	(A3)+6,A4	; source: <pppp>	LOAD.W	(A3)+10,#GCICX/8 ; source: <ii>	LOAD.L	A4,A1		; A4 <-- ^gencar des icnes	LOAD.L	A4,#(A4)+OGCWID	; A4 <-- ^table des largeurs	LOAD.W	D2,#1+GCICY+1	; D2 <-- hauteur	SWAP.W	D2	CLR.W	D2	LOAD.B	D2,(A4)+(D3.W)	ADD.W	D2,#2		; D2 <-- largeur	LOAD.W	D1,D2	ADD.W	D1,#8-1	SR.W	D1,#3		; D1 <-- largeur en bytes	LOAD.W	(A3)+12,#1	; destination: <xx>	LOAD.W	(A3)+14,#1	; destination: <yy>	LOAD.L	A4,A2		; A4 <-- ^buffer pour matrice	LOAD.B	(A4+),D2	; OLUMAM/N <-- dx	SWAP.W	D2	LOAD.B	(A4+),D2	; OLUMAM/N <-- dy	SWAP.W	D2	LOAD.L	(A3)+16,A4	; destination: <pppp>	LOAD.W	(A3)+20,D1	; destination: <ii>	LOAD.L	D4,D2	SWAP.W	D4	MUL.WU	D4,D1	DEC.W	D440$:	CLR.B	(A4+)		; OLUMAM/N <-- efface tout	DECJ.W,NMO D4,40$	SUB.W	D2,#2	LOAD.W	(A3)+22,D2	; <dxx>	SWAP.W	D2	SUB.W	D2,#2	LOAD.W	(A3)+24,D2	; <dyy>	LOAD.B	(A3)+26,#SETDOT	; <mode>	LOAD.W	D3,#1+26	LIB	?STRING		; OLUMAM/N <-- icne	LOAD.L	A4,A2		; A4 <-- ^dx,dy,matrice	LOAD.L	A5,#0		; A5 <-- matrice fond automatique	POPM.L	D1..D4,A1,A3	RET;------------\\; CMOUTILFOND >;------------/; Construit les matrices chair et fond d'un outil quelconque d'aprs; une icne et la suivante contenue dans IPP21.; in	D3.W	code de l'icne;	A2.L	^buffer pour matrice; out	A4.L	^dx,dy,matrice chair;	A5.L	^dx,dy,matrice fond; mod	D7.W, A4.L, A5.LCMOUTILFOND:	PUSHM.L	D0..D4,A1,A3	LOAD.L	A1,(A6)+OPGICO	; A1 <-- ^gencar des icnes IPP21	TCLR.L	D3:#7	JUMP',BC 20$	LOAD.L	A1,(A6)+OPHICO	; A1 <-- ^gencar des icnes IPP2220$:	LOAD.W	D0,D3		; D0 <-- code de l'icne	LOAD.L	A3,#(A6)+OBUDIS	LOAD.W	(A3)+0,#DRAWRASTER	CLR.L	(A3)+2		; source: <xx> et <yy>	LOAD.L	A4,A1		; A4 <-- ^gencar des icnes	LOAD.W	D4,(A4)+OGCMSB	MUL.WU	D4,D0	ADD.L	D4,#OGCMAT	ADD.L	A4,D4		; A4 <-- ^matrice chair	LOAD.L	(A3)+6,A4	; source: <pppp>	LOAD.W	(A3)+10,#GCICX/8 ; source: <ii>	LOAD.L	A4,A1		; A4 <-- ^gencar des icnes	LOAD.L	A4,#(A4)+OGCWID	; A4 <-- ^table des largeurs	LOAD.W	D2,#GCICY	; D2 <-- hauteur	SWAP.W	D2	CLR.W	D2	LOAD.B	D2,(A4)+(D0.W)	; D2 <-- largeur	LOAD.W	D1,D2	ADD.W	D1,#8-1	SR.W	D1,#3		; D1 <-- largeur en bytes	CLR.L	(A3)+12		; destination: <xx> et <yy>	LOAD.L	A4,A2		; A4 <-- ^buffer pour matrice	LOAD.B	(A4+),D2	; OLUMAM/N <-- dx chair	SWAP.W	D2	LOAD.B	(A4+),D2	; OLUMAM/N <-- dy chair	SWAP.W	D2	LOAD.L	(A3)+16,A4	; destination: <pppp>	LOAD.W	(A3)+20,D1	; destination: <ii>	LOAD.L	D4,D2	SWAP.W	D4	MUL.WU	D4,D1	DEC.W	D440$:	CLR.B	(A4+)		; OLUMAM/N <-- efface tout	DECJ.W,NMO D4,40$	SWAP.W	D2	LOAD.L	(A3)+22,D2	; <dxx> et <dyy>	SWAP.W	D2	LOAD.B	(A3)+26,#SETDOT	; <mode>	LOAD.W	D3,#1+26	LIB	?STRING		; OLUMAM/N <-- icne chair	LOAD.L	A5,A4		; A5 <-- ^futur dx,dy,matrice fond	LOAD.L	A4,A1		; A4 <-- ^gencar des icnes	LOAD.W	D4,(A4)+OGCMSB	LOAD.W	D3,D0	INC.W	D3	MUL.WU	D4,D3	ADD.L	D4,#OGCMAT	ADD.L	A4,D4		; A4 <-- ^matrice suivante (fond)	LOAD.L	(A3)+6,A4	; source: <pppp>	LOAD.L	A4,A5	LOAD.B	(A4+),D2	; OLUMAM/N <-- dx fond	SWAP.W	D2	LOAD.B	(A4+),D2	; OLUMAM/N <-- dy fond	SWAP.W	D2	LOAD.L	(A3)+16,A4	; destination: <pppp>	LOAD.L	D4,D2	SWAP.W	D4	MUL.WU	D4,D1	DEC.W	D460$:	CLR.B	(A4+)		; OLUMAM/N <-- efface tout	DECJ.W,NMO D4,60$	LOAD.W	D3,#1+26	LIB	?STRING		; OLUMAM/N <-- icne fond	LOAD.L	A4,A2		; A4 <-- ^dx,dy,matrice chair	POPM.L	D0..D4,A1,A3	RET;----------\\; WAITMOUSE >;==========/; Met la souris en attente (sablier).; in	-; out	-; mod	-WAITMOUSE:	PUSHM.L	D4,D7	CLR.W	D4	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;----------\\; NORMMOUSE >;==========/; Remet la flche de la souris.; in	-; out	-; mod	-NORMMOUSE:	PUSHM.L	D4,D7	LOAD.W	D4,#1	LIB	?WAITMOUSE	POPM.L	D4,D7	RET;--------\\; DRMDEF  >;========/; Dfini la demi-trame super-rapidement.; ATTENTION:	Le fait d'crire directement dans le descripteur;		de la fentre fait que la trame est inverse !; in	D4.L	demi-trame; out	-; mod	D7.WDRMDEF:	LOAD.L (A0)+ODFTRA+0,D4	LOAD.L (A0)+ODFTRA+4,D4	CLR.L	(A0)+ODFTPM	; annule XTRAME	RET;--------\\; OPEWDO  >;========/; Utilise la swdo de dessin, si ncessaire.; in	-; out	-; mod	D7.WOPEWDO:	TEST.W	(A6)+OWUSE	JUMP',NE 20$	PUSHM.L	D3,A3	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DIMWDO	LOAD.W	(A3)+1,(A6)+OWPOS+2	LOAD.W	(A3)+3,(A6)+OWPOS+0	LOAD.W	(A3)+5,(A6)+OWDIM+2	LOAD.W	(A3)+7,(A6)+OWDIM+0	LOAD.W	D3,#9	LIB	?STRING	POPM.L	D3,A320$:	INC.W	(A6)+OWUSE	RET;--------\\; CLOWDO  >;========/; Ferme la swdo de dessin, si ncessaire.; in	-; out	-; mod	D7.WCLOWDO:	DEC.W	(A6)+OWUSE	JUMP',NE 90$	PUSHM.L	D3,A3	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DIMWDO	CLR.L	(A3)+1	LOAD.W	(A3)+5,(A0)+ODFDX	LOAD.W	(A3)+7,(A0)+ODFDY	LOAD.W	D3,#9	LIB	?STRING	POPM.L	D3,A390$:	RET;----------\\; OPEDISMAT >;==========/; Modifie le descripteur de la fentre pour pouvoir dessiner; directement dans la matrice principale.; in	A4.L	^matrice o dessiner;	D4.L	dimensions (dy;dx); out	-; mod	D7.WOPEDISMAT:	PUSH.L	D4	CALL	CCMO		; enlve la souris	LOAD.L	(A6)+OSDDIS+ODFABS,(A0)+ODFABS	LOAD.W	(A6)+OSDDIS+ODFIIX,(A0)+ODFIIX	LOAD.W	(A6)+OSDDIS+ODFIIY,(A0)+ODFIIY	LOAD.L	(A6)+OSDDIS+ODFY,(A0)+ODFY	LOAD.L	(A6)+OSDDIS+ODFDY,(A0)+ODFDY	LOAD.L	(A6)+OSDDIS+ODFFY,(A0)+ODFFY	LOAD.L	(A6)+OSDDIS+ODFFDY,(A0)+ODFFDY	LOAD.L	(A6)+OSDDIS+ODFWBY,(A0)+ODFWBY	LOAD.L	(A6)+OSDDIS+ODFWEY,(A0)+ODFWEY;;?	LOAD.W	(A6)+OSDDIS+ODFTTC,(A0)+ODFTTC	LOAD.L	(A0)+ODFABS,A4	CLR.L	(A0)+ODFY	LOAD.L	(A0)+ODFDY,D4	CLR.L	(A0)+ODFFY	LOAD.L	(A0)+ODFFDY,D4	CLR.L	(A0)+ODFWBY	LOAD.L	(A0)+ODFWEY,D4	LOAD.W	(A0)+ODFIIX,#1	ADD.W	D4,#16-1	AND.B	D4,#B'11110000	SR.W	D4,#3	LOAD.W	(A0)+ODFIIY,D4	POP.L	D4	RET;----------\\; CLODISMAT >;==========/; Modifie le descripteur de la fentre pour pouvoir de nouveau; dessiner dans l'cran.; in	-; out	-; mod	D7.WCLODISMAT:	LOAD.L	(A0)+ODFABS,(A6)+OSDDIS+ODFABS	LOAD.W	(A0)+ODFIIX,(A6)+OSDDIS+ODFIIX	LOAD.W	(A0)+ODFIIY,(A6)+OSDDIS+ODFIIY	LOAD.L	(A0)+ODFY,(A6)+OSDDIS+ODFY	LOAD.L	(A0)+ODFDY,(A6)+OSDDIS+ODFDY	LOAD.L	(A0)+ODFFY,(A6)+OSDDIS+ODFFY	LOAD.L	(A0)+ODFFDY,(A6)+OSDDIS+ODFFDY	LOAD.L	(A0)+ODFWBY,(A6)+OSDDIS+ODFWBY	LOAD.L	(A0)+ODFWEY,(A6)+OSDDIS+ODFWEY;;?	LOAD.W	(A0)+ODFTTC,(A6)+OSDDIS+ODFTTC	RET;--------\\; AFMENU  >;========/; Affiche les soft-keys.; in	-; out	-; mod	D7.WAFMENU:	PUSHM.L	D3,A3	LOAD.B	D3,(A6)+OXICO	COMP.B	D3,#NIVPOIGNEE	JUMP',NE 20$	LOAD.L	A3,#R16"TXMPOIGNEETX	COMP.B	(A6)+OYICO,#ICOTX	JUMP',EQ 80$	LOAD.L	A3,#R16"TXMPOIGNEE	JUMP'	80$20$:	LOAD.L	A3,#R16"TXMSPLINE	COMP.B	D3,#NIVSPLINE	JUMP',EQ 80$	LOAD.L	A3,#R16"TXMLINEB	COMP.B	D3,#NIVLINEB	JUMP',EQ 80$	LOAD.L	A3,#R16"TXMENU80$:	LIB	?AFMENU	POPM.L	D3,A3	RET;--------\\; CONVMPX >;========/; Converti un nombre horizontal en millimtres --> en points.; in	D4.W	nombre [mm]; out	D4.W	nombre [p]; mod	D3.W, D4.LCONVMPX:	MUL.WA	D4,#10000	LOAD.W	D3,(A6)+OMMX	CALL	DIVD4D3	CONV.LA.WA D4	LOAD.W	D3,(A6)+OFACX	JUMP'	DIVD4D3;--------\\; CONVMPY >;========/; Converti un nombre vertical en millimtres --> en points.; in	D4.W	nombre [mm]; out	D4.W	nombre [p]; mod	D3.W, D4.LCONVMPY:	MUL.WA	D4,#10000	LOAD.W	D3,(A6)+OMMY	CALL	DIVD4D3	CONV.LA.WA D4	LOAD.W	D3,(A6)+OFACY	JUMP'	DIVD4D3;--------\\; CONVPMX >;========/; Converti un nombre horizontal en points --> en millimtres.; in	D4.W	nombre [p]; out	D4.W	nombre [mm]; mod	D3.W, D4.LCONVPMX:	MUL.WA	D4,(A6)+OFACX	MUL.WA	D4,(A6)+OMMX	LOAD.W	D3,#10000	JUMP'	DIVD4D3;--------\\; CONVPMY >;========/; Converti un nombre vertical en points --> en millimtres.; in	D4.W	nombre [p]; out	D4.W	nombre [mm]; mod	D3.W, D4.LCONVPMY:	MUL.WA	D4,(A6)+OFACY	MUL.WA	D4,(A6)+OMMY	LOAD.W	D3,#10000;	JUMP'	DIVD4D3;--------\\; DIVD4D3 >;--------/; Divise D4 par D3 avec un arrondi.; in	D4.L	nombre  diviser (+/-);	D3.W	diviseur (+); out	D4.L	reste/div; mod	D4.LDIVD4D3:	PUSH.W	D3	DIV.WA	D4,D3	JUMP',NS 40$	SR.W	D3,#1	SWAP.W	D4	COMP.W	D4,D3	JUMP',LE 20$	SWAP.W	D4	INC.W	D4		; D4 <-- arrondi (+1)	POP.W	D3	RET20$:	SWAP.W	D4	POP.W	D3	RET40$:	SR.W	D3,#1	SWAP.W	D4		; D4 <-- reste ngatif	NEG.W	D4		; D4 <-- reste positif	COMP.W	D4,D3	JUMP',LE 60$	SWAP.W	D4	DEC.W	D4		; D4 <-- arrondi (-1)	POP.W	D3	RET60$:	SWAP.W	D4	POP.W	D3	RET	.END