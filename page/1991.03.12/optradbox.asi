	.SBTTL	OPTRADBOX.ASI;--------\\; XopDGET >;========/; Donne le numro du pinceau slectionn.; in	A0.L	canal;	A4.L	^table des trames/nil si par dfaut; out	D3.W	trame slectionne;	D7.W	erreur; mod	D3.L, D7.WXopDGET:	PUSH.L	A4	COMP.L	A4,#0		; objet par dfaut ?	JUMP',NE NODEF$		; non => NODEF$	LOAD.L	A4,(A0)+OPDEF	; A4 <-- ^objet trame par dfautNODEF$:	LOAD.W	D3,(A4)+OTATSEL	; D3 <-- trame slectionne	POP.L	A4	CLR.W	D7		; retour EQ	RET;--------\\; XopDPUT >;========/; Spcifie le numro du pinceau.; in	A0.L	canal;	A4.L	^table des trames/nil si par dfaut;	D3.W	trame  slectionner; out	D7.W	erreur; mod	D7.WXopDPUT:	PUSH.L	A4	COMP.L	A4,#0		; objet par dfaut ?	JUMP',NE NODEF$		; non => NODEF$	LOAD.L	A4,(A0)+OPDEF	; A4 <-- ^objet trame par dfautNODEF$:	LOAD.W	(A4)+OTATSEL,D3	; slectionne une trame	POP.L	A4	CLR.W	D7		; retour EQ	RET;------------\\; XopDTSELECT >;============/; Choisi et/ou modifie une trame temporaire  utiliser.; in	A0.L	canal;	A4.L	^table des trames/nil si par dfaut;	D2.W	trame  slectionner; out	D2.W	trame slectionne;	D3.L	dernire touche (F1/F0);	D4.W	nb de trames modifies;	D7.W	erreur; mod	D2.L, D3.L, D4.L, D7.WXopDTSELECT:	PUSH.L	A4	COMP.L	A4,#0		; objet par dfaut ?	JUMP',NE NODEF$		; non => NODEF$	LOAD.L	A4,(A0)+OPDEF	; A4 <-- ^objet trame par dfautNODEF$:	PUSH.W	(A4)+OTATSEL	; stack <-- trame slectionne	LOAD.W	(A4)+OTATSEL,D2	; OTATSEL <-- trame slectionne temporairement	CALL	XopDSELECT	; choisi/modifie une trame ...	LOAD.W	D2,(A4)+OTATSEL	; D2 <-- trame slectionne temporairement	POP.W	(A4)+OTATSEL	; OTATSEL <-- trame slectionne initialement	POP.L	A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; XopDSELECT >;===========/; Choisi et/ou modifie une trame  utiliser.; in	A0.L	canal;	A4.L	^table des trames/nil si par dfaut; out	D3.L	dernire touche (F1/F0);	D4.W	nb de trames modifies;	D7.W	erreur; mod	D3.L, D4.L, D7.WXopDSELECT:	PUSHM.L	D0..D2,D5,D6,A0..A5	LOAD.L	A5,A0		; A5 <-- ^variables globales	LOAD.L	A0,(A5)+OPDDIS	; A0 <-- ^descripteur fentre	COMP.L	A4,#0		; objet par dfaut ?	JUMP',NE NODEF$		; non => NODEF$	LOAD.L	A4,(A5)+OPDEF	; A4 <-- ^objet trame par dfautNODEF$:	LOAD.L	(A5)+OPTAB,A4	; OPTAB <-- ^table des trames	LOAD.W	D6,(A4)+OTATSEL	; D6 <-- trame slectionne	LOAD.L	A2,#R16"TDBOX_TRA	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	LOAD.W	D7,#DB_OPEN	PAGE_	DBOX		; ouvre la DBOX	JUMP,NE EXIT$	LOAD.W	D3,#IDENTTRAME	LOAD.L	A4,#(A5)+OUSBUF	LOAD.W	D4,#NBRX*NBRY	LOAD.W	D7,#DF_GETULIST	PAGE_	DEF		; OUSBUF <-- trames utilises	CALL	DBPALGET	; cran <-- image mmorise	JUMP',EQ PALOK$	CALL	DBRDESCADRE	; dessine les cadres des rectangles	CLR.W	D0	LOAD.W	D1,#NBRX*NBRY	CALL	DBRDESTRAS	; dessine toutes les trames	CALL	DBPALSAV	; buffer <-- image cranPALOK$:	CLR.W	D0	LOAD.W	D1,#NBRX*NBRY	CALL	DBRUSETRAS	; marque les utilises	LOAD.W	D0,D6	CALL	DBRINV		; inverse le rectangle slectionn	CLR.W	D0		; D0 <-- nb de trames modifiesLOOP$:	LOAD.W	D7,#MI_SCMO	PAGE_	MISC		; remet la souris	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_TRA	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ USE$	COMP.W	D3,#F4	JUMP,EQ MODIF$	COMP.W	D3,#F7	JUMP,EQ PREND$	COMP.W	D3,#F9	JUMP,EQ SAUVE$	COMP.W	D3,#F0	JUMP,EQ END$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$CLIC$:	LOAD.W	D3,D6	CALL	DBRSEL		; slectionne un nouveau rectangle	JUMP,NE BIP$	COMP.W	D3,D6		; double-clic ?	JUMP,EQ USE$		; oui => USE$	JUMP	LOOP$MODIF$:	CALL	DBOXMODTRAME	; modifie une trame ...	PUSH.W	D7	LOAD.L	A2,#R16"TDBOX_TRA	LOAD.W	D7,#DB_RSK	PAGE_	DBOX		; refait les soft-keys	POP.W	D7	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	PUSH.W	D0	LOAD.W	D0,D6	LOAD.W	D1,#1	CALL	DBRINV		; teint le rectangle slectionn	CALL	DBRDESTRAS	; dessine la trame modifie	CALL	DBRUSETRAS	; marque l'utilise	CALL	DBPALUPD	; mj l'image cran si ncessaire	CALL	DBPALSAV	; buffer <-- image cran	CALL	DBRINV		; allume le rectangle slectionn	POP.W	D0	INC.W	D0		; D0 <-- une trame de plus modifie	JUMP	LOOP$PREND$:	CALL	TRAPREND	; prend les trames ...	PUSH.W	D7	LOAD.L	A2,#R16"TDBOX_TRA	LOAD.W	D7,#DB_RSK	PAGE_	DBOX		; refait les soft-keys	POP.W	D7	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	LOAD.W	D0,D6	CALL	DBRINV		; teint le rectangle slectionn	CLR.W	D0	LOAD.W	D1,#NBRX*NBRY	CALL	DBRDESTRAS	; dessine toutes les trames	CALL	DBRUSETRAS	; marque les utilises	CALL	DBPALSAV	; buffer <-- image cran	LOAD.W	D0,D6	CALL	DBRINV		; allume le rectangle slectionn	LOAD.W	D0,#NBRX*NBRY	; D0 <-- toutes les trames modifies	JUMP	LOOP$SAUVE$:	CALL	TRASAUVE	; sauve les trames ...	PUSH.W	D7	LOAD.L	A2,#R16"TDBOX_TRA	LOAD.W	D7,#DB_RSK	PAGE_	DBOX		; refait les soft-keys	POP.W	D7	JUMP,NE BIP$	JUMP	LOOP$USE$:	LOAD.L	A4,(A5)+OPTAB	; A4 <-- ^table des trames	LOAD.W	(A4)+OTATSEL,D6	; mj. la trame slectionne	LOAD.W	D3,#F1END$:	LOAD.W	D4,D0		; D4 <-- nb de trames modifies	JUMP',EQ NOREG$	INC.L	(A5)+OREGEN	; change le numro de rgnrationNOREG$:	LOAD.W	D7,#DB_CLOSE	PAGE_	DBOX		; ferme la DBOXEXIT$:	POPM.L	D0..D2,D5,D6,A0..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX_TRA:	.W	10$-TDBOX_TRA	.W	20$-TDBOX_TRA	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Choix de la trame :"	.B	ODBCR,ODBCR2	.B	ODBLABEL,100	.B	ODBTEXT,0	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBTABX,60	.B	ODBLABEL,101	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" UTILISE "	.B	ODBBOX,0,F4,TDBMEV	.ASCIZ	" MODIFIE "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F7,TDBNORM	.ASCIZ	" PREND "	.B	ODBBOX,0,F9,TDBNORM	.ASCIZ	" SAUVE "	.B	ODBTABX,60-10	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Utilise"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Modifie"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Prend       Sauve"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_TRA:	.W	F1,F2,F3,0		DOKF1-TKEY_TRA	.W	F4,F5,F6,0		DOKF4-TKEY_TRA	.W	F7,0			DOKF7-TKEY_TRA	.W	F9,0			DOKF9-TKEY_TRA	.W	F0,F13,F14,F15,0	DOKF0-TKEY_TRA	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_TRA	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_TRA	.W	0;-------------\\; DBOXMODTRAME >;=============/; Modifie une trame.; in	D6.W	trame  modifier;	D0.W	nb de trames modifies; out	D0.W	nb de trames modifies;	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D0.L, D3.L, D7.WDBOXMODTRAME:	PUSHM.L	D1,D2,D4..D6,A1..A4	MUL.WU	D6,#LDTRA	LOAD.L	A4,(A5)+OPTAB	; A4 <-- ^table des trames	ADD.L	A4,D6	LOAD.W	(A5)+ODBTGP,(A4)+OTRAGP	LOAD.W	(A5)+ODBTDI,(A4)+OTRADI	LOAD.W	(A5)+ODBTI1,(A4)+OTRAI1	LOAD.W	(A5)+ODBTD1,(A4)+OTRAD1	LOAD.W	(A5)+ODBTE1,(A4)+OTRAE1	LOAD.W	(A5)+ODBTE2,(A4)+OTRAE2	LOAD.W	(A5)+ODBTCC,(A4)+OTRACC	LOAD.W	(A5)+ODBTCF,(A4)+OTRACF	LOAD.L	D4,(A4)+OTRAFA	; D4 <-- fanions	JUMP',NE DEF$	LOAD.L	D4,#2^BTRAGR!2^BTRAPC!2^BTRADHDEF$:	LOAD.L	A2,#R16"TDBOX$	LOAD.W	D7,#DB_MEMPT	PAGE_	DBOX		; mj ^table dbox	LOAD.L	A2,#R16"DBMTTESTC	LOAD.W	D7,#DB_MEMAFC	PAGE_	DBOX		; mj ^routine d'affichage	LOAD.L	A2,#R16"TDBOX_MODTRA	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.W	D7,#DB_OPEN	PAGE_	DBOX		; ouvre la DBOX	JUMP,NE EXIT$	LOAD.W	D2,#2^BDBGCLABEL!201	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	LOAD.W	D2,#2^BDBGCLABEL!200	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	PUSH.L	D4	LOAD.L	D4,D3	CLR.W	D4	LOAD.W	D3,(A0)+ODFCX	MUL.WU	D3,#15	LOAD.W	D2,#SETDOT	LIB	?DRSEG	POP.L	D4	CLR.W	D2AFF$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_AFF	PAGE_	DBOX		; affiche le paramtre	INC.W	D2	COMP.W	D2,#6	JUMP,LO AFF$	CALL	DBMTTT		; mj dbox selon type de trameXLINE$:	CLR.W	D2	TEST.L	D4:#BTRAGR	JUMP',BS NLINE$	LOAD.W	D2,#2NLINE$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_MEDIT	PAGE_	DBOXTEST$:	CALL	DBMTTEST	; affiche la trame obtenueLOOP$:	LOAD.W	D7,#MI_SCMO	PAGE_	MISC		; remet la souris	DBOX_	EDIT		; attend une action ...	LOAD.W	D7,#DB_ZEROCR	PAGE_	DBOX		; remplace <CR> par <0>	LOAD.L	A1,#R16"TKEY_MODTRA	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#F7	JUMP,EQ COLORC$	COMP.W	D3,#F8	JUMP,EQ COLORF$	COMP.W	D3,#UNDO	JUMP,EQ UNDO$	COMP.W	D3,#CLEAR	JUMP,EQ UNDO$	COMP.W	D3,#CR	JUMP,EQ RETURN$	COMP.W	D3,#ENTER	JUMP,EQ ENTER$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	INC.W	D2		; D2 <-- paramtre suivant	LOAD.L	A3,(A5)+ODBTPT	ADD.W	A3,D2	ADD.W	A3,D2RETURN2$:	LOAD.W	D1,(A3+)	COMP.B	D1,#100	JUMP,LO XLINE$	TEST.L	D1:#BDBGCGREY	JUMP,BC NLINE$	INC.W	D2		; D2 <-- paramtre suivant	JUMP	RETURN2$CLIC$:	LOAD.L	(A5)+ODBTFA,D4	LOAD.W	D7,#DB_CLIC	PAGE_	DBOX	JUMP,EQ LOOP$	JUMP	TEST$ENTER$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	JUMP	TEST$KEYDBOX$:			; KEYDBOX =>	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	COMP.B	D3,#100	JUMP,HS CLINE$	COMP.B	D3,#BTRAQC	JUMP,EQ TEST$	COMP.B	D3,#BTRATR	JUMP,EQ TEST$	COMP.B	D3,#BTRAD2	JUMP',EQ SET2$	LOAD.L	D1,#H'FFFFFF00	COMP.B	D3,#8	JUMP',LO SET$	RL.L	D1,#8	COMP.B	D3,#16	JUMP',LO SET$	RL.L	D1,#8	COMP.B	D3,#24	JUMP',LO SET$	RL.L	D1,#8SET$:	TSET.L	D1:#BTRAQC	TSET.L	D1:#BTRAD2	AND.L	D4,D1	TSET.L	D4:D3SET2$:	CALL	DBMTTT		; mj dbox selon type de trame	JUMP	XLINE$CLINE$:	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$COLORC$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	LOAD.W	D3,(A5)+ODBTCC	CALL	DBMTMCOL	; choix de la couleur de chair ...	JUMP,NE NLINE$	LOAD.W	(A5)+ODBTCC,D3	JUMP	NLINE$COLORF$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	LOAD.W	D3,(A5)+ODBTCF	CALL	DBMTMCOL	; choix de la couleur de fond ...	JUMP,NE NLINE$	LOAD.W	(A5)+ODBTCF,D3	JUMP	NLINE$OK$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	LOAD.L	A4,(A5)+OPTAB	; A4 <-- ^table des trames	ADD.L	A4,D6	CALL	DBMTPUT		; OTRAxx <-- ODBTxxEND$:	LOAD.W	D7,#DB_CLOSE	PAGE_	DBOX		; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4..D6,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	ODBTGP,DBTYPN,0,100,3,2^BDBGCLABEL!100,0,3+2	.W	ODBTDI,DBTYPU,0,200*FACMMPT,02*FACMMPT,2^BDBGCLABEL!101,1,7+2	.W	ODBTI1,DBTYPN,0,180,5,2^BDBGCLABEL!102,2,3+2	.W	ODBTD1,DBTYPU,0,200*FACMMPT,10*FACMMPT,2^BDBGCLABEL!103,3,7+2	.W	ODBTE1,DBTYPU,0,200*FACMMPT,02*FACMMPT,2^BDBGCLABEL!104,4,7+2	.W	ODBTE2,DBTYPU,0,200*FACMMPT,02*FACMMPT,2^BDBGCLABEL!105,5,7+2	.W	-1;---------\\; DBMTMCOL >;---------/; Choix d'une couleur dans le mmenu.; in	D3.W	couleur actuelle (0..n);	D0.W	nb de trames modifies; out	D3.W	nouvelle couleur (0..n);	D0.W	nb de trames modifies;	D7.W	erreur; mod	D0.L, D3.L, D7.WDBMTMCOL:	PUSHM.L	D1,D2,D4..D6,A2..A4	LOAD.W	D6,D3	LOAD.W	D5,D0	LOAD.L	D4,#(40+1)*(16+3)	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour construire le mmenu	JUMP,NE EXIT$	LOAD.L	A2,A4	LOAD.L	A3,A2	LOAD.B	(A3+),#SPACE	; met une case vide au dbut	CLR.B	(A3+)	LOAD.B	(A3+),#-1	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D0,#IDENTCOLOR	LOAD.W	D1,#opDGETMENU	PAGE_	OBJCALL		; A3/D3/D4 <-- ^plus loin/cases grises/nb cases	LOAD.W	D2,D4		; au moins une case ?	JUMP',EQ DBOX$		; non => DBOX$	DEC.L	A3	LOAD.L	A4,#R16"TXAUT$XFER$:	LOAD.B	(A3+),(A4+)	; mmenu <-- case "autre.."	JUMP,NE XFER$	CLR.B	(A3)		; mmenu <-- terminateur	LOAD.L	D4,D3		; D4 <-- cases grises	SL.L	D4,#1		; D4 <-- saute la case vide tout en haut	LOAD.W	D3,D6		; D3 <-- couleur actuelle	INC.W	D3		; D3 <-- saute la case vide tout en haut	TSET.L	D3:#15		; D3 <-- cases grises dans D4.L !	LOAD.L	A3,A2	LIB	?MMENU		; choix de la couleur de chair ...	JUMP',NE GIVMEM$	DEC.W	D3		; D3 <-- ignore la case vide tout en haut	JUMP',NS GIVMEM$	COMP.W	D3,D2		; dans la case "autre.." ?	JUMP',EQ DBOX$		; oui => DBOX$	LOAD.W	D6,D3	INC.W	D5		; D5 <-- une trame modifie	JUMP'	GIVMEM$DBOX$:	LOAD.W	D2,D6		; D2 <-- couleur actuelle	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D0,#IDENTCOLOR	LOAD.W	D1,#opDTSELECT	PAGE_	OBJCALL		; choix d'une couleur ...	JUMP',NE GIVMEM$	ADD.W	D5,D4		; D5 <-- nb de trames modifies	COMP.W	D3,#F1	JUMP',NE GIVMEM$	LOAD.W	D6,D2		; D6 <-- nouvelle couleurGIVMEM$:	PUSH.W	D7	LOAD.L	A4,A2	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; libre la mmoire	POP.W	D7EXIT$:	LOAD.W	D3,D6		; D3 <-- nouvelle couleur	LOAD.W	D0,D5		; D0 <-- nb de trames modifies	POPM.L	D1,D2,D4..D6,A2..A4	TEST.W	D7		; retour EQ/NE	RETTXAUT$:	.ASCIZE	"<-1> autre.. ";-------\\; DBMTTT >;-------/; Met  jour la dbox selon le type de trame.; in	D4.L	fanions; out	-; mod	D7.WDBMTTT:	PUSHM.L	D1..D4,A2..A4	LOAD.L	D1,D4		; D1 <-- fanions	TEST.L	D1:#BTRAHA	JUMP',BS 15$	LOAD.L	A2,#R16"TABLE1$	TEST.L	D1:#BTRAPC	JUMP',BS 20$	LOAD.L	A2,#R16"TABLE2$	JUMP'	20$15$:	LOAD.L	A2,#R16"TABLE3$	TEST.L	D1:#BTRAD2	JUMP',BC 20$	LOAD.L	A2,#R16"TABLE4$20$:	LOAD.L	(A5)+ODBTPT,A2	LOAD.L	A3,A222$:	LOAD.W	D2,(A3+)	JUMP',EQ 30$	DBOX_	GETCO		; grise/dgrise un objet	JUMP	22$30$:	LOAD.W	D2,(A2+)	JUMP',EQ 40$	SUB.B	D2,#100	JUMP,LO 30$	TEST.L	D2:#BDBGCGREY	JUMP,BS 30$	AND.W	D2,#H'00FF	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_AFF	PAGE_	DBOX		; affiche le paramtre	JUMP	30$40$:	POPM.L	D1..D4,A2..A4	RETTABLE1$:	.W	2^BDBGCLABEL!2^BDBGCFULL!100	.W	2^BDBGCLABEL!2^BDBGCGREY!101	.W	2^BDBGCLABEL!2^BDBGCGREY!102	.W	2^BDBGCLABEL!2^BDBGCGREY!103	.W	2^BDBGCLABEL!2^BDBGCGREY!104	.W	2^BDBGCLABEL!2^BDBGCGREY!105	.W	2^BDBGCLABEL!2^BDBGCFULL!40;;?	.W	2^BDBGCLABEL!2^BDBGCFULL!41;;?	.W	2^BDBGCLABEL!2^BDBGCFULL!42	.W	2^BDBGCLABEL!2^BDBGCFULL!43	.W	2^BDBGCLABEL!2^BDBGCFULL!44	.W	2^BDBGCLABEL!2^BDBGCFULL!45	.W	2^BDBGCLABEL!2^BDBGCFULL!46	.W	2^BDBGCLABEL!2^BDBGCFULL!47	.W	2^BDBGCLABEL!2^BDBGCGREY!48	.W	2^BDBGCLABEL!2^BDBGCGREY!49	.W	2^BDBGCLABEL!2^BDBGCGREY!60	.W	2^BDBGCLABEL!2^BDBGCGREY!61	.W	2^BDBGCLABEL!2^BDBGCGREY!62	.W	2^BDBGCLABEL!2^BDBGCGREY!63	.W	2^BDBGCLABEL!2^BDBGCGREY!64	.W	2^BDBGCLABEL!2^BDBGCGREY!65	.W	2^BDBGCLABEL!2^BDBGCGREY!66	.W	2^BDBGCLABEL!2^BDBGCGREY!67	.W	2^BDBGCLABEL!2^BDBGCGREY!68	.W	0TABLE2$:	.W	2^BDBGCLABEL!2^BDBGCFULL!100	.W	2^BDBGCLABEL!2^BDBGCFULL!101	.W	2^BDBGCLABEL!2^BDBGCGREY!102	.W	2^BDBGCLABEL!2^BDBGCGREY!103	.W	2^BDBGCLABEL!2^BDBGCGREY!104	.W	2^BDBGCLABEL!2^BDBGCGREY!105	.W	2^BDBGCLABEL!2^BDBGCFULL!40;;?	.W	2^BDBGCLABEL!2^BDBGCFULL!41;;?	.W	2^BDBGCLABEL!2^BDBGCFULL!42	.W	2^BDBGCLABEL!2^BDBGCFULL!43	.W	2^BDBGCLABEL!2^BDBGCGREY!44	.W	2^BDBGCLABEL!2^BDBGCGREY!45	.W	2^BDBGCLABEL!2^BDBGCFULL!46	.W	2^BDBGCLABEL!2^BDBGCFULL!47	.W	2^BDBGCLABEL!2^BDBGCFULL!48	.W	2^BDBGCLABEL!2^BDBGCFULL!49	.W	2^BDBGCLABEL!2^BDBGCGREY!60	.W	2^BDBGCLABEL!2^BDBGCGREY!61	.W	2^BDBGCLABEL!2^BDBGCGREY!62	.W	2^BDBGCLABEL!2^BDBGCGREY!63	.W	2^BDBGCLABEL!2^BDBGCGREY!64	.W	2^BDBGCLABEL!2^BDBGCGREY!65	.W	2^BDBGCLABEL!2^BDBGCGREY!66	.W	2^BDBGCLABEL!2^BDBGCGREY!67	.W	2^BDBGCLABEL!2^BDBGCGREY!68	.W	0TABLE3$:	.W	2^BDBGCLABEL!2^BDBGCGREY!100	.W	2^BDBGCLABEL!2^BDBGCGREY!101	.W	2^BDBGCLABEL!2^BDBGCFULL!102	.W	2^BDBGCLABEL!2^BDBGCFULL!103	.W	2^BDBGCLABEL!2^BDBGCFULL!104	.W	2^BDBGCLABEL!2^BDBGCGREY!105	.W	2^BDBGCLABEL!2^BDBGCGREY!40;;?	.W	2^BDBGCLABEL!2^BDBGCGREY!41;;?	.W	2^BDBGCLABEL!2^BDBGCGREY!42	.W	2^BDBGCLABEL!2^BDBGCGREY!43	.W	2^BDBGCLABEL!2^BDBGCGREY!44	.W	2^BDBGCLABEL!2^BDBGCGREY!45	.W	2^BDBGCLABEL!2^BDBGCGREY!46	.W	2^BDBGCLABEL!2^BDBGCGREY!47	.W	2^BDBGCLABEL!2^BDBGCGREY!48	.W	2^BDBGCLABEL!2^BDBGCGREY!49	.W	2^BDBGCLABEL!2^BDBGCFULL!60	.W	2^BDBGCLABEL!2^BDBGCFULL!61	.W	2^BDBGCLABEL!2^BDBGCFULL!62	.W	2^BDBGCLABEL!2^BDBGCFULL!63	.W	2^BDBGCLABEL!2^BDBGCGREY!64	.W	2^BDBGCLABEL!2^BDBGCGREY!65	.W	2^BDBGCLABEL!2^BDBGCGREY!66	.W	2^BDBGCLABEL!2^BDBGCGREY!67	.W	2^BDBGCLABEL!2^BDBGCGREY!68	.W	0TABLE4$:	.W	2^BDBGCLABEL!2^BDBGCGREY!100	.W	2^BDBGCLABEL!2^BDBGCGREY!101	.W	2^BDBGCLABEL!2^BDBGCFULL!102	.W	2^BDBGCLABEL!2^BDBGCFULL!103	.W	2^BDBGCLABEL!2^BDBGCFULL!104	.W	2^BDBGCLABEL!2^BDBGCFULL!105	.W	2^BDBGCLABEL!2^BDBGCGREY!40;;?	.W	2^BDBGCLABEL!2^BDBGCGREY!41;;?	.W	2^BDBGCLABEL!2^BDBGCGREY!42	.W	2^BDBGCLABEL!2^BDBGCGREY!43	.W	2^BDBGCLABEL!2^BDBGCGREY!44	.W	2^BDBGCLABEL!2^BDBGCGREY!45	.W	2^BDBGCLABEL!2^BDBGCGREY!46	.W	2^BDBGCLABEL!2^BDBGCGREY!47	.W	2^BDBGCLABEL!2^BDBGCGREY!48	.W	2^BDBGCLABEL!2^BDBGCGREY!49	.W	2^BDBGCLABEL!2^BDBGCFULL!60	.W	2^BDBGCLABEL!2^BDBGCFULL!61	.W	2^BDBGCLABEL!2^BDBGCFULL!62	.W	2^BDBGCLABEL!2^BDBGCFULL!63	.W	2^BDBGCLABEL!2^BDBGCFULL!64	.W	2^BDBGCLABEL!2^BDBGCFULL!65	.W	2^BDBGCLABEL!2^BDBGCFULL!66	.W	2^BDBGCLABEL!2^BDBGCFULL!67	.W	2^BDBGCLABEL!2^BDBGCFULL!68	.W	0;----------\\; DBMTTESTC >;----------/; Affiche une petite trame de test pendant le DB_CLIC.; in	D2.W	mode (CLRDOT/SETDOT); out	-; mod	D7.WDBMTTESTC:	PUSH.L	D4	COMP.W	D2,#SETDOT	JUMP',NE EXIT$	LOAD.L	D4,(A5)+ODBTFA	CALL	DBMTTESTEXIT$:	POP.L	D4	RET;---------\\; DBMTTEST >;---------/; Affiche une petite trame de test.; in	D4.L	fanions; out	-; mod	D7.WDBMTTEST:	PUSHM.L	D1..D4,A4	LOAD.L	A4,#(A5)+OTTRA	; A4 <-- ^trame bidon	CALL	DBMTPUT		; OTRAxx <-- ODBTxx	LOAD.W	D4,#1	LOAD.W	D7,#DR_CHGSCALE	PAGE_	DRAW		; met l'chelle 100%	PUSH.W	D4	LOAD.W	D2,#2^BDBGCLABEL!31	DBOX_	GETCO	SWAP.W	D3	ADD.W	D3,#4	SWAP.W	D3	PUSH.L	D3	LOAD.W	D2,#2^BDBGCLABEL!30	DBOX_	GETCO	POP.L	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; dessine le pourtour	LIB	?AFTIM	.B	COLOROP,COLOROPPUSH,0	.EVEN	PUSHM.L	D3,A0	LOAD.W	D2,#SETDOT	; D2 <-- mode	LOAD.W	D3,#2^15	; D3 <-- numro de la trame bidon + pas d'offset;	LOAD.L	A4,#(A5)+OTTRA	; A4 <-- ^trame bidon	LOAD.L	A0,A5		; A0 <-- canal	CALL	XopDUSE		; utilise la trame bidon	POPM.L	D3,A0	LOAD.W	D1,D2		; D1 <-- SETDOT/LOADDOT/zro	LOAD.W	D2,#LOADDOT	; D2 <-- mode	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LIB	?DRTRAME	; dessine la trame	PUSH.L	D4	CLR.L	D4	CALL	DRMDEF	POP.L	D4	COMP.W	D1,D2		; trame opaque ?	JUMP',EQ EXIT$		; oui => EXIT$	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	LOAD.W	D4,#20	LOAD.W	D2,#SETDOT	CALL	DESETOILE	; dessine l'toile "transparent"EXIT$:	LIB	?AFTIM	.B	COLOROP,COLOROPPOP,0	.EVEN	POP.W	D4	LOAD.W	D7,#DR_PUTSCALE	PAGE_	DRAW		; remet l'chelle courante	POPM.L	D1..D4,A4	RET;--------\\; DBMTPUT >;--------/; Met  jour les paramtres d'une trame.; in	A4.L	^trame;	D4.L	fanions; out	-; mod	D7.WDBMTPUT:	PUSH.L	D3	LOAD.W	D3,(A5)+ODBTGP	COMP.W	D3,#100	JUMP',LS 20$	LOAD.W	D3,#10020$:	LOAD.W	(A4)+OTRAGP,D3	LOAD.W	D3,(A5)+ODBTDI	JUMP',NE 30$	INC.W	D330$:	LOAD.W	(A4)+OTRADI,D3	LOAD.W	D3,(A5)+ODBTI1	COMP.W	D3,#180	JUMP',LS 40$	LOAD.W	D3,#18040$:	LOAD.W	(A4)+OTRAI1,D3	LOAD.W	D3,(A5)+ODBTD1	JUMP',NE 50$	INC.W	D350$:	LOAD.W	(A4)+OTRAD1,D3	LOAD.W	D3,(A5)+ODBTE1	COMP.W	D3,(A4)+OTRAD1	JUMP',LS 60$	LOAD.W	D3,(A4)+OTRAD160$:	LOAD.W	(A4)+OTRAE1,D3	LOAD.W	D3,(A5)+ODBTE2	COMP.W	D3,(A4)+OTRAD1	JUMP',LS 70$	LOAD.W	D3,(A4)+OTRAD170$:	LOAD.W	(A4)+OTRAE2,D3	LOAD.W	(A4)+OTRACC,(A5)+ODBTCC	LOAD.W	(A4)+OTRACF,(A5)+ODBTCF	LOAD.L	(A4)+OTRAFA,D4	POP.L	D3	RETTDBOX_MODTRA:	.W	10$-TDBOX_MODTRA	.W	20$-TDBOX_MODTRA	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"   Trame :"	.B	ODBTABX,17	.B	ODBLABEL,40	.B	ODBLCIRCLE,BTRAPC!2^6!2^7,KEYDBOX/H'100,BTRAPC	.ASCIZ	" gris"	.B	ODBTABX,17+24	.B	ODBLABEL,100	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBLABEL,43	.B	ODBTEXT	.ASCIZ	"%"	.B	ODBCR	.B	ODBTABX,17	.B	ODBLABEL,46	.B	ODBLCIRCLE,BTRAGC!2^6!2^7,KEYDBOX/H'100,BTRAGC	.ASCIZ	" points carrs"	.B	ODBCR2	.B	ODBLCIRCLE,BTRAGR!2^6!2^7,KEYDBOX/H'100,BTRAGR	.ASCIZ	" points"	.B	ODBCR2	.B	ODBTABX,17	.B	ODBLABEL,47	.B	ODBLCIRCLE,BTRAGO!2^6!2^7,KEYDBOX/H'100,BTRAGO	.ASCIZ	" points ronds"	.B	ODBTABX,17+18	.B	ODBLABEL,48	.B	ODBTEXT	.ASCIZ	"grain "	.B	ODBLABEL,101	.B	ODBCLINE,(7+2)!2^7,KEYDBOX/H'100,101,TDBNORM	.B	ODBCR2	.B	ODBLCIRCLE,BTRAHA!2^6!2^7,KEYDBOX/H'100,BTRAHA	.ASCIZ	" lignes"	.B	ODBCR2	.B	ODBTABX,17	.B	ODBLABEL,49	.B	ODBSQUARE,BTRAQC!2^7,KEYDBOX/H'100,BTRAQC	.ASCIZ	" quinconce"	.B	ODBCR	.B	ODBLABEL,200	.B	ODBTEXT,0	.B	ODBCR,ODBCR2	.B	ODBLABEL,60	.B	ODBTEXT	.ASCIZ	"Inclinaison"	.B	ODBLABEL,102	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,102,TDBNORM	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBLABEL,61	.B	ODBTEXT	.ASCIZ	"Distance"	.B	ODBLABEL,103	.B	ODBCLINE,(7+2)!2^7,KEYDBOX/H'100,103,TDBNORM	.B	ODBTABX,43	.B	ODBLABEL,62	.B	ODBTEXT	.ASCIZ	"Epaisseur"	.B	ODBLABEL,104	.B	ODBCLINE,(7+2)!2^7,KEYDBOX/H'100,104,TDBNORM	.B	ODBTEXT	.ASCIZ	" "	.B	ODBCR,ODBCR	.B	ODBLABEL,63	.B	ODBSQUARE,BTRAD2!2^7,KEYDBOX/H'100,BTRAD2	.ASCIZ	" 2me ligne"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBLABEL,64	.B	ODBLCIRCLE,BTRADH!2^6!2^7,KEYDBOX/H'100,BTRADH	.ASCIZ	" -"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBLABEL,65	.B	ODBLCIRCLE,BTRADO!2^6!2^7,KEYDBOX/H'100,BTRADO	.ASCIZ	" \"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBLABEL,66	.B	ODBLCIRCLE,BTRADV!2^6!2^7,KEYDBOX/H'100,BTRADV	.ASCIZ	" |"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBLABEL,67	.B	ODBLCIRCLE,BTRADI!2^6!2^7,KEYDBOX/H'100,BTRADI	.ASCIZ	" /"	.B	ODBTABX,43	.B	ODBLABEL,68	.B	ODBTEXT	.ASCIZ	"Epaisseur"	.B	ODBLABEL,105	.B	ODBCLINE,(7+2)!2^7,KEYDBOX/H'100,105,TDBNORM	.B	ODBCR	.B	ODBLABEL,201	.B	ODBTEXT,0	.B	ODBCR	.B	ODBSQUARE,BTRATR!2^7,KEYDBOX/H'100,BTRATR	.ASCIZ	" transparent"	.B	ODBTABX,31	.B	ODBLABEL,30	.B	ODBTEXT,0	.B	ODBCR,ODBCR2	.B	ODBTABX,7	.B	ODBTEXT	.ASCIZ	"Couleur"	.B	ODBTABX,15	.B	ODBBOX,0,F7,TDBOMBRE	.ASCIZ	"CHAIR"	.B	ODBTABX,21	.B	ODBBOX,0,F8,TDBOMBRE	.ASCIZ	"FOND"	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	ODBTABX,31+32	.B	ODBLABEL,31	.B	ODBTEXT,0	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_MODTRA:	.W	F1,F2,F3,0		DOKF1-TKEY_MODTRA	.W	F0,F13,F14,F15,0	DOKF0-TKEY_MODTRA	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_MODTRA	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_MODTRA	.W	0;---------\\; DBPALSAV >;---------/; Sauve l'image cran de la palette.; in	-; out	D7.W	erreur; mod	D7.WDBPALSAV:	PUSHM.L	D0..D6,A3,A4	LOAD.W	D1,#opDGETREGEN	LOAD.W	D0,#IDENTCOLOR	PAGE_	OBJCALL		; D4 <-- numro de rgnration des couleurs	LOAD.L	(A5)+ODBRRC,D4	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP,NE OK$		; oui => OK	TEST.L	(A5)+ODBRPB	JUMP',NE BUFOK$	LOAD.W	D4,(A5)+ODBRLX	MUL.WU	D4,#NBRX	INC.W	D4	LOAD.W	(A5)+ODBRPD+2,D4	LOAD.W	D4,(A5)+ODBRLY	MUL.WU	D4,#NBRY	INC.W	D4	LOAD.W	(A5)+ODBRPD+0,D4	LOAD.W	D4,(A5)+ODBRPD+2	ADD.W	D4,#16-1	SR.W	D4,#4	SL.W	D4,#1	MUL.WU	D4,(A5)+ODBRPD+0	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour image cran	JUMP',NE EXIT$	LOAD.L	(A5)+ODBRPB,A4BUFOK$:	LOAD.W	D7,#MI_CCMO	PAGE_	MISC		; enlve la souris	LOAD.L	D3,(A5)+ODBRPY	LOAD.L	A3,#0	CLR.L	D4	LOAD.L	A4,(A5)+ODBRPB	LOAD.W	D6,(A5)+ODBRPD+2	ADD.W	D6,#16-1	SR.W	D6,#4	SL.W	D6,#1	LOAD.L	D2,(A5)+ODBRPD	LOAD.W	D1,#LOADDOT	LOAD.L	A2,A0	GRA_	RASTER		; buffer <-- image cranOK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBPALUPD >;---------/; Met  jour l'image cran de la palette, si ncessaire.; in	-; out	-; mod	D7.WDBPALUPD:	PUSHM.L	D0,D1,D4	LOAD.W	D1,#opDGETREGEN	LOAD.W	D0,#IDENTCOLOR	PAGE_	OBJCALL		; D4 <-- numro de rgnration des couleurs	COMP.L	D4,(A5)+ODBRRC	JUMP',EQ EXIT$UPDATE$:	CLR.W	D0	LOAD.W	D1,#NBRX*NBRY	CALL	DBRDESTRAS	; redessine toutes les trames	CALL	DBRUSETRAS	; marque les utilisesEXIT$:	POPM.L	D0,D1,D4	RET;---------\\; DBPALGET >;---------/; Restitue l'image cran de la palette.; in	-; out	D7.W	erreur; mod	D7.WDBPALGET:	PUSHM.L	D0..D6,A3,A4	TEST.L	(A5)+ODBRPB	JUMP',EQ ERROR$	LOAD.W	D1,#opDGETREGEN	LOAD.W	D0,#IDENTCOLOR	PAGE_	OBJCALL		; D4 <-- numro de rgnration des couleurs	COMP.L	D4,(A5)+ODBRRC	JUMP',NE ERROR$	LOAD.W	D7,#MI_CCMO	PAGE_	MISC		; enlve la souris	CLR.L	D3	LOAD.L	A3,(A5)+ODBRPB	LOAD.W	D5,(A5)+ODBRPD+2	ADD.W	D5,#16-1	SR.W	D5,#4	SL.W	D5,#1	LOAD.L	D4,(A5)+ODBRPY	LOAD.L	A4,#0	LOAD.L	D2,(A5)+ODBRPD+0	LOAD.W	D1,#LOADDOT	LOAD.L	A2,A0	GRA_	RASTER		; cran <-- image mmorise	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$ERROR$:	LOAD.W	D7,#1EXIT$:	POPM.L	D0..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-------\\; DBRSEL >;-------/; Slectionne un nouveau rectangle.; in	D6.W	rectangle slectionn (0..n); out	D6.W	nouveau rectangle (0..n);	D7.W	erreur; mod	D6.L, D7.WDBRSEL:	PUSHM.L	D0,D3,D4	CALL	DBRDET		; est-on dans un rectangle ?	JUMP',NE 90$		; non => 90$	EX.L	D0,D6	CALL	DBRINV		; efface l'ancien	LOAD.W	D0,D6	CALL	DBRINV		; allume le nouveau20$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris bouge ?	JUMP',NE 80$		; non => 80$	CALL	DBRDET		; D0 <-- rectangle o est la souris	JUMP,NE 20$	COMP.W	D0,D6		; toujours dans le mme ?	JUMP,EQ 20$		; oui => 20$				; non =>	EX.L	D0,D6	CALL	DBRINV		; efface l'ancien	LOAD.W	D0,D6	CALL	DBRINV		; allume le nouveau	JUMP	20$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,D3,D4	TEST.W	D7		; retour EQ/NE	RET;-------\\; DBRDET >;-------/; Dtecte dans quel rectangle est la souris.; in	-; out	D0.W	rectangle (0..n);	D7.W	erreur; mod	D0.L, D7.WDBRDET:	PUSHM.L	D1..D4	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP',NE 90$	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la matrice	SUB.W	D4,(A0)+ODFFX	; D4 <-- pos relative dans swdo	JUMP',LO 90$	SUB.W	D4,(A5)+ODBRPX	; D4 <-- pos relative dans rectangle	JUMP',LO 90$	CLR.L	D0	LOAD.W	D0,D4	DIV.WU	D0,(A5)+ODBRLX	; D0 <-- coordonne X	COMP.W	D0,#NBRX	JUMP',HS 90$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	; D4 <-- pos relative dans swdo	JUMP',LO 90$	SUB.W	D4,(A5)+ODBRPY	; D4 <-- pos relative dans rectangle	JUMP',LO 90$	CLR.L	D1	LOAD.W	D1,D4	DIV.WU	D1,(A5)+ODBRLY	; D1 <-- coordonne Y	COMP.W	D1,#NBRY	JUMP',HS 90$	MUL.WU	D1,#NBRX	ADD.W	D0,D1		; D0 <-- no du rectangle	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RET;-------\\; DBRINV >;-------/; Inverse un rectangle.; in	D0.W	no du rectangle (0..n); out	-; mod	D7.WDBRINV:	PUSHM.L	D2..D4	LOAD.L	D4,#-1	CALL	DRMDEF	LOAD.W	D2,#INVDOT	CALL	DBRPOS	JUMP',NE 90$	PUSHM.L	D3,D4	ADD.W	D3,#2	SWAP.W	D3	ADD.W	D3,#2	SWAP.W	D3	SUB.W	D4,#3	SWAP.W	D4	SUB.W	D4,#3	SWAP.W	D4	LIB	?DRTRAME	; inverse un rectangle	POPM.L	D3,D4	ADD.W	D3,#6	SWAP.W	D3	ADD.W	D3,#6	SWAP.W	D3	SUB.W	D4,#(6*2)-1	SWAP.W	D4	SUB.W	D4,#(6*2)-1	SWAP.W	D4	LIB	?DRTRAME	; inverse l'emplacement90$:	POPM.L	D2..D4	RET;-----------\\; DBRUSETRAS >;-----------/; Dessine une ou plusieurs utilisations.; in	D0.W	premire trame;	D1.W	nombre de trames; out	-; mod	D7.WDBRUSETRAS:	PUSHM.L	D0..D4,A3,A4	LOAD.L	A3,#(A5)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWMATRIXLOOP$:	CALL	DBRPOS		; D3/D4 <-- pos/dim	JUMP',NE EXIT$	INC.W	D3	SWAP.W	D3	INC.W	D3	LOAD.L	(A3)+1,D3	LOAD.L	A4,#R16"MACLR$	LOAD.L	(A3)+5,A4	LOAD.B	(A3)+9,#CLRDOT!PENDOT	LOAD.W	D3,#10	LIB	?STRING	LOAD.L	A4,#(A5)+OUSBUF	TEST.B	(A4)+(D0.W)	; trame utilise ?	JUMP',EQ NEXT$		; non => NEXT$	LOAD.L	A4,#R16"MASET$	LOAD.L	(A3)+5,A4	LOAD.B	(A3)+9,#SETDOT!PENDOT	LOAD.W	D3,#10	LIB	?STRINGNEXT$:	INC.W	D0	DEC.W	D1	JUMP,NE LOOP$EXIT$:	POPM.L	D0..D4,A3,A4	RETMACLR$:	.B	8,8	.B	B'11111111	.B	B'11111111	.B	B'11111110	.B	B'11111100	.B	B'11111000	.B	B'11110000	.B	B'11100000	.B	B'11000000MASET$:	.B	8,8	.B	B'00000000	.B	B'01111110	.B	B'01111100	.B	B'01111000	.B	B'01110000	.B	B'01100000	.B	B'01000000	.B	B'00000000	.EVEN;-----------\\; DBRDESTRAS >;-----------/; Dessine une ou plusieurs trames.; in	D0.W	premire trame;	D1.W	nombre de trames; out	-; mod	D7.WDBRDESTRAS:	PUSHM.L	D0,D1,D3,D4	LOAD.W	D7,#DR_GETSCALE	PAGE_	DRAW		; D4 <-- chelle courante	LOAD.W	D3,D4	LOAD.W	D4,#1	LOAD.W	D7,#DR_PUTSCALE	PAGE_	DRAW		; met l'chelle 100%20$:	CALL	DBRDESTRA	; dessine une trame	INC.W	D0	DEC.W	D1	JUMP,NE 20$	CLR.L	D4	CALL	DRMDEF	LOAD.W	D4,D3	LOAD.W	D7,#DR_PUTSCALE	PAGE_	DRAW		; remet l'chelle courante	POPM.L	D0,D1,D3,D4	RET;----------\\; DBRDESTRA >;----------/; Dessine une trame dans un rectangle.; in	D0.W	numro du rectangle; out	-; mod	D7.WDBRDESTRA:	PUSHM.L	D1..D4,A4	CALL	DBRPOS	JUMP,NE EXIT$	ADD.W	D3,#6	SWAP.W	D3	ADD.W	D3,#6	SWAP.W	D3	SUB.W	D4,#(6*2)-1	SWAP.W	D4	SUB.W	D4,#(6*2)-1	SWAP.W	D4	LIB	?AFTIM	.B	COLOROP,COLOROPPUSH,0	.EVEN	PUSHM.L	D3,A0	LOAD.W	D2,#SETDOT	; D2 <-- mode	LOAD.W	D3,D0		; D3 <-- numro de la trame	TSET.L	D3:#15		; D3 <-- pas d'offset	LOAD.L	A4,(A5)+OPTAB	; A4 <-- ^table des trames	LOAD.L	A0,A5		; A0 <-- canal	CALL	XopDUSE		; utilise la bonne trame	POPM.L	D3,A0	LOAD.W	D1,D2		; D1 <-- SETDOT/LOADDOT/zro	LOAD.W	D2,#LOADDOT	; D2 <-- mode	LIB	?DRTRAME	; dessine la trame	COMP.W	D1,D2		; trame opaque ?	JUMP',EQ END$		; oui => END$	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	LOAD.W	D4,#10	LOAD.W	D2,#SETDOT	CALL	DESETOILE	; dessine l'toile "transparent"END$:	LIB	?AFTIM	.B	COLOROP,COLOROPPOP,0	.EVENEXIT$:	POPM.L	D1..D4,A4	RET;-------\\; DBRPOS >;-------/; Donne la position et les dimensions d'un rectangle.; in	D0.W	no du rectangle (0..n); out	D3.L	coin sup/gauche (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D7.WDBRPOS:	PUSHM.L	D0,D1	LOAD.W	D7,#1		; D7 <-- erreur	COMP.W	D0,#NBRX*NBRY	JUMP',HS 90$	AND.L	D0,#H'FFFF	DIV.WU	D0,#NBRX	LOAD.W	D1,D0		; D1 <-- Y	SWAP.W	D0		; D0 <-- X	MUL.WU	D1,(A5)+ODBRLY	ADD.W	D1,(A5)+ODBRPY	MUL.WU	D0,(A5)+ODBRLX	ADD.W	D0,(A5)+ODBRPX	LOAD.W	D3,D1	SWAP.W	D3	LOAD.W	D3,D0	LOAD.L	D4,(A5)+ODBRLY	; D4 <-- dimensions	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,D1	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBRDESCADRE >;------------/; Dessine les rectangles pour entourer la palette; de trames ou de pinceaux.; in	-; out	-; mod	D7.WDBRDESCADRE:	PUSHM.L	D0..D4	LOAD.W	D2,#2^BDBGCLABEL!100	DBOX_	GETCO	SWAP.W	D3	SUB.W	D3,#16	SWAP.W	D3	LOAD.L	(A5)+ODBRPY,D3	LOAD.W	D2,#2^BDBGCLABEL!101	DBOX_	GETCO	CLR.L	D4	LOAD.W	D4,D3	SUB.W	D4,(A5)+ODBRPX	DIV.WU	D4,#NBRX	LOAD.W	(A5)+ODBRLX,D4	MUL.WU	D4,#NBRX	SUB.W	D4,(A0)+ODFFDX	NEG.W	D4	SR.W	D4,#1	LOAD.W	(A5)+ODBRPX,D4	CLR.W	D3	SWAP.W	D3	SUB.W	D3,(A5)+ODBRPY	DIV.WU	D3,#NBRY	LOAD.W	(A5)+ODBRLY,D3	LOAD.L	D3,(A5)+ODBRPY	LOAD.L	D4,(A5)+ODBRLY	LOAD.W	D2,#SETDOT	; D2 <-- mode de dessin	LOAD.W	D1,#NBRY-1	; D1 <-- compteur vertical30$:	PUSHM.L	D3,D4	LOAD.W	D0,#NBRX-1	; D0 <-- compteur horizontal40$:	LIB	?DRRECT		; dessine rectangle	ADD.W	D3,D4		; D3 <-- X suivant	DECJ.W,NMO D0,40$	POPM.L	D3,D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4		; D3 <-- Y suivant	SWAP.W	D4	SWAP.W	D3	DECJ.W,NMO D1,30$	POPM.L	D0..D4	RET;----------\\; DESETOILE >;==========/; Dessine une toile  huit branches.; in	D3.L	centre de l'toile (y;x);	D4.W	lg d'une branche;	D2.W	mode de dessin;	A0.L	^descripteur; out	-; mod	D7.WDESETOILE:	PUSHM.L	D1..D4,A2	LOAD.W	D1,D2		; D1 <-- mode	LOAD.L	A2,A0		; A2 <-- ^descripteur	CLR.L	D2	LOAD.W	D2,D4		; D2 <-- lg d'une branche	LOAD.L	D4,D3		; D4 <-- centre	SUB.W	D4,D2	CLR.L	D3	LOAD.W	D3,D2	ADD.W	D3,D2	INC.W	D3	GRA_	LINE		; dessine "-"	ADD.W	D4,D2	SWAP.W	D4	SUB.W	D4,D2	SWAP.W	D4	SWAP.W	D3	GRA_	LINE		; dessine "|"	SUB.W	D4,D2	INC.W	D2	DIV.WU	D2,#3		; D2 <-- lg  enlever pour "\" et "/"	ADD.W	D4,D2	SWAP.W	D4	ADD.W	D4,D2	SWAP.W	D4	SWAP.W	D3	SUB.W	D3,D2	SUB.W	D3,D2	LOAD.W	D2,D3	SWAP.W	D3	LOAD.W	D3,D2	GRA_	LINE		; dessine "\"	ADD.W	D4,D3	DEC.W	D4	NEG.W	D3	GRA_	LINE		; dessine "/"	POPM.L	D1..D4,A2	RET;--------\\; DRMDEF  >;========/; Dfini la demi-trame super-rapidement.; ATTENTION:	Le fait d'crire directement dans le descripteur;		de la fentre fait que la trame est inverse;		entre le Smaky 8 et 100 (gauche <--> droite) !;		Il ne faut donc utiliser que des trames simples;		(pas de hachures par exemple).; in	D4.L	demi-trame; out	-; mod	D7.WDRMDEF:	LOAD.L (A0)+ODFTRA+0,D4	LOAD.L (A0)+ODFTRA+4,D4	CLR.L	(A0)+ODFTPM	; annule XTRAME	RET;--------\\; DOK...  >;========/DOKMGP:	LOAD.W	D3,#KEYMGP	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RETDOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RETDOKF2:	LOAD.W	D3,#F2	RETDOKF3:	LOAD.W	D3,#F3	RETDOKF4:	LOAD.W	D3,#F4	RETDOKF5:	LOAD.W	D3,#F5	RETDOKF6:	LOAD.W	D3,#F6	RETDOKF7:	LOAD.W	D3,#F7	RETDOKF8:	LOAD.W	D3,#F8	RETDOKF9:	LOAD.W	D3,#F9	RETDOKF10:	LOAD.W	D3,#F10	RETDOKF11:	LOAD.W	D3,#F11	RETDOKF12:	LOAD.W	D3,#F12	RETDOKF13:	LOAD.W	D3,#F13	RETDOKF14:	LOAD.W	D3,#F14	RETDOKF15:	LOAD.W	D3,#F15	RET	.END