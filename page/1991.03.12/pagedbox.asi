	.SBTTL	PAGEDBOX.ASI;----------\\; DBOXEDITO >;==========/; Edite un nom de fichier en sortie.; in	A3.L	^nom du fichier;	D4.L	fanions par dfaut;	D2.W	mode; out	D2.W	mode;	D3.W	dernire touche (F1/F4/F0);	D7.W	erreur; mod	D2.L, D3.L, D7.WDBOXEDITO:	PUSHM.L	D1,D4,D5,A2..A5	TEST.B	(A3)		; nom du fichier existe ?	JUMP',EQ 10$		; non => 10$				; oui =>	CLR.W	D7		; D7 <-- ok	LOAD.W	D3,#F1		; D3 <-- comme si (SAUVE)	TEST.L	D2:#BDBAUTO	; mode automatique ?	JUMP,BS	EXIT$		; oui => EXIT$10$:	CALL	DBOXOPEN1	LOAD.W	D4,D2		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"TEXPA	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_SAUVE	; D1 <-- code du sous-appel	TSET.L	D2:#BDBEXTEND	; D2 <-- sous-appel d'extension	TSET.L	D2:#BDBSAV	; D2 <-- sauve le fond	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1	TEST.L	D2:#BDBNMAJ	JUMP',BC 30$	TSET.L	D3:#BDBIONMAJ	; D3 <-- touche (MET A JOUR) grise30$:	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	LOAD.W	D2,D4		; D2 <-- nouveau mode (fanions)	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7EXIT$:	POPM.L	D1,D4,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXEDITE >;==========/; Edite un nom de fichier en sortie (extraction).; in	A3.L	^nom du fichier;	D4.L	fanions; out	D4.L	fanions;	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITE:	PUSHM.L	D1,D2,D5,A2..A5	CALL	DBOXOPEN1	TEST.L	D4	JUMP',NE FANOK$	LOAD.L	D4,#2^15FANOK$:	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A2,#R16"TDBOX_EDITE	LOAD.L	A3,#R16"TDBOX_IOL	LOAD.L	A4,#R16"TEXEX	; A4 <-- ^critre de recherche (extensions)	LOAD.W	D1,#DBOX_EXTRAIT; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOOBJ!2^BDBIOEXTM	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7	POPM.L	D1,D2,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX_EDITE:	.B	LDBOX_EDITE	.B	ODBLCIRCLE,15!2^7,0,1	.ASCIZ	" sauve une partie de page (.LPAGE)"	.B	ODBCR	.B	ODBLCIRCLE,14!2^7,0,1	.ASCIZ	" sauve une image DESSIN4  (.IMAGE)"	.B	ODBCRLDBOX_EDITE = .-TDBOX_EDITE-1	.EVEN;----------\\; DBOXEDITI >;==========/; Edite un nom de fichier en entre (prend).; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITI:	PUSHM.L	D1,D2,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"TEXPA	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_PREND	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7EXIT$:	POPM.L	D1,D2,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXEDITA >;==========/; Edite un nom de fichier en entre (ajoute).; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITA:	PUSHM.L	D1,D2,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IOL	LOAD.L	A4,#R16"TEXLPA	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_AJOUTE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7EXIT$:	POPM.L	D1,D2,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXSAVE >;=========/; Sauve le gencar selon le choix de l'utilisateur.; in	D0.W	mode (0=quitte, 1=nouveau texte); out	D7.W	0	=> ok, on peut quitter;		1	=> (ANNULE), donc on reste;		autre	=> erreur grve; mod	D7.WDBOXSAVE:	PUSHM.L	D1..D5,A2..A5	TEST.B	(A6)+OMAJ	; mise  jour ncessaire ?	JUMP,F	80$		; non => 80$ (quitte, snif)				; oui =>	CALL	DBOXOPEN1	CLR.L	D3		; D3 <-- numro de la zone	TEST.B	D0	JUMP',NE 25$	TSET.L	D3:#BDBIOQUIT	; D3 <-- texte "avant de quitter"25$:	LOAD.L	A5,#(A6)+OBUNAME; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_MAJ	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7	COMP.W	D3,#F0		; ANNULE ?	JUMP',EQ 85$	COMP.W	D3,#F4		; NON ?	JUMP',EQ 80$	LOAD.W	D2,#2^BDBAUTO	; D2 <-- mode automatique	CALL	SAUVETOUT	; sauve tout sur disque	JUMP'	EXIT$80$:	CLR.W	D7		; D7 <-- quitte	JUMP'	EXIT$85$:	LOAD.W	D7,#1		; D7 <-- resteEXIT$:	POPM.L	D1..D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXQUITTE >;===========/; Demande si l'on veut quitter DESSIN.; in	-; out	D3.W	dernire touche (F1/F4);	D7.W	erreur; mod	D3.L, D7.WDBOXQUITTE:	PUSHM.L	D1,D2,D4,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_QUITTE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	CLR.L	D3	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7EXIT$:	POPM.L	D1,D2,D4,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBOXNEWPAGE >;============/; Demande comment crer une nouvelle page.; in	-; out	D3.W	dernire touche (F1/F4);	D4.L	fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXNEWPAGE:	PUSHM.L	D1,D2,D5,A1..A5	LIB	?BUZZ	LOAD.L	A5,A6		; A5 <-- ^variables pour put/get	LOAD.L	A2,#R16"TDBOX$	CALL	DBOXMEMPT	LOAD.L	A2,#R16"TDBOX_NEWPAGE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+ONPFAN	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$	PUSH.L	D4	CALL	__GROUPNBPAGE	LOAD.W	D1,D4		; D1 <-- nb total de pages	LOAD.W	D2,#50!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.W	D3,#4	LOAD.W	D2,#2^BAFDCM	CLR.L	D4	LOAD.W	D4,(A6)+OPAGE	INC.W	D4		; D1 <-- 1..n	COMP.W	D4,D1		; est-ce la dernire page ?	JUMP',LO INIT2$		; non => INIT2$				; oui =>	LIB	?AFTIM	.ASCIZ	"aprs la page "	.EVEN	LIB	?AFDEC		; affiche le numro de la page	JUMP'	INIT3$INIT2$:	LIB	?AFTIM	.ASCIZ	"entre la page "	.EVEN	LIB	?AFDEC		; affiche le numro de la page	LIB	?AFTIM	.ASCIZ	" et la page "	.EVEN	INC.W	D4	LIB	?AFDEC		; affiche le numro de la page suivanteINIT3$:	LOAD.B	D3,#'.	LIB	?AFCAR	LOAD.W	D2,#51!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	CLR.L	D4	LOAD.W	D4,(A6)+OPAGE	INC.W	D4	LOAD.W	D3,#4	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC		; affiche le numro de la page	POP.L	D4	CLR.W	D2AFF$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXAFF		; affiche le paramtre	INC.W	D2	COMP.W	D2,#1	JUMP,LO AFF$	CLR.W	D2NLINE$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXMEDITLOOP$:	DBOX_	EDIT		; attend une action ...	CALL	ZEROCR	LOAD.L	A1,#R16"TKEY_NEWPAGE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#CLEAR	JUMP',EQ UNDO$	COMP.W	D3,#CR	JUMP',EQ RETURN$	COMP.W	D3,#ENTER	JUMP',EQ RETURN$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP',EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	CALL	DBOXPUT	JUMP,NE BIP$	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,#1	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$KEYDBOX$:			; KEYDBOX =>	CALL	DBOXPUT	JUMP,NE BIP$	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$CLIC$:	CALL	DBOXCLIC	; action dans les flches +/-	JUMP,NE BIP$	JUMP	NLINE$OK$:	CALL	DBOXPUT	JUMP,NE BIP$	LOAD.L	(A6)+ONPFAN,D4	; mj les fanionsEND$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D5,A1..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	ONPNBC,DBTYPN,1,999,1,2^BDBGCLABEL!100,0,3+2	.W	-1TDBOX_NEWPAGE:	.W	10$-TDBOX_NEWPAGE	.W	20$-TDBOX_NEWPAGE	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Cre "	.B	ODBLABEL,100	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTEXT	.ASCIZ	"   nouvelles pages"	.B	ODBCR,ODBCR2	.B	ODBLABEL,50	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBLCIRCLE,0	.ASCIZ	" cre des pages vides"	.B	ODBCR	.B	ODBLCIRCLE,1	.ASCIZ	" cre des modles |"	.B	ODBCR2	.B	ODBTABX,22	.B	ODBTEXT	.ASCIZ	"de la page "	.B	ODBLABEL,51	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBCR2	.B	ODBLCIRCLE,2	.ASCIZ	" cre des copies  |"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	"  CREE  "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Cre"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_NEWPAGE:	.W	F1,F2,F3,0		DOKF1-TKEY_NEWPAGE	.W	F0,F13,F14,F15,0	DOKF0-TKEY_NEWPAGE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_NEWPAGE	.W	0;--------------\\; DBOXNEWCALQUE >;==============/; Demande comment crer un nouveau calque.; in	-; out	D3.W	dernire touche (F1/F4);	D4.L	fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXNEWCALQUE:	PUSHM.L	D1,D2,D5,A1..A4	LIB	?BUZZ	LOAD.L	A2,#R16"TDBOX_NEWCALQUE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+ONCFAN	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$	PUSH.L	D4	LOAD.W	D2,#100!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.W	D3,(A6)+OIDCAL+OIDPOSV	ADD.B	D3,#'A	LIB	?AFCAR		; affiche la lettre du calque	LOAD.B	D1,D3	LOAD.B	D3,#'.	LIB	?AFCAR	LOAD.W	D2,#101!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.B	D3,D1	LIB	?AFCAR		; affiche la lettre du calque	POP.L	D4LOOP$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_NEWCALQUE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP',EQ OK$	COMP.W	D3,#F0	JUMP',EQ END$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$OK$:	LOAD.L	(A6)+ONCFAN,D4	; mj les fanionsEND$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_NEWCALQUE:	.W	10$-TDBOX_NEWCALQUE	.W	20$-TDBOX_NEWCALQUE	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Cre un nouveau calque"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"par-dessus le calque "	.B	ODBLABEL,100	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBLCIRCLE,0	.ASCIZ	" cre un calque vide"	.B	ODBCR	.B	ODBLCIRCLE,1	.ASCIZ	" cre une copie du calque "	.B	ODBLABEL,101	.B	ODBTEXT	.ASCIZ	" "	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	"  CREE  "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Cre"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_NEWCALQUE:	.W	F1,F2,F3,0		DOKF1-TKEY_NEWCALQUE	.W	F0,F13,F14,F15,0	DOKF0-TKEY_NEWCALQUE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_NEWCALQUE	.W	0;-----------\\; DBOXEFPAGE >;===========/; Demande s'il faut effacer la page.; in	-; out	D3.W	dernire touche (F1/F4);	D4.L	fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEFPAGE:	PUSHM.L	D1,D2,D5,A1..A4	LIB	?BUZZ	LOAD.L	A2,#R16"TDBOX_EFPAGE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+OEPFAN	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$	PUSH.L	D4	LOAD.W	D2,#101!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	CLR.L	D4	LOAD.W	D4,(A6)+OPAGE	INC.W	D4	LOAD.W	D3,#4	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC		; affiche le numro de la page	POP.L	D4MAJ$:	LOAD.L	A3,#R16"TXCLR$	TEST.L	D4:#0	JUMP',BS MAJ2$	LOAD.L	A3,#R16"TXKIL$MAJ2$:	PUSH.L	D4	LOAD.W	D2,#100!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTEXT		; affiche EFFACE/SUPPRIME	POP.L	D4	CALL	DBEFPAFF	; affiche qq renseignementsLOOP$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_EFPAGE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP',EQ OK$	COMP.W	D3,#F0	JUMP',EQ END$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ MAJ$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$OK$:	LOAD.L	(A6)+OEPFAN,D4	; mj les fanionsEND$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTXCLR$:	.ASCIZ	"  EFFACE "TXKIL$:	.ASCIZ	" SUPPRIME"	.EVEN;---------\\; DBEFPAFF >;---------/; Affiche quelques renseignements.; in	D4.L	fanions; out	-; mod	D7.WDBEFPAFF:	PUSHM.L	D1..D4,D6	LOAD.L	D6,(A6)+OOBACH	; D6 <-- canal de l'arbre des objets	LOAD.L	D1,D4		; D1 <-- fanions	LOAD.W	D2,#110!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	TEST.L	D1:#2	JUMP',BS ALL$	LOAD.W	D3,(A6)+OPAGE	; D3 <-- page visible	LOAD.W	D4,#-1		; D4 <-- tous les calques	CALL	__LSTA_BEGIN	; A4 <-- ^page de base	CALL	__LSTA_NB	; D4 <-- nb d'lments	SUB.W	D4,(A6)+OIDCAL+OIDHTV ; D4 <-- dcompte les objets "calques"	CLR.L	D1	LOAD.W	D1,D4	LIB	?AFTIM	.ASCIZ	"(la page "	.EVEN	CLR.L	D4	LOAD.W	D4,(A6)+OPAGE	INC.W	D4	LOAD.W	D3,#4	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC		; affiche le numro de la page	TEST.W	D1	JUMP',NE ONE5$	LIB	?AFTIM	.ASCIZ	" ne"	.EVENONE5$:	LIB	?AFTIM	.ASCIZ	" contient "	.EVEN	JUMP'	NB$ALL$:	LOAD.W	D3,#-1		; D3 <-- toutes les pages	LOAD.W	D4,#-1		; D4 <-- tous les calques	CALL	__LSTA_BEGIN	; A4 <-- ^document	CALL	__LSTA_NB	; D4 <-- nb d'lments	CLR.L	D1	LOAD.W	D1,D4	LIB	?AFTIM	.ASCIZ	"(les pages"	.EVEN;	TEST.W	D1;	JUMP',NE ALL5$;	LIB	?AFTIM;	.ASCIZ	" ne";	.EVEN;ALL5$:	LIB	?AFTIM	.ASCIZ	" contiennent "	.EVENNB$:	LOAD.L	D4,D1		; D4 <-- nb d'objets	JUMP',EQ RIEN$	AND.L	D4,#H'FFFF	LOAD.W	D3,#4	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC		; affiche le nombre d'objets	LIB	?AFTIM	.ASCIZ	" objet"	.EVEN	COMP.W	D4,#1	JUMP',LS END$	LOAD.B	D3,#'s	LIB	?AFCAR	JUMP'	END$RIEN$:	LIB	?AFTIM	.ASCIZ	"rien"	.EVENEND$:	LIB	?AFTIM	.ASCIZ	")<EFLI>"	.EVEN	POPM.L	D1..D4,D6	RETTDBOX_EFPAGE:	.W	10$-TDBOX_EFPAGE	.W	20$-TDBOX_EFPAGE	.W	0,010$:	.B	ODBLCIRCLE,0!2^7,KEYDBOX/H'100,0	.ASCIZ	" efface   |"	.B	ODBCR2	.B	ODBTABX,14	.B	ODBTEXT	.ASCIZ	"la page "	.B	ODBLABEL,101	.B	ODBTEXT,0	.B	ODBCR2	.B	ODBLCIRCLE,1!2^7,KEYDBOX/H'100,1	.ASCIZ	" supprime |"	.B	ODBCR,ODBCR2	.B	ODBLCIRCLE,2!2^7,KEYDBOX/H'100,2	.ASCIZ	" supprime toutes les pages"	.B	ODBCR,ODBCR	.B	ODBLABEL,110	.B	ODBTEXT,0	.B	ODBTABX,35	.B	ODBCR,ODBCR,ODBCR	.B	ODBLABEL,100	.B	ODBBOX,0,F1,TDBNORM	.ASCIZ	"          "		;  EFFACE  ;		; SUPPRIME ;	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBMEV	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Efface/Supprime"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_EFPAGE:	.W	F1,F2,F3,0		DOKF1-TKEY_EFPAGE	.W	F0,F13,F14,F15,0	DOKF0-TKEY_EFPAGE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_EFPAGE	.W	0;-------------\\; DBOXEFCALQUE >;=============/; Demande s'il faut effacer le calque.; in	-; out	D3.W	dernire touche (F1/F4);	D4.L	fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEFCALQUE:	PUSHM.L	D1,D2,D5,A1..A4	LIB	?BUZZ	LOAD.L	A2,#R16"TDBOX_EFCALQUE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+OECFAN	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$	PUSH.L	D4	LOAD.W	D2,#101!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.W	D3,(A6)+OIDCAL+OIDPOSV	ADD.B	D3,#'A	LIB	?AFCAR		; affiche la lettre du calque	POP.L	D4MAJ$:	LOAD.L	A3,#R16"TXHID$	TEST.L	D4:#0	JUMP',BS MAJ2$	LOAD.L	A3,#R16"TXCLR$	TEST.L	D4:#1	JUMP',BS MAJ2$	LOAD.L	A3,#R16"TXKIL$MAJ2$:	PUSH.L	D4	LOAD.W	D2,#100!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTEXT		; affiche EFFACE/SUPPRIME	POP.L	D4	CALL	DBEFCAFF	; affiche qq renseignementsLOOP$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_EFCALQUE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP',EQ OK$	COMP.W	D3,#F0	JUMP',EQ END$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ MAJ$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$OK$:	LOAD.L	(A6)+OECFAN,D4	; mj les fanionsEND$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTXHID$:	.ASCIZ	"  CACHE  "TXCLR$:	.ASCIZ	"  EFFACE "TXKIL$:	.ASCIZ	" SUPPRIME"	.EVEN;---------\\; DBEFCAFF >;---------/; Affiche quelques renseignements.; in	D4.L	fanions; out	-; mod	D7.WDBEFCAFF:	PUSHM.L	D1..D4,D6	LOAD.L	D6,(A6)+OOBACH	; D6 <-- canal de l'arbre des objets	LOAD.L	D1,D4		; D1 <-- fanions	LOAD.W	D2,#110!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	TEST.L	D1:#3	JUMP',BS ALL$	LOAD.W	D3,(A6)+OPAGE	; D3 <-- page visible	LOAD.W	D4,(A6)+OCALQ	; D4 <-- calque visible	CALL	__LSTA_BEGIN	; A4 <-- ^calque de base	CALL	__LSTA_NB	; D4 <-- nb d'lments	CLR.L	D1	LOAD.W	D1,D4	LIB	?AFTIM	.ASCIZ	"(le calque "	.EVEN	LOAD.W	D3,(A6)+OIDCAL+OIDPOSV	ADD.B	D3,#'A	LIB	?AFCAR		; affiche la lettre du calque	TEST.W	D1	JUMP',NE ONE5$	LIB	?AFTIM	.ASCIZ	" ne"	.EVENONE5$:	LIB	?AFTIM	.ASCIZ	" contient "	.EVEN	JUMP'	NB$ALL$:	LOAD.W	D3,(A6)+OPAGE	; D3 <-- page visible	LOAD.W	D4,#-1		; D4 <-- tous les calques	CALL	__LSTA_BEGIN	; A4 <-- ^page de base	CALL	__LSTA_NB	; D4 <-- nb d'lments	SUB.W	D4,(A6)+OIDCAL+OIDHTV ; D4 <-- dcompte les objets "calques"	CLR.L	D1	LOAD.W	D1,D4	LIB	?AFTIM	.ASCIZ	"(les calques"	.EVEN	TEST.W	D1	JUMP',NE ALL5$	LIB	?AFTIM	.ASCIZ	" ne"	.EVENALL5$:	LIB	?AFTIM	.ASCIZ	" contiennent "	.EVENNB$:	LOAD.L	D4,D1		; D4 <-- nb d'objets	JUMP',EQ RIEN$	LOAD.W	D3,#4	LOAD.W	D2,#2^BAFDCM	LIB	?AFDEC		; affiche le nombre d'objets	LIB	?AFTIM	.ASCIZ	" objet"	.EVEN	COMP.W	D4,#1	JUMP',LS END$	LOAD.B	D3,#'s	LIB	?AFCAR	JUMP'	END$RIEN$:	LIB	?AFTIM	.ASCIZ	"rien"	.EVENEND$:	LIB	?AFTIM	.ASCIZ	")<EFLI>"	.EVEN	POPM.L	D1..D4,D6	RETTDBOX_EFCALQUE:	.W	10$-TDBOX_EFCALQUE	.W	20$-TDBOX_EFCALQUE	.W	0,010$:	.B	ODBLCIRCLE,0!2^7,KEYDBOX/H'100,0	.ASCIZ	" cache    |"	.B	ODBCR	.B	ODBLCIRCLE,1!2^7,KEYDBOX/H'100,0	.ASCIZ	" efface   | le calque "	.B	ODBLABEL,101	.B	ODBTEXT,0	.B	ODBCR	.B	ODBLCIRCLE,2!2^7,KEYDBOX/H'100,1	.ASCIZ	" supprime |"	.B	ODBCR,ODBCR2	.B	ODBLCIRCLE,3!2^7,KEYDBOX/H'100,2	.ASCIZ	" supprime tous les calques de la page"	.B	ODBCR,ODBCR	.B	ODBLABEL,110	.B	ODBTEXT,0	.B	ODBTABX,35	.B	ODBCR,ODBCR,ODBCR	.B	ODBLABEL,100	.B	ODBBOX,0,F1,TDBNORM	.ASCIZ	"          "		;  EFFACE  ;		; SUPPRIME ;	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBMEV	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	"Cache/"	.ASCIZ	"Efface/Supprime"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_EFCALQUE:	.W	F1,F2,F3,0		DOKF1-TKEY_EFCALQUE	.W	F0,F13,F14,F15,0	DOKF0-TKEY_EFCALQUE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_EFCALQUE	.W	0;------------\\; DBOXDEFPAGE >;============/; Demande les dfinitions de page.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXDEFPAGE:	PUSHM.L	D0..D2,D4,D5,A0..A5	PUSH.L	(A6)+ODESYD	PUSH.W	(A6)+ODESMG	PUSH.W	(A6)+ODESMD	PUSH.W	(A6)+ODESMS	PUSH.W	(A6)+ODESMI	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur fentre	LOAD.L	A5,A6		; A5 <-- ^variables pour put/get	LOAD.L	A2,#R16"TDBOX$	CALL	DBOXMEMPT	LOAD.L	A2,#R16"DBDFPPINV	CALL	DBOXMEMAFC	LOAD.L	A2,#R16"TDBOX_DEFPAGE	LOAD.W	D2,#2^BDBSAV	CLR.L	D4	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	CALL	DBDFPDRAW	; dessine la scroll-list	CALL	DBDFPPINIT	; initialise la pageDIM$:	CLR.W	(A6)+ODBPA1	CLR.W	(A6)+ODBPA2	CLR.W	(A6)+ODBPA3	CLR.W	(A6)+ODBPA4	CALL	GETPRIDIM	; D4/D3/D2 <-- dimensions/marges hard	JUMP',NE DIM2$	LOAD.W	(A6)+ODBPA1,D3	SWAP.W	D3	LOAD.W	(A6)+ODBPA3,D3	LOAD.W	(A6)+ODBPA2,D2	SWAP.W	D2	LOAD.W	(A6)+ODBPA4,D2DIM2$:	CLR.W	D2REFAIT$:	PUSH.W	D2	CLR.W	D2AFF$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXAFF		; affiche le paramtre	INC.W	D2	COMP.W	D2,#6	JUMP,LO AFF$	POP.W	D2NLINE$:	CALL	DBDFPPINV	; allume la pageNLINEP$:	CALL	DBDFPUPDATE	; mj la scroll-liste	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXMEDITLOOP$:	DBOX_	EDIT		; attend action ...	CALL	ZEROCR	LOAD.L	A1,#R16"TKEY_DEFPAGE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ DAC$	COMP.W	D3,#F4	JUMP,EQ CHOIX$	COMP.W	D3,#F0	JUMP,EQ CANCEL$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#CLEAR	JUMP',EQ UNDO$	COMP.W	D3,#CR	JUMP',EQ RETURN$	COMP.W	D3,#ENTER	JUMP',EQ RETURN$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP',EQ KEYDBOX$	JUMP'	BIP$BIPP$:	CALL	DBDFPPINV	; allume la pageBIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	CALL	DBDFPPINV	; efface la page	CALL	DBOXPUT	JUMP,NE BIPP$	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,#6	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$KEYDBOX$:			; KEYDBOX =>	CALL	DBDFPPINV	; efface la page	CALL	DBOXPUT	JUMP,NE BIPP$	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$CLIC$:	CALL	DBOXCLIC	; action dans les flches +/-	JUMP,EQ NLINEP$	CALL	DBDFPPINV	; efface la page	LIB	?IFMOUSE	; D4 <-- position de la souris (y;x)	JUMP,NE BIPP$	SUB.W	D4,(A0)+ODFFX	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	SWAP.W	D4	CALL	DBDFPMOVE	; dplace la scroll-liste ...	JUMP,EQ REFAIT$	CALL	DBDFPPINV	; allume la page	CALL	DBDFPPMOVE	; dplace la page ...	JUMP,EQ NLINEP$	JUMP	BIP$CHOIX$:	CALL	DBDFPPINV	; efface la page	CALL	DBOXPUT	JUMP,NE BIPP$	LOAD.L	A2,(A6)+OCAPRINT	CLR.L	D3	PRINTA_	SELECTION	; choix prsentation/papier/imprimante ...	LOAD.L	A2,#R16"TDBOX_DEFPAGE	CALL	DBOXRSK		; refait les soft-keys	CALL	GETPRIDIP	; D4/D3/D2 <-- dimensions/marges prsentation	JUMP,NE BIPP$	LOAD.W	(A6)+ODESXD,D4	SWAP.W	D4	LOAD.W	(A6)+ODESYD,D4	LOAD.W	(A6)+ODESMG,D3	SWAP.W	D3	LOAD.W	(A6)+ODESMS,D3	LOAD.W	(A6)+ODESMD,D2	SWAP.W	D2	LOAD.W	(A6)+ODESMI,D2	JUMP	DIM$DAC$:				; D'ACCORD =>	CALL	DBDFPPINV	; efface la page	CALL	DBOXPUT	JUMP,NE BIPP$	ADD.L	SP,#2+2+2+2+4	CALL	DBOXCLOSE	; ferme la DBOX	JUMP'	EXIT$CANCEL$:			; ANNULE =>	POP.W	(A6)+ODESMI	POP.W	(A6)+ODESMS	POP.W	(A6)+ODESMD	POP.W	(A6)+ODESMG	POP.L	(A6)+ODESYD	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A0..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	ODESXD,DBTYPU,1000*FACMMPT,(2^15)-1,100*FACMMPT,2^BDBGCLABEL!100,0,8+2	.W	ODESYD,DBTYPU,1000*FACMMPT,(2^15)-1,100*FACMMPT,2^BDBGCLABEL!101,1,8+2	.W	ODESMG,DBTYPU!2^14,ODBPA1,(2^15)-1,10*FACMMPT,2^BDBGCLABEL!102,2,8+2	.W	ODESMD,DBTYPU!2^14,ODBPA2,(2^15)-1,10*FACMMPT,2^BDBGCLABEL!103,3,8+2	.W	ODESMS,DBTYPU!2^14,ODBPA3,(2^15)-1,10*FACMMPT,2^BDBGCLABEL!104,4,8+2	.W	ODESMI,DBTYPU!2^14,ODBPA4,(2^15)-1,10*FACMMPT,2^BDBGCLABEL!105,5,8+2	.W	-1;----------\\; DBDFPDRAW >;----------/; Dessine la scroll-liste.; in	-; out	-; mod	D7.WDBDFPDRAW:	PUSHM.L	D2..D4,A5	LOAD.L	A5,#(A6)+ODBSLV	; A5 <-- ^variables scroll-liste	LOAD.W	D2,#200!2^BDBGCLABEL	DBOX_	GETCO	SWAP.W	D3	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,(A0)+ODFC2Y	SWAP.W	D3	LOAD.L	(A5)+OSLPOS,D3	LOAD.W	D2,#201!2^BDBGCLABEL	DBOX_	GETCO	SUB.W	D3,(A5)+OSLPOS+2	SWAP.W	D3	ADD.W	D3,(A0)+ODFC2Y	SUB.W	D3,(A5)+OSLPOS+0	SWAP.W	D3	LOAD.L	(A5)+OSLDIM,D3	CLR.B	(A5)+OSLVID	CLR.B	(A5)+OSLHOR	SCROLL_	LDRAW		; dessine la scroll-liste	LOAD.W	(A5)+OSLCYS,#-1	POPM.L	D2..D4,A5	RET;------------\\; DBDFPUPDATE >;------------/; Dessine la scroll-liste.; in	-; out	-; mod	D7.WDBDFPUPDATE:	PUSHM.L	D2..D4,A3,A5	LOAD.L	A5,#(A6)+ODBSLV	; A5 <-- ^variables scroll-liste;;?	COMP.W	(A5)+OSLCYS,#LDBDFPPAP-1;;?	JUMP,EQ EXIT$	LOAD.L	A3,#R16"TDBDFPPAP	CLR.W	D3LOOP$:	LOAD.W	D4,(A3)+28	SUB.W	D4,#10*FACMMPT	COMP.W	D4,(A6)+ODESXD	JUMP',HS NEXT$	ADD.W	D4,#20*FACMMPT	COMP.W	D4,(A6)+ODESXD	JUMP',LO NEXT$	LOAD.W	D4,(A3)+30	SUB.W	D4,#10*FACMMPT	COMP.W	D4,(A6)+ODESYD	JUMP',HS NEXT$	ADD.W	D4,#20*FACMMPT	COMP.W	D4,(A6)+ODESYD	JUMP',HS FOUND$NEXT$:	LOAD.L	A3,#(A3)+32	; A3 <-- ^papier suivant	INC.W	D3	COMP.W	D3,#LDBDFPPAP-1	JUMP,LO LOOP$FOUND$:	COMP.W	D3,(A5)+OSLCYS	; est-ce cette case dj slectionne ?	JUMP',EQ EXIT$		; oui => EXIT$	LOAD.W	(A5)+OSLCYS,D3	LOAD.W	(A5)+OSLCYN,#LDBDFPPAP	LOAD.L	A3,#R16"DBDFPGET	LOAD.L	(A5)+OSLADL,A3	SCROLL_	LUPDATE		; dessine le contenuEXIT$:	POPM.L	D2..D4,A3,A5	RET;---------\\; DBDFPGET >;---------/; Donne le texte  mettre dans la scroll-liste.; in	D3.W	rang de la case (0..n); out	A3.L	^contenu;	D3.W	ligne; mod	D3.L, D7.W, A3.LDBDFPGET:	LOAD.L	A3,#R16"TDBDFPPAP	MUL.WU	D3,#32	ADD.L	A3,D3		; A3 <-- ^texte	CLR.W	D3	LOAD.B	D3,(A3)+27	; D3 <-- ligne	CLR.W	D7		; retour EQ	RET;----------\\; DBDFPMOVE >;----------/; Dplace la scroll-liste.; in	D4.L	position de la souris (y;x); out	D7.W	erreur; mod	D7.WDBDFPMOVE:	PUSHM.L	D3,A3,A5	LOAD.L	A5,#(A6)+ODBSLV	; A5 <-- ^variables scroll-liste	SCROLL_	LMOVE		; dplace la scroll-liste	JUMP',NE EXIT$	LOAD.W	D3,(A5)+OSLCYS	CALL	DBDFPGET	; A3 <-- ^contenu de la case choisie	TEST.W	(A3)+28	JUMP',EQ EXIT$	LOAD.W	(A6)+ODESXD,(A3)+28	LOAD.W	(A6)+ODESYD,(A3)+30EXIT$:	POPM.L	D3,A3,A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBDFPPINIT >;-----------/; Initialise la page.; in	-; out	-; mod	D7.WDBDFPPINIT:	PUSHM.L	D2..D4	LOAD.W	D2,#202!2^BDBGCLABEL	DBOX_	GETCO	ADD.W	D3,#4	SWAP.W	D3	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,(A0)+ODFC2Y	SWAP.W	D3	LOAD.L	(A6)+ODBDPC,D3	LOAD.W	D2,#203!2^BDBGCLABEL	DBOX_	GETCO	SUB.W	D3,(A6)+ODBDPC+2	LOAD.L	D4,#(2^15)-1	DIV.WU	D4,D3	LOAD.W	(A6)+ODBDPF,D4	LIB	?AFTIM	.B	MAPTT	.B	B'10001000	.B	1	.B	0	.EVEN	LOAD.L	D4,#(2^15)-1	DIV.WU	D4,(A6)+ODBDPF	LOAD.W	D3,D4	SWAP.W	D4	LOAD.W	D4,D3	LOAD.L	D3,(A6)+ODBDPC	LOAD.W	D2,#INVDOT!TTTDOT	LIB	?DRRECT	POPM.L	D2..D4	RET;-----------\\; DBDFPPMOVE >;-----------/; Dplace une poigne.; in	D4.L	position de la souris (y;x); out	D7.W	erreur; mod	D7.WDBDFPPMOVE:	PUSHM.L	D2..D4	CALL	DBDFPPDET	; D2 <-- poigne o est la souris	JUMP',NE EXIT$LOOP$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP',NE EXIT$	LIB	?IFMOUSE	; D4 <-- position de la souris (y;x)	JUMP,NE LOOP$	SUB.W	D4,(A0)+ODFFX	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	SWAP.W	D4	LOAD.L	D3,D4	CALL	DBDFPPINV	; efface l'ancien	CALL	DBDFPPDEP	CALL	DBDFPPINV	; allume le nouveau	JUMP	LOOP$EXIT$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBDFPPDET >;----------/; Dtecte dans quelle poigne est la souris.; in	D4.L	position de la souris (y;x); out	D2.W	rang (0..2);	D7.W	erreur; mod	D2.L, D7.WDBDFPPDET:	PUSHM.L	D3..D5	LOAD.L	D5,D4		; D4 <-- position en X	SWAP.W	D5		; D5 <-- position en Y	CLR.W	D2LOOP$:	CALL	DBDFPPPOS	; D3 <-- position poigne	SUB.W	D3,#5	COMP.W	D4,D3	JUMP',LT NEXT$	ADD.W	D3,#5+5	COMP.W	D4,D3	JUMP',GE NEXT$	SWAP.W	D3	SUB.W	D3,#5	COMP.W	D5,D3	JUMP',LT NEXT$	ADD.W	D3,#5+5	COMP.W	D5,D3	JUMP',GE NEXT$	CLR.W	D7		; D7 <-- trouv	JUMP'	EXIT$NEXT$:	INC.W	D2	COMP.W	D2,#5	JUMP,LO LOOP$	LOAD.W	D7,#1EXIT$:	POPM.L	D3..D5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBDFPPINV >;----------/; Inverse la page.; in	-; out	-; mod	D7.WDBDFPPINV:	PUSHM.L	D1..D4	LIB	?AFTIM	.B	MAPTT	.B	B'10101010	.B	1	.B	0	.EVEN	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	CLR.W	D2	CALL	DBDFPPPOS	; D3 <-- position poigne	LOAD.L	D4,D3	LOAD.L	D3,(A6)+ODBDPC	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRRECT	LOAD.W	D2,#2	CALL	DBDFPPPOS	; D3 <-- position poigne	LOAD.W	D4,D3	LOAD.W	D2,#4	CALL	DBDFPPPOS	; D3 <-- position poigne	SUB.W	D4,D3	PUSH.W	D3	PUSH.W	D4	LOAD.W	D2,#3	CALL	DBDFPPPOS	; D3 <-- position poigne	SWAP.W	D3	LOAD.W	D4,D3	LOAD.W	D2,#1	CALL	DBDFPPPOS	; D3 <-- position poigne	SWAP.W	D3	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	POP.W	D4	POP.W	D3	LOAD.W	D2,#INVDOT!TTTDOT	LIB	?DRRECT	CLR.W	D1LOOP$:	LOAD.W	D2,D1	CALL	DBDFPPPOS	; D3 <-- position poigne	SUB.W	D3,#3	SWAP.W	D3	SUB.W	D3,#3	SWAP.W	D3	LOAD.L	D4,#H'10000*7+7	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	; inverse une poigne	INC.W	D1	COMP.W	D1,#5	JUMP,LO LOOP$	POPM.L	D1..D4	RET;----------\\; DBDFPPDEP >;----------/; Dplace une poigne.; in	D3.L	nouvelle position (y;x);	D2.W	rang (0..2); out	-; mod	D7.WDBDFPPDEP:	PUSHM.L	D2..D4,A3,A4	SUB.W	D3,(A6)+ODBDPC+2	JUMP',NC OKX1$	CLR.W	D3OKX1$:	LOAD.W	D4,D3	MUL.WU	D4,(A6)+ODBDPF	COMP.L	D4,#(2^15)-1	JUMP',LS OKX2$	LOAD.W	D4,#(2^15)-1OKX2$:	LOAD.W	D3,D4	SWAP.W	D3	SUB.W	D3,(A6)+ODBDPC+0	JUMP',NC OKY1$	CLR.W	D3OKY1$:	LOAD.W	D4,D3	MUL.WU	D4,(A6)+ODBDPF	COMP.L	D4,#(2^15)-1	JUMP',LS OKY2$	LOAD.W	D4,#(2^15)-1OKY2$:	LOAD.W	D3,D4	SWAP.W	D3	COMP.W	D2,#1	JUMP',EQ P1$	COMP.W	D2,#2	JUMP',EQ P2$	COMP.W	D2,#3	JUMP,EQ P3$	COMP.W	D2,#4	JUMP,EQ P4$P0$:	LOAD.L	(A6)+ODESYD,D3	CLR.W	D2	CALL	DBOXGET	CALL	DBOXAFF	LOAD.W	D2,#1	CALL	DBOXGET	CALL	DBOXAFF	JUMP	EXIT$P1$:	SWAP.W	D3	COMP.W	D3,(A6)+ODBPA3	JUMP',GE P1OK$	LOAD.W	D3,(A6)+ODBPA3P1OK$:	LOAD.W	(A6)+ODESMS,D3	LOAD.W	D2,#4	CALL	DBOXGET	CALL	DBOXAFF	JUMP	EXIT$P2$:	SUB.W	D3,(A6)+ODESXD	NEG.W	D3	COMP.W	D3,(A6)+ODBPA2	JUMP',GE P2OK$	LOAD.W	D3,(A6)+ODBPA2P2OK$:	LOAD.W	(A6)+ODESMD,D3	LOAD.W	D2,#3	CALL	DBOXGET	CALL	DBOXAFF	JUMP'	EXIT$P3$:	SWAP.W	D3	SUB.W	D3,(A6)+ODESYD	NEG.W	D3	COMP.W	D3,(A6)+ODBPA4	JUMP',GE P3OK$	LOAD.W	D3,(A6)+ODBPA4P3OK$:	LOAD.W	(A6)+ODESMI,D3	LOAD.W	D2,#5	CALL	DBOXGET	CALL	DBOXAFF	JUMP'	EXIT$P4$:	COMP.W	D3,(A6)+ODBPA1	JUMP',GE P4OK$	LOAD.W	D3,(A6)+ODBPA1P4OK$:	LOAD.W	(A6)+ODESMG,D3	LOAD.W	D2,#2	CALL	DBOXGET	CALL	DBOXAFF;	JUMP'	EXIT$EXIT$:	POPM.L	D2..D4,A3,A4	RET;----------\\; DBDFPPPOS >;----------/; Donne la position d'une poigne.; in	D2.W	rang (0..2); out	D3.L	position (y;x); mod	D3.L, D7.WDBDFPPPOS:	PUSH.L	D4	COMP.W	D2,#1	JUMP',EQ P1$	COMP.W	D2,#2	JUMP',EQ P2$	COMP.W	D2,#3	JUMP',EQ P3$	COMP.W	D2,#4	JUMP',EQ P4$P0$:	LOAD.L	D3,(A6)+ODESYD	JUMP'	EXIT$P1$:	LOAD.W	D3,(A6)+ODESMS	SWAP.W	D3	LOAD.W	D3,(A6)+ODESXD	SR.W	D3,#1	JUMP'	EXIT$P2$:	LOAD.W	D3,(A6)+ODESYD	SR.W	D3,#1	SWAP.W	D3	LOAD.W	D3,(A6)+ODESXD	SUB.W	D3,(A6)+ODESMD	JUMP'	EXIT$P3$:	LOAD.W	D3,(A6)+ODESYD	SUB.W	D3,(A6)+ODESMI	SWAP.W	D3	LOAD.W	D3,(A6)+ODESXD	SR.W	D3,#1	JUMP'	EXIT$P4$:	LOAD.W	D3,(A6)+ODESYD	SR.W	D3,#1	SWAP.W	D3	LOAD.W	D3,(A6)+ODESMG;	JUMP'	EXIT$EXIT$:	CLR.L	D4	LOAD.W	D4,D3	DIV.WU	D4,(A6)+ODBDPF	LOAD.W	D3,D4	ADD.W	D3,(A6)+ODBDPC+2	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,D3	DIV.WU	D4,(A6)+ODBDPF	LOAD.W	D3,D4	ADD.W	D3,(A6)+ODBDPC+0	SWAP.W	D3	POP.L	D4	RETTDBDFPPAP:	.ASCIZ	"A2 vertical               "	.B	0	.W	4200*FACMMPT,5940*FACMMPT	.ASCIZ	"A2 horizontal             "	.B	0	.W	5940*FACMMPT,4200*FACMMPT	.ASCIZ	"A3 vertical               "	.B	0	.W	2970*FACMMPT,4200*FACMMPT	.ASCIZ	"A3 horizontal             "	.B	0	.W	4200*FACMMPT,2970*FACMMPT	.ASCIZ	"A4 vertical               "	.B	0	.W	2100*FACMMPT,2970*FACMMPT	.ASCIZ	"A4 horizontal             "	.B	0	.W	2970*FACMMPT,2100*FACMMPT	.ASCIZ	"A5 vertical               "	.B	0	.W	1480*FACMMPT,2100*FACMMPT	.ASCIZ	"A5 horizontal             "	.B	0	.W	2100*FACMMPT,1480*FACMMPT	.ASCIZ	"A6 vertical               "	.B	0	.W	1050*FACMMPT,1480*FACMMPT	.ASCIZ	"A6 horizontal             "	.B	1	.W	1480*FACMMPT,1050*FACMMPT	.ASCIZ	"B5 vertical               "	.B	0	.W	1760*FACMMPT,2500*FACMMPT	.ASCIZ	"B5 horizontal             "	.B	0	.W	2500*FACMMPT,1760*FACMMPT	.ASCIZ	"B6 vertical               "	.B	0	.W	1250*FACMMPT,1760*FACMMPT	.ASCIZ	"B6 horizontal             "	.B	1	.W	1760*FACMMPT,1250*FACMMPT	.ASCIZ	"C5 vertical               "	.B	0	.W	1620*FACMMPT,2290*FACMMPT	.ASCIZ	"C5 horizontal             "	.B	0	.W	2290*FACMMPT,1620*FACMMPT	.ASCIZ	"C6 vertical               "	.B	0	.W	1140*FACMMPT,1620*FACMMPT	.ASCIZ	"C6 horizontal             "	.B	1	.W	1620*FACMMPT,1140*FACMMPT	.ASCIZ	"E6 vertical               "	.B	0	.W	1400*FACMMPT,2000*FACMMPT	.ASCIZ	"E6 horizontal             "	.B	1	.W	2000*FACMMPT,1400*FACMMPT	.ASCIZ	"US letter vertical        "	.B	0	.W	2160*FACMMPT,2790*FACMMPT	.ASCIZ	"US letter horizontal      "	.B	1	.W	2790*FACMMPT,2160*FACMMPT	.ASCIZ	"autre ...                 "	.B	0	.W	0,0LDBDFPPAP =	(.-TDBDFPPAP)/32TDBOX_DEFPAGE:	.W	10$-TDBOX_DEFPAGE	.W	20$-TDBOX_DEFPAGE	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Format d'une page :"	.B	ODBTABX,24+2	.B	ODBTEXT	.ASCIZ	"Largeur"	.B	ODBLABEL,100	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTABX,24+2+22	.B	ODBLABEL,202	.B	ODBTEXT,0	.B	ODBTABX,24+2+22+24+1	.B	ODBCR,ODBCR	.B	ODBLABEL,200	.B	ODBTEXT,0	.B	ODBTABX,24+2	.B	ODBTEXT	.ASCIZ	"Hauteur"	.B	ODBLABEL,101	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,101,TDBNORM	.B	ODBCR,ODBCR,ODBCR	.B	ODBTABX,24+2	.B	ODBTEXT	.ASCIZ	"Marges :"	.B	ODBCR,ODBCR	.B	ODBTABX,24+2	.B	ODBTEXT	.ASCIZ	"Gauche "	.B	ODBLABEL,102	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,102,TDBNORM	.B	ODBCR,ODBCR	.B	ODBTABX,24+2	.B	ODBTEXT	.ASCIZ	"Droite "	.B	ODBLABEL,103	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,103,TDBNORM	.B	ODBCR,ODBCR	.B	ODBTABX,24+2	.B	ODBTEXT	.ASCIZ	"Sup.   "	.B	ODBLABEL,104	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,104,TDBNORM	.B	ODBTABX,24	.B	ODBLABEL,201	.B	ODBTEXT,0	.B	ODBTABX,24+2+22+24-1	.B	ODBLABEL,203	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	" "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	ODBTABX,24+2	.B	ODBTEXT	.ASCIZ	"Inf.   "	.B	ODBLABEL,105	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,105,TDBNORM	.B	ODBTABX,24+2+22	.B	ODBBOX,0,F4,TDBOMBRE	.ASCIZ	"   CHOIX IMPRIMANTE   "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Choix"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_DEFPAGE:	.W	F1,F2,F3,0		DOKF1-TKEY_DEFPAGE	.W	F4,F5,F6,0		DOKF4-TKEY_DEFPAGE	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_DEFPAGE	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_DEFPAGE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_DEFPAGE	.W	0;------------\\; DBOXDEFUNIT >;============/; Demande les dfinitions d'unit.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXDEFUNIT:	PUSHM.L	D1,D2,D4,D5,A1..A4	CLR.L	D4	LOAD.W	D3,(A6)+OUNIT	TSET.L	D4:D3	LOAD.L	A2,#R16"TDBOX_DEFUNIT	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$LOOP$:	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_DEFUNIT	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP',EQ DAC$	COMP.W	D3,#F0	JUMP',EQ CANCEL$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$DAC$:				; D'ACCORD =>	LOAD.W	D1,#-1ULOOP$:	INC.W	D1	RR.W	D4,#1	JUMP,CC ULOOP$	LOAD.W	(A6)+OUNIT,D1CANCEL$:			; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_DEFUNIT:	.W	10$-TDBOX_DEFUNIT	.W	20$-TDBOX_DEFUNIT	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Dfinition de l'unit de travail :"	.B	ODBCR,ODBCR	.B	ODBLCIRCLE,UNITMM	.ASCIZ	" mm  (millimtre)"	.B	ODBTABX,26	.B	ODBLCIRCLE,UNITDI	.ASCIZ	" di  (didot)"	.B	ODBCR	.B	ODBLCIRCLE,UNITCM	.ASCIZ	" cm  (centimtre)"	.B	ODBTABX,26	.B	ODBLCIRCLE,UNITCI	.ASCIZ	" ci  (cicro)"	.B	ODBCR	.B	ODBLCIRCLE,UNITIN	.ASCIZ	" in  (pouce)"	.B	ODBTABX,26	.B	ODBLCIRCLE,UNITPI	.ASCIZ	" pi  (pica)"	.B	ODBCR	.B	ODBLCIRCLE,UNITPT	.ASCIZ	" pt  (point interne)"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	"  ANNULE  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_DEFUNIT:	.W	F1,F2,F3,CR,0		DOKF1-TKEY_DEFUNIT	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_DEFUNIT	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_DEFUNIT	.W	0;------------\\; DBOXDEFMOUS >;============/; Demande les dfinitions pour la souris.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXDEFMOUS:	PUSHM.L	D1,D2,D4,D5,A1..A4	CLR.L	D4	LOAD.W	D4,(A6)+ODEF	; D4 <-- dfinitions gnrales	LOAD.L	A2,#R16"TDBOX_DEFMOUS	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	TEST.L	(A6)+OPHELP	; fichier d'aide charg ?	JUMP',NE LOOP$		; oui => LOOP$	PUSH.L	D4	LOAD.W	D2,#BDEFHELP!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO		; grise "aide"	POP.L	D4	TCLR.L	D4:#BDEFHELPLOOP$:	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_DEFMOUS	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP',EQ DAC$	COMP.W	D3,#F0	JUMP',EQ CANCEL$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$DAC$:				; D'ACCORD =>	LOAD.W	(A6)+ODEF,D4	; ODEF <-- dfinitions gnralesCANCEL$:			; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_DEFMOUS:	.W	10$-TDBOX_DEFMOUS	.W	20$-TDBOX_DEFMOUS	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Dfinitions pour la souris :"	.B	ODBCR,ODBCR	.B	ODBLABEL,BDEFHELP	.B	ODBSQUARE,BDEFHELP	.ASCIZ	" textes d'aide pour les icnes"	.B	ODBCR	.B	ODBSQUARE,BDEFMDC	.ASCIZ	" mmorise la dernire case dans les menus"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	"  ANNULE  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_DEFMOUS:	.W	F1,F2,F3,CR,0		DOKF1-TKEY_DEFMOUS	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_DEFMOUS	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_DEFMOUS	.W	0;------------\\; DBOXDEFCOUL >;============/; Choix des couleurs.; in	-; out	D7.W	erreur; mod	D7.WDBOXDEFCOUL:	PUSHM.L	D4,D5,A3,A5	CALL	DBOXOPEN1	LOAD.L	D4,#2^BICMPAL	LOAD.L	D5,(A6)+OIDCRET	LOAD.L	A3,#R16"NAME$	CALL	DBOXGTCOUL	; A5 <-- ^table TCOUL	ICOL_	MODCRET		; modifie la CRET ...	LOAD.L	(A6)+OIDCRET,D5	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7	POPM.L	D4,D5,A3,A5	TEST.W	D7		; retour EQ/NE	RETNAME$:	.ASCIZE	"PAGE"DBOXGTCOUL:	LOAD.L	A5,#R16"TCOUL$	RETTCOUL$:	.L	COLORFPAGE	.W	-1,-1,-1	.ASCIZE	"fond de la page"	.L	COLORSELECT	.W	-1,0,0	.ASCIZE	"slections (avec le bouton de droite)"	.L	COLORCDRAW	.W	0,0,0	.ASCIZE	"chair dessin"	.L	COLORFDRAW	.W	-1,-1,-1	.ASCIZE	"fond dessin"	.L	COLORCINFO	.W	-1,0,0	.ASCIZE	"texte des informations (tout en haut)"	.L	COLORFINFO	.W	-1,-1,0	.ASCIZE	"fond des informations"	.L	COLORCHELP	.W	0,0,0	.ASCIZE	"textes d'aide"	.L	COLORFHELP	.W	0,-1,-1	.B	1	.ASCIZE	"fond des aides"	.L	COLORCIN1	.W	0,0,0	.ASCIZE	"dessin des outils"	.L	COLORFIN1	.W	-1,-1,-1	.ASCIZE	"fond   des outils"	.L	COLORCIN2	.W	0,0,0	.ASCIZE	"dessin des sous-outils ou des objets"	.L	COLORFIN2	.W	-1,-1,-1	.ASCIZE	"fond   des sous-outils ou des objets"	.L	COLORCIN3	.W	0,0,0	.ASCIZE	"dessin des choix"	.L	COLORFIN3	.W	-1,-1,-1	.ASCIZE	"fond   des choix"	.L	COLORCIN4	.W	0,0,0	.ASCIZE	"dessin des actions"	.L	COLORFIN4	.W	-1,-1,-1	.ASCIZE	"fond   des actions"	.L	0;-----------\\; DBOXDEFOBJ >;===========/; Demande les dfinitions pour les objets.; in	-; out	D3.W	dernire touche;	A3.L	^noms des objets;	D7.W	erreur; mod	D3.L, D7.W, A3.L; Variables en accord avec DEF$ (voir plus loin) :	.PC	PCVAR	.LOC	0	.BLKB	5		; longueur pour "99 - "ODBDONM:.BLKB	7		; longueur pour "ABCDE :"ODBDOUS:.BLKB	1		; 0/SPACE	.BLKB	8		; longueur pour "utilis<0>"ODBDODC:.BLKB	1		; 1 => objet impossible  dconnecterODBDORG:.BLKB	1		; rang (0..n)LDBDO:	.PC	PCCODEDBOXDEFOBJ:	PUSHM.L	D0..D2,D4,D5,A0..A2,A4,A5	LOAD.L	A5,A6		; A5 <-- ^variables pour put/get	LOAD.L	A2,#R16"TDBOX$	CALL	DBOXMEMPT	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur fentre	LOAD.L	A2,#R16"TDBOX_DEFOBJ	LOAD.W	D2,#2^BDBSAV	CLR.L	D4	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	CALL	DBDFOLIST	; A2/D2 <-- liste des objets	JUMP,NE CANCEL$	CALL	DBDFODRAW	; dessine la scroll-list	CALL	DBDFORMAJ	; mj les rangs en ASCII	CALL	DBDFOUPDATE	; mj la scroll-list	LOAD.L	A3,#(A6)+ODBLIN	CLR.B	(A3)	CLR.W	D2	CALL	DBOXAFF		; affiche les flches +/-FAN$:	LOAD.W	D2,#100!2^BDBGCLABEL!2^BDBGCFULL	LOAD.W	D1,#B'01	; D1 <-- fanion "n'utilise pas"	LOAD.W	D3,(A6)+ODBSLV+OSLCYS	CALL	DBDFOGET	; A3 <-- ^case	TEST.B	(A3)+ODBDOUS	; objet utilis ?	JUMP',EQ GREY$		; non => GREY$	LOAD.W	D1,#B'10	; D1 <-- fanion "utilise"	TEST.B	(A3)+ODBDODC	; objet dconnectable ?	JUMP',EQ GREY$	LOAD.W	D2,#100!2^BDBGCLABEL!2^BDBGCGREYGREY$:	DBOX_	GETCO		; grise/dgrise "n'utilise pas"IFEDIT$:	LOAD.W	D3,(A6)+ODBSLV+OSLCYS	CALL	DBDFOGET	; A3 <-- ^case	TEST.B	(A3)+ODBDOUS	; objet utilis ?	JUMP',EQ NOEDIT$	; non => NOEDIT$EDIT$:	LOAD.W	D2,#50!2^BDBGCLABEL!2^BDBGCFULL	DBOX_	GETCO	LOAD.W	D2,#51!2^BDBGCLABEL!2^BDBGCFULL	DBOX_	GETCO	LOAD.W	D2,#52!2^BDBGCLABEL!2^BDBGCFULL	DBOX_	GETCO	CLR.W	D4	LOAD.B	D4,(A3)+ODBDORG	INC.B	D4	LOAD.W	(A6)+ORANG,D4	CLR.W	D2	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXAFF		; affiche le paramtre	CALL	DBOXMEDIT	JUMP'	LOOP$NOEDIT$:	LOAD.W	D2,#50!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#51!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#52!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#51!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.ASCIZE	"  "		; efface l'ancien chiffre	LOAD.W	D2,#-1	CALL	DBOXMEDIT	; y'a rien d'ditable;	JUMP'	LOOP$LOOP$:	LOAD.L	D4,D1	DBOX_	EDIT		; attend action ...	LOAD.L	D1,D4	TEST.L	D1:#1		; rang ditable (utilise) ?	JUMP',BC ZERO$		; non => ZERO$	CALL	ZEROCRZERO$:	PUSH.W	D1	LOAD.L	A1,#R16"TKEY_DEFOBJ	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	POP.W	D1	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP',EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ DAC$	COMP.W	D3,#F0	JUMP,EQ CANCEL$	LOAD.W	D0,D3	AND.W	D0,#H'FF00	COMP.W	D0,#KEYDBOX	JUMP',EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$KEYDBOX$:			; KEYDBOX =>	CALL	DBDFORMOD	; mj d'aprs le rang dit	LOAD.W	D4,D3	LOAD.W	D3,(A6)+ODBSLV+OSLCYS	CALL	DBDFOGET	; A3 <-- ^case	TEST.B	D4	JUMP',EQ KDEL$KNEW$:	TEST.B	(A3)+ODBDOUS	JUMP,NE IFEDIT$	LOAD.B	(A3)+ODBDOUS,#SPACE ; objet utilis	CALL	DBDFORNEW	; donne un nouveau rang	CALL	DBDFOUPDATE	; mj la scroll-list	JUMP	IFEDIT$KDEL$:	TEST.B	(A3)+ODBDOUS	JUMP,EQ IFEDIT$	CLR.B	(A3)+ODBDOUS	; objet libre	CALL	DBDFORDEL	; supprime un rang	CALL	DBDFOUPDATE	; mj la scroll-list	JUMP	IFEDIT$CLIC$:	CLR.W	D0	TEST.L	D1:#1		; rang ditable (utilise) ?	JUMP',BC CSL$		; non => CSL$	CLR.W	D2	CALL	DBOXCLIC	; action dans les flches +/-	JUMP,EQ LOOP$	CALL	DBDFORMOD	; mj d'aprs le rang dit	LOAD.W	D0,D7CSL$:	LIB	?IFMOUSE	; D4 <-- position de la souris (y;x)	JUMP',NE CBIP$	SUB.W	D4,(A0)+ODFFX	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	SWAP.W	D4	CALL	DBDFOMOVE	; dplace la scroll-liste ...	JUMP',NE CBIP$	TEST.W	D0	JUMP,EQ FAN$	CALL	DBDFOUPDATE	; mj la scroll-list	JUMP	FAN$CBIP$:	TEST.W	D0	JUMP,EQ BIP$	CALL	DBDFOUPDATE	; mj la scroll-list	JUMP	BIP$DAC$:				; D'ACCORD =>	CALL	DBDFORMOD	; mj d'aprs le rang dit	CALL	DBDFODONE	; A3 <-- ^liste des noms	CLR.W	D7		; D7 <-- okCANCEL$:			; ANNULE =>	PUSH.W	D7	CALL	DBOXCLOSE	; ferme la DBOX	POP.W	D7EXIT$:	POPM.L	D0..D2,D4,D5,A0..A2,A4,A5	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	ORANG,DBTYPN,1,99,1,2^BDBGCLABEL!51,0,2+2	.W	-1;----------\\; DBDFOLIST >;----------/; Fait la liste de tous les objets dans le dossier systme.; in	-; out	A2.L	^liste;	D2.W	nb de fichiers trouvs (0..n);	D7.W	erreur; mod	D2.L, D7.W, A2.LDBDFOLIST:	PUSHM.L	D1,D3..D6,A1,A3,A4	CALL	__WAITMOUSE	; met le sablier	LOAD.L	A3,#R16"DIR$	LOAD.L	A4,#R16"CRIT$	LOAD.W	D3,#2^BOPSYS	FOS	?LISTOPEN	JUMP,NE EXIT9$	LOAD.W	D7,#ERFDNE	LOAD.W	D2,D4		; D2 <-- nb de fichiers trouvs	JUMP,EQ EXIT8$	LOAD.L	A1,#(A6)+OIOTM	; A1 <-- ^liste	LOAD.W	D1,D2LOOP$:	FOS	?LISTNXT	; A3/A4 <-- ^nom/^arguments	JUMP',NE EXIT8$	DEC.W	D2		; D2 <-- nb compte pas l'objet GROUP	LOAD.L	A4,#R16"GROUP$	LOAD.L	A2,#R16"TERM$	LIB	?CPSTRING	; est-ce l'objet GROUP ?	JUMP',EQ NEXT$		; oui => NEXT$ (ignore-le)	INC.W	D2	LOAD.L	A4,A1	LOAD.L	A2,#R16"DEF$NAME1$:	LOAD.B	(A4+),(A2+)	JUMP,NE NAME1$	LOAD.L	A4,#(A1)+ODBDONM	ADD.L	A3,#4		; A3 <-- saute "GRA_"NAME2$:	LOAD.B	D3,(A3+)	COMP.B	D3,#'.	JUMP',EQ NAME4$	LOAD.B	(A4+),D3	JUMP	NAME2$NAME4$:	LOAD.L	A1,#(A1)+LDBDONEXT$:	DEC.W	D1	JUMP,NE LOOP$	LOAD.L	A2,#(A6)+OIOTM	; A2 <-- ^liste	CALL	DBDFOUSE	CALL	DBDFORINIT	CLR.W	D7		; D7 <-- okEXIT8$:	PUSH.W	D7	FOS	?LISTCLOSE	POP.W	D7EXIT9$:	CALL	__NORMMOUSE	; enlve le sablier	POPM.L	D1,D3..D6,A1,A3,A4	TEST.W	D7		; retour EQ/NE	RETDIR$:	.ASCIZ	""CRIT$:	.ASCIZ	"GRA_*.OPAGE"GROUP$:	.ASCIZ	"GRA_GROUP.OPAGE"TERM$:	.B	0,-1		;99 - ABCDE : utilis<0>DEF$:	.ASCIZ	"           : utilise"	.EVEN;---------\\; DBDFOUSE >;---------/; Indique quels sont les objets utiliss.; in	A2.L	^liste;	D2.W	nb de fichiers trouvs (0..n); out	-; mod	D7.WDBDFOUSE:	PUSHM.L	D0..D3,D6,A2..A4	TEST.W	D2	JUMP',EQ EXIT$LOOP$:	CLR.B	(A2)+ODBDODC	; objet dconnectable	LOAD.L	A3,#(A2)+ODBDONM ; A3 <-- ^nom	LOAD.W	D3,#TYPOBEDIT	CALL	OBJIFCON	; objet connect ?	JUMP',EQ CON$		; oui => CON$	CLR.B	(A2)+ODBDOUS	; objet libre	JUMP'	NEXT$CON$:	LOAD.L	D6,(A6)+OOBACH	LOAD.W	D3,#-1	CALL	__LSTA_FIRST	; A4 <-- ^premier objet	JUMP',NE NEXT$CLOOP$:	COMP.W	D0,(A4)+OobjIDENT	JUMP',EQ USE$	CALL	__LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ CLOOP$	JUMP'	NEXT$USE$:	SET.B	(A2)+ODBDODC	; objet impossible  dconnecterNEXT$:	LOAD.L	A2,#(A2)+LDBDO	DEC.W	D2	JUMP,NE LOOP$EXIT$:	POPM.L	D0..D3,D6,A2..A4	RET;-----------\\; DBDFORINIT >;-----------/; Indique les rangs des objets utiliss.; in	A2.L	^liste;	D2.W	nb de fichiers trouvs (0..n); out	-; mod	D7.WDBDFORINIT:	PUSHM.L	D0,D2..D4,A2..A4	TEST.W	D2	JUMP',EQ EXIT$LOOP$:	CLR.B	(A2)+ODBDORG	LOAD.L	A3,#(A2)+ODBDONM ; A3 <-- ^nom	LOAD.W	D3,#TYPOBEDIT	CALL	OBJIFCON	; objet connect ?	JUMP',NE NEXT$		; non => NEXT$	LOAD.L	A4,#(A6)+ORICO	CLR.B	D4SRC$:	TEST.B	(A4)		; fin de la table ?	JUMP',EQ NEXT$		; oui => NEXT$	INC.B	D4	COMP.B	D0,(A4+)	; identificateur trouv ?	JUMP,NE SRC$		; non => SRC$	DEC.B	D4	LOAD.B	(A2)+ODBDORG,D4NEXT$:	LOAD.L	A2,#(A2)+LDBDO	DEC.W	D2	JUMP,NE LOOP$EXIT$:	POPM.L	D0,D2..D4,A2..A4	RET;----------\\; DBDFORNEW >;----------/; Met  jour le rang aprs avoir connect un nouvel objet.; in	-; out	-; mod	D7.WDBDFORNEW:	PUSHM.L	D3,D4,A3	LOAD.W	D3,(A6)+ODBSLV+OSLCYS	CALL	DBDFOGET	; A3 <-- ^case	CALL	DBDFOCNTU	; D4 <-- nb d'objets connects	DEC.B	D4	LOAD.B	(A3)+ODBDORG,D4	CALL	DBDFORMAJ	; met  jour les rangs en ASCII	POPM.L	D3,D4,A4	RET;----------\\; DBDFORDEL >;----------/; Met  jour le rang aprs avoir dconnect un objet.; in	-; out	-; mod	D7.WDBDFORDEL:	PUSHM.L	D2,D3,A2,A3	LOAD.W	D3,(A6)+ODBSLV+OSLCYS	CALL	DBDFOGET	; A3 <-- ^case	LOAD.B	D3,(A3)+ODBDORG	LOAD.W	D2,(A6)+ODBSLV+OSLCYN	JUMP',EQ END$	LOAD.L	A2,#(A6)+OIOTMLOOP$:	TEST.B	(A2)+ODBDOUS	; objet utilis ?	JUMP',EQ NEXT$		; non => NEXT$	COMP.B	D3,(A2)+ODBDORG	JUMP',HI NEXT$	DEC.B	(A2)+ODBDORGNEXT$:	LOAD.L	A2,#(A2)+LDBDO	DEC.W	D2	JUMP,NE LOOP$END$:	CALL	DBDFORMAJ	; met  jour les rangs en ASCII	POPM.L	D2,D3,A2,A3	RET;----------\\; DBDFORMOD >;----------/; Met  jour les rangs aprs la modification d'un seul.; in	A3.L	^rang en ASCII; out	D7.W	NE si qq chose de chang; mod	D7.WDBDFORMOD:	PUSHM.L	D2..D4,A2,A3	LOAD.L	A2,A3		; A2 <-- ^rang en ASCII	LOAD.W	D3,(A6)+ODBSLV+OSLCYS	CALL	DBDFOGET	; A3 <-- ^case	TEST.B	(A3)+ODBDOUS	; objet utilis ?	JUMP,EQ IDEM$		; non => IDEM$	EX.L	A3,A2	CLR.W	D2	CALL	DBOXPUT		; mj le rang ditable	JUMP,NE IDEM$	EX.L	A2,A3	LOAD.W	D3,(A6)+ORANG	; D3 <-- nouveau rang (1..n)	DEC.W	D3		; D3 <-- nouveau rang (0..n)	JUMP,NS IDEM$	CALL	DBDFOCNTU	; D4 <-- nb d'objets connects	COMP.W	D3,D4		; dpasse le maximum possible ?	JUMP',LO MAX$		; non => MAX$	LOAD.W	D3,D4	DEC.W	D3		; D3 <-- rang maximum possibleMAX$:	COMP.B	D3,(A3)+ODBDORG	; rang chang ?	JUMP',EQ IDEM$		; non => IDEM$	LOAD.W	D2,(A6)+ODBSLV+OSLCYN	JUMP',EQ END$	LOAD.L	A2,#(A6)+OIOTMLOOP$:	TEST.B	(A2)+ODBDOUS	; objet utilis ?	JUMP',EQ NEXT$		; non => NEXT$	COMP.B	D3,(A2)+ODBDORG	; rang trouv ?	JUMP',EQ CHANGE$	; oui => CHANGE$NEXT$:	LOAD.L	A2,#(A2)+LDBDO	DEC.W	D2	JUMP,NE LOOP$	JUMP'	END$CHANGE$:	LOAD.B	(A2)+ODBDORG,(A3)+ODBDORG ; permuteEND$:	LOAD.B	(A3)+ODBDORG,D3	CALL	DBDFORMAJ	; met  jour les rangs en ASCII	LOAD.W	D7,#1		; D7 <-- qq chose de chang	JUMP'	EXIT$IDEM$:	CLR.W	D7		; D7 <-- rien de changEXIT$:	POPM.L	D2..D4,A2,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBDFORMAJ >;----------/; Met  jour tous les rangs en ASCII.; in	-; out	-; mod	D7.WDBDFORMAJ:	PUSHM.L	D0..D4,A2,A4	LOAD.W	D1,(A6)+ODBSLV+OSLCYN	JUMP',EQ EXIT$	LOAD.L	A2,#(A6)+OIOTMLOOP$:	LOAD.B	(A2),#SPACE	LOAD.B	(A2)+1,#SPACE	LOAD.B	(A2)+3,#SPACE	TEST.B	(A2)+ODBDOUS	; objet utilis ?	JUMP',EQ NEXT$		; non => NEXT$	CLR.L	D4	LOAD.B	D4,(A2)+ODBDORG	INC.B	D4		; D4 <-- rang (1..n)	LOAD.L	A4,A2	LOAD.W	D3,#2		; D3 <-- 2 digits	CLR.W	D2		; D2 <-- mode	LIB	?PUTDEC		; liste <-- numro en ASCII	LOAD.B	(A4+),#SPACE	LOAD.B	(A4),#'-NEXT$:	LOAD.L	A2,#(A2)+LDBDO	DEC.W	D1	JUMP,NE LOOP$EXIT$:	POPM.L	D0..D4,A2,A4	RET;----------\\; DBDFOCNTU >;----------/; Compte le nombre d'objets connects.; in	-; out	D4.W	nb d'objets connects (0..n); mod	D4.L, D7.WDBDFOCNTU:	PUSHM.L	D2,A2	CLR.W	D4	LOAD.W	D2,(A6)+ODBSLV+OSLCYN	JUMP',EQ EXIT$	LOAD.L	A2,#(A6)+OIOTMLOOP$:	TEST.B	(A2)+ODBDOUS	; objet utilis ?	JUMP',EQ NEXT$		; non => NEXT$	INC.W	D4		; D4 <-- un objet de plus connectNEXT$:	LOAD.L	A2,#(A2)+LDBDO	DEC.W	D2	JUMP,NE LOOP$EXIT$:	POPM.L	D2,A2	RET;----------\\; DBDFODONE >;----------/; Prpare la liste des noms.; in	-; out	A3.L	^liste des noms; mod	D7.W, A3.LDBDFODONE:	PUSHM.L	D3,D4,A4	LOAD.L	A3,#(A6)+OIOTM+LTMIO/2 ; A3 <-- ^buffer o mettre la liste	TEST.W	(A6)+ODBSLV+OSLCYN	JUMP',EQ END$	CLR.W	D3		; D3 <-- rang cherchSLOOP$:	LOAD.L	A4,#(A6)+OIOTM	LOAD.W	D4,(A6)+ODBSLV+OSLCYNSSLOOP$:	TEST.B	(A4)+ODBDOUS	; objet utilis ?	JUMP',EQ SSNEXT$	; non => SSNEXT$	COMP.B	D3,(A4)+ODBDORG	; est-ce le bon rang ?	JUMP',NE SSNEXT$	; non => SSNEXT$	CALL	DBDFODONEPUT	; liste <-- nom	CLR.B	(A4)+ODBDOUS	; plus utilis !SSNEXT$:	LOAD.L	A4,#(A4)+LDBDO	DEC.W	D4	JUMP,NE SSLOOP$SNEXT$:	INC.W	D3	COMP.W	D3,(A6)+ODBSLV+OSLCYN	JUMP,LO SLOOP$END$:	LOAD.L	A4,#R16"GROUP$	LOAD.L	A4,#(A4)-ODBDONM	CALL	DBDFODONEPUT	; liste <-- "GROUP"	CLR.B	(A3+)	LOAD.L	A3,#(A6)+OIOTM+LTMIO/2 ; A3 <-- ^liste des noms	POPM.L	D3,D4,A4	RETGROUP$:	.ASCIZ	"GROUP"	.EVEN;-------------\\; DBDFODONEPUT >;-------------/; Met un nom dans la liste.; in	A4.L	^lment;	A3.L	^fin de la liste; out	A3.L	^plus loin; mod	D7.W, A3.LDBDFODONEPUT:	PUSHM.L	D3,A2	LOAD.L	A2,#(A4)+ODBDONMLOOP$:	LOAD.B	D3,(A2+)	COMP.B	D3,#SPACE	JUMP',EQ END$	LOAD.B	(A3+),D3	; liste <-- nom	JUMP	LOOP$END$:	CLR.B	(A3+)	POPM.L	D3,A2	RET;----------\\; DBDFODRAW >;----------/; Dessine la scroll-liste.; in	A2.L	^liste;	D2.W	nb de fichiers trouvs (0..n); out	-; mod	D7.WDBDFODRAW:	PUSHM.L	D2..D4,A5	LOAD.L	A5,#(A6)+ODBSLV	; A5 <-- ^variables scroll-liste	LOAD.W	(A5)+OSLCYN,D2	CLR.W	(A5)+OSLCYS	LOAD.W	D2,#200!2^BDBGCLABEL	DBOX_	GETCO	SWAP.W	D3	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,(A0)+ODFC2Y	SWAP.W	D3	LOAD.L	(A5)+OSLPOS,D3	LOAD.W	D2,#201!2^BDBGCLABEL	DBOX_	GETCO	SUB.W	D3,(A5)+OSLPOS+2	SWAP.W	D3	ADD.W	D3,(A0)+ODFC2Y	SUB.W	D3,(A5)+OSLPOS+0	SWAP.W	D3	LOAD.L	(A5)+OSLDIM,D3	CLR.B	(A5)+OSLVID	CLR.B	(A5)+OSLHOR	SCROLL_	LDRAW		; dessine la scroll-liste	POPM.L	D2..D4,A5	RET;------------\\; DBDFOUPDATE >;------------/; Dessine la scroll-liste.; in	-; out	-; mod	D7.WDBDFOUPDATE:	PUSHM.L	A3,A5	LOAD.L	A5,#(A6)+ODBSLV	; A5 <-- ^variables scroll-liste	LOAD.L	A3,#R16"DBDFOGET	LOAD.L	(A5)+OSLADL,A3	SCROLL_	LUPDATE		; dessine le contenu	POPM.L	A3,A5	RET;---------\\; DBDFOGET >;---------/; Donne le texte  mettre dans la scroll-liste.; in	D3.W	rang de la case (0..n); out	A3.L	^contenu;	D3.W	ligne; mod	D3.L, D7.W, A3.LDBDFOGET:	LOAD.L	A3,#(A6)+OIOTM	MUL.WU	D3,#LDBDO	ADD.L	A3,D3	CLR.W	D3	CLR.W	D7		; retour EQ	RET;----------\\; DBDFOMOVE >;----------/; Dplace la scroll-liste.; in	D4.L	position de la souris (y;x);	D2.L	fanions; out	D2.L	fanions;	D7.W	erreur; mod	D2.L, D7.WDBDFOMOVE:	PUSH.L	A5	LOAD.L	A5,#(A6)+ODBSLV	; A5 <-- ^variables scroll-liste	SCROLL_	LMOVE		; dplace la scroll-liste	POP.L	A5	TEST.W	D7		; retour EQ/NE	RETTDBOX_DEFOBJ:	.W	10$-TDBOX_DEFOBJ	.W	20$-TDBOX_DEFOBJ	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Choix des objets  utiliser :"	.B	ODBCR,ODBCR	.B	ODBLABEL,200	.B	ODBTEXT,0	.B	ODBTABX,25+3	.B	ODBLCIRCLE,1!2^7,KEYDBOX/H'100,1	.ASCIZ	" utilise"	.B	ODBCR	.B	ODBTABX,25+3	.B	ODBLABEL,100	.B	ODBLCIRCLE,0!2^7,KEYDBOX/H'100,0	.ASCIZ	" n'utilise pas"	.B	ODBCR,ODBCR,ODBCR,ODBCR2	.B	ODBTABX,25+3	.B	ODBLABEL,50	.B	ODBTEXT	.ASCIZ	"Position "	.B	ODBLABEL,51	.B	ODBCLINE,2+2	.B	ODBCR,ODBCR2	.B	ODBTABX,25+3	.B	ODBLABEL,52	.B	ODBTEXT	.ASCIZ	"(dans les icnes)"	.B	ODBCR	.B	ODBTABX,25	.B	ODBLABEL,201	.B	ODBTEXT,0	.B	ODBCR,ODBCR,ODBCR2	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" UTILISE "	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Utilise"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_DEFOBJ:	.W	F1,F2,F3,0		DOKF1-TKEY_DEFOBJ	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_DEFOBJ	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_DEFOBJ	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_DEFOBJ	.W	0;------------\\; DBOXDEFDUPL >;============/; Choix du dplacement lors d'un duplique.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXDEFDUPL:	PUSHM.L	D0..D2,D4,D5,A1..A5	LOAD.L	A5,A6		; A5 <-- ^variables pour put/get	LOAD.L	A2,#R16"TDBOX$	CALL	DBOXMEMPT	LOAD.L	A2,#R16"TDBOX_DEFDUPL	LOAD.W	D2,#2^BDBSAV	CLR.L	D4		; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	CLR.W	D2AFF$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXAFF		; affiche le paramtre	INC.W	D2	COMP.W	D2,#2	JUMP,LO AFF$	CLR.W	D2NLINE$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXMEDITLOOP$:	DBOX_	EDIT		; attend action ...	CALL	ZEROCR	LOAD.L	A1,#R16"TKEY_DEFDUPL	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ DAC$	COMP.W	D3,#F0	JUMP,EQ CANCEL$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#CLEAR	JUMP',EQ UNDO$	COMP.W	D3,#CR	JUMP',EQ RETURN$	COMP.W	D3,#ENTER	JUMP',EQ RETURN$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP',EQ KEYDBOX$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	CALL	DBOXPUT	JUMP,NE BIP$	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,#2	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$KEYDBOX$:			; KEYDBOX =>	CALL	DBOXPUT	JUMP,NE BIP$	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$CLIC$:	CALL	DBOXCLIC	; action dans les flches +/-	JUMP,NE BIP$	JUMP	NLINE$DAC$:				; D'ACCORD =>	CALL	DBOXPUT	JUMP,NE BIP$CANCEL$:			; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A1..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	OSELDD+2,DBTYPUS,-1000*FACMMPT,+1000*FACMMPT,10*FACMMPT,2^BDBGCLABEL!100,0,8+2	.W	OSELDD+0,DBTYPUS,-1000*FACMMPT,+1000*FACMMPT,10*FACMMPT,2^BDBGCLABEL!101,1,8+2	.W	-1TDBOX_DEFDUPL:	.W	10$-TDBOX_DEFDUPL	.W	20$-TDBOX_DEFDUPL	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Les objets dupliqus seront dplacs"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"comme suit :"	.B	ODBCR,ODBCR,ODBCR2	.B	ODBTEXT	.ASCIZ	"Dplacement horizontal "	.B	ODBLABEL,100	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Dplacement vertical   "	.B	ODBLABEL,101	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,101,TDBNORM	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" DUPLIQUE "	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	"  ANNULE  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Duplique"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_DEFDUPL:	.W	F1,F2,F3,0		DOKF1-TKEY_DEFDUPL	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_DEFDUPL	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_DEFDUPL	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_DEFDUPL	.W	0;---------\\; DBOXGRID >;=========/; Demande le pas et la grille.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXGRID:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.L	A5,A6		; A5 <-- ^variables pour put/get	LOAD.L	A2,#R16"TDBOX$	CALL	DBOXMEMPT	LOAD.L	A2,#R16"TDBOX_GRID	LOAD.W	D2,#2^BDBSAV	LOAD.L	D4,(A6)+OGRID	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	PUSH.L	D4	LOAD.W	D2,#SETDOT	LOAD.W	D3,(A0)+ODFCX	MUL.WU	D3,#25+1-1	LOAD.W	D4,(A0)+ODFCY	MUL.WU	D4,#7	SUB.W	D4,#5	SWAP.W	D4	LIB	?DRSEG	LOAD.W	D3,(A0)+ODFCY	MUL.WU	D3,#7	SUB.W	D3,#5	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	LIB	?DRSEG	LOAD.W	D3,(A0)+ODFCY	MUL.WU	D3,#11	SUB.W	D3,#5	SWAP.W	D3	LIB	?DRSEG	POP.L	D4	CLR.W	D2REFAIT$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXAFF		; affiche le paramtreNLINE$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre;	CALL	DBOXMEDITSUBD$:	CALL	DBGRSUBD	; affieche la subdivisionLOOP$:	DBOX_	EDIT		; attend action ...	CALL	ZEROCR	LOAD.L	A1,#R16"TKEY_GRID	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ DAC$	COMP.W	D3,#F0	JUMP,EQ CANCEL$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEYDBOX$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	SUBD$KEYDBOX$:	CALL	DBOXPUT	JUMP,NE BIP$	COMP.W	D3,#KEYDBOX+100	JUMP,EQ SUBD$	LOAD.L	D1,#H'FFFFFF00	COMP.B	D3,#8	JUMP',LO KEYDBOX2$	LOAD.L	D1,#H'FFFF00FF	COMP.B	D3,#16	JUMP',LO KEYDBOX2$	LOAD.L	D1,#H'FF00FFFF;	COMP.B	D3,#24;	JUMP',LO KEYDBOX2$;	LOAD.L	D1,#H'00FFFFFFKEYDBOX2$:	AND.L	D4,D1		; D4 <-- teint toute la range	TSET.L	D4:D3		; D4 <-- allume juste le bon	JUMP	SUBD$CLIC$:	CALL	DBOXCLIC	; action dans les flches +/-	JUMP,NE BIP$	TSET.L	D4:#BGRIDPAN	TCLR.L	D4:#BGRIDPAX	TEST.W	(A6)+OPAS	JUMP,EQ NLINE$	TCLR.L	D4:#BGRIDPAN	TSET.L	D4:#BGRIDPAX	JUMP	NLINE$DAC$:				; D'ACCORD =>	CALL	DBOXPUT	JUMP,NE BIP$	LOAD.L	(A6)+OGRID,D4CANCEL$:			; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	OPAS,DBTYPU,0,1000*FACMMPT,10*FACMMPT,2^BDBGCLABEL!100,0,8+2	.W	-1;---------\\; DBGRSUBD >;---------/; Affiche la dimension d'une subdivision.; in	D5.L	canal dbox;	D4.L	fanions; out	-; mod	D7.WDBGRSUBD:	PUSHM.L	D1..D4,A3,A4	LOAD.L	D1,D4	LOAD.W	D2,#200!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A6)+OBUDIS	LOAD.L	A4,A3	LOAD.B	(A4+),#'(	LOAD.W	D4,#2	TEST.L	D1:#BGRIDMU2	JUMP',BS SUBDIV$	LOAD.W	D4,#3	TEST.L	D1:#BGRIDMU3	JUMP',BS SUBDIV$	LOAD.W	D4,#4	TEST.L	D1:#BGRIDMU4	JUMP',BS SUBDIV$	LOAD.W	D4,#5	TEST.L	D1:#BGRIDMU5	JUMP',BS SUBDIV$	LOAD.W	D4,#6	TEST.L	D1:#BGRIDMU6	JUMP',BS SUBDIV$	LOAD.W	D4,#8		; D1 <-- subdivisionSUBDIV$:	MUL.WU	D4,(A6)+OPAS	; D4 <-- pas*subdivision	CALL	_PUTUNUM	LOAD.B	(A4+),#')	LOAD.B	(A4+),#EFLI	LOAD.L	D3,A4	SUB.L	D3,A3	LIB	?STRING	POPM.L	D1..D4,A3,A4	RETTDBOX_GRID:	.W	10$-TDBOX_GRID	.W	20$-TDBOX_GRID	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Magntisme :"	.B	ODBTABX,25	.B	ODBTEXT	.ASCIZ	"Grille :"	.B	ODBCR,ODBCR2	.B	ODBLCIRCLE,BGRIDPAN!2^7!2^6,KEYDBOX/H'100,BGRIDPAN	.ASCIZ	" aucun"	.B	ODBTABX,25	.B	ODBLCIRCLE,BGRIDGRN!2^7!2^6,KEYDBOX/H'100,BGRIDGRN	.ASCIZ	" invisible"	.B	ODBCR	.B	ODBTABX,25	.B	ODBLCIRCLE,BGRIDGRL!2^7!2^6,KEYDBOX/H'100,BGRIDGRL	.ASCIZ	" dessus"	.B	ODBCR	.B	ODBLCIRCLE,BGRIDPAX!2^7!2^6,KEYDBOX/H'100,BGRIDPAX	.ASCIZ	" pas "	.B	ODBLABEL,100	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTABX,25	.B	ODBLCIRCLE,BGRIDGRF!2^7!2^6,KEYDBOX/H'100,BGRIDGRF	.ASCIZ	" dessous"	.B	ODBCR,ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Subdivisions :"	.B	ODBTABX,28	.B	ODBLABEL,200	.B	ODBTEXT,0	.B	ODBCR,ODBCR2	.B	ODBLCIRCLE,BGRIDMU2!2^7!2^6,KEYDBOX/H'100,BGRIDMU2	.ASCIZ	" 2"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBLCIRCLE,BGRIDMU3!2^7!2^6,KEYDBOX/H'100,BGRIDMU3	.ASCIZ	" 3"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBLCIRCLE,BGRIDMU4!2^7!2^6,KEYDBOX/H'100,BGRIDMU4	.ASCIZ	" 4"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBLCIRCLE,BGRIDMU5!2^7!2^6,KEYDBOX/H'100,BGRIDMU5	.ASCIZ	" 5"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBLCIRCLE,BGRIDMU6!2^7!2^6,KEYDBOX/H'100,BGRIDMU6	.ASCIZ	" 6"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBLCIRCLE,BGRIDMU8!2^7!2^6,KEYDBOX/H'100,BGRIDMU8	.ASCIZ	" 8"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	"  ANNULE  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_GRID:	.W	F1,F2,F3,CR,0		DOKF1-TKEY_GRID	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_GRID	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_GRID	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_GRID	.W	0;--------\\; DBOXVUE >;========/; Choisi le mode pour la vue.; in	-; out	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXVUE:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_VUE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+OVUE	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP',NE EXIT$	PUSH.L	D4	LOAD.W	D3,(A0)+ODFCX	MUL.WU	D3,#24-1	LOAD.W	D4,(A0)+ODFCY	MUL.WU	D4,#6	ADD.W	D4,#4	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRSEG	CLR.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	LIB	?DRSEG	LOAD.W	D3,(A0)+ODFCY	MUL.WU	D3,#11	SUB.W	D3,#5	SWAP.W	D3	LIB	?DRSEG	POP.L	D4LOOP$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_VUE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP',EQ USE$	COMP.W	D3,#F0	JUMP',EQ END$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$USE$:	LOAD.L	(A6)+OVUE,D4END$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_VUE:	.W	10$-TDBOX_VUE	.W	20$-TDBOX_VUE	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Calque actif :"	.B	ODBTABX,24	.B	ODBTEXT	.ASCIZ	"Autres calques :"	.B	ODBCR,ODBCR2	.B	ODBSQUARE,BVUEPEN	.ASCIZ	" traits rels"	.B	ODBTABX,24	.B	ODBSQUARE,BVUECPEN	.ASCIZ	" traits rels"	.B	ODBCR	.B	ODBSQUARE,BVUETRAME	.ASCIZ	" trames relles"	.B	ODBTABX,24	.B	ODBSQUARE,BVUECTRAME	.ASCIZ	" trames relles"	.B	ODBCR	.B	ODBSQUARE,BVUECHAR	.ASCIZ	" caractres rels"	.B	ODBTABX,24	.B	ODBSQUARE,BVUECCHAR	.ASCIZ	" caractres rels"	.B	ODBCR,ODBCR2	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"Repres pour les"	.B	ODBTABX,18	.B	ODBSQUARE,BVUEREPMARG	.ASCIZ	" marges"	.B	ODBCR	.B	ODBTABX,18	.B	ODBSQUARE,BVUEREPCOL	.ASCIZ	" colonnes"	.B	ODBCR	.B	ODBTABX,18	.B	ODBSQUARE,BVUEGROUP	.ASCIZ	" groupes"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_VUE:	.W	F1,F2,F3,0		DOKF1-TKEY_VUE	.W	F0,F13,F14,F15,0	DOKF0-TKEY_VUE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_VUE	.W	0;-------------\\; DBOXCOLONNES >;=============/; Demande le nombre de colonnes.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXCOLONNES:	PUSHM.L	D0..D2,D4,D5,A1..A5	LOAD.L	A5,A6		; A5 <-- ^variables pour put/get	LOAD.L	A2,#R16"TDBOX$	CALL	DBOXMEMPT	LOAD.L	A2,#R16"TDBOX_COLONNES	LOAD.W	D2,#2^BDBSAV	LOAD.L	D4,(A6)+OCOLFA	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	LOAD.W	D2,#2^BDBGCLABEL!200	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	LOAD.W	D2,#2^BDBGCLABEL!201	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	LOAD.W	D2,#2^BDBGCLABEL!202	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	CLR.W	D2REFAIT$:	PUSH.W	D2	CLR.W	D2AFF$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXAFF		; affiche le paramtre	INC.W	D2	COMP.W	D2,#2	JUMP,LO AFF$	POP.W	D2NLINE$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXMEDITLOOP$:	DBOX_	EDIT		; attend action ...	CALL	ZEROCR	LOAD.L	A1,#R16"TKEY_COLONNES	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ DAC$	COMP.W	D3,#F0	JUMP,EQ CANCEL$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#CLEAR	JUMP',EQ UNDO$	COMP.W	D3,#CR	JUMP',EQ RETURN$	COMP.W	D3,#ENTER	JUMP',EQ RETURN$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP',EQ KEYDBOX$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	CALL	DBOXPUT	JUMP,NE BIP$	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,#2	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$KEYDBOX$:			; KEYDBOX =>	CALL	DBOXPUT	JUMP,NE BIP$	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$CLIC$:	CALL	DBOXCLIC	; action dans les flches +/-	JUMP,NE BIP$	JUMP	NLINE$DAC$:				; D'ACCORD =>	CALL	DBOXPUT	JUMP,NE BIP$	LOAD.L	(A6)+OCOLFA,D4	CALL	DBCOPX		; OCOLPX <-- position X des colonnes	TEST.L	D4:#BCOLMAGN	JUMP',BC CANCEL$	TSET.B	(A6)+OVUE+0:#BVUEREPCOL-24CANCEL$:			; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A1..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	OCOLNB,DBTYPN,1,10,1,2^BDBGCLABEL!100,0,3+2	.W	OCOLES,DBTYPU,0,1000*FACMMPT,10*FACMMPT,2^BDBGCLABEL!101,1,8+2	.W	-1;-------\\; DBCOPX >;-------/; Calcule les positions en X des diffrentes colonnes.; in	-; out	-; mod	D7.WDBCOPX:	PUSHM.L	D2..D4,A4	LOAD.L	A4,#(A6)+OCOLPX	CLR.L	D2	LOAD.W	D2,(A6)+ODESXD	SUB.W	D2,(A6)+ODESMG	SUB.W	D2,(A6)+ODESMD	; D2 <-- largeur pour toutes les colonnes	LOAD.W	D3,(A6)+OCOLES	LOAD.W	D4,(A6)+OCOLNB	DEC.W	D4	JUMP',LE ONE$	MUL.WU	D3,D4		; D3 <-- largeur de toutes les gouttires	SUB.W	D2,D3		; D2 <-- largeur sans les gouttires	JUMP',LE ONE$	DIV.WU	D2,(A6)+OCOLNB	; D2 <-- largeur d'une colonne	LOAD.W	D3,(A6)+ODESMG	; D3 <-- origine en X	LOAD.W	D4,(A6)+OCOLNB	; D4 <-- nb de colonnesLOOP$:	LOAD.W	(A4+),D3	; OCOLPX <-- dbut colonne	ADD.W	D3,D2	LOAD.W	(A4+),D3	; OCOLPX <-- fin colonne	ADD.W	D3,(A6)+OCOLES	; D3 <-- origine suivante en X	DEC.W	D4	JUMP,NE LOOP$	JUMP'	END$ONE$:	LOAD.W	(A4+),(A6)+ODESMG	LOAD.W	D3,(A6)+ODESXD	SUB.W	D3,(A6)+ODESMD	LOAD.W	(A4+),D3END$:	LOAD.W	(A4),#-1	; OCOLPX <-- terminateur	POPM.L	D2..D4,A4	RETTDBOX_COLONNES:	.W	10$-TDBOX_COLONNES	.W	20$-TDBOX_COLONNES	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Repres pour les colonnes :"	.B	ODBCR	.B	ODBLABEL,200	.B	ODBTEXT,0	.B	ODBCR,ODBCR2	.B	ODBTEXT	.ASCIZ	"Nombre de colonnes "	.B	ODBLABEL,100	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Gouttires         "	.B	ODBLABEL,101	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,101,TDBNORM	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCR	.B	ODBLABEL,201	.B	ODBTEXT,0	.B	ODBCR	.B	ODBSQUARE,BCOLMAGN	.ASCIZ	" repres magntiques"	.B	ODBCR	.B	ODBLABEL,202	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	"  ANNULE  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_COLONNES:	.W	F1,F2,F3,0		DOKF1-TKEY_COLONNES	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_COLONNES	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_COLONNES	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_COLONNES	.W	0;------------\\; DBOXHORVERT >;============/; Demande les contraintes horizontal/vertical.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXHORVERT:	PUSHM.L	D0..D2,D4,D5,A1..A5	LOAD.L	A5,A6		; A5 <-- ^variables pour put/get	LOAD.L	A2,#R16"TDBOX$	CALL	DBOXMEMPT	LOAD.L	A2,#R16"TDBOX_HORVERT	LOAD.W	D2,#2^BDBSAV	LOAD.L	D4,(A6)+OHVFAN	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	LOAD.W	D2,#2^BDBGCLABEL!200	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	LOAD.W	D2,#2^BDBGCLABEL!201	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	CLR.W	D2REFAIT$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXAFF		; affiche le paramtreNLINE$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre;	CALL	DBOXMEDITLOOP$:	DBOX_	EDIT		; attend action ...	CALL	ZEROCR	LOAD.L	A1,#R16"TKEY_HORVERT	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ DAC$	COMP.W	D3,#F0	JUMP,EQ CANCEL$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#CLEAR	JUMP',EQ UNDO$	COMP.W	D3,#CR	JUMP',EQ RETURN$	COMP.W	D3,#ENTER	JUMP',EQ RETURN$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP',EQ KEYDBOX$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	JUMP	NLINE$KEYDBOX$:			; KEYDBOX =>	CALL	DBOXPUT	JUMP,NE BIP$	COMP.W	D3,#KEYDBOX+100	JUMP',EQ CLIC2$	LOAD.L	D1,#H'FFFFFF00	COMP.B	D3,#8	JUMP',LO KEYDBOX2$	LOAD.L	D1,#H'FFFF00FF;	COMP.B	D3,#16;	JUMP',LO KEYDBOX2$;	LOAD.L	D1,#H'FF00FFFF;	COMP.B	D3,#24;	JUMP',LO KEYDBOX2$;	LOAD.L	D1,#H'00FFFFFFKEYDBOX2$:	AND.L	D4,D1		; D4 <-- teint toute la range	TSET.L	D4:D3		; D4 <-- allume juste le bon	JUMP	NLINE$CLIC$:	CALL	DBOXCLIC	; action dans les flches +/-	JUMP,NE BIP$CLIC2$:	TCLR.L	D4:#BHV090	TSET.L	D4:#BHVAUTRE	JUMP	NLINE$DAC$:				; D'ACCORD =>	CALL	DBOXPUT	JUMP,NE BIP$	LOAD.L	(A6)+OHVFAN,D4CANCEL$:			; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A1..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	OHVVAL,DBTYPN,10,90,5,2^BDBGCLABEL!100,0,3+2	.W	-1TDBOX_HORVERT:	.W	10$-TDBOX_HORVERT	.W	20$-TDBOX_HORVERT	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Contraintes sur le dplacement de la souris : "	.B	ODBCR,ODBCR	.B	ODBLCIRCLE,BHV090!2^7!2^6,KEYDBOX/H'100,BHV090	.ASCIZ	" horizontal/vertical"	.B	ODBCR	.B	ODBLCIRCLE,BHVAUTRE!2^7!2^6,KEYDBOX/H'100,BHVAUTRE	.ASCIZ	" autre  ...........  "	.B	ODBLABEL,100	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTEXT	.ASCIZ	"  degrs"	.B	ODBCR,ODBCR2	.B	ODBLABEL,200	.B	ODBTEXT,0	.B	ODBCR	.B	ODBLCIRCLE,BHVNON!2^7!2^6,KEYDBOX/H'100,BHVNON	.ASCIZ	" pas de contrainte"	.B	ODBCR	.B	ODBLCIRCLE,BHVCURSOR!2^7!2^6,KEYDBOX/H'100,BHVCURSOR	.ASCIZ	" contrainte si touche (CURSOR) enfonce"	.B	ODBCR	.B	ODBLCIRCLE,BHVOUI!2^7!2^6,KEYDBOX/H'100,BHVOUI	.ASCIZ	" contrainte permanente"	.B	ODBCR,ODBCR2	.B	ODBSQUARE,BHVSHOW	.ASCIZ	" montre les contraintes"	.B	ODBCR	.B	ODBLABEL,201	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	"  ANNULE  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_HORVERT:	.W	F1,F2,F3,0		DOKF1-TKEY_HORVERT	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_HORVERT	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_HORVERT	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_HORVERT	.W	0;---------\\; DBOXMOVE >;=========/; Demande un dplacement.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXMOVE:	PUSHM.L	D0..D2,D4,D5,A0..A5	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur fentre	LOAD.L	A5,A6		; A5 <-- ^variables pour put/get	LOAD.L	A2,#R16"TDBOX$	CALL	DBOXMEMPT	LOAD.L	A2,#R16"TDBOX_MOVE	LOAD.W	D2,#2^BDBSAV	CLR.L	D4	LOAD.W	D4,(A6)+OMOVEF	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	LOAD.W	D2,#2^BDBGCLABEL!200	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	LOAD.W	D2,#2^BDBGCLABEL!201	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	LOAD.W	D2,#2^BDBGCLABEL!202	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	PUSH.L	D4	LOAD.W	D2,#50!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.B	USEGC,GCICF,GCICS,GCICT+1	.B	AFTOUT,ICOMOVEXY&H'7F,AFNORM	.B	0	.EVEN	LOAD.W	D2,#51!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.B	AFTOUT,ICOMOVED&H'7F,AFNORM	.B	0	.EVEN	LOAD.W	D2,#52!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.B	AFTOUT,ICOMOVEA&H'7F,AFNORM	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.EVEN	POP.L	D4	CLR.W	D2AFF$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXAFF		; affiche le paramtre	INC.W	D2	COMP.W	D2,#4	JUMP,LO AFF$CIRCLE$:	LOAD.W	D2,#3	TEST.L	D4:#BMOVEA	JUMP',BS NLINE$	DEC.W	D2	TEST.L	D4:#BMOVED	JUMP',BS NLINE$	DEC.W	D2	TEST.L	D4:#BMOVEY	JUMP',BS NLINE$	CLR.W	D2NLINE$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXMEDIT	COMP.W	D2,#1	JUMP',HI NOXY$	TEST.L	D4:#BMOVEX	JUMP',BS LOOP$	TEST.L	D4:#BMOVEY	JUMP',BS LOOP$	TEST.L	D4:#BMOVEXY	JUMP',BS LOOP$	LOAD.B	D4,#2^BMOVEXY	JUMP'	LOOP$NOXY$:	LOAD.B	D4,#2^BMOVEA	COMP.W	D2,#3	JUMP',EQ LOOP$	LOAD.B	D4,#2^BMOVEDLOOP$:	DBOX_	EDIT		; attend action ...	CALL	ZEROCR	LOAD.L	A1,#R16"TKEY_MOVE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ DAC$	COMP.W	D3,#F0	JUMP,EQ CANCEL$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#CLEAR	JUMP',EQ UNDO$	COMP.W	D3,#CR	JUMP',EQ RETURN$	COMP.W	D3,#ENTER	JUMP',EQ RETURN$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP',EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	CALL	DBOXPUT	JUMP,NE BIP$	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,#4	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$KEYDBOX$:			; KEYDBOX =>	CALL	DBOXPUT	JUMP,NE BIP$	COMP.B	D3,#8	JUMP',LO SERIE07$	COMP.B	D3,#16	JUMP',LO SERIE815$	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$SERIE07$:	CLR.B	D4	TSET.L	D4:D3	JUMP	CIRCLE$SERIE815$:	AND.W	D4,#H'00FF	TSET.L	D4:D3	JUMP	LOOP$CLIC$:	CALL	DBOXCLIC	; action dans les flches +/-	JUMP,NE BIP$	JUMP	NLINE$DAC$:				; D'ACCORD =>CANCEL$:			; ANNULE =>	CALL	DBOXPUT	JUMP,NE BIP$	LOAD.W	(A6)+OMOVEF,D4	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A0..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	OMOVEX,DBTYPUS,-1000*FACMMPT,+1000*FACMMPT,10*FACMMPT,2^BDBGCLABEL!100,0,8+2	.W	OMOVEY,DBTYPUS,-1000*FACMMPT,+1000*FACMMPT,10*FACMMPT,2^BDBGCLABEL!101,1,8+2	.W	OMOVED,DBTYPU,0,+1000*FACMMPT,10*FACMMPT,2^BDBGCLABEL!102,2,8+2	.W	OMOVEA,DBTYPNS,-360,+360,5,2^BDBGCLABEL!103,3,4+2	.W	-1TDBOX_MOVE:	.W	10$-TDBOX_MOVE	.W	20$-TDBOX_MOVE	.W	0,010$:	.B	ODBLCIRCLE,BMOVEX!2^7!2^6,KEYDBOX/H'100,BMOVEX	.ASCIZ	""	.B	ODBTABX,5	.B	ODBTEXT	.ASCIZ	"horizontal "	.B	ODBLABEL,100	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBCR2	.B	ODBTABX,3	.B	ODBTEXT	.ASCIZ	"/"	.B	ODBCR2	.B	ODBLCIRCLE,BMOVEXY!2^7!2^6,KEYDBOX/H'100,BMOVEXY	.ASCIZ	"-"	.B	ODBTABX,34	.B	ODBLABEL,50	.B	ODBTEXT,0	.B	ODBTEXT	.ASCIZ	"     "	.B	ODBCR2	.B	ODBTABX,3	.B	ODBTEXT	.ASCIZ	"\"	.B	ODBCR2	.B	ODBLCIRCLE,BMOVEY!2^7!2^6,KEYDBOX/H'100,BMOVEY	.ASCIZ	""	.B	ODBTABX,5	.B	ODBTEXT	.ASCIZ	"vertical   "	.B	ODBLABEL,101	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,101,TDBNORM	.B	ODBCR	.B	ODBLABEL,200	.B	ODBTEXT,0	.B	ODBCR,ODBCR2	.B	ODBLCIRCLE,BMOVED!2^7!2^6,KEYDBOX/H'100,BMOVED	.ASCIZ	""	.B	ODBTABX,5	.B	ODBTEXT	.ASCIZ	"distance   "	.B	ODBLABEL,102	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,102,TDBNORM	.B	ODBTABX,34	.B	ODBLABEL,51	.B	ODBTEXT,0	.B	ODBCR	.B	ODBLABEL,201	.B	ODBTEXT,0	.B	ODBCR,ODBCR2	.B	ODBLCIRCLE,BMOVEA!2^7!2^6,KEYDBOX/H'100,BMOVEA	.ASCIZ	""	.B	ODBTABX,5	.B	ODBTEXT	.ASCIZ	"angle      "	.B	ODBLABEL,103	.B	ODBCLINE,(4+2)!2^7,KEYDBOX/H'100,103,TDBNORM	.B	ODBTEXT	.ASCIZ	"  degrs"	.B	ODBTABX,34	.B	ODBLABEL,52	.B	ODBTEXT,0	.B	ODBCR	.B	ODBLABEL,202	.B	ODBTEXT,0	.B	ODBCR	.B	ODBTABX,25	.B	ODBLCIRCLE,BMOVEALL!2^7!2^6,KEYDBOX/H'100,BMOVEALL	.ASCIZ	" 1<TAB>2<TAB>3<TAB>  .."	.B	ODBCR	.B	ODBTABX,25	.B	ODBLCIRCLE,BMOVE2!2^7!2^6,KEYDBOX/H'100,BMOVE2	.ASCIZ	" 1<TAB>2 3<TAB>4 .."	.B	ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" DEPLACE "	.B	ODBTEXT	.ASCIZ	" "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	ODBTABX,25	.B	ODBLCIRCLE,BMOVEREF!2^7!2^6,KEYDBOX/H'100,BMOVEREF	.ASCIZ	" 1<TAB>2 1<TAB>3 .."	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Dplace"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_MOVE:	.W	F1,F2,F3,0		DOKF1-TKEY_MOVE	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_MOVE	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_MOVE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_MOVE	.W	0;-------------\\; DBOXDIMIMAGE >;=============/; Demande les dimensions pour une image.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXDIMIMAGE:	PUSHM.L	D0..D2,D4,D5,A1..A5	LOAD.L	A5,A6		; A5 <-- ^variables pour put/get	LOAD.L	A2,#R16"TDBOX$	CALL	DBOXMEMPT	LOAD.L	A2,#R16"TDBOX_DIMIMAGE	LOAD.W	D2,#2^BDBSAV	LOAD.L	D4,(A6)+OFADIM	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	PUSH.L	D4	LOAD.W	D3,(A0)+ODFCX	MUL.WU	D3,#30	LOAD.W	D4,(A0)+ODFCY	MUL.WU	D4,#9	SWAP.W	D4	CLR.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRSEG	CLR.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	LIB	?DRSEG	POP.L	D4	CLR.W	D2REFAIT$:	PUSH.W	D2	CLR.W	D2AFF$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXAFF		; affiche le paramtre	INC.W	D2	COMP.W	D2,#1	JUMP,LO AFF$	POP.W	D2NLINE$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXMEDITLOOP$:	DBOX_	EDIT		; attend action ...	CALL	ZEROCR	LOAD.L	A1,#R16"TKEY_DIMIMAGE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ DAC$	COMP.W	D3,#F0	JUMP,EQ CANCEL$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#CLEAR	JUMP',EQ UNDO$	COMP.W	D3,#CR	JUMP',EQ RETURN$	COMP.W	D3,#ENTER	JUMP',EQ RETURN$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP',EQ KEYDBOX$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	CALL	DBOXPUT	JUMP,NE BIP$	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,#1	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$KEYDBOX$:			; KEYDBOX =>	CALL	DBOXPUT	JUMP,NE BIP$	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$CLIC$:	CALL	DBOXCLIC	; action dans les flches +/-	JUMP,NE BIP$	JUMP	NLINE$DAC$:				; D'ACCORD =>	CALL	DBOXPUT	JUMP,NE BIP$	LOAD.L	(A6)+OFADIM,D4CANCEL$:			; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A1..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	ODBIMX,DBTYPN,16,5000,10,2^BDBGCLABEL!100,0,4+2	.W	-1TDBOX_DIMIMAGE:	.W	10$-TDBOX_DIMIMAGE	.W	20$-TDBOX_DIMIMAGE	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Dimensions de l'image :"	.B	ODBTABX,30	.B	ODBTEXT	.ASCIZ	"Trames grises : "	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Largeur "	.B	ODBLABEL,100	.B	ODBCLINE,(4+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTEXT	.ASCIZ	"   [point]"	.B	ODBTABX,30	.B	ODBLCIRCLE,BPRIGX1	.ASCIZ	" x 1"	.B	ODBCR	.B	ODBTABX,30	.B	ODBLCIRCLE,BPRIGX2	.ASCIZ	" x 2"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"(La hauteur est calcule"	.B	ODBTABX,30	.B	ODBLCIRCLE,BPRIGX3	.ASCIZ	" x 3"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"pour que l'image conserve"	.B	ODBTABX,30	.B	ODBLCIRCLE,BPRIGX4	.ASCIZ	" x 4"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"ses proportions)"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	"  SAUVE  "	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	"  ANNULE  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Sauve"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_DIMIMAGE:	.W	F1,F2,F3,0		DOKF1-TKEY_DIMIMAGE	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_DIMIMAGE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_DIMIMAGE	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_DIMIMAGE	.W	0;----------\\; DBOXPRINT >;==========/; Choisi le mode pour l'impression.; in	-; out	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXPRINT:	PUSHM.L	D1,D2,D4,D5,A1..A5	LOAD.L	A5,A6		; A5 <-- ^variables pour put/get	LOAD.L	A2,#R16"TDBOX$	CALL	DBOXMEMPT	LOAD.W	D4,(A6)+OPRTO	COMP.W	D4,(A6)+OIDPAG+OIDHTV	JUMP',LS MAX$	LOAD.W	(A6)+OPRTO,(A6)+OIDPAG+OIDHTVMAX$:	LOAD.L	A2,#R16"TDBOX_PRINT	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+OPRINT	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$	PUSH.L	D4	LOAD.W	D3,(A0)+ODFCY	MUL.WU	D3,#3	SWAP.W	D3	CLR.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	LOAD.W	D2,#SETDOT	LIB	?DRSEG	LOAD.W	D2,#200!2^BDBGCLABEL	DBOX_	GETCO	SWAP.W	D3	LOAD.W	D4,(A0)+ODFCY	MUL.WU	D4,#3	LOAD.W	D3,D4	SWAP.W	D3	LOAD.W	D4,(A0)+ODFCY	MUL.WU	D4,#3+4	SUB.W	D4,#8	SWAP.W	D4	CLR.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRSEG	CLR.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	LIB	?DRSEG	LOAD.W	D2,#201!2^BDBGCLABEL	DBOX_	GETCO	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	CLR.W	D3	LOAD.W	D2,#SETDOT	LIB	?DRSEG	POP.L	D4	CLR.W	D2REFAIT$:	PUSH.W	D2	CLR.W	D2AFF$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXAFF		; affiche le paramtre	INC.W	D2	COMP.W	D2,#4	JUMP,LO AFF$	POP.W	D2NLINE$:	LOAD.W	(A6)+OPRFMI,#1	LOAD.W	(A6)+OPRFMA,(A6)+OPRTO	LOAD.W	(A6)+OPRTMI,(A6)+OPRFROM	LOAD.W	(A6)+OPRTMA,(A6)+OIDPAG+OIDHTV	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXMEDITLOOP$:	DBOX_	EDIT		; attend action ...	CALL	ZEROCR	LOAD.L	A1,#R16"TKEY_PRINT	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ USE$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#CLEAR	JUMP',EQ UNDO$	COMP.W	D3,#CR	JUMP',EQ RETURN$	COMP.W	D3,#ENTER	JUMP',EQ RETURN$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP',EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	CALL	DBOXPUT	JUMP,NE BIP$	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,#4	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$KEYDBOX$:			; KEYDBOX =>	CALL	DBOXPUT	JUMP,NE BIP$	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$CLIC$:	CALL	DBOXCLIC	; action dans les flches +/-	JUMP,NE BIP$	JUMP	NLINE$USE$:	CALL	DBOXPUT	JUMP,NE BIP$	TEST.W	(A6)+OPRSC1	JUMP,EQ BIP$	JUMP',LE OK$	TEST.W	(A6)+OPRSC2	JUMP,EQ BIP$	JUMP',LE OK$	LOAD.W	D7,#ERPPSCA	; D7 <-- trop grand	LOAD.W	D2,(A6)+ODESXD	MUL.WU	D2,(A6)+OPRSC2	DIV.WU	D2,(A6)+OPRSC1	JUMP',NS END$	JUMP',VS END$	LOAD.W	D2,(A6)+ODESYD	MUL.WU	D2,(A6)+OPRSC2	DIV.WU	D2,(A6)+OPRSC1	JUMP',NS END$	JUMP',VS END$OK$:	CLR.W	D7	LOAD.L	(A6)+OPRINT,D4END$:	PUSH.W	D7	CALL	DBOXCLOSE	; ferme la DBOX	POP.W	D7EXIT$:	POPM.L	D1,D2,D4,D5,A1..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	OPRFROM,DBTYPN!2^14!2^15,OPRFMI,OPRFMA,1,2^BDBGCLABEL!100,0,3+2	.W	OPRTO,  DBTYPN!2^14!2^15,OPRTMI,OPRTMA,1,2^BDBGCLABEL!101,1,3+2	.W	OPRSC1,DBTYPUF,0,1000*FACMMPT,0,2^BDBGCLABEL!102,2,8+2	.W	OPRSC2,DBTYPUF,0,1000*FACMMPT,0,2^BDBGCLABEL!103,3,8+2	.W	-1TDBOX_PRINT:	.W	10$-TDBOX_PRINT	.W	20$-TDBOX_PRINT	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Imprime les pages de "	.B	ODBLABEL,100	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTEXT	.ASCIZ	"  jusqu' "	.B	ODBLABEL,101	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,101,TDBNORM	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Calques  imprimer :"	.B	ODBTABX,28-2	.B	ODBLABEL,200	.B	ODBTEXT,0	.B	ODBTABX,28	.B	ODBTEXT	.ASCIZ	"Trames grises : "	.B	ODBCR,ODBCR2	.B	ODBSQUARE,0	.ASCIZ	" A"	.B	ODBTABX,6	.B	ODBSQUARE,4	.ASCIZ	" E"	.B	ODBTABX,12	.B	ODBSQUARE,8	.ASCIZ	" I"	.B	ODBTABX,18	.B	ODBSQUARE,12	.ASCIZ	" M"	.B	ODBTABX,28	.B	ODBLCIRCLE,BPRIGX1	.ASCIZ	" x 1"	.B	ODBCR	.B	ODBSQUARE,1	.ASCIZ	" B"	.B	ODBTABX,6	.B	ODBSQUARE,5	.ASCIZ	" F"	.B	ODBTABX,12	.B	ODBSQUARE,9	.ASCIZ	" J"	.B	ODBTABX,18	.B	ODBSQUARE,13	.ASCIZ	" N"	.B	ODBTABX,28	.B	ODBLCIRCLE,BPRIGX2	.ASCIZ	" x 2"	.B	ODBCR	.B	ODBSQUARE,2	.ASCIZ	" C"	.B	ODBTABX,6	.B	ODBSQUARE,6	.ASCIZ	" G"	.B	ODBTABX,12	.B	ODBSQUARE,10	.ASCIZ	" K"	.B	ODBTABX,18	.B	ODBSQUARE,14	.ASCIZ	" O"	.B	ODBTABX,28	.B	ODBLCIRCLE,BPRIGX3	.ASCIZ	" x 3"	.B	ODBCR	.B	ODBSQUARE,3	.ASCIZ	" D"	.B	ODBTABX,6	.B	ODBSQUARE,7	.ASCIZ	" H"	.B	ODBTABX,12	.B	ODBSQUARE,11	.ASCIZ	" L"	.B	ODBTABX,18	.B	ODBSQUARE,15	.ASCIZ	" P"	.B	ODBTABX,28	.B	ODBLCIRCLE,BPRIGX4	.ASCIZ	" x 4"	.B	ODBCR,ODBCR	.B	ODBTABX,14	.B	ODBTEXT	.ASCIZ	"cran"	.B	ODBTABX,14+12+5	.B	ODBTEXT	.ASCIZ	"papier"	.B	ODBCR2	.B	ODBTEXT	.ASCIZ	"Changement"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"d'chelle :  "	.B	ODBLABEL,102	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,102,TDBNORM	.B	ODBTEXT	.ASCIZ	" --<'>> "	.B	ODBLABEL,103	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,103,TDBNORM	.B	ODBCR	.B	ODBLABEL,201	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" IMPRIME "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBSQUARE,BPRIPS	.ASCIZ	" PostScript"	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Imprime"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_PRINT:	.W	F1,F2,F3,0		DOKF1-TKEY_PRINT	.W	F0,F13,F14,F15,0	DOKF0-TKEY_PRINT	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_PRINT	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_PRINT	.W	0;-------------\\; DBOXFRAGMENT >;=============/; Faut-il fragmenter ?; in	-; out	D3.L	dernire touche (F1/F4);	D7.W	erreur; mod	D3.L, D7.WDBOXFRAGMENT:	PUSHM.L	D1,D2,D4,D5,A1..A4	LIB	?BUZZ	LOAD.L	A2,#R16"TDBOX_FRAGMENT	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+OFRAFA	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$	PUSH.L	D4	LOAD.W	D2,#100!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.B	USEGC,GCICF,GCICS,GCICT	.B	AFTOUT,ICOOOPER,AFNORM	.B	0	.EVEN	LOAD.W	D2,#101!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.B	AFTOUT,ICOZDEFBEZ,AFNORM	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.EVEN	POP.L	D4LOOP$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_FRAGMENT	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP',EQ FRAG$	COMP.W	D3,#F13	JUMP',EQ QUIT$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$FRAG$:	LOAD.L	(A6)+OFRAFA,D4QUIT$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_FRAGMENT:	.W	10$-TDBOX_FRAGMENT	.W	20$-TDBOX_FRAGMENT	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Fragmente tous les objets slectionns."	.B	ODBCR,ODBCR2	.B	ODBTEXT	.ASCIZ	"ATTENTION:  Cette opration est"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"            irrversible !"	.B	ODBCR,ODBCR	.B	ODBLCIRCLE,0	.ASCIZ	" droites et courbes de Bzier"	.B	ODBCR	.B	ODBLCIRCLE,1	.ASCIZ	" uniquement des courbes (pour "	.B	ODBLABEL,100	.B	ODBTEXT	.ASCIZ	"   <H'09>"	.B	ODBLABEL,101	.B	ODBTEXT	.ASCIZ	"   )"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBNORM	.ASCIZ	" FRAGMENTE "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F13,TDBMEV	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Fragmente"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_FRAGMENT:	.W	F1,F2,F3,0		DOKF1-TKEY_FRAGMENT	.W	F13,F14,F15,0		DOKF13-TKEY_FRAGMENT	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_FRAGMENT	.W	0;----------\\; DBOXIOREV >;==========/; Avertissement ...; in	-; out	D3.L	dernire touche (F1/F4);	D7.W	erreur; mod	D3.L, D7.WDBOXIOREV:	PUSHM.L	D1,D2,D4,D5,A1..A4	LIB	?BUZZ	LOAD.L	A2,#R16"TDBOX_IOREV	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4	CALL	DBOXOPEN	; ouvre la DBOX	JUMP',NE EXIT$LOOP$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_IOREV	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP',EQ QUIT$	COMP.W	D3,#F4	JUMP',EQ QUIT$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$QUIT$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_IOREV:	.W	10$-TDBOX_IOREV	.W	20$-TDBOX_IOREV	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"<AFINV> ATTENTION : <AFDIR>"	.B	ODBCR,ODBCR2	.B	ODBTEXT	.ASCIZ	"De nombreuses incompatibilits empchent"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"de reprendre un ancien document .PAGE !"	.B	ODBCR,ODBCR2	.B	ODBTEXT	.ASCIZ	"Voulez-vous quand mme essayer ?"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBNORM	.ASCIZ	"  OUI  "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F4,TDBMEV	.ASCIZ	"  NON  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Oui"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Non"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVENTKEY_IOREV:	.W	F1,F2,F3,0		DOKF1-TKEY_IOREV	.W	F4,F5,F6,CR,0		DOKF4-TKEY_IOREV	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_IOREV	.W	0;-----------\\; DBOXZPRINT >;===========/; Avertissement ...; in	-; out	D3.L	dernire touche (F1/F4);	D7.W	erreur; mod	D3.L, D7.WDBOXZPRINT:	PUSHM.L	D1,D2,D4,D5,A1..A4	LIB	?BUZZ	LOAD.L	A2,#R16"TDBOX_ZPRINT	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4	CALL	DBOXOPEN	; ouvre la DBOX	JUMP',NE EXIT$LOOP$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_ZPRINT	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP',EQ QUIT$	COMP.W	D3,#F4	JUMP',EQ QUIT$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$QUIT$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_ZPRINT:	.W	10$-TDBOX_ZPRINT	.W	20$-TDBOX_ZPRINT	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"<AFINV> ATTENTION : <AFDIR>"	.B	ODBCR,ODBCR2	.B	ODBTEXT	.ASCIZ	"Le zoom graphique de la prsentation"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"d'impression n'est pas rgl sur un !"	.B	ODBCR,ODBCR2	.B	ODBTEXT	.ASCIZ	"Voulez-vous quand mme imprimer ?"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBNORM	.ASCIZ	"  OUI  "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F4,TDBMEV	.ASCIZ	"  NON  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Oui"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Non"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVENTKEY_ZPRINT:	.W	F1,F2,F3,0		DOKF1-TKEY_ZPRINT	.W	F4,F5,F6,CR,0		DOKF4-TKEY_ZPRINT	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_ZPRINT	.W	0;----------\\; DBOXERROR >;==========/; Affiche une erreur.; in	D7.W	erreur; out	D7.W	erreur; mod	D7.WDBOXERROR:	PUSHM.L	D2..D4,A3	LOAD.W	D4,D7	JUMP',EQ 20$	COMP.W	D7,#ERKNO	JUMP',EQ 20$	COMP.W	D7,#ERKSTO	JUMP',NE 30$20$:	CLR.W	D7		; D7 <-- ok	JUMP'	90$30$:	CALL	DBOXOPEN1	; remet la flche	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	CALL	DBERTEXT	; A3 <-- ^message interne  PAGE	JUMP',EQ 50$	LOAD.W	D7,D4		; D7 <-- code de l'erreur	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur "externe" ...	JUMP'	80$50$:	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	TERROR		; affiche l'erreur "interne" ...80$:	CALL	DBOXCLOSE1	; remet les soft-keys90$:	POPM.L	D2..D4,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBERTEXT >;---------/; Donne le texte d'une erreur interne  PAGE.; in	D4.W	erreur; out	A3.L	^message d'erreur;	D7.W	erreur; mod	D7.W, A3.LDBERTEXT:	PUSH.L	D3	LOAD.W	D7,#ERPBIP	; D7 <-- pas trouv	LOAD.W	D3,D4	SR.W	D3,#8	COMP.B	D3,#ERPAGE/H'100 ; erreur interne  PAGE ?	JUMP',NE 90$		; non => 90$				; oui =>	LOAD.L	A3,#R16"TABLE$20$:	TEST.W	(A3+)		; fin de la table ?	JUMP',EQ 80$		; oui => 80$	COMP.W	D4,(A3)-2	; erreur trouve ?	JUMP',EQ 80$		; oui => 80$30$:	TEST.B	(A3+)		; A3 <-- saute un .ASCIZ	JUMP,NE	30$	LOAD.L	D3,A3	INC.L	D3	TCLR.L	D3:#0		; A3 <-- saute comme .EVEN	LOAD.L	A3,D3	JUMP	20$80$:	CLR.W	D7		; D7 <-- trouv90$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RETTABLE$:	.W	ERPAILOP	.ASCIZ	"Opration impossible !"	.EVEN	.W	ERPAHANDDNE	.ASCIZ	"Poigne n'existe pas !"	.EVEN	.W	ERPAHANDEND	.ASCIZ	"Dernire poigne !"	.EVEN	.W	ERPOVER	.ASCIZ	"Dpassement de capacit !"	.EVEN	.W	ERPMDNE	.ASCIZ	"Mthode n'existe pas !"	.EVEN	.W	ERPOBPC	.ASCII	"Il existe un ou plusieurs objets<CR>"	.ASCIZ	"qui ne sont pas chargs !"	.EVEN	.W	ERPIOFORM	.ASCIZ	"Fichier .PAGE incompatible !"	.EVEN	.W	ERPIOASSF	.ASCIZ	/Fichier "!" trop grand !/	.EVEN	.W	ERPNOTF	.ASCII	"Pas trouv dans la<CR>"	.ASCIZ	"direction choisie !"	.EVEN	.W	ERPPSCA	.ASCII	"Le changement d'chelle produit<CR>"	.ASCIZ	"un document trop grand !"	.EVEN	.W	0	.ASCIZ	"Erreur avec le logiciel PAGE !"	.EVEN	.END