	.SBTTL	OPPENNUM.ASINUMLX	=	3		; largeur d'un chiffreNUMLY	=	5		; hauteur d'un chiffre;--------\\; NUMDRAW >;========/; Affiche un chiffre en tout petit.; in	D3.L	position (y;x);	D4.W	chiffre [obj]; out	-; mod	D7.WNUMDRAW:	PUSHM.L	D2..D4,A4	LOAD.W	D7,#MI_CCMO	PAGE_	MISC		; enlve la souris	LOAD.L	A4,#(A5)+OBUDIS	LOAD.W	D7,#MI_PUTUNUM	PAGE_	MISC		; OBUDIS <-- nombre	CLR.B	(A4)	LOAD.L	A4,#(A5)+OBUDIS	CLR.W	D2CLOOP$:	LOAD.B	D4,(A4+)	JUMP',EQ CEND$	COMP.B	D4,#'.	JUMP',EQ CINC$	COMP.B	D4,#'0	JUMP,LO CLOOP$	COMP.B	D4,#'9	JUMP,HI CLOOP$CINC$:	INC.W	D2	JUMP	CLOOP$CEND$:	MUL.WU	D2,#NUMLX+1	SUB.W	D3,D2		; D3 <-- dbut en X (drapeau  gauche)	SWAP.W	D3	SUB.W	D3,#NUMLY	; D3 <-- dbut en Y (haut des caractres)	SWAP.W	D3	LOAD.L	A4,#(A5)+OBUDISDLOOP$:	CLR.W	D4	LOAD.B	D4,(A4+)	JUMP',EQ EXIT$	COMP.B	D4,#'.	JUMP',EQ DPOINT$	SUB.B	D4,#'0	JUMP,LO DLOOP$	COMP.B	D4,#9	JUMP,HI DLOOP$	JUMP'	DDRAW$DPOINT$:	LOAD.W	D4,#10DDRAW$:	CALL	NUMDIGIT	; affiche un digit	ADD.W	D3,#NUMLX+1	; D3 <-- position suivante	JUMP	DLOOP$EXIT$:	POPM.L	D2..D4,A4	RET;---------\\; NUMDIGIT >;---------/; Affiche un digit.; in	D3.L	position (y;x);	D4.W	digit (0..10); out	-; mod	D7.WNUMDIGIT:	PUSHM.L	D0..D5,A2..A4	LOAD.L	A3,#R16"MATRIX$	MUL.WU	D4,#NUMLY	ADD.L	A3,D4		; A3 <-- ^source (matrice)	LOAD.L	D4,D3		; D4 <-- position destination	CLR.L	D3		; D3 <-- position source	LOAD.W	D5,#1		; D5 <-- Iy source	LOAD.L	A4,#0		; A4 <-- destination (cran)	LOAD.L	D2,#H'10000*NUMLY+NUMLX	LOAD.W	D1,#SETDOT	LOAD.L	A2,A0	GRA_	RASTER		; cran <-- un "caractre"EXIT$:	POPM.L	D0..D5,A2..A4	RETMATRIX$:			; 0	.B	B'01000000	.B	B'10100000	.B	B'10100000	.B	B'10100000	.B	B'01000000				; 1	.B	B'01000000	.B	B'11000000	.B	B'01000000	.B	B'01000000	.B	B'11100000				; 2	.B	B'11000000	.B	B'00100000	.B	B'01000000	.B	B'10000000	.B	B'11100000				; 3	.B	B'11100000	.B	B'00100000	.B	B'01000000	.B	B'00100000	.B	B'11000000				; 4	.B	B'00100000	.B	B'01100000	.B	B'10100000	.B	B'11100000	.B	B'00100000				; 5	.B	B'11000000	.B	B'10000000	.B	B'11100000	.B	B'00100000	.B	B'11000000				; 6	.B	B'01100000	.B	B'10000000	.B	B'11100000	.B	B'10100000	.B	B'11100000				; 7	.B	B'11100000	.B	B'00100000	.B	B'01000000	.B	B'01000000	.B	B'01000000				; 8	.B	B'11100000	.B	B'10100000	.B	B'11100000	.B	B'10100000	.B	B'11100000				; 9	.B	B'11100000	.B	B'10100000	.B	B'11100000	.B	B'00100000	.B	B'11000000				; .	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'01000000	.EVEN	.END