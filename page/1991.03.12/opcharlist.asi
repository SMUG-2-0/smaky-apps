	.SBTTL	OPCHARLIST.ASI;---------\\; LISTGENC >;=========/; Refait toute la liste des gencars.; in	-; out	-; mod	D7.WLISTGENC:	PUSHM.L	D1..D5,A3,A4	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	LOAD.L	A3,#R16"MODUN$	LOAD.W	D3,#2	LIB	?STRING		; plus de modulos	LIB	?GETWDO	PUSH.W	D5		; stack <-- swdo actuelle	LOAD.L	D3,(A5)+OSLVAR+OSLPOS	INC.W	D3	ADD.W	D3,(A0)+ODFFX	SWAP.W	D3	INC.W	D3	ADD.W	D3,(A0)+ODFFY	SWAP.W	D3	LOAD.L	D4,(A5)+OSLVAR+OSLDIM	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LIB	?CREWDO	LIB	?USEWDO	LOAD.B	D3,#EOP	LIB	?AFCAR		; efface la swdo	LIB	?FLUSHNGC	; poutz tout	LOAD.L	A3,#R16"DIR$	LOAD.L	A4,#R16"CRIT$	LOAD.L	D3,#2^BOPSYS	FOS	?LISTOPEN	JUMP',NE EXIT$	LOAD.L	D1,#-1		; D1 <-- dernier gencarLOOP$:	FOS	?LISTNXT	; A3/A4 <-- ^nom/^arguments	JUMP',NE END$	ADD.L	A3,#4		; A3 <-- saute "SMA_"	LIB	?SYNGC		; D3/D4/D5 <-- f/s/t	AND.L	D3,#H'FF	SL.L	D3,#8	LOAD.B	D3,D4	SL.L	D3,#8	LOAD.B	D3,D5		; D3 <-- "-fst"	LOAD.L	D2,D3	AND.L	D2,#H'00FFFF00	; D2 <-- "-fs-"	COMP.L	D2,D1		; comme le dernier gencar trouv ?	JUMP,EQ LOOP$		; oui => LOOP$	LOAD.L	D1,D2	LOAD.L	A3,#(A5)+OBUDIS	LOAD.L	A4,A3	LOAD.W	D4,#20	LOAD.W	D2,#2^0	LIB	?TEXTGC		; OBUDIS <-- nom du gencar	CLR.B	(A4)	LIB	?AFCR	LIB	?AFSPACE	LIB	?AFTEXT		; affiche le nom complet	JUMP	LOOP$END$:	FOS	?LISTCLOSEEXIT$:	LIB	?GETWDO	LIB	?KILWDO	POP.W	D5		; D5 <-- swdo initiale	LIB	?USEWDO	LOAD.L	A3,#R16"MODUY$	LOAD.W	D3,#2	LIB	?STRING		; remet les modulos	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: enlve le sablier	POPM.L	D1..D5,A3,A4	TEST.W	D7		; retour EQ/NE	RETMODUN$:	.B	MMODULO,1MODUY$:	.B	MMODULO,0DIR$:	.ASCIZ	"#:"CRIT$:	.ASCIZ	"SMA_*.GENC"	.EVEN	.END