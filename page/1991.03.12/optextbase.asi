	.SBTTL	OPTEXTBASE.ASI;-----------\\; BASZONEPOS >;===========/; Cherche la position dans le buffer correspondant  une; position graphique (souris par exemple).; in	A4.L	^objet texte;	D4.L	position (y;x); out	D4.L	position dans BUTX;	D7.W	erreur; mod	D4.L, D7.WBASZONEPOS:	PUSHM.L	D3,D6,A3,A4	CALL	CARINIPT	; initialise pour CARGETPT	LOAD.L	D6,(A4)+OOBCHT	LOAD.L	A3,A4PREV$:	CALL	BASGPPAVE	; souris dans ce pav ?	JUMP',EQ PAVE$		; oui => PAVE$	CALL	BASPREVPAVE	; A4 <-- ^pav prcdent	JUMP,EQ PREV$	LOAD.L	A4,A3NEXT$:	CALL	BASGPPAVE	; souris dans ce pav ?	JUMP',EQ PAVE$		; oui => PAVE$	CALL	BASNEXTPAVE	; A4 <-- ^pav suivant	JUMP,EQ NEXT$	JUMP'	EXIT$PAVE$:	CALL	BASGPLINE	; A3 <-- ^ligne dans OPJ*	JUMP',NE EXIT$	CALL	BASGPCAR	; D4 <-- position o aller dans BUTX	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; BASZONEINV >;===========/; Inverse une zone quelconque d'un texte pouvant appartenir;  plusieurs lignes de plusieurs pavs diffrents.; in	A4.L	^objet texte;	D4.L	position dbut dans BUTX;	D5.L	position fin dans BUTX; out	-; mod	D7.WBASZONEINV:	PUSHM.L	D3..D5,A3,A4	PUSH.L	D4	LOAD.L	D4,#H'10000*COLORFDRAW+COLOR_PPHILI	LOAD.W	D7,#DR_COLORINIT	PAGE_	DRAW		; spcifie les couleurs	LOAD.L	D4,#-1	CALL	DRMDEF		; trame pour inverser	POP.L	D4	COMP.L	D4,D5	JUMP',LS ORD$	EX.L	D4,D5		; D4 <-- toujours avant D5 !ORD$:	CALL	CARPJSEARCH	; A3 <-- ^dans OPJxxx	JUMP',NE EXIT$LOOP$:	CALL	BASZONEILINE	; inverse dans une ligne	CLR.L	D3	LOAD.W	D3,(A3)+OPJNBC	ADD.L	D3,(A3)+OPJPDL	; D3 <-- position fin de la ligne	COMP.L	D5,D3		; est-on arriv  la fin ?	JUMP',LS EXIT$		; oui => EXIT$	CALL	CARPJNEXT	; A3/A4 <-- ^ligne suivante	JUMP,EQ LOOP$EXIT$:	POPM.L	D3..D5,A3,A4	RET;-------------\\; BASZONEILINE >;-------------/; Inverse une partie de texte contenu dans une seule ligne.; in	A4.L	^objet texte;	A3.L	^dans OPJ*;	D4.L	position dbut;	D5.L	position fin; out	-; mod	D7.WBASZONEILINE:	PUSHM.L	D2..D4	CALL	CARPOSDIM	; cherche position/dimensions du pav	CALL	BASPOSCLINE	; D2 <-- position dbut (y;x)	LOAD.L	D3,D2	LOAD.L	D4,D5	CALL	BASPOSCLINE	; D2 <-- position fin (y;x)	LOAD.L	D4,D2	COMP.W	D3,D4	JUMP',EQ EXIT$	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,(A3)+OPJBL	SUB.W	D4,(A3)+OPJBL	ADD.W	D4,(A3)+OPJIL	SWAP.W	D4	SWAP.W	D3	LOAD.W	D2,#INVDOT	LOAD.W	D7,#DR_TRAME	PAGE_	DRAW		; inverse une partie de ligneEXIT$:	POPM.L	D2..D4	RET;----------\\; BASGETPOS >;==========/; Cherche la position dans le buffer correspondant  une position graphique; (souris par exemple) pour y positionner le curseur.; in	A4.L	^objet texte;	D4.L	position (y;x); out	D7.W	erreur; mod	D7.WBASGETPOS:	PUSHM.L	D3,D4,D6,A3,A4	CALL	CARINIPT	; initialise pour CARGETPT	LOAD.L	D6,(A4)+OOBCHT	LOAD.L	A3,A4PREV$:	CALL	BASGPPAVE	; souris dans ce pav ?	JUMP',EQ PAVE$		; oui => PAVE$	CALL	BASPREVPAVE	; A4 <-- ^pav prcdent	JUMP,EQ PREV$	LOAD.L	A4,A3NEXT$:	CALL	BASGPPAVE	; souris dans ce pav ?	JUMP',EQ PAVE$		; oui => PAVE$	CALL	BASNEXTPAVE	; A4 <-- ^pav suivant	JUMP,EQ NEXT$	JUMP'	EXIT$PAVE$:	CALL	BASGPLINE	; A3 <-- ^ligne dans OPJ*	JUMP',NE EXIT$	LOAD.L	D3,D4	CALL	_BUTX_GETPOS	EX.L	D3,D4		; D3 <-- position actuelle	CALL	BASGPCAR	; D4 <-- position o aller dans BUTX	COMP.L	(A5)+OTXCP1,#-1	JUMP',EQ POS$	COMP.L	D4,D3		; position change ?	JUMP',EQ OK$		; non => OK$POS$:	CALL	_BUTX_SETPOS	; positionne dans le texte	CALL	BASCLRCURS	; teint le curseur	LOAD.L	(A5)+OTXCP1,#-1	; curseur pas (encore) retrouv	CALL	EDAFCURS	; cherche la position du curseur	CALL	BASSETCURS	; allume le curseur	CALL	BASSETREGLE	; dessine la rgleOK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; BASGPPAVE >;----------/; Regarde si la souris est dans un pav.; in	A4.L	^objet texte;	D4.L	position (y;x); out	D7.W	erreur; mod	D7.WBASGPPAVE:	PUSHM.L	D3,D4	LOAD.W	D7,#1	TEST.B	(A4)+OOBNODR	; pav dans une autre page ?	JUMP',NE EXIT$		; oui => EXIT$	CALL	CARPOSDIM	; cherche position/dimensions du pav	LOAD.W	D7,#1	LOAD.W	D3,(A5)+OTXPOS+2	COMP.W	D4,D3	JUMP',LT EXIT$	ADD.W	D3,(A5)+OTXDIM+2	COMP.W	D4,D3	JUMP',GE EXIT$	SWAP.W	D4	LOAD.W	D3,(A5)+OTXPOS+0	COMP.W	D4,D3	JUMP',LT EXIT$	ADD.W	D3,(A5)+OTXDIM+0	COMP.W	D4,D3	JUMP',GE EXIT$	CLR.W	D7EXIT$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; BASGPLINE >;----------/; Cherche quelle ligne correspond  une position donne.; in	A4.L	^objet texte;	D4.L	position (y;-); out	A3.L	^dans OPJ*;	D7.W	erreur; mod	D7.W, A3.LBASGPLINE:	PUSHM.L	D3,D4	TEST.L	(A4)+OOBPPJ	; table OPJxxx existe ?	JUMP',NE POS$		; oui => POS$	CALL	CARCOUPEPALL	; calcule la table OPJxxx	JUMP',NE EXIT$POS$:	CALL	CARPOSDIM	; cherche position/dimensions du pav	LOAD.L	A3,(A4)+OOBPPJ	; A3 <-- ^table OPJxxx	SWAP.W	D4		; D4 <-- position en YYLOOP$:	CALL	CARPJVALID	; valide l'information (si ncessaire)	TEST.W	(A3)+OPJNBC	; a-t-on atteint la dernire ligne ?	JUMP',EQ OK$		; oui => OK$	LOAD.W	D3,(A5)+OTXPOS+0	ADD.W	D3,(A3)+OPJPYR	ADD.W	D3,(A3)+OPJIL	; D3 <-- position bas de la ligne	COMP.W	D4,D3	JUMP',LT OK$	LOAD.L	A3,#(A3)+LPJ	; A3 <-- ^description ligne suivante	JUMP	YLOOP$OK$:	CLR.W	D7		; D7 <-- trouvEXIT$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; BASGPCAR >;---------/; Cherche quel caractre correspond  une position donne.; in	A4.L	^objet texte;	D4.L	position (-;x);	A3.L	^dans OPJ*; out	D4.L	position dans BUTX; mod	D4.L, D7.W	.PC	PCVAR	.LOC	0OBGCPIN:.BLKB	2		; position initialeOBGCPOX:.BLKB	2		; position chercheOBGCPOD:.BLKB	2		; position dbut caractreOBGCNBC:.BLKB	2		; nb de caractres restantOBGCCNJ:.BLKB	2		; nb de caractres non justifisOBGCLC:	.BLKB	1		; dernier caractre affich	.EVENLBGC:	.PC	PCCODEBASGPCAR:	PUSHM.L	D0..D3,D5,A2	SUB.L	SP,#LBGC	; SP <-- ^variables locales	LOAD.L	A2,(A3)+OPJJUS	; A2 <-- ^table de justification	LOAD.W	(SP)+OBGCPOX,D4	; OBGCPOX <-- position cherche	CALL	_BUTX_POSSAVE	; D4 <-- no de la position initiale	LOAD.W	(SP)+OBGCPIN,D4	LOAD.L	D4,(A3)+OPJPDL	CALL	_BUTX_SETPOS	; va au dbut de la ligne	LOAD.W	(SP)+OBGCNBC,(A3)+OPJNBC	LOAD.W	(SP)+OBGCCNJ,(A3)+OPJCNJ	CALL	BASCALCSAJEX	; D0/D1 <-- reste/nb pour les SAJEXs	LOAD.B	D3,#SPACE	CALL	BASPOSBLINE	; D2 <-- position sur la ligne de baseLOOP$:	LOAD.W	(SP)+OBGCPOD,D2	; OBGCPOD <-- position dbut caractre	LOAD.B	(SP)+OBGCLC,D3	; OBGCLC <-- dernier caractre affich	CALL	_BUTX_AVANCE	; D3/D4/D5 <-- caractre suivant	JUMP,NE EOL$	COMP.B	D3,#PEOT	JUMP,EQ FOUND$	CALL	CARCHASSETAB	; D5 <-- chasse	ADD.W	D2,D5		; D2 <-- avance dans la ligne	TEST.B	(A2)+OJSMODE:#BJSMDA ; align ?	JUMP,BC NEXT$		; non => NEXT$				; oui =>	TEST.W	(SP)+OBGCCNJ	; caractre non justifi ?	JUMP,GT NEXT$		; oui => NEXT$	COMP.B	D3,#SPACE	JUMP',NE ITC$	COMP.B	D3,(SP)+OBGCLC	; dernier caractre tait dj un espace ?	JUMP',EQ ITC$		; oui => ITC$	TEST.W	(A2)+OJSESPC	; espacement entre les caractres ?	JUMP',EQ SAJEX$		; non => SAJEX$				; oui =>	CLR.L	D3	LOAD.W	D3,(A2)+OJSESPC	; D3 <-- espacement entre les caractres	SUB.L	D3,#100	NEG.L	D3	DIV.WU	D3,#5SLOOP$:	CALL	BASAFSAJEX	; affiche un "sajex"	DEC.W	D3	JUMP,NC SLOOP$	LOAD.B	D3,#SPACE	JUMP'	NEXT$ITC$:	TEST.W	(A2)+OJSESPC	; espacement entre les caractres ?	JUMP',EQ NEXT$		; non => NEXT$SAJEX$:	CALL	BASAFSAJEX	; affiche un "sajex";	JUMP'	NEXT$NEXT$:	LOAD.W	D4,D2	SUB.W	D4,(SP)+OBGCPOD	SR.W	D4,#1	ADD.W	D4,(SP)+OBGCPOD	; D4 <-- milieu du caractre avanc	COMP.W	D4,(SP)+OBGCPOX	JUMP',GE FOUND$	DEC.W	(SP)+OBGCCNJ	; un caractre non justifi de moins	DEC.W	(SP)+OBGCNBC	; encore un caractre  afficher ?	JUMP,NE LOOP$		; oui => LOOP$EOL$:	CALL	_BUTX_GETPOS	; D4 <-- position atteinte	LOAD.L	D2,D4	CALL	_BUTX_RECULE	; D3/D4/D5 <-- caractre suivant	JUMP',NE END$	COMP.B	D3,#PEOT	JUMP',NE END$	DEC.L	D2	JUMP'	END$FOUND$:	CALL	_BUTX_GETPOS	; D4 <-- position atteinte	DEC.L	D4	LOAD.L	D2,D4END$:	LOAD.W	D4,(SP)+OBGCPIN	CALL	_BUTX_POSEND	; revient  la position initiale	LOAD.L	D4,D2		; D4 <-- position atteinte	ADD.L	SP,#LBGC	; POP variables locales	POPM.L	D0..D3,D5,A2	RET;-----------\\; BASPOSCURS >;===========/; Donne la position du curseur.; in	A4.L	^objet texte; out	D3.L	P1 (y;x);	D4.L	P2 (y;x);	D7.W	erreur; mod	D3.L, D4.L, D7.WBASPOSCURS:	LOAD.W	D7,#1	COMP.L	(A5)+OTXCP1,#-1	; position dj connue ?	JUMP',NE GIVE$		; oui => GIVE$	CALL	EDAFCURS	; cherche la position du curseurGIVE$:	LOAD.W	D7,#1		; D7 <-- position inconnue	LOAD.L	D3,(A5)+OTXCP1	; D3 <-- P1 curseur	COMP.L	D3,#-1	JUMP',EQ EXIT$	LOAD.L	D4,(A5)+OTXCP2	; D4 <-- P2 curseur	CLR.W	D7		; D7 <-- okEXIT$:	TEST.W	D7		; retour EQ/NE	RET;---------\\; EDAFCURS >;---------/; Cherche simplement la position du curseur.; in	A4.L	^objet texte; out	-; mod	D7.WEDAFCURS:	PUSHM.L	A3,A4	CALL	CARINIPT	; initialise pour CARGETPT	CALL	BASIXYCURS	; calcule la position du curseur	COMP.L	(A5)+OTXCP1,#-1	; curseur trouv ?	JUMP',NE PEND$		; oui => PEND$	LOAD.L	A3,A4NLOOP$:	CALL	BASNEXTPAVE	; A4 <-- ^pav suivant	JUMP',NE NEND$	CALL	BASIXYCURS	; calcule la position du curseur	COMP.L	(A5)+OTXCP1,#-1	; curseur trouv ?	JUMP',NE PEND$		; oui => PEND$	JUMP	NLOOP$NEND$:	LOAD.L	A4,A3PLOOP$:	CALL	BASPREVPAVE	; A4 <-- ^pav prcdent	JUMP',NE PEND$	CALL	BASIXYCURS	; calcule la position du curseur	COMP.L	(A5)+OTXCP1,#-1	; curseur trouv ?	JUMP,EQ PLOOP$		; non => PLOOP$PEND$:	POPM.L	A3,A4	RET;------------\\; EDAFMAJALLi >;============/; Raffiche tout ce qui est ncessaire pendant l'dition, en se; laissant interrompre le plus souvent possible (entre chaque ligne).; in	A4.L	^objet texte; out	D7.W	ok; mod	D7.W	.PC	PCVAR	.LOC	0OEAMRPP:.BLKB	4		; recule: ^pavOEAMRPL:.BLKB	4		; recule: ^ligneOEAMAPP:.BLKB	4		; avance: ^pavOEAMAPL:.BLKB	4		; avance: ^ligneLEAM:	.PC	PCCODEEDAFMAJALLi:	PUSHM.L	D4,D6,A2..A4	SUB.L	SP,#LEAM	; SP <-- ^variables locales	CALL	CARINIPT	; initialise pour CARGETPT	LOAD.L	D6,(A4)+OOBCHT	CALL	CARMODSPY	; prjustification <-- selon les espions	CALL	BASCLRCURS	; teint le curseur	LOAD.L	(A5)+OTXCP1,#-1	; curseur pas (encore) retrouv	CALL	EDIFEVENT	; une touche presse ?	JUMP,EQ EXIT$		; oui => EXIT$	LOAD.L	(A5)+OTXVUE,#2^BVUESET!2^BVUEPROV!2^BVUEPROVI	LOAD.L	(A5)+OTXMOD,#SETDOT!2^BVUECHAR	CALL	CARPOSDIM	; cherche position/dimensions du pav; Cherche la table de prjustification de la ligne o est le curseur.	CALL	_BUTX_GETPOS	; D4 <-- position du curseur	CALL	CARPJSEARCH	; A3 <-- ^dans OPJxxx	JUMP',EQ BEGIN$	TEST.L	(A4)+OOBPPJ	; table OPJxxx existe ?	JUMP',NE PTL$		; oui => PTL$	CALL	CARCOUPEPALL	; calcule la table OPJxxx	JUMP,NE EXIT$PTL$:	LOAD.L	A3,(A4)+OOBPPJ	; A3 <-- ^table OPJxxxBEGIN$:	LOAD.L	(SP)+OEAMRPP,A4	LOAD.L	(SP)+OEAMRPL,A3	LOAD.L	(SP)+OEAMAPP,A4	LOAD.L	(SP)+OEAMAPL,A3; Affiche la ligne o est le curseur.	CALL	EDIFEVENT	; une touche presse ?	JUMP,EQ EXIT$		; oui => EXIT$	CALL	EDAFMAJLINE	; affiche la ligne o est le curseur; Affiche la ligne aprs le curseur.CN$:;	LOAD.L	A4,(SP)+OEAMAPP;	LOAD.L	A3,(SP)+OEAMAPL	CALL	EDIFEVENT	; une touche presse ?	JUMP,EQ EXIT$		; oui => EXIT$	CALL	CARPJNEXT	; A3/A4 <-- ^ligne suivante	JUMP',NE CP$	CALL	EDAFMAJLINE	; affiche la ligne aprs le curseur	LOAD.L	(SP)+OEAMAPP,A4	LOAD.L	(SP)+OEAMAPL,A3; Affiche la ligne avant le curseur.CP$:	LOAD.L	A4,(SP)+OEAMRPP	LOAD.L	A3,(SP)+OEAMRPL	CALL	EDIFEVENT	; une touche presse ?	JUMP,EQ EXIT$		; oui => EXIT$	CALL	CARPJPREV	; A3/A4 <-- ^ligne prcdente	JUMP',NE PN$	CALL	EDAFMAJLINE	; affiche la ligne avant le curseur	LOAD.L	(SP)+OEAMRPP,A4	LOAD.L	(SP)+OEAMRPL,A3; Affiche les lignes suivantes dans le mme pav.PN$:	LOAD.L	A4,(SP)+OEAMAPP	LOAD.L	A3,(SP)+OEAMAPL	LOAD.L	A2,A4PNLOOP$:	CALL	EDIFEVENT	; une touche presse ?	JUMP,EQ EXIT$		; oui => EXIT$	CALL	CARPJNEXT	; A3/A4 <-- ^ligne suivante	JUMP',NE PP$	COMP.L	A4,A2		; est-on toujours dans le mme pav ?	JUMP',NE PP$		; non => PP$	CALL	EDAFMAJLINE	; affiche une ligne suivante	LOAD.L	(SP)+OEAMAPP,A4	LOAD.L	(SP)+OEAMAPL,A3	JUMP	PNLOOP$; Affiche les lignes prcdentes dans le mme pav.PP$:	LOAD.L	A4,(SP)+OEAMRPP	LOAD.L	A3,(SP)+OEAMRPL	LOAD.L	A2,A4PPLOOP$:	CALL	EDIFEVENT	; une touche presse ?	JUMP,EQ EXIT$		; oui => EXIT$	CALL	CARPJPREV	; A3/A4 <-- ^ligne prcdente	JUMP',NE FN$	COMP.L	A4,A2		; est-on toujours dans le mme pav ?	JUMP',NE FN$		; non => FN$	CALL	EDAFMAJLINE	; affiche une ligne prcdente	LOAD.L	(SP)+OEAMRPP,A4	LOAD.L	(SP)+OEAMRPL,A3	JUMP	PPLOOP$; Affiche toutes les lignes suivantes jusqu' la fin.FN$:	LOAD.W	D7,#MI_SCMO	PAGE_	MISC		; remet la souris	LOAD.L	A4,(SP)+OEAMAPP	LOAD.L	A3,(SP)+OEAMAPL	LOAD.L	A2,A4FNLOOP$:	CALL	EDIFEVENT	; une touche presse ?	JUMP',EQ EXIT$		; oui => EXIT$	CALL	CARPJNEXT	; A3/A4 <-- ^ligne suivante	JUMP',NE FP$	COMP.L	A4,A2		; est-on toujours dans le mme pav ?	JUMP',EQ FNDRAW$	; oui => FNDRAW$	LOAD.L	A2,A4	LOAD.W	D7,#MI_SCMO	PAGE_	MISC		; remet la sourisFNDRAW$:	CALL	EDAFMAJLINE	; affiche une ligne suivante	JUMP	FNLOOP$; Affiche toutes les lignes prcdentes jusqu'au dbut.FP$:	LOAD.W	D7,#MI_SCMO	PAGE_	MISC		; remet la souris	LOAD.L	A4,(SP)+OEAMRPP	LOAD.L	A3,(SP)+OEAMRPL	LOAD.L	A2,A4FPLOOP$:	CALL	EDIFEVENT	; une touche presse ?	JUMP',EQ EXIT$		; oui => EXIT$	CALL	CARPJPREV	; A3/A4 <-- ^ligne prcdente	JUMP',NE EXIT$	COMP.L	A4,A2		; est-on toujours dans le mme pav ?	JUMP',EQ FPDRAW$	; oui => FPDRAW$	LOAD.L	A2,A4	LOAD.W	D7,#MI_SCMO	PAGE_	MISC		; remet la sourisFPDRAW$:	CALL	EDAFMAJLINE	; affiche une ligne prcdente	JUMP	FPLOOP$EXIT$:	ADD.L	SP,#LEAM	; POP variables locales	POPM.L	D4,D6,A2..A4	CLR.W	D7		; retour EQ	RET;------------\\; EDAFMAJLINE >;------------/; Affiche une ligne quelconque.; in	A4.L	^objet texte;	A3.L	^dans OPJxxx; out	-; mod	D7.WEDAFMAJLINE:	TEST.B	(A4)+OOBNODR	; pav dans une autre page ?	JUMP',NE EXIT$		; oui => EXIT$	TEST.B	(A3)+OPJFLG:#BPJFLAFF ; ligne dj affiche ?	JUMP',BS CURS$		; oui => CURS$	CALL	EDAFLINE	; affiche une ligne	TSET.B	(A3)+OPJFLG:#BPJFLAFF ; indique ligne afficheCURS$:	COMP.L	(A5)+OTXCP1,#-1	; curseur dj trouv ?	JUMP',NE EXIT$		; oui => EXIT$	CALL	BASIXCURS	; calcule la position du curseur	CALL	BASSETCURS	; allume le curseur (si trouv)	CALL	BASSETREGLE	; dessine la rgleEXIT$:	RET;---------\\; EDAFLINE >;---------/; Affiche une ligne de texte.; Le curseur est dplac au dbut de la ligne suivante !; in	A4.L	^objet texte;	A3.L	^dans OPJxxx; out	-; mod	D7.WEDAFLINE:	PUSHM.L	D2..D4,A2	CALL	_BUTX_POSSAVE	; D4 <-- no de la position	LOAD.W	D2,D4	CALL	CARPOSDIM	; cherche position/dimensions du pav	LOAD.W	D3,(A5)+OTXPOS+0	ADD.W	D3,(A3)+OPJPYR	; D3 <-- position dbut en Y	LOAD.W	D4,D3	ADD.W	D4,(A3)+OPJIL	; D4 <-- position fin en Y	PUSHM.L	A3,A4	PUSH.L	(A5)+OTXPOS	PUSH.L	(A5)+OTXDIM	CALL	CARPJNEXT	; A3/A4 <-- ^ligne suivante	POP.L	(A5)+OTXDIM	POP.L	(A5)+OTXPOS	LOAD.L	A2,A4		; A2 <-- ^pav suivant	POPM.L	A3,A4	TEST.W	D7		; est-ce la dernire ligne du texte ?	JUMP',NE DOWNY$		; oui => DOWNY$	COMP.L	A4,A2		; est-ce la dernire ligne du pav ?	JUMP',EQ OKY$		; non => OKY$DOWNY$:	LOAD.W	D4,(A5)+OTXPOS+0	ADD.W	D4,(A5)+OTXDIM+0 ; D4 <-- position fin en Y (jusqu'en bas)OKY$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,(A5)+OTXPOS+2 ; D3 <-- position dbut en X	LOAD.W	D4,(A5)+OTXDIM+2	ADD.W	D4,D3		; D4 <-- position fin en X	PUSH.L	D4	LOAD.L	D4,#1		; D4 <-- mode couleur	LOAD.W	D7,#DR_BMOPENMODE	PAGE_	DRAW		; indique un bitmap couleur	POP.L	D4	LOAD.W	D7,#DR_BMOPENDIM	PAGE_	DRAW		; dbut du dessin dans un bitmap	JUMP',NE EXIT$	CALL	BASAFLINE	; affiche la ligne	LOAD.W	D7,#DR_BMUPDALL	PAGE_	DRAW		; indique qu'il faut tout mettre  jour	LOAD.W	D7,#DR_BMCLOSE	PAGE_	DRAW		; fin du dessin dans un bitmapEXIT$:	LOAD.W	D4,D2	CALL	_BUTX_POSEND	; revient o l'on tait	POPM.L	D2..D4,A2	RET;----------\\; EDIFEVENT >;----------/; Regarde si un vnement (une touche presse) est survenu.; in	-; out	D7.W	ok si touche presse; mod	D7.WEDIFEVENT:	PUSHM.L	D3,D4	LOAD.W	D7,#MI_TESTEVENT	PAGE_	MISC		; une touche presse ?	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;------------\\; EDAFMAJALLv >;============/; Affiche tous les pavs, et change ventuellement de page si; le curseur s'est beaucoup dplac.; in	A4.L	^objet texte; out	D7.W	ok; mod	D7.WEDAFMAJALLv:	PUSHM.L	A0,A4	LOAD.L	A0,(A5)+OPDDIS	; A0 <-- ^descripteur fentre	CALL	EDAFMAJALL	; affiche tous les pavs	LOAD.W	D7,#MI_GETROOT	PAGE_	MISC		; A4 <-- ^racine de l'objet texte	LOAD.W	D7,#MI_EDITVISU	PAGE_	MISC		; change v. de page	POPM.L	A0,A4	CLR.W	D7		; retour EQ	RET;-----------\\; EDAFMAJALL >;===========/; Affiche tous les pavs de texte pendant l'dition.;  1)	affiche l'objet donn en entre (o est le curseur);  2)	affiche les objets suivants;  3)	affiche les objets prcdents; in	A4.L	^objet texte; out	D7.W	ok; mod	D7.WEDAFMAJALL:	PUSHM.L	D6,A3,A4	CALL	CARINIPT	; initialise pour CARGETPT	LOAD.L	D6,(A4)+OOBCHT	CALL	CARMODSPY	; prjustification <-- selon les espions	CALL	BASCLRCURS	; teint le curseur	LOAD.L	(A5)+OTXCP1,#-1	; curseur pas (encore) retrouv	CALL	EDAFMAJPAVE	; affiche le pav courant	LOAD.L	A3,A4NLOOP$:	CALL	BASNEXTPAVE	; A4 <-- ^pav suivant	JUMP',NE NEND$	CALL	EDAFMAJPAVE	; affiche un pav suivant	JUMP	NLOOP$NEND$:	LOAD.L	A4,A3PLOOP$:	CALL	BASPREVPAVE	; A4 <-- ^pav prcdent	JUMP',NE PEND$	CALL	EDAFMAJPAVE	; affiche un pav prcdent	JUMP	PLOOP$PEND$:	POPM.L	D6,A3,A4	CLR.W	D7		; retour EQ	RET;------------\\; EDAFMAJPAVE >;------------/; Affiche un pav de texte pendant l'dition.; in	A4.L	^objet texte; out	-; mod	D7.WEDAFMAJPAVE:	PUSHM.L	D1..D4	TEST.B	(A4)+OOBNODR	; pav dans une autre page ?	JUMP',NE EXIT$		; oui => EXIT$	LOAD.L	D4,#1		; D4 <-- mode couleur	LOAD.W	D7,#DR_BMOPENMODE	PAGE_	DRAW		; indique un bitmap couleur	CALL	EDDIMPAVE	; D3/D4 <-- dimensions du pav	LOAD.W	D7,#DR_BMOPENDIM	PAGE_	DRAW		; dbut du dessin dans un bitmap	JUMP',NE EXIT$	CALL	EDCADREPAVE	; dessine le cadre	LOAD.L	D1,#2^BVUESET!2^BVUEPROV!2^BVUEPROVI	LOAD.L	D2,#SETDOT!2^BVUECHAR ; D2 <-- mode de dessin	CALL	BASAFPAVE	; dessine le contenu du pav	LOAD.W	D7,#DR_BMUPDALL	PAGE_	DRAW		; indique qu'il faut tout mettre  jour	LOAD.W	D7,#DR_BMCLOSE	PAGE_	DRAW		; fin du dessin dans un bitmap	COMP.L	(A5)+OTXCP1,#-1	; curseur dj trouv ?	JUMP',NE EXIT$		; oui => EXIT$	CALL	BASIXYCURS	; calcule la position du curseur	CALL	BASSETCURS	; allume le curseur (si trouv)	CALL	BASSETREGLE	; dessine la rgleEXIT$:	POPM.L	D1..D4	RET;---------\\; EDAFPAVE >;---------/; Affiche un pav de texte pendant l'dition.; Le pav est affich dans un bitmap (d'un coup) avec un; rectangle traitill autour.; in	A4.L	^objet texte; out	-; mod	D7.WEDAFPAVE:	PUSHM.L	D1..D4	CALL	CARINIPT	; initialise pour CARGETPT	TEST.B	(A4)+OOBNODR	; pav dans une autre page ?	JUMP',NE EXIT$		; oui => EXIT$	LOAD.L	D4,#1		; D4 <-- mode couleur	LOAD.W	D7,#DR_BMOPENMODE	PAGE_	DRAW		; indique un bitmap couleur	CALL	EDDIMPAVE	; D3/D4 <-- dimensions du pav	LOAD.W	D7,#DR_BMOPENDIM	PAGE_	DRAW		; dbut du dessin dans un bitmap	JUMP',NE EXIT$	CALL	EDCADREPAVE	; dessine le cadre	LOAD.L	D1,#2^BVUESET!2^BVUEPROV!2^BVUEPROVI	LOAD.L	D2,#SETDOT!2^BVUECHAR ; D2 <-- mode de dessin	CALL	BASAFPAVE	; dessine le contenu du pav	LOAD.W	D7,#DR_BMUPDALL	PAGE_	DRAW		; indique qu'il faut tout mettre  jour	LOAD.W	D7,#DR_BMCLOSE	PAGE_	DRAW		; fin du dessin dans un bitmapEXIT$:	POPM.L	D1..D4	RET;------------\\; EDCADREPAVE >;------------/; Dessine le cadre autour d'un pav pendant l'dition.; in	D3.L	P1 (y;x);	D4.L	P2 (y;x); out	-; mod	D7.WEDCADREPAVE:	PUSHM.L	D1..D4	PUSH.L	D4	LOAD.L	D4,#H'10000*H'FFFF+COLORSELECT	LOAD.W	D7,#DR_COLORINIT	PAGE_	DRAW		; spcifie les couleurs	POP.L	D4	LOAD.L	D2,D4	LOAD.W	D4,#1	LOAD.W	D7,#MA_SCALEN	PAGE_	MATH		; D4 <-- retrait d'un point [obj]	EX.L	D2,D4	SUB.W	D4,D2	SWAP.W	D4	SUB.W	D4,D2		; P2 <-- dans le bitmap visible !	SWAP.W	D4	LOAD.W	D1,#B'00110011	; D1 <-- map pour traitill	LOAD.W	D2,#SETDOT!TTTDOT	LOAD.W	D7,#DR_RECTHV	PAGE_	DRAW		; dessine un rectangle pointill	POPM.L	D1..D4	RET;----------\\; EDDIMPAVE >;----------/; Calcule les dimensions pendant l'dition d'un pav de texte.; Rserve une marge de 3 points [scr] tout autour.; in	A4.L	^objet texte; out	D3.L	P1 (y;x);	D4.L	P2 (y;x); mod	D3.L, D4.L, D7.WEDDIMPAVE:	PUSHM.L	D1,D2	CALL	GETP1		; D4 <-- P1	LOAD.L	D3,D4	LOAD.L	D2,D4	CALL	GETP2		; D4 <-- P2	EX.L	D2,D4	LOAD.L	D1,D2	CALL	RECTOR		; D3/D4 <-- rectangle englobant	LOAD.L	D2,D4	CALL	GETP3		; D4 <-- P3	EX.L	D2,D4	LOAD.L	D1,D2	CALL	RECTOR		; D3/D4 <-- rectangle englobant	LOAD.L	D2,D4	CALL	GETP4		; D4 <-- P4	EX.L	D2,D4	LOAD.L	D1,D2	CALL	RECTOR		; D3/D4 <-- rectangle englobant	LOAD.L	D2,D4	LOAD.W	D4,#3	LOAD.W	D7,#MA_SCALEN	PAGE_	MATH		; D4 <-- marge [obj]	EX.L	D2,D4	SUB.W	D3,D2	SWAP.W	D3	SUB.W	D3,D2		; P1 <-- plus en haut  gauche	SWAP.W	D3	LOAD.L	D2,D4	LOAD.W	D4,#3+1	LOAD.W	D7,#MA_SCALEN	PAGE_	MATH		; D4 <-- marge [obj]	EX.L	D2,D4	ADD.W	D4,D2	SWAP.W	D4	ADD.W	D4,D2		; P2 <-- plus en bas  droite	SWAP.W	D4	POPM.L	D1,D2	RET;----------\\; BASAFPAVE >;==========/; Affiche un pav de texte.; in	A4.L	^objet texte;	D2.L	mode de dessin;	D1.L	mode de la vue; out	-; mod	D7.WBASAFPAVE:	PUSHM.L	D3,D4,D6,A3	CALL	CARINIPT	; initialise pour CARGETPT	LOAD.L	D4,#H'10000*COLORFPAGE+COLORCDRAW	LOAD.W	D7,#DR_COLORINIT	PAGE_	DRAW		; spcifie les couleurs	LOAD.L	(A5)+OTXMOD,D2	; OTXMOD <-- mode	LOAD.L	(A5)+OTXVUE,D1	; OTXVUE <-- vue	LOAD.L	D6,(A4)+OOBCHT	; D6 <-- canal pour le buffer de texte	CALL	_BUTX_POSSAVE	; D4 <-- no de la position	PUSH.W	D4	TEST.L	(A4)+OOBPPJ	; table OPJxxx existe ?	JUMP',NE DRAW$		; oui => DRAW$	CALL	CARCOUPEPALL	; calcule la table OPJxxx	JUMP,NE EXIT$DRAW$:	CALL	CARPOSDIM	; cherche position/dimensions du pav	LOAD.L	A3,(A4)+OOBPPJ	; A3 <-- ^table OPJxxxLOOP$:	CALL	CARPJVALID	; valide l'information (si ncessaire)	TEST.W	(A3)+OPJNBC	; encore une ligne ?	JUMP,EQ OK$		; non => OK$	TEST.L	(A4)+OOBA	; pav de texte tourn ?	JUMP',NE LINE$		; oui => LINE$	LOAD.W	D4,(A5)+OTXPOS+0	ADD.W	D4,(A3)+OPJPYR	LOAD.W	D3,(A3)+OPJBL	SUB.W	D3,(A3)+OPJH1	JUMP',NC DOWN$	ADD.W	D4,D3DOWN$:	SWAP.W	D4	LOAD.W	D7,#MA_OBJDRAW	PAGE_	MATH		; D4 <-- position [scr]	SWAP.W	D4	COMP.W	D4,(A0)+ODFFDY	; dpasse le bas de la swdo de dessin ?	JUMP',GE NEXT$		; oui => NEXT$	LOAD.W	D4,(A5)+OTXPOS+0	ADD.W	D4,(A3)+OPJPYR	ADD.W	D4,(A3)+OPJIL	LOAD.W	D3,(A3)+OPJIL	SUB.W	D3,(A3)+OPJBL	SUB.W	D3,(A3)+OPJH2	JUMP',NC UP$	SUB.W	D4,D3UP$:	SWAP.W	D4	LOAD.W	D7,#MA_OBJDRAW	PAGE_	MATH		; D4 <-- position [scr]	SWAP.W	D4	TEST.W	D4		; dpasse le haut de la swdo de dessin ?	JUMP',NS NEXT$		; oui => NEXT$LINE$:	CALL	BASAFLINE	; affiche une ligne de texteNEXT$:	LOAD.L	A3,#(A3)+LPJ	; A3 <-- ^description ligne suivante	JUMP	LOOP$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POP.W	D4	CALL	_BUTX_POSEND	; revient o l'on tait	POPM.L	D3,D4,D6,A3	RET;----------\\; BASAFLINE >;==========/; Affiche une ligne de texte.; Le curseur est dplac au dbut de la ligne suivante !; N'utilise pas BASPOSCLINE pour des raisons de vitesse ...; in	A4.L	^objet texte;	A3.L	^dans OPJxxx; out	-; mod	D7.W	.PC	PCVAR	.LOC	0OBALNBC:.BLKB	2		; nb de caractres restantOBALCNJ:.BLKB	2		; nb de caractres non justifisOBALLC:	.BLKB	1		; dernier caractre affich	.EVENLBAL:	.PC	PCCODEBASAFLINE:	PUSHM.L	D0..D5,A2	SUB.L	SP,#LBAL	; SP <-- ^variables locales	LOAD.L	A2,(A3)+OPJJUS	; A2 <-- ^table de justification	LOAD.L	D4,(A3)+OPJPDL	CALL	_BUTX_SETPOS	; va au dbut de la ligne	CALL	BASPOSBLINE	; D2 <-- position sur la ligne de base	LOAD.W	(SP)+OBALNBC,(A3)+OPJNBC	LOAD.W	(SP)+OBALCNJ,(A3)+OPJCNJ; Affiche tous les caractres de la ligne.	CALL	BASCALCSAJEX	; D0/D1 <-- reste/nb pour les SAJEXs	LOAD.B	D3,#SPACE	CLR.W	(A5)+OTXSNO	; pas de soulignementLOOP$:	LOAD.B	(SP)+OBALLC,D3	; OBALLC <-- dernier caractre affich	CALL	_BUTX_AVANCE	; D3/D4/D5 <-- caractre suivant	JUMP,NE END$	SWAP.W	D3	LOAD.W	D3,(SP)+OBALNBC	; D3 <-- 1 si dernier caractre	SWAP.W	D3	CALL	BASAFCAR	; affiche un caractre	TEST.B	(A2)+OJSMODE:#BJSMDA ; align ?	JUMP,BC NEXT$		; non => NEXT$				; oui =>	TEST.W	(SP)+OBALCNJ	; caractre non justifi ?	JUMP,GT NEXT$		; oui => NEXT$	COMP.B	D3,#SPACE	JUMP',NE ITC$	COMP.B	D3,(SP)+OBALLC	; dernier caractre tait dj un espace ?	JUMP',EQ ITC$		; oui => ITC$	TEST.W	(A2)+OJSESPC	; espacement entre les caractres ?	JUMP',EQ SAJEX$		; non => SAJEX$				; oui =>	CLR.L	D3	LOAD.W	D3,(A2)+OJSESPC	; D3 <-- espacement entre les caractres	SUB.L	D3,#100	NEG.L	D3	DIV.WU	D3,#5SLOOP$:	CALL	BASAFSAJEX	; affiche un "sajex"	DEC.W	D3	JUMP,NC SLOOP$	LOAD.B	D3,#SPACE	JUMP'	NEXT$ITC$:	TEST.W	(A2)+OJSESPC	; espacement entre les caractres ?	JUMP',EQ NEXT$		; non => NEXT$SAJEX$:	CALL	BASAFSAJEX	; affiche un "sajex";	JUMP'	NEXT$NEXT$:	DEC.W	(SP)+OBALCNJ	; un caractre non justifi de moins	DEC.W	(SP)+OBALNBC	; encore un caractre  afficher ?	JUMP,NE LOOP$		; oui => LOOP$; Affiche ventuellement le tiret en fin de ligne, s'il y a eu; division automatique. Utilise le mme gencar que pour le dernier; caractre affich.END$:	CLR.L	D3	LOAD.B	D3,(A3)+OPJEOL	; D3 <-- info eol	COMP.B	D3,#'-	JUMP',NE EOL$	CALL	BASAFCAR	; affiche le tiretEOL$:	CLR.W	D0	CALL	BASAFSOUL	; affiche le soulignement si ncessaire	ADD.L	SP,#LBAL	; POP variables locales	POPM.L	D0..D5,A2	RET;-----------\\; BASIXYCURS >;===========/; Calcule la position du curseur, s'il est dans le pav donn.; in	A4.L		^objet texte; out	(A5)+OTXCP1.L	P1 (y;x);	(A5)+OTXCP2.L	P2 (y;x); mod	D7.WBASIXYCURS:	PUSHM.L	D2..D6,A3	TEST.B	(A4)+OOBNODR	; pav dans une autre page ?	JUMP,NE ERROR$		; oui => ERROR$	LOAD.L	D6,(A4)+OOBCHT	; D6 <-- canal pour le buffer de texte	TEST.L	(A4)+OOBPPJ	; table OPJxxx existe ?	JUMP',NE POS$		; oui => POS$	CALL	CARCOUPEPALL	; calcule la table OPJxxx	JUMP,NE ERROR$POS$:	CALL	CARPOSDIM	; cherche position/dimensions du pav; Cherche verticalement dans quelle ligne est le curseur.	CALL	_BUTX_GETINFO	; D3/D4/D5 <-- ?/nb car/?	LOAD.L	D5,D4		; D5 <-- nb de caractres	CALL	_BUTX_GETPOS	; D4 <-- position du curseur	LOAD.L	A3,(A4)+OOBPPJ	; A3 <-- ^table OPJxxx	LOAD.L	D3,(A3)+OPJPDL	; D3 <-- position dbut premire ligne	TEST.L	D5		; pav vide ?	JUMP',EQ XSEARCH$	; oui => XSEARCH$YLOOP$:	CALL	CARPJVALID	; valide l'information (si ncessaire)	CLR.L	D2	LOAD.W	D2,(A3)+OPJNBC	; encore une ligne ?	JUMP',EQ ERROR$		; non => ERROR$	COMP.L	D4,D3		; est-ce que le curseur est avant cette ligne ?	JUMP',LO ERROR$		; oui => ERROR$	ADD.L	D3,D2		; D3 <-- position dbut ligne suivante	COMP.L	D4,D3		; est-ce que le curseur est aprs cette ligne ?	JUMP',LO XSEARCH$	; non => XSEARCH$ (trouv)	LOAD.L	A3,#(A3)+LPJ	; A3 <-- ^description ligne suivante	JUMP	YLOOP$; Cherche horizontalement o est le curseur dans la ligne.XSEARCH$:	CALL	BASPOSCLINE	; D2 <-- position (y;x)	SWAP.W	D2	LOAD.L	D4,D2	SUB.W	D4,(A3)+OPJBL	SWAP.W	D4	CALL	BASPOSROT	; D4 <-- point tourn	LOAD.L	(A5)+OTXCP1,D4	LOAD.L	D4,D2	SUB.W	D4,(A3)+OPJBL	ADD.W	D4,(A3)+OPJIL	SWAP.W	D4	CALL	BASPOSROT	; D4 <-- point tourn	LOAD.L	(A5)+OTXCP2,D4	LOAD.L	(A5)+OTXCPP,A4	LOAD.L	(A5)+OTXCPJ,(A3)+OPJJUS	JUMP'	EXIT$ERROR$:	LOAD.L	(A5)+OTXCP1,#-1	; curseur pas trouvEXIT$:	POPM.L	D2..D6,A3	RET;----------\\; BASIXCURS >;==========/; Calcule la position du curseur, s'il est dans la ligne donne.; in	A4.L		^objet texte;	A3.L		^dans OPJxxx; out	(A5)+OTXCP1.L	P1 (y;x);	(A5)+OTXCP2.L	P2 (y;x); mod	D7.WBASIXCURS:	PUSHM.L	D2..D4	CALL	_BUTX_GETPOS	; D4 <-- position du curseur	LOAD.L	D3,(A3)+OPJPDL	; D3 <-- position dbut ligne	COMP.L	D4,D3		; curseur avant la ligne ?	JUMP',LO EXIT$		; oui => EXIT$	CLR.L	D2	LOAD.W	D2,(A3)+OPJNBC	ADD.L	D3,D2		; D3 <-- position fin ligne	COMP.L	D4,D3		; curseur aprs la ligne ?	JUMP',HS EXIT$		; oui => EXIT$	CALL	CARPOSDIM	; cherche position/dimensions du pav	CALL	BASPOSCLINE	; D2 <-- position (y;x)	SWAP.W	D2	LOAD.L	D4,D2	SUB.W	D4,(A3)+OPJBL	SWAP.W	D4	CALL	BASPOSROT	; D4 <-- point tourn	LOAD.L	(A5)+OTXCP1,D4	LOAD.L	D4,D2	SUB.W	D4,(A3)+OPJBL	ADD.W	D4,(A3)+OPJIL	SWAP.W	D4	CALL	BASPOSROT	; D4 <-- point tourn	LOAD.L	(A5)+OTXCP2,D4	LOAD.L	(A5)+OTXCPP,A4	LOAD.L	(A5)+OTXCPJ,(A3)+OPJJUSEXIT$:	POPM.L	D2..D4	RET;------------\\; BASPOSCLINE >;------------/; Cherche la position d'un caractre dans une ligne.; in	A4.L	^objet texte;	A3.L	^dans OPJxxx;	D4.L	position du caractre dans BUTX; out	D2.L	position du caractre (y;x); mod	D2.L, D7.W	.PC	PCVAR	.LOC	0OBPLPIN:.BLKB	2		; position initialeOBPLNBA:.BLKB	2		; nb de caractres  avancerOBPLNBC:.BLKB	2		; nb de caractres restantOBPLCNJ:.BLKB	2		; nb de caractres non justifisOBPLLC:	.BLKB	1		; dernier caractre affich	.EVENLBPL:	.PC	PCCODEBASPOSCLINE:	PUSHM.L	D0,D1,D3..D5,A2	SUB.L	SP,#LBPL	; SP <-- ^variables locales	LOAD.L	A2,(A3)+OPJJUS	; A2 <-- ^table de justification	CALL	BASPOSBLINE	; D2 <-- position sur la ligne de base	LOAD.L	D3,D4		; D3 <-- position dans BUTX	CALL	_BUTX_POSSAVE	; D4 <-- no de la position initiale	LOAD.W	(SP)+OBPLPIN,D4	LOAD.L	D4,(A3)+OPJPDL	SUB.L	D3,D4		; D3 <-- nb de caractres  avancer dans la ligne	JUMP,LO END$	LOAD.W	(SP)+OBPLNBA,D3;	LOAD.L	D4,(A3)+OPJPDL	CALL	_BUTX_SETPOS	; va au dbut de la ligne	LOAD.W	(SP)+OBPLNBC,(A3)+OPJNBC	LOAD.W	(SP)+OBPLCNJ,(A3)+OPJCNJ	CALL	BASCALCSAJEX	; D0/D1 <-- reste/nb pour les SAJEXs	LOAD.B	D3,#SPACELOOP$:	DEC.W	(SP)+OBPLNBA	JUMP,NS END$	LOAD.B	(SP)+OBPLLC,D3	; OBPLLC <-- dernier caractre affich	CALL	_BUTX_AVANCE	; D3/D4/D5 <-- caractre suivant	JUMP,NE END$	CALL	CARCHASSETAB	; D5 <-- chasse	ADD.W	D2,D5		; D2 <-- avance dans la ligne	TEST.B	(A2)+OJSMODE:#BJSMDA ; align ?	JUMP,BC NEXT$		; non => NEXT$				; oui =>	TEST.W	(SP)+OBPLCNJ	; caractre non justifi ?	JUMP,GT NEXT$		; oui => NEXT$	COMP.B	D3,#SPACE	JUMP',NE ITC$	COMP.B	D3,(SP)+OBPLLC	; dernier caractre tait dj un espace ?	JUMP',EQ ITC$		; oui => ITC$	TEST.W	(A2)+OJSESPC	; espacement entre les caractres ?	JUMP',EQ SAJEX$		; non => SAJEX$				; oui =>	CLR.L	D3	LOAD.W	D3,(A2)+OJSESPC	; D3 <-- espacement entre les caractres	SUB.L	D3,#100	NEG.L	D3	DIV.WU	D3,#5SLOOP$:	CALL	BASAFSAJEX	; affiche un "sajex"	DEC.W	D3	JUMP,NC SLOOP$	LOAD.B	D3,#SPACE	JUMP'	NEXT$ITC$:	TEST.W	(A2)+OJSESPC	; espacement entre les caractres ?	JUMP',EQ NEXT$		; non => NEXT$SAJEX$:	CALL	BASAFSAJEX	; affiche un "sajex";	JUMP'	NEXT$NEXT$:	DEC.W	(SP)+OBPLCNJ	; un caractre non justifi de moins	DEC.W	(SP)+OBPLNBC	; encore un caractre  afficher ?	JUMP,NE LOOP$		; oui => LOOP$END$:	LOAD.W	D4,(SP)+OBPLPIN	CALL	_BUTX_POSEND	; revient  la position initiale	ADD.L	SP,#LBPL	; POP variables locales	POPM.L	D0,D1,D3..D5,A2	RET;------------\\; BASPOSBLINE >;------------/; Calcule la position du dbut de la ligne.; in	A4.L	^objet texte;	A3.L	^dans OPJxxx; out	D2.L	position dbut ligne (y;x); mod	D2.L, D7.WBASPOSBLINE:	PUSHM.L	D3,D4,A2	LOAD.L	A2,(A3)+OPJJUS	; A2 <-- ^table de justification	LOAD.L	D2,(A5)+OTXPOS	SWAP.W	D2	ADD.W	D2,(A3)+OPJPYR	ADD.W	D2,(A3)+OPJBL	SWAP.W	D2		; D2 <-- position sur la ligne de base	TEST.B	(A3)+OPJFLG:#BPJFLFIRST ; premire ligne du paragraphe ?	JUMP',BS IND$		; oui => IND$	LOAD.W	D4,(A3)+OPJIND	; D4 <-- indentation	JUMP',NE RENF$IND$:	LOAD.W	D4,(A2)+OJSESPG	TEST.B	(A3)+OPJFLG:#BPJFLFIRST ; premire ligne du paragraphe ?	JUMP',BC RENF$		; non => RENF$	ADD.W	D4,(A2)+OJSESPR	; D4 <-- tient compte du renfoncementRENF$:	ADD.W	D2,D4	LOAD.W	D3,(A5)+OTXDIM+2	SUB.W	D3,D4	SUB.W	D3,(A2)+OJSESPD	SUB.W	D3,(A3)+OPJLX	; D3 <-- largeur laisse vide	JUMP',LE EXIT$	TEST.W	(A3)+OPJCNJ	; ligne contient des tabulateurs ?	JUMP',NE EXIT$		; oui => EXIT$	TEST.B	(A2)+OJSMODE:#BJSMDG ; drapeau  gauche ?	JUMP',BS POSX$		; oui => POSX$	SR.W	D3,#1		; D3 <-- seulement la moiti	TEST.B	(A2)+OJSMODE:#BJSMDC ; centr ?	JUMP',BC EXIT$POSX$:	ADD.W	D2,D3		; D2 <-- avance en XEXIT$:	POPM.L	D3,D4,A2	RET;-------------\\; BASCALCSAJEX >;-------------/; Calcul la largeur des "sajex" en mode align.; in	A4.L	^objet texte;	A3.L	^dans OPJxxx; out	D1.L	reste/nb pour les SAJEXs;	D0.L	rpartiteur du reste; mod	D0.L, D1.L, D7.WBASCALCSAJEX:	PUSHM.L	D3,D4,A2	LOAD.L	A2,(A3)+OPJJUS	; A2 <-- ^table de justification	LOAD.B	D4,(A3)+OPJEOL	; D4 <-- info eol	COMP.B	D4,#CR		; fin de ligne force ?	JUMP,EQ NOJUST$		; oui => NOJUST$	COMP.B	D4,#TAB		; tabulateur ?	JUMP,EQ NOJUST$		; oui => NOJUST$	COMP.B	D4,#EOP		; fin du pav ?	JUMP,EQ NOJUST$		; oui => NOJUST$	COMP.B	D4,#PEOT	; fin du texte ?	JUMP,EQ NOJUST$		; oui => NOJUST$	LOAD.W	D1,(A3)+OPJNBS	; D1 <-- nb d'espaces	CLR.L	D3	LOAD.W	D3,(A2)+OJSESPC	; espaces entre tous les caractres ?	JUMP',EQ SPACE$		; non => SPACE$				; oui =>	SUB.L	D3,#100	NEG.L	D3	DIV.WU	D3,#5	MUL.WU	D1,D3	ADD.W	D1,(A3)+OPJNBC	; D1 <-- nb de caractres + nb d'espaces	SUB.W	D1,(A3)+OPJCNJ	; D1 <-- ne compte pas les caractres non justifis	DEC.W	D1	COMP.B	D4,#SPACE	JUMP',NE 30$	DEC.W	D130$:	COMP.B	D4,#'-	JUMP',NE SPACE$	INC.W	D1SPACE$:	CLR.L	D3	LOAD.W	D3,(A5)+OTXDIM+2	TEST.B	(A3)+OPJFLG:#BPJFLFIRST ; premire ligne du paragraphe ?	JUMP',BS IND$		; oui => IND$	LOAD.W	D4,(A3)+OPJIND	; D4 <-- indentation	JUMP',NE RENF$IND$:	LOAD.W	D4,(A2)+OJSESPG	TEST.B	(A3)+OPJFLG:#BPJFLFIRST ; premire ligne du paragraphe ?	JUMP',BC RENF$		; non => RENF$	ADD.W	D4,(A2)+OJSESPR	; D3 <-- tient compte du renfoncementRENF$:	ADD.W	D4,(A2)+OJSESPD	ADD.W	D4,(A3)+OPJLX	; D4 <-- largeur occupe	SUB.W	D3,D4		; D3 <-- largeur laisse vide	JUMP',LE NOJUST$	TEST.W	D1	JUMP',LE NOJUST$	CLR.L	D0	LOAD.W	D0,D1	DIV.WU	D3,D1	LOAD.L	D1,D3		; D1 <-- reste/nb	SWAP.W	D3	TEST.W	D3	JUMP',EQ NOREST$	DIV.WU	D0,D3	LOAD.W	D3,D0	SWAP.W	D0	LOAD.W	D0,D3	SR.W	D0,#1		; D0 <-- rpartiteur du reste	JUMP',NE EXIT$	INC.W	D0	JUMP'	EXIT$NOJUST$:	CLR.L	D1		; D1 <-- n'aligne pas !NOREST$:	CLR.L	D0EXIT$:	POPM.L	D3,D4,A2	RET;-----------\\; BASAFSAJEX >;-----------/; Affiche un sajex (en ralit, avance sans rien afficher).; in	D2.L	position (y;x);	D1.L	reste/nb;	D0.L	rpartiteur du reste; out	D2.L	position suivante (y;x);	D1.L	nouveau reste;	D0.L	nouvelle rpartition du reste; mod	D0.L, D1.L, D2.L, D7.WBASAFSAJEX:	PUSH.W	D3	LOAD.W	D3,D1		; D3 <-- avance selon "nb"	TEST.W	D0	JUMP',EQ 20$	DEC.W	D0	JUMP',NE 40$	SWAP.W	D0	PUSH.W	D0	SWAP.W	D0	POP.W	D0		; D0[low] <-- D0[high]20$:	SWAP.W	D1	TEST.W	D1		; encore un reste ?	JUMP',EQ 30$		; non => 30$	DEC.W	D1		; D1 <-- un reste de moins	INC.W	D3		; D3 <-- avance selon "reste"30$:	SWAP.W	D140$:	ADD.W	D2,D3		; D2 <-- avance en X	POP.W	D3	RET;---------\\; BASAFCAR >;=========/; Affiche un caractre.; in	A4.L	^objet texte;	A3.L	^dans OPJxxx;	A2.L	^table de justification;	D2.L	position absolue (y;x);	D3.B	caractre;		 16..31: si 1 => pas de soulignement;	D4.L	info 1;	D5.L	info 2; out	D2.L	position suivante (y;x); mod	D2.L, D7.WBASAFCAR:	PUSHM.L	D0,D1,D3,D4,D5,A1..A4	LOAD.L	A1,A4		; A1 <-- ^objet	LOAD.L	D0,D4		; D0 <-- info1	AND.W	D0,#CCSOMSK	SR.W	D0,#CCSOSHI	; D0 <-- rang du soulignement (0..3)	COMP.W	D0,(A5)+OTXSNO	; toujours le mme type de soulignement ?	JUMP',EQ SOEND$		; oui => SOEND$	CALL	BASAFSOUL	; affiche le soulignementSOEND$:	COMP.B	D3,#TAB	JUMP,EQ TAB$	LOAD.L	D0,D3	AND.W	D0,#H'00FF	CLR.W	D5		; D5 <-- dplacement si indice/exposant	LOAD.L	D3,D4		; D3 <-- info1	AND.L	D3,#CCEXMSK;	SR.L	D3,#CCEXSHI	; D3 <-- rang de l'exposant (0..2)	SWAP.W	D3	TEST.W	D3	JUMP',EQ EXP$	CALL	CAREXPY		; D5 <-- position relative (+y)	COMP.W	D3,#2	JUMP',EQ EXP$	NEG.W	D5		; D5 <-- position relative (-y)EXP$:	LOAD.L	D3,D4		; D3 <-- info1	AND.W	D3,#CCGCMSK;	SR.W	D3,#CCGCSHI	; D3 <-- numro du gencar	CALL	CARGETPT	; A3/A4/D3/D4 <-- ^gencar/^chasses/h1;h2/interl	JUMP,NE EXIT$	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ NOCOUL$	; non => NOCOUL$	PUSHM.L	D0,D2,A4	LOAD.L	D3,D4	SWAP.W	D3		; D3 <-- couleur chair (selon CARGETPT)	LOAD.W	D2,#SETDOT	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D0,#IDENTCOLOR	LOAD.W	D1,#opDUSE	PAGE_	OBJCALL		; choisi la couleur pour dessiner le caractre	POPM.L	D0,D2,A4NOCOUL$:	LOAD.L	D4,D2		; D4 <-- position	SWAP.W	D4	ADD.W	D4,D5		; D4 <-- position selon indice/exposant	SWAP.W	D4	LOAD.W	D1,(A1)+OOBA+0	; D1 <-- angle de rotation	JUMP',EQ NOROT$	LOAD.L	D3,(A5)+OTXPOS	; D3 <-- centre de symtrie	LIB	?CALCPSYM	; D4 <-- nouvelle position (y;x)NOROT$:	LOAD.L	D1,D2		; D1 <-- position non tourne	LOAD.L	D3,D0		; D3 <-- caractre	TEST.B	(A5)+OTXVUE+3:#BVUEPROV-0	JUMP',BS 13$	COMP.B	D3,#CADRATIN	; cadratin ?	JUMP',NE 10$		; non => 10$	LOAD.B	D3,#SPACE	; oui => comme un espace10$:	COMP.B	D3,#CR		; fin de ligne ?	JUMP',NE 11$		; non => 11$	LOAD.B	D3,#SPACE	; oui => comme un espace11$:	COMP.B	D3,#EOP		; fin de ligne ?	JUMP',NE 12$		; non => 12$	LOAD.B	D3,#SPACE	; oui => comme un espace12$:	COMP.B	D3,#PEOT	; fin de ligne ?	JUMP',NE 13$		; non => 13$	LOAD.B	D3,#SPACE	; oui => comme un espace13$:	LOAD.L	D2,(A5)+OTXMOD	; D2 <-- mode d'affichage	EX.L	A4,A3		; A4 <-- ^gencar bitmap, A3 <-- ^chasses	LOAD.W	D7,#DR_CHARQ	PUSH.L	A2	LOAD.L	A2,(A5)+OADDRAW	CALL	(A2)		; PAGE_DRAW, affiche un caractre	POP.L	A2	COMP.B	D3,#CADRATIN	; cadratin ?	JUMP',NE 20$		; non => 20$	LOAD.B	D3,#SPACE	; oui => comme un espace20$:	COMP.B	D3,#CR		; fin de ligne ?	JUMP',NE 21$		; non => 21$	LOAD.B	D3,#SPACE	; oui => comme un espace21$:	COMP.B	D3,#EOP		; fin de ligne ?	JUMP',NE 22$		; non => 22$	LOAD.B	D3,#SPACE	; oui => comme un espace22$:	COMP.B	D3,#PEOT	; fin de ligne ?	JUMP',NE 23$		; non => 23$	LOAD.B	D3,#SPACE	; oui => comme un espace23$:	LOAD.L	D2,D1	SL.W	D3,#1	LOAD.W	D1,(A3)+(D3.W)	; D1 <-- largeur du caractre	ADD.W	D1,(A2)+OJSITCA	; D1 <-- largeur caractre + intercaractre	JUMP',NC ADDLG$	CLR.W	D1ADDLG$:	ADD.W	D2,D1		; D2 <-- position suivante	JUMP'	SOUL$TAB$:	LOAD.L	D0,D2	LOAD.W	D1,D2	SUB.W	D1,(A5)+OTXPOS+2	CALL	TABNEXT		; D1 <-- position suivante	ADD.W	D1,(A5)+OTXPOS+2	LOAD.W	D2,D1	TEST.B	(A5)+OTXVUE+3:#BVUEPROV-0	JUMP',BC SOUL$	CALL	BASAFTAB	; affiche un tabulateur;	JUMP'	SOUL$SOUL$:	TEST.W	(A5)+OTXSNO	; soulignement en cours ?	JUMP',EQ EXIT$		; non => EXIT$				; oui =>	SWAP.W	D3	COMP.W	D3,#1		; dernier caractre de la ligne ?	JUMP',EQ EXIT$		; oui => EXIT$	LOAD.W	(A5)+OTXSFX,D2	; OTXSFX <-- fin du soulignementEXIT$:	POPM.L	D0,D1,D3,D4,D5,A1..A4	RET;---------\\; BASAFTAB >;---------/; Affiche un tabulateur.; in	A4.L	^objet texte;	D0.L	position dbut (y;x);	D2.L	position fin (y;x);	D4.L	info 1 (du caractre TAB); out	-; mod	D7.WBASAFTAB:	PUSHM.L	D2..D4	COMP.L	D0,D2		; dbut = fin ?	JUMP,EQ EXIT$		; oui => EXIT$	PUSHM.L	A3,A4	LOAD.L	D3,D4		; D3 <-- info1	AND.W	D3,#CCGCMSK;	SR.W	D3,#CCGCSHI	; D3 <-- numro du gencar	CALL	CARGETPT	; A3/A4/D3/D4 <-- ^gencar/^chasses/h1;h2/interl	POPM.L	A3,A4	JUMP,NE EXIT$	SWAP.W	D3		; D3 <-- h1	SR.W	D3,#1		; D3 <-- h1/2	SWAP.W	D0	SWAP.W	D2	SUB.W	D0,D3	SUB.W	D2,D3	SWAP.W	D2	SWAP.W	D0	LOAD.L	D4,D0	CALL	BASPOSROT	LOAD.L	D3,D4		; D3 <-- dbut tourn	LOAD.L	D4,D2	CALL	BASPOSROT	; D4 <-- fin tourne	LIB	?AFTIM	.B	MAPTT	.B	B'00010001	; map traitill	.B	1		; chelle	.B	0	.EVEN	LOAD.L	D2,(A5)+OTXMOD	; D2 <-- mode d'affichage	TSET.L	D2:#BTTTDOT	LOAD.W	D7,#DR_LINE	PAGE_	DRAW		; trace une ligne pointilleEXIT$:	POPM.L	D2..D4	RET;----------\\; BASAFSOUL >;----------/; Affiche un soulignement.; in	A4.L	^objet texte;	A3.L	^dans OPJxxx;	A2.L	^table de justification;	D0.W	nouveau soulignement;	D2.L	position absolue (y;x); out	-; mod	D7.WBASAFSOUL:	PUSHM.L	D1,D3..D5	COMP.W	D0,(A5)+OTXSNO	; changement de soulignement ?	JUMP,EQ EXIT$		; non => EXIT$	LOAD.W	D3,(A5)+OTXSNO	; D3 <-- ancien type de soulignement	JUMP,EQ NEXT$	LOAD.W	D1,(A2)+OJSSOUD	; D1 <-- distance	JUMP',NE POS$	LOAD.W	D1,#05*FACMMPTPOS$:	LOAD.W	D5,(A2)+OJSSOUH	; D5 <-- paisseur	JUMP',NE EP$	LOAD.W	D5,#02*FACMMPTEP$:	COMP.W	D3,#3		; biff ?	JUMP',EQ BIFF$	LOAD.W	D4,(A5)+OTXSPY	ADD.W	D4,D1	CALL	BASAFSDRAW	; affiche un trait de soulignement	COMP.W	D3,#2		; double soulignement ?	JUMP',NE NEXT$	LOAD.W	D4,(A5)+OTXSPY	ADD.W	D4,D1	ADD.W	D4,D5	ADD.W	D4,D1	CALL	BASAFSDRAW	; affiche un deuxime trait de soulignement	JUMP'	NEXT$BIFF$:	LOAD.W	D4,(A5)+OTXSPY	ADD.W	D4,D1	LOAD.W	D3,(A3)+OPJH1	SR.W	D3,#1	SUB.W	D4,D3	CALL	BASAFSDRAW	; affiche un trait pour bifferNEXT$:	TEST.W	D0	JUMP',EQ MEM$	LOAD.W	(A5)+OTXSDX,D2	SWAP.W	D2	LOAD.W	(A5)+OTXSPY,D2	SWAP.W	D2MEM$:	LOAD.W	(A5)+OTXSNO,D0	; OTXSNO <-- nouveau type de soulignementEXIT$:	POPM.L	D1,D3..D5	RET;-----------\\; BASAFSDRAW >;-----------/; Affiche un trait de soulignement.; in	D4.W	position en Y;	D5.W	paisseur; out	D7.W	erreur; mod	D7.WBASAFSDRAW:	PUSHM.L	D2..D4	LOAD.W	D2,D4		; D2 <-- position en Y	LOAD.W	D4,#1	SWAP.W	D4	LOAD.W	D7,#MA_SCALEN	PAGE_	MATH	SWAP.W	D4		; D4 <-- 1 point graphique [obj]	COMP.W	D5,D4		; paisseur visible ?	JUMP',GE EP$		; non => EP$	LOAD.W	D5,D4		; D5 <-- 1 point graphique au minimumEP$:	LOAD.L	D4,#-1		; D4 <-- trame pour dessiner	COMP.B	(A5)+OTXMOD+3,#CLRDOT	JUMP',NE MDEF$	CLR.L	D4		; D4 <-- trame pour effacerMDEF$:	CALL	DRMDEF		; dfinit la trame  utiliser	LOAD.W	D7,#DR_POLYOPEN	PAGE_	DRAW	JUMP,NE EXIT$	LOAD.W	D4,D2	SWAP.W	D4	LOAD.W	D4,(A5)+OTXSDX	CALL	BASPOSROT	LOAD.L	D3,D4	LOAD.W	D4,D2	SWAP.W	D4	LOAD.W	D4,(A5)+OTXSFX	CALL	BASPOSROT	LOAD.W	D7,#DR_POLYLINE	; ligne suprieure	PAGE_	DRAW	LOAD.L	D3,D4	LOAD.W	D4,D2	ADD.W	D4,D5	SWAP.W	D4	LOAD.W	D4,(A5)+OTXSFX	CALL	BASPOSROT	LOAD.W	D7,#DR_POLYLINE	; ligne de droite	PAGE_	DRAW	LOAD.L	D3,D4	LOAD.W	D4,D2	ADD.W	D4,D5	SWAP.W	D4	LOAD.W	D4,(A5)+OTXSDX	CALL	BASPOSROT	LOAD.W	D7,#DR_POLYLINE	; ligne infrieure	PAGE_	DRAW	LOAD.L	D3,D4	LOAD.W	D4,D2	SWAP.W	D4	LOAD.W	D4,(A5)+OTXSDX	CALL	BASPOSROT	LOAD.W	D7,#DR_POLYLINE	; ligne de gauche	PAGE_	DRAW	LOAD.L	D2,(A5)+OTXMOD	; D2 <-- mode d'affichage	LOAD.W	D7,#DR_POLYCLOSE	PAGE_	DRAW	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; BASPOSROT >;----------/; Fait tourner un point.; in	A4.L	^objet texte;	D4.L	P (y;x); out	D4.L	P'(y;x); mod	D4.L, D7.WBASPOSROT:	PUSHM.L	D1,D3	LOAD.W	D1,(A4)+OOBA+0	; D1 <-- angle de rotation	JUMP',EQ EXIT$	LOAD.L	D3,(A5)+OTXPOS	; D3 <-- centre de symtrie	LIB	?CALCPSYM	; D4 <-- nouvelle position (y;x)EXIT$:	POPM.L	D1,D3	RET;------------\\; BASSETREGLE >;============/; Dessine la rgle, sur le pav o est le curseur.; in	-; out	-; mod	D7.WBASSETREGLE:	PUSHM.L	D0..D4,A2..A4	COMP.L	(A5)+OTXCP1,#-1	; curseur dj trouv ?	JUMP',EQ EXIT$		; non => EXIT$	LOAD.L	A4,(A5)+OTXCPP	; A4 <-- ^pav o est le curseur	LOAD.L	A2,(A5)+OTXCPJ	; A2 <-- ^table de justification	CALL	CARPOSDIM	LOAD.L	D3,(A5)+OTXPOS	; D3 <-- coin inf/gauche	LOAD.W	D4,(A5)+OTXDIM+2 ; D4 <-- largeur	LOAD.W	D2,#1		; D2 <-- open	LOAD.W	D0,#IDENTJUST	LOAD.W	D1,#opDUSE	PAGE_	OBJCALL		; affiche la rgleEXIT$:	POPM.L	D0..D4,A2..A4	RET;------------\\; BASCLRREGLE >;============/; Enlve la rgle, sur le pav o est le curseur.; in	-; out	-; mod	D7.WBASCLRREGLE:	PUSHM.L	D0..D2	LOAD.W	D2,#2		; D2 <-- close	LOAD.W	D0,#IDENTJUST	LOAD.W	D1,#opDUSE	PAGE_	OBJCALL		; enlve la rgle	POPM.L	D0..D2	RET;-----------\\; BASSETCURS >;===========/; Allume le curseur.; in	A4.L	^objet texte; out	-; mod	D7.WBASSETCURS:	TEST.B	(A5)+OTXCIF	; curseur dj allum ?	JUMP',T EXIT$		; oui => EXIT$	CALL	BASINVCURS	; allume le curseurEXIT$:	RET;-----------\\; BASCLRCURS >;===========/; Eteint le curseur.; in	A4.L	^objet texte; out	-; mod	D7.WBASCLRCURS:	TEST.B	(A5)+OTXCIF	; curseur dj teint ?	JUMP',F EXIT$		; oui => EXIT$	CALL	BASINVCURS	; teint le curseurEXIT$:	RET;-----------\\; BASINVCURS >;===========/; Inverse le curseur.; in	A4.L	^objet texte; out	-; mod	D7.WBASINVCURS:	PUSHM.L	D2..D4	LOAD.L	D3,(A5)+OTXCP1	; D3 <-- P1 curseur	COMP.L	D3,#-1	JUMP',EQ EXIT$	LOAD.L	D4,#H'10000*COLORFDRAW+COLORSELECT	LOAD.W	D7,#DR_COLORINIT	PAGE_	DRAW		; spcifie les couleurs	LOAD.L	D4,(A5)+OTXCP2	; D4 <-- P2 curseur	LOAD.W	D7,#DR_WDOOPEN	PAGE_	DRAW		; dessine dans la swdo	LOAD.W	D2,#INVDOT	LOAD.W	D7,#DR_LINEM	PAGE_	DRAW		; dessine une barre verticale	LOAD.W	D7,#DR_WDOCLOSE	PAGE_	DRAW		; fin du dessin dans la swdo	NOT.B	(A5)+OTXCIF	; inverse l'tat du curseurEXIT$:	POPM.L	D2..D4	RET;------------\\; BASNEXTPAVE >;============/; Cherche l'objet suivant dans une chane NEXTPREV.; in	A4.L	^objet; out	A4.L	^objet suivant;	D7.W	erreur; mod	D7.W, A4.LBASNEXTPAVE:	LOAD.W	D7,#1	TEST.L	(A4)+OOBNEXT	; y a t-il un objet suivant ?	JUMP',EQ EXIT$		; non => EXIT$	LOAD.L	A4,(A4)+OOBNEXT	; A4 <-- ^racine objet suivant	LOAD.W	D7,#MI_GETDATA	PAGE_	MISC		; A4 <-- ^data objet suivantEXIT$:	TEST.W	D7		; retour EQ/NE	RET;------------\\; BASPREVPAVE >;============/; Cherche l'objet prcdent dans une chane NEXTPREV.; in	A4.L	^objet; out	A4.L	^objet prcdent;	D7.W	erreur; mod	D7.W, A4.LBASPREVPAVE:	LOAD.W	D7,#1	TEST.L	(A4)+OOBPREV	; y a t-il un objet prcdent ?	JUMP',EQ EXIT$		; non => EXIT$	LOAD.L	A4,(A4)+OOBPREV	; A4 <-- ^racine objet prcdent	LOAD.W	D7,#MI_GETDATA	PAGE_	MISC		; A4 <-- ^data objet prcdentEXIT$:	TEST.W	D7		; retour EQ/NE	RET	.END