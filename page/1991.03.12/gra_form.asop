	.TITLE	GRA_FORM.OPAGE;	--------------------------------------;		(C) 1989 - Pierre ARNAUD;	--------------------------------------;	Source de l'objet FORMULE pour le programme;	PAGE.	.PROC	M68000	.BASE	10'10; Rv	Date		Amliorations; ---------------------------------------------------------------------------------------------; 0.4	16/01/91	[DR] ne plante plus sur SMAKY100;			[DR] nouveaux symboles N,Z,Q,R,D,C;			[DR] utilise les couleurs de PAGE.ASS; 0.3b  03/01/90	Voil, la couleur y est aussi, tout comme le nouveau gencar 'Classic'.;			GETDEF/GETLDEF devraient fonctionner eux aussi.; 0.3a	28/12/90	Adaptation  PAGE 2.0. La couleur n'est pas supporte (GETLDEF et autres);			Bien 15 heures de travail  essayer de comprendre ce qu'il a fallu mo-;			difier.; 0.2	20/06/90	Nouvelle mthode. Adaptation  PAGE 1.10; 0.2	04/06/90	On peut tourner les formules. Les oprations "miroir" conservent les;			points P1 et P3 correctement.; 0.1	25/04/90	70 heures plus tard... une version (presque) distribuable; 0.0	28/03/90	Dbut des travaux	.REF	SMAKY	.REF	GESMEM	.REF	MODULES	.REF	RES	.REF	PAGE	.REF	NEWLIB	.REF	XCAR	.REF	OPFORM	.REF	MONMONdebug	= FALSE				; pas de messages MON ?..AdaptCharToFit	= TRUE				; on adapte chaque car. selon ses propres [h1;h2]KEYDBOX		= 16'7E00PAGEREV		= 0				; rvisionPAGEVERS	= 4				; versionPAGEPROV	= " "				; rvision.version provisoire	.REV	PAGEREV,PAGEVERS	.IDENT	"(C)  Pierre ARNAUD et EPSITEC-system SA";	Cette macro utilise Aj ^variables;	GETRES	type, id, Ai, Aj	.MACRO	GETRES	PUSH.32	%3	PUSHM.32 D0|D1|D2|A2|A4	MOVE.32	#%1,D0				; type	MOVE.32	#%2,D1				; ressource	MOVE.32	#2**BRSGETPOINTER+2**BRSGETnoHAND,D2	MOVE.32	{%4}+OCANRES,A2	RES_	GET	MOVE.32	A4,{SP}+4*5	POPM.32	D0|D1|D2|A2|A4	POP.32	%3	TEST.16	D7	.ENDMACRO	.MACRO	DEBUG	PUSHM.32 D3|D4	LIB	?AFTIM	.8	SAVWDO,EOP	.ASCIZE	"%1"	LIB	?GETCAR	MOVE.8	#GETWDO,D3	LIB	?AFCAR	POPM.32	D3|D4	.ENDMACRO;	Affiche un petit message dans DEB_FORM..	.MACRO	AFTEXT	.LOCALMACRO REF,DO	PUSHM.32 A3	JUMP	R8^DOREF:	.ASCIZE	"%1"DO:	MOVE.32	#R16^REF,A3	TRAP	#13	POPM.32	A3	.ENDMACRO;	Montre les registres dans DEB_FORM..	.MACRO	REGS	.IF LENGTH(%1).GT.0	AFTEXT	%1	.ENDIF	TRAP	#12	.ENDMACRO;	Rend le ^descripteur de symbole dans {Ai} selon choix dans {A4}+OOBMSYMB	.MACRO	GSYMBDESC	PUSH.32 D4	MOVE.32	{A5}+ODRINST,%1	MOVE.16	{%1}+OOBMSYMB,D4	SL.16	#2,D4				; selon numro de symbole choisi	MOVE.32	#{A5}+OP1SYMBDESC,%1		; A3 <- ^table des ^descripteur des symboles	ADD.A16	D4,%1	POP.32	D4	.ENDMACRO	.LOC	0;	Contenu de l'en-tte "mthode" des modules objet .OPAGE;	-------------------------------------------------------	.16	16'ABCD			; identificateur permettant de reconnatre un .OPAGE	.16	NBCALL			; nb d'appels existants	.16	0,0,0,0,0,0		; rserve;	Mthodes pour l'itialisation du module objet;	--------------------------------------------	.16	XopGETTYPE		; rend le type du module-objet .OPAGE (TYPOBedit/def)	.16	XopGETIDENT		; rend l'identificateur de ce module-objet	.16	XopGETNAME		; rend le nom de ce module-objet	.16	XopGETNAMEDEF		; rend la liste des noms de DEF_*.OPAGE utiliss	.16	XopOPEN			; appel au chargement du .OPAGE, rend le canal des vars.	.16	XopCLOSE		; appel lors du "quitte" du .OPAGE, rend la mmoire;	Mthodes pour la cration d'une instance d'objet (XopCR..);	------------------------------------------------	.16	XopCRGETLG		; rend la taille d'une instance d'objet compacte	.16	XopCRINIT		; initialisation d'une instance d'objet  sa cration	.16	XopCRCLOSE		; fermeture de l'objet aprs sa cration	.16	XopCRCOPYLG		; rend la taille pour la copie d'une instance d'objet	.16	XopCRCOPYXFER		; copie effectivement une instance d'objet	.16	XopCRREAD		; complments  la lecture aprs cration (par PREND/AJOUTE)	.16	XopCRWRITE		; complments  l'criture aprs sauvetage (par SAUVE/EXTR.)	.16	0 ;XopCRWRITELIST		; ?	.16	0 ;XopCRASSFILE			; dfinit les fichiers  mettre dans le "!PAGE"	.16	0 ;XopCRCOPYUNDO		; copie pour pouvoir faire un UNDO	.16	0 ;XopCRADAPT			; adapte la taille si nouvelle longueur d'instance	.16	0,0,0,0,0,0,0	.16	0,0,0,0,0,0,0,0	.16	XopICOHELP		; rend un texte d'aide pour une icne donne	.16	XopGETICONE		; rend le ^raster d'une icne propre au module objet;	Mthodes spcifiques  un module objet de type TYPOBEDIT (fichiers GRA_xxx.OPAGE);	---------------------------------------------------------------------------------	.16	XopCRLGCOM		; rend tailles pour compactifier instance d'objet cre	.16	XopCRMOVE		; lors de la cration, dplace une poigne	.16	0 ; XopCRICOLIST		; rend la liste des icnes pendant la cration	.16	0 ; XopCRICOMOD		; ragit face aux icnes de cration presses	.16	0 ; XopCRICOGET		; rend l'tat d'une icne de cration	.16	0 ; XopCRICOOUTIL		; rend l'icne de la souris  utiliser comme outil crateur	.16	XopDRAW			; dessine une instance d'objet	.16	XopIDENTSTATE		; rend le pointeur aux identificateurs (pour dfinir dessin)	.16	XopMODSTATE		; modifie l'tat (appel des modules objet de dfinition)	.16	XopGETBBOX		; rend la "bounding box" d'une instance d'objet	.16	XopDETECT		; dtecte si la souris est sur l'instance d'objet;	Mthodes pour la modification d'une instance d'objet;	----------------------------------------------------	.16	XopHANDLGEXT		; rend tailles pour tendre l'instance d'objet  modifier	.16	XopHANDLGCOM		; rend tailles pour compactifier l'instance d'objet modifie	.16	XopHANDGET		; rend la position & type d'une poigne de modification	.16	XopHANDMOVE		; demande au module objet de dplacer une poigne	.16	XopHANDICOLIST		; rend la liste des icnes pendant la modification	.16	XopHANDICOMOD		; ragit face aux icnes de modification presses	.16	XopHANDICOGET		; rend l'tat d'une icne de modification	.16	0 ; XopHANDICOOUTIL		; rend l'icne de la souris  utiliser comme outil de modif.	.16	0 ; XopHANDEVENT		; ragit face  un vnement (clavier/souris)	.16	XopZONEMOVE		; transforme une instance d'objet par une mthode de PAGE;	Mthodes pour l'dition d'une instance d'objet;	----------------------------------------------	.16	XopEDITMOVE		; opration d'dition sur une instance d'objet	.16	XopEDITICOLIST		; rend la liste des icnes pendant l'dition	.16	XopEDITICOMOD		; ragit face aux icnes d'dition presses	.16	XopEDITICOGET		; rend l'tat d'une icne d'dition	.16	XopEDITICOOUTIL		; rend l'icne de la souris  utiliser comme outil d'dition	.16	XopEDITEVENT		; ragit face  un vnement (clavier/souris)	.16	XopEDITDRAW		; raffiche l'instance d'objet modifie par EDITEVENT	.16	0	.16	0 ; XopCRINFO		; demande la ligne d'informations (pour afficher dx/dy..)	.16	0 ; XopCRMMENU		; affiche & gre le menu du milieu lors de la cration	.16	0 ; XopHANDINFO		; demande la ligne d'informations (pour afficher dx/dy..)	.16	0 ; XopHANDMMENU		; affice & gre le menu du milieu lors de la modification	.16	XopEDITINFO		; demande la ligne d'informations (pour afficher dx/dy..)	.16	XopEDITMMENU		; affiche & gre le menu du milieu lors de l'dition	.16	XopBUTTON		; indique le bouton de la souris  utiliser	.16	0 ; XopZONEMODIF		; modifie l'objet dans une zone	.16	XopGETDEF		; modifie l'objet dans une zone	.16	0 ; XopMAGNETIC		; ??	.16	0 ; XopMESSGET	.16	XopGETLDEFNBCALL:;----------\\;  XopOPEN  >;==========/; Appel  l'ouverture du module objet. Cette mthode se charge de; prendre la mmoire des variables locales.; in	-; out	A0.32	canal (^variables locales);	D7.16	erreur; mod	D7.16, A0.32XopOPEN:	PUSHM.32 D0..D6|A1..A5	MOVE.32	#MTYPCP,D1	MOVE.32	#LGVAR,D4	GESMEM	?GETMEM				; variables globales	JUMP,NE	ERR$	GESMEM	?CLEARMEM	MOVE.32	A4,A0	CALL	FORDEFOPEN			; charge les ressources	JUMP,NE	ERR$	MOVE.32	{A0}+OCANRES,A2	MOVE.32	#RtypDGBM,D0	MOVE.32	#0,D1	MOVE.32	#2**BRSGETCOPY+2**BRSGETnoHAND,D2	RES_	GET				; demande une copie de la fonte des symboles	JUMP,NE	ERR$	MOVE.32	A4,{A0}+OP1SYMBDESC		; conserve le pointeur au premier (swiss)	MOVE.32	#1,D1	RES_	GET				; demande une copie de la fonte des symboles	JUMP,NE	ERR$	MOVE.32	A4,{A0}+OP2SYMBDESC		; conserve le pointeur au second (times)	MOVE.16	#PAGE_DRAW,D3	LIB_	GETAD				; cherche l'adresse	MOVE.32	A3,{A0}+OPAGEDRAW	LIB	?GETPDIS	MOVE.32	A4,{A0}+OPDDIS	MOVE.32	A0,A5				; A5 <-- ^variables locales	MOVE.32	#R16^NMIMA$,A3	MOVE.16	#DB_IMALOAD,D7	PAGE_	DBOX				; charge l'image "PAGE_MATH.IMAGE"	JUMP,NE	R8^ERR$	MOVE.32	A4,{A0}+OIPPT	MOVE.32	D4,{A0}+OIPDIM	MOVE.32	#{A0}+OICOSYMB,A2	GETRES	RtypPAGEICOTAB,0,A3,A0	MOVE.16	#8*3-1,D2TCOPY$:	MOVE.16	{A3+},{A2+}	DJ.16,NMO D2,TCOPY$	MOVE.32	{A0}+OP1SYMBDESC,A4	MOVE.16	#16'FA,{A4}+ODGBMCORPS		; bon corps	MOVE.32	#DR_GETPGC,D7	PAGE_	DRAW				; tente un coup..	JUMP,EQ	R8^INI1$XCARL$:	MOVE.32	#xcLISTREFAIT,D7	XCAR_	LIST	MOVE.32	#DR_GETPGC,D7	PAGE_	DRAW				; retente un coup..	JUMP,NE	R8^ERR$INI1$:	MOVE.32	{A0}+OP2SYMBDESC,A4	MOVE.16	#16'FA,{A4}+ODGBMCORPS		; bon corps	MOVE.32	#DR_GETPGC,D7	PAGE_	DRAW				; tente un coup..	JUMP,NE	R8^XCARL$ERR$:	POPM.32	D0..D6|A1..A5	TEST.16	D7	RETNMIMA$:	.ASCIZE	"PAGE_MATH.IMAGE";-----------\\;  XopCLOSE  >;===========/; Appel  la fermeture du module objet. Cette mthode se charge de; rendre la mmoire des variables locales.; in	A0.32	canal; out	-; mod	D7.16XopCLOSE:	PUSHM.32 D1|A4	TEST.32	{A0}+OIPPT	JUMP,EQ	R8^NOIMA$	MOVE.32	{A0}+OIPPT,A4	MOVE.16	#DB_IMAKILL,D7	PAGE_	DBOX				; dcharge l'image "PAGE_MATH.IMAGE"NOIMA$:	CALL	FORDEFCLOSE			; dcharge les ressources	MOVE.32	#MTYPCP,D1	MOVE.32	{A0}+OP1SYMBDESC,A4	GESMEM	?GIVMEM				; rend le premier descripteur des symboles	MOVE.32	{A0}+OP2SYMBDESC,A4	GESMEM	?GIVMEM				; rend le second descripteur des symboles	MOVE.32	A0,A4	GESMEM	?GIVMEM				; rend la mmoire des variables	POPM.32	D1|A4	RET;-------------\\;  XopGETTYPE  >;=============/; Rend le type du module objet (rend TYPOBEDIT si c'est un module objet; d'dition graphique et TYPOBDEF si c'est un module objet de dfinition); in	A0.32	canal; out	D4.32	type de module objet;	D7.16	erreur; mod	D4.32, D7.16XopGETTYPE:	MOVE.16	#TYPOBEDIT,D4	CLR.16	D7	RET;--------------\\;  XopGETIDENT  >;==============/; Rend l'identificateur (unique) qui correspond  ce module-objet. Pour; obtenir un identificateur, contacter EPSITEC-system sa; in	A0.32	canal; out	D4.16	identificateur;	D7.16	erreur; mod	D4.16, D7.16XopGETIDENT:	MOVE.16	#IDENT,D4	CLR.16	D7	RET;-------------\\;  XopGETNAME  >;=============/; Rend le pointeur au nom du module objet. Ce nom correspond au nom du; fichier contenu sur le disque; in	A0.32	canal; out	A3.32	^nom du module objet;	D7.16	erreur; mod	D7.16, A3.32XopGETNAME:	MOVE.32	#R16^NOM$,A3	CLR.16	D7	RETNOM$:	.ASCIZE	"GRA_FORM.OPAGE";----------------\\;  XopGETNAMEDEF  >;================/; Rend la liste des objets ncessaires  l'objet FORMULE.; in	A0.32	canal; out	A3.32	^liste de .ASCIZ + <0>;	D7.16	erreur; mod	D7.16, A3.32XopGETNAMEDEF:	MOVE.32	#R16^LISTE$,A3	CLR.16	D7	RETLISTE$:	.ASCIZ	"DEF_PEN.OPAGE"	.ASCIZ	"DEF_TRAME.OPAGE" 	.ASCIZ	"DEF_CHAR.OPAGE"	.8	0	.EVEN;-------------\\;  XopCRGETLG  >;=============/; Rend la longueur ncessaire pour crer une instance de l'objet; in	A0.32	canal; out	D4.16	longueur ncessaire (octets);	D7.16	erreur; mod	D4.16, D7.16XopCRGETLG:	MOVE.16	#LOB,D4	CLR.16	D7	RET;------------\\;  XopCRINIT  >;============/; Initialisation d'un objet  sa cration (on fixe les paramtres par; dfaut comme le pinceau, la trame, le fond, etc...); in	A0.32	canal;	A4.32	^instance d'objet  initialiser; out	D7.16	erreur; mod	D7.16XopCRINIT:	PUSHM.32 D0..D6|A1..A5	MOVE.32	A0,A5	MOVE.32	A4,{A5}+ODRINST	MOVE.32	A4,A1				; A1 <-- ^objet	MOVE.32	#0,A4				; A4 <-- collection de fontes par dfaut	MOVE.32	#IDENTCHAR,D0	MOVE.32	#opDGET,D1			; demande la fonte par dfaut	PAGE_	OBJCALL				; D3 <-- numro de la fonte par dfaut	JUMP,NE	R8^ERR$	MOVE.16	D3,{A1}+OOBDEFCHAR		; caractre de base	MOVE.16	D3,{A1}+OOBFONT			; fonte par dfaut	MOVE.16	#3,{A1}+OOBPEN			; pinceau pas trop fin (vive la foi !)	MOVE.16	#19,{A1}+OOBTRA			; trame noire (esprons)	MOVE.32	A1,A4	CALL	FORTXTOPEN			; initialise un texte nul	CALL	GETDGBM				; cherche le descripteur de la fonte par dfaut	JUMP,NE	R8^ERR$	MOVE.16	{A3}+ODGBMCORPS,{A4}+OOBSIZE	; taille du corps  utiliser	MOVE.32	A4,{A5}+ODRINST	CALL	INITGENC	MOVE.16	#75,{A4}+OOBRED			; facteur de rduction en %ERR$:	POPM.32	D0..D6|A1..A5	TEST.16	D7	RET;-------------\\;  XopCRCLOSE  >;=============/; Dtruit une instance d'objet (c'est ici qu'il faut librer les tranches; mmoires associes, s'il y en a); in	A0.32	canal;	A4.32	^instance d'objet  dtruire; out	D7.16	erreur; mod	D7.16, A4.32XopCRCLOSE:	PUSHM.32 A5	MOVE.32	A0,A5	MOVE.32	A4,{A5}+ODRINST	CALL	SYMBKILLPG			; libre mmoire des poignes	CALL	FORTXTCLOSE			; libre le texte	POPM.32	A5	TEST.16	D7	RET;--------------\\;  XopCRCOPYLG  >;==============/; Rend la taille ncessaire pour copier une instance d'objet.; in	A0.32	canal;	A3.32	^instance d'objet source; out	D4.16	taille mmoire ncessaire  la copie;	D7.16	erreur; mod	D4.16, D7.16XopCRCOPYLG:	MOVE.16	#LOB,D4	CLR.16	D7	RET;----------------\\;  XopCRCOPYXFER  >;================/; Copie une instance objet dans une autre. Il faut prendre garde  ne; pas copier btement les pointeurs, mais  copier aussi le contenu des; tranches pointes s'il y en a !; in	A0.32	canal;	A3.32	^instance d'objet source;	A4.32	^instance d'objet destination; out	D7.16	erreur; mod	D7.16XopCRCOPYXFER:	PUSHM.32 D0..D6|A0..A5	MOVE.32	A0,A5	MOVE.32	A4,{A5}+ODRINST	MOVE.32	A4,A2				; A2 <-- ^future instance copie	MOVE.16	#LOB,D4	CALL	FORCOPYMEM			; copie l'instance	MOVE.32	{A3}+OOBTXTUSE,D4		; taille ncessaire	MOVE.32	{A3}+OOBPTXT,A3			; ^tranche source	MOVE.32	A4,A1				; conserve instance d'objet destination	MOVE.32	#MTYPCP,D1	GESMEM	?GETMEM				; demande tranche pour contenu du texte	JUMP,NE	R8^ERR$	CALL	FORCOPYMEM			; copie les tranches	MOVE.32	A4,{A1}+OOBPTXT			; mmorise le nouveau ^contenu du texte	MOVE.32	A2,A4				; A4 <-- ^nouvelle instance	CALL	SYMBXFERPG			; refait toutes les poignes (pas de mmoire commune)ERR$:	POPM.32	D0..D6|A0..A5	TEST.16	D7	RET;----------\\; XopCRREAD >;==========/; Effectue encore quelques travaux aprs la lecture sur disque. On peut; par exemple charger des blocs de donnes supplmentaires.; On peut faire directement des IO_RDMANY/IO_RDONE, il faut cependant prendre; garde  lire tout ce qui nous revient, sans quoi PAGE aurait des problmes; lors du chargement de la suite..; in	A0.32	canal;	A4.32	^instance d'objet lue sur disque; out	D7.16	erreur; mod	D7.16XopCRREAD:	PUSHM.32 D0..D6|A0..A5	MOVE.32	A0,A5	MOVE.32	A4,{A5}+ODRINST	CALL	FORTXTIOREAD			; lit le complment	JUMP,NE	R8^ERR$	MOVE.32	A4,{A5}+ODRINST	CALL	INITGENC	CLR.32	{A4}+OOBxP3	CALL	SYMBXFERPG			; refait toutes les poignes	CLR.16	{A4}+OOBINIPGERR$:	POPM.32	D0..D6|A0..A5	TEST.16	D7	RET;-----------\\; XopCRWRITE >;===========/; Effectue encore quelques travaux aprs l'criture sur disque. Mmes remarques; que pour XopCRREAD ( la diffrence prs qu'ici on crit  l'aide des appels; IO_WRMANY/IO_WRONE); in	A0.32	canal;	A4.32	^instance d'objet crit sur le disque; out	D7.16	erreur; mod	D7.16XopCRWRITE:	PUSHM.32 D0..D6|A0..A5	MOVE.32	A0,A5	MOVE.32	A4,{A5}+ODRINST	CALL	FORTXTIOWRITE			; crit le complment	POPM.32	D0..D6|A0..A5	TEST.16	D7	RET;--------------\\;  XopGETICONE  >;==============/; Rend le pointeur au motif reprsentant l'icne, ce qui permet de les stocker; dans un fichier de ressources...; in	A0.32	canal;	D3.16	numro de l'icne demande; out	A4.32	^motif du type DRAWMATRIX (dx,dy, icne);	D7.16	erreur; mod	A4.32, D7.16XopGETICONE:	PUSHM.32 D0..D6|A0..A3|A5	MOVE.32	A0,A5	MOVE.32	A4,{A5}+ODRINST	COMP.16	#ICOSPEN,D3	JUMP,EQ	PEN$	COMP.16	#ICOSTRAME,D3	JUMP,EQ	TRAME$	COMP.16	#ICOSCHAR,D3		;  construire !	JUMP,EQ	CHAR$	COMP.16	#ICOSYMB,D3	JUMP,HS	SYMB$	JUMP	AUTRE$			; non => autre, interneSYMB$:	SUB.16	#ICOSYMB,D3		; D3 <-- numro de l'lment intressant	MOVE.32	#{A5}+OICOSYMB,A2	SL.16	#1,D3	MOVE.16	{A2}+A16^{D3},D2	; D2 <-- numro du symbole  coller	COMP.16	#-1,D2	JUMP,EQ	GREY$	CALL	IPPOS			; D3 <-- [y;x] de l'icne et D4 <-- [dy;dx] de l'icne	JUMP,NE	GREY$	MOVE.32	#16'00130018,D4		; [dx] = 24 / [dy]=20	MOVE.8	#24,{A5}+OICOSIZE+0	MOVE.8	#20,{A5}+OICOSIZE+1	PUSHM.32 D1..D6|A2|A3	MOVE.32	{A5}+OPDDIS,A2		; A2 <-- descripteur cran	MOVE.32	{A5}+OIPPT,A3		; A3 <-- ^image source	MOVE.16	{A5}+OIPDIM+2,D5	SR.16	#3,D5			; D5 <-- largeur en bytes	MOVE.32	D4,D2			; D2 <-- [dy;dx]	ADD.32	#16'00010005,D3		; D3 <-- position source	CLR.32	D4			; D4 <-- position destination	MOVE.32	#{A5}+OICOBUF,A4	; A4 <-- ^mmoire destination	MOVE.16	#24/8,D6		; D6 <-- largeur destination en bytes	MOVE.8	#LOADDOT,D1		; D1 <-- transfert	GRA_	RASTER			; copie dans le buffer	POPM.32	D1..D6|A2|A3	MOVE.32	#{A5}+OICOSIZE,A4	; A4 <-- ^dx,dy,icne	CLR.16	D7	JUMP	EXIT$GREY$:	MOVE.32	#{A5}+OICOSIZE,A4	; A4 <-- ^dx,dy,icne	MOVE.8	#24,{A4+}	MOVE.8	#20,{A4+}	MOVE.16	#24*20/(4*8)-1,D0DOGR$:	MOVE.32	#0,{A4+}	DJ.16,NMO D0,DOGR$	MOVE.32	#{A5}+OICOSIZE,A4	; A4 <-- ^dx,dy,icne	CLR.16	D7	JUMP	EXIT$PEN$:	MOVE.32	A4,A3			; A3 <-- ^objet	MOVE.32	#0,A4			; A4 <-- objet par dfaut	MOVE.16	#IDENTPEN,D0	MOVE.16	#opDGET,D1	PAGE_	OBJCALL			; D3 <-- pinceau slectionn	MOVE.16	D3,D2			; D2 <-- pinceau initial	MOVE.16	{A3}+OOBPEN,D3		; D3 <-- pinceau de l'objet	MOVE.16	#opDPUT,D1	PAGE_	OBJCALL			; slectionne le bon pinceau	MOVE.16	#ICOIOBJET,D3	MOVE.16	#opGETICONE,D1	PAGE_	OBJCALL			; A4 <-- ^dx,dy,icne	MOVE.32	A4,A3	MOVE.32	#0,A4			; A4 <-- objet par dfaut	MOVE.16	D2,D3			; D3 <-- pinceau initial	MOVE.16	#opDPUT,D1	PAGE_	OBJCALL			; slectionne le pinceau initial	MOVE.32	A3,A4	CLR.16	D7			; D7 <-- ok	JUMP	EXIT$TRAME$:	MOVE.32	A4,A3			; A3 <-- ^objet	MOVE.32	#0,A4			; A4 <-- objet par dfaut	MOVE.16	#IDENTTRAME,D0	MOVE.16	#opDGET,D1	PAGE_	OBJCALL			; D3 <-- pinceau slectionn	MOVE.16	D3,D2			; D2 <-- pinceau initial	MOVE.16	{A3}+OOBTRA,D3		; D3 <-- pinceau de l'objet	MOVE.16	#opDPUT,D1	PAGE_	OBJCALL			; slectionne le bon pinceau	MOVE.16	#ICOIOBJET,D3	MOVE.16	#opGETICONE,D1	PAGE_	OBJCALL			; A4 <-- ^dx,dy,icne	MOVE.32	A4,A3	MOVE.32	#0,A4			; A4 <-- objet par dfaut	MOVE.16	D2,D3			; D3 <-- pinceau initial	MOVE.16	#opDPUT,D1	PAGE_	OBJCALL			; slectionne le pinceau initial	MOVE.32	A3,A4	CLR.16	D7			; D7 <-- ok	JUMP	EXIT$CHAR$:	MOVE.32	#0,A4			; A4 <-- objet par dfaut	MOVE.16	#IDENTCHAR,D0	MOVE.16	#opDGET,D1	PAGE_	OBJCALL			; D3 <-- caractre slectionn	MOVE.16	D3,D2			; D2 <-- caractre initial	MOVE.16	{A3}+OOBFONT,D3		; D3 <-- caractre de l'objet	MOVE.16	#opDPUT,D1	PAGE_	OBJCALL			; slectionne le bon caractre	MOVE.16	#ICOIOBJET,D3	MOVE.16	#opGETICONE,D1	PAGE_	OBJCALL			; A4 <-- ^dx,dy,icne	MOVE.32	A4,A3	MOVE.32	#0,A4			; A4 <-- objet par dfaut	MOVE.16	D2,D3			; D3 <-- caractre initial	MOVE.16	#opDPUT,D1	PAGE_	OBJCALL			; slectionne le caractre initial	MOVE.32	A3,A4	CLR.16	D7			; D7 <-- ok	JUMP	R8^EXIT$AUTRE$:	MOVE.32	{A5}+OCANRES,A2	MOVE.32	{A5}+OTYPRASTER,A0	MOVE.32	D3,D1	AND.32	#16'0000007F,D1			; ne prend que 1..127	DEC.16	D1				; utilise 0..126	MOVE.32	#2**BRSGETPOINTER,D2	MOVE.32	{A5}+ORESGET,A4	CALL	{A4}				; demande le ^ressource icneEXIT$:	POPM.32	D0..D6|A0..A3|A5	TEST.16	D7	RET;-------------\\;  XopICOHELP  >;=============/; Rend le texte d'aide pour une icne donne.; in	A0.32	canal;	D3.16	icne demande; out	A3.32	^texte d'aide;	D7.16	erreur; mod	A3.32, D7.16XopICOHELP:	PUSHM.32 D0..D6|A0..A2|A4|A5	MOVE.32	A0,A5	MOVE.32	A4,{A5}+ODRINST	COMP.16	#-1,D3	JUMP,EQ	R8^ERROR$	COMP.16	#ICOSPEN,D3	JUMP,EQ	PEN$	COMP.16	#ICOSTRAME,D3	JUMP,EQ	TRAME$	COMP.16	#ICOSCHAR,D3		;  construire !	JUMP,EQ	CHAR$	COMP.16	#ICOSYMB,D3	JUMP,HS	SYMB$	JUMP	AUTRE$			; non => autre, interneERROR$:	MOVE.16	#1,D7	JUMP	EXIT$SYMB$:	SUB.16	#ICOSYMB,D3		; D3 <-- numro de l'lment intressant	MOVE.32	#{A5}+OICOSYMB,A2	SL.16	#1,D3	MOVE.16	{A2}+A16^{D3},D2	; D2 <-- numro du symbole  coller (par table d'quivalences)	COMP.16	#-1,D2	JUMP,EQ	GREY$	CLR.32	D0	MOVE.16	D2,D0	MOVE.32	{A5}+OCANRES,A2	MOVE.32	{A5}+OTYPHELPPAGE,A0	MOVE.32	#0,D1			; texte pour tous les symboles	MOVE.32	#2**BRSGETPOINTER,D2	MOVE.32	{A5}+ORESGET,A4	CALL	{A4}			; demande le ^ressource icne	MOVE.32	#{A5}+OBUTEXT,A3COPY1$:	MOVE.8	{A4+},D3	COMP.8	#"*",D3	JUMP,EQ	R8^OK1$	MOVE.8	D3,{A3+}	JUMP	COPY1$OK1$:	PUSH.32	A4	MOVE.32	{A5}+OTYPHELPSYMBS,A0	MOVE.32	D0,D1	MOVE.32	{A5}+ORESGET,A4	CALL	{A4}			; demande le ^ressource icneCOPY2$:	MOVE.8	{A4+},D3	JUMP,EQ	R8^OK2$	COMP.8	#"&",D3	JUMP,NE	R8^OK02$	MOVE.8	#-1,D3OK02$:	MOVE.8	D3,{A3+}	JUMP	COPY2$OK2$:	POP.32	A4COPY3$:	MOVE.8	{A4+},{A3+}	JUMP,NE	COPY3$	MOVE.32	#{A5}+OBUTEXT,A3	; A3 <-- texte d'aide complet	JUMP	EXIT$GREY$:	MOVE.16	#1,D7	JUMP	EXIT$PEN$:	MOVE.16	#ICOIOBJET,D3	MOVE.16	#IDENTPEN,D0	MOVE.16	#opICOHELP,D1	PAGE_	OBJCALL				; A3 <-- ^texte	JUMP	EXIT$TRAME$:	MOVE.16	#ICOIOBJET,D3	MOVE.16	#IDENTTRAME,D0	MOVE.16	#opICOHELP,D1	PAGE_	OBJCALL				; A3 <-- ^texte	JUMP	EXIT$CHAR$:	MOVE.16	#ICOIOBJET,D3	MOVE.16	#IDENTCHAR,D0	MOVE.16	#opICOHELP,D1	PAGE_	OBJCALL				; A3 <-- ^texte	JUMP	EXIT$AUTRE$:	MOVE.32	{A5}+OCANRES,A2	MOVE.32	{A5}+OTYPHELPPAGE,A0	MOVE.32	D3,D1	AND.32	#16'0000007F,D1			; ne prend que 1..127						; utilise 1..127	MOVE.32	#2**BRSGETPOINTER,D2	MOVE.32	{A5}+ORESGET,A4	CALL	{A4}				; demande le ^ressource icne	MOVE.32	A4,A3				; A3 <-- ^texteEXIT$:	POPM.32	D0..D6|A0..A2|A4|A5	TEST.16	D7	RET;-------------\\;  XopCRLGCOM  >;=============/; Rend la taille mmoire ncessaire  compactifier une instance d'objet; dont la cration vient de se terminer.; in	A0.32	canal;	A4.32	^instance d'objet tendue (actuelle); out	D3.16	longueur de l'objet tendu;	D4.16	longueur de l'objet compactifi;	D7.16	erreur; mod	D7.16, D3.16, D4.16XopCRLGCOM:	MOVE.16	#LOB,D3	MOVE.16	D3,D4	CLR.16	D7	RET;------------\\;  XopCRMOVE  >;============/; Dplace une poigne durant la cration de l'objet. Cette mthode; permet de rajouter/dplacer les poignes lors de la cration. Le; logiciel PAGE demande que l'instance ne soit jamais dessine !; in	A0.32	canal;	A4.32	^instance d'objet tendue;	D3.16	opration CRMOVExxx;		CRMOVEOPEN commence la "cration" interactive;		CRMOVEBEGIN commence avec une nouvelle poigne (provisoire);		CRMOVEDRAG dplace la nouvelle poigne (provisoire);		CRMOVEEND termine avec la nouvelle poigne (devient dfinitive);		CRMOVECLOSE termine la "cration" interactive;	D4.32	nouvelle position [y;x] si D3=CRMOVEBEGIN/DRAG; out	D7.16	erreur; mod	D7.16XopCRMOVE:	PUSHM.32 D1..D4|A5	MOVE.32	A0,A5	MOVE.32	A4,{A5}+ODRINST	CLR.16	D7	COMP.16	#CRMOVEOPEN,D3		; commence la "cration" interactive ?	JUMP,EQ	R8^OPEN$		; oui => OPEN$	COMP.16	#CRMOVEBEGIN,D3		; commence avec une nouvelle poigne ?	JUMP,EQ	R8^BEGIN$		; oui => BEGIN$	COMP.16	#CRMOVEDRAG,D3		; dplace la nouvelle poigne ?	JUMP,EQ	R8^DRAG$		; oui => DRAG$	COMP.16	#CRMOVEEND,D3		; termine avec la nouvelle poigne ?	JUMP,EQ	R8^END$			; oui => END$	COMP.16	#CRMOVECLOSE,D3		; termine la "cration" interactive ?	JUMP,EQ	CLOSE$			; oui => CLOSE$	MOVE.16	#ERPAILOP,D7		; autre..	JUMP	EXIT$			; termine avec erreur "opration illgale"OPEN$:	JUMP	EXIT$			; rien  faireBEGIN$:	MOVE.32	D4,{A4}+OOBP1		; coordonne P1 [y;x]	MOVE.32	D4,{A4}+OOBP3		; confondu avec P3 [y;x]	JUMP	EXIT$DRAG$:	MOVE.32	D4,{A4}+OOBP3	JUMP	EXIT$; Repris tel quel de GRA_TEXT.ASOPEND$:	MOVE.32	{A4}+OOBP1,D4	SUB.16	{A4}+OOBP3+2,D4	JUMP,NC	R8^END1X$	NEG.16	D4END1X$:	SWAP.32	D4	SUB.16	{A4}+OOBP3+0,D4	JUMP,NC	R8^END1Y$	NEG.16	D4END1Y$:	SWAP.32	D4	MOVE.16	#MA_SCALEP,D7	PAGE_	MATH		; D4 <-- dimensions (dy;dx)	COMP.16	#2,D4	JUMP,LO	R8^ESEARCH$	SWAP.32	D4	COMP.16	#2,D4	JUMP,HS	R8^EOK$ESEARCH$:	CLR.16	D2ELOOP$:	MOVE.16	#DR_GETCOL,D7	PAGE_	DRAW		; D3/D4 <-- position colonne	JUMP,NE	EXIT$	MOVE.32	{A4}+OOBP1,D1	COMP.16	D3,D1	JUMP,LT	R8^ENEXT$	COMP.16	D4,D1	JUMP,GE	R8^ENEXT$	SWAP.32	D1	SWAP.32	D3	SWAP.32	D4	COMP.16	D3,D1	JUMP,LT	R8^ENEXT$	COMP.16	D4,D1	JUMP,LT	R8^ECOL$ENEXT$:	INC.16	D2			; D2 <-- colonne suivante	JUMP	ELOOP$ECOL$:	SWAP.32	D3	SWAP.32	D4	MOVE.32	D3,{A4}+OOBP1	MOVE.32	D4,{A4}+OOBP3EOK$:	MOVE.16	{A4}+OOBP1+0,D2	COMP.16	{A4}+OOBP3+0,D2	JUMP,LE	R8^END2$	MOVE.16	{A4}+OOBP1+2,D2	COMP.16	{A4}+OOBP3+2,D2	JUMP,LE	R8^END270$	JUMP	R8^END180$END2$:	MOVE.16	{A4}+OOBP1+2,D2	COMP.16	{A4}+OOBP3+2,D2	JUMP,LE	R8^END0$	JUMP	R8^END90$END0$:	CLR.16	D1	JUMP	R8^ENDX$END90$:	MOVE.16	#90,D1	JUMP	R8^ENDX$END180$:	MOVE.16	#180,D1	JUMP	R8^ENDX$END270$:	MOVE.16	#270,D1;	JUMP	R8^ENDX$ENDX$:	MOVE.16	D1,{A4}+OOBA+0;	CLR.16	{A4}+OOBA+2	CALL	INVANGLE	MOVE.32	{A4}+OOBP3,D4	CALL	GETPX	MOVE.32	D4,{A4}+OOBP3CLOSE$:;	JUMP	R8^OK$OK$:	CLR.16	D7			; D7 <-- okEXIT$:	POPM.32	D1..D4|A5	TEST.16	D7			; retour EQ/NE	RET;----------------\\;  XopIDENTSTATE  >;================/; Rend la liste des identificateurs des tats de ce module-objet (par exemple l'tat; d'dition des trames, des plumes, du fond, des caractres..); in	A0.32	canal; out	A4.32	^identificateurs des tats (.16  i1, i2, i3 .. -1);	D7.16	erreur; mod	A4.32, D7.16XopIDENTSTATE:	MOVE.32	#R16^IDENT$,A4	CLR.16	D7	RETIDENT$:	.16	IDENTPEN, IDENTTRAME, 0, IDENTCHAR, -1;--------------\\;  XopMODSTATE  >;==============/; Modifie l'tat d'une instance d'objet (modifie la trame, la plume, le; fond, etc..); in	A0.32	canal;	D3.16	icne d'tat presse; out	D4.16	nombre de modifications;	D7.16	erreur; mod	D4.16, D7.16XopMODSTATE:	PUSHM.32 D0..D5|A4|A5	MOVE.32	A0,A5	MOVE.32	A4,{A5}+ODRINST	COMP.16	#IDENTCHAR,D3	JUMP,EQ	R8^CHAR$	COMP.16	#IDENTTRAME,D3	JUMP,EQ	R8^TRAME$	COMP.16	#IDENTPEN,D3	JUMP,EQ	R8^PEN$	MOVE.16	#1,D7	JUMP	R8^ERR$TRAME$:	MOVE.32	#0,A4				; A4 <-- objet par dfaut	MOVE.16	#IDENTTRAME,D0	MOVE.16	#opDSELECT,D1	PAGE_	OBJCALL				; slectionne une trame	JUMP	R8^ERR$PEN$:	MOVE.32	#0,A4				; A4 <-- objet par dfaut	MOVE.16	#IDENTPEN,D0	MOVE.16	#opDSELECT,D1	PAGE_	OBJCALL				; slectionne un pinceau	JUMP	R8^ERR$CHAR$:	MOVE.32	#0,A4				; A4 <-- objet par dfaut	MOVE.16	#IDENTCHAR,D0	MOVE.16	#opDSELECT,D1	PAGE_	OBJCALL				; slectionne un caractre ...	MOVE.32	{A5}+ODRINST,A4	CALL	INITGENCERR$:	POPM.32	D0..D5|A4|A5	TEST.16	D7				; retour EQ/NE	RET;-----------\\; XopGETBBOX >;===========/; Calcule la "bounding box" d'un objet.; in	A0.32	canal;	A4.32	^objet texte; out	D3.32	coin sup/gauche (y;x);	D4.32	coin inf/droite (y;x);	D7.16	erreur; mod	D3.32, D4.32, D7.16XopGETBBOX:	PUSHM.32 D0|D1|D6|A5	PUSHM.32 D0|D1|D3|D4|A4	MOVE.16	{A4}+OOBPEN,D3			; D3 <-- numro du pinceau	MOVE.32	#0,A4				; A4 <-- objet par dfaut	MOVE.16	#IDENTPEN,D0	MOVE.16	#opDGETDIM,D1	PAGE_	OBJCALL				; D4 <-- demi-dimensions [dy;dx]	MOVE.32	D4,D6	POPM.32	D0|D1|D3|D4|A4	MOVE.32	A0,A5	MOVE.32	A4,{A5}+ODRINST.IF FALSE	MOVE.32	#16'7FFF7FFF,D0			; min = maximum	MOVE.32	#16'80008000,D1			; max = minimum	CALL	GETP1	CALL	INSBBOX				; insre le point dans le "bounding box"	CALL	GETP2	CALL	INSBBOX				; insre le point dans le "bounding box"	CALL	GETP3	CALL	INSBBOX				; insre le point dans le "bounding box"	CALL	GETP4	CALL	INSBBOX				; insre le point dans le "bounding box"	MOVE.32	D0,D3				; coordonnes minimum	MOVE.32	D1,D4				; coordonnes maximum.ELSE FALSE	CALL	EDDIMPAVE.ENDIF FALSE	ADD.16	#1,D4	SUB.16	#1,D3	SUB.16	D6,D3	ADD.16	D6,D4	ADD.16	D6,D4	SWAP.32	D6	SWAP.32	D4	SWAP.32	D3	ADD.16	#1,D4	SUB.16	#1,D3	SUB.16	D6,D3	ADD.16	D6,D4	ADD.16	D6,D4	SWAP.32	D6	SWAP.32	D4	SWAP.32	D3	POPM.32	D0|D1|D6|A5	CLR.16	D7				; retour EQ	RET;------------\\;  XopDETECT  >;============/; Dtermine si la souris est sur le pourtour de l'instance d'objet. La; marge de dtection dpend de l'chelle d'affichage (grand zoom, petite; marge..); in	A0.32	canal;	A4.32	^instance d'objet;	D2.16	marge de dtection (0..n);	D4.32	position de la souris [y;x]; out	D7.16	erreur; mod	D7.16XopDETECT:	PUSHM.32 D1..D5	MOVE.32	D4,D5				; D5 <-- position de la souris	CALL	GETP1	MOVE.32	D4,D1	MOVE.32	D4,D3				; D3 <-- P1	CALL	GETP2				; D4 <-- P2	MOVE.16	#MA_DETLINE,D7	PAGE_	MATH				; souris le long de la droite ?	JUMP,EQ	R8^EXIT$			; oui => EXIT$	MOVE.32	D4,D3				; D3 <-- P2	CALL	GETP3				; D4 <-- P3	MOVE.16	#MA_DETLINE,D7	PAGE_	MATH				; souris le long de la droite ?	JUMP,EQ	R8^EXIT$			; oui => EXIT$	MOVE.32	D4,D3				; D3 <-- P3	CALL	GETP4				; D4 <-- P4	MOVE.16	#MA_DETLINE,D7	PAGE_	MATH				; souris le long de la droite ?	JUMP,EQ	R8^EXIT$			; oui => EXIT$	MOVE.32	D4,D3				; D3 <-- P4	MOVE.32	D1,D4				; D4 <-- P1	MOVE.16	#MA_DETLINE,D7	PAGE_	MATH				; souris le long de la droite ?EXIT$:	POPM.32	D1..D5	TEST.16	D7				; retour EQ/NE	RET;----------\\;  XopDRAW  >;==========/; Dessine un objet texte.; in	A0.32	canal;	A4.32	^objet formule;	D2.32	mode de dessin; out	D7.16	erreur; mod	D7.16XopDRAW:	PUSHM.32 D1..D6|A0|A1|A5	MOVE.32	A0,A5				; A5 <-- ^variables globales	MOVE.32	A4,{A5}+ODRINST; ### pas beau du tout :	MOVE.32	#{A5}+OFONTBUF+16*LDGBM,A1	; A1 <- ^gencar symboles	CLR.16	{A1}+ODGBMCORPS			; taille de corps incorrecte	CALL	INITGENC	CALL	SYMBREDOPG	MOVE.32	D2,D1	TEST.32	D1:#BVUESHIFT	JUMP,BS	RECT$	TEST.32	D1:#BVUEPROV	JUMP,BS	RECT$	MOVE.16	#INVDOT,D2	TEST.32	D1:#BVUESET	JUMP,BC	R8^VUESET$	MOVE.16	#SETDOT,D2VUESET$:	TEST.32	D1:#BVUECLR	JUMP,BC	R8^VUECLR$	MOVE.16	#CLRDOT,D2VUECLR$:	CALL	DRAWFORMULE			; dessine la formule	JUMP	R8^COIN$VIDE$:	PUSH.32	A0	MOVE.32	{A5}+OPDDIS,A0			; A0 <-- ^descripteur fentre [DR]	MOVE.32	#16'10000*COLORFPAGE+COLORCDRAW,D4	MOVE.16	#DR_COLORINIT,D7	PAGE_	DRAW				; spcifie les couleurs	POP.32	A0	CALL	GETP1	MOVE.32	D4,D3				; D3 <-- P1	CALL	GETP3				; D4 <-- P3	MOVE.16	#DR_LINE,D7	PAGE_	DRAW	CALL	GETP2	MOVE.32	D4,D3				; D3 <-- P2	CALL	GETP4				; D4 <-- P4	MOVE.16	#DR_LINE,D7	PAGE_	DRAWCOIN$:	TEST.32	D1:#BVUEGROUP			; visualise les objets groupes ?	JUMP,BS	R8^CDRAW$			; oui => CDRAW$	COMP.16	#SETDOT,D2	JUMP,EQ	EXIT$	COMP.16	#CLRDOT,D2	JUMP,EQ	EXIT$CDRAW$:	MOVE.16	#DR_GETPRINT,D7	PAGE_	DRAW				; D4 <-- mode d'impression	CLR.16	D7	TEST.32	D4				; impression en cours ?	JUMP,NE	EXIT$				; oui => EXIT$	CALL	DRCOIN				; dessine les quatre coins	JUMP	EXIT$RECT$:	MOVE.16	#INVDOT,D2	TEST.32	D1:#BVUESHIFT	JUMP,BC	R8^VUESHIFT$	TSET.32	D2:#BTTTDOTVUESHIFT$:	TEST.32	D1:#BVUETTT	JUMP,BC	R8^VUETTT$	TSET.32	D2:#BTTTDOTVUETTT$:	TEST.32	D1:#BVUEPROVI	JUMP,BC	R8^RECT2$	CALL	DRAWFORMULE			; dessine la formuleRECT2$:	TEST.32	D1:#BVUEPROVE	JUMP,BC	R8^EXIT$	PUSH.32	A0	MOVE.32	{A5}+OPDDIS,A0			; A0 <-- ^descripteur fentre [DR]	MOVE.32	#16'10000*COLORFPAGE+COLORCDRAW,D4	MOVE.16	#DR_COLORINIT,D7	PAGE_	DRAW				; spcifie les couleurs	POP.32	A0	CALL	GETP1	MOVE.32	D4,D1	MOVE.32	D4,D3				; D3 <-- P1	CALL	GETP2				; D4 <-- P2	MOVE.16	#DR_LINE,D7	PAGE_	DRAW	MOVE.32	D4,D3				; D3 <-- P2	CALL	GETP3				; D4 <-- P3	MOVE.16	#DR_LINE,D7	PAGE_	DRAW	MOVE.32	D4,D3				; D3 <-- P3	CALL	GETP4				; D4 <-- P4	MOVE.16	#DR_LINE,D7	PAGE_	DRAW	MOVE.32	D4,D3				; D3 <-- P4	MOVE.32	D1,D4				; D4 <-- P1	MOVE.16	#DR_LINE,D7	PAGE_	DRAWEXIT$:	POPM.32	D1..D6|A0|A1|A5	TEST.16	D7				; retour EQ/NE	RET;---------------\\;  XopHANDLGEXT  >;===============/; Rend les longueurs pour tendre une instance d'objet pour les modifica-; tions avec opHANDxxx; in	A0.32	canal;	A4.32	^instance; out	D3.16	longueur de l'objet compact (lg actuelle);	D4.16	longueur de l'objet tendu (lg nouvelle);	D7.16	erreur; mod	D3.16, D4.16, D7.16XopHANDLGEXT:	MOVE.16	#LOB,D3	MOVE.16	#LOBHAND,D4	CLR.16	D7				; retour EQ	RET;---------------\\;  XopHANDLGCOM  >;===============/; Rend les longueurs pour compactifier une instance d'objet aprs les modifica-; tions avec opHANDxxx; in	A0.32	canal;	A4.32	^instance; out	D3.16	longueur de l'objet tendu (lg actuelle);	D4.16	longueur de l'objet compact (lg nouvelle);	D7.16	erreur; mod	D3.16, D4.16, D7.16XopHANDLGCOM:	PUSH.32 A5	MOVE.32	A0,A5	MOVE.32	A4,{A5}+ODRINST	CALL	FORTXTCOMPACT	MOVE.16	#LOBHAND,D3	MOVE.16	#LOB,D4	POP.32	A5	CLR.16	D7				; retour EQ	RET;-------------\\;  XopHANDGET  >;=============/; Rend la poigne  utiliser en fonction de son rang.; in	A0.32	canal;	A4.32	^instance de l'objet;	D2.16	rang de la poigne (0..n); out	D3.16	icne de la poigne (ICOHANDxxx);		ICOHANDEXT poigne d'extrmit (carre);		ICOHANDCDG centre de gravit (toile);		ICOHANDSEC point secondaire (petit rond);	D4.32	position [y;x];	D7.16	erreur; mod	D3.16, D4.32, D7.16XopHANDGET:	CLR.16	D7				; D7 <-- ok	MOVE.16	#ICOHANDEXT,D3			; D3 <-- icne extrmit	TEST.16	D2	JUMP,EQ	R8^MP0$	COMP.16	#1,D2	JUMP,EQ	R8^P1$	COMP.16	#2,D2	JUMP,EQ	R8^P2$	COMP.16	#3,D2	JUMP,EQ	R8^P3$	COMP.16	#4,D2	JUMP,EQ	R8^P4$	MOVE.16	#ERPAHANDEND,D7			; D7 <-- dernire poigne	JUMP	EXIT$MP0$:	CALL	GETP1	MOVE.32	D4,D3	CALL	GETP3	ADD.16	D3,D4	ASR.16	#1,D4	SWAP.32	D3	SWAP.32	D4	ADD.16	D3,D4	ASR.16	#1,D4;	SWAP.32	D3	SWAP.32	D4	MOVE.16	#ICOHANDCDG,D3			; D3 <-- icne centre de gravit	JUMP	R8^EXIT$P1$:	CALL	GETP1				; D4 <-- P1	JUMP	R8^EXIT$P2$:	CALL	GETP2				; D4 <-- P2	JUMP	R8^EXIT$P3$:	CALL	GETP3				; D4 <-- P3	JUMP	R8^EXIT$P4$:	CALL	GETP4				; D4 <-- P4;;	JUMP	R8^EXIT$EXIT$:	TEST.16	D7				; retour EQ/NE	RET;--------------\\;  XopHANDMOVE  >;==============/; Dplace une poigne durant la modification de l'objet. Cette mthode; permet de dplacer les poignes lors de la cration. Le logiciel PAGE; demande que l'instance ne soit jamais dessine.; in	A0.32	canal;	A4.32	^instance d'objet tendue;	D3.16	opration HANDMOVExxx;		HANDMOVEOPEN commence la modification interactive;		HANDMOVEBEGIN slectionne une nouvelle poigne;		HANDMOVEDRAG dplace la poigne slectionne;		HANDMOVEEND termine avec la poigne slectionne;		HANDMOVECLOSE termine la modification interactive;	D4.32	nouvelle position [y;x] si D3=HANDMOVEBEGIN/DRAG; out	D7.16	erreur; mod	D7.16XopHANDMOVE:	PUSHM.32 D0..D5|A1|A5	CLR.16	D7				; D7 <-- ok	MOVE.32	A0,A5	MOVE.32	A4,{A5}+ODRINST	COMP.16	#HANDMOVEOPEN,D3	JUMP,EQ	OPEN$	COMP.16	#HANDMOVEBEGIN,D3	JUMP,EQ	BEGIN$	COMP.16	#HANDMOVEDRAG,D3	JUMP,EQ	DRAG$	COMP.16	#HANDMOVEEND,D3	JUMP,EQ	END$	COMP.16	#HANDMOVECLOSE,D3	JUMP,EQ	CLOSE$	MOVE.16	#ERPAILOP,D7			; D7 <-- impossible	JUMP	EXIT$OPEN$:	CALL	GETP1	MOVE.32	D4,D3	CALL	GETP3	ADD.16	D3,D4	ASR.16	#1,D4	SWAP.32	D3	SWAP.32	D4	ADD.16	D3,D4	ASR.16	#1,D4;	SWAP.32	D3	SWAP.32	D4	MOVE.32	D4,{A4}+OOBFIX			; OOBFIX <-- point fixe initial	JUMP	EXIT$BEGIN$:	MOVE.32	{A4}+OOBP1,{A4}+OOBBP1	MOVE.32	{A4}+OOBP3,{A4}+OOBBP3	MOVE.32	{A4}+OOBA,{A4}+OOBBA	CALL	GETP1	MOVE.32	D4,{A4}+OOBBR1	CALL	GETP2	MOVE.32	D4,{A4}+OOBBR2	CALL	GETP3	MOVE.32	D4,{A4}+OOBBR3	CALL	GETP4	MOVE.32	D4,{A4}+OOBBR4	JUMP	EXIT$DRAG$:	TEST.16	D2	JUMP,EQ	DRAGMCDG$	COMP.16	#1,D2	JUMP,EQ	DRAGMP1$	COMP.16	#2,D2	JUMP,EQ	DRAGMP2$	COMP.16	#3,D2	JUMP,EQ	DRAGMP3$	COMP.16	#4,D2	JUMP,EQ	DRAGMP4$	MOVE.16	#ERPAILOP,D7			; D7 <-- impossible	JUMP	EXIT$DRAGMCDG$:	MOVE.32	{A4}+OOBBR1,D3	ADD.16	{A4}+OOBBR3+2,D3	ASR.16	#1,D3	SUB.16	D3,D4	SWAP.32	D3	SWAP.32	D4	ADD.16	{A4}+OOBBR3+0,D3	ASR.16	#1,D3	SUB.16	D3,D4	SWAP.32	D3	SWAP.32	D4	MOVE.32	{A4}+OOBBP1,D3	ADD.16	D4,D3	SWAP.32	D3	SWAP.32	D4	ADD.16	D4,D3	SWAP.32	D3	SWAP.32	D4	MOVE.32	D3,{A4}+OOBP1	MOVE.32	{A4}+OOBBP3,D3	ADD.16	D4,D3	SWAP.32	D3	SWAP.32	D4	ADD.16	D4,D3	SWAP.32	D3	SWAP.32	D4	MOVE.32	D3,{A4}+OOBP3	JUMP	DRAGEND$DRAGMP1$:	MOVE.32	D4,{A4}+OOBP1	MOVE.32	{A4}+OOBBR3,D4	MOVE.16	{A4}+OOBA+0,D1	CALL	INVANGLE	CALL	GETPX	MOVE.32	D4,{A4}+OOBP3	JUMP	DRAGEND$DRAGMP2$:	MOVE.32	{A4}+OOBBR1,D0			; D0 <-- P1 old	MOVE.32	{A4}+OOBBR2,D1			; D1 <-- P2 old	MOVE.32	D4,D2				; D2 <-- P2 new	CALL	CALCMOVE			; D3 <-- P1 new	MOVE.32	D3,{A4}+OOBP1	MOVE.32	{A4}+OOBBR3,D0			; D0 <-- P3 old	MOVE.32	{A4}+OOBBR2,D1			; D1 <-- P2 old	MOVE.32	D4,D2				; D2 <-- P2 new	CALL	CALCMOVE			; D3 <-- P3 new	MOVE.32	D3,D4	MOVE.16	{A4}+OOBA+0,D1	CALL	INVANGLE	CALL	GETPX	MOVE.32	D4,{A4}+OOBP3	JUMP	DRAGEND$DRAGMP3$:	MOVE.16	{A4}+OOBA+0,D1	CALL	INVANGLE	CALL	GETPX	MOVE.32	D4,{A4}+OOBP3	JUMP	DRAGEND$DRAGMP4$:	MOVE.32	{A4}+OOBBR1,D0			; D0 <-- P1 old	MOVE.32	{A4}+OOBBR4,D1			; D1 <-- P4 old	MOVE.32	D4,D2				; D2 <-- P4 new	CALL	CALCMOVE			; D3 <-- P1 new	MOVE.32	D3,{A4}+OOBP1	MOVE.32	{A4}+OOBBR3,D0			; D0 <-- P3 old	MOVE.32	{A4}+OOBBR4,D1			; D1 <-- P4 old	MOVE.32	D4,D2				; D2 <-- P4 new	CALL	CALCMOVE			; D3 <-- P3 new	MOVE.32	D3,D4	MOVE.16	{A4}+OOBA+0,D1	CALL	INVANGLE	CALL	GETPX	MOVE.32	D4,{A4}+OOBP3	JUMP	DRAGEND$DRAGEND$:;	JUMP	EXIT$END$:;	JUMP	EXIT$CLOSE$:;	JUMP	EXIT$EXIT$:	POPM.32	D0..D5|A1|A5	TEST.16	D7				; retour EQ/NE	RET;-----------------\\;  XopHANDICOLIST  >;=================/; Rend le pointeur sur la liste des icnes disponibles lors de l'dition; de l'instance.;; La liste doit contenir :;	 8x	OPIL	icnes pour les sous-outils (n'utiliser que les 4 premiers);	 1x	OPIC	sparateur;	 2x	OPIL	icnes pour les tats (objets de dfinition);	 1x	OPIF	terminateur; in	A0.32	canal; out	A3.32	^liste des icnes;	A2.32	^table des soft-keys;	D7.16	erreur; mod	A2.32, A3.32, D7.16XopHANDICOLIST:	MOVE.32	#R16^ICONE$,A3	MOVE.32	#R16^SOFTKEY$,A2	CLR.16	D7	RET	ICONE$:	.16	OPIL	.16	OPIL	.16	OPIL	.16	OPIL	.16	OPIL	.16	OPIL	.16	OPIL	.16	OPIL	.16	OPIC	.16	OPIS,ICOSPEN,0,OPIS,ICOSTRAME,0,OPIS,ICOSGREY+2,0,OPIL	.16	OPIS,ICOSCHAR,TICODIAL,OPIS,ICOSGREY+4,0,OPIS,ICOSGREY+5,0,OPIL	.16	OPIFSOFTKEY$:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.EVEN;----------------\\;  XopHANDICOMOD  >;================/; Ragit suite au clic dans une icne de gauche.; in	A0.32	canal;	A4.32	^instance tendue;	D3.16	icne clique; out	D4.16	nombre de modifications;	D7.16	erreur; mod	D4.16, D7.16XopHANDICOMOD:	PUSHM.32 D0..D3|D5|A3|A4|A5	MOVE.32	A0,A5	MOVE.32	A4,{A5}+ODRINST	CLR.16	D7			; ok	CLR.16	D4			; aucune modification	COMP.16	#ICOSPEN,D3	JUMP,EQ	PEN$	COMP.16	#ICOSTRAME,D3		; si c'est un tat qui est slectionn, dite celui-ci	JUMP,EQ	TRAME$	COMP.16	#ICOSCHAR,D3	JUMP,EQ	CHAR$	MOVE.16	#1,D7	JUMP	EXIT$			; dans les autres cas, on ne sait que fairePEN$:	MOVE.32	A4,A3			; copie le ^instance	MOVE.32	#0,A4			; objet par dfaut	MOVE.16	{A3}+OOBPEN,D2		; nouveau pinceau  utiliser	MOVE.16	#IDENTPEN,D0	MOVE.16	#opDTSELECT,D1	PAGE_	OBJCALL			; slectionne temporairement un pinceau ...	JUMP,NE	EXIT$	COMP.16	#F1,D3			; autre que "D'ACCORD" n'enregistre pas	JUMP,NE	EXIT$	MOVE.16	D2,{A3}+OOBPEN	JUMP	EXIT$TRAME$:	MOVE.32	A4,A3			; copie le ^instance	MOVE.32	#0,A4			; objet par dfaut	MOVE.16	{A3}+OOBTRA,D2		; nouvelle trame  utiliser	MOVE.16	#IDENTTRAME,D0	MOVE.16	#opDTSELECT,D1	PAGE_	OBJCALL			; slectionne temporairement une trame ...	JUMP,NE	R8^EXIT$	COMP.16	#F1,D3			; autre que "D'ACCORD" n'enregistre pas	JUMP,NE	R8^EXIT$	MOVE.16	D2,{A3}+OOBTRA	JUMP	R8^EXIT$CHAR$:	MOVE.32	A4,A3			; copie le ^instance	MOVE.32	#0,A4			; objet par dfaut	MOVE.16	{A3}+OOBFONT,D2		; nouveau caractre  utiliser	MOVE.16	#IDENTCHAR,D0	MOVE.16	#opDTSELECT,D1	PAGE_	OBJCALL			; slectionne temporairement un caractre ...	JUMP,NE	R8^EXIT$	MOVE.32	A3,A4	CALL	INITGENC		; refait les gencars	CLR.16	{A4}+OOBINIPG	COMP.16	#F1,D3			; autre que "D'ACCORD" n'enregistre pas	JUMP,NE	R8^EXIT$	MOVE.16	D2,{A4}+OOBFONT;	JUMP	R8^EXIT$EXIT$:	POPM.32	D0..D3|D5|A3|A4|A5	TEST.16	D7	RET;----------------\\;  XopHANDICOGET  >;================/; Rend l'tat d'une icne de modification donne.; in	A0.32	canal;	A4.32	^instance d'objet tendue;	D3.16	icne; out	D4.32	tats (STICOxxxx);		STICONORM icne teinte normale;		STICOINV icne inverse;		STICOGREY icne grise;		STICOINVL icne inverse avec point  gauche (left);		STICOINVR icne inverse avec point  droite (right);		+ BSTICOCHGHAND si change les poignes ncessaire;		+ BSTICOCHGDRAW si change le dessin ncessaire;		+ BSTICOCHGUPIC si change l'icne;	D7.16	erreur; mod	D4.16, D7.16XopHANDICOGET:	PUSHM.32 D3	CLR.16	D7				; ok	CLR.32	D4				; pas de flags	COMP.16	#ICOSPEN,D3	JUMP,EQ R8^UPIC$	COMP.16	#ICOSTRAME,D3	JUMP,EQ R8^UPIC$	COMP.16	#ICOSCHAR,D3	JUMP,EQ	R8^UPIC$	COMP.16	#ICOZHOMOT,D3	JUMP,EQ	R8^HOMOT$	COMP.16	#ICOSGREY+2,D3	JUMP,EQ	R8^GREY$	COMP.16	#ICOSGREY+4,D3	JUMP,EQ	R8^GREY$	COMP.16	#ICOSGREY+5,D3	JUMP,EQ	R8^GREY$	MOVE.16	#1,D7	JUMP	R8^EXIT$			; dans les autres cas, on ne sait que faireUPIC$:	TSET.32	D4:#BSTICOCHGUPIC  		; D4 <-- faudra changer l'icne	TSET.32	D4:#BSTICOCHGDRAW		; D4 <-- faudra aussi refaire le dessin	MOVE.16	#STICONORM,D4	JUMP	R8^EXIT$GREY$:	MOVE.16	#STICOGREY,D4	JUMP	R8^EXIT$HOMOT$:	MOVE.16	#STICOINV,D4;	JUMP	R8^EXIT$EXIT$:	POPM.32	D3	TEST.16	D7	RET;--------------\\;  XopZONEMOVE  >;==============/; Transforme la figure par une routine approprie qui effectue les; calculs de conversion.; in	A0.32	canal;	A4.32	^instance d'objet tendu;	D3.16	tat (ZONEMOVExxx);		ZONEMOVEBEGIN annonce le dbut d'une transformation;		ZONEMOVEDRAG demande d'effectuer la transformation sur les points du ZONEMOVEOPEN;		ZONEMOVEEND annonce fin d'une transformation;		ZONEMOVEHOMOT teste si l'on peut zoomer en dformant ou s'il faut conserver;			      un rapport d'homottie (figures rgulires devant conserver les;			      angles);		ZONEMOVEZOOM teste si l'on peut faire des zoom.;	A2.32	^routine de transformation d'un point; out	D4.16	0 si homottie pas obligatoire (si D3=ZONEMOVEHOMOT);		0 si zoom possible (si D3=ZONEMOVEZOOM);	D7.16	erreur; mod	D4.16, D7.16XopZONEMOVE:	PUSHM.32 D1..D3|D5|A5	CLR.16	D7				; D7 <-- ok	MOVE.32	A0,A5	MOVE.32	A4,{A5}+ODRINST	COMP.16	#ZONEMOVEBEGIN,D3	JUMP,EQ	BEGIN$	COMP.16	#ZONEMOVEDRAG,D3	JUMP,EQ	DRAG$	COMP.16	#ZONEMOVEEND,D3	JUMP,EQ	END$	COMP.16	#ZONEMOVEHOMOT,D3	JUMP,EQ	HOMOT$	COMP.16	#ZONEMOVEZOOM,D3	JUMP,EQ	ZOOM$	MOVE.16	#ERPAILOP,D7			; D7 <-- impossible	JUMP	EXIT$BEGIN$:	SET.8	{A5}+OISZONEMOVE	CALL	GETP1	MOVE.32	D4,{A4}+OOBBR1	CALL	GETP2	MOVE.32	D4,{A4}+OOBBR2	CALL	GETP3	MOVE.32	D4,{A4}+OOBBR3	JUMP	EXIT$DRAG$:	MOVE.32	{A4}+OOBBR1,D4	CALL	{A2}				; D4 <-- point transform	MOVE.32	D4,{A4}+OOBP1	MOVE.32	{A4}+OOBBR2,D4	CALL	{A2}				; D4 <-- point transform	MOVE.32	D4,D5	MOVE.32	{A4}+OOBBR3,D4	CALL	{A2}				; D4 <-- point transform	MOVE.32	D4,{A4}+OOBP3	MOVE.32	{A4}+OOBP1,D3	SUB.16	D5,D3	SWAP.32	D3	SWAP.32	D5	SUB.16	D5,D3	SWAP.32	D3	SWAP.32	D5	LIB	?CALCHYPO	EX.32	D5,D4	MOVE.32	{A4}+OOBP1,D3	ADD.16	D3,D5	SWAP.32	D3	SWAP.32	D5	MOVE.16	D3,D5	SWAP.32	D5	SWAP.32	D3	LIB	?CALCANGLE			; D2 <-- angle de rotation du rectangle	MOVE.16	D2,{A4}+OOBA+0	MOVE.32	{A4}+OOBP3,D4	MOVE.16	D2,D1	CALL	INVANGLE	CALL	GETPX	MOVE.32	D4,{A4}+OOBP3	JUMP	EXIT$END$:	CLR.8	{A5}+OISZONEMOVE	CALL	REDOP1P3	JUMP	R8^EXIT$HOMOT$:	CLR.16	D4				; D4 <-- dformation possible	MOVE.16	{A4}+OOBA,D3	JUMP,EQ	R8^EXIT$	COMP.16	#90,D3	JUMP,EQ	R8^EXIT$	COMP.16	#180,D3	JUMP,EQ	R8^EXIT$	COMP.16	#270,D3	JUMP,EQ	R8^EXIT$	INC.16	D4				; D4 <-- homothtie ncessaire	JUMP	R8^EXIT$ZOOM$:	CLR.16	D7	MOVE.16	#1,D4				; D4 <-- zoom pas possibleEXIT$:	POPM.32	D1..D3|D5|A5	TEST.16	D7				; retour EQ/NE	RET;---------------\\; XopEDITICOLIST >;===============/; Donne la liste des icnes pendant l'dition d'une instance d'objet.; La liste doit contenir :;	 8x	OPIL	icnes pour les sous-outils (n'utiliser que les 4 premiers);	 1x	OPIC	sparateur;	 2x	OPIL	icnes pour les tats (objets de dfinition);	 1x	OPIF	terminateur; in	A0.32	canal; out	A3.32	^liste des icnes;	A2.32	^table des soft-keys;	D7.16	erreur; mod	D7.16, A2.32, A3.32XopEDITICOLIST:	MOVE.32	#R16^ICONE$,A3	MOVE.32	#R16^SOFTKEY$,A2	CLR.16	D7				; retour EQ	RETICONE$:	.16	OPIS,ICOSYMB+0,0,OPIS,ICOSYMB+1,0,OPIS,ICOSYMB+2,0,OPIL	.16	OPIS,ICOSYMB+3,0,OPIS,ICOSYMB+4,0,OPIS,ICOSYMB+5,0,OPIL	.16	OPIS,ICOSYMB+6,0,OPIS,ICOSYMB+7,0,OPIS,ICOSYMB+8,0,OPIL	.16	OPIS,ICOSYMB+9,0,OPIS,ICOSYMB+10,0,OPIS,ICOSYMB+11,0,OPIL	.16	OPIS,ICOSYMB+12,0,OPIS,ICOSYMB+13,0,OPIS,ICOSYMB+14,0,OPIL	.16	OPIS,ICOSYMB+15,0,OPIS,ICOSYMB+16,0,OPIS,ICOSYMB+17,0,OPIL	.16	OPIS,ICOSYMB+18,0,OPIS,ICOSYMB+19,0,OPIS,ICOSYMB+20,0,OPIL	.16	OPIS,ICOSYMB+21,0,OPIS,ICOSYMB+22,0,OPIS,ICOSYMB+23,0,OPIL	.16	OPIC	.16	OPIS,ICOSPEN,0,OPIS,ICOSTRAME,0,OPIS,ICOSGREY+2,0,OPIL	.16	OPIS,ICOSCHAR,TICODIAL,OPIS,ICOSGREY+4,0,OPIS,ICOSGREY+5,0,OPIL	.16	OPIFSOFTKEY$:	.ASCIZ	""	.ASCIZ	"Fin"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	" Df.            "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Insre un symbole"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.EVEN;--------------\\; XopEDITICOMOD >;==============/; Modifie une icne dans laquelle on a cliqu (ragit selon le clic; effectu).; in	A0.32	canal;	A4.32	^instance d'objet;	D3.16	icne clique; out	D4.16	nb de modifications;	D7.16	erreur; mod	D4.32, D7.16XopEDITICOMOD:	PUSHM.32 D0..D3|A1..A5	MOVE.32	A0,A5				; A5 <-- ^variables globales	MOVE.32	A4,{A5}+ODRINST	TEST.8	{A5}+OTXCIF			; curseur teint ?	JUMP,EQ	R8^CLEARED$			; oui => c'est bon	CALL	BASINVCURS			; non => teint..CLEARED$:	CLR.16	D7				; D7 <-- ok	CLR.16	D4				; D4 <-- aucune modification	COMP.16	#ICOSPEN,D3	JUMP,EQ	PEN$	COMP.16	#ICOSTRAME,D3	JUMP,EQ	TRAME$	COMP.16	#ICOSCHAR,D3	JUMP,EQ	CHAR$	COMP.16	#ICOSYMB,D3	JUMP,HS	SYMB$	MOVE.16	#1,D7	JUMP	EXIT$SYMB$:	SUB.16	#ICOSYMB,D3			; D3 <-- numro de l'lment intressant	MOVE.32	#{A5}+OICOSYMB,A2	SL.16	#1,D3	ADD.A16	D3,A2				; A2 <-- ^numro  coller	LIB	?GETSHIFT	TEST.32	D3:#BCHANGE			; change l'icne ?	JUMP,BC	R8^INSYM$			; non => insre le symbole	MOVE.32	#R16^CHOIX$,A3	CALL	DBOXCHOIX	JUMP,NE	R8^BIP$	COMP.16	#F1,D3	JUMP,NE	R8^BIP$	MOVE.16	D2,{A2}	JUMP	EXIT$BIP$:	MOVE.16	#ERPBIP,D7	JUMP	EXIT$INSYM$:	MOVE.16	#ERPBIP,D7	MOVE.16	{A2},D2				; D2 <-- numro du symbole  coller	COMP.16	#-1,D2	JUMP,EQ	EXIT$;;?	CLR.16	{A4}+OOBINIPG	CALL	SYMBCHOIX	JUMP	REDRAW$PEN$:	MOVE.32	A4,A3				; A3 <-- ^objet	MOVE.16	{A3}+OOBPEN,D2			; D2 <-- pinceau de l'objet	MOVE.32	#0,A4				; A4 <-- objet par dfaut	MOVE.16	#IDENTPEN,D0	MOVE.16	#opDTSELECT,D1	PAGE_	OBJCALL				; slectionne temporairement un pinceau ...	JUMP,NE	EXIT$	COMP.16	#F1,D3				; "Utilise" ?	JUMP,NE	EXIT$				; non => rien	MOVE.32	A3,A4	MOVE.16	D2,{A4}+OOBPEN	MOVE.16	#1,D3				; D3 <-- affiche tout	CALL	XopEDITDRAW			; affiche le nouveau pav de texte	JUMP	EXIT$TRAME$:	MOVE.32	A4,A3				; A3 <-- ^objet	MOVE.16	{A3}+OOBTRA,D2			; D2 <-- trame de l'objet	MOVE.32	#0,A4				; A4 <-- objet par dfaut	MOVE.16	#IDENTTRAME,D0	MOVE.16	#opDTSELECT,D1	PAGE_	OBJCALL				; slectionne temporairement une trame ...	JUMP,NE	EXIT$	COMP.16	#F1,D3				; "Utilise" ?	JUMP,NE	EXIT$				; non => rien	MOVE.32	A3,A4	MOVE.16	D2,{A4}+OOBTRA	MOVE.16	#1,D3				; D3 <-- affiche tout	CALL	XopEDITDRAW			; affiche le nouveau pav de texte	JUMP	R8^EXIT$CHAR$:	MOVE.32	A4,A3				; A3 <-- ^objet	MOVE.16	{A3}+OOBFONT,D2			; D2 <-- caractre de l'objet	MOVE.32	#0,A4				; A4 <-- objet par dfaut	MOVE.16	#IDENTCHAR,D0	MOVE.16	#opDTSELECT,D1	PAGE_	OBJCALL				; slectionne temporairement un caractre ...	JUMP,NE	R8^EXIT$	MOVE.32	A3,A4	CALL	INITGENC			; refait les gencars	CLR.16	{A4}+OOBINIPG	COMP.16	#F1,D3				; "Utilise" ?	JUMP,NE	R8^EXIT$			; non => rien	MOVE.16	D2,{A3}+OOBFONTREDRAW$:	MOVE.16	#1,D3				; D3 <-- affiche tout	CALL	XopEDITDRAW			; affiche le nouveau pav de texte	PUSHM.32 D2|D3|D4	CALL	CALCPOSCURS			; D4 <-- [y;x] du curseur  l'cran	MOVE.16	D7,D2	CALL	CALCSIZECURS	MOVE.32	D3,{A5}+OTXCP1	MOVE.32	D4,{A5}+OTXCP2	POPM.32 D2|D3|D4;	JUMP	R8^EXIT$EXIT$:	POPM.32	D0..D3|A1..A5	TEST.16	D7				; retour EQ/NE	RETCHOIX$:	.ASCIZE	"Choix du symbole mathmatique  mettre sous forme d'icne :";--------------\\; XopEDITICOGET >;==============/; Donne l'tat d'une icne du mode d'dition.; in	A0.32	canal;	A4.32	^instance d'objet;	D3.16	icne; out	D4.16	tat (STICOxxxx);		STICONORM icne teinte normale;		STICOINV icne inverse;		STICOGREY icne grise;		+ BSTICOCHGHAND si change les poignes ncessaire;		+ BSTICOCHGDRAW si change le dessin ncessaire;	D7.16	erreur; mod	D4.32, D7.16XopEDITICOGET:	PUSHM.32 D2|D3|A2|A5	MOVE.32	A0,A5	MOVE.32	A4,{A5}+ODRINST	CLR.16	D7				; D7 <-- ok	CLR.32	D4				; D4 <-- clear flags BSTICOxxx	COMP.16	#ICOSGREY+2,D3	JUMP,EQ	GREY$	COMP.16	#ICOSGREY+4,D3	JUMP,EQ	GREY$	COMP.16	#ICOSGREY+5,D3	JUMP,EQ	GREY$	COMP.16	#ICOSPEN,D3	JUMP,EQ UPIC$	COMP.16	#ICOSTRAME,D3	JUMP,EQ UPIC$	COMP.16	#ICOSCHAR,D3	JUMP,EQ	UPIC$	COMP.16	#ICOSYMB,D3	JUMP,HS	SYMB$	MOVE.16	#1,D7	JUMP	EXIT$SYMB$:	SUB.16	#ICOSYMB,D3			; D3 <-- numro de l'lment intressant	MOVE.32	#{A5}+OICOSYMB,A2	SL.16	#1,D3	MOVE.16	{A2}+A16^{D3},D2		; D2 <-- numro du symbole  coller	MOVE.32	#STICONORM+2**BSTICOCHGUPIC,D4	JUMP	EXIT$GREY$:	MOVE.16	#STICOGREY,D4	JUMP	R8^EXIT$UPIC$:	TSET.32	D4:#BSTICOCHGUPIC 	 	; D4 <-- faudra changer l'icne	MOVE.16	#STICONORM,D4;	JUMP	R8^EXIT$EXIT$:	POPM.32	D2|D3|A2|A5	TEST.16	D7				; retour EQ/NE	RET;-------------\\; XopEDITEVENT >;=============/; Edite une instance d'objet selon une touche presse.; in	A0.32	canal;	A4.32	^instance d'objet;	D3.32	touche presse;	D4.32	position de la souris (si D3=KEYM?P); out	D7.16	erreur; mod	D7.16XopEDITEVENT:	PUSHM.32 D0|D2|D3|D4|A0|A5	MOVE.32	A0,A5				; A5 <-- ^variables globales	MOVE.32	{A5}+ODRINST,D0	MOVE.32	A4,{A5}+ODRINST	COMP.32	A4,D0	JUMP,EQ	R8^OKSIZ$	CALL	INITGENC	CALL	SYMBREDOPGOKSIZ$:	COMP.16	#KEYTIMO,D3	JUMP,EQ	TIMO$	TEST.32	D3	JUMP,EQ	R8^DRAW$	MOVE.16	#ERPBIP,D7	TEST.16	{A4}+OOBA	JUMP,NE	R8^ERR$	TEST.8	{A5}+OTXCIF			; curseur teint ?	JUMP,EQ	R8^CLEARED$			; oui => c'est bon	CALL	BASINVCURS			; non => teint..CLEARED$:	CLR.16	D7	CALL	EDITEVENT			; dite selon l'vnementDRAW$:	CALL	XopEDITDRAW	CLR.32	{A4}+OOBH1			; force le recalcul de la taille de la formule	CALL	CALCPOSCURS			; D4 <-- [y;x] du curseur  l'cran	CALL	CALCSIZECURS	MOVE.32	D3,{A5}+OTXCP1	MOVE.32	D4,{A5}+OTXCP2	JUMP	R8^ERR$TIMO$:	CALL	BASINVCURS			; inverse le curseur..ERR$:	POPM.32	D0|D2|D3|D4|A0|A5	TEST.16	D7				; retour EQ/NE	RET;----------------\\; XopEDITICOOUTIL >;================/; Donne l'icne  utiliser comme outil pour le lutin de la souris.; in	A0.32	canal;	A4.32	^objet texte;	D4.32	position de la souris (y;x)  [scr]; out	D3.16	icne pour la souris;	D7.16	erreur; mod	D3.32, D7.16XopEDITICOOUTIL:	MOVE.16	#ICOOEDIT,D3			; D3 <-- curseur d'dition	CLR.16	D7				; D7 <-- ok	RET;------------\\; XopEDITMOVE >;============/; Donne la position pour slectionner une zone dans l'instance d'objet; actuellement en cours d'dition.; in	A0.32	canal;	A4.32	^instance d'objet;	D3.16	tat (EDITMOVExxxx);		EDITMOVEOPEN ouverture;		EDITMOVEBEGIN dbut de l'dition (bouton press);		EDITMOVEDRAG dplacement;		EDITMOVEEND fin de l'dition (bouton relch);		EDITMOVECLOSE fermeture;		EDITMOVEGA donne l'angle normal;		EDITMOVEGAE donne l'angle pendant l'dition;		EDITMOVEREGLE action dans la rgle (pav de texte);	D4.32	nouvelle position (y;x), si D3=EDITMOVEBEGIN/DRAG; out	D4.16	nb de modifications, si D3=EDITMOVEREGLE;	D4.32	angle, si D3=EDITMOVEGA[E];	D7.16	erreur; mod	D4.32, D7.16XopEDITMOVE:	PUSHM.32 D3..D5|A0|A1|A5	MOVE.32	A0,A5				; A5 <-- ^variables globales	MOVE.32	{A5}+ODRINST,D5	MOVE.32	A4,{A5}+ODRINST	COMP.32	A4,D5	JUMP,EQ	R8^OKSIZ$	CALL	INITGENC	CALL	SYMBREDOPGOKSIZ$:	MOVE.32	{A5}+OPDDIS,A0			; A0 <-- ^descripteur fentre	CLR.16	D7				; D7 <-- ok	COMP.16	#EDITMOVEOPEN,D3	JUMP,EQ	R8^OPEN$	COMP.16	#EDITMOVEBEGIN,D3	JUMP,EQ	R8^BEGIN$	COMP.16	#EDITMOVEDRAG,D3	JUMP,EQ	DRAG$	COMP.16	#EDITMOVEEND,D3	JUMP,EQ	END$	COMP.16	#EDITMOVECLOSE,D3	JUMP,EQ	CLOSE$	COMP.16	#EDITMOVEGA,D3	JUMP,EQ	GETA$	COMP.16	#EDITMOVEGAE,D3	JUMP,EQ	GETAE$	MOVE.16	#ERPAILOP,D7			; D7 <-- impossible	JUMP	EXIT$OPEN$:	CALL	INITGENC			; initialise les gnrateurs de caractres	CALL	CALCPOSCURS			; D4 <-- [y;x] du curseur  l'cran	CALL	CALCSIZECURS	CLR.8	{A5}+OTXCIF	MOVE.32	D3,{A5}+OTXCP1	MOVE.32	D4,{A5}+OTXCP2	MOVE.32	{A4}+OOBA,{A4}+OOBAE	CLR.32	{A4}+OOBA			; pav droit pendant l'dition !	CALL	EDDIMPAVE	MOVE.32	D3,{A4}+OOBEDDIM+0	MOVE.32	D4,{A4}+OOBEDDIM+4	JUMP	EXIT$BEGIN$:	COMP.16	#KEYMDP,{A5}+OEDIT	JUMP,EQ	R8^ZBEGIN$	CALL	GETMOUSECURS			; positionne le curseur	JUMP	EXIT$ZBEGIN$:	MOVE.16	#ERPAILOP,D7			; D7 <-- impossible	TEST.32	{A4}+OOBA			; pav de texte tourn ?	JUMP,NE	EXIT$				; oui => EXIT$	CALL	GETPOSZONE			; D4 <-- position dans le buffer	JUMP,NE	EXIT$	MOVE.32	D4,{A5}+OTXZO1	MOVE.32	D4,{A5}+OTXZO2	JUMP	EXIT$DRAG$:	COMP.16	#KEYMDP,{A5}+OEDIT	JUMP,EQ	R8^ZDRAG$	CALL	GETMOUSECURS			; positionne le curseur	JUMP	EXIT$ZDRAG$:	CALL	GETPOSZONE			; D4 <-- position dans le buffer	JUMP,NE	EXIT$	COMP.32	{A5}+OTXZO2,D4			; est-on toujours  la mme position ?	JUMP,EQ	EXIT$				; oui => EXIT$	MOVE.32	{A5}+OTXZO2,D5	MOVE.32	D4,{A5}+OTXZO2	SET.8	{A5}+OTXDOINV			; demande d'inverser !	MOVE.32	A5,A0				; A0 <-- ^variables globales	MOVE.32	#0,D3				; D3 <-- affichage minimal	CALL	XopEDITDRAW	CLR.8	{A5}+OTXDOINV	JUMP	EXIT$END$:	COMP.16	#KEYMDP,{A5}+OEDIT	JUMP,EQ	R8^ZEND$	CALL	CALCPOSCURS			; D4 <-- [y;x] du curseur  l'cran	CALL	CALCSIZECURS			; D3 <-- [dy;dx] du curseur	MOVE.32	D3,{A5}+OTXCP1	MOVE.32	D4,{A5}+OTXCP2	JUMP	EXIT$ZEND$:	MOVE.32	A4,A1	CALL	EDITMMENU			; dite selon mmenu ...	MOVE.32	A5,A0				; A0 <-- ^variables globales	CLR.16	D3				; D3 <-- affichage minimal	CALL	XopEDITDRAW			; affiche le nouveau pav de texte	JUMP	R8^EXIT$CLOSE$:	MOVE.32	{A4}+OOBAE,{A4}+OOBA	JUMP	R8^EXIT$GETA$:	MOVE.32	{A4}+OOBA,D4	JUMP	R8^EXIT$GETAE$:	MOVE.32	{A4}+OOBAE,D4;	JUMP	R8^EXIT$EXIT$:	POPM.32	D3..D5|A0|A1|A5	TEST.16	D7				; retour EQ/NE	RET;------------\\; XopEDITDRAW >;============/; Affiche une instance d'objet aprs une modification avec "opEDITEVENT".; in	A0.32	canal;	A4.32	^instance d'objet; out	D7.16	erreur; mod	D7.16XopEDITDRAW:	PUSHM.32 D1|D2|D3|D4|A0|A1|A5	MOVE.32	A0,A5				; A5 <-- ^variables globales; ### pas beau du tout :	MOVE.32	#{A5}+OFONTBUF+16*LDGBM,A1	; A1 <- ^gencar symboles	CLR.16	{A1}+ODGBMCORPS			; taille de corps incorrecte	CALL	INITGENC	CALL	SYMBREDOPG	TEST.8	{A5}+OTXCIF			; curseur teint ?	JUMP,EQ	R8^CLEARED$			; oui => c'est bon	CALL	BASINVCURS			; non => teint..CLEARED$:	MOVE.32	#MI_CCMO,D7	PAGE_	MISC	MOVE.32	{A5}+OPDDIS,A0			; A0 <-- ^descripteur fentre	TEST.16	{A4}+OOBINIPG	JUMP,NE	R8^PGOK$	CALL	SYMBREDOPG			; reprend de nouvelles valeursPGOK$:	PUSH.32	A0	MOVE.32	{A5}+OPDDIS,A0			; A0 <-- ^descripteur fentre [DR]	MOVE.32	#2**0,D4			; D4 <-- mode couleur [DR]	MOVE.16	#DR_BMOPENMODE,D7	PAGE_	DRAW				; utilise le mode couleur/noir & blanc	POP.32	A0	MOVE.32	{A4}+OOBEDDIM+0,D3	MOVE.32	{A4}+OOBEDDIM+4,D4	MOVE.16	#DR_BMOPENDIM,D7		; D3/D4 <-- taille du pav	PAGE_	DRAW	JUMP,NE	EXIT$	CALL	EDCADREPAVE			; affiche le rectangle en pointill	MOVE.32	A4,A1				; A1 <-- ^objet texte	MOVE.32	#2**BVUESET.OR.2**BVUEPROV.OR.2**BVUEPROVI,D1	MOVE.32	#SETDOT.OR.2**BVUECHAR,D2	; D2 <-- mode de dessin	CALL	DRAWFORMULE			; affiche la formule	MOVE.16	#DR_BMCLOSE,D7	PAGE_	DRAW				; fin du dessin dans un bitmap	MOVE.32	#MI_SCMO,D7	PAGE_	MISC	TEST.8	{A5}+OTXCIF			; curseur teint ?	JUMP,EQ	R8^EXIT$			; oui => fin	PUSH.8	{A5}+OTXCIF	CALL	BASINVCURS			; non => rallume..	POP.8	{A5}+OTXCIFEXIT$:	POPM.32	D1|D2|D3|D4|A0|A1|A5	CLR.16	D7				; retour EQ	RET;-------------\\; XopEDITMMENU >;=============/; Actionne le mmenu pour le bouton du milieu pendant l'dition. Affiche le; MMENU et gre les actions en consquence.; in	A0.32	canal;	A4.32	^instance d'objet; out	D7.16	erreur; mod	D7.16, A3.32XopEDITMMENU:	PUSHM.32 D0|D1|D2|A1|A2|A3|A4|A5	MOVE.32	A0,A5				; ^variables locales	MOVE.32	A4,{A5}+ODRINST	MOVE.32	A4,A1				; ^instance	MOVE.16	#ICOIOBJET,D3	CALL	XopGETICONE			; A4 <-- ^matrice	MOVE.16	#ICOUSER+0,D3			; D3 <-- code de l'icne PAGE	MOVE.32	#DR_PUTICO,D7	PAGE_	DRAW				; IPP21 <-- matrice de l'icne	MOVE.32	{A5}+OCANRES,A2	MOVE.32	#RtypMMENUS,D0	MOVE.32	#RMENUMILIEU,D1	MOVE.32	#2**BRSGETPOINTER+2**BRSGETnoHAND,D2	RES_	GET				; demande le ^menu du milieu	JUMP,NE	EXIT$	MOVE.32	A4,A3	MOVE.32	#{A5}+OMMEDIT,A4		; ^in/out pour mmenu.	CLR.32	{A4}+(LMM*0)+OMMINA	CLR.32	{A4}+(LMM*1)+OMMINA	TSET.8	{A4}+(LMM*0)+OMMINA+3:#1	TSET.8	{A4}+(LMM*0)+OMMINA+3:#3	TSET.8	{A4}+(LMM*1)+OMMINA+3:#0	MOVE.32	#MI_MMENUS,D7	PAGE_	MISC	JUMP,NE	R8^EXIT$	COMP.16	#4,{A4}+(LMM*0)+OMMSEL		; "dfinitions" ?	JUMP,EQ	R8^DEF$	COMP.16	#2,{A4}+(LMM*0)+OMMSEL		; "dition" ?	JUMP,EQ	R8^EDIT$	COMP.16	#5,{A4}+(LMM*0)+OMMSEL		; "symboles" ?	JUMP,EQ	R8^INS$	JUMP	EXIT$INS$:	MOVE.32	A1,A4				; A4 <-- ^instance	CALL	CHOIX	JUMP	REDRAW$EDIT$:	COMP.16	#1,{A4}+(LMM*1)+OMMSEL		; "efface" ?	JUMP,EQ	R8^EFFACE$	COMP.16	#2,{A4}+(LMM*1)+OMMSEL		; "aide" ?	JUMP,EQ	R8^HELP$	JUMP	R8^EXIT$EFFACE$:	MOVE.32	#2,{A1}+OOBTXTUSE		; plus rien que le terminateur	CLR.32	{A1}+OOBPOC			; curseur au dbut	MOVE.32	{A1}+OOBPTXT,A4	CLR.16	{A4}	JUMP	R8^REDRAW$			; tout effac + redessine..HELP$:	CALL	AFHELP	JUMP	R8^EXIT$DEF$:	CALL	DBOXDEF	JUMP,NE	R8^EXIT$REDRAW$:	MOVE.32	A1,A4	CLR.16	{A4}+OOBINIPG	MOVE.32	A5,A0	CALL	XopEDITDRAW			; redessineEXIT$:	POPM.32	D0|D1|D2|A1|A2|A3|A4|A5	TEST.16	D7	RET;----------\\; XopBUTTON >;==========/; Indique le bouton de la souris utilis.; Doit tre excut avant XopEDITMOVE et XopEDITICOMOD.; in	A0.32	canal;	D3.16	bouton de la souris utilis (KEYMGP/KEYMDP); out	-; mod	D7.16XopBUTTON:	MOVE.16	D3,{A0}+OEDIT	CLR.16	D7				; retour EQ	RET;----------\\; XopGETDEF >;==========/; Modifie l'objet dans une zone. Demande de signaler quel est l'tat actuel utilis.; in	A0.32	canal;	A4.32	^objet;	D3.16	identificateur de l'tat  obtenir; out	D4.16	tat utilis;	D7.16	erreur; mod	D4.32, D7.16XopGETDEF:;;	COMP.16	#IDENTCHAR,D3;;	JUMP,EQ	R8^CHAR$	COMP.16	#IDENTPEN,D3	JUMP,EQ	R8^PEN$	COMP.16	#IDENTTRAME,D3	JUMP,EQ	R8^TRAME$	COMP.16	#IDENTCHAR,D3	JUMP,EQ	R8^MANY$	COMP.16	#IDENTCOLOR,D3	JUMP,EQ	R8^MANY$	MOVE.16	#ERPAILOP,D7	RETMANY$:	MOVE.16	#ERPLDEF,D7			; utiliser GETLDEF !	RET;CHAR$:	MOVE.16	{A4}+OOBFONT,D4;	CLR.16	D7;	RETPEN$:	MOVE.16	{A4}+OOBPEN,D4	CLR.16	D7	RETTRAME$:	MOVE.16	{A4}+OOBTRA,D4	CLR.16	D7	RET;-----------\\; XopGETLDEF >;===========/; Demande de signaler quels sont les tats actuels utiliss.; in	A0.32	canal;	A4.32	^objet;	D3.16	identificateur de l'tat  obtenir;	A2.32	^buffer;	D2.16	taille maximale du buffer; out	{A2}++	^liste des tats (.16 termins par -1);	D7.16	erreur; mod	D7.16XopGETLDEF:	PUSHM.32 D0..D6|A0..A5	COMP.16	#IDENTCHAR,D3	JUMP,EQ	CHAR$	COMP.16	#IDENTCOLOR,D3	JUMP,EQ	COLOR$FULL$:	MOVE.16	#ERPAILOP,D7	JUMP	EXIT$; Met la liste des car. utiliss... Seulement si INITGENC a eu lieu !CHAR$:	CLR.16	D4	MOVE.32	#{A0}+OFONTCOLORS,A3LOOPCHAR$:	MOVE.16	{A3+},D3	COMP.16	#-1,D3	JUMP,EQ	R8^NEXTCHAR$	SUB.16	#2,D2	JUMP,LE	FULL$	MOVE.16	D4,{A2+}NEXTCHAR$:	INC.16	D4	COMP.16	#16,D4	JUMP,NE	LOOPCHAR$	MOVE.16	#-1,{A2}	CLR.16	D7	JUMP	EXIT$COLOR$:	CLR.16	D4	MOVE.32	#{A0}+OFONTCOLORS,A3LOOPCOLOR$:	MOVE.16	{A3+},D3	COMP.16	#-1,D3	JUMP,EQ	R8^NEXTCOLOR$	SUB.16	#2,D2	JUMP,LE	FULL$	MOVE.16	D3,{A2+}NEXTCOLOR$:	INC.16	D4	COMP.16	#17,D4	JUMP,NE	LOOPCOLOR$			; <-- table remplie avec les couleurs des caractres	MOVE.32	A4,A3				; A3 <-- ^objet	MOVE.16	{A3}+OOBPEN,D4			; D4 <-- numro du pinceau	MOVE.16	#IDENTCOLOR,D3	MOVE.32	#0,A4				; A4 <-- objet par dfaut	MOVE.16	#IDENTPEN,D0	MOVE.16	#opDGETLDEF,D1	PAGE_	OBJCALL				; {A2++} <-- couleur du pinceau	JUMP,NE	R8^EXIT$	MOVE.16	{A3}+OOBTRA,D4			; D4 <-- numro de la trame;	MOVE.16	#IDENTCOLOR,D3;	MOVE.32	#0,A4				; A4 <-- objet par dfaut	MOVE.16	#IDENTTRAME,D0;	MOVE.16	#opDGETLDEF,D1	PAGE_	OBJCALL				; {A2++} <-- couleurs de la trame	JUMP,NE	R8^EXIT$TERM$:	MOVE.16	#-1,{A2}			; {A2} <-- terminateur;	JUMP	R8^OK$OK$:	CLR.16	D7				; D7 <-- okEXIT$:	POPM.32	D0..D6|A0..A5	TEST.16	D7				; retour EQ/NE	RET;------------\\; XopEDITINFO >;============/; Donne les informations pendant l'dition.; in	A0.32	canal;	A4.32	^objet tendu;	A3.32	^buffer (dj rempli d'espaces);	D3.16	lg max buffer; out	(A3)++	informations (ne pas mettre de <0>);	D7.16	erreur; mod	D7.16, A3.32XopEDITINFO:	PUSHM.32 D4|D5|A1|A3|A4|A5	MOVE.32	A0,A5	MOVE.32	A4,{A5}+ODRINST	MOVE.32	A4,A1				; A1 <-- ^objet texte	MOVE.32	A3,A4				; A4 <-- ^buffer	MOVE.32	{A1}+OOBTXTUSE,D4		; D4 <-- nombre de car. utiliss	SR.32	#1,D4	DEC.32	D4	MOVE.32	#MI_PUTANUM,D7	PAGE_	MISC				; buffer <-- nb caractres	MOVE.32	#R16^TEXT$,A3XFER$:	MOVE.8	{A3+},{A4+}	JUMP,NE	XFER$	MOVE.8	#SPACE,{A4}-1;;	MOVE.16	{A5}+OTXIMBRIC,D4;;	MOVE.32	#MI_PUTANUM,D7;;	PAGE_	MISC				; buffer <-- profondeur d'imbrication	POPM.32	D4|D5|A1|A3|A4|A5	CLR.16	D7				; retour EQ	RETTEXT$:	.ASCIZ	" caractre(s)"	.EVEN;;	Routines diverses utiles..;	--------------------------;----------\\;  INSBBOX  >;==========/; Insre un point pour faire le "bounding box" d'un objet; in	D0.32	[y;x] minimum;	D1.32	[y;x] maximum;	D4.32	Px; out	D0.32	[y;x] minimum;	D1.32	[y;x] maximum; mod	D0.32, D1.32INSBBOX:	COMP.16	D4,D0				; [x].min < x ?	JUMP,LE	R8^OK1$				; oui => ne change rien	MOVE.16	D4,D0OK1$:	COMP.16	D4,D1				; [x].max < x ?	JUMP,GE	R8^OK2$				; non => ne change rien	MOVE.16	D4,D1OK2$:	SWAP.32	D0	SWAP.32	D1				; prend les [x;y]	SWAP.32	D4	COMP.16	D4,D0				; [y].min < y ?	JUMP,LE	R8^OK3$				; oui => ne change rien	MOVE.16	D4,D0OK3$:	COMP.16	D4,D1				; [y].max < y ?	JUMP,GE	R8^OK4$				; non => ne change rien	MOVE.16	D4,D1OK4$:	SWAP.32	D0	SWAP.32	D1				; rcupre [y;x]	SWAP.32	D4	RET;--------\\; DRCOIN  >;========/; Trace les quatre coins.; in	A4.32	^objet;	D2.16	mode de dessin; out	-; mod	D7.16DRCOIN:	PUSHM.32 D3|D4	PUSH.32	A0	MOVE.32	{A5}+OPDDIS,A0			; A0 <-- ^descripteur fentre [DR]	MOVE.32	#16'10000*COLORFPAGE+COLORCDRAW,D4	MOVE.16	#DR_COLORINIT,D7	PAGE_	DRAW	POP.32	A0	CALL	GETP1	MOVE.32	D4,D3				; D3 <-- P1	CALL	GETP2				; D4 <-- P2	CALL	R8^DRLINE18	CALL	GETP4				; D4 <-- P4	CALL	R8^DRLINE18	CALL	GETP2	MOVE.32	D4,D3				; D3 <-- P2	CALL	GETP1				; D4 <-- P1	CALL	R8^DRLINE18	CALL	GETP3				; D4 <-- P3	CALL	R8^DRLINE18	CALL	GETP3	MOVE.32	D4,D3				; D3 <-- P3	CALL	GETP2				; D4 <-- P2	CALL	R8^DRLINE18	CALL	GETP4				; D4 <-- P4	CALL	R8^DRLINE18	CALL	GETP4	MOVE.32	D4,D3				; D3 <-- P4	CALL	GETP1				; D4 <-- P1	CALL	R8^DRLINE18	CALL	GETP3				; D4 <-- P3	CALL	R8^DRLINE18	POPM.32	D3|D4	RET;---------\\; DRLINE18 >;---------/; Trace un huitime de ligne.; in	D3.32	origine (y;x);	D4.32	arrive (y;x); out	-; mod	D7.16DRLINE18:	PUSHM.32 D3|D4	SUB.16	D3,D4	ASR.16	#3,D4	ADD.16	D3,D4	SWAP.32	D3	SWAP.32	D4	SUB.16	D3,D4	ASR.16	#3,D4	ADD.16	D3,D4	SWAP.32	D3	SWAP.32	D4	MOVE.16	#DR_LINE,D7	PAGE_	DRAW	POPM.32	D3|D4	RET.IF 0 ; [DR];-----------\\;  DRAWRECT  >;===========/; Dessine le rectangle.; in	A5.32	^var. locales;	A4.32	^objet texte;	D2.16	mode de dessin (SETDOT/CLR/INV/TTT...); out	D7.16; mod	D7.16DRAWRECT:	PUSHM.32 D1|D3|D4	CALL	GETP1	MOVE.32	D4,D1	MOVE.32	D4,D3				; D3 <- P1	CALL	GETP2				; D4 <- P2	MOVE.32	#DR_LINE,D7	PAGE_	DRAW	MOVE.32	D4,D3				; D3 <- P2	CALL	GETP3				; D4 <- P3	MOVE.32	#DR_LINE,D7	PAGE_	DRAW	MOVE.32	D4,D3				; D3 <- P3	CALL	GETP4				; D4 <- P4	MOVE.32	#DR_LINE,D7	PAGE_	DRAW	MOVE.32	D4,D3				; D3 <- P4	MOVE.32	D1,D4				; D4 <- P1	MOVE.32	#DR_LINE,D7	PAGE_	DRAWERR$:	POPM.32	D1|D3|D4	TEST.16	D7	RET.ENDIF;-----------\\;  INVANGLE  >;===========/; Inverse l'angle de rotation.; in	D1.16	angle en degrs; out	D1.16	angle tourn : 360-angle; mod	D1.16INVANGLE:	TEST.16	D1	JUMP,EQ	R8^OK$	SUB.16	#360,D1				; angle symtrique	NEG.16	D1OK$:	RET;-----------\\;  REDOP1P3  >;===========/; Met  jour P1 et P3 de telle faon qu'ils soient  nouveau ok; in	A4.32	^instance de l'objet; out	-; mod	-REDOP1P3:	PUSHM.32 D2|D3|D4	SUB.A16	#16,A7	CALL	GETP1	MOVE.32	D4,{A7}+0	CALL	GETP2	MOVE.32	D4,{A7}+4	CALL	GETP3	MOVE.32	D4,{A7}+8	CALL	GETP4	MOVE.32	D4,{A7}+12	MOVE.16	{A4}+OOBP1+2,D3	MOVE.16	{A4}+OOBP3+2,D4	COMP.16	D3,D4	JUMP,GT	R8^OKX$	MOVE.16	D3,{A4}+OOBP3+2	MOVE.16	D4,{A4}+OOBP1+2OKX$:	MOVE.16	{A4}+OOBP1+0,D3	MOVE.16	{A4}+OOBP3+0,D4	COMP.16	D3,D4	JUMP,GT	R8^OKY$	MOVE.16	{A7}+12+2,D2	SUB.16	{A7}+0+2,D2	ADD.16	D2,{A4}+OOBP1+2	ADD.16	D2,{A4}+OOBP3+2	MOVE.16	D3,{A4}+OOBP3+0	MOVE.16	D4,{A4}+OOBP1+0	MOVE.16	{A4}+OOBP1+0,D2	SUB.16	{A7}+12+0,D2	SUB.16	D2,{A4}+OOBP1+0	SUB.16	D2,{A4}+OOBP3+0OKY$:	ADD.A16	#16,A7	POPM.32	D2|D3|D4	TEST.16	D7	RET;--------\\; RECTOR  >;========/; Effectue un "ou" (union) entre deux rectangles.; in	D1/D2	P1/P2 rectangle A;	  /D4	P1/P2 rectangle B; out	D3/D4	P1/P2 rectangle A ! B; mod	D3.32, D4.32RECTOR:	COMP.16	D1,D3	JUMP,LE	R8^L20$	MOVE.16	D1,D3L20$:	COMP.16	D2,D4	JUMP,GE	R8^L22$	MOVE.16	D2,D4L22$:	SWAP.32	D1	SWAP.32	D2	SWAP.32	D3	SWAP.32	D4	COMP.16	D1,D3	JUMP,LE	R8^L40$	MOVE.16	D1,D3L40$:	COMP.16	D2,D4	JUMP,GE	R8^L42$	MOVE.16	D2,D4L42$:	SWAP.32	D1	SWAP.32	D2	SWAP.32	D3	SWAP.32	D4	RET;------------\\; EDCADREPAVE >;------------/; Dessine le cadre autour d'un pav pendant l'dition.; in	D3.32	P1 (y;x);	D4.32	P2 (y;x); out	-; mod	D7.16EDCADREPAVE:	PUSHM.32 D1..D4	MOVE.32	D4,D2	MOVE.16	#1,D4	MOVE.16	#MA_SCALEN,D7	PAGE_	MATH				; D4 <-- retrait d'un point [obj]	EX.32	D4,D2	SUB.16	D2,D4	SWAP.32	D4	SUB.16	D2,D4				; P2 <-- dans le bitmap visible !	SWAP.32	D4	MOVE.16	#2'00110011,D1			; D1 <-- map pour traitill	MOVE.16	#SETDOT.OR.TTTDOT,D2	MOVE.16	#DR_RECTHV,D7	PAGE_	DRAW				; dessine un rectangle pointill	POPM.32	D1..D4	RET;----------\\; EDDIMPAVE >;----------/; Calcule les dimensions pendant l'dition d'un pav de texte.; Rserve une marge de 3 points [scr] tout autour.; in	A4.32	^objet texte; out	D3.32	P1 (y;x);	D4.32	P2 (y;x); mod	D3.32, D4.32, D7.16EDDIMPAVE:	PUSHM.32 D1|D2	CALL	GETP1				; D4 <-- P1	MOVE.32	D4,D3	MOVE.32	D4,D2	CALL	GETP2				; D4 <-- P2	EX.32	D4,D2	MOVE.32	D2,D1	CALL	RECTOR				; D3/D4 <-- rectangle englobant	MOVE.32	D4,D2	CALL	GETP3				; D4 <-- P3	EX.32	D4,D2	MOVE.32	D2,D1	CALL	RECTOR				; D3/D4 <-- rectangle englobant	MOVE.32	D4,D2	CALL	GETP4				; D4 <-- P4	EX.32	D4,D2	MOVE.32	D2,D1	CALL	RECTOR				; D3/D4 <-- rectangle englobant	MOVE.32	D4,D2	MOVE.16	#3,D4	MOVE.16	#MA_SCALEN,D7	PAGE_	MATH				; D4 <-- marge [obj]	EX.32	D4,D2	SUB.16	D2,D3	SWAP.32	D3	SUB.16	D2,D3				; P1 <-- plus en haut  gauche	SWAP.32	D3	MOVE.32	D4,D2	MOVE.16	#3+1,D4	MOVE.16	#MA_SCALEN,D7	PAGE_	MATH				; D4 <-- marge [obj]	EX.32	D4,D2	ADD.16	D2,D4	SWAP.32	D4	ADD.16	D2,D4				; P2 <-- plus en bas  droite	SWAP.32	D4	POPM.32	D1|D2	RET;--------\\;  GETP1  >;========/; Cherche le point P1 du cadre; in	A4.32	^instance d'objet; out	D4.32	P1 [y;x]; mod	D4.32, D7.16GETP1:	MOVE.32	{A4}+OOBP1,D4	RET;--------\\;  GETP2  >;========/; Cherche le point P2 du cadre; in	A4.32	^instance d'objet; out	D4.32	P2 [y;x]; mod	D4.32, D7.16GETP2:	PUSHM.32 D1|D3	MOVE.16	{A4}+OOBP1+0,D4	SWAP.32	D4	MOVE.16	{A4}+OOBP3+2,D4			; [y;x] de P2	MOVE.16	{A4}+OOBA+0,D1	JUMP,EQ	R8^OK$				; D1 <-- angle de rotation	MOVE.32	{A4}+OOBP1,D3			; D3 <-- centre	LIB	?CALCPSYM			; D4 <-- P2 tourn autour du cercleOK$:	POPM.32	D1|D3	RET;--------\\;  GETP3  >;========/; Cherche le point P3 du cadre; in	A4.32	^instance d'objet; out	D4.32	P3 [y;x]; mod	D4.32, D7.16GETP3:	PUSHM.32 D1|D3	MOVE.32	{A4}+OOBP3,D4	MOVE.16	{A4}+OOBA+0,D1	JUMP,EQ	R8^OK$				; D1 <-- angle de rotation	MOVE.32	{A4}+OOBP1,D3			; D3 <-- centre	LIB	?CALCPSYM			; D4 <-- P3 tourn autour du cercleOK$:	POPM.32	D1|D3	RET;--------\\;  GETP4  >;========/; Cherche le point P4 du cadre; in	A4.32	^instance d'objet; out	D4.32	P4 [y;x]; mod	D4.32, D7.16GETP4:	PUSHM.32 D1|D3	MOVE.16	{A4}+OOBP3+0,D4	SWAP.32	D4	MOVE.16	{A4}+OOBP1+2,D4			; [y;x] de P4	MOVE.16	{A4}+OOBA+0,D1	JUMP,EQ	R8^OK$				; D1 <-- angle de rotation	MOVE.32	{A4}+OOBP1,D3			; D3 <-- centre	LIB	?CALCPSYM			; D4 <-- P4 tourn autour du cercleOK$:	POPM.32	D1|D3	RET;--------\\;  GETPX  >;========/; Cherche le point Px du cadre; in	A4.32	^instance d'objet;	D1.16	angle de rotation;	D4.32	point Px  tourner; out	D4.32	point Px tourn; mod	D4.32, D7.16GETPX:	PUSH.32 D3	TEST.16	D1	JUMP,EQ	R8^ERR$	MOVE.32	{A4}+OOBP1,D3		; D3 <-- centre	LIB	?CALCPSYM		; D4 <-- Px tourn autour du centreERR$:	POP.32	D3	TEST.16	D7	RET;---------\\; CALCMOVE >;---------/; Calcule le point C situ  l'intersection de d2 et d3, sachant que :;   -  d1 passe par A et B;   -  d2 passe par A et C;   -  d3 passe par C et D;   -  d1 est parallle  d3;   -  d2 est perpendiculaire  d1 et d3;	  | A            B;	--o------------o----;	  |      d1;	  | d2;	  |         d3;	--o------------------o----;	  | C                  D;;             Ax*P' - Dx*P + Dy - Ay;	Cx = ------------------------;	               P'-P;;	Cy = (Cx-Ax)*P' + Ay;;	        By - Ay;	P  = + ---------  (pente de d1 et d3);	        Bx - Ax;;	        Bx - Ax;	P' = - ---------  (pente de d2);	        By - Ay; in	D0.32	A (y;x);	D1.32	B (y;x);	D2.32	D (y;x); out	D3.32	C (y;x); mod	D3.32, D7.16CALCMOVE:	PUSHM.32 D0..D2|D4..D6|A0..A2	MOVE.32	D0,D5				; D5 <-- Ay;Ax	MOVE.32	D1,A2				; A2 <-- By;Bx	MOVE.32	D2,D6				; D6 <-- Dy;Bx	MOVE.16	A2,D3	SUB.16	D5,D3				; D3 <-- Bx-Ax	SWAP.32	D3	MOVE.16	#CHOUIA,D3	MOVE.32	A2,D4	SWAP.32	D4	SWAP.32	D5	SUB.16	D5,D4				; D4 <-- By-Ay	SWAP.32	D5	SWAP.32	D4	MOVE.16	#CHOUIA,D4	MOVE.32	D4,D1	MOVE.32	D3,D2	MOVE.16	#MA_FIXDIV,D7	PAGE_	MATH	JUMP,VS	OVER$	MOVE.32	D0,A0				; A0 <-- P	MOVE.32	D3,D1	MOVE.32	D4,D2	MOVE.16	#MA_FIXDIV,D7	PAGE_	MATH	JUMP,VS	OVER$	NEG.32	D0	MOVE.32	D0,A1				; A1 <-- P'	MOVE.16	D5,D1	SWAP.32	D1	MOVE.16	#CHOUIA,D1	MOVE.32	A1,D2	MOVE.16	#MA_FIXMUL,D7	PAGE_	MATH				; D0 <-- Ax*P'	JUMP,VS	OVER$	MOVE.32	D0,D3	MOVE.16	D6,D1	SWAP.32	D1	MOVE.16	#CHOUIA,D1	MOVE.32	A0,D2	MOVE.16	#MA_FIXMUL,D7	PAGE_	MATH				; D0 <-- Dx*P	JUMP,VS	OVER$	SUB.32	D0,D3	MOVE.32	D5,D0	MOVE.16	#CHOUIA,D0			; D0 <-- Ay	SUB.32	D0,D3	MOVE.32	D6,D0	MOVE.16	#CHOUIA,D0			; D0 <-- Dy	ADD.32	D0,D3	MOVE.32	D3,D1				; D1 <-- (Ax*P')-(Dx*P)-Ay+Dy	MOVE.32	A1,D2	SUB.32	A0,D2				; D2 <-- P'-P	MOVE.16	#MA_FIXDIV,D7	PAGE_	MATH				; D0 <-- Cx	JUMP,VS	OVER$	MOVE.32	D0,D3	MOVE.16	D5,D1	SWAP.32	D1	MOVE.16	#CHOUIA,D1			; D1 <-- Ax	SUB.32	D3,D1				; D1 <-- Ax-Cx	NEG.32	D1				; D1 <-- Cx-Ax	MOVE.32	A1,D2	MOVE.16	#MA_FIXMUL,D7	PAGE_	MATH				; D0 <-- (Cx-Ax)*P'	JUMP,VS	OVER$	MOVE.32	D5,D1	MOVE.16	#CHOUIA,D1			; D1 <-- Ay	ADD.32	D1,D0				; D0 <-- Cy	SWAP.32	D0	MOVE.16	D0,D3	SWAP.32	D3	JUMP	R8^EXIT$OVER$:	MOVE.16	A2,D3	SUB.16	D5,D3				; D3 <-- Bx-Ax	JUMP,NC	R8^POSX$	NEG.16	D3POSX$:	SWAP.32	D5	MOVE.32	A2,D4	SWAP.32	D4	SUB.16	D5,D4				; D4 <-- By-Ay	JUMP,NC	R8^POSY$	NEG.16	D3POSY$:	SWAP.32	D5	COMP.16	D4,D3	JUMP,LO	R8^VERT$HORIZ$:	MOVE.32	D6,D3	MOVE.16	D5,D3	JUMP	R8^EXIT$VERT$:	MOVE.32	D5,D3	MOVE.16	D6,D3;	JUMP	R8^EXIT$EXIT$:	POPM.32	D0..D2|D4..D6|A0..A2	RET	.INS	OPFORMDEF.ASI	.INS	OPFORMDRAW.ASI	.INS	OPFORMEDIT.ASI	.INS	OPFORMSYMB.ASI	.INS	OPFORMHELP.ASI	.END