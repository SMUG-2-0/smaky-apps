	.SBTTL	OPIMAGIO.ASI;----------\\; IOIMALOAD >;==========/; Charge une image en mmoire.; in	A3.L	^nom de l'image;	A4.L	^objet image; out	A3.L	^en-tte;	A4.L	^image;	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	A4.L, D7.W, A3.L, A4.LIOIMALOADSC:	TEST.B	(A4)+OOBFIM:#BIMSCAN	JUMP,BS IOIMASCANIOIMALOAD:	PUSHM.L	D0,D1,D3,D6,A1,A2,A5	LOAD.W	D7,#MI_WAITMOUSE	PAGE_	MISC		; souris: met le sablier	LOAD.L	A5,A3		; A5 <-- ^nom de l'image	LOAD.L	D4,#LGHIMA	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour l'en-tte	JUMP,NE 90$	LOAD.L	A2,A4		; A2 <-- ^en-tte	LOAD.W	D3,#2^BOPRD	; D3 <-- mode d'ouverture	FOS	?OPEN		; ouvre l'image	JUMP,NE 84$	LOAD.L	A4,A2	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 82$	COMP.B	(A2)+OIMTYP,#H'82 ; image du LAMI ?	JUMP',NE 20$		; non => 20$				; oui =>	CLR.B	D3	LOAD.L	D4,#256	FOS	?SPOS		; saute la stupide en-tte de 256 bytes !	JUMP,NE 82$	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 82$20$:	LOAD.W	D0,(A2)+OIMDLX	; D0 <-- largeur de l'image	LOAD.W	D1,(A2)+OIMDLY	; D1 <-- hauteur de l'image	LOAD.W	D4,D0	SR.W	D4,#3	MUL.WU	D4,D1		; D4 <-- largeur*hauteur/8	ADD.L	D4,#IMLBUF	; D4 <-- rserve pour codage	PUSH.W	D1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour toute l'image	POPM.W	D1	JUMP,NE 82$	LOAD.L	A1,#(A4)+IMLBUF	; A1 <-- ^image	LOAD.L	D4,(A2)+OIMNBB	; D4 <-- longueur  lire	TEST.B	(A2)+OIMCOD	; image code ?	JUMP',NE 30$		; oui => 30$				; non =>	LOAD.L	A4,A1	FOS	?RDBYTE		; lit toute l'image dcode	JUMP,NE 80$	JUMP'	35$30$:	FOS	?RDBYTE		; lit toute l'image code	JUMP',NE 80$	LOAD.L	A3,A1	GRA_	DECOIMA		; dcode l'image ...	JUMP',NE 80$35$:	FOS	?CLOSE		; ferme l'image	JUMP',NE 84$	LOAD.L	A3,A2		; A3 <-- ^en-tte	LOAD.L	A4,A1		; A4 <-- ^image	LOAD.W	D4,D1	SWAP.W	D4	LOAD.W	D4,D0		; D4 <-- dimensions de l'image	CLR.W	D7		; D7 <-- ok	JUMP'	90$80$:	PUSH.W	D7	LOAD.L	A4,#(A1)-IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'image	POP.W	D782$:	PUSH.W	D7	FOS	?CLOSE		; ferme l'image	POP.W	D784$:	PUSHM.L	D7,A4	LOAD.L	A4,A2	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend le buffer pour l'en-tete	POPM.L	D7,A490$:	POPM.L	D0,D1,D3,D6,A1,A2,A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; IOIMASCAN >;==========/; Scanne une image en mmoire.; in	-; out	A3.L	^en-tte;	A4.L	^image;	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	A4.L, D7.W, A3.L, A4.LIOIMASCAN:	PUSHM.L	D1..D3,D5,D6,A2	LOAD.W	D7,#ERKSTO	LOAD.L	D6,(A0)+OCASCAN	; D6 <-- canal SCAN	JUMP,EQ	EXIT9$		; scanner absent => EXIT9$	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX		; prpare l'ouverture de la DBOX	LIB	?GETWDO	LOAD.W	D1,D5		; D1 <-- swdo initiale	LIB	?GETDIM		; D4 <-- dimensions de tout l'cran	CLR.L	D3	LIB	?CREWDO	LIB	?USEWDO		; utilise tout l'cran	LOAD.B	D3,#SAVWDO	LIB	?AFCAR		; sauve tout l'cran	JUMP',NE SAVKO$	LOAD.L	D4,#-1		; D4 <-- dimensions maximales	CLR.L	D3		; D3 <-- mode	SCAN_	READ		; A4/D4/D5 <-- ^image/dimensions/iy ...	LOAD.L	A2,A4		; A2 <-- ^image	LOAD.L	D2,D4		; D2 <-- dimensions	LOAD.B	D3,#GETWDO	LIB	?AFCAR		; restitue tout l'cran	CLR.W	D7SAVKO$:	PUSHM.L	D5,D7	LIB	?GETWDO	EX.L	D5,D1	LIB	?USEWDO		; utilise la swdo initiale	LOAD.W	D5,D1	LIB	?KILWDO	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX		; prpare la fermeture de la DBOX	POPM.L	D5,D7	TEST.W	D7	JUMP,NE	EXIT8$	LOAD.W	D7,#ERKSTO	TEST.L	D2		; y a-t-il une image lue ?	JUMP,EQ	EXIT8$		; non => EXIT8$	LOAD.L	D4,#LGHIMA	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour l'en-tte	JUMP,NE EXIT8$	GESMEM	?CLEARMEM	LOAD.L	A3,A4		; A3 <-- ^en-tte	LOAD.B	(A3)+OIMTYP,#H'81;	LOAD.B	(A3)+OIMCOD,#H'00	LOAD.B	(A3)+OIMBIP,#H'01	LOAD.B	(A3)+OIMDIR,#H'02	ADD.W	D2,#16-1	AND.B	D2,#B'11110000	LOAD.W	(A3)+OIMDLX,D2	SWAP.W	D2	LOAD.W	(A3)+OIMDLY,D2	MUL.WU	D5,D2	LOAD.L	(A3)+OIMNBB,D5	LOAD.L	D4,D5	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour l'image	JUMP,NE EXIT7$	PUSH.L	A4XFER$:	LOAD.B	(A4+),(A2+)	DEC.L	D4	JUMP,NE	XFER$	POP.L	A4	LOAD.W	D4,(A3)+OIMDLY	SWAP.W	D4	LOAD.W	D4,(A3)+OIMDLX	; D4 <-- dimensions	JUMP'	EXIT8$EXIT7$:	PUSH.W	D7	LOAD.W	D1,#MTYPCP	LOAD.L	A4,A3	GESMEM	?GIVMEM		; libre l'en-tte	POP.W	D7EXIT8$:	PUSH.W	D7	SCAN_	RELEASE		; libre l'image lue	POP.W	D7EXIT9$:	POPM.L	D1..D3,D5,D6,A2	TEST.W	D7		; retour EQ/NE	RET;----------\\; IOIMAKILL >;==========/; Libre la mmoire d'une image.; in	A3.L	^en-tte;	A4.L	^image; out	-; mod	-IOIMAKILL:	PUSHM.L	D1,D7,A4	LOAD.L	A4,A3	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'en-tte	LOAD.L	A4,#(A4)-IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'image	POPM.L	D1,D7,A4	RET;--------\\; AFIMAGE >;========/; Affiche une image.; in	A4.L	^objet;	D2.W	mode; out	-; mod	D7.WAFIMAGE:	PUSHM.L	D3,D4,A3	CALL	CALCMATRICE	; calcule la matrice (D4 <-- coin sup/gauche)	JUMP,NE EXIT$	LOAD.W	D7,#MI_CCMO	PAGE_	MISC		; enlve la souris	LOAD.L	A3,#(A5)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWRASTER	CLR.L	(A3)+1	LOAD.L	(A3)+5,(A4)+OOBPMA	JUMP',NE NO11$	LOAD.L	(A3)+5,(A4)+OOBPIMNO11$:	LOAD.W	D3,(A4)+OOBDMA+2	ADD.W	D3,#8-1	SR.W	D3,#3	LOAD.W	(A3)+9,D3	SWAP.W	D4	LOAD.L	(A3)+11,D4	CLR.L	(A3)+15	CLR.W	(A3)+19	LOAD.W	(A3)+21,(A4)+OOBDMA+2	LOAD.W	(A3)+23,(A4)+OOBDMA+0	LOAD.B	(A3)+25,D2	LOAD.W	D3,#26	LIB	?STRING		; affiche l'imageEXIT$:	POPM.L	D3,D4,A3	TEST.W	D7		; retour EQ/NE	RET;------------\\; CALCMATRICE >;------------/; Calcule la matrice stretche.; in	A4.L	^objet image; out	D4.L	coin sup/gauche (y;x)  [scr];	D7.W	erreur; mod	D4.L, D7.WCALCMATRICE:	PUSHM.L	D0..D3,A0,A3,A4	LOAD.W	D7,#1	TEST.L	(A4)+OOBPIM	; image existe ?	JUMP,EQ EXIT$		; non => EXIT$	CALL	XopGETBBOX	; D3/D4 <-- bounding bbox	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.L	D0,D3		; D0 <-- coin sup/gauche	LOAD.L	D2,D4		; D2 <-- coin inf/droite	TEST.L	(A4)+OOBPMA	; matrice existe ?	JUMP',EQ CREATE$	; non => CREATE$	LOAD.W	D7,#DR_GETSCALE	PAGE_	DRAW		; D4 <-- chelle actuelle	COMP.W	D4,(A4)+OOBSMA	; mme chelle ?	JUMP',NE CREATE$	; non => CREATE$	LOAD.W	D4,(A4)+OOBA	COMP.W	D4,(A4)+OOBAMA	; mme angle ?	JUMP',NE CREATE$	; non => CREATE$	CALL	CALCDIM		; D4 <-- dimensions de l'image	COMP.L	D4,(A4)+OOBDMA	; mmes dimensions ?	JUMP,EQ OK$		; oui => OK$CREATE$:	LOAD.L	A3,A4		; A3 <-- ^objet	TEST.L	(A3)+OOBPMA	JUMP',EQ NOREL$	LOAD.L	A4,(A3)+OOBPMA	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la matrice	CLR.L	(A3)+OOBPMANOREL$:	LOAD.L	A4,A3		; A4 <-- ^objet	CALL	CALCDIM		; D4 <-- dimensions de l'image	LOAD.L	(A3)+OOBDMA,D4	COMP.L	D4,(A3)+OOBDIM	; exactement les mmes dimensions ?	JUMP,EQ	OK$		; oui => OK$	ADD.W	D4,#8-1	SR.W	D4,#3	LOAD.L	D3,D4	SWAP.W	D3		; D3 <-- hauteur	INC.W	D3		; D3 <-- une ligne de rserve !	MUL.WU	D4,D3	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^nouvelle matrice	JUMP,NE EXIT$	GESMEM	?CLEARMEM	LOAD.L	(A3)+OOBPMA,A4	LOAD.L	A4,A3		; A4 <-- ^objet	LOAD.L	A0,#(A5)+OVARST	; A0 <-- ^variables pour "stretch"	LOAD.L	(A0)+OSTRSPT,(A4)+OOBPIM	LOAD.W	D4,(A4)+OOBDIM+2	ADD.W	D4,#8-1	SR.W	D4,#3	LOAD.W	(A0)+OSTRSDX,D4	CLR.L	(A0)+OSTRS0	LOAD.L	D4,(A4)+OOBDIM	DEC.W	D4		; D4 <-- -1 car OSTRS2 doit tre inclu !	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.L	(A0)+OSTRS2,D4	LOAD.L	(A0)+OSTRDPT,(A4)+OOBPMA	LOAD.W	D4,(A4)+OOBDMA+2	ADD.W	D4,#8-1	SR.W	D4,#3	LOAD.W	(A0)+OSTRDDX,D4	CALL	GETP1	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	LOAD.W	D7,#MA_SCALEP	PAGE_	MATH		; D4 <-- dimensions selon chelle	LOAD.L	(A0)+OSTRD0,D4	CALL	GETP2	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	LOAD.W	D7,#MA_SCALEP	PAGE_	MATH		; D4 <-- dimensions selon chelle	LOAD.L	(A0)+OSTRD1,D4	CALL	GETP3	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	LOAD.W	D7,#MA_SCALEP	PAGE_	MATH		; D4 <-- dimensions selon chelle	LOAD.L	(A0)+OSTRD2,D4	CALL	GETP4	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	LOAD.W	D7,#MA_SCALEP	PAGE_	MATH		; D4 <-- dimensions selon chelle	LOAD.L	(A0)+OSTRD3,D4	LOAD.W	(A0)+OSTRTYP,#1	; nouveau mode (OSTRD2 exclu)	ST_	RECT		; hop, vive les dformations ...	LOAD.W	D7,#DR_GETSCALE	PAGE_	DRAW		; D4 <-- chelle actuelle	LOAD.W	(A4)+OOBSMA,D4	; OOBSMA <-- chelle actuelle	LOAD.W	(A4)+OOBAMA,(A4)+OOBA ; OOBAMA <-- angle actuelOK$:	LOAD.L	D4,D0	LOAD.W	D7,#MA_OBJDRAW	PAGE_	MATH		; D4 <-- coin sup/gauche (y;x)	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D3,A0,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CALCDIM >;--------/; Calcule les dimensions de l'image.; in	D0.L	coin sup/gauche;	D2.L	coin inf/droite;	A4.L	^objet image; out	D4.L	dimensions (dy;dx); mod	D4.L, D7.WCALCDIM:	PUSHM.L	D3	LOAD.L	D4,D2	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	LOAD.W	D7,#MA_SCALEP	PAGE_	MATH		; D4 <-- dimensions selon chelle.IF 0	LOAD.W	D3,D4	MUL.WU	D3,#1000	DIV.WU	D3,(A4)+OOBDIM+2	COMP.W	D3,#1000-15	; admet un cart de +/-1.5%	JUMP',LO EXIT$	COMP.W	D3,#1000+15	JUMP',HS EXIT$	LOAD.L	D3,D4	SWAP.W	D3	MUL.WU	D3,#1000	DIV.WU	D3,(A4)+OOBDIM+0	COMP.W	D3,#1000-15	; admet un cart de +/-1.5%	JUMP',LO EXIT$	COMP.W	D3,#1000+15	JUMP',HS EXIT$	LOAD.L	D4,(A4)+OOBDIM	; D4 <-- dimensions exactes.ENDIFEXIT$:	POPM.L	D3	RET	.END