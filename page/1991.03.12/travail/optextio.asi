	.SBTTL	OPTEXTIO.ASI;--------\\; IORALL  >;========/; Lit tout un texte.; in	A4.L	^objet texte;	D6.L	canal pour le buffer de texte; out	D7.W	erreur; mod	D7.WIORALL:	PUSHM.L	D3,D4,A3LOOP$:	LOAD.L	A3,#(A5)+OBUFILE	CALL	DBOXTXPREND	; demande le nom ...	JUMP',NE EXIT$	COMP.W	D3,#F1	JUMP',NE EXIT$	CALL	_BUTX_FLUSH	; efface tout	CALL	CARMODPALL	; signal qu'il faudra tout redessiner	CALL	IORTEXT		; lit le fichier texte	JUMP',EQ EXIT$	CALL	DBOXERROR	; affiche l'erreur	JUMP	LOOP$EXIT$:	POPM.L	D3,D4,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; IORADD  >;========/; Ajoute tout un texte.; in	A4.L	^objet texte;	D6.L	canal pour le buffer de texte; out	D7.W	erreur; mod	D7.WIORADD:	PUSHM.L	D3,D4,A3LOOP$:	LOAD.L	A3,#(A5)+OBUFILE	CALL	DBOXTXAJOUTE	; demande le nom ...	JUMP',NE EXIT$	COMP.W	D3,#F1	JUMP',NE EXIT$	CALL	CARMODPALL	; signal qu'il faudra tout redessiner	CALL	IORTEXT		; lit le fichier texte	JUMP',EQ EXIT$	CALL	DBOXERROR	; affiche l'erreur	JUMP	LOOP$EXIT$:	POPM.L	D3,D4,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; IORTEXT >;--------/; Prend ou ajoute un fichier texte.; in	A4.L	^objet texte;	A3.L	^nom du fichier; out	D7.W	erreur; mod	D7.WIORTEXT:	PUSHM.L	D2..D5	LOAD.W	D7,#MI_WAITMOUSE	PAGE_	MISC		; souris: met le sablier	LOAD.W	D7,#IO_RDOPEN	PAGE_	IO		; ouvre le fichier en entre	JUMP,NE EXIT$	CALL	_BUTX_GETPOS	; D4 <-- position actuelle	LOAD.L	D5,D4	CLR.B	D2		; D2 <-- enable <cr>LOOP$:	CALL	RDSKBOA		; D3 <-- lit un caractre	JUMP',NE END$	CALL	EINSERE		; insert un caractre	JUMP',NE END$	JUMP	LOOP$END$:	PUSH.W	D7	LOAD.L	D4,D5	CALL	_BUTX_SETPOS	; revient au dbut du fichier lu	POP.W	D7	LOAD.W	D5,D7	LOAD.W	D7,#IO_RDCLOSE	PAGE_	IO		; ferme le fichier en entre	COMP.W	D7,#EROUTF	; fin du fichier ?	JUMP',NE EXIT$		; non => EXIT$	CLR.W	D7		; D7 <-- okEXIT$:	PUSH.W	D7	LOAD.W	D7,#MI_NORMMOUSE	PAGE_	MISC		; souris: enlve le sablier	POP.W	D7	POPM.L	D2..D5	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDSKBOA >;--------/; Lit un caractre, en ignorant les commandes "boa".; in	D2.B	disable/enable <cr>; out	D2.B	disable/enable <cr>;	D3.B	caractre lu;	D7.W	erreur; mod	D2.L, D3.L, D7.WRDSKBOA:	PUSHM.L	D4,A410$:	LOAD.W	D7,#IO_RDONE	PAGE_	IO		; D3 <-- lit un caractre	JUMP,NE EXIT$	TEST.L	D3:#7	JUMP,BS 10$	COMP.B	D3,#CR	JUMP',NE 12$	TEST.B	D2		; disable <cr> ?	JUMP,T	10$		; oui => 10$12$:	LOAD.B	D4,D3	LOAD.B	D3,#CR	COMP.B	D4,#H'0A	; pseudo-CR ?	JUMP,EQ 10$	COMP.B	D4,#H'06	; pseudo-FF ?	JUMP,EQ 10$	COMP.B	D4,#H'0C	; FF ?	JUMP,EQ OK$	LOAD.B	D3,#'-	COMP.B	D4,#H'0B	; pseudo-tiret ?	JUMP,EQ 10$	LOAD.B	D3,#H'02	COMP.B	D4,#H'02	; cadratin ?	JUMP,EQ OK$	LOAD.B	D3,D4	COMP.B	D3,#'\	JUMP,NE OK$; Lit toute une commande "boa".	LOAD.L	A4,#(A5)+OBUBOA	LOAD.W	D4,#LBUBOA-2	LOAD.W	D7,#IO_RDONE	PAGE_	IO		; D3 <-- lit 1er caractre d'une "boa"	JUMP,NE EXIT$	LOAD.B	(A4+),D3	; OBUBOA <-- commande "boa"	DEC.W	D4	LIB	?MINMAJ	COMP.B	D3,#'\		; double "boa" ?	JUMP,EQ OK$		; oui => OK$	COMP.B	D3,#'A		; commence par une lettre ?	JUMP,LO 10$		; non => 10$	COMP.B	D3,#'Z	JUMP,HI 10$20$:	LOAD.W	D7,#IO_RDONE	PAGE_	IO		; D3 <-- lit une "boa"	JUMP,NE EXIT$	TEST.W	D4	JUMP',EQ 22$	LOAD.B	(A4+),D3	; OBUBOA <-- commande "boa"	DEC.W	D422$:	COMP.B	D3,#';		; fin de la "boa" ?	JUMP',EQ 24$	COMP.B	D3,#':	JUMP,NE 20$24$:	CLR.B	(A4)		; OBUBOA <-- terminateur	LOAD.L	A4,#(A5)+OBUBOA	CALL	RDSRBOA		; D3 <-- no commande "boa"	TEST.B	D3	JUMP,EQ 10$	COMP.B	D3,#1	JUMP',EQ 30$	COMP.B	D3,#2	JUMP',EQ 31$	COMP.B	D3,#3	JUMP',EQ 35$	JUMP	10$30$:				; disable <cr> =>	LOAD.B	D2,#-1	JUMP	10$31$:				; enable <cr> =>	CLR.B	D2	JUMP	10$35$:				; define =>	LOAD.W	D7,#IO_RDONE	PAGE_	IO		; D3 <-- lit un caractre	JUMP',NE EXIT$	COMP.B	D3,#CR	JUMP,NE 35$	JUMP	10$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDSRBOA >;--------/; Cherche s'il s'agit d'une commande "boa" spciale.; in	A4.L	^commande "boa"; out	D3.B	no commande (zro si pas trouv); mod	D3.L, D7.WRDSRBOA:	PUSHM.L	A2..A4	LOAD.L	A3,#R16"TABLE$10$:	LOAD.B	D3,(A3+)	; D3 <-- no commande	JUMP',EQ EXIT$	LOAD.L	A2,A420$:	TEST.B	(A3)	JUMP',EQ EXIT$	COMP.B	(A3+),(A2+)	JUMP,EQ 20$30$:	TEST.B	(A3+)	JUMP,NE 30$	JUMP	10$EXIT$:	POPM.L	A2..A4	RETTABLE$:	.B	1	.ASCIZ	"disable <'<>cr<'>>"	.B	2	.ASCIZ	"enable <'<>cr<'>>"	.B	3	.ASCIZ	"define "	.B	0	.EVEN;--------\\; IOWALL  >;========/; Ecrit tout un texte.; in	A4.L	^objet texte;	D6.L	canal pour le buffer de texte; out	D7.W	erreur; mod	D7.WIOWALL:	PUSHM.L	D0,D3,D4,A3LOOP$:	LOAD.L	A3,#(A5)+OBUFILE	CALL	DBOXTXSAUVE	; demande le nom ...	JUMP,NE EXIT$	COMP.W	D3,#F1	JUMP,NE EXIT$CREATE$:	LOAD.W	D7,#MI_WAITMOUSE	PAGE_	MISC		; souris: met le sablier	LOAD.L	D3,#DEFATT	; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	LOAD.L	D0,#FOS?CREATE	LOAD.W	D7,#DB_ERCALL	PAGE_	DBOX		; cre le fichier	PUSH.W	D7	LOAD.W	D7,#MI_NORMMOUSE	PAGE_	MISC		; souris: enlve le sablier	POP.W	D7	JUMP',EQ WRITE$		; ok => WRITE$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP',NE ERROR$		; non => ERROR$				; oui =>	CALL	DBOXDELETE	; dtruit le fichier ?	COMP.W	D3,#'O	JUMP,NE LOOP$	LOAD.W	D7,#MI_WAITMOUSE	PAGE_	MISC		; souris: met le sablier	LOAD.L	D0,#FOS?DELETE	LOAD.W	D7,#DB_ERCALL	PAGE_	DBOX		; dtruit le fichier	JUMP',NE ERROR$	JUMP	CREATE$WRITE$:	CALL	IOWTEXT		; crit le texte	JUMP',EQ EXIT$ERROR$:	CALL	DBOXERROR	; affiche l'erreur	JUMP	LOOP$EXIT$:	POPM.L	D0,D3,D4,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; IOWTEXT >;--------/; Sauve un fichier texte.; in	A4.L	^objet texte;	A3.L	^nom du fichier; out	D7.W	erreur; mod	D7.WIOWTEXT:	PUSHM.L	D2..D5	LOAD.W	D7,#MI_WAITMOUSE	PAGE_	MISC		; souris: met le sablier	LOAD.W	D7,#IO_WROPEN	PAGE_	IO		; ouvre le fichier en sortie	JUMP',NE EXIT$	CALL	_BUTX_POSSAVE	; D4 <-- no de la position actuelle	LOAD.W	D2,D4	CLR.L	D4	CALL	_BUTX_SETPOS	; va au tout dbutLOOP$:	CALL	_BUTX_AVANCE	; D3/D4/D5 <-- un caractre	JUMP',NE OK$	COMP.B	D3,#PEOT	JUMP',EQ OK$	CALL	_BUTX_NOSUPPL	; D3 <-- caractre < 128	LOAD.W	D7,#IO_WRONE	PAGE_	IO		; crit un caractre	JUMP',NE END$	JUMP	LOOP$OK$:	CLR.W	D7		; D7 <-- okEND$:	PUSH.W	D7	LOAD.W	D4,D2	CALL	_BUTX_POSEND	; retourne o l'on tait	POP.W	D7	LOAD.W	D5,D7	LOAD.W	D7,#IO_WRCLOSE	PAGE_	IO		; ferme le fichier en sortieEXIT$:	PUSH.W	D7	LOAD.W	D7,#MI_NORMMOUSE	PAGE_	MISC		; souris: enlve le sablier	POP.W	D7	POPM.L	D2..D5	TEST.W	D7		; retour EQ/NE	RET	.END