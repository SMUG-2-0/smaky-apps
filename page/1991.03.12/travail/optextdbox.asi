	.SBTTL	OPTEXTDBOX.ASI;-----------\\; DBOXINSCAR >;===========/; Choix d'un caractre  insrer.; in	-; out	D3.W	dernire touche (F1/F0);	D2.W	caractre  insrer;	D7.W	erreur; mod	D2.L, D3.L, D7.WDBOXINSCAR:	PUSHM.L	D0,D1,D4,D5,A0..A4	LOAD.L	A0,(A5)+OPDDIS	; A0 <-- ^descripteur fentre	LOAD.L	A2,#R16"TDBOX_INSCAR	LOAD.W	D2,#2^BDBSAV	CLR.L	D4	LOAD.W	D7,#DB_OPEN	PAGE_	DBOX		; ouvre la DBOX	JUMP,NE	EXIT$	LOAD.L	A4,(A5)+OIPPT	LOAD.L	D4,(A5)+OIPDIM	LOAD.L	D3,#H'10000*IPWDOY+IPWDOX	LOAD.W	D7,#DB_IMASHOW	PAGE_	DBOX		; affiche l'image de la palette	LOAD.W	D0,#-1	LOAD.W	D2,D0	CALL	IPINV		; allume le caractre actuelLOOP$:	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_INSCAR	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP',EQ CLIC$	COMP.W	D3,#F1	JUMP',EQ OK$	COMP.W	D3,#F0	JUMP',EQ CANCEL$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$CLIC$:	CALL	IPMOVE		; slectionne un caractre ...	JUMP,NE LOOP$	LOAD.W	D3,#F1OK$:	COMP.W	D0,#-1	JUMP,EQ BIP$	LOAD.W	D2,D0CANCEL$:			; ANNULE =>	LOAD.W	D7,#DB_CLOSE	PAGE_	DBOX		; ferme la DBOXEXIT$:	POPM.L	D0,D1,D4,D5,A0..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; IPMOVE  >;--------/; Change de caractre slectionn.; in	D0.W	caractre slectionn; out	D0.W	nouveau caractre;	D7.W	0 => double clic; mod	D0.L, D7.WIPMOVE:	PUSHM.L	D1..D4	LOAD.W	D1,D0	JUMP'	CPOS$CLOOP$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP',NE CEND$CPOS$:	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE CLOOP$	SUB.W	D4,(A0)+ODFFX	JUMP,LO CLOOP$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	JUMP,LO CLOOP$	SWAP.W	D4	CALL	IPDET		; D2 <-- caractre o est la souris	COMP.W	D2,D0		; toujours dans le mme ?	JUMP,EQ CLOOP$		; oui => CLOOP$				; non =>	EX.L	D0,D2	CALL	IPINV		; efface l'ancien	LOAD.W	D2,D0	CALL	IPINV		; allume le nouveau	JUMP	CLOOP$CEND$:	LOAD.W	D7,#1		; D7 <-- simple clic	COMP.W	D0,D1	JUMP',NE EXIT$	COMP.W	D0,#-1	JUMP',EQ EXIT$	CLR.W	D7		; D7 <-- double clicEXIT$:	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; IPDET   >;--------/; Dtecte dans quel caractre est la souris.; in	D4.L	position de la souris (y;x); out	D2.W	caractre (0..255,-1);	D7.W	erreur; mod	D2.L, D7.WIPDET:	PUSHM.L	D0,D1,D3,D4	LOAD.W	D0,D4	LOAD.L	D1,D4	SWAP.W	D1	CLR.W	D7	CLR.W	D220$:	CALL	IPPOS		; D3/D4 <-- position/dimensions	ADD.W	D3,#IPWDOX	SWAP.W	D3	ADD.W	D3,#IPWDOY	SWAP.W	D3	COMP.W	D0,D3	JUMP',LO 40$	ADD.W	D3,D4	COMP.W	D0,D3	JUMP',HS 40$	SWAP.W	D3	SWAP.W	D4	COMP.W	D1,D3	JUMP',LO 40$	ADD.W	D3,D4	COMP.W	D1,D3	JUMP',LO 90$40$:	INC.W	D2	COMP.W	D2,#256	JUMP,LO 20$	LOAD.W	D2,#-1	LOAD.W	D7,#190$:	POPM.L	D0,D1,D3,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; IPINV   >;--------/; Inverse un caractre.; in	D2.W	caractre (0..255,-1); out	-; mod	D7.WIPINV:	PUSHM.L	D2..D4	COMP.W	D2,#-1	JUMP',EQ 90$	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	CALL	IPPOS		; D3/D4 <-- position/dimensions	ADD.W	D3,#IPWDOX+1	SWAP.W	D3	ADD.W	D3,#IPWDOY+1	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRTRAME90$:	POPM.L	D2..D4	RET;--------\\; IPPOS   >;--------/; Donne la position et les dimensions d'un caractre.; in	D2.W	caractre (0..255); out	D3.L	position (y;x);	D4.L	dimensions (dy;dx); mod	D3.L, D4.L, D7.WIPPOS:	PUSHM.L	D1,D2	LOAD.L	D3,#H'10000*IPPOSY+(IPPOSX+(IPDIMX*(16+1)))	SUB.W	D2,#128	JUMP',NC 20$	ADD.W	D2,#128	LOAD.L	D3,#H'10000*IPPOSY+IPPOSX20$:	LOAD.W	D1,D2	AND.W	D1,#B'1111	MUL.WU	D1,#IPDIMX	ADD.W	D3,D1	LOAD.W	D1,D2	SR.W	D1,#4	MUL.WU	D1,#IPDIMY	SWAP.W	D3	ADD.W	D3,D1	SWAP.W	D3	LOAD.L	D4,#H'10000*IPDIMY+IPDIMX	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RETTDBOX_INSCAR:	.W	10$-TDBOX_INSCAR	.W	20$-TDBOX_INSCAR	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Choix du caractre  insrer :"	.B	ODBTABX,69	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" INSERE "	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBBOX,0,END,TDBNORM	.ASCIZ	"  ANNULE  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Insre"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_INSCAR:	.W	F1,F2,F3,CR,0		DOKF1-TKEY_INSCAR	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_INSCAR	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_INSCAR	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_INSCAR	.W	0;-----------\\; DBOXFRAPPE >;===========/; Dialogue pour la frappe.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXFRAPPE:	PUSHM.L	D0..D2,D4..D6,A0..A4	LOAD.L	A0,(A5)+OPDDIS	; A0 <-- ^descripteur fentre	CLR.L	D4		; D4 <-- fanions	LOAD.L	D3,(A5)+OFRMSK	AND.L	D3,#CCGCMSK	JUMP',EQ OPEN1$	TSET.L	D4:#0	LOAD.L	D3,(A5)+OFRCAR	AND.L	D3,#CCGCMSK;	SR.L	D3,#CCGCSHI	INC.B	D3		; D3 <-- +1  cause "ordinaire"	LOAD.W	(A5)+OFRSL1+OSLCYS,D3OPEN1$:	LOAD.L	D3,(A5)+OFRMSK	AND.L	D3,#CCSOMSK	JUMP',EQ OPEN2$	TSET.L	D4:#1	LOAD.L	D3,(A5)+OFRCAR	AND.L	D3,#CCSOMSK	SR.L	D3,#CCSOSHI	LOAD.W	(A5)+OFRSL2+OSLCYS,D3OPEN2$:	LOAD.L	D3,(A5)+OFRMSK	AND.L	D3,#CCEXMSK	JUMP',EQ OPEN3$	TSET.L	D4:#2	LOAD.L	D3,(A5)+OFRCAR	AND.L	D3,#CCEXMSK;	SR.L	D3,#CCEXSHI	SWAP.W	D3	LOAD.W	(A5)+OFRSL3+OSLCYS,D3OPEN3$:	LOAD.L	A2,#R16"TDBOX_FRAPPE	LOAD.W	D2,#2^BDBSAV	LOAD.W	D7,#DB_OPEN	PAGE_	DBOX		; ouvre la DBOX	JUMP,NE EXIT$	LOAD.L	A3,#(A5)+OCHMM	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D0,#IDENTCHAR	LOAD.W	D1,#opDGETMENU	PAGE_	OBJCALL		; OCHMM <-- construit le mmenu des caractresDRAW$:	CLR.W	D3DRAW1$:	CALL	DBFRLDRAW	; dessine une scroll-list	TEST.L	D4:D3		; fanion enclench ?	JUMP',BS DRAW2$		; oui => DRAW2$	CALL	DBFRLGREY	; grise la scroll-listDRAW2$:	INC.W	D3	COMP.W	D3,#3	JUMP,LO DRAW1$LOOP$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_FRAPPE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ ANNULE$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEY$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$KEY$:	TEST.L	D4:D3	JUMP',BS KEY4$	CALL	DBFRLGREY	; grise la scroll-list	JUMP	LOOP$KEY4$:	CALL	DBFRLDRAW	; dessine la scroll-list	JUMP	LOOP$CLIC$:	PUSH.L	D4	LOAD.L	D1,D4	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP',NE CLICBIP$	SUB.W	D4,(A0)+ODFFX	JUMP',LO CLICBIP$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	JUMP',LO CLICBIP$	SWAP.W	D4	TEST.L	D1:#0	JUMP',BC CLIC2$	PUSHM.L	A5,A6	LOAD.L	A6,A5		; A6 <-- ^variables !	LOAD.L	A5,#(A5)+OFRSL1	SCROLL_	LMOVE		; dplace scroll-list ...	POPM.L	A5,A6	JUMP',EQ CLICOK$CLIC2$:	TEST.L	D1:#1	JUMP',BC CLIC3$	PUSHM.L	A5,A6	LOAD.L	A6,A5		; A6 <-- ^variables !	LOAD.L	A5,#(A5)+OFRSL2	SCROLL_	LMOVE		; dplace scroll-list ...	POPM.L	A5,A6	JUMP',EQ CLICOK$CLIC3$:	TEST.L	D1:#2	JUMP',BC CLICBIP$	PUSHM.L	A5,A6	LOAD.L	A6,A5		; A6 <-- ^variables !	LOAD.L	A5,#(A5)+OFRSL3	SCROLL_	LMOVE		; dplace scroll-list ...	POPM.L	A5,A6	JUMP',EQ CLICOK$CLICBIP$:	POP.L	D4	JUMP	BIP$CLICOK$:	POP.L	D4	JUMP	LOOP$OK$:	PUSH.L	D3	CLR.L	(A5)+OFRMSK	CLR.L	(A5)+OFRCAR	CLR.W	D3	CALL	DBFRLGET	; D0/D1 <-- masque/caractre	OR.L	(A5)+OFRMSK,D0	OR.L	(A5)+OFRCAR,D1	INC.W	D3	CALL	DBFRLGET	; D0/D1 <-- masque/caractre	OR.L	(A5)+OFRMSK,D0	OR.L	(A5)+OFRCAR,D1	INC.W	D3	CALL	DBFRLGET	; D0/D1 <-- masque/caractre	OR.L	(A5)+OFRMSK,D0	OR.L	(A5)+OFRCAR,D1	INC.W	D3	CALL	DBFRLGET	; D0/D1 <-- masque/caractre	OR.L	(A5)+OFRMSK,D0	OR.L	(A5)+OFRCAR,D1	POP.L	D3ANNULE$:	LOAD.W	D7,#DB_CLOSE	PAGE_	DBOX		; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4..D6,A0..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBFRLDRAW >;----------/; Dessine une scroll-list.; in	D3.B	bit; out	-; mod	D7.WDBFRLDRAW:	PUSHM.L	D1..D4,A3,A4,A6	LOAD.B	D2,D3	LOAD.L	A3,#(A5)+OCHMM	; A3 <-- ^mmenu des caractres	LOAD.W	D1,#1		; D1 <-- dj 1  cause "ordinaire"30$:	TEST.B	(A3)	JUMP',EQ 34$	INC.W	D132$:	TEST.B	(A3+)	JUMP,NE 32$	JUMP	30$34$:	LOAD.L	A4,#(A5)+OFRSL1	LOAD.L	A3,#R16"DBFRLGPT1	DEC.B	D3	JUMP',NS 50$	LOAD.L	A4,#(A5)+OFRSL2	LOAD.L	A3,#R16"DBFRLGPT2	LOAD.W	D1,#4	DEC.B	D3	JUMP',NS 50$	LOAD.L	A4,#(A5)+OFRSL3	LOAD.L	A3,#R16"DBFRLGPT3	LOAD.W	D1,#350$:	AND.W	D2,#H'FF	TSET.L	D2:#BDBGCLABEL	DBOX_	GETCO	ADD.W	D3,#2	SWAP.W	D3	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,(A0)+ODFC2Y	SUB.W	D3,#4	SWAP.W	D3	LOAD.L	(A4)+OSLPOS,D3	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#15	LOAD.W	(A4)+OSLDIM+2,D4	LOAD.W	D4,(A0)+ODFCY	MUL.WU	D4,#5+1	LOAD.W	(A4)+OSLDIM+0,D4	EX.L	A4,A5	SCROLL_	LDRAW		; dessine la scroll-list vide	EX.L	A4,A5	LOAD.L	(A4)+OSLADL,A3	LOAD.W	(A4)+OSLCYN,D1	LOAD.L	A6,A5		; A6 <-- ^variables !	EX.L	A4,A5	SCROLL_	LUPDATE		; dessine le contenu de la scroll-list	EX.L	A4,A5	POPM.L	D1..D4,A3,A4,A6	RET;----------\\; DBFRLGPT1 >;----------/; Donne le texte contenu dans la scroll-list 1.; in	D3.W	rang; out	A3.L	^texte;	D3.W	0=rien, 1=ligne;	D7.W; mod	D3.L, D7.W, A3.LDBFRLGPT1:	DEC.W	D3	JUMP',NS DEF$	LOAD.L	A3,#(A6)+OCHMM	; A3 <-- ^mmenu des caractresLOOP$:	DEC.W	D3	JUMP',NS FOUND$NEXT$:	TEST.B	(A3+)		; A3 <-- ^titre suivant	JUMP,NE NEXT$	JUMP	LOOP$FOUND$:	INC.L	A3		; A3 <-- saute le premier espace	CLR.W	D3		; D3 <-- pas de ligne	JUMP'	EXIT$DEF$:	LOAD.L	A3,#R16"CDEF$	LOAD.W	D3,#1		; D3 <-- ligneEXIT$:	CLR.W	D7		; retour EQ/NE	RETCDEF$:	.ASCIZ	"Ordinaire"	.EVEN;----------\\; DBFRLGPT2 >;----------/; Donne le texte contenu dans la scroll-list 2.; in	D3.W	rang; out	A3.L	^texte;	D3.W	0=rien, 1=ligne;	D7.W; mod	D3.L, D7.W, A3.LDBFRLGPT2:	LOAD.L	A3,#R16"DBFRTSOUL	MUL.WU	D3,#12+2+8	ADD.L	A3,D3		; A3 <-- ^texte	CLR.W	D3		; D3 <-- pas de ligne	CLR.W	D7		; retour EQ/NE	RET;----------\\; DBFRLGPT3 >;----------/; Donne le texte contenu dans la scroll-list 3.; in	D3.W	rang; out	A3.L	^texte;	D3.W	0=rien, 1=ligne;	D7.W; mod	D3.L, D7.W, A3.LDBFRLGPT3:	LOAD.L	A3,#R16"DBFRTEXP	MUL.WU	D3,#12+2+8	ADD.L	A3,D3		; A3 <-- ^texte	CLR.W	D3		; D3 <-- pas de ligne	CLR.W	D7		; retour EQ/NE	RET;---------\\; DBFRLGET >;---------/; Donne le caractre et le masque d'une scroll-list.; in	D3.B	bit;	D4.L	fanions; out	D0.L	masque;	D1.L	caractre; mod	D0.L, D1.L, D7.WDBFRLGET:	PUSHM.L	D3,A3,A4	CLR.L	D0		; D0 <-- pas de masque	CLR.L	D1		; D1 <-- pas de caractre	TEST.L	D4:D3		; fanion enclench ?	JUMP,BC 90$		; non => 90$	LOAD.L	A4,#(A5)+OFRSL1	DEC.B	D3	JUMP',NS 40$	LOAD.L	A4,#(A5)+OFRSL2	LOAD.L	A3,#R16"DBFRTSOUL	DEC.B	D3	JUMP',NS 10$	LOAD.L	A4,#(A5)+OFRSL3	LOAD.L	A3,#R16"DBFRTEXP10$:				; mode =>	LOAD.W	D3,(A4)+OSLCYS	MUL.WU	D3,#12+2+8	ADD.L	A3,D3		; A3 <-- ^texte	LOAD.L	D0,(A3)+12+2+0	; D0 <-- masque	LOAD.L	D1,(A3)+12+2+4	; D1 <-- caractre	JUMP'	90$40$:				; caractre =>	LOAD.L	D0,#CCGCMSK	; D0 <-- masque;	CLR.L	D1	LOAD.W	D1,(A4)+OSLCYS	DEC.B	D1		; D1 <-- -1  cause "ordinaire";	SL.L	D1,#CCGCSHI	; D1 <-- caractre90$:	POPM.L	D3,A3,A4	RET;----------\\; DBFRLGREY >;----------/; Grise une scroll-list.; in	D3.B	bit; out	-; mod	D7.WDBFRLGREY:	PUSHM.L	D2..D4,A4	LOAD.L	A4,#(A5)+OFRSL1	DEC.B	D3	JUMP',NS 10$	LOAD.L	A4,#(A5)+OFRSL2	DEC.B	D3	JUMP',NS 10$	LOAD.L	A4,#(A5)+OFRSL310$:	LOAD.W	D3,(A4)+OSLCYS	; D3 <-- case slectionne	EX.L	A4,A5	SCROLL_	LINVCASE	; teint la case slectionne	EX.L	A4,A5	LOAD.L	D3,#H'55AA55AA	LOAD.L	D4,D3	LIB	?DRMDEF	LOAD.L	D3,(A4)+OSLPOS	LOAD.L	D4,(A4)+OSLDIM	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; grise la scroll-list	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	LOAD.L	D3,(A4)+OSLPOS	INC.W	D3	SWAP.W	D3	ADD.W	D3,#LGSCROLL	SWAP.W	D3	LOAD.L	D4,(A4)+OSLDIM	LOAD.W	D4,#LGSCROLL-2	SWAP.W	D4	SUB.W	D4,#LGSCROLL+LGSCROLL-1	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface l'ascenseur (sans les flches)	POPM.L	D2..D4,A4	RETTDBOX_FRAPPE:	.W	10$-TDBOX_FRAPPE	.W	20$-TDBOX_FRAPPE	.W	0,010$:	.B	ODBTABX,18*0	.B	ODBSQUARE,0!2^7,KEYDBOX/H'100,0	.ASCIZ	" caractre"	.B	ODBTABX,18*1	.B	ODBSQUARE,1!2^7,KEYDBOX/H'100,1	.ASCIZ	" soulign"	.B	ODBTABX,18*2	.B	ODBSQUARE,2!2^7,KEYDBOX/H'100,2	.ASCIZ	" exposant"	.B	ODBTABX,(18*3)-1	.B	ODBCR,ODBCR	.B	ODBTABX,18*0	.B	ODBLABEL,0	.B	ODBTEXT,0	.B	ODBTABX,18*1	.B	ODBLABEL,1	.B	ODBTEXT,0	.B	ODBTABX,18*2	.B	ODBLABEL,2	.B	ODBTEXT,0	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" FRAPPE "	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBBOX,0,END,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Frappe"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_FRAPPE:	.W	F1,F2,F3,0		DOKF1-TKEY_FRAPPE	.W	END,F0,F13,F14,F15,0	DOKF0-TKEY_FRAPPE	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_FRAPPE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_FRAPPE	.W	0;-----------\\; DBOXCHANGE >;===========/; Dialogue pour les recherches/substitutions.; in	D3.W	touche actionne; out	D3.W	dernire touche (DEFINE/F1/F4/F7/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXCHANGE:	PUSHM.L	D0..D2,D4..D6,A0..A4	LOAD.L	A0,(A5)+OPDDIS	; A0 <-- ^descripteur fentre	LOAD.W	D1,D3	LOAD.L	A2,#R16"TDBOX_CHANGE	LOAD.W	D2,#2^BDBSAV!2^BDBMAX	LOAD.L	D4,(A5)+OCHFAN	; D4 <-- fanions	TEST.L	D1:#BCHANGE+8	; actionn avec (CHANGE-DEFINE) ?	JUMP',BS OPEN2$		; oui => OPEN2$	AND.L	D4,#-1-(2^BCHCAR1!2^BCHMOD1!2^BCHCAR2!2^BCHMOD2)OPEN2$:	TEST.L	D4	JUMP',NE OPEN3$	LOAD.L	D4,#2^BCHAVOPEN3$:	LOAD.W	D7,#DB_OPEN	PAGE_	DBOX		; ouvre la DBOX	JUMP,NE EXIT$	PUSH.L	D4	LOAD.W	D2,#100!2^BDBGCLABEL	DBOX_	GETCO	SWAP.W	D3	SUB.W	D3,#4	SWAP.W	D3	CLR.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	LOAD.W	D2,#SETDOT	LIB	?DRSEG		; ligne horizontale	LOAD.L	D4,D3	CLR.W	D4	CLR.L	D3	LOAD.W	D3,(A0)+ODFFDX	SR.W	D3,#1	LIB	?DRSEG		; ligne verticale	POP.L	D4	TEST.L	D1:#BCHANGE+8	; actionn avec (CHANGE-DEFINE) ?	JUMP',BS OPEN5$		; oui => OPEN5$	CLR.B	(A5)+OCH1	; chane de recherche vide	CLR.B	(A5)+OCH2	; chane de substitution vide	CLR.W	(A5)+OCHSL1+OSLCYS	CLR.W	(A5)+OCHSL2+OSLCYS	CLR.W	(A5)+OCHSL3+OSLCYS	CLR.W	(A5)+OCHSL4+OSLCYSOPEN5$:	CLR.W	D2		; D2 <-- rang ligne en dition	TEST.L	D1:#BCHANGE+8	; actionn avec (CHANGE-DEFINE) ?	JUMP',BC DRAW$		; non => DRAW$	COMP.B	D1,#DEFINE+SHIFT ; mmenu "change" ?	JUMP',NE DRAW$		; non => DRAW$	INC.W	D2		; D2 <-- rang ligne en ditionDRAW$:	PUSH.W	D2	CLR.W	D2	LOAD.L	A3,#(A5)+OCH1	CALL	DBCHAFCH	; affiche la chane de recherche	INC.W	D2	LOAD.L	A3,#(A5)+OCH2	CALL	DBCHAFCH	; affiche la chane de substitution	POP.W	D2	PUSHM.L	A3,A4	LOAD.L	A3,#(A5)+OCHMM	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D0,#IDENTCHAR	LOAD.W	D1,#opDGETMENU	PAGE_	OBJCALL		; OCHMM <-- construit le mmenu des caractres	POPM.L	A3,A4	LOAD.W	D3,#BCHCAR1DRAW1$:	CALL	DBCHLDRAW	; dessine une scroll-list	TEST.L	D4:D3		; fanion enclench ?	JUMP',BS DRAW2$		; oui => DRAW2$	CALL	DBCHLGREY	; grise la scroll-listDRAW2$:	INC.W	D3	COMP.W	D3,#BCHCAR1+4	JUMP,LO DRAW1$LINE$:	LOAD.W	D3,D2	DBOX_	MEDIT	LOAD.L	A3,#(A5)+OCH1	; A3 <-- ^chane de recherche	TEST.W	D2	JUMP',EQ LINE2$	LOAD.L	A3,#(A5)+OCH2	; A3 <-- ^chane de substitutionLINE2$:	LOAD.L	A4,A3LINE4$:	TEST.B	(A4+)	JUMP,NE LINE4$	DEC.L	A4		; A4 <-- ^fin de la chaneLOOP$:	DBOX_	EDIT		; attend une action ...	LOAD.W	D7,#DB_ZEROCR	PAGE_	DBOX	LOAD.L	A1,#R16"TKEY_CHANGE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F4	JUMP,EQ OK$	COMP.W	D3,#F7	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ ANNULE$	COMP.W	D3,#CR	JUMP,EQ INSERT$	COMP.W	D3,#LF	JUMP,EQ INSERT$	COMP.W	D3,#TAB	JUMP,EQ INSERT$	COMP.W	D3,#CADRATIN	JUMP,EQ INSERT$	COMP.W	D3,#EOP	JUMP,EQ INSERT$	COMP.W	D3,#'*	JUMP,EQ INSERTJ$	COMP.W	D3,#'?	JUMP,EQ INSERTJ$	COMP.W	D3,#UNDO	JUMP,EQ UNDO$	COMP.W	D3,#DEFINE	JUMP,EQ DEFINE$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEY$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$INSERTJ$:	TSET.L	D4:#BCHJOKERINSERT$:	PUSH.L	A5	LOAD.L	A5,#(A5)+OBUDIS	TSET.L	D3:#7	LOAD.B	(A5),D3	CLR.B	(A5)+1	LOAD.W	D3,#MAXCH	LIB	?INSERT	POPM.L	A5	JUMP,NE BIP$	JUMP	LOOP$UNDO$:	LOAD.L	A3,#(A5)+OCH1	LOAD.L	A4,#(A5)+OCHL1UNDO1$:	LOAD.B	(A3+),(A4+)	; OCH1 <-- OCHL1	JUMP,NE UNDO1$	LOAD.L	A3,#(A5)+OCH2	LOAD.L	A4,#(A5)+OCHL2UNDO2$:	LOAD.B	(A3+),(A4+)	; OCH2 <-- OCHL2	JUMP,NE UNDO2$	LOAD.W	(A5)+OCHSL1+OSLCYS,(A5)+OCHCS1	LOAD.W	(A5)+OCHSL2+OSLCYS,(A5)+OCHCS2	LOAD.W	(A5)+OCHSL3+OSLCYS,(A5)+OCHCS3	LOAD.W	(A5)+OCHSL4+OSLCYS,(A5)+OCHCS4	LOAD.L	D4,(A5)+OCHFAN	; D4 <-- fanions originaux	JUMP	DRAW$KEY$:	COMP.B	D3,#BCHCAR1	JUMP',HS KEY2$	CLR.W	D2	LOAD.B	D2,D3		; D2 <-- rang o l'on a cliqu	JUMP	LINE$KEY2$:	TEST.L	D4:D3	JUMP',BS KEY4$	CALL	DBCHLGREY	; grise la scroll-list	JUMP	LOOP$KEY4$:	CALL	DBCHLDRAW	; dessine la scroll-list	JUMP	LOOP$DEFINE$:	INC.W	D2		; D2 <-- rang suivant	COMP.W	D2,#2	JUMP,LO LINE$	JUMP	OK$CLIC$:	PUSH.L	D4	LOAD.L	D1,D4	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP',NE CLICBIP$	SUB.W	D4,(A0)+ODFFX	JUMP',LO CLICBIP$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	JUMP',LO CLICBIP$	SWAP.W	D4	TEST.L	D1:#BCHCAR1	JUMP',BC CLIC2$	PUSHM.L	A5,A6	LOAD.L	A6,A5		; A6 <-- ^variables !	LOAD.L	A5,#(A5)+OCHSL1	SCROLL_	LMOVE		; dplace scroll-list ...	POPM.L	A5,A6	JUMP',EQ CLICOK$CLIC2$:	TEST.L	D1:#BCHMOD1	JUMP',BC CLIC3$	PUSHM.L	A5,A6	LOAD.L	A6,A5		; A6 <-- ^variables !	LOAD.L	A5,#(A5)+OCHSL2	SCROLL_	LMOVE		; dplace scroll-list ...	POPM.L	A5,A6	JUMP',EQ CLICOK$CLIC3$:	TEST.L	D1:#BCHCAR2	JUMP',BC CLIC4$	PUSHM.L	A5,A6	LOAD.L	A6,A5		; A6 <-- ^variables !	LOAD.L	A5,#(A5)+OCHSL3	SCROLL_	LMOVE		; dplace scroll-list ...	POPM.L	A5,A6	JUMP',EQ CLICOK$CLIC4$:	TEST.L	D1:#BCHMOD2	JUMP',BC CLICBIP$	PUSHM.L	A5,A6	LOAD.L	A6,A5		; A6 <-- ^variables !	LOAD.L	A5,#(A5)+OCHSL4	SCROLL_	LMOVE		; dplace scroll-list ...	POPM.L	A5,A6	JUMP',EQ CLICOK$CLICBIP$:	POP.L	D4	JUMP	BIP$CLICOK$:	POP.L	D4	JUMP	LOOP$OK$:	PUSH.L	D3	CLR.L	(A5)+OCHM1	CLR.L	(A5)+OCHC1	LOAD.W	D3,#BCHCAR1	CALL	DBCHLGET	; D0/D1 <-- masque/caractre	OR.L	(A5)+OCHM1,D0	OR.L	(A5)+OCHC1,D1	LOAD.W	D3,#BCHMOD1	CALL	DBCHLGET	; D0/D1 <-- masque/caractre	OR.L	(A5)+OCHM1,D0	OR.L	(A5)+OCHC1,D1	CLR.L	(A5)+OCHM2	CLR.L	(A5)+OCHC2	LOAD.W	D3,#BCHCAR2	CALL	DBCHLGET	; D0/D1 <-- masque/caractre	OR.L	(A5)+OCHM2,D0	OR.L	(A5)+OCHC2,D1	LOAD.W	D3,#BCHMOD2	CALL	DBCHLGET	; D0/D1 <-- masque/caractre	OR.L	(A5)+OCHM2,D0	OR.L	(A5)+OCHC2,D1	LOAD.W	(A5)+OCHCS1,(A5)+OCHSL1+OSLCYS	LOAD.W	(A5)+OCHCS2,(A5)+OCHSL2+OSLCYS	LOAD.W	(A5)+OCHCS3,(A5)+OCHSL3+OSLCYS	LOAD.W	(A5)+OCHCS4,(A5)+OCHSL4+OSLCYS	LOAD.L	(A5)+OCHFAN,D4	LOAD.L	A3,#(A5)+OCH1	LOAD.L	A4,#(A5)+OCHL1OK1$:	TCLR.B	(A3):#7	LOAD.B	(A4+),(A3+)	; OCHL1 <-- OCH1	JUMP,NE OK1$	LOAD.L	A3,#(A5)+OCH2	LOAD.L	A4,#(A5)+OCHL2OK2$:	TCLR.B	(A3):#7	LOAD.B	(A4+),(A3+)	; OCHL2 <-- OCH2	JUMP,NE OK2$	POP.L	D3ANNULE$:	LOAD.W	D7,#DB_CLOSE	PAGE_	DBOX		; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4..D6,A0..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBCHLDRAW >;----------/; Dessine une scroll-list.; in	D3.B	bit; out	-; mod	D7.WDBCHLDRAW:	PUSHM.L	D2..D4,A3,A4,A6	LOAD.B	D2,D3	LOAD.L	A4,#(A5)+OCHSL1	COMP.B	D2,#BCHCAR1	JUMP',EQ 10$	LOAD.L	A4,#(A5)+OCHSL2	COMP.B	D2,#BCHMOD1	JUMP',EQ 10$	LOAD.L	A4,#(A5)+OCHSL3	COMP.B	D2,#BCHCAR2	JUMP',EQ 10$	LOAD.L	A4,#(A5)+OCHSL410$:	AND.W	D2,#H'FF	TSET.L	D2:#BDBGCLABEL	DBOX_	GETCO	ADD.W	D3,#2	SWAP.W	D3	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,(A0)+ODFC2Y	SUB.W	D3,#4	SWAP.W	D3	LOAD.L	(A4)+OSLPOS,D3	LOAD.W	D4,(A0)+ODFCX	MUL.WU	D4,#15	LOAD.W	(A4)+OSLDIM+2,D4	LOAD.W	D4,(A0)+ODFCY	MUL.WU	D4,#5+1	LOAD.W	(A4)+OSLDIM+0,D4	EX.L	A4,A5	SCROLL_	LDRAW		; dessine la scroll-list vide	EX.L	A4,A5	LOAD.L	A3,#R16"DBCHLGPT24	LOAD.W	D4,#4+3	COMP.B	D2,#BCHMOD1	JUMP',EQ 40$	COMP.B	D2,#BCHMOD2	JUMP',EQ 40$	LOAD.L	A3,#(A5)+OCHMM	; A3 <-- ^mmenu des caractres	LOAD.W	D4,#1		; D4 <-- dj 1  cause "ordinaire"30$:	TEST.B	(A3)	JUMP',EQ 34$	INC.W	D432$:	TEST.B	(A3+)	JUMP,NE 32$	JUMP	30$34$:	LOAD.L	A3,#R16"DBCHLGPT1340$:	LOAD.L	(A4)+OSLADL,A3	LOAD.W	(A4)+OSLCYN,D4	LOAD.L	A6,A5		; A6 <-- ^variables !	EX.L	A4,A5	SCROLL_	LUPDATE		; dessine le contenu de la scroll-list	EX.L	A4,A5	POPM.L	D2..D4,A3,A4,A6	RET;-----------\\; DBCHLGPT13 >;-----------/; Donne le texte contenu dans les scroll-list 1 et 3.; in	D3.W	rang; out	A3.L	^texte;	D3.W	0=rien, 1=ligne;	D7.W; mod	D3.L, D7.W, A3.LDBCHLGPT13:	DEC.W	D3	JUMP',NS DEF$	LOAD.L	A3,#(A6)+OCHMM	; A3 <-- ^mmenu des caractresLOOP$:	DEC.W	D3	JUMP',NS FOUND$NEXT$:	TEST.B	(A3+)		; A3 <-- ^titre suivant	JUMP,NE NEXT$	JUMP	LOOP$FOUND$:	INC.L	A3		; A3 <-- saute le premier espace	CLR.W	D3		; D3 <-- pas de ligne	JUMP'	EXIT$DEF$:	LOAD.L	A3,#R16"CDEF$	LOAD.W	D3,#1		; D3 <-- ligneEXIT$:	CLR.W	D7		; retour EQ/NE	RETCDEF$:	.ASCIZ	"Ordinaire"	.EVEN;-----------\\; DBCHLGPT24 >;-----------/; Donne le texte contenu dans les scroll-list 2 et 4.; in	D3.W	rang; out	A3.L	^texte;	D3.W	0=rien, 1=ligne;	D7.W; mod	D3.L, D7.W, A3.LDBCHLGPT24:	LOAD.L	A3,#R16"DBCHTMODE	MUL.WU	D3,#12+2+8	ADD.L	A3,D3		; A3 <-- ^texte	LOAD.W	D3,(A3)+12	; D3 <-- 0/1	CLR.W	D7		; retour EQ/NE	RET;---------\\; DBCHLGET >;---------/; Donne le caractre et le masque d'une scroll-list.; in	D3.B	bit;	D4.L	fanions; out	D0.L	masque;	D1.L	caractre; mod	D0.L, D1.L, D7.WDBCHLGET:	PUSHM.L	D3,A3,A4	CLR.L	D0		; D0 <-- pas de masque	CLR.L	D1		; D1 <-- pas de caractre	TEST.L	D4:D3		; fanion enclench ?	JUMP,BC 90$		; non => 90$	LOAD.L	A4,#(A5)+OCHSL1	COMP.B	D3,#BCHCAR1	JUMP',EQ 10$	LOAD.L	A4,#(A5)+OCHSL2	COMP.B	D3,#BCHMOD1	JUMP',EQ 10$	LOAD.L	A4,#(A5)+OCHSL3	COMP.B	D3,#BCHCAR2	JUMP',EQ 10$	LOAD.L	A4,#(A5)+OCHSL410$:	COMP.B	D3,#BCHMOD1	JUMP',EQ 40$	COMP.B	D3,#BCHMOD2	JUMP',EQ 40$				; caractre =>	LOAD.L	D0,#CCGCMSK	; D0 <-- masque;	CLR.L	D1	LOAD.W	D1,(A4)+OSLCYS	DEC.B	D1		; D1 <-- -1  cause "ordinaire";	SL.L	D1,#CCGCSHI	; D1 <-- caractre	JUMP'	90$40$:				; mode =>	LOAD.L	A3,#R16"DBCHTMODE	LOAD.W	D3,(A4)+OSLCYS	MUL.WU	D3,#12+2+8	ADD.L	A3,D3		; A3 <-- ^texte	LOAD.L	D0,(A3)+12+2+0	; D0 <-- masque	LOAD.L	D1,(A3)+12+2+4	; D1 <-- caractre90$:	POPM.L	D3,A3,A4	RET;----------\\; DBCHLGREY >;----------/; Grise une scroll-list.; in	D3.B	bit; out	-; mod	D7.WDBCHLGREY:	PUSHM.L	D2..D4,A4	LOAD.L	A4,#(A5)+OCHSL1	COMP.B	D3,#BCHCAR1	JUMP',EQ 10$	LOAD.L	A4,#(A5)+OCHSL2	COMP.B	D3,#BCHMOD1	JUMP',EQ 10$	LOAD.L	A4,#(A5)+OCHSL3	COMP.B	D3,#BCHCAR2	JUMP',EQ 10$	LOAD.L	A4,#(A5)+OCHSL410$:	LOAD.W	D3,(A4)+OSLCYS	; D3 <-- case slectionne	EX.L	A4,A5	SCROLL_	LINVCASE	; teint la case slectionne	EX.L	A4,A5	LOAD.L	D3,#H'55AA55AA	LOAD.L	D4,D3	LIB	?DRMDEF	LOAD.L	D3,(A4)+OSLPOS	LOAD.L	D4,(A4)+OSLDIM	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; grise la scroll-list	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	LOAD.L	D3,(A4)+OSLPOS	INC.W	D3	SWAP.W	D3	ADD.W	D3,#LGSCROLL	SWAP.W	D3	LOAD.L	D4,(A4)+OSLDIM	LOAD.W	D4,#LGSCROLL-2	SWAP.W	D4	SUB.W	D4,#LGSCROLL+LGSCROLL-1	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface l'ascenseur (sans les flches)	POPM.L	D2..D4,A4	RET;---------\\; DBCHAFCH >;---------/; Affiche un texte en dition.; in	D2.W	rang;	A3.L	^chane; out	-; mod	D7.WDBCHAFCH:	PUSHM.L	D2..D4,A0,A3,A4	LOAD.L	A0,(A5)+OPDDIS	; A0 <-- ^descripteur fentre	LOAD.L	A4,#(A5)+OBUDIS10$:	LOAD.B	D3,(A3+)	JUMP',EQ 12$	TCLR.L	D3:#7	LOAD.B	(A4+),D3	; OBUDIS <-- chane sans bits 2^7 !	JUMP	10$12$:	CLR.B	(A4)	LOAD.L	A3,#(A5)+OBUDIS	TSET.L	D2:#BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	; positionne le curseur au dbut	PUSH.W	D3	LOAD.B	D3,#AFTOUT	LIB	?AFCAR	POP.W	D3	SUB.W	D4,D3	AND.L	D4,#H'FFFF	DIV.WU	D4,(A0)+ODFCX	; D4 <-- nb de caractres  afficher	LOAD.L	A4,A3	LOAD.W	D3,#-120$:	INC.W	D3		; D3 <-- nb de caractres du nom	TEST.B	(A4+)	JUMP,NE 20$	COMP.W	D3,D4		; place pour tout afficher ?	JUMP',LS 50$		; oui => 50$				; non =>	LIB	?AFTIM		; affiche flche "<-" inverse	.B	AFINV,5,AFDIR,0	.EVEN	DEC.W	D4	SUB.W	D3,D4	ADD.W	A3,D3	LOAD.W	D3,D4	LIB	?STRING		; affiche la fin du nom	LIB	?AFSPACE	JUMP'	80$50$:	LIB	?STRING		; affiche le nom	SUB.W	D4,D3	JUMP',EQ 80$	LOAD.B	D3,#MSPACE	LIB	?AFCAR	LOAD.B	D3,D4	LIB	?AFCAR		; efface la fin80$:	LOAD.B	D3,#AFNORM	LIB	?AFCAR	POPM.L	D2..D4,A0,A3,A4	RETDBCHTMODE:DBFRTSOUL:	.ASCIZ	"Normal     "	.W	0	.L	CCSOMSK,(2^CCSOSHI)*0	.ASCIZ	"Soulign   "	.W	0	.L	CCSOMSK,(2^CCSOSHI)*1	.ASCIZ	"Biff      "	.W	0	.L	CCSOMSK,(2^CCSOSHI)*2	.ASCIZ	"Surlign   "	.W	1	.L	CCSOMSK,(2^CCSOSHI)*3DBFRTEXP:	.ASCIZ	"Normal     "	.W	0	.L	CCEXMSK,(2^CCEXSHI)*0	.ASCIZ	"Exposant   "	.W	0	.L	CCEXMSK,(2^CCEXSHI)*1	.ASCIZ	"Indice     "	.W	1	.L	CCEXMSK,(2^CCEXSHI)*2	.EVENTDBOX_CHANGE:	.W	10$-TDBOX_CHANGE	.W	20$-TDBOX_CHANGE	.W	0,010$:	.B	ODBCR	.B	ODBTABX,2	.B	ODBTEXT	.ASCIZ	" Cherche :"	.B	ODBTABX,2+23	.B	ODBBOX,0,'*,TDBNORM	.ASCIZ	" * "	.B	ODBBOX,0,'?,TDBNORM	.ASCIZ	" ? "	.B	ODBTABX,40	.B	ODBTEXT	.ASCIZ	" A changer par :"	.B	ODBTABX,77	.B	ODBCR,ODBCR	.B	ODBTABX,2	.B	ODBLABEL,0	.B	ODBXLINE,32,MAXCH,0,KEYDBOX/H'100,0,TDBOMBRE	.B	ODBTABX,40	.B	ODBLABEL,1	.B	ODBXLINE,32,MAXCH,0,KEYDBOX/H'100,1,TDBOMBRE	.B	ODBCR,ODBCR	.B	ODBTABX,2	.B	ODBSQUARE,BCHCAR1!2^7,KEYDBOX/H'100,BCHCAR1	.ASCIZ	" caractre"	.B	ODBTABX,2+18	.B	ODBSQUARE,BCHMOD1!2^7,KEYDBOX/H'100,BCHMOD1	.ASCIZ	" mode"	.B	ODBTABX,40	.B	ODBSQUARE,BCHCAR2!2^7,KEYDBOX/H'100,BCHCAR2	.ASCIZ	" caractre"	.B	ODBTABX,40+18	.B	ODBSQUARE,BCHMOD2!2^7,KEYDBOX/H'100,BCHMOD2	.ASCIZ	" mode"	.B	ODBCR,ODBCR	.B	ODBTABX,2	.B	ODBLABEL,BCHCAR1	.B	ODBTEXT,0	.B	ODBTABX,2+18	.B	ODBLABEL,BCHMOD1	.B	ODBTEXT,0	.B	ODBTABX,40	.B	ODBLABEL,BCHCAR2	.B	ODBTEXT,0	.B	ODBTABX,40+18	.B	ODBLABEL,BCHMOD2	.B	ODBTEXT,0	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBLABEL,100	.B	ODBTEXT,0	.B	ODBCR	.B	ODBTABX,2	.B	ODBLCIRCLE,BCHAR	.ASCIZ	" <11> en arrire"	.B	ODBTABX,19	.B	ODBSQUARE,BCHMIMA	.ASCIZ	" majuscules et minuscules"	.B	ODBTABX,49	.B	ODBSQUARE,BCHJOKER	.ASCIZ	" recherche avec jokers"	.B	ODBCR	.B	ODBTABX,2	.B	ODBLCIRCLE,BCHAV	.ASCIZ	" <9> en avant"	.B	ODBTABX,19	.B	ODBSQUARE,BCHMOT	.ASCIZ	" seulement les mots entiers"	.B	ODBCR	.B	ODBCR,ODBCR	.B	ODBTABX,2	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" CHERCHE "	.B	ODBBOX,0,F4,TDBMEV	.ASCIZ	" COMPTE "	.B	ODBBOX,0,F7,TDBMEV	.ASCIZ	" CHANGE "	.B	ODBBOX,0,END,TDBNORM	.ASCIZ	" ANNULE "	.B	ODBTABX,40+21	.B	ODBBOX,0,UNDO,TDBOMBRE	.ASCIZ	" PRECEDENT "	.B	ODBCR	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Cherche"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Compte"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Change"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_CHANGE:	.W	F1,F2,F3,0		DOKF1-TKEY_CHANGE	.W	F4,F5,F6,0		DOKF4-TKEY_CHANGE	.W	F7,F8,F9,0		DOKF7-TKEY_CHANGE	.W	END,F0,F13,F14,F15,0	DOKF0-TKEY_CHANGE	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_CHANGE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_CHANGE	.W	0;---------\\; DBOXSURE >;=========/; Demande "Etes-vous sr ? "; in	D3.W	touche;	D2.L	+/- nombre (remplace le # du texte); out	D7.W	rponse; mod	D7.WDBOXSURE:	COMP.L	D2,#+10	JUMP',GE DBOX$	COMP.L	D2,#-10	JUMP',LE DBOX$	CLR.W	D7	RETDBOX$:	PUSHM.L	D1..D5,A0..A4	LOAD.L	D1,D2		; D1 <-- nombre	LIB	?BUZZ		; signal qq chose de spcial	LOAD.L	A2,#R16"TDBOX_SURE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.W	D7,#DB_OPEN	PAGE_	DBOX		; ouvre la DBOX	JUMP,NE 90$	LOAD.L	A3,#R16"TABLE$	LIB	?MINMAJ10$:	TEST.W	(A3+)	JUMP',EQ 14$	COMP.W	D3,(A3)-2	JUMP',EQ 14$12$:	TEST.B	(A3+)	JUMP,NE 12$	LOAD.L	D2,A3	TEST.L	D2:#0	JUMP,BC 10$	INC.L	A3	JUMP	10$14$:	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LOAD.L	D2,D3	LOAD.L	A0,(A5)+OPDDIS	; A0 <-- ^descripteur de la fentre20$:	LOAD.L	D3,D2	LIB	?SETCURS	SWAP.W	D2	ADD.W	D2,(A0)+ODFCY	SWAP.W	D222$:	LOAD.B	D3,(A3+)	JUMP,EQ 50$	COMP.B	D3,#CR	JUMP,EQ 20$	COMP.B	D3,#'#	JUMP',EQ 26$	LIB	?AFCAR	JUMP	22$26$:	PUSH.W	D2	LOAD.L	D4,D1	JUMP',NC 27$	NEG.L	D427$:	LOAD.W	D3,#8	LOAD.W	D2,#2^BAFDCM!2^BAFDSP	LIB	?AFDEC	POP.W	D2	JUMP	22$50$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_SURE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	50$		; oui => 50$	CLR.W	D4		; D4 <-- rponse "oui"	COMP.W	D3,#F1	JUMP',EQ 80$	LOAD.W	D4,#ERKNO	; D4 <-- rponse "non"	COMP.W	D3,#F4	JUMP',EQ 80$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	50$80$:	LOAD.W	D7,#DB_CLOSE	PAGE_	DBOX		; ferme la DBOX	LOAD.W	D7,D4		; D7 <-- oui/non90$:	POPM.L	D1..D5,A0..A4	TEST.W	D7		; retour EQ/NE	RETTABLE$:	.W	H'100*(CURSOR!KILL)+'V	.ASCII	"Voulez-vous dtruire les # caractres<CR>"	.ASCIZ	"situs entre le curseur et la fin du texte ?"	.EVEN	.W	H'100*(CURSOR!KILL)+'T	.ASCII	"Voulez-vous dtruire les # caractres<CR>"	.ASCIZ	"situs entre le curseur et le dbut du texte ?"	.EVEN	.W	H'100*(PROGRA!CHANGE)+'V	.ASCII	"Voulez-vous convertir les # caractres<CR>"	.ASCIZ	"situs entre le curseur et la fin du texte ?"	.EVEN	.W	H'100*(PROGRA!CHANGE)+'T	.ASCII	"Voulez-vous convertir les # caractres<CR>"	.ASCIZ	"situs entre le curseur et le dbut du texte ?"	.EVEN	.W	0	.ASCIZ	"Etes-vous sr ?<CR>"	.EVEN	.W	0TDBOX_SURE:	.W	10$-TDBOX_SURE	.W	20$-TDBOX_SURE	.W	0,010$:	.B	ODBLABEL,1	.B	ODBTEXT	.ASCIZ	""	.B	ODBTABX,47	.B	ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBNORM	.ASCIZ	"   OUI   "	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBBOX,0,F4,TDBMEV	.ASCIZ	"   NON   "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Oui"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Non"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVENTKEY_SURE:	.W	'O,'Y,'J,'S,F1,F2,F3,0	DOKF1-TKEY_SURE	.W	'N,F4,F5,F6,0		DOKF4-TKEY_SURE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_SURE	.W	0;--------------\\; DBOXOCCURENCE >;==============/; Demande comment compter.; in	D4.L	nombre d'occurences; out	D7.W	erreur; mod	D7.WDBOXOCCURENCE:	PUSHM.L	D1..D5,A1..A4	LOAD.L	D1,D4	LOAD.L	A2,#R16"TDBOX_OCCURENCE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.W	D7,#DB_OPEN	PAGE_	DBOX		; ouvre la DBOX	JUMP,NE 90$	LOAD.W	D2,#1!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	D4,D1	LOAD.W	D3,#8	LOAD.W	D2,#2^BAFDCM!2^BAFDSP	LIB	?AFDEC20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_OCCURENCE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1	JUMP',EQ 80$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$80$:	LOAD.W	D7,#DB_CLOSE	PAGE_	DBOX		; ferme la DBOX90$:	POPM.L	D1..D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_OCCURENCE:	.W	10$-TDBOX_OCCURENCE	.W	20$-TDBOX_OCCURENCE	.W	0,010$:	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"Nombre d'occurences : "	.B	ODBLABEL,1	.B	ODBTEXT	.ASCIZ	"        "	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	"   VU   "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"vu"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVENTKEY_OCCURENCE:	.W	CR,F1,F2,F3,0		DOKF1-TKEY_OCCURENCE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_OCCURENCE	.W	0;------------\\; DBOXCHERCHE >;============/; Demande comment chercher.; in	-; out	D3.W	touche (F1/F13);	D7.W	erreur; mod	D3.L, D7.WDBOXCHERCHE:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_CHERCHE	LOAD.W	D2,#2^BDBSAV!2^BDBPOS	LOAD.W	D3,#6	CALL	DBCSPOS		; D3 <-- position	LOAD.W	D7,#DB_OPEN	PAGE_	DBOX		; ouvre la DBOX	JUMP,NE 90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_CHERCHE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1	JUMP',EQ 80$	COMP.W	D3,#F13	JUMP',EQ 80$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$80$:	LOAD.W	D7,#DB_CLOSE	PAGE_	DBOX		; ferme la DBOX90$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_CHERCHE:	.W	10$-TDBOX_CHERCHE	.W	20$-TDBOX_CHERCHE	.W	0,010$:	.B	ODBBOX,0,F1,TDBNORM	.ASCIZ	" SUIVANT "	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBBOX,0,F13,TDBMEV	.ASCIZ	"  STOP  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Suivant"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Stop"	.EVENTKEY_CHERCHE:	.W	CR,F1,F2,F3,0		DOKF1-TKEY_CHERCHE	.W	END,F13,F14,F15,0	DOKF13-TKEY_CHERCHE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_CHERCHE	.W	0;--------------\\; DBOXSUBSTITUE >;==============/; Demande comment chercher.; in	-; out	D3.W	touche (F1/F4/F7/F10/F13);	D7.W	erreur; mod	D3.L, D7.WDBOXSUBSTITUE:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_SUBSTITUE	LOAD.W	D2,#2^BDBSAV!2^BDBPOS	LOAD.W	D3,#10	CALL	DBCSPOS		; D3 <-- position	LOAD.W	D7,#DB_OPEN	PAGE_	DBOX		; ouvre la DBOX	JUMP,NE 90$20$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_SUBSTITUE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	20$		; oui => 20$	COMP.W	D3,#F1	JUMP',EQ 80$	COMP.W	D3,#F4	JUMP',EQ 80$	COMP.W	D3,#F7	JUMP',EQ 80$	COMP.W	D3,#F10	JUMP',EQ 80$	COMP.W	D3,#F13	JUMP',EQ 80$	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	20$80$:	LOAD.W	D7,#DB_CLOSE	PAGE_	DBOX		; ferme la DBOX90$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_SUBSTITUE:	.W	10$-TDBOX_SUBSTITUE	.W	20$-TDBOX_SUBSTITUE	.W	0,010$:	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" CHANGE "	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBBOX,0,F4,TDBNORM	.ASCIZ	" SUIVANT "	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBBOX,0,F7,TDBNORM	.ASCIZ	" PARTOUT "	.B	ODBTEXT	.ASCIZ	"     "	.B	ODBBOX,0,F10,TDBOMBRE	.ASCIZ	"   UN   "	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBBOX,0,F13,TDBOMBRE	.ASCIZ	"  STOP  "	.B	ODBCR,ODBCR;		 [ CHANGE ]    [ SUIVANT ]    [ PARTOUT ]      [   UN   ]    [  STOP  ]	.B	ODBTEXT	.ASCIZ	"Change puis   Cherche le     Change partout   Change puis   Stoppe sans"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"cherche le    suivant sans   d'un seul coup   stoppe        changer"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"suivant       changer"	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Change"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Suivant"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Partout"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Un"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Stop"	.EVENTKEY_SUBSTITUE:	.W	CR,F1,F2,F3,0		DOKF1-TKEY_SUBSTITUE	.W	UNDO,F4,F5,F6,0		DOKF4-TKEY_SUBSTITUE	.W	F7,F8,F9,0		DOKF7-TKEY_SUBSTITUE	.W	F10,F11,F12,0		DOKF10-TKEY_SUBSTITUE	.W	END,F13,F14,F15,0	DOKF13-TKEY_SUBSTITUE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_SUBSTITUE	.W	0;--------\\; DBCSPOS >;--------/; Calcule la position du centre de la dbox en fonction de la; position du curseur.; in	A5.L	^description zone;	D3.W	nombre de lignes de la dbox; out	D3.L	position pour centre dbox; mod	D3.L, D7.WDBCSPOS:	PUSHM.L	D2,D4,A0	LOAD.L	A0,(A5)+OPDDIS	; A0 <-- ^descripteur de la fentre	LOAD.W	D4,(A5)+OTXCP2+2	SUB.W	D4,(A5)+OTXCP1+2	ASR.W	D4,#1	ADD.W	D4,(A5)+OTXCP1+2	SWAP.W	D4	LOAD.W	D4,(A5)+OTXCP2+0	SUB.W	D4,(A5)+OTXCP1+0	ASR.W	D4,#1	ADD.W	D4,(A5)+OTXCP1+0	SWAP.W	D4		; D4 <-- centre du curseur [obj]	LOAD.W	D7,#MA_OBJSCR	PAGE_	MATH		; D4 <-- centre du curseur [scr]	SWAP.W	D4	LOAD.W	D2,(A0)+ODFC1Y	ADD.W	D2,(A0)+ODFC2Y	MUL.WU	D2,D3		; D2 <-- hauteur suppose de la dbox	COMP.W	D4,D2		; possible de mettre dbox au-dessus ?	JUMP',HS 20$		; oui => 20$	ADD.W	D4,D2	ADD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y20$:	SR.W	D2,#1	SUB.W	D4,D2	SWAP.W	D4	LOAD.L	D3,D4	POPM.L	D2,D4,A0	RET;------------\\; DBOXTXPREND >;============/; Edite un nom de fichier texte en entre (prend).; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXTXPREND:	PUSHM.L	D1,D2,D5,A2..A5	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX		; prpare l'ouverture de la DBOX	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IOTX	LOAD.L	A4,#R16"TEXTX	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_PREND	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1!2^BDBIOFULL	LOAD.W	D7,#DB_POS5	PAGE_	DBOX		; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX		; prpare la fermeture de la DBOX	POP.W	D7EXIT$:	POPM.L	D1,D2,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-------------\\; DBOXTXAJOUTE >;=============/; Edite un nom de fichier texte en entre (ajoute).; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXTXAJOUTE:	PUSHM.L	D1,D2,D5,A2..A5	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX		; prpare l'ouverture de la DBOX	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IOTX	LOAD.L	A4,#R16"TEXTX	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_AJOUTE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1!2^BDBIOFULL	LOAD.W	D7,#DB_POS5	PAGE_	DBOX		; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX		; prpare la fermeture de la DBOX	POP.W	D7EXIT$:	POPM.L	D1,D2,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBOXTXSAUVE >;============/; Edite un nom de fichier texte en sortie.; in	A3.L	^nom du fichier;	D4.L	fanions par dfaut; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXTXSAUVE:	PUSHM.L	D1,D2,D4,D5,A2..A5	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX		; prpare l'ouverture de la DBOX	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IOTX	LOAD.L	A4,#R16"TEXTX	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_EXTRAIT; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1!2^BDBIOFULL	LOAD.W	D7,#DB_POS5	PAGE_	DBOX		; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	LOAD.W	D2,D4		; D2 <-- nouveau mode (fanions)	PUSH.W	D7	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX		; prpare la fermeture de la DBOX	POP.W	D7EXIT$:	POPM.L	D1,D2,D4,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX_IOTX:	.ASCIZ	"PAGE"		; nom du logiciel	.ASCIZ	"Mtexte"	; [M,F] nom des lments manipuls	.ASCIZ	""		; [M,F] nom du contenant	.B	0TEXTX:	.ASCIZ	".TEXT"	.EVEN;-----------\\; DBOXDELETE >;===========/; Demande s'il faut dtruire un fichier.; in	A3.L	^nom du fichier; out	D3.W	'O/'N; mod	D7.WDBOXDELETE:	PUSH.L	D2	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX		; prpare l'ouverture de la DBOX	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX		; prpare la fermeture de la DBOX	POP.L	D2	RET;----------\\; DBOXERROR >;==========/; Affiche une erreur.; in	D7.W	erreur; out	-; mod	D7.WDBOXERROR:	PUSHM.L	D2,D3	PUSH.W	D7	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX		; prpare l'ouverture de la DBOX	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX		; prpare la fermeture de la DBOX	POPM.L	D2,D3	RET;--------\\; DOK...  >;========/DOKMGR:	LOAD.W	D3,#KEYMGR	RETDOKMGP:	LOAD.W	D3,#KEYMGP	RETDOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RETDOKF4:	LOAD.W	D3,#F4	RETDOKF7:	LOAD.W	D3,#F7	RETDOKF10:	LOAD.W	D3,#F10	RETDOKF13:	LOAD.W	D3,#F13	RET	.END