	.SBTTL	OPCHARABC.ASI;--------\\; AFFABC  >;========/; Affiche un caractre analytique, construit.; in	D4.L	fanions; out	-; mod	D7.WAFFABC:	PUSHM.L	D0..D4,A3,A4	LOAD.L	D3,D4	LIB	?AFTIM	.B	COLOROP,COLOROPPUSH,0	.EVEN	LOAD.L	D4,#H'10000*COLOR_PAFPAGE	LOAD.W	D4,(A5)+OCCAR+OCARCO	ADD.W	D4,#COLOR_PANOIR	LOAD.W	D7,#DR_COLORINIT	PAGE_	DRAW		; spcifie les couleurs	CALL	DISCLEAR	; efface l'emplacement	TEST.L	D3:#BFANAFF	; affiche ?	JUMP',BC EXIT$		; non => EXIT$	CLR.W	D4	LIB	?WAITMOUSE	; souris: met le sablier	LOAD.W	D3,(A5)+OSLVAR+OSLCYS	LOAD.W	D7,#xcLISTGETNL	XCAR_	LIST		; A3 <-- ^nom complet	JUMP',NE ERROR$	LOAD.W	D7,#xcLISTSRCNC	XCAR_	LIST		; D3/D4 <-- rang/"-fst"	JUMP',NE ERROR$	SR.L	D4,#8	LOAD.B	D1,D4		; D1 <-- style/chasse	SR.L	D4,#8	LOAD.B	D0,D4		; D0 <-- fonte	LOAD.W	D2,(A5)+OABCDIM+0	SUB.W	D2,#10		; D2 <-- taille	LOAD.L	D3,(A5)+OABCPOS	; D3 <-- position	LOAD.L	D4,(A5)+OABCDIM	; D4 <-- dimensions	XCAR_	SHOW		; affiche "Abc"	JUMP',EQ EXIT$ERROR$:	CALL	DISERROR	; affiche une grande croixEXIT$:	LIB	?AFTIM	.B	COLOROP,COLOROPPOP,0	.EVEN	LOAD.W	D4,#1	LIB	?WAITMOUSE	; souris: enlve le sablier	POPM.L	D0..D4,A3,A4	RET;---------\\; DISERROR >;---------/; Effiche une erreur dans l'emplacement pour le caractre.; in	-; out	-; mod	D7.WDISERROR:	PUSHM.L	D2..D4	LOAD.W	D2,#SETDOT	LOAD.L	D3,(A5)+OABCPOS	LOAD.L	D4,(A5)+OABCDIM	LIB	?DRSEG	LOAD.L	D3,(A5)+OABCPOS	ADD.W	D3,D4	DEC.W	D3	NEG.W	D4	LIB	?DRSEG	POPM.L	D2..D4	RET;---------\\; DISCLEAR >;---------/; Efface l'emplacement pour le caractre.; in	-; out	-; mod	D7.WDISCLEAR:	PUSHM.L	D2..D4	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	LOAD.L	D3,(A5)+OABCPOS	LOAD.L	D4,(A5)+OABCDIM	LOAD.W	D2,#CLRDOT	LIB	?DRMATRIX	; efface le dernier gencar	POPM.L	D2..D4	RET	.END