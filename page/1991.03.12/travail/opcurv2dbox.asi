	.SBTTL	OPCURV2DBOX.ASI;------------\\; DBOXTENSION >;============/; Choix de la tension.; in	A4.L	^objet; out	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXTENSION:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.L	A1,A4		; A1 <-- ^objet	LOAD.L	A2,#R16"TDBOX$	LOAD.W	D7,#DB_MEMPT	PAGE_	DBOX		; mj ^table dbox	LOAD.W	(A5)+ODBP1,(A1)+OOBTEN	LOAD.L	A2,#R16"TDBOX_TENSION	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.W	D7,#DB_OPEN	PAGE_	DBOX		; ouvre la DBOX	JUMP,NE EXIT$	CLR.W	D2	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_AFF	PAGE_	DBOX		; affiche le paramtre	LOAD.W	D7,#DB_MEDIT	PAGE_	DBOXLOOP$:	LOAD.W	D7,#MI_SCMO	PAGE_	MISC		; remet la souris	DBOX_	EDIT		; attend une action ...	LOAD.W	D7,#DB_ZEROCR	PAGE_	DBOX		; remplace <CR> par <0>	PUSH.L	A1	LOAD.L	A1,#R16"TKEY_TENSION	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	POP.L	A1	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP',EQ CLIC$	COMP.W	D3,#F1	JUMP',EQ OK$	COMP.W	D3,#F0	JUMP',EQ END$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#CLEAR	JUMP',EQ UNDO$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$CLIC$:	LOAD.W	D7,#DB_CLIC	PAGE_	DBOX	JUMP,NE BIP$	JUMP	LOOP$OK$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	LOAD.W	(A1)+OOBTEN,(A5)+ODBP1END$:	LOAD.W	D7,#DB_CLOSE	PAGE_	DBOX		; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	ODBP1,DBTYPN,0,100,5,2^BDBGCLABEL!100,0,3+2	.W	-1TDBOX_TENSION:	.W	10$-TDBOX_TENSION	.W	20$-TDBOX_TENSION	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Tension de la courbe "	.B	ODBLABEL,100	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"  0 = courbe dtendue"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"100 = courbe trs tendue"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_TENSION:	.W	F1,F2,F3,0		DOKF1-TKEY_TENSION	.W	F0,F13,F14,F15,0	DOKF0-TKEY_TENSION	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_TENSION	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_TENSION	.W	0;--------\\; DOK...  >;========/DOKMGR:	LOAD.W	D3,#KEYMGR	RETDOKMGP:	LOAD.W	D3,#KEYMGP	RETDOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RET	.END