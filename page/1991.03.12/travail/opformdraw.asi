	.CHAP	OPFORMDRAW.ASI;	----------------------------------------;		(C) 1990 - Pierre Arnaud;	----------------------------------------;	Source de la gestion du dessin des symboles dfinissant les;	formules de l'objet "formule" de PAGE.;	INITGENC,	initialise les gnrateurs de caractres. Il faut faire cet;			appel avant XopDRAW et aprs xxxICOMOD ou MODSTATE.;	GETPGC,		rend le ^gc bitmap ncessaire  DR_CHARQ.;	Date      Rv	Commentaire;	-------------------------------------------------------------------------------;	28/03/90  0.0	Dbut des travaux;	-------------------------------------------------------------------------------;--------------\\;  DRAWFORMULE  >;==============/; Dessine le contenu d'une formule. Passe en revue tous les lments contenus; et affiche-les un  un..; in	A5.32	^variables locales;	A4.32	^instance;	D1.32	mode demand par PAGE;	D2.16	SETDOT/CLRDOT; out	D7.16	erreur; mod	D7.16DRAWFORMULE:	PUSHM.32 D1|D2|D3|D4|D6|A0|A1|A3	TEST.16	{A4}+OOBINIPG	JUMP,NE	R8^PGOK$	CALL	SYMBREDOPG			; reprend de nouvelles valeursPGOK$:	MOVE.32	{A4}+OOBP3,D3	SUB.32	{A4}+OOBP1,D3	MOVE.32	D3,{A4}+OOBxP3	CLR.16	D7	MOVE.32	{A5}+ODRINST,D6	COMP.32	A4,D6	JUMP,EQ	R8^OKSIZ$	CALL	INITGENC	CALL	SYMBREDOPGOKSIZ$:	MOVE.32	A4,{A5}+ODRINST			; instance en cours de dessin	MOVE.16	D2,{A5}+ODRMODE			; mode de dessin	MOVE.32	D1,{A5}+ODRRMODE	COMP.32	#2,{A4}+OOBTXTUSE		; taille utilise = rien ?	JUMP,NE	R8^DRAW$			; qqch => dessine	TEST.32	D1:#BVUEPROV			; provisoire ?	JUMP,BC	R8^NIL$				; oui => on n'affiche pas le cadre !	TEST.32	D1:#BVUEPROVI	JUMP,BS	R8^DRAW$	JUMP	END$NIL$:	CALL	DRAWNIL				; dessine "rien"	JUMP	ERR$DRAW$:	CLR.16	{A5}+ODRIMBRIC			; niveau d'imbrication nul	TEST.32	{A4}+OOBH1			; taille initialise	JUMP,NE	R8^OK1$	CALL	CALCSIZE			; calcule la taille de la formule	MOVE.32	D3,{A4}+OOBH1OK1$:	CLR.16	{A5}+ODRPOS+2			; [x] position = 0	MOVE.16	{A4}+OOBH1,{A5}+ODRPOS+0	; [y] position = ligne de base	MOVE.32	{A4}+OOBPTXT,A3			; A3 <- ^buffer du "texte"	CLR.32	{A5}+OTXCURS			; curseur en dbut de "texte"	CLR.16	{A5}+OTXOK			; pas encore trouv ce qu'il fallait	MOVE.16	#doDRAW,D6			; D6 <- dessine !DO$:	TEST.16	{A3}	JUMP,EQ	END$	CALL	DRAWELEM			; dessine juste un lment	JUMP,EQ	R8^DO$	REGS	"Erreur fatale dans DRAWFORMULE"END$:	MOVE.32	A5,A0	CALL	XopGETBBOX	MOVE.32	#DR_BMBBOX,D7	PAGE_	DRAW				; fixe le BBOX de la formule	MOVE.32	#DR_BMUPDALL,D7	PAGE_	DRAW				; dessine tout le bitmap !	CLR.16	D7ERR$:	POPM.32	D1|D2|D3|D4|D6|A0|A1|A3	TEST.16	D7	RET;--------------\\;  DRAWINITPEN  >;==============/; Initialise le pinceau; in	D2.16	mode de dessin par dfaut;	A4.32	^instance;	A5.32	^var locales; out	D2.16	modifi;	D7.16; mod	D2.16, D7.32DRAWINITPEN:	PUSHM.32 D0|D1|D3|A3|A4	MOVE.32	A4,A3	MOVE.16	{A3}+OOBPEN,D3	MOVE.32	#0,A4	MOVE.32	#IDENTPEN,D0	MOVE.32	#opDUSE,D1	PAGE_	OBJCALLERR$:	POPM.32	D0|D1|D3|A3|A4	RET;----------------\\;  DRAWINITTRAME  >;================/; Initialise la trame; in	D2.16	mode de dessin par dfaut;	A4.32	^instance;	A5.32	^var locales; out	D2.16	modifi;	D7.16; mod	D2.16, D7.32DRAWINITTRAME:	PUSHM.32 D0|D1|D3|A3|A4	MOVE.32	A4,A3	MOVE.16	{A3}+OOBTRA,D3	MOVE.32	#0,A4	MOVE.32	#IDENTTRAME,D0	MOVE.32	#opDUSE,D1	PAGE_	OBJCALLERR$:	POPM.32	D0|D1|D3|A3|A4	TEST.16	D7	RET;-----------\\;  CALCSIZE  >;===========/; Calcule la taille totale de la formule => {A4}+OOBH1/H2; in	A4.32	^instance;	A5.32	^variables; out	D3.32	[h1;h2] total;	D7.16; mod	D3.32, D7.16CALCSIZE:	PUSHM.32 D6|A3|A4	PUSH.16	{A5}+ODRIMBRIC	PUSH.32	{A5}+ODRPOS	PUSH.32	{A5}+OTXSIZE	PUSH.32	{A5}+OTXCURS	PUSH.16	{A5}+OTXOK	CLR.16	{A5}+ODRIMBRIC			; niveau d'imbrication nul	MOVE.32	{A4}+OOBPTXT,A3			; A3 <- ^buffer du "texte";;	MOVE.16	{A4}+OOBDEFCHAR,D3	MOVE.16	#16,D3	CALL	GETFONTH1H2	CLR.32	{A5}+OTXCURS			; curseur en dbut de "texte"	CLR.16	{A5}+OTXOK			; pas encore trouv ce qu'il fallait	MOVE.16	#doGETSIZE,D6			; D6 <- cherche la taille !DO$:	TEST.16	{A3}	JUMP,EQ	END$	CALL	DRAWELEM			; dessine juste un lment	JUMP,NE	R8^ERR$	COMP.16	{A5}+OTXSIZE+2,D3		; cherche h2	JUMP,GT	R8^OKH2$	MOVE.16	{A5}+OTXSIZE+2,D3OKH2$:	SWAP.32	D3	COMP.16	{A5}+OTXSIZE+0,D3		; cherche h1	JUMP,GT	R8^OKH1$	MOVE.16	{A5}+OTXSIZE+0,D3OKH1$:	SWAP.32	D3	JUMP	R8^DO$END$:	CLR.16	D7				; D7 <- ok	MOVE.16	D3,D6	SWAP.32	D3	ADD.16	D3,D6	COMP.16	{A4}+OOBxP3+0,D6	JUMP,LE	R8^OKY$	MOVE.16	D6,{A4}+OOBxP3+0OKY$:	SWAP.32	D3ERR$:	POP.16	{A5}+OTXOK	POP.32	{A5}+OTXCURS	POP.32	{A5}+OTXSIZE	POP.32	{A5}+ODRPOS	POP.16	{A5}+ODRIMBRIC	POPM.32	D6|A3|A4	TEST.16	D7	RET;---------------\\;  CALCSIZECURS  >;===============/; Calcule la taille du curseur; in	A4.32	^instance;	D4.32	position du curseur [y;x]; out	D3.32	position [y;x] dbut;	D4.32	position [y;x] fin;	D7.16	erreur; mod	D3.32, D4.32, D7.16CALCSIZECURS:	PUSHM.32 D2	MOVE.16	{A5}+OTXIMBRIC,{A5}+ODRIMBRIC;;	MOVE.16	{A4}+OOBDEFCHAR,D3	MOVE.16	#16,D3	CALL	GETFONTH1H2	JUMP,NE	R8^ERR$	MOVE.32	D3,D2	SWAP.32	D4	MOVE.32	D4,D3	ADD.16	D2,D4	SWAP.32	D2	SUB.16	D2,D3	SWAP.32	D4	SWAP.32	D3ERR$:	CLR.16	{A5}+ODRIMBRIC	POPM.32	D2	TEST.16	D7	RET;--------------\\;  CALCPOSCURS  >;==============/; Cherche la position [y;x] du curseur en fonction de sa position dans le texte.; in	A4.32	^instance;	A5.32	^variables; out	D4.32	[y;x] du curseur;	D7.16; mod	D3.32, D7.16CALCPOSCURS:	PUSHM.32 D3|D6|A3	PUSH.16	{A5}+ODRIMBRIC	PUSH.32	{A5}+ODRPOS	PUSH.32	{A5}+OTXSIZE	PUSH.32	{A5}+OTXCURS	PUSH.16	{A5}+OTXOK	CLR.16	{A5}+ODRIMBRIC			; niveau d'imbrication nul	TEST.32	{A4}+OOBH1			; taille initialise	JUMP,NE	R8^OK1$	CALL	CALCSIZE			; calcule la taille de la formule	MOVE.32	D3,{A4}+OOBH1OK1$:	CLR.16	{A5}+ODRPOS+2			; [x] position = 0	MOVE.16	{A4}+OOBH1,{A5}+ODRPOS+0	; [y] position = ligne de base	TEST.32	{A4}+OOBPOC			; curseur au dbut ?	JUMP,EQ	R8^END$				; oui => c'est dj bon !	MOVE.32	{A4}+OOBPTXT,A3			; A3 <- ^buffer du "texte"	CLR.32	{A5}+OTXCURS			; curseur en dbut de "texte"	CLR.16	{A5}+OTXOK			; pas encore trouv ce qu'il fallait	MOVE.16	#doGETPOS,D6			; D6 <- cherche la position du curseur  l'cranDO$:	TEST.16	{A3}	JUMP,EQ	END$	CALL	DRAWELEM			; dessine juste un lment	JUMP,NE	R8^ERR$	TEST.16	{A5}+OTXOK	JUMP,EQ	R8^DO$END$:	MOVE.32	{A5}+ODRPOS,D4			; position	CALL	TRANSF1toDRAW			; D4 <- position relle [obj]	CLR.16	D7ERR$:	POP.16	{A5}+OTXOK	POP.32	{A5}+OTXCURS	POP.32	{A5}+OTXSIZE	POP.32	{A5}+ODRPOS	POP.16	{A5}+ODRIMBRIC	POPM.32	D3|D6|A3	TEST.16	D7	RET;-------------\\;  GETPOSZONE  >;=============/; Cherche les positions de dpart/fin d'une zone.; in	D4.32	[y;x] de la souris; out	D4.32	"poc" dans le texte (position du curseur); mod	D4.32, D7.16GETPOSZONE:	PUSH.32	{A4}+OOBPOC	CALL	GETMOUSECURS			; cherche la position du curseur	JUMP,NE	R8^ERR$	MOVE.32	{A4}+OOBPOC,D4			; position du "curseur" dans le texteERR$:	POP.32	{A4}+OOBPOC	TEST.16	D7	RET;---------------\\;  GETMOUSECURS  >;===============/; Cherche la position de la souris dans le buffer de texte.; in	D4.32	[y;x] de la souris;	A4.32	^instance; out	{A4}+OOBPOC initialis;	D7.16	erreur; mod	D7.16GETMOUSECURS:	PUSHM.32 D3|D6|A3	PUSH.16	{A5}+ODRIMBRIC	PUSH.32	{A5}+ODRPOS	PUSH.32	{A5}+OTXSIZE	PUSH.32	{A5}+OTXCURS	PUSH.16	{A5}+OTXOK	CLR.16	{A5}+ODRIMBRIC			; niveau d'imbrication nul	TEST.32	{A4}+OOBH1			; taille initialise	JUMP,NE	R8^OK1$	CALL	CALCSIZE			; calcule la taille de la formule	MOVE.32	D3,{A4}+OOBH1OK1$:	CLR.16	{A5}+ODRPOS+2			; [x] position = 0	MOVE.16	{A4}+OOBH1,{A5}+ODRPOS+0	; [y] position = ligne de base	MOVE.32	{A4}+OOBPTXT,A3			; A3 <- ^buffer du "texte"	CLR.32	{A5}+OTXCURS			; curseur en dbut de "texte"	CLR.16	{A5}+OTXOK			; pas encore trouv ce qu'il fallait	MOVE.16	#doGETCURS,D6			; D6 <- cherche la position du curseur  l'cran	CALL	TRANSF1toOBJ			; D4 <- position par rapport  l'objet	JUMP,NE	R8^ERR$	MOVE.32	D4,{A5}+OTXPOS			; mmorise position  analyserDO$:	TEST.16	{A3}	JUMP,EQ	END$	CALL	DRAWELEM			; dessine juste un lment	JUMP,NE	R8^ERR$	TEST.16	{A5}+OTXOK	JUMP,EQ	R8^DO$	MOVE.32	{A5}+OTXCURS,{A4}+OOBPOC	CLR.16	D7	JUMP	R8^ERR$END$:	MOVE.16	#1,D7ERR$:	POP.16	{A5}+OTXOK	POP.32	{A5}+OTXCURS	POP.32	{A5}+OTXSIZE	POP.32	{A5}+ODRPOS	POP.16	{A5}+ODRIMBRIC	POPM.32	D3|D6|A3	TEST.16	D7	RET;-----------\\;  DRAWELEM  >;===========/; Dessine un lment unique dcrit par A3.32. Cet appel peut tre rcursif.; in	D6.16	type d'opration (doDRAW/doGETCURS/doGETSIZE/doGETPOS);	A3.32	^description de la formule;	A4.32	^instance de l'objet;	A5.32	^variables locales; out	A3.32	^plus loin;	D7.16	erreur fatale; mod	A3.32, D7.16DRAWELEM:	PUSHM.32 D0|D1REDO$:	CLR.16	D7	CLR.32	D1	MOVE.8	{A3},D1				; code gnral	MOVE.16	{A3+},D0			; code entier	ADD.32	#2,{A5}+OTXCURS			; position suivante	COMP.16	#CR,D0				; sparateur qui n'a rien  faire ici ?	JUMP,EQ	CR$	COMP.8	#tfCHFONTMAX,D1			; fonte de caractre ?	JUMP,LE	CHAR$				; caractre  afficher	COMP.8	#tfSYMBBEGIN,D1			; dbut de symbole ?	JUMP,EQ	SYMB$	MOVE.16	#1,D7	JUMP	ERR$CR$:	SUB.A16	#2,A3				; A3 ^sur le <CR>	SUB.32	#2,{A5}+OTXCURS			; position du curseur juste avant le <CR>	PUSH.32	D4	PUSH.32	{A4}+OOBPOC	MOVE.32	A3,D4	SUB.32	{A4}+OOBPTXT,D4			; D4 <- offset du curseur	MOVE.32	D4,{A4}+OOBPOC			; position pour effacer juste un !	MOVE.32	#2,D4	CALL	TXTDEL				; efface juste le <CR> du buffer	CLR.16	{A4}+OOBINIPG	POP.32	{A4}+OOBPOC	POP.32	D4	JUMP	REDO$CHAR$:	CALL	DRAWCHAR			; affiche le caractre	JUMP	ERR$SYMB$:	SUB.32	#2,A3	COMP.16	#doDRAW,D6	JUMP,EQ	R8^SYDR$	COMP.16	#doGETSIZE,D6	JUMP,EQ	R8^SYSIZ$	CALL	SYMBDRAW	JUMP	ERR$SYDR$:	CALL	SYMBDRAW	JUMP	R8^ERR$SYSIZ$:	PUSHM.32 D3|D4	CALL	SYMBGETSIZE	MOVE.32	D3,{A5}+OTXSIZE	POPM.32	D3|D4;	JUMP	R8^ERR$ERR$:	POPM.32	D0|D1	TEST.16	D7	RET;;-----------\\;  DRAWCHAR  >;===========/; Dessine un caractre unique.; in	D0.8	caractre;	D1.32	fonte;	A4.32	^instance de l'objet;	D6.16	type d'opration (doDRAW/doGETCURS/doGETSIZE/doGETPOS);	A5.32	^variables locales; out	D7.16	erreur; mod	D7.16DRAWCHAR:	PUSHM.32 D0|D1|D2|D3|D4|A0|A1|A3|A4	MOVE.16	D1,D3				; D3 <-  fonte	COMP.16	#doGETSIZE,D6			; demande la taille ?	JUMP,NE	R8^noSIZE$			; non => suite	CALL	GETPCHASSE			; cherche le ^chasse	CLR.16	D3	MOVE.8	D0,D3				; caractre	CALL	GETCARH1H2			; D3 <- [h1;h2]	MOVE.32	D3,{A5}+OTXSIZE			; mmorise et ok !	JUMP	OK$noSIZE$:	CALL	GETPGC				; A4 <- ^gc bitmap	JUMP,NE	ERR$	CLR.32	D3	MOVE.8	D0,D3				; D3 <- caractre	MOVE.32	{A5}+ODRPOS,D4			; position d'affichage par rapport  P1;;	MOVE.32	A4,A4				; A4 <- ^gc	PUSH.32	A4	MOVE.32	{A5}+ODRINST,A4	CALL	TRANSF1toDRAW			; D4 <- coord.	POP.32	A4	MOVE.16	{A5}+ODRMODE,D2			; D2 <- mode de dessin;;	MOVE.16	D3,D3				; D3 <- caractre	COMP.16	#doDRAW,D6			; dessine ?	JUMP,NE	R8^noDRAW$	MOVE.32	#DR_CHARQ,D7	PAGE_	DRAW				; dessine le caractre	JUMP,NE	ERR$noDRAW$:	MOVE.32	{A5}+ODRPOS,D0			; position d'affichage par rapport  P1	PUSH.16	D3	MOVE.16	D1,D3				; D3 <- fonte	CALL	GETPCHASSE			; A4 <- ^chasse	POP.16	D3				; D3 <- code ASCII	CALL	GETCARLENGTH			; D4 <- [dx]	MOVE.16	D1,D3				; D3 <- fonte	MOVE.32	D0,D1				; D1 <- position avant	ADD.16	D4,D0				; D0 <- position aprs	TEST.8	{A5}+OTXDOINV			; inverse une zone ?	JUMP,EQ	noINVZONE$			; non =>suite	CALL	INVZONECAR			; inverse selon D3/D0/D1/A4noINVZONE$:	COMP.16	#doGETCURS,D6			; position cran -> curseur ?	JUMP,NE	noCURS$	COMP.16	{A5}+OTXPOS+2,D0		; aprs selon [x] ?	JUMP,LT	R8^noCURS$			; oui => trop loin	COMP.16	{A5}+OTXPOS+2,D1		; avant selon [x'] ?	JUMP,GT	R8^noCURS$			; oui => pas assez loin	SWAP.32	D1	CALL	GETFONTH1H2			; D3 <- taille [h1;h2] de la fonte	MOVE.16	D1,D2	ADD.16	D3,D2	COMP.16	{A5}+OTXPOS+0,D2		; en-dessous selon [y] ?	JUMP,LT	R8^noCURS$			; oui => trop bas	SWAP.32	D3	MOVE.16	D1,D2	SUB.16	D3,D2	COMP.16	{A5}+OTXPOS+0,D2		; en-dessus selon [y] ?	JUMP,GT	R8^noCURS$			; oui => trop haut	SWAP.32	D1	SR.16	#1,D4				; cherche D4/2 (demi-largeur)	ADD.16	D4,D1				; position [x]+1/2*[dx]	COMP.16	{A5}+OTXPOS+2,D1		;  gauche ?	JUMP,LT	R8^OK$				; non => ok !	SUB.32	#2,{A5}+OTXCURS			; oui => un car. avant !OK$:	MOVE.16	{A5}+ODRIMBRIC,{A5}+OTXIMBRIC	MOVE.16	{A5}+ODRIMBRIC,D0	MOVE.16	#1,{A5}+OTXOK			; ok !	JUMP	R8^END$noCURS$:	COMP.16	#doGETPOS,D6	JUMP,NE	R8^noP1$	MOVE.32	{A5}+OTXCURS,D1			; position actuellement affiche	MOVE.32	{A5}+ODRINST,A4	COMP.32	{A4}+OOBPOC,D1			; cherche position curseur "texte"	JUMP,GT	R8^OK$				; prend ancienne position si position dpassenoP1$:	MOVE.32	D0,{A5}+ODRPOS			; sauve position nouvelle	MOVE.32	D0,D4	MOVE.32	{A5}+ODRINST,A4			; ajuste la largeur	CALL	TRANSF1toDRAW	COMP.16	#doGETPOS,D6			; curseur -> position cran ?	JUMP,NE	R8^noPOS$			; non => suite	MOVE.32	{A5}+OTXCURS,D0			; position du curseur "cran"	MOVE.32	{A5}+ODRINST,A4	COMP.32	{A4}+OOBPOC,D0			; cherche position curseur "texte"	JUMP,EQ	R8^OK$				; gaux => ok (position en {A5}+ODRPOS)noPOS$:END$:	CLR.16	D7ERR$:	POPM.32	D0|D1|D2|D3|D4|A0|A1|A3|A4	TEST.16	D7	RET;-------------\\;  INVZONECAR  >;=============/; Inverse une zone.; in	A4.32	^chasse;	D0.32	position aprs;	D1.32	position avant;	D3.16	fonte; out	-; mod	D7.32INVZONECAR:	PUSHM.32 D1..D4|A0|A4	MOVE.32	{A5}+OTXCURS,D2	COMP.32	{A5}+OTXZO1,D2	JUMP,LE	R8^ERR$	COMP.32	{A5}+OTXZO2,D2	JUMP,GT	R8^ERR$				; ne fait que si dans zone	MOVE.32	D1,D4	CALL	GETFONTH1H2	JUMP,NE	R8^ERR$	MOVE.32	D3,D2	SWAP.32	D4	MOVE.32	D4,D3	ADD.16	D2,D4	SWAP.32	D2	SUB.16	D2,D3	SWAP.32	D4	SWAP.32	D3				; [y;x] avant/haut	MOVE.16	D0,D4				; [y;x] aprs/bas	MOVE.32	{A5}+ODRINST,A4			; ^instance	CALL	TRANSFtoDRAW	MOVE.32	{A5}+OPDDIS,A0	MOVE.32	#-1,{A0}+ODFTRA+0	MOVE.32	#-1,{A0}+ODFTRA+4	CLR.32	{A0}+ODFTPM	MOVE.16	#INVDOT,D2	MOVE.32	#DR_TRAME,D7	PAGE_	DRAWERR$:	POPM.32	D1..D4|A0|A4	RET;----------------\\;  DRAWPOLYCLOSE  >;================/; Ferme le polygone de remplissage + remplit !; in	A5.32	^var;	D6.16	dessine si doDRAW; out	-; mod	D7.16DRAWPOLYCLOSE:	PUSHM.32 D1|D2	COMP.16	#doDRAW,D6	JUMP,NE	R8^ERR$	MOVE.16	{A5}+ODRMODE,D2	MOVE.32	{A5}+ODRRMODE,D1		; mode rel de dessin	TSET.32	D1:#BVUETRAME;;;	JUMP,BC	R8^OK$	TCLR.32	D2:#BTTTDOT	CALL	DRAWINITTRAME			; prend la bonne trame	COMP.16	#-1,D2	JUMP,EQ	R8^ERR$OK$:	MOVE.32	#DR_POLYCLOSE,D7	PAGE_	DRAW				; dessine la surface polygonaleERR$:	POPM.32	D1|D2	TEST.16	D7	RET;---------------\\;  DRAWPOLYOPEN  >;===============/; Dbut du polygone de remplissage; in	A5.32	^var;	D6.16	dessine si doDRAW; out	-; mod	D7.16DRAWPOLYOPEN:	COMP.16	#doDRAW,D6	JUMP,NE	R8^ERR$	MOVE.32	#DR_POLYOPEN,D7	PAGE_	DRAW				; dessine la surface polygonaleERR$:	CLR.16	D7	RET;------------\\;  DRAWLIGNE  >;============/; Dessine une ligne (coord. rel. P1); in	A5.32	^var;	D3.32	[y;x] dpart;	D4.32	[y;x] arrive;	D6.16	dessine si doDRAW; out	-; mod	D7.16DRAWLIGNE:	PUSHM.32 D1|D2|D3|D4|A0|A4	COMP.16	#doDRAW,D6	JUMP,NE	R8^END$	MOVE.32	{A5}+ODRRMODE,D1		; mode rel de dessin	MOVE.32	D1,D2	MOVE.16	{A5}+ODRMODE,D2	TEST.32	D1:#BVUEPEN	JUMP,BC	R8^OK$	CALL	DRAWINITPEN	COMP.16	#-1,D2	JUMP,EQ	R8^END$OK$:	MOVE.32	{A5}+ODRINST,A4	CALL	TRANSFtoDRAW			; prt  l'affichage !	MOVE.32	#DR_LINE,D7	MOVE.32	{A5}+OPAGEDRAW,A0	CALL	{A0}				; PAGE_DRAWEND$:	POPM.32	D1|D2|D3|D4|A0|A4	CLR.16	D7	RET;---------------\\;  DRAWPOLYLINE  >;===============/; Dessine une ligne pour le remplissage (coord. rel. P1); in	A5.32	^var;	D3.32	[y;x] dpart;	D4.32	[y;x] arrive;	D6.16	dessine si doDRAW; out	-; mod	D7.16DRAWPOLYLINE:	PUSHM.32 D3|D4|A0|A4	COMP.16	#doDRAW,D6	JUMP,NE	R8^ERR$	MOVE.32	{A5}+ODRINST,A4	CALL	TRANSFtoDRAW			; prt  l'affichage !	MOVE.32	#DR_POLYLINE,D7	MOVE.32	{A5}+OPAGEDRAW,A0	CALL	{A0}				; PAGE_DRAWERR$:	POPM.32	D3|D4|A0|A4	CLR.16	D7	RET;---------------\\;  TRANSFtoDRAW  >;===============/; Transforme les coordonnes relatives  la poigne P1 en tournant/dplaant; si ncessaire; in	A4.32	^instance de l'objet;	D3.32	A [y;x] de dpart;	D4.32	B [y;x] de dpart; out	D3.32	A [y;x] transform;	D4.32	B [y;x] transform; mod	D3.32, D4.32, D7.16TRANSFtoDRAW:	CALL	TRANSF1toDRAW	JUMP,NE	R8^ERR$	EX.32	D3,D4	CALL	TRANSF1toDRAW	EX.32	D3,D4ERR$:	TEST.16	D7	RET;--------------\\;  TRANSFtoOBJ  >;==============/; Transforme les coordonnes absolues en coordonnes relatives  la poigne; P1 en tournant/dplaant si ncessaire; in	A4.32	^instance de l'objet;	D3.32	A [y;x] absolu;	D4.32	B [y;x] absolu; out	D7.16	si <> 0, le point est hors normes !;	D3.32	A [y;x] relatif non tourn;	D4.32	B [y;x] relatif non tourn; mod	D3.32, D4.32, D7.16TRANSFtoOBJ:	PUSH.32 D1	MOVE.16	#1,D7				; D7 <- point hors normes	SUB.16	{A4}+OOBP1+2,D3	JUMP,CS	R8^ERR$	SUB.16	{A4}+OOBP1+2,D4	JUMP,CS	R8^ERR$	SWAP.32	D3	SWAP.32	D4	SUB.16	{A4}+OOBP1+0,D3	JUMP,CS	R8^ERR$	SUB.16	{A4}+OOBP1+0,D4	JUMP,CS	R8^ERR$	SWAP.32	D3	SWAP.32	D4	MOVE.16	{A4}+OOBA+0,D1	JUMP,EQ	R8^OK$	CALL	INVANGLE			; inverse la rotation	PUSH.32	D3	MOVE.32	{A4}+OOBP1,D3	LIB	?CALCPSYM	POP.32	D3				; A tourn	EX.32	D3,D4	PUSH.32	D3	MOVE.32	{A4}+OOBP1,D3	LIB	?CALCPSYM	POP.32	D3	EX.32	D3,D4				; B tournOK$:	CLR.16	D7ERR$:	POP.32	D1	TEST.16	D7	RET;----------------\\;  TRANSF1toDRAW  >;================/; Transforme les coordonnes relatives  la poigne P1 en tournant/dplaant; si ncessaire; in	A4.32	^instance de l'objet;	D4.32	[y;x] de dpart; out	D4.32	[y;x] transform; mod	D4.32, D7.16TRANSF1toDRAW:	PUSH.32 D1	PUSHM.32 D3|D4	MOVE.16	{A4}+OOBxP3+2,D3	COMP.16	D3,D4	JUMP,LE	R8^OKX$	MOVE.16	D4,D3OKX$:	MOVE.16	D3,{A4}+OOBxP3+2 		; nouveau [dx] chang !	POPM.32	D3|D4	MOVE.16	{A4}+OOBA+0,D1	JUMP,EQ	R8^OK$	PUSH.32	D3	MOVE.32	{A4}+OOBP1,D3	LIB	?CALCPSYM	POP.32	D3OK$:	ADD.32	{A4}+OOBP1,D4	CLR.16	D7ERR$:	POP.32	D1	TEST.16	D7	RET;---------------\\;  TRANSF1toOBJ  >;===============/; Transforme les coordonnes absolues en coordonnes relatives  la poigne; P1 en tournant/dplaant si ncessaire; in	A4.32	^instance de l'objet;	D4.32	[y;x] absolu; out	D7.16	si <> 0, le point est hors normes !;	D4.32	[y;x] relatif non tourn; mod	D3.32, D4.32, D7.16TRANSF1toOBJ:	PUSH.32 D1	MOVE.16	#1,D7				; D7 <- point hors normes	SUB.16	{A4}+OOBP1+2,D4	JUMP,CS	R8^ERR$	SWAP.32	D4	SUB.16	{A4}+OOBP1+0,D4	JUMP,CS	R8^ERR$	SWAP.32	D4	MOVE.16	{A4}+OOBA+0,D1	JUMP,EQ	R8^OK$	CALL	INVANGLE			; inverse la rotation	PUSH.32	D3	MOVE.32	{A4}+OOBP1,D3	LIB	?CALCPSYM	POP.32	D3OK$:	CLR.16	D7ERR$:	POP.32	D1	TEST.16	D7	RET;----------\\;  DRAWNIL  >;==========/; Dessine une formule ne contenant rien (nulle); in	A4.32	^instance;	A5.32	^var. locales;	D2.16	mode de dessin; out	D7.16	erreur; mod	D7.16DRAWNIL:	PUSHM.32 D3|D4	CALL	GETP1	MOVE.32	D4,D3				; D3 <-- P1	CALL	GETP2				; D4 <-- P2	CALL	DRLINE14	CALL	GETP4				; D4 <-- P4	CALL	DRLINE14	CALL	GETP2	MOVE.32	D4,D3				; D3 <-- P2	CALL	GETP1				; D4 <-- P1	CALL	DRLINE14	CALL	GETP3				; D4 <-- P3	CALL	DRLINE14	CALL	GETP3	MOVE.32	D4,D3				; D3 <-- P3	CALL	GETP2				; D4 <-- P2	CALL	DRLINE14	CALL	GETP4				; D4 <-- P4	CALL	DRLINE14	CALL	GETP4	MOVE.32	D4,D3				; D3 <-- P4	CALL	GETP1				; D4 <-- P1	CALL	DRLINE14	CALL	GETP3				; D4 <-- P3	CALL	DRLINE14	CALL	GETP1	MOVE.32	D4,D3				; D3 <-- P1	CALL	GETP3				; D4 <-- P3	MOVE.16	#DR_LINE,D7	PAGE_	DRAW	CALL	GETP2	MOVE.32	D4,D3				; D3 <-- P2	CALL	GETP4				; D4 <-- P4	MOVE.16	#DR_LINE,D7	PAGE_	DRAWEXIT$:	POPM.32	D3|D4	TEST.16	D7	RET;---------\\; DRLINE14 >;---------/; Trace un quart de ligne.; in	D3.32	origine (y;x);	D4.32	arrive (y;x); out	-; mod	D7.16DRLINE14:	PUSHM.32 D3|D4	SUB.16	D3,D4	ASR.16	#2,D4	ADD.16	D3,D4	SWAP.32	D3	SWAP.32	D4	SUB.16	D3,D4	ASR.16	#2,D4	ADD.16	D3,D4	SWAP.32	D3	SWAP.32	D4	MOVE.16	#DR_LINE,D7	PAGE_	DRAW	POPM.32	D3|D4	RET;------------\\;  CLONEDGBM  >;============/; Copie le descripteur de gencar bitmap pour s'en fabriquer un soi-mme.; in	D3.16	numro de la fonte  utiliser (16 => symboles);	A3.32	buffer de LDGBM octets (rcepteur); out	D7.16	erreur; mod	D7.16CLONEDGBM:	PUSHM.32 D4|A3|A4	MOVE.32	A3,A4				; A4 <- ^zone de rception	COMP.16	#16,D3				; fonte "symboles" ?	JUMP,NE	R8^DGBM$			; non => cherche les descripteurs genc. bitmap	GSYMBDESC A3				; A3 <-- ^^descripteur des symboles	MOVE.32	{A3},A3	JUMP	R8^COPY$			; demande une copieDGBM$:	CALL	GETDGBM				; A3 <- ^descripteur du gencar bitmap	JUMP,NE	R8^ERR$				; si erreur => ne fait rienCOPY$:	MOVE.32	#LDGBM,D4	CALL	FORCOPYMEM			; copie le descripteur de bitmap gencar	COMP.16	#16,D3				; pas les symboles ?	JUMP,NE	R8^ERR$				; non => rien de plus	MOVE.32	{A5}+ODRINST,A3	MOVE.16	{A3}+OOBSIZE,D4	MOVE.16	D4,{A4}+ODGBMCORPS		; mmorise la taille du corpsERR$:	POPM.32	D4|A3|A4	TEST.16	D7	RET;----------\\;  GETDGBM  >;==========/; Cherche le descripteur du gencar bitmap; in	D3.16	numro de la fonte  utiliser; out	A3.32	descripteur de gencar bitmap;	D7.16	erreur; mod	D7.16GETDGBM:	PUSHM.32 D0|D1|D3|D4|A2|A4	MOVE.32	#0,A4	MOVE.32	#IDENTCHAR,D0	MOVE.32	#opDGETDIM,D1	PAGE_	OBJCALL				; rend D3/D4/A2/A3/A4 selon fonteERR$:	POPM.32	D0|D1|D3|D4|A2|A4	TEST.16	D7	RET.IF 0;--------------\\;  CALCIMBRICR  >;==============/; Rduit une valeur relle selon l'imbrication actuelle; in	A5.32	^variables locales;	D4.32	valeur relle  rduire; out	D4.32	valeur rduite; mod	D4.32, D7.32CALCIMBRICR:	PUSHM.32 D0|D1|D2|A0	MOVE.16	{A5}+ODRIMBRIC,D0	JUMP,EQ	R8^ERR$	DEC.16	D0	COMP.16	#7,D0	JUMP,LE	R8^OK$	MOVE.16	#7,D0OK$:	MOVE.32	D4,D1	SL.16	#2,D0	MOVE.32	#R16^TABLE$,A0	MOVE.32	{A0}+A16^{D0},D2	MOVE.32	#MA_FIXDIV,D7	PAGE_	MATH	MOVE.32	D0,D4				; rsultatERR$:	POPM.32	D0|D1|D2|A0	RETTABLE$:	.16	1,16'4000			; / 1.25	16/20	.16	1,16'8000			; / 1.5		16/24	.16	1,16'F000			; / 1.9375	16/31	.16	2,16'8000			; / 2.5		16/40	.16	3,16'0000			; / 3		16/48	.16	3,16'D000			; / 3.8125	16/61	.16	4,16'C000			; / 4.75	16/76	.16	5,16'C000			; / 5.75	16/92.ENDIF;--------------\\;  CALCIMBRICI  >;==============/; Rduit une valeur entire selon l'imbrication actuelle; in	A5.32	^variables locales;	D4.16	valeur entire  rduire; out	D4.16	valeur rduite; mod	D4.32CALCIMBRICI:	PUSHM.32 D1|D2|D3|A4	MOVE.16	{A5}+ODRIMBRIC,D3	JUMP,EQ	R8^ERR$	DEC.16	D3	COMP.16	#7,D3	JUMP,LE	R8^OK$	MOVE.16	#7,D3OK$:	CLR.32	D1	MOVE.16	D4,D1	MOVE.32	{A5}+ODRINST,A4	MOVE.16	{A4}+OOBRED,D2			; facteur de rductionDO$:	MUL.A16	D2,D1	DIV.A16	#100,D1	DJ.16,NMO D3,DO$	MOVE.16	D1,D4ERR$:	POPM.32	D1|D2|D3|A4	RET.IF 0	PUSHM.32 D0|A0	MOVE.16	{A5}+ODRIMBRIC,D0	JUMP,EQ	R8^ERR$	DEC.16	D0	COMP.16	#7,D0	JUMP,LE	R8^OK$	MOVE.16	#7,D0OK$:	AND.32	#16'0000FFFF,D4	SL.32	#4,D4	SL.16	#1,D0	MOVE.32	#R16^TABLE$,A0	DIV.A16	{A0}+A16^{D0},D4		; x:=x*16/nERR$:	POPM.32	D0|A0	RETTABLE$:	.16	20				; / 1.25	16/20	.16	24				; / 1.5		16/24	.16	31				; / 1.9375	16/31	.16	40				; / 2.5		16/40	.16	48				; / 3		16/48	.16	61				; / 3.8125	16/61	.16	76				; / 4.75	16/76	.16	92				; / 5.75	16/92.ENDIF;;-----------\\;  INITGENC  >;===========/; Initialise les gnrateurs des fontes 0  16. On cherche les tailles par dfaut; et on clne les descripteurs des 16 fontes dfinies. Les ^gc sont tous remis ; zro.; in	A4.32	^instance d'objet;	A5.32	^variables locales; out	D7.16	erreur; mod	D7.16INITGENC:	PUSHM.32 D2|D3|A1..A3	MOVE.32	A4,{A5}+ODRINST	MOVE.16	#-1,{A5}+ODRLFONT	CLR.32	{A4}+OOBH1	.IF 0	GSYMBDESC A1	MOVE.32	{A1},A1				; A1 <- ^gencar symboles	.ELSE	MOVE.32	#{A5}+OFONTBUF+16*LDGBM,A1	; A1 <- ^gencar symboles	.ENDIF	MOVE.16	{A4}+OOBSIZE,D2	COMP.16	{A1}+ODGBMCORPS,D2		; taille de corps correcte ?	JUMP,EQ	R8^GO$	MOVE.32	A1,A3	MOVE.16	#16,D3	CALL	CLONEDGBM	MOVE.16	D2,{A1}+ODGBMCORPS;;	MOVE.16	{A3}+ODGBMCORPS,D2;;	COMP.16	{A1}+ODGBMCORPS,D2		; corps identiques ?;;	JUMP,EQ	R8^GO$				; oui => dbut des mises  zro;;;;	MOVE.16	{A3}+ODGBMCORPS,{A1}+ODGBMCORPS	; taille actuelle des symboles;;	MOVE.32	{A3}+ODGBMROTATE,{A1}+ODGBMROTATE ; rotation en degrs rels;;	MOVE.16	{A3}+ODGBMZOOMX,{A1}+ODGBMZOOMX	; zoom normal [x];;	MOVE.16	{A3}+ODGBMZOOMY,{A1}+ODGBMZOOMY	; zoom normal [y]	CALL	SFONTINIT			; initialise la fonte des symbolesGO$:	CLR.32	D2				; D2 <- <0> (plus rapide que CLR)	MOVE.32	#0,D3				; D3 <- compteur 0..16	MOVE.32	#{A5}+OFONTBUF,A3		; A3 <- ^buffers pour les fontes	MOVE.32	#{A5}+OFONTPGC,A2		; A2 <- ^buffer pour ^gc	MOVE.32	#{A5}+OFONTCORPS,A1		; A1 <- ^buffers pour le corps d'origineCLONE$:	MOVE.8	D2,{A3}				; par dfaut, pas de fonte	CALL	CLONEDGBM			; clone si existe	MOVE.16	{A3}+ODGBMCORPS,{A1+}		; {A1} <- copie la taille du corps d'origine	MOVE.32	D2,{A2+}			; {A2} <- pas de ^gc	ADD.A16	#LDGBM,A3			; {A3} <- copie du descripteur	INC.16	D3	COMP.16	#16+1,D3			; passe en revue les 16 fontes + 1 fonte de symboles	JUMP,LT	R8^CLONE$ERR$:	POPM.32	D2|D3|A1..A3	CLR.16	D7	RET;---------\\;  GETPGC  >;=========/; Rend le ^gc d'une fonte donne selon sa taille.; in	A5.32	^variables locales;	D3.16	fonte dsire; out	A4.32	^gc bitmap; mod	A4.32, D7.16GETPGC:	PUSHM.32 D1|D3|D4|A2|A3	SL.16	#1,D3				; offset  la taille	MOVE.16	{A5}+A16^{D3}+OFONTCORPS,D4	; taille de dpart	CALL	CALCIMBRICI			; taille  utiliser	SL.16	#1,D3	MOVE.32	#{A5}+OFONTPGC,A2	MOVE.32	#{A5}+OFONTBUF,A4	ADD.A16	D3,A2				; A2 <- ^pgc	MUL.16	#ldgbm/4,D3	ADD.A16	D3,A4				; A4 <- ^dgbm	COMP.16	{A4}+OdgbmCORPS,D4		; corps taille ok ?	JUMP,EQ	R8^GETPGC$			; oui => cherche le ^gc	MOVE.16	D4,{A4}+OdgbmCORPS		; nouvelle taille	CLR.32	{A2}				; pas de ^gc initialisGETPGC$:	TEST.32	{A2}	JUMP,NE	R8^OKPGC$	MOVE.32	{A5}+ODRINST,A3	MOVE.32	{A3}+OOBA,D1			; D1 <- angle de rotation	MOVE.32	#DR_GETPGC,D7	PAGE_	DRAW				; demande le ^gc pour cette taille	JUMP,NE	R8^ERR$	MOVE.32	A3,{A2}				; mmorise le ^gc bitmapOKPGC$:	MOVE.32	{A2},A4				; rend le ^gc bitmap	CLR.16	D7ERR$:	POPM.32	D1|D3|D4|A2|A3	TEST.16	D7	RET;-------------\\;  GETPCHASSE  >;=============/; Cherche le ^chasse; in	D3.16	numro de la fonte; out	A4.32	^table de chasse;	D7.16	erreur; mod	A4.32, D7.16GETPCHASSE:	PUSHM.32 D3|D4	CALL	EDGETDIM			; cherche A4/D3/D4ERR$:	POPM.32	D3|D4	TEST.16	D7	RET;--------------\\;  GETFONTH1H2  >;==============/; Demande les paramtres [h1;h2] de la fonte complte.; in	D3.16	numro de la fonte actuelle; out	D3.32	[h1;h2]; mod	D3.32, D7.16GETFONTH1H2:	PUSHM.32 D4|A4	CALL	EDGETDIM	JUMP,NE	R8^ERR$	MOVE.16	D3,D4	CALL	CALCIMBRICI	MOVE.16	D4,D3	SWAP.32	D3	MOVE.16	D3,D4	CALL	CALCIMBRICI	MOVE.16	D4,D3	SWAP.32	D3ERR$:	POPM.32	D4|A4	TEST.16	D7	RET;-----------\\;  EDGETDIM  >;===========/; Rend les paramtres d'une fonte donne; in	D3.16	numro de la fonte;	A5.32	^var; out	A4.32	^table de chasse	[obj];	D3.32	[h1;h2]			[obj];	D4.16	interligne		[obj];	D7.16	erreur; mod	A4.32, D3.32, D4.16, D7.16EDGETDIM:	PUSHM.32 D0..D2|A2|A3	MOVE.16	D3,D2	COMP.16	{A5}+ODRLFONT,D3	JUMP,EQ	R8^SAME$			; pas chang	COMP.16	#16,D3				; fonte des symboles ?	JUMP,NE	R8^FONT$			; non => fonte normale	CALL	SFONTGETDIM			; simule "opDGETDIM"	JUMP	R8^MEM$				; mmorise le rsultatFONT$:	MOVE.32	#0,A4	MOVE.32	#IDENTCHAR,D0	MOVE.32	#opDGETDIM,D1	PAGE_	OBJCALL				; A2/A3/A4/D3/D4 <-- paramtres	JUMP,NE	R8^ERR$MEM$:	MOVE.16	D2,{A5}+ODRLFONT	MOVE.32	A4,{A5}+ODRCHASSE	MOVE.32	D3,{A5}+ODRH1H2	MOVE.16	D4,{A5}+ODRINTERL	JUMP	R8^OK$SAME$:	MOVE.32	{A5}+ODRCHASSE,A4		; A4 <- ^table de chasse	MOVE.32	{A5}+ODRH1H2,D3			; D3 <- [h1;h2]	MOVE.16	{A5}+ODRINTERL,D4		; D4 <- interligneOK$:	CLR.16	D7ERR$:	POPM.32	D0..D2|A2|A3	TEST.16	D7	RET;---------------\\;  GETCARLENGTH  >;===============/; Cherche la largeur d'un caractre (chasse).; in	A4.32	^table de chasse;	D3.16	code ASCII; out	D4.16	largeur [dx]; mod	D4.16, D7.16GETCARLENGTH:	PUSHM.32 A4	MOVE.16	D3,D4	SL.16	#1,D4	MOVE.16	{A4}+A16^{D4},D4		; chasse [dx] du caractre en units [obj]	CALL	CALCIMBRICI			; et taille  cause de l'imbricationERR$:	POPM.32	A4	RET;-------------\\;  GETCARH1H2  >;=============/; Cherche h1 et h2 d'un caractre.; in	A4.32	^table de chasse;	D3.16	code ASCII; out	D3.32	[h1;h2] aux format [obj]; mod	D3.32, D7.16GETCARH1H2:	PUSHM.32 D4|A4	DEC.16	D3	MOVE.16	D3,D4	SL.16	#1,D4	ADD.A16	D4,A4	MOVE.32	{A4}+1024,D4	CALL	CALCIMBRICI			; rduction d'chelle	MOVE.16	D4,D3				; [--;h1]	SWAP.32	D3	MOVE.32	{A4}+2048,D4	CALL	CALCIMBRICI			; rduction	MOVE.16	D4,D3				; [h1;h2]ERR$:	POPM.32	D4|A4	RET;----------\\; SFONTINIT >;----------/; Initialise les paramtres (chasse, h1, h2, etc.) d'un caractre.; En fait, on simule ce que fait l'objet DEF_CHAR en ce qui concerne; la table des chasses...; Initialise :;	{A5}+OSFONTCARPL;	{A5}+OSFONTCARH1;	{A5}+OSFONTCARH2;	{A5}+OSFONTCARIL; in	A5.32	^variables; out	-; mod	D7.16SFONTINIT:	PUSHM.32 D1..D4|A2..A4	TEST.32	{A5}+OSFONTCARPL		; pointeur chasse initialis ?	JUMP,EQ	R8^FMEM$			; non => ok !	MOVE.32	{A5}+OSFONTCARPL,A4		; libre la mmoire	MOVE.16	#MTYPCP,D1	GESMEM	?GIVMEM				; libre la table de chasse	CLR.32	{A5}+OSFONTCARPLFMEM$:	MOVE.16	#DR_GETSCALE,D7	PAGE_	DRAW				; D4 <-- chelle courante	MOVE.16	D4,D3	MOVE.16	#0,D4	MOVE.16	#DR_PUTSCALE,D7	PAGE_	DRAW				; met l'chelle 1:1	.IF 0	GSYMBDESC A4	MOVE.32	{A4},A4				; A4 <-- ^descripteur	.ELSE	MOVE.32	#{A5}+OFONTBUF+16*LDGBM,A4	; A4 <- ^gencar symboles	.ENDIF	CLR.32	D1				; D1 <-- angle de rotation nul [DR]	MOVE.16	#DR_GETPGC,D7	PAGE_	DRAW				; A3 <-- ^gencar bitmap	JUMP,NE	LGEND$	MOVE.16	{A3}+oxcbmYMIN,{A5}+OSFONTCARH1	MOVE.16	{A3}+oxcbmYMAX,{A5}+OSFONTCARH2	MOVE.16	{A3}+oxcbmITL,{A5}+OSFONTCARIL	MOVE.32	#(xcNBCAR*2)*5,D4	MOVE.16	#MTYPCP,D1	GESMEM	?GETMEM				; A4 <-- ^mmoire pour table de chasse	MOVE.32	A4,{A5}+OSFONTCARPL	MOVE.32	#{A3}+oxcbmLENGTH,A2	MOVE.16	#(xcNBCAR/2)-1,D4XFLG$:	MOVE.32	{A2+},{A4+}			; table <-- chasses	DJ.16,NMO D4,XFLG$	MOVE.32	#{A3}+oxcbmXMINS,A2	MOVE.16	#(xcNBCAR/2)-1,D4XFXMIN$:	MOVE.32	{A2+},{A4+}			; table <-- XMINS	DJ.16,NMO D4,XFXMIN$	MOVE.32	#{A3}+oxcbmYMINS,A2	MOVE.16	#(xcNBCAR/2)-1,D4XFYMIN$:	MOVE.32	{A2+},{A4+}			; table <-- YMINS	DJ.16,NMO D4,XFYMIN$	MOVE.32	#{A3}+oxcbmXMAXS,A2	MOVE.16	#(xcNBCAR/2)-1,D4XFXMAX$:	MOVE.32	{A2+},{A4+}			; table <-- XMAXS	DJ.16,NMO D4,XFXMAX$	MOVE.32	#{A3}+oxcbmYMAXS,A2	MOVE.16	#(xcNBCAR/2)-1,D4XFYMAX$:	MOVE.32	{A2+},{A4+}			; table <-- YMAXS	DJ.16,NMO D4,XFYMAX$LGEND$:	MOVE.16	D3,D4	MOVE.16	#DR_PUTSCALE,D7	PAGE_	DRAW				; remet l'chelle couranteEXIT$:	POPM.32	D1..D4|A2..A4	RET;--------------\\;  SFONTGETDIM  >;==============/; Cherche les dimensions de la fonte des symboles; in	A5.32	^variables; out	A2.32	^nom de la fonction;	A3.32	^descripteur bitmap;	A4.32	^table chasse,xmin,ymin,xmax,ymax	[obj];	D3.32	hauteurs [h1;h2]			[obj];	D4.16	interligne				[obj];	D7.16	erreur; mod	A2.32, A3.32, A4.32, D3.32, D4.16, D7.16SFONTGETDIM:	.IF 0	GSYMBDESC A3	MOVE.32	{A3},A3	.ELSE	MOVE.32	#{A5}+OFONTBUF+16*LDGBM,A3	; A3 <- ^gencar symboles	.ENDIF	MOVE.32	#R16^NOM$,A2	MOVE.32	{A5}+OSFONTCARPL,A4	MOVE.32	{A5}+OSFONTCARH1,D3	MOVE.16	{A5}+OSFONTCARIL,D4	CLR.16	D7	RETNOM$:	.ASCIZE	"Symboles"	.END