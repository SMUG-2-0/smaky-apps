	.SBTTL	OPTEXTTAB.ASI;--------\\; TABNEXT >;========/; Cherche la position sur le tabulateur suivant.; in	A4.L	^objet;	A2.L	^table de justification;	D1.W	position dans la ligne; out	D1.L	 0..15: position suivante;		16..31: type de tabulateur (ICORGTAB?); mod	D1.L, D7.WTABNEXT:	PUSHM.L	D2..D4,A3	LOAD.L	A3,#(A2)+OJSTABSLOOP$:	TEST.L	(A3)		; fin de la table ?	JUMP',EQ ERROR$	LOAD.W	D3,(A3)+2	; D3 <-- icne (type du tabulateur)	CALL	TABNEXTLG	; D4 <-- longueur	CLR.L	D2	LOAD.W	D2,(A5)+OTXDIM+2	COMP.L	D4,D2		; dpasse la largeur du pav ?	JUMP',HS ERROR$		; oui => ERROR$	NEG.W	D4	ADD.W	D4,(A3)		; D4 <-- position	JUMP',NS NEXT$	COMP.W	D1,D4	JUMP',LO FOUND$NEXT$:	ADD.L	A3,#4		; A3 <-- ^tabulateur suivant	JUMP	LOOP$FOUND$:	SWAP.W	D1	LOAD.W	D1,D3		; D1 <-- ICORGTAB?	SWAP.W	D1	LOAD.W	D1,D4		; D1 <-- nouvelle position	JUMP'	EXIT$ERROR$:	AND.L	D1,#H'FFFF	; D1 <-- type de tabulateur inconnu	ADD.W	D1,#50*FACMMPT	; D1 <-- avance de 5mm !EXIT$:	POPM.L	D2..D4,A3	RET;----------\\; TABNEXTLG >;----------/; Cherche la longueur jusqu'au prochain tabulateur.; in	D3.W	icne (ICORGTAB?); out	D4.L	longueur; mod	D4.L, D7.WTABNEXTLG:	PUSHM.L	D1..D3,D5	LOAD.W	D1,D3		; D1 <-- icne	CLR.L	D4	COMP.W	D1,#ICORGTABD	; tabulateur droite ?	JUMP,EQ EXIT$		; oui => EXIT$	COMP.W	D1,#ICORGTABI	; indentateur ?	JUMP,EQ EXIT$		; oui => EXIT$	CALL	_BUTX_POSSAV	; sauve la position du curseur	PUSH.W	D4	CLR.L	D2LOOP$:	CALL	_BUTX_AVANCE	; D3/D4/D5 <-- caractre suivant	JUMP',NE END$	COMP.B	D3,#CR	JUMP',EQ END$	COMP.B	D3,#EOP	JUMP',EQ END$	COMP.B	D3,#TAB	JUMP',EQ END$	COMP.W	D1,#ICORGTABN	; tabulateur dcimal ?	JUMP',NE LG$		; non => LG$	COMP.B	D3,#'.	JUMP',EQ END$	COMP.B	D3,#',	JUMP',EQ END$LG$:	CALL	CARCHASSE	; D5 <-- chasse du caractre	AND.L	D5,#H'FFFF	ADD.L	D2,D5	JUMP	LOOP$END$:	POP.W	D4	CALL	_BUTX_POSEND	; revient o l'on tait	LOAD.L	D4,D2		; D4 <-- longueur	COMP.W	D1,#ICORGTABC	; tabulateur centr ?	JUMP',NE EXIT$		; non => EXIT$	SR.L	D4,#1EXIT$:	POPM.L	D1..D3,D5	RET	.END