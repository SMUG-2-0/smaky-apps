	.SBTTL	PAGECLIC.ASI;************;;    CLIC    ;;************;CLIC:	COMP.W	D3,#KEYMMP	JUMP,EQ CLICM	LOAD.W	D1,D3		; D1 <-- bouton press	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP; Traite le cas o la souris est dans un ascenseur.	LOAD.L	A1,#0	CALL	_DOMASCENSEUR	; agit dans ascenseurs selon souris	JUMP,EQ LOOP	LOAD.L	A5,#(A6)+OIDCAL	; A5 <-- ^indicateur des calques	CALL	_INDMOVE	; change de calque ...	JUMP,EQ ICALQUE$	COMP.W	D7,#2		; dplacement ?	JUMP,EQ IDCALQUE$	LOAD.L	A5,#(A6)+OIDPAG	; A5 <-- ^indicateur des pages	CALL	_INDMOVE	; change de page ...	JUMP,EQ IPAGE$	COMP.W	D7,#2		; dplacement ?	JUMP,EQ IDPAGE$; Traite le cas o la souris est dans une icne.	CALL	_MOVICONE	; souris dans une icne ?	JUMP,EQ ICONE$		; oui => ICONE$				; non =>	CALL	_DPLICONE	; dplace toutes les icnes ?	JUMP,EQ LOOP		; oui => LOOP; Traite le cas o la souris est dans les informations.	CALL	_ICAMOVE	; souris dans le cadre ?	JUMP,EQ CADRE$		; oui => CADRE$	LOAD.W	D3,D1		; D3 <-- bouton press	COMP.W	D3,#KEYMGP	JUMP,EQ CLICG	COMP.W	D3,#KEYMDP	JUMP,EQ CLICD	JUMP	BIPICALQUE$:	TEST.W	D3	JUMP',NS ICSPEC$	LOAD.L	D4,(A6)+OCALCA	TCLR.L	D4:D3		; D4 <-- ce calque doit tre visible !	LOAD.L	(A6)+OCALCA,D4	SUB.W	D3,(A5)+OIDHTV	NEG.W	D3	DEC.W	D3	COMP.W	D3,(A6)+OCALQ	JUMP,EQ LOOP	LOAD.W	(A6)+OCALQ,D3	; OCALQ <-- nouveau calque o travailler	CALL	_INDUPDATE	; mj l'indicateur des calques	CALL	_DESINFNBOBJ	; affiche le nombre d'objets	JUMP	DOREFAITICSPEC$:	COMP.W	D3,#-4	JUMP,EQ DONEWCALQUE	COMP.W	D3,#-5	JUMP,EQ DOEFCALQUE	JUMP	BIPIDCALQUE$:	SUB.W	D3,(A5)+OIDHTV	NEG.W	D3;	DEC.W	D3	LOAD.L	D6,(A6)+OOBACH	LOAD.W	D2,D3	LOAD.W	D4,D3	LOAD.L	A2,#R16"_LSTA_EXFC	LOAD.W	D3,(A6)+OPAGE	; D3 <-- page courante	CALL	_LSTA_BEGIN	JUMP',EQ IDCF$	DEC.W	D4	CALL	_LSTA_BEGIN	LOAD.L	A2,#R16"_LSTA_EXFAIDCF$:	LOAD.L	A3,A4		; A3 <-- ^calque frre cadet/an	LOAD.W	D4,(A6)+OCALQ	CALL	_LSTA_BEGIN	; A4 <-- ^calque  dplacer	CALL	(A2)		; CALL  _LSTA_EXFC/A	SET.B	(A6)+OMAJ	; mise  jour sur disque ncessaire	LOAD.W	(A6)+OCALQ,D2	COMP.W	D2,D4	JUMP,LO DOCALQUE	DEC.W	(A6)+OCALQ	JUMP	DOCALQUEIPAGE$:	TEST.W	D3	JUMP',NS IPSPEC$	COMP.W	D3,(A6)+OPAGE	JUMP,EQ LOOP	LOAD.W	(A6)+OPAGE,D3	; OPAGE <-- nouvelle page o travailler	LOAD.W	(A6)+OCALQ,#-1	; utilise le calque tout dessus (A)	JUMP	DOCALQUEIPSPEC$:	COMP.W	D3,#-4	JUMP,EQ DONEWPAGE	COMP.W	D3,#-5	JUMP,EQ DOEFPAGE	JUMP	BIPIDPAGE$:	LOAD.L	D6,(A6)+OOBACH	LOAD.W	D2,D3	LOAD.W	D4,#-1		; D4 <-- tous les calques	LOAD.L	A2,#R16"_LSTA_EXFC	CALL	_LSTA_BEGIN	JUMP',EQ IDPF$	DEC.W	D3	CALL	_LSTA_BEGIN	LOAD.L	A2,#R16"_LSTA_EXFAIDPF$:	LOAD.L	A3,A4		; A3 <-- ^page frre cadet/an	LOAD.W	D3,(A6)+OPAGE	CALL	_LSTA_BEGIN	; A4 <-- ^page  dplacer	CALL	(A2)		; CALL  _LSTA_EXFC/A	SET.B	(A6)+OMAJ	; mise  jour sur disque ncessaire	LOAD.W	(A6)+OPAGE,D2	COMP.W	D2,D3	JUMP,LO DOPAGE	DEC.W	(A6)+OPAGE	JUMP	DOPAGEICONE$:	COMP.W	D3,#ICOOCRAYON	JUMP',EQ OUTIL$	COMP.W	D3,#ICOOLOUPE	JUMP',EQ OUTIL$	COMP.W	D3,#ICOOMAIN	JUMP',EQ OUTIL$	COMP.W	D3,#ICOOEDIT	JUMP',EQ OUTIL$	COMP.W	D3,#ICOOSUITE	JUMP',EQ OUTIL$	CALL	SELICONE	; action selon l'icne clique	JUMP,NE BIP	CALL	_UPDICONE	; met  jour l'tat des icnes	JUMP	LOOPOUTIL$:	COMP.W	D3,(A6)+OOUTIL	JUMP,EQ BIP	LOAD.W	(A6)+OOUTIL,D3	CALL	_DESICONE	; dessine les icnes de gauche	CALL	_MAJICONE	; mj. les icnes variables	CALL	_UPDICONE	; met  jour les icnes	CALL	_AFMENU		; refait les soft-keys	JUMP	LOOPCADRE$:	TEST.W	D2	JUMP',EQ SCALE$	JUMP	BIPSCALE$:	CALL	GMMENUSCALE	; choix de l'chelle ...	JUMP,NE LOOP	JUMP	LOUPEQ;*************;;    CLICM    ;;*************;CLICM:	CALL	MMMENUINIT	; A4 <-- ^paramtres	TSET.B	(A4)+(LMM*0)+OMMINA+3:#4 ; grise la case "opration"	TSET.B	(A4)+(LMM*2)+OMMINA+3:#0 ; grise la case "annule"	TEST.L	(A6)+OPHELP	; fichier d'aide charg ?	JUMP',NE MHELP$		; oui => MHELP$	TSET.B	(A4)+(LMM*2)+OMMINA+3:#2 ; grise la case "aide"MHELP$:	CALL	MMMENUCHOIX	; choix selon mmenu ...	JUMP,NE ERROR	TEST.W	D3	JUMP,EQ LOOP	JUMP	KEY;*************;;    CLICG    ;;*************;CLICG:	LOAD.W	D3,(A6)+OOUTIL	COMP.W	D3,#ICOOCRAYON	JUMP,EQ CRAYON	COMP.W	D3,#ICOOLOUPE	JUMP,EQ LOUPE	COMP.W	D3,#ICOOMAIN	JUMP,EQ MAIN	COMP.W	D3,#ICOOEDIT	JUMP,EQ EDIT	COMP.W	D3,#ICOOSUITE	JUMP,EQ SUITE	JUMP	BIP;*************;;    CLICD    ;;*************;CLICD:	JUMP	SELECT;**************;;    CRAYON    ;;**************;CRAYON:	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP	CLR.L	(A6)+OSELPP	; pas d'objet pre !	CLR.L	(A6)+OLIMP1	LOAD.L	(A6)+OLIMP2,(A6)+ODESYDCRAYON1:	CLR.L	(A6)+OLIMB1	CLR.L	(A6)+OLIMB2	; pas de test pour les fils !	LOAD.W	(A6)+OOUTIL,#ICOOCRAYON	CALL	_CONVSCROBP	; D4 <-- position [obj]	JUMP,NE CRBIP$	CALL	ZONEQCLIPONE	; dans la zone du pre ventuel ?	JUMP,NE CRBIP$	LOAD.L	D2,D4	CLR.L	(A6)+OAPOS	LOAD.W	D0,(A6)+OOBJET	ADD.W	D0,(A6)+OICOFO	SUB.W	D0,#ICOOBJET	CALL	_OBJGETID	; D0 <-- identificateur de l'objet	JUMP,NE CRBIP$	LOAD.W	D3,(A6)+OPAGE	; D3 <-- page visible	LOAD.W	D4,(A6)+OCALQ	; D4 <-- calque visible	LOAD.L	D6,(A6)+OOBACH	; D6 <-- canal de l'arbre des objets	CALL	_LSTA_BEGIN	; A4 <-- ^objet de base	LOAD.L	A3,A4		; A3 <-- ^objet de base comme pre (pour LSTA_INSERT)	LOAD.L	A4,#0		; A4 <-- pas de frre	LOAD.W	D1,#opCRGETLG	CALL	_OBJCALL	; D4 <-- longueur ncessaire	JUMP,NE CRBIP$	CALL	_LSTA_INSERT	; A4 <-- ^objet  la tte	JUMP,NE CRERROR$	LOAD.W	(A4)+OobjIDENT,D0	SET.B	(A6)+OMAJ	; mise  jour sur disque ncessaire	LOAD.W	D1,#opCRINIT	CALL	_OBJCALLD	; initialise l'objet	JUMP,NE DEL$	LOAD.W	D3,#CRMOVEOPEN	; D3 <-- dbut	LOAD.W	D1,#opCRMOVE	CALL	_OBJCALLD	; indique le dbut de la cration	LOAD.L	(A6)+OSELPS,A4	LOAD.W	D1,#opCRICOLIST	CALL	_OBJCALLD	; A3 <-- ^liste des icnes, A2 <-- ^table des softkeys	JUMP',NE BEGIN$	LOAD.L	(A6)+OICOPH,A3	; OICOPH <-- ^liste des icnes	LOAD.L	(A6)+OICOPS,A2	; OICOPS <-- ^table des soft-keys	LOAD.W	(A6)+OICONIV,#NICOCREATE ; dbut de l'opration	LOAD.W	(A6)+OICOID,D0	; OICOID <-- identificateur	CALL	_DESICONE	; dessine les icnes de gauche	CALL	_MAJICONE	; mj. les icnes variables	CALL	_AFMENU		; refait les soft-keys	LOAD.L	A5,#(A6)+OIDPAG	CALL	_INDUPDATE	; mj l'indicateur des pages	LOAD.L	A5,#(A6)+OIDCAL	CALL	_INDUPDATE	; mj l'indicateur des calquesBEGIN$:	LOAD.L	D4,D2		; D4 <-- position de la souris	LOAD.W	D3,#ICOOCRAYON	CALL	_SELMO		; utilise le bon lutin	CALL	HVOPEN		; contrainte: fixe le point initial	JUMP	CREATE0$LOOP$:	CALL	_UPDICONE	; met  jour l'tat des icnes	CALL	_SCMO		; remet la sourisLOOP2$:	LOAD.W	D3,(A6)+OOUTIL	COMP.W	D3,#ICOOCRAYON	JUMP',NE LOOP3$	LOAD.W	D1,#opCRICOOUTIL	CALL	_OBJCALLD	; D3 <-- icne pour la souris	JUMP',EQ LOOP3$	LOAD.W	D3,#ICOOCRAYONLOOP3$:	CALL	_SELMO		; utilise le bon lutin	CALL	_DESINFXY	; affiche X= et Y= dans les informations	CALL	_WAITMOVE	; attend dplacement souris ...	COMP.W	D3,#KEYMPO	JUMP,EQ LOOP2$	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMMP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMDP	JUMP',EQ CLIC$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#CR	JUMP,EQ END$	COMP.W	D3,#UNDO	JUMP,EQ CANCEL$	COMP.W	D3,#DEL	JUMP,EQ CANCEL$	COMP.W	D3,#BS	JUMP,EQ CANCEL$	COMP.W	D3,#DELETE	JUMP,EQ CANCEL$	COMP.W	D3,#HELP	JUMP,EQ HELP$	TEST.L	D3:#BKRELEAS	JUMP',BS BIP$	TEST.L	D3:#BKPSEUDO	; changement de touches super-shift ?	JUMP',BS SHIFT$		; oui => SHIFT$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOP$SHIFT$:	LOAD.L	D4,(A6)+OHVFIX	CALL	HVCONV		; met/enlve les repres	JUMP	LOOP$CLIC$:	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP$	LOAD.L	A1,#R16"ASCINV$	CALL	_DOMASCENSEUR	; agit dans ascenseurs selon souris	JUMP,EQ LOOP$	LOAD.W	D1,#opBUTTON	CALL	_OBJCALLD	; indique le bouton utilis	CALL	_MOVICONE	; souris dans une icne ?	JUMP',EQ ICONE$		; oui => ICONE$	CALL	_DPLICONE	; dplace toutes les icnes ?	JUMP,EQ LOOP$		; oui => LOOP$	COMP.W	(A6)+OOUTIL,#ICOOLOUPE	JUMP,EQ LOUPE$	COMP.W	(A6)+OOUTIL,#ICOOMAIN	JUMP,EQ MAIN$	JUMP	CREATE$ICONE$:	COMP.W	D3,#ICOOCRAYON	JUMP,EQ OUTIL$	COMP.W	D3,#ICOOLOUPE	JUMP,EQ OUTIL$	COMP.W	D3,#ICOOMAIN	JUMP,EQ OUTIL$	COMP.W	D3,#ICOOFLECHE	JUMP,EQ HAND$	COMP.W	D3,#ICOOOPER	JUMP,EQ HAND$	COMP.W	D3,#ICOOGROUPE	JUMP,EQ HAND$	COMP.W	D3,#ICOOPLAN	JUMP,EQ HAND$	COMP.W	D3,#ICODACCORD	JUMP,EQ END$	COMP.W	D3,#ICOANNULE	JUMP,EQ CANCEL$	CALL	SELICONE	; action selon l'icne clique	JUMP,EQ LOOP$	CLR.L	D4	LOAD.W	D1,#opCRICOGET	CALL	_OBJCALLD	; D4/A3 <-- tat/^liste	LOAD.L	D5,D4	TEST.L	D5:#BSTICOCHGDRAW ; faut-il changer le dessin ?	JUMP',BC ICONE23$	; non => ICONE23$	LOAD.L	D2,#2^BVUECLR!2^BVUEPROV!2^BVUEPROVE	CALL	DESOBJET	; efface l'objetICONE23$:	LOAD.W	D1,#opCRICOMOD	CALL	_OBJCALLD	; agit dans l'objet selon l'ine clique ...	JUMP',NE ICONE3$	ADD.W	(A6)+OGBBOX,D4	; OGBBOX <-- nb de modificationsICONE3$:	PUSH.W	D7	TEST.L	D5:#BSTICOCHGDRAW ; faut-il changer le dessin ?	JUMP',BC ICONE43$	; non => ICONE43$	LOAD.L	D2,#2^BVUESET!2^BVUEPROV!2^BVUEPROVE	CALL	DESOBJET	; redessine l'objetICONE43$:	TEST.L	D5:#BSTICOCHGUPIC ; faut-il changer l'icne ?	JUMP',BC ICONE44$	; non => ICONE44$	CALL	_DESICONEONE	; redessine l'icneICONE44$:	TEST.L	D5:#BSTICOCHGUPLI ; faut-il changer une liste d'icnes ?	JUMP',BC ICONE46$	; non => ICONE46$ICONE45$:	LOAD.W	D3,(A3+)	JUMP',EQ ICONE46$	CALL	_DESICONEONE	; redessine une icne	JUMP	ICONE45$ICONE46$:	POP.W	D7	JUMP,NE BIP$	JUMP	LOOP$OUTIL$:	COMP.W	D3,(A6)+OOUTIL	JUMP,EQ BIP$	LOAD.W	(A6)+OOUTIL,D3	CALL	_DESICONE	; dessine les icnes de gauche	CALL	_MAJICONE	; mj. les icnes variables	JUMP	LOOP$CREATE$:	CALL	_CONVSCROBP	; D4 <-- point o est la souris	JUMP,NE BIP$	CALL	ZONEQCLIPONE	; dans la zone du pre ventuel ?	JUMP,NE BIP$CREATE0$:	CALL	HVCONV		; D4 <-- point selon contrainte	LOAD.L	D5,D4	LOAD.L	D2,#2^BVUECLR!2^BVUEPROV!2^BVUEPROVE	CALL	DESOBJET	; teint l'objet	LOAD.W	D3,#CRMOVEBEGIN	; D3 <-- dbut	LOAD.W	D1,#opCRMOVE	CALL	_OBJCALLD	; indique le dbut du dplacement	PUSH.W	D7	LOAD.L	D2,#2^BVUESET!2^BVUEPROV!2^BVUEPROVE	CALL	DESOBJET	; allume l'objet	POP.W	D7	JUMP,NE END$CREATE2$:	CALL	_SCMO		; remet la souris	CALL	_WAITMOVE	; attend dplacement souris ...	JUMP,NE CREATE8$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE CREATE2$	CALL	_CONVSCROBP	; D4 <-- point o est la souris	JUMP,NE CREATE2$	CALL	HVCONV		; D4 <-- point selon contrainte	COMP.L	D4,D5		; position change ?	JUMP,EQ CREATE2$	; non => CREATE2$	LOAD.W	D3,#-1	LOAD.L	D2,#2^BVUECLR!2^BVUEPROV!2^BVUEPROVE!2^BVUEPROVH	CALL	DESOBJET	; teint l'objet	LOAD.W	D3,#CRMOVEDRAG	; D3 <-- dplacement	LOAD.W	D1,#opCRMOVE	CALL	_OBJCALLD	; dplace la poigne	CALL	HANDPOSOK	; nouvelle position ok ?	JUMP',EQ CREATE5$	; oui => CREATE5$	LOAD.L	D4,D5;	LOAD.W	D3,#CRMOVEDRAG	; D3 <-- dplacement;	LOAD.W	D1,#opCRMOVE	CALL	_OBJCALLD	; dplace la poigne o elle tait avant	LOAD.W	D3,#-1	LOAD.L	D2,#2^BVUESET!2^BVUEPROV!2^BVUEPROVE!2^BVUEPROVH	CALL	DESOBJET	; allume l'objet	CALL	_CONVOBJSCR	; D4 <-- position [scr]	JUMP,NE CREATE2$	SUB.W	D4,(A6)+OLUPX	SWAP.W	D4	SUB.W	D4,(A6)+OLUPY	SWAP.W	D4	CALL	_PMOUSE		; dplace la souris !	JUMP	CREATE2$CREATE5$:	LOAD.W	D3,#-1	LOAD.L	D2,#2^BVUESET!2^BVUEPROV!2^BVUEPROVE!2^BVUEPROVH	CALL	DESOBJET	; allume l'objet	LOAD.L	D5,D4		; D5 <-- dernire position	LOAD.W	D1,#opCRINFO	CALL	_DESINFOBJ	; affiche les informations	JUMP	CREATE2$CREATE8$:	CALL	HVCLOSE		; contrainte: termine	LOAD.L	D2,#2^BVUECLR!2^BVUEPROV!2^BVUEPROVE	CALL	DESOBJET	; teint l'objet	LOAD.W	D3,#CRMOVEEND	; D3 <-- fin	LOAD.W	D1,#opCRMOVE	CALL	_OBJCALLD	; indique la fin du dplacement	PUSH.W	D7	LOAD.L	D2,#2^BVUESET!2^BVUEPROV!2^BVUEPROVE	CALL	DESOBJET	; allume l'objet	POP.W	D7	JUMP,NE CANCEL1$	CALL	_DESINFALL	; remet les informations normales	COMP.W	(A6)+OICONIV,#NICOCREATE ; icnes de gauche changes ?	JUMP,NE END2$		; non => END2$	CALL	HVOPEN		; contrainte: fixe le point initial	JUMP	LOOP$LOUPE$:	CALL	LOUPOUTIL	; D1/D2/D3 <-- P1/P2/suivant	JUMP,NE BIP$	CALL	LOUPSCALE	; D4 <-- nouvelle chelle	JUMP,NE BIP$	CALL	ASCINV$		; teint la slection	CALL	LOUPDRAW	; affiche  la nouvelle chelle	CALL	ASCINV$		; allume la slection	JUMP	LOOP$MAIN$:	CALL	ASCINV$		; teint la slection	CALL	MAINMOVE	; dplace selon la main ...	PUSH.W	D7	CALL	ASCINV$		; allume la slection	POP.W	D7	JUMP,NE BIP$	JUMP	LOOP$HELP$:	CALL	_HELPACTION	; aide ...	JUMP	LOOP$HAND$:	LOAD.W	D0,D3	CALL	HVCLOSE		; contrainte: termine	LOAD.L	D2,#2^BVUECLR!2^BVUEPROV!2^BVUEPROVE	CALL	DESOBJET	; teint l'objet	LOAD.W	D3,#CRMOVECLOSE	; D3 <-- fin	LOAD.W	D1,#opCRMOVE	CALL	_OBJCALLD	; indique la fin de la cration	JUMP',NE CANCEL2$	CALL	_LSTO_CCOMPACT	; A4 <-- ^objet compact	LOAD.W	D3,D0		; D3 <-- outil	TEST.L	(A6)+OSELPP	; y a-t-il un pre ?	JUMP,EQ SELONE		; non => SELONE	CALL	SELFILS$	; dslectionne le pre	JUMP	SELONE		; slectionne le filsCANCEL$:	CALL	HVCLOSE		; contrainte: termineCANCEL1$:	LOAD.L	D2,#2^BVUECLR!2^BVUEPROV!2^BVUEPROVE	CALL	DESOBJET	; teint l'objet	LOAD.W	D3,#CRMOVECLOSE	; D3 <-- fin	LOAD.W	D1,#opCRMOVE	CALL	_OBJCALLD	; indique la fin de la crationCANCEL2$:	CALL	_LSTA_REMOVE	; enlve l'objet	JUMP'	MENU$END$:	CALL	HVCLOSE		; contrainte: termineEND2$:	LOAD.L	D2,#2^BVUECLR!2^BVUEPROV!2^BVUEPROVE	CALL	DESOBJET	; teint l'objet	LOAD.W	D3,#CRMOVECLOSE	; D3 <-- fin	LOAD.W	D1,#opCRMOVE	CALL	_OBJCALLD	; indique la fin de la cration	JUMP,NE CANCEL2$	CALL	_LSTO_CCOMPACT	; A4 <-- ^objet compact	TEST.L	(A6)+OSELPP	; y a-t-il un pre ?	JUMP,NE PSELA$		; oui => PSELA$	LOAD.W	D1,#opHANDIFCR	CALL	_OBJCALLD	; slectionne tout de suite ?	JUMP,EQ SELECT$		; oui => SELECT$	LOAD.W	D1,#opEDITICOLIST	CALL	_OBJCALLD	; A3 <-- ^liste des icnes, A2 <-- ^table des softkeys	JUMP,EQ EDIT$		; si elle existe => EDIT$ (dite l'objet cr)	LOAD.W	D1,#opHANDIFCR	CALL	_OBJCALLD	; slectionne tout de suite ?	JUMP,EQ SELECT$		; oui => SELECT$	CALL	DESSET		; dessine l'objet dfinitifMENU$:	TEST.L	(A6)+OSELPP	; y a-t-il un pre ?	JUMP,NE PSEL$		; oui => PSEL$	CALL	_DESINFNBOBJ	; affiche le nombre d'objets	TEST.W	(A6)+OICONIV	; icnes de gauche changes ?	JUMP,EQ LOOP		; non => LOOP	CLR.W	(A6)+OICONIV	; fin de la cration	CALL	_DESICONE	; remet les icnes  gauche	CALL	_MAJICONE	CALL	_AFMENU		; refait les soft-keys	JUMP	LOOPPSELA$:	LOAD.W	D1,#opHANDIFCR	CALL	_OBJCALLD	; slectionne tout de suite ?	JUMP',EQ PSELECT$	; oui => PSELECT$	LOAD.W	D1,#opEDITICOLIST	CALL	_OBJCALLD	; A3 <-- ^liste des icnes, A2 <-- ^table des softkeys	JUMP',EQ PEDIT$		; si elle existe => PEDIT$ (dite l'objet cr)	LOAD.L	D2,#2^BVUESET!2^BVUEPROV!2^BVUEPROVE!2^BVUEPROVI	CALL	DESOBJET	; allume l'objet cr	LOAD.L	A3,(A6)+OSELPP	; A3 <-- ^pre	CALL	_GROUPADOPT	; le pre adopte le filsPSEL$:	LOAD.L	A4,(A6)+OSELPP	; A4 <-- ^pre	LOAD.L	D2,#2^BVUECLR!2^BVUEPROV!2^BVUEPROVE!2^BVUEPROVI	CALL	DESOBJETF	; teint l'objet pre et ses fils	LOAD.W	D3,#ICOOCRAYON	; D3 <-- outil	JUMP	SELONEPSELECT$:	CALL	SELFILS$	; dslectionne le pre	JUMP'	SELECT$PEDIT$:	CALL	SELFILS$	; dslectionne le pre	JUMP'	EDIT$CRBIP$:	TEST.L	(A6)+OSELPP	; y a-t-il un pre ?	JUMP,EQ BIP		; non => BIP	LOAD.B	D3,#BIPLIT	LIB	?BEEP	JUMP	PSEL$CRERROR$:	TEST.L	(A6)+OSELPP	; y a-t-il un pre ?	JUMP,EQ ERROR		; non => ERROR	CALL	_DBOXERROR	; affiche l'erreur ...	JUMP	PSEL$EDIT$:	CALL	_DESINFNBOBJ	; affiche le nombre d'objets	JUMP	EDIT3SELECT$:	CALL	_DESINFNBOBJ	; affiche le nombre d'objets	LOAD.W	D3,#ICOOFLECHE	; D3 <-- outil	JUMP	SELONEDEL$:	PUSH.W	D7	CALL	_LSTA_REMOVE	; enlve l'objet	CALL	_DESINFNBOBJ	; affiche le nombre d'objets	POP.W	D7	JUMP	CRERROR$;--------\\; ASCINV$ >;--------/; Inverse l'objet en cours de cration.; in	A4.L	^objet; out	-; mod	D7.WASCINV$:	PUSH.L	D2	PUSH.L	(A6)+OAPOS	INC.W	(A6)+OASNBI	TEST.B	(A6)+OASNBI+1:#0	JUMP',BC ASCSET$ASCCLR$:	CALL	HVCLR		; efface les repres	LOAD.L	D2,#2^BVUECLR!2^BVUEPROV!2^BVUEPROVE	CALL	DESOBJET	; efface l'objet	TEST.L	(A6)+OSELPP	; y a-t-il un pre ?	JUMP',EQ ASCEND$	PUSH.L	A4	LOAD.L	A4,(A6)+OSELPP	LOAD.L	D2,#2^BVUECLR!2^BVUEPROV!2^BVUEPROVE!2^BVUEPROVI	CALL	DESOBJETF	; efface l'objet pre et ses fils	POP.L	A4	JUMP'	ASCEND$ASCSET$:	LOAD.L	D2,#2^BVUESET!2^BVUEPROV!2^BVUEPROVE	CALL	DESOBJET	; allume l'objet	CALL	HVSET		; allume les repres	TEST.L	(A6)+OSELPP	; y a-t-il un pre ?	JUMP',EQ ASCEND$	PUSH.L	A4	LOAD.L	A4,(A6)+OSELPP	LOAD.L	D2,#2^BVUESET!2^BVUEPROV!2^BVUEPROVE!2^BVUEPROVI	CALL	DESOBJETF	; allume l'objet pre et ses fils	POP.L	A4;	JUMP'	ASCEND$ASCEND$:	POP.L	(A6)+OAPOS	POP.L	D2	RET;---------\\; SELFILS$ >;---------/; Slectionne le fils et dslectionne le pre.; in	fils effac;	pre en inverse vido; out	fils effac et adopt par le pre;	pre dslectionn et dessin normalement; in	A4.L	^objet fils; out	-; mod	D7.WSELFILS$:	PUSHM.L	D2,A3,A4	LOAD.L	A3,A4		; A3 <-- ^fils	LOAD.L	A4,(A6)+OSELPP	; A4 <-- ^pre	LOAD.L	D2,#2^BVUECLR!2^BVUEPROV!2^BVUEPROVE!2^BVUEPROVI	CALL	DESOBJETF	; teint l'objet pre et ses fils	EX.L	A3,A4		; A3/A4 <-- ^pre/fils	CALL	_GROUPADOPT	; le pre adopte le fils	EX.L	A3,A4		; A3/A4 <-- ^fils/pre	CALL	_LSTO_HCOMPACT	; compactifie le pre	TSET.B	(A3)+OobjFLAGS:#BobjEXTEND	CALL	DESSET		; dessine le pre dfinitif	TCLR.B	(A3)+OobjFLAGS:#BobjEXTEND	POPM.L	D2,A3,A4	TEST.W	D7		; retour EQ/NE	RET;**************;;    SELECT    ;;**************;SELECT:	CALL	_CONVSCROBJ	; D4 <-- position [obj]	JUMP,NE BIP	PUSH.L	D4	LOAD.W	D3,(A6)+OPAGE	; D3 <-- page visible	LOAD.W	D4,(A6)+OCALQ	; D4 <-- calque visible	LOAD.L	D6,(A6)+OOBACH	; D6 <-- canal de l'arbre des objets	CALL	_LSTA_BEGIN	; A4 <-- ^objet de base	POP.L	D4	LOAD.L	(A6)+OSELPS,A4	CLR.W	(A6)+OSELNB	LOAD.L	A1,#R16"HANDIFSEL1	CALL	SELSELECT	; slectione qq objets ...	JUMP,NE BIP	LOAD.W	D3,#ICOOFLECHE	; D3 <-- outil	JUMP	SELGOSELONE:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BS OEXTOK$	CALL	_LSTO_HEXTEND	; A4 <-- ^objet tendu	JUMP',EQ OEXTOK$	PUSH.W	D7	CALL	DESSET		; redessine l'objet	POP.W	D7	JUMP	ERROROEXTOK$:	LOAD.L	(A6)+OSELPS,A4	; OSELPS <-- ^objet slectionn	LOAD.W	(A6)+OSELNB,#1	SET.B	(A6)+OMAJ	; mise  jour sur disque ncessaire	JUMP'	SELGOSELIO:	CALL	ZONEMOVEBC	LOAD.L	A2,#R16"POINT$	CALL	ZONEMOVEDC	; dplace dans la partie visible	CALL	ZONEMOVEEC	CALL	SELOBJMAJ	; met  jour la slection	LOAD.W	D3,#ICOOFLECHE	JUMP'	SELGOPOINT$:	ADD.W	D4,(A6)+ODESX1	SWAP.W	D4	ADD.W	D4,(A6)+ODESY1	SWAP.W	D4	RETSELGO:	LOAD.W	(A6)+OOUTIL,D3	LOAD.W	(A6)+OICONIV,#NICOSELECT ; dbut de l'opration	LOAD.L	(A6)+OSELDD,(A6)+OSELDV	CLR.L	(A6)+OSELDO	; pas d'origine pour duplique	LOAD.L	A5,#(A6)+OIDPAG	CALL	_INDUPDATESEL	; mj l'indicateur des pages	LOAD.L	A5,#(A6)+OIDCAL	CALL	_INDUPDATESEL	; mj l'indicateur des calquesOPENSET$:	PUSH.W	(A6)+OOUTIL	LOAD.W	(A6)+OOUTIL,#ICOOFLECHE	CALL	SELOBJSET	; allume tous les objets	POP.W	(A6)+OOUTILOPEN$:	CALL	SELOPEN		; ouverture de la slection;	JUMP,NE ???	CALL	_DESICONE	; dessine les icnes de gauche	CALL	_MAJICONE	; mj. les icnes variables	CALL	_AFMENU		; refait les soft-keysINFO$:	CALL	SELINFO		; affiche les informationsLOOP$:	CALL	_UPDICONE	; met  jour l'tat des icnes	CALL	_SCMO		; remet la sourisLOOP2$:	CALL	_IFMOUSE	; D4 <-- position de la souris	CALL	SELICOM		; D3 <-- icne pour la souris	CALL	_SELMO		; utilise le bon lutin	CALL	SELINFOXY	; affiche X= et Y= dans les informations	CALL	_WAITMOVE	; attend dplacement souris ...	COMP.W	D3,#KEYMPO	JUMP,EQ LOOP2$	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#KEYMMP	JUMP,EQ CLIC$	COMP.W	D3,#KEYMDP	JUMP,EQ CLIC$KEY$:	LOAD.W	D2,D3	LIB	?MINMAJ	EX.L	D2,D3	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#CR	JUMP,EQ END$	COMP.W	D3,#UNDO	JUMP,EQ UNDO$	COMP.W	D3,#DEL	JUMP,EQ DETRUIT$	COMP.W	D3,#BS	JUMP,EQ DETRUIT$	COMP.W	D3,#DELETE	JUMP,EQ DETRUIT$	COMP.W	D3,#DEFINE	JUMP,EQ DUPLIQUE$	COMP.W	D3,#HELP	JUMP,EQ HELP$	COMP.W	D3,#F3	JUMP,EQ SAUVE$	COMP.W	D3,#F14	JUMP,EQ DETRUIT$	COMP.W	D2,#H'100*(2^BCHANGE)+'A	JUMP,EQ VUE$	COMP.W	D2,#H'100*(2^BCHANGE)+'G	JUMP,EQ GRID$	COMP.W	D2,#H'100*(2^BCHANGE)+'R	JUMP,EQ COL$	COMP.W	D2,#H'100*(2^BCHANGE)+'S	JUMP,EQ HORVERT$	COMP.W	D2,#H'100*(2^BPROGRA)+'F	JUMP,EQ FRAG$	TEST.L	D3:#BKRELEAS	JUMP',BS EVENT$	TEST.L	D3:#BKPSEUDO	; changement de touches super-shift ?	JUMP,BS LOOP2$		; oui => LOOP2$EVENT$:	COMP.W	(A6)+OOUTIL,#ICOOFLECHE	JUMP',NE BIP$	COMP.W	(A6)+OSELNB,#1	JUMP',NE BIP$	LOAD.L	A4,(A6)+OSELPS	; A4 <-- ^objet	LOAD.W	D1,#opHANDEVENT	CALL	_OBJCALLD	; donne l'vnement  l'objet	JUMP,EQ INFO$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOP$ERROR$:	CALL	_DBOXERROR	; affiche l'erreur ...	JUMP	LOOP$CLIC$:	COMP.W	D3,#KEYMMP	JUMP,EQ CLICM$	LOAD.W	D0,D3		; D0 <-- bouton press	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP$	LOAD.L	A1,#R16"ASCINV$	CALL	_DOMASCENSEUR	; agit dans ascenseurs selon souris	JUMP,EQ LOOP$	LOAD.L	A5,#(A6)+OIDCAL	; A5 <-- ^indicateur des calques	CALL	_INDMOVESEL	; change de calque ...	COMP.W	D7,#2		; dplacement ?	JUMP,EQ IDCALQUE$	LOAD.L	A5,#(A6)+OIDPAG	; A5 <-- ^indicateur des pages	CALL	_INDMOVESEL	; change de page ...	COMP.W	D7,#2		; dplacement ?	JUMP,EQ IDPAGE$	LOAD.L	A4,(A6)+OSELPS	; A4 <-- ^objet	LOAD.W	D3,D0		; D3 <-- bouton press	LOAD.W	D1,#opBUTTON	CALL	_OBJCALLD	; indique le bouton utilis	CALL	_MOVICONE	; souris dans une icne ?	JUMP,EQ ICONE$		; oui => ICONE$	CALL	_DPLICONE	; dplace toutes les icnes ?	JUMP,EQ LOOP$		; oui => LOOP$	COMP.W	(A6)+OOUTIL,#ICOOFLECHE	JUMP',NE CLIC4$	COMP.W	(A6)+OSELNB,#1	JUMP',EQ CLIC5$CLIC4$:	CALL	_ICAMOVE	; souris dans le cadre ?	JUMP,EQ CADRE$		; oui => CADRE$CLIC5$:	COMP.W	D0,#KEYMGP	JUMP,EQ CLICG$	COMP.W	D0,#KEYMDP	JUMP,EQ CLICD$	JUMP	BIP$CLICM$:	CALL	MMMENUINIT	; A4 <-- ^paramtres	TSET.B	(A4)+(LMM*0)+OMMINA+3:#5 ; grise la case "dfinitions"	TSET.B	(A4)+(LMM*1)+OMMINA+3:#0 ; grise la case "prend"	TSET.B	(A4)+(LMM*1)+OMMINA+3:#1 ; grise la case "ajoute"	TSET.B	(A4)+(LMM*1)+OMMINA+3:#3 ; grise la case "imprime"	TEST.L	(A6)+OPHELP	; fichier d'aide charg ?	JUMP',NE MHELP$		; oui => MHELP$	TSET.B	(A4)+(LMM*2)+OMMINA+3:#2 ; grise la case "aide"MHELP$:	CALL	MMMENUCHOIX	; choix selon mmenu ...	JUMP,NE BIP$	TEST.W	D3	JUMP,EQ LOOP$	JUMP	KEY$SAUVE$:	CALL	_SAUVESELECT	; sauve les objets slectionns ...	JUMP,NE ERROR$	JUMP	LOOP$VUE$:	CALL	_DBOXVUE	; choix de la vue ...	JUMP,NE ERROR$	COMP.W	D3,#F1	JUMP,NE LOOP$	JUMP	REFAIT$GRID$:	CALL	_DBOXGRID	; choix de la grille ...	JUMP,NE ERROR$	COMP.W	D3,#F1	JUMP,NE LOOP$	JUMP	REFAIT$COL$:	CALL	_DBOXCOLONNES	; nombre de colonnes ...	JUMP,NE ERROR$	COMP.W	D3,#F1	JUMP,NE LOOP$	SET.B	(A6)+OMAJ	; mise  jour sur disque ncessaire	JUMP	REFAIT$HORVERT$:	CALL	_DBOXHORVERT	; choix contrainte ...	JUMP,NE ERROR$	JUMP	LOOP$REFAIT$:	CALL	ASCINV$		; teint la slection	CALL	DESOBJETS	; redessine tous les objets	CALL	ASCINV$		; allume la slection	JUMP	INFO$FRAG$:	CALL	_DBOXFRAGMENT	; fragmente ...	JUMP,NE	ERROR$	COMP.W	D3,#F1	JUMP,NE LOOP$	CLR.W	D2		; D2 <-- normal	CALL	SELCLOSE	; ferme la slection	CALL	FRAGSELECT	; fragmente tous les objets slectionns	JUMP',EQ FRAG8$	CALL	_DBOXERROR	; affiche l'erreur ...FRAG8$:	INC.W	(A6)+OGDRAW	; faudra tout redessiner	JUMP	MENU$ICONE$:	COMP.W	D3,#ICOOCRAYON	JUMP,EQ OUTIL$	COMP.W	D3,#ICOOLOUPE	JUMP,EQ OUTIL$	COMP.W	D3,#ICOOMAIN	JUMP,EQ OUTIL$	COMP.W	D3,#ICOOFLECHE	JUMP,EQ OUTIL$	COMP.W	D3,#ICOOOPER	JUMP,EQ OUTIL$	COMP.W	D3,#ICOOGROUPE	JUMP,EQ OUTIL$	COMP.W	D3,#ICOOPLAN	JUMP,EQ OUTIL$	COMP.W	D3,#ICOOEDIT	JUMP,EQ EDIT$	COMP.W	D3,#ICOOSUITE	JUMP,EQ SUITE$	COMP.W	D3,#ICOZZOOM	JUMP,EQ OPER$	COMP.W	D3,#ICOZTOURNE	JUMP,EQ OPER$	COMP.W	D3,#ICOZMIROIR	JUMP,EQ OPER$	COMP.W	D3,#ICOZDEFORME	JUMP,EQ OPER$	COMP.W	D3,#ICOZDEFBEZ	JUMP,EQ OPER$	COMP.W	D3,#ICOGROUPMAKE	JUMP,EQ GRMAKE$	COMP.W	D3,#ICOGROUPKILL	JUMP,EQ GRKILL$	COMP.W	D3,#ICODUPLIQUE	JUMP,EQ DUPLIQUE$	COMP.W	D3,#ICODETRUIT	JUMP,EQ DETRUIT$	COMP.W	D3,#ICODACCORD	JUMP,EQ END$	COMP.W	D3,#ICOANNULE	JUMP,EQ UNDO$	CALL	SELICONE	; action selon l'icne clique	JUMP,EQ LOOP$	COMP.W	(A6)+OSELNB,#1	JUMP,NE BIP$; Clic dans une icne propre  un objet donn.	LOAD.L	A4,(A6)+OSELPS	; A4 <-- ^objet	LOAD.W	D1,#opHANDICOGET	CALL	_OBJCALLD	; D4/A3 <-- tat/^liste	LOAD.L	D5,D4		; D5 <-- tat	TEST.L	D5:#BSTICOCHGHAND ; faut-il changer les poignes ?	JUMP',BC ONE22$		; non => ONE22$	CALL	SELPOICLR	; teint toutes les poignesONE22$:	TEST.L	D5:#BSTICOCHGDRAW ; faut-il changer le dessin ?	JUMP',BC ONE23$		; non => ONE23$	CALL	SELOBJCLR	; efface l'objetONE23$:	LOAD.W	D1,#opHANDICOMOD	CALL	_OBJCALLD	; agit dans l'objet selon l'ine clique ...	JUMP',NE ONE3$	ADD.W	(A6)+OGBBOX,D4	; OGBBOX <-- nb de modificationsONE3$:	PUSH.W	D7	TEST.L	D5:#BSTICOCHGDRAW ; faut-il changer le dessin ?	JUMP',BC ONE42$		; non => ONE42$	CALL	SELOBJSET	; redessine l'objetONE42$:	TEST.L	D5:#BSTICOCHGHAND ; faut-il changer les poignes ?	JUMP',BC ONE43$		; non => ONE43$	CALL	SELPOISET	; allume toutes les poignesONE43$:	TEST.L	D5:#BSTICOCHGUPIC ; faut-il changer l'icne ?	JUMP',BC ONE44$		; non => ONE44$	CALL	_DESICONEONE	; redessine l'icneONE44$:	TEST.L	D5:#BSTICOCHGUPLI ; faut-il changer une liste d'icnes ?	JUMP',BC ONE46$		; non => ONE46$ONE45$:	LOAD.W	D3,(A3+)	JUMP',EQ ONE46$	CALL	_DESICONEONE	; redessine une icne	JUMP	ONE45$ONE46$:	POP.W	D7	JUMP,NE BIP$	JUMP	INFO$OUTIL$:	COMP.W	D3,(A6)+OOUTIL	JUMP,EQ BIP$	CLR.W	D2		; D2 <-- normal	CALL	SELCLOSE	; ferme la slection	LOAD.W	(A6)+OOUTIL,D3	JUMP	OPEN$OPER$:	COMP.W	D3,(A6)+OOPER	JUMP,EQ BIP$	CLR.W	D2		; D2 <-- normal	CALL	SELCLOSE	LOAD.W	(A6)+OOPER,D3	JUMP	OPEN$GRMAKE$:	CLR.W	D2		; D2 <-- normal	CALL	SELCLOSE	; ferme la slection	CALL	SELOBJCLR	; teint tous les objets	CALL	ZONEGRMAKE	; groupe toute la slection	JUMP',NE GRERR$GRSEL$:	CALL	_LSTO_HEXTEND	; tend l'objet pre	JUMP',NE GRERR$	LOAD.W	(A6)+OSELNB,#1	LOAD.L	(A6)+OSELPS,A4	; OSELPS <-- ^objet slectionn (le pre)	LOAD.W	(A6)+OOUTIL,#ICOOFLECHE	JUMP	OPENSET$GRERR$:	CALL	_DBOXERROR	; affiche l'erreur ...GREND$:	CALL	SELTERMINE	; dslectionne tout	LOAD.L	D3,(A6)+OZONY1	LOAD.L	D4,(A6)+OZONY2	CALL	DESALLWDO	; redessine toute la fentre	JUMP	MENU$GRKILL$:	CLR.W	D2		; D2 <-- normal	CALL	SELCLOSE	; ferme la slection	CALL	SELOBJCLR	; teint tous les objets	CALL	ZONEGRKILL	; tue tous les pres	JUMP',NE GRERR$	TEST.W	D4		; au moins un pre tu ?	JUMP',EQ GRKBIP$	; non => GRKBIP$	CALL	SELOBJMAJ	; met  jour la slection	JUMP	OPENSET$GRKBIP$:	CALL	SELOPEN		; r-ouvre la slection	CALL	SELOBJSET	; allume tous les objets	JUMP	BIP$GRCHG$:	CLR.W	D2		; D2 <-- normal	CALL	SELCLOSE	; ferme la slection	CALL	SELOBJCLR	; teint tous les objets	CALL	ZONEGRCHG	; A4 <-- ^nouveau pre	JUMP',NE GRCHG8$	CALL	DESCLEAR	; efface le nouveau pre	CALL	_LSTO_HEXTEND	; tend le nouveau pre	LOAD.L	(A6)+OSELPS,A4	LOAD.W	(A6)+OSELNB,#1GRCHG8$:	LOAD.W	(A6)+OOUTIL,#ICOOFLECHE	JUMP	OPENSET$IDCALQUE$:	TEST.W	D3	JUMP,NS BIP$	SUB.W	D3,(A5)+OIDHTV	NEG.W	D3	DEC.W	D3	LOAD.W	D4,D3		; D4 <-- calque o dplacer	LOAD.W	D3,(A6)+OPAGE	; D3 <-- reste dans la mme page	JUMP'	IDCHANGE$IDPAGE$:	TEST.W	D3	JUMP,NS BIP$;	LOAD.W	D3,D3		; D3 <-- page o dplacer	CLR.W	D4		; D4 <-- le dernier calque !IDCHANGE$:	CLR.W	D2		; D2 <-- normal	CALL	SELCLOSE	; ferme la slection	CALL	ZONEADOPT	; le pre adopte tous les objets slectionns	CALL	WORKPAGE	; travaille dans une nouvelle page	CALL	WORKCALQUE	; travaille dans un nouveau calque	CALL	SELOBJMAJ	; met  jour la slection	TEST.W	(A6)+OSELNB	JUMP',EQ IDCHBIP$	INC.W	(A6)+OGDRAW	; il faudra tout redessiner	CALL	DESREFAIT	; refait le dessin	LOAD.L	A5,#(A6)+OIDPAG	CALL	_INDUPDATESEL	; mj l'indicateur des pages	LOAD.L	A5,#(A6)+OIDCAL	CALL	_INDUPDATESEL	; mj l'indicateur des calques	JUMP	OPEN$IDCHBIP$:	CALL	SELTERMINE	; dslectionne tout	INC.W	(A6)+OGDRAW	; il faudra tout redessiner	JUMP	MENU$CADRE$:	TEST.W	D2	JUMP',EQ SCALE$	JUMP	BIP$SCALE$:	CALL	GMMENUSCALE	; choix de l'chelle ...	JUMP,NE LOOP$	JUMP	LOUPEQ$CLICG$:	COMP.W	(A6)+OOUTIL,#ICOOCRAYON	JUMP,EQ CRAYON$	COMP.W	(A6)+OOUTIL,#ICOOLOUPE	JUMP,EQ LOUPE$	COMP.W	(A6)+OOUTIL,#ICOOMAIN	JUMP,EQ MAIN$	COMP.W	(A6)+OOUTIL,#ICOOGROUPE	JUMP,EQ GRCHG$	COMP.W	(A6)+OOUTIL,#ICOOPLAN	JUMP,EQ CPLAN$	CALL	SELICOM		; D3 <-- icne pour la souris	COMP.W	D3,#ICOOEDIT	JUMP,EQ EDIT$	CALL	SELDETECT	; D2 <-- rang de la poigne	JUMP,NE BIP$	CALL	_CONVSCROBP	; D4 <-- point o est la souris	JUMP,NE BIP$	CALL	SELBEGIN	; dbut du dplacementHLOOPT$:	LOAD.L	D5,D4	CLR.W	D0		; D0 <-- tout est dplacHLOOP$:	CALL	_SCMO		; remet la souris	CALL	SELINFOMOVE	; affiche les informations	CALL	_WAITMOVE	; attend dplacement souris ...	JUMP',NE HEND$HMOVE$:	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE HLOOP$	CALL	_CONVSCROBP	; D4 <-- point o est la souris	JUMP,NE HLOOP$	CALL	HVCONV		; D4 <-- point selon contrainte	COMP.L	D4,D5		; position change ?	JUMP,EQ HLOOP$		; non => HLOOP$	LOAD.W	D3,#1		; D3 <-- dplace en attendant un vnement	CALL	SELDRAG		; dplace la poigne	JUMP,NE HLOOPT$		; si aucun vnement => HLOOPT$				; si vnement =>	INC.W	D0		; D0 <-- tout n'est pas dplac	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,EQ HMOVE$		; oui => HMOVE$HEND$:	TEST.W	D0		; est-ce que tout est dplac ?	JUMP',EQ HEND5$		; oui => HEND5$	CLR.W	D3		; D3 <-- dplace tout	CALL	SELDRAG		; fini de dplacer la poigneHEND5$:	CALL	SELEND		; fin du dplacement	JUMP,NE BIP$	JUMP	INFO$CRAYON$:	CLR.W	D2		; D2 <-- normal	CALL	SELCLOSE	; ferme le dplacement	LOAD.L	(A6)+OSELPP,(A6)+OSELPS	LOAD.W	(A6)+OOUTIL,#ICOOCRAYON	PUSH.L	D4	LOAD.L	A4,(A6)+OSELPS	; A4 <-- ^objet	LOAD.W	D1,#opGETBBOX	CALL	_OBJCALLD	; D3/D4 <-- bounding box	LOAD.L	(A4)+OobjBBOX1,D3	LOAD.L	(A4)+OobjBBOX2,D4	CALL	_LSTA_BBOX	; D3/D4 <-- bbox du pre	LOAD.L	(A6)+OLIMP1,D3	LOAD.L	(A6)+OLIMP2,D4	POP.L	D4	JUMP	CRAYON1LOUPE$:	CALL	LOUPOUTIL	; D1/D2/D3 <-- P1/P2/suivant	JUMP,NE BIP$	CALL	LOUPSCALE	; D4 <-- nouvelle chelle	JUMP,NE BIP$LOUPEQ$:	CALL	ASCINV$		; teint la slection	CALL	LOUPDRAW	; affiche  la nouvelle chelle	CALL	ASCINV$		; allume la slection	JUMP	LOOP$MAIN$:	CALL	ASCINV$		; teint la slection	CALL	MAINMOVE	; dplace selon la main ...	PUSH.W	D7	CALL	ASCINV$		; allume la slection	POP.W	D7	JUMP,NE BIP$	JUMP	LOOP$CPLAN$:	CALL	_CONVSCROBJ	; D4 <-- position [obj]	JUMP,NE BIP$	LOAD.L	A1,#R16"HANDIFSEL2	CALL	HANDSELECT	; A4 <-- ^objet montr	JUMP,NE BIP$	COMP.W	(A6)+OPLAN,#ICOODEVANT	JUMP',NE CPDER$	CALL	_GROUPDEVANT	; met devant l'objet choisi	JUMP,NE BIP$	JUMP	LOOP$CPDER$:	CALL	_GROUPDERRIERE	; met derrire l'objet choisi	JUMP,NE BIP$	JUMP	LOOP$CLICD$:	LOAD.L	D1,D4		; D1 <-- position de la souris	LOAD.W	D3,#ICODACCORD	CALL	_GSTICONE	; D4 <-- tat de l'icne	COMP.W	D4,#STICONORM	; icne normale ?	JUMP,NE BIP$		; non => BIP$	LOAD.L	D4,D1	CALL	_CONVSCROBJ	; D4 <-- position [obj]	JUMP,NE BIP$	CLR.W	D2		; D2 <-- normal	CALL	SELCLOSE	; ferme le dplacement	CALL	SELOBJCLR	; teint tous les objets	LIB	?GETSHIFT	; D3 <-- touches super-shift	TEST.L	D3:#BCOPY	JUMP',BS MULTI$	CALL	SELTERMINE	; dslectionne tout	CALL	DESREFAIT	; refait le dessin, si ncessaire	CLR.W	(A6)+OSELNB	LOAD.L	A1,#R16"HANDIFSEL1	CALL	SELSELECT	; slectione qq objets ...	JUMP,NE MENU$	JUMP	OPENSET$MULTI$:	LOAD.L	A1,#R16"HANDIFSEL2	CALL	SELSELECT	; slectione qq objets ...	JUMP,EQ OPENSET$	LOAD.W	D3,#BIPLIT	LIB	?BEEP	JUMP	OPENSET$HELP$:	CALL	_HELPACTION	; aide ...	JUMP	LOOP$EDIT$:	CLR.W	D2		; D2 <-- normal	CALL	SELCLOSE	; ferme le dplacement;;?	CALL	SELOBJCLR	; teint tous les objets	LOAD.L	A4,(A6)+OSELPS	; A4 <-- ^objet	CALL	_LSTO_HCOMPACT	; SELTERMINE, mais sans rafficher !;;?	CALL	SELTERMINE	; dslectionne tout	CALL	_IFMOUSE	; D4 <-- position de la souris	CALL	_CONVSCROBJ	; D4 <-- position [obj]	JUMP	EDIT3SUITE$:	CLR.W	D2		; D2 <-- normal	CALL	SELCLOSE	; ferme le dplacement	CALL	SELOBJCLR	; teint tous les objets	CALL	SELTERMINE	; dslectionne tout	LOAD.L	A4,(A6)+OSELPS	; A4 <-- ^objet	CLR.W	D2		; D2 <-- met [1] au "cdg"	LOAD.W	(A6)+OOUTIL,#ICOOSUITE	JUMP	SUITE3DUPLIQUE$:	LIB	?GETSHIFT	; D3 <-- touches super-shift	TEST.L	D3:#BCHANGE	JUMP',BC DUPL1$	CALL	_DBOXDEFDUPL	; choix du dplacement ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	LOAD.L	(A6)+OSELDV,(A6)+OSELDD	CLR.L	(A6)+OSELDO	; pas d'origine pour dupliqueDUPL1$:	CALL	SELGETREF	; D4 <-- rfrence (y;x)	TEST.L	(A6)+OSELDO	; dplacement depuis dernier duplique ?	JUMP',EQ DUPL3$		; non => DUPL3$	LOAD.L	D3,D4	SUB.W	D3,(A6)+OSELDO+2	SWAP.W	D3	SUB.W	D3,(A6)+OSELDO+0	SWAP.W	D3	TEST.L	D3	JUMP',EQ DUPL3$	LOAD.L	(A6)+OSELDD,D3DUPL3$:	LOAD.L	(A6)+OSELDO,D4	; OSELDO <-- origine pour prochain duplique	CLR.W	D2		; D2 <-- normal	CALL	SELCLOSE	; ferme le dplacement	CALL	SELOBJCLR	; teint tous les objets	CALL	ZONEDUPLIQUE	; duplique tous les objets slectionns	JUMP,NE MENU$	CALL	ZONEMOVEBC	LOAD.L	A2,#R16"DUPLPT$	CALL	ZONEMOVEDC	; dplace en bas  droite selon OSELDD	CALL	ZONEMOVEEC	JUMP	OPENSET$DUPLPT$:	ADD.W	D4,(A6)+OSELDD+2	SWAP.W	D4	ADD.W	D4,(A6)+OSELDD+0	SWAP.W	D4	RETDETRUIT$:	CLR.W	D2		; D2 <-- normal	CALL	SELCLOSE	; ferme le dplacement	CALL	SELOBJCLR	; teint tous les objets	CALL	ZONEDETRUIT	; dtruit tous les objets slectionns	JUMP	MENU$UNDO$:	LOAD.W	D2,#1		; D2 <-- annule	CALL	SELCLOSE	; ferme le dplacement	LOAD.L	D3,(A6)+OZONB1	LOAD.L	D4,(A6)+OZONB2	CALL	DESALLWDO	; redessine toute la fentre initiale	JUMP	MENU$END$:	CLR.W	D2		; D2 <-- normal	CALL	SELCLOSE	; ferme le dplacement	CALL	SELOBJCLR	; teint tous les objets	CALL	SELTERMINE	; dslectionne toutMENU$:;	COMP.W	(A6)+OOUTIL,#ICOOCRAYON;	JUMP',EQ MENU2$	COMP.W	(A6)+OOUTIL,#ICOOLOUPE	JUMP',EQ MENU2$	COMP.W	(A6)+OOUTIL,#ICOOMAIN	JUMP',EQ MENU2$	COMP.W	(A6)+OOUTIL,#ICOOSUITE	JUMP',EQ MENU2$	LOAD.W	(A6)+OOUTIL,#ICOOCRAYONMENU2$:	CLR.W	(A6)+OICONIV	; fin des poignes	CALL	_DESICONE	; remet les icnes  gauche	CALL	_MAJICONE	CALL	_AFMENU		; refait les soft-keys	CALL	_DESINFALL	; remet les informations normales	LOAD.L	A5,#(A6)+OIDPAG	CALL	_INDUPDATE	; mj l'indicateur des pages	LOAD.L	A5,#(A6)+OIDCAL	CALL	_INDUPDATE	; mj l'indicateur des calques	JUMP	LOOP;--------\\; ASCINV$ >;--------/; Inverse le ou les objets slectionns.; in	-; out	-; mod	D7.WASCINV$:	CALL	WDOOPEN		; dessine dans la swdo	INC.W	(A6)+OASNBI	TEST.B	(A6)+OASNBI+1:#0	JUMP',BC ASCSET$ASCCLR$:	CALL	SELPOICLR	; enlve toutes les poignes	CALL	SELRECCLR	; efface le rectangle de slection	CALL	SELINICLR	; efface le dessin initial	JUMP'	ASCEND$ASCSET$:	CALL	SELINISET	; allume le dessin initial	CALL	SELRECSET	; allume le rectangle de slection	CALL	SELPOISET	; remet toutes les poignes;	JUMP'	ASCEND$ASCEND$:	CALL	WDOCLOSE	; fin du dessin dans la swdo	RET;************;;    EDIT    ;;************;EDIT:	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP	LOAD.L	A3,#0	CALL	EDITSELECT	; slectionne un objet ...	JUMP,NE BIPEDIT3:	LOAD.W	(A6)+OOUTED,(A6)+OOUTIL	LOAD.W	(A6)+OOUTIL,#ICOOEDIT	LOAD.W	D1,#opEDITINFO	CALL	_DESINFOBJ	; affiche les informations	CALL	EDITOPEN	; dbut de l'dition pour la chane	LOAD.W	D1,#opEDITICOLIST	CALL	_OBJCALLD	; A3 <-- ^liste des icnes, A2 <-- ^table des softkeys	LOAD.L	(A6)+OICOPH,A3	; OICOPH <-- ^liste des icnes	LOAD.L	(A6)+OICOPS,A2	; OICOPS <-- ^table des soft-keys	LOAD.W	(A6)+OICONIV,#NICOEDIT ; dbut de l'opration	LOAD.W	(A6)+OICOID,(A4)+OobjIDENT ; OICOID <-- identificateur	CALL	_DESICONE	; dessine les icnes de gauche	CALL	_MAJICONE	; mj. les icnes variables	CALL	_AFMENU		; refait les soft-keys	LOAD.L	A5,#(A6)+OIDPAG	CALL	_INDUPDATE	; mj l'indicateur des pages	LOAD.L	A5,#(A6)+OIDCAL	CALL	_INDUPDATE	; mj l'indicateur des calquesLOOP$:	CLR.L	D3	LOAD.W	D1,#opEDITEVENT	CALL	_OBJCALLD	; met  jour si pas terminLOOP1$:	CALL	_UPDICONE	; met  jour l'tat des icnes	CALL	_SCMO		; remet la sourisLOOP2$:	LOAD.W	D3,(A6)+OOUTIL	COMP.W	D3,#ICOOEDIT	JUMP',NE LOOP24$	CALL	_IFMOUSE	; D4 <-- position de la souris	LOAD.W	D1,#opEDITICOOUTIL	CALL	_OBJCALLD	; D3 <-- icne pour la souris	JUMP',EQ LOOP24$	LOAD.W	D3,#ICOOEDITLOOP24$:	CALL	_SELMO		; utilise le bon lutinLOOP5$:	LOAD.W	D3,#15		; D3 <-- attente maximale	CALL	_WAITEVENT	; attend vnement ...	JUMP',NE TIMO$	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,EQ LOOP2$		; oui => LOOP2$	JUMP'	EVENT$TIMO$:	LOAD.L	D3,#KEYTIMO	; D3 <-- "touche" spciale	LOAD.W	D1,#opEDITEVENT	CALL	_OBJCALLD	; donne l'vnement  l'objet	JUMP	LOOP5$EVENT$:;;?	COMP.W	D3,#KEYMGR;;?	JUMP,EQ LOOP5$;;?	COMP.W	D3,#KEYMMR	; bouton relch ?;;?	JUMP,EQ LOOP5$		; oui => LOOP5$;;?	COMP.W	D3,#KEYMDR;;?	JUMP,EQ LOOP5$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#KEYMMP	; bouton press ?	JUMP,EQ CLIC$		; oui => CLIC$	COMP.W	D3,#KEYMDP	JUMP,EQ CLIC$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#HELP	JUMP,EQ HELP$	LOAD.W	D1,#opEDITEVENT	CALL	_OBJCALLD	; donne l'vnement  l'objet	JUMP,NE ERROR$	CALL	_TESTEVENT	; touche presse pendant le traitement de l'vnement ?	JUMP,EQ LOOP5$		; oui => LOOP5$	CALL	SUITEOBJCURS	; A4 <-- ^objet o est le curseur	CALL	SUITEVISU	; dplace v. pour voir le curseur	JUMP	LOOP1$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOP$ERROR$:	COMP.W	D7,#ERPBIP	JUMP,EQ BIP$	CALL	_DBOXERROR	; affiche l'erreur ...	JUMP	LOOP$CLICM$:	LOAD.W	D1,#opEDITMMENU	CALL	_OBJCALLD	; mmenu du bouton du milieu	JUMP,NE BIP$	JUMP	LOOP$CLIC$:	COMP.W	D3,#KEYMMP	JUMP,EQ CLICM$	LOAD.W	D0,D3		; D0 <-- bouton press	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP$	LOAD.L	A1,#R16"ASCINV$	CALL	_DOMASCENSEUR	; agit dans ascenseurs selon souris	JUMP,EQ LOOP$	LOAD.L	A5,#(A6)+OIDCAL	; A5 <-- ^indicateur des calques	CALL	_INDMOVE	; change de calque ...	JUMP,EQ DCALQUE$	LOAD.L	A5,#(A6)+OIDPAG	; A5 <-- ^indicateur des pages	CALL	_INDMOVE	; change de page ...	JUMP,EQ DPAGE$	LOAD.W	D3,D0		; D3 <-- bouton press	LOAD.W	D1,#opBUTTON	CALL	_OBJCALLD	; indique le bouton utilis	CALL	_MOVICONE	; souris dans une icne ?	JUMP',EQ ICONE$		; oui => ICONE$	CALL	_DPLICONE	; dplace toutes les icnes ?	JUMP,EQ LOOP$		; oui => LOOP$	COMP.W	D0,#KEYMGP	JUMP,EQ CLICG$	COMP.W	D0,#KEYMDP	JUMP,EQ CLICD$	JUMP	BIP$ICONE$:	COMP.W	D3,#ICOOCRAYON	JUMP,EQ HAND$	COMP.W	D3,#ICOOLOUPE	JUMP,EQ OUTIL$	COMP.W	D3,#ICOOMAIN	JUMP,EQ OUTIL$	COMP.W	D3,#ICOOFLECHE	JUMP,EQ HAND$	COMP.W	D3,#ICOOOPER	JUMP,EQ HAND$	COMP.W	D3,#ICOOEDIT	JUMP,EQ OUTIL$	COMP.W	D3,#ICOOGROUPE	JUMP,EQ HAND$	COMP.W	D3,#ICOOPLAN	JUMP,EQ HAND$	COMP.W	D3,#ICOOSUITE	JUMP,EQ SUITE$	COMP.W	D3,#ICODACCORD	JUMP,EQ END$	COMP.W	D3,#ICOANNULE	JUMP,EQ UNDO$	CALL	SELICONE	; action selon l'icne clique	JUMP,EQ LOOP$	CALL	SUITEOBJCURS	; A4 <-- ^objet o est le curseur	CLR.L	D4	LOAD.W	D1,#opEDITICOGET	CALL	_OBJCALLD	; D4/A3 <-- tat/^liste	LOAD.L	D5,D4	TEST.L	D5:#BSTICOCHGDRAW ; faut-il changer le dessin ?	JUMP',BC ICONE23$	; non => ICONE23$	LOAD.L	D2,#2^BVUECLR!2^BVUEPROV!2^BVUEPROVI	LOAD.L	A1,#R16"DESOBJET	CALL	SUITEEXEC	; efface les objets;;?	CALL	DESOBJET	; efface l'objetICONE23$:	LOAD.W	D1,#opEDITICOMOD	CALL	_OBJCALLD	; agit dans l'objet selon l'ine clique ...	JUMP',NE ICONE3$	ADD.W	(A6)+OGBBOX,D4	; OGBBOX <-- nb de modificationsICONE3$:	PUSH.W	D7	TEST.L	D5:#BSTICOCHGDRAW ; faut-il changer le dessin ?	JUMP',BC ICONE43$	; non => ICONE43$	LOAD.L	D2,#2^BVUESET!2^BVUEPROV!2^BVUEPROVI	LOAD.L	A1,#R16"DESOBJET	CALL	SUITEEXEC	; redessine les objets;;?	CALL	DESOBJET	; redessine l'objetICONE43$:	TEST.L	D5:#BSTICOCHGUPIC ; faut-il changer l'icne ?	JUMP',BC ICONE44$	; non => ICONE44$	CALL	_DESICONEONE	; redessine l'icneICONE44$:	TEST.L	D5:#BSTICOCHGUPLI ; faut-il changer une liste d'icnes ?	JUMP',BC ICONE46$	; non => ICONE46$ICONE45$:	LOAD.W	D3,(A3+)	JUMP',EQ ICONE46$	CALL	_DESICONEONE	; redessine une icne	JUMP	ICONE45$ICONE46$:	POP.W	D7	JUMP,NE BIP$	JUMP	LOOP$OUTIL$:	COMP.W	D3,(A6)+OOUTIL	JUMP,EQ BIP$	LOAD.W	(A6)+OOUTIL,D3	CALL	_DESICONE	; dessine les icnes de gauche	CALL	_MAJICONE	; mj. les icnes variables	JUMP	LOOP$CLICD$:	CALL	_CONVSCROBJ	; D4 <-- position [obj]	JUMP,NE BIP$	JUMP'	MOVE1$CLICG$:	COMP.W	(A6)+OOUTIL,#ICOOLOUPE	JUMP,EQ LOUPE$	COMP.W	(A6)+OOUTIL,#ICOOMAIN	JUMP,EQ MAIN$	COMP.W	(A6)+OLUTIN,#ICOOEDIT	JUMP,NE REGLE$	LOAD.L	D3,D4	CALL	_CONVSCROBJ	; D4 <-- position [obj]	JUMP,NE BIP$	LOAD.L	A3,A4	CALL	DEEOBJET	; A4 <-- ^objet montr	EX.L	A3,A4	JUMP',NE MOVE1$	CALL	SUITEIFSAME	; objet montr dans mme chane que objet actuel ?;;?	COMP.L	A3,A4		; objet montr = objet actuel ?	JUMP,NE RESEL$		; non => RESEL$MOVE1$:	SUB.W	D4,(A6)+OAPOS+2	SWAP.W	D4	SUB.W	D4,(A6)+OAPOS+0	SWAP.W	D4	CALL	WDOOPEN		; dessine dans la swdo	LOAD.W	D3,#EDITMOVEBEGIN ; D3 <-- dbut	LOAD.W	D1,#opEDITMOVE	CALL	_OBJCALLD	; indique le dbut du dplacement	PUSH.W	D7	CALL	WDOCLOSE	; fin du dessin dans la swdo	POP.W	D7	JUMP,NE BIP$MOVE2$:	CALL	_SCMO		; remet la souris	CALL	_WAITMOVE	; attend dplacement souris ...	JUMP',NE MOVE8$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE MOVE2$	CALL	_CONVSCROBJ	; D4 <-- point o est la souris	JUMP,NE MOVE2$	SUB.W	D4,(A6)+OAPOS+2	SWAP.W	D4	SUB.W	D4,(A6)+OAPOS+0	SWAP.W	D4	CALL	WDOOPEN		; dessine dans la swdo	LOAD.W	D3,#EDITMOVEDRAG ; D3 <-- dplacement	LOAD.W	D1,#opEDITMOVE	CALL	_OBJCALLD	; dplace la poigne	CALL	WDOCLOSE	; fin du dessin dans la swdo	JUMP	MOVE2$MOVE8$:	CALL	WDOOPEN		; dessine dans la swdo	LOAD.W	D3,#EDITMOVEEND	; D3 <-- fin	LOAD.W	D1,#opEDITMOVE	CALL	_OBJCALLD	; indique la fin du dplacement	PUSH.W	D7	CALL	WDOCLOSE	; fin du dessin dans la swdo	POP.W	D7	JUMP,NE ERROR$	JUMP	LOOP$REGLE$:	LOAD.W	D3,#EDITMOVEREGLE ; D3 <-- rgle	LOAD.W	D1,#opEDITMOVE	CALL	_OBJCALLD	; action dans la rgle	COMP.W	D7,#ERPBIP	JUMP,EQ LOOP$	TEST.W	D7	JUMP,NE BIP$	ADD.W	(A6)+OGBBOX,D4	; OGBBOX <-- nb de modifications	JUMP	LOOP$DCALQUE$:	TEST.W	D3	JUMP,NS BIP$	SUB.W	D3,(A5)+OIDHTV	NEG.W	D3	DEC.W	D3	LOAD.W	D4,D3		; D4 <-- calque o dplacer	LOAD.W	D3,(A6)+OPAGE	; D3 <-- reste dans la mme page	JUMP'	DCHANGE$DPAGE$:	TEST.W	D3	JUMP,NS BIP$;	LOAD.W	D3,D3		; D3 <-- page o dplacer	CLR.W	D4		; D4 <-- le dernier calque !DCHANGE$:	LOAD.W	(A6)+OPAGE,D3	LOAD.W	(A6)+OCALQ,D4	CALL	WORKPAGE	; travaille dans une nouvelle page	CALL	WORKCALQUE	; travaille dans un nouveau calque	CALL	SUITEIFDRAW	; indique les objets  dessiner	INC.W	(A6)+OGDRAW	; il faudra tout redessiner	CALL	DESREFAIT	; refait le dessin	CLR.L	D3	LOAD.W	D1,#opEDITEVENT	CALL	_OBJCALLD	; affiche tous les objets de la chane	LOAD.L	A5,#(A6)+OIDPAG	CALL	_INDUPDATE	; mj l'indicateur des pages	LOAD.L	A5,#(A6)+OIDCAL	CALL	_INDUPDATE	; mj l'indicateur des calques	JUMP	LOOP$LOUPE$:	CALL	LOUPOUTIL	; D1/D2/D3 <-- P1/P2/suivant	JUMP,NE BIP$	CALL	LOUPSCALE	; D4 <-- nouvelle chelle	JUMP,NE BIP$	CALL	ASCINV$		; teint la slection	CALL	LOUPDRAW	; affiche  la nouvelle chelle	CALL	ASCINV$		; allume la slection	JUMP	LOOP$MAIN$:	CALL	ASCINV$		; teint la slection	CALL	MAINMOVE	; dplace selon la main ...	PUSH.W	D7	CALL	ASCINV$		; allume la slection	POP.W	D7	JUMP,NE BIP$	JUMP	LOOP$HELP$:	CALL	_HELPACTION	; aide ...	JUMP	LOOP$RESEL$:	LOAD.L	D4,D3		; D4 <-- position de la souris [scr]	LOAD.L	A3,A4		; A3 <-- ^objet actuel	CALL	EDITSELECT	; slectionne un objet ...	EX.L	A3,A4		; A3 <-- ^nouveau, A4 <-- ^actuel	JUMP,NE BIP$RESEL5$:	CLR.W	D2		; D2 <-- normal	CALL	EDITCLOSE	; fin de l'dition pour la chane	CALL	SUITEDRAW	; redessine les objets de la chane dans la page	LOAD.L	A4,A3		; A4 <-- ^nouvel objet	JUMP	EDIT3HAND$:	LOAD.W	D0,D3		; D0 <-- outil	CALL	SUITEOBJCURS	; A4 <-- ^objet o est le curseur	CLR.W	D2		; D2 <-- normal	CALL	EDITCLOSE	; fin de l'dition pour la chane	TEST.W	(A6)+OGBBOX	; y a-t-il eu des modifications ?	JUMP',NE HAND4$		; oui => HAND4$	TSET.B	(A4)+OobjFLAGS:#BobjEXTEND	CALL	SUITEDRAW	; redessine tout dans la page (sans l'objet)	TCLR.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP'	HAND6$HAND4$:	TSET.B	(A4)+OobjFLAGS:#BobjEXTEND	CALL	DESREFAIT	; refait le dessin	TCLR.B	(A4)+OobjFLAGS:#BobjEXTEND	LOAD.L	D2,#2^BVUECLR!2^BVUEPROV!2^BVUEPROVI!2^BVUEPROVE	CALL	DESOBJET	; efface l'objetHAND6$:	LOAD.W	D3,D0		; D3 <-- outil	JUMP	SELONESUITE$:	CALL	SUITEOBJCURS	; A4 <-- ^objet o est le curseur	CLR.W	D2		; D2 <-- normal	CALL	EDITCLOSE	; fin de l'dition pour la chane	CALL	SUITEDRAW	; redessine les objets de la chane dans la page	CALL	SUITEFLUSH	; annuleSUITEP$:	CALL	SUITEPREV	; A4 <-- ^objet prcdent	JUMP,EQ SUITEP$SUITEN$:	CLR.W	D2		; D2 <-- met [n] au "cdg"	CALL	SUITEADD	; slectionne un objet	JUMP',NE SUITEF$	CALL	SUITENEXT	; A4 <-- ^objet suivant	JUMP,EQ SUITEN$SUITEF$:	LOAD.W	(A6)+OOUTIL,#ICOOSUITE	JUMP	SUITE4UNDO$:	LOAD.W	D2,#1		; D2 <-- annule	CALL	EDITCLOSE	; fin de l'dition pour la chane	CALL	SUITEDRAW	; redessine les objets de la chane dans la page	JUMP'	MENU$END$:	CLR.W	D2		; D2 <-- normal	CALL	EDITCLOSE	; fin de l'dition pour la chane	CALL	SUITEDRAW	; redessine les objets de la chane dans la pageMENU$:	LOAD.W	D3,(A6)+OOUTED	COMP.W	D3,#ICOOCRAYON	JUMP',EQ MENU2$	COMP.W	D3,#ICOOLOUPE	JUMP',EQ MENU2$	COMP.W	D3,#ICOOMAIN	JUMP',EQ MENU2$	COMP.W	D3,#ICOOEDIT	JUMP',EQ MENU2$	COMP.W	D3,#ICOOSUITE	JUMP',EQ MENU2$	LOAD.W	D3,#ICOOCRAYONMENU2$:	LOAD.W	(A6)+OOUTIL,D3	CALL	HANDUNDOFLUSH	; annule le UNDO	CLR.W	(A6)+OICONIV	; fin des poignes	CALL	_DESICONE	; remet les icnes  gauche	CALL	_MAJICONE	CALL	_AFMENU		; refait les soft-keys	CALL	_DESINFALL	; remet les informations normales	JUMP	LOOP;--------\\; ASCINV$ >;--------/; Inverse l'objet en cours d'dition.; in	A4.L	^objet; out	-; mod	D7.WASCINV$:	INC.W	(A6)+OASNBI	TEST.B	(A6)+OASNBI+1:#0	JUMP',BC ASCSET$ASCCLR$:	CALL	SUITECLRREGLE	; enlve la rgle	JUMP'	ASCEND$ASCSET$:	CALL	SUITESETREGLE	; remet la rgle;	JUMP'	ASCEND$ASCEND$:	RET;*************;;    SUITE    ;;*************;SUITE:	CALL	_CONVSCROBJ	; D4 <-- position [obj]	JUMP,NE BIP	CALL	SUITESELECT	; A4/D2 <-- ^objet/poigne	JUMP,NE BIPSUITE3:	CALL	SUITEFLUSH	; annule	CALL	SUITEADD	; slectionne un objetSUITE4:	CALL	SUITESETALL	; montre	LOAD.W	(A6)+OICONIV,#NICOSUITE ; dbut de l'opration	CALL	_DESICONE	; dessine les icnes de gauche	CALL	_MAJICONE	; mj. les icnes variables	CALL	_AFMENU		; refait les soft-keys	LOAD.L	A5,#(A6)+OIDPAG	CALL	_INDUPDATE	; mj l'indicateur des pages	LOAD.L	A5,#(A6)+OIDCAL	CALL	_INDUPDATE	; mj l'indicateur des calquesLOOP$:	CALL	_UPDICONE	; met  jour l'tat des icnes	CALL	_SCMO		; remet la sourisLOOP2$:	LOAD.W	D3,(A6)+OOUTIL	CALL	_SELMO		; utilise le bon lutin	CALL	SELINFOXY	; affiche X= et Y= dans les informations	CALL	_WAITMOVE	; attend dplacement souris ...	COMP.W	D3,#KEYMPO	JUMP,EQ LOOP2$	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#KEYMMP	JUMP,EQ CLIC$	COMP.W	D3,#KEYMDP	JUMP,EQ CLIC$KEY$:	LOAD.W	D2,D3	LIB	?MINMAJ	EX.L	D2,D3	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#CR	JUMP,EQ END$	COMP.W	D3,#HELP	JUMP,EQ HELP$	COMP.W	D3,#BS	JUMP,EQ RAZ$	COMP.W	D3,#DEL	JUMP,EQ RAZ$	COMP.W	D3,#DELETE	JUMP,EQ RAZ$	COMP.W	D3,#CLEAR	JUMP,EQ RAZ$	COMP.W	D3,#DEFINE	JUMP,EQ MOVEI$	COMP.W	D2,#H'100*(2^BCHANGE)+'A	JUMP,EQ VUE$	COMP.W	D2,#H'100*(2^BCHANGE)+'G	JUMP,EQ GRID$	COMP.W	D2,#H'100*(2^BCHANGE)+'R	JUMP,EQ COL$	COMP.W	D2,#H'100*(2^BCHANGE)+'S	JUMP,EQ HORVERT$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOP$ERROR$:	COMP.W	D7,#ERPBIP	JUMP,EQ BIP$	CALL	_DBOXERROR	; affiche l'erreur ...	JUMP	LOOP$CLICM$:	CALL	MMMENUINIT	; A4 <-- ^paramtres	TSET.B	(A4)+(LMM*0)+OMMINA+3:#4 ; grise la case "opration"	TSET.B	(A4)+(LMM*0)+OMMINA+3:#5 ; grise la case "dfinitions"	TSET.B	(A4)+(LMM*1)+OMMINA+3:#0 ; grise la case "prend"	TSET.B	(A4)+(LMM*1)+OMMINA+3:#1 ; grise la case "ajoute"	TSET.B	(A4)+(LMM*1)+OMMINA+3:#2 ; grise la case "sauve"	TSET.B	(A4)+(LMM*1)+OMMINA+3:#3 ; grise la case "imprime"	TEST.L	(A6)+OPHELP	; fichier d'aide charg ?	JUMP',NE MHELP$		; oui => MHELP$	TSET.B	(A4)+(LMM*2)+OMMINA+3:#2 ; grise la case "aide"MHELP$:	CALL	MMMENUCHOIX	; choix selon mmenu ...	JUMP,NE BIP$	TEST.W	D3	JUMP,EQ LOOP$	JUMP	KEY$VUE$:	CALL	_DBOXVUE	; choix de la vue ...	JUMP,NE ERROR$	COMP.W	D3,#F1	JUMP,NE LOOP$	JUMP	REFAIT$GRID$:	CALL	_DBOXGRID	; choix de la grille ...	JUMP,NE ERROR$	COMP.W	D3,#F1	JUMP,NE LOOP$	JUMP	REFAIT$COL$:	CALL	_DBOXCOLONNES	; nombre de colonnes ...	JUMP,NE ERROR$	COMP.W	D3,#F1	JUMP,NE LOOP$	SET.B	(A6)+OMAJ	; mise  jour sur disque ncessaire	JUMP	REFAIT$HORVERT$:	CALL	_DBOXHORVERT	; choix contrainte ...	JUMP,NE ERROR$	JUMP	LOOP$REFAIT$:	CALL	ASCINV$		; teint la slection	CALL	DESOBJETS	; redessine tous les objets	CALL	ASCINV$		; allume la slection	JUMP	LOOP$CLIC$:	COMP.W	D3,#KEYMMP	JUMP,EQ CLICM$	LOAD.W	D0,D3		; D0 <-- bouton press	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP$	LOAD.L	A1,#R16"ASCINV$	CALL	_DOMASCENSEUR	; agit dans ascenseurs selon souris	JUMP,EQ LOOP$	LOAD.L	A5,#(A6)+OIDCAL	; A5 <-- ^indicateur des calques	CALL	_INDMOVE	; change de calque ...	JUMP,EQ DCALQUE$	LOAD.L	A5,#(A6)+OIDPAG	; A5 <-- ^indicateur des pages	CALL	_INDMOVE	; change de page ...	JUMP,EQ DPAGE$	CALL	_MOVICONE	; souris dans une icne ?	JUMP',EQ ICONE$		; oui => ICONE$	CALL	_DPLICONE	; dplace toutes les icnes ?	JUMP,EQ LOOP$		; oui => LOOP$	CALL	_ICAMOVE	; souris dans le cadre ?	JUMP,EQ CADRE$		; oui => CADRE$	COMP.W	D0,#KEYMGP	JUMP,EQ CLICG$	COMP.W	D0,#KEYMDP	JUMP,EQ CLICD$	JUMP	BIP$ICONE$:	COMP.W	D3,#ICOOLOUPE	JUMP',EQ OUTIL$	COMP.W	D3,#ICOOMAIN	JUMP',EQ OUTIL$	COMP.W	D3,#ICOOSUITE	JUMP',EQ OUTIL$	COMP.W	D3,#ICOOFLECHE	JUMP,EQ HAND$	COMP.W	D3,#ICOOOPER	JUMP,EQ HAND$	COMP.W	D3,#ICOOGROUPE	JUMP,EQ HAND$	COMP.W	D3,#ICOOPLAN	JUMP,EQ HAND$	COMP.W	D3,#ICOOEDIT	JUMP,EQ EDIT$	COMP.W	D3,#ICOSCOULE	JUMP,EQ COULE$	COMP.W	D3,#ICOSLIBERE	JUMP,EQ LIBERE$	COMP.W	D3,#ICOSMOVE	JUMP,EQ MOVE$	COMP.W	D3,#ICOSMOVEI	JUMP,EQ MOVEI$	COMP.W	D3,#ICOSRAZ	JUMP,EQ RAZ$	COMP.W	D3,#ICODACCORD	JUMP,EQ END$	CALL	SELICONE	; action selon l'icne clique	JUMP,EQ LOOP$	JUMP	BIP$OUTIL$:	COMP.W	D3,(A6)+OOUTIL	JUMP,EQ BIP$	LOAD.W	(A6)+OOUTIL,D3	CALL	_DESICONE	; dessine les icnes de gauche	CALL	_MAJICONE	; mj. les icnes variables	JUMP	LOOP$COULE$:	CALL	ASCINV$		; teint la slection	CALL	SUITECOULE	; fait couler	INC.W	(A6)+OGDRAW	; il faudra tout redessiner	CALL	DESREFAIT	; refait le dessin	CALL	ASCINV$		; allume la slection	JUMP	LOOP$LIBERE$:	CALL	ASCINV$		; teint la slection	CALL	SUITELIBERE	; fait couler	INC.W	(A6)+OGDRAW	; il faudra tout redessiner	CALL	DESREFAIT	; refait le dessin	CALL	ASCINV$		; allume la slection	JUMP	LOOP$MOVE$:	CALL	SUITEIHAND	; initialise les paramtres	CALL	_DBOXMOVE	; demande le dplacement ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$MOVEI$:	CALL	ASCINV$		; teint la slection	CALL	SUITEMHAND	; dplace les poignes	CALL	ASCINV$		; allume la slection	JUMP	LOOP$RAZ$:	CALL	ASCINV$		; teint la slection	CALL	SUITEFLUSH	; annule	CALL	ASCINV$		; allume la slection	JUMP	LOOP$CLICD$:	CALL	_CONVSCROBJ	; D4 <-- position [obj]	JUMP,NE BIP$	CALL	SUITECLRALL	; efface tout	PUSH.L	D4	LOAD.W	D3,(A6)+OPAGE	; D3 <-- page visible	LOAD.W	D4,(A6)+OCALQ	; D4 <-- calque visible	LOAD.L	D6,(A6)+OOBACH	; D6 <-- canal de l'arbre des objets	CALL	_LSTA_BEGIN	; A4 <-- ^objet de base	POP.L	D4	LOAD.L	(A6)+OSELPS,A4	CLR.W	(A6)+OSELNB	LOAD.L	A1,#R16"HANDIFSEL1	CALL	SELSELECT	; slectione qq objets ...	JUMP',NE SEL8$	LOAD.W	D3,#ICOOFLECHE	JUMP	SELGOSEL8$:	CALL	SUITESETALL	; montre tout	JUMP	BIP$CLICG$:	COMP.W	(A6)+OOUTIL,#ICOOLOUPE	JUMP,EQ LOUPE$	COMP.W	(A6)+OOUTIL,#ICOOMAIN	JUMP,EQ MAIN$	CALL	_CONVSCROBJ	; D4 <-- position [obj]	JUMP,NE BIP$	CALL	SUITESELECT	; A4/D2 <-- ^objet/poigne	JUMP,NE BIP$	CALL	SUITECLRALL	; efface tout	CALL	SUITEADD	; slectionne un objet	CALL	SUITESETALL	; montre tout	JUMP	LOOP$DCALQUE$:	TEST.W	D3	JUMP,NS BIP$	SUB.W	D3,(A5)+OIDHTV	NEG.W	D3	DEC.W	D3	LOAD.W	D4,D3		; D4 <-- calque o dplacer	LOAD.W	D3,(A6)+OPAGE	; D3 <-- reste dans la mme page	JUMP'	DCHANGE$DPAGE$:	TEST.W	D3	JUMP,NS BIP$;	LOAD.W	D3,D3		; D3 <-- page o dplacer	CLR.W	D4		; D4 <-- le dernier calque !DCHANGE$:	CALL	ASCINV$	LOAD.W	(A6)+OPAGE,D3	LOAD.W	(A6)+OCALQ,D4	CALL	WORKPAGE	; travaille dans une nouvelle page	CALL	WORKCALQUE	; travaille dans un nouveau calque	INC.W	(A6)+OGDRAW	; il faudra tout redessiner	CALL	DESREFAIT	; refait le dessin	CALL	ASCINV$	LOAD.L	A5,#(A6)+OIDPAG	CALL	_INDUPDATE	; mj l'indicateur des pages	LOAD.L	A5,#(A6)+OIDCAL	CALL	_INDUPDATE	; mj l'indicateur des calques	JUMP	LOOP$LOUPE$:	CALL	LOUPOUTIL	; D1/D2/D3 <-- P1/P2/suivant	JUMP,NE BIP$	CALL	LOUPSCALE	; D4 <-- nouvelle chelle	JUMP,NE BIP$	CALL	ASCINV$		; teint la slection	CALL	LOUPDRAW	; affiche  la nouvelle chelle	CALL	ASCINV$		; allume la slection	JUMP	LOOP$MAIN$:	CALL	ASCINV$		; teint la slection	CALL	MAINMOVE	; dplace selon la main ...	PUSH.W	D7	CALL	ASCINV$		; allume la slection	POP.W	D7	JUMP,NE BIP$	JUMP	LOOP$CADRE$:	TEST.W	D2	JUMP',EQ SCALE$	JUMP	BIP$SCALE$:	CALL	GMMENUSCALE	; choix de l'chelle ...	JUMP,NE LOOP$	CALL	ASCINV$		; teint la slection	CALL	LOUPDRAW	; affiche  la nouvelle chelle	CALL	ASCINV$		; allume la slection	JUMP	LOOP$HAND$:	CALL	SUITECLRALL	; efface tout	LOAD.L	A4,(A6)+OSSTA+OSSOBJ ; A4 <-- ^objet	CALL	DESCLEAR	; efface l'objet	JUMP	SELONEEDIT$:	CALL	SUITECLRALL	; efface tout	LOAD.L	A4,(A6)+OSSTA+OSSOBJ ; A4 <-- ^objet	JUMP	EDIT3HELP$:	CALL	_HELPACTION	; aide ...	JUMP	LOOP$END$:	CALL	SUITECLRALL	; efface toutMENU$:	CLR.W	(A6)+OICONIV	; fin des poignes	CALL	_DESICONE	; remet les icnes  gauche	CALL	_MAJICONE	CALL	_AFMENU		; refait les soft-keys	CALL	_DESINFALL	; remet les informations normales	JUMP	LOOP;--------\\; ASCINV$ >;--------/; Inverse l'objet en cours d'dition.; in	-; out	-; mod	D7.WASCINV$:	CALL	WDOOPEN		; dessine dans la swdo	INC.W	(A6)+OASNBI	TEST.B	(A6)+OASNBI+1:#0	JUMP',BC ASCSET$ASCCLR$:	CALL	SUITECLRALL	; teint tout	JUMP'	ASCEND$ASCSET$:	CALL	SUITESETALL	; allume tout;	JUMP'	ASCEND$ASCEND$:	CALL	WDOCLOSE	; fin du dessin dans la swdo	RET;*************;;    LOUPE    ;;*************;LOUPE:	CALL	LOUPOUTIL	; D1/D2/D3 <-- P1/P2/suivant	JUMP,NE BIPLOUPES:	CALL	LOUPSCALE	; D4 <-- nouvelle chelle	JUMP,NE BIPLOUPEQ:	CALL	LOUPDRAW	; affiche  la nouvelle chelle	JUMP	LOOP;----------\\; LOUPOUTIL >;==========/; Cherche la position et le sous-outil.; in	-; out	D1.L	P1 de la souris (y;x);	D2.L	P2 de la souris (y;x);	D3.W	+1/-1 pour suivant/prcdent;	D7.W	erreur; mod	D1.L, D2.L, D3.L, D7.WLOUPOUTIL:	PUSH.L	D4	PUSH.L	(A6)+OZONY1	PUSH.L	(A6)+OZONY2	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE EXIT$	CALL	_CONVSCROBJ	; D4 <-- position [obj]	JUMP,NE EXIT$	LOAD.L	(A6)+OZONY1,D4	LOAD.L	(A6)+OZONY2,D4	LOAD.W	D2,#1		; D2 <-- open	CALL	DESISHIFTZ	; dessine le premier rectangleLOOP$:	CALL	_DESINFXY	; affiche X= et Y= dans les informations	LOAD.W	D2,#2		; D2 <-- shift	CALL	DESISHIFTZ	; fait tourner le traitill	CALL	_WAITMOVES	; attend dplacement ...	JUMP',NE END$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE LOOP$	CALL	_CONVSCROBJ	; D4 <-- point o est la souris	JUMP,NE LOOP$	COMP.L	D4,(A6)+OZONY2	; position change ?	JUMP,EQ LOOP$		; non => ZLOOP$				; oui =>	LOAD.W	D2,#3		; D2 <-- close	CALL	DESISHIFTZ	; efface l'ancien rectangle	LOAD.L	(A6)+OZONY2,D4	LOAD.W	D2,#1		; D2 <-- open	CALL	DESISHIFTZ	; dessine le nouveau rectangle	JUMP	LOOP$END$:	LOAD.W	D2,#3		; D2 <-- close	CALL	DESISHIFTZ	; efface le dernier rectangle	LOAD.L	D4,(A6)+OZONY1	CALL	_CONVOBJSCR	LOAD.L	D3,D4	LOAD.L	D4,(A6)+OZONY2	CALL	_CONVOBJSCR	CALL	ORDONNE	SUB.W	D4,D3	COMP.W	D4,#4		; largeur >4 points cran ?	JUMP',LO CLIC$		; oui => CLIC$	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	COMP.W	D4,#4		; hauteur >4 points cran ?	JUMP',LO CLIC$		; oui => CLIC$	LOAD.L	D3,(A6)+OZONY1	LOAD.L	D4,(A6)+OZONY2	CALL	ORDONNE	LOAD.L	D1,D3		; D1 <-- P1	LOAD.L	D2,D4		; D2 <-- P2	LOAD.W	D3,#+1		; D3 <-- suivante	JUMP'	OK$CLIC$:	LOAD.L	D1,(A6)+OZONY1	; D1 <-- P1	LOAD.L	D2,D1		; D2 <-- P2	LOAD.W	D3,#+1		; D3 <-- suivante	COMP.W	(A6)+OLOUPE,#ICOOLOUPEP	JUMP',EQ OK$	LOAD.W	D3,#-1		; D3 <-- prcdenteOK$:	CLR.W	D7EXIT$:	POP.L	(A6)+OZONY2	POP.L	(A6)+OZONY1	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; LOUPSCALE >;==========/; Cherche l'chelle  utiliser.; in	D1.L	P1 de la souris (y;x);	D2.L	P2 de la souris (y;x);	D3.W	+1/-1 pour suivant/prcdent; out	D1.L	nouvelle position (y;x);	D4.W	nouvelle chelle;	D7.W	erreur; mod	D1.L, D4.L, D7.WLOUPSCALE:	PUSHM.L	D2,D3,D5,D6	COMP.L	D1,D2		; P1 = P2 ?	JUMP',NE ZONE$		; non => ZONE$	LOAD.W	D4,(A6)+OSCA100	; D4 <-- chelle pour 100%	TEST.W	D3	JUMP,EQ OK$	CALL	_NEXTSCALE	; D4 <-- nouvelle chelle	JUMP	EXIT$ZONE$:	LOAD.W	D3,D2	SUB.W	D3,D1		; D3 <-- largeur souhaite	SWAP.W	D1	SWAP.W	D2	LOAD.W	D4,D2	SUB.W	D4,D1		; D4 <-- hauteur souhaite	SWAP.W	D1	SWAP.W	D2	LOAD.W	D5,(A6)+ODESX2	SUB.W	D5,(A6)+ODESX1	; D5 <-- largeur visible	MUL.WA	D5,#100	DIV.WA	D5,D3		; D5 <-- rapport horizontal *100	LOAD.W	D6,(A6)+ODESY2	SUB.W	D6,(A6)+ODESY1	; D6 <-- hauteur visible	MUL.WA	D6,#100	DIV.WA	D6,D4		; D6 <-- rapport vertical *100	ADD.W	D5,D6	ASR.W	D5,#1		; D5 <-- AVE(Rx,Ry)	LOAD.W	D3,#64	LOAD.W	D4,(A6)+OSCALE	JUMP',EQ IN$	JUMP',NS INN$INP$:	DIV.WU	D3,D4	JUMP'	IN$INN$:	NEG.W	D4	MUL.WU	D3,D4;	JUMP'	IN$IN$:	MUL.WA	D3,#100	DIV.WA	D3,D5		; D3 <-- nouvelle chelle (..64..)	COMP.W	D3,#64	JUMP',HI OUTN$OUTP$:	LOAD.L	D4,#64	DIV.WU	D4,D3	COMP.W	D4,#1	JUMP',EQ OUT0$	JUMP'	OUT$OUTN$:	CLR.L	D4	LOAD.W	D4,D3	DIV.WU	D4,#64	COMP.W	D4,#1	JUMP',EQ OUT0$	NEG.W	D4	JUMP'	OUT$OUT0$:	CLR.W	D4OUT$:	CALL	_PROXSCALE	; D4 <-- chelle la plus proche	SUB.W	D2,D1	ASR.W	D2,#1	ADD.W	D2,D1	SWAP.W	D1	SWAP.W	D2	SUB.W	D2,D1	ASR.W	D2,#1	ADD.W	D2,D1;	SWAP.W	D1	SWAP.W	D2	LOAD.L	D1,D2		; D1 <-- nouvelle positionOK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2,D3,D5,D6	TEST.W	D7		; retour EQ/NE	RET;---------\\; LOUPDRAW >;=========/; Affiche selon une nouvelle chelle.; in	D1.L	nouvelle position (y;x);	D4.W	nouvelle chelle; out	-; mod	D7.WLOUPDRAW:	PUSHM.L	D1,D4	LOAD.W	(A6)+OSCALE,D4	LOAD.L	D4,(A6)+OWDOY2	SUB.W	D4,(A6)+OWDOX1	SR.W	D4,#1	SWAP.W	D4	SUB.W	D4,(A6)+OWDOY1	SR.W	D4,#1	SWAP.W	D4	CALL	_SCALEN	SUB.W	D1,D4	SWAP.W	D4	SWAP.W	D1	SUB.W	D1,D4;	SWAP.W	D4	SWAP.W	D1	LOAD.L	D4,D1	CALL	_CLIPPOS	; D4 <-- position clippe et arrondie	LOAD.L	(A6)+ODESY1,D4	CALL	_DESINFSCALE	; affiche l'chelle	CALL	_MAJCADRE	; mj cadre (ascenseurs et rgles)	CALL	DESOBJETS	; redessine tous les objets	POPM.L	D1,D4	RET;************;;    MAIN    ;;************;MAIN:	CALL'	MAINMOVE	; dplace selon la main ...	JUMP,NE BIP	JUMP	LOOP;---------\\; MAINMOVE >;=========/; Dplace la vue selon la main.; in	-; out	D7.W	erreur; mod	D7.WMAINMOVE:	PUSHM.L	D3..D6	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE EXIT$	LOAD.L	D5,D4	LOAD.L	D6,(A6)+ODESY1	LOAD.W	D3,#ICOOMAIN	CALL	_SELMO		; utilise le bon lutinLOOP$:	CALL	_SCMO		; remet la souris	CALL	_WAITMOVE	; attend dplacement souris ...	JUMP',NE END$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE LOOP$	SUB.W	D4,D5	NEG.W	D4	SWAP.W	D4	SWAP.W	D5	SUB.W	D4,D5	NEG.W	D4	SWAP.W	D4	SWAP.W	D5	CALL	_SCALEN	ADD.W	D4,D6	SWAP.W	D4	SWAP.W	D6	ADD.W	D4,D6	SWAP.W	D4	SWAP.W	D6	CALL	_CLIPPOS	; D4 <-- position clippe et arrondie	LOAD.L	D3,(A6)+ODESY1	LOAD.L	(A6)+ODESY1,D4	CALL	_CHGCADRE	; met  jour OWDOY2/OWDOX2	LOAD.L	D4,D3		; D4 <-- ancienne position	CALL	DEMOBJETS	; dessine les objets	CALL	_MOVCADRE	; dplace ascenseurs et rgles	JUMP	LOOP$END$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3..D6	TEST.W	D7		; retour EQ/NE	RET;------------\\; GMMENUSCALE >;============/; Demande l'chelle dans un mmenu.; in	-; out	D1.L	position (y;x);	D4.W	nouvelle chelle;	D7.W	erreur; mod	D1.L, D4.L, D7.WGMMENUSCALE:	PUSHM.L	D3,A3,A4	CALL	_GETMMENUSCALE	; A3/D3 <-- ^mmenu chelle/case grise	LOAD.L	A4,#(A6)+OMPASC	; A4 <-- ^paramtres	CLR.L	D4	TSET.L	D4:D3	LOAD.L	(A4)+(LMM*0)+OMMINA,D4	CALL	_MMENUS		; choix selon mmenus ...	JUMP',NE EXIT$	LOAD.W	D7,#ERPBIP	LOAD.W	D4,(A4)+(LMM*0)+OMMSEL	JUMP',EQ EXIT$	SL.W	D4,#1	CALL	_GETTASCALE	; A4 <-- R16"TASCALE	LOAD.W	D4,(A4)+(D4.W)-2 ; D4 <-- nouvelle chelle	LOAD.W	D1,(A6)+ODESY2	SUB.W	D1,(A6)+ODESY1	SR.W	D1,#1	ADD.W	D1,(A6)+ODESY1	SWAP.W	D1	LOAD.W	D1,(A6)+ODESX2	SUB.W	D1,(A6)+ODESX1	SR.W	D1,#1	ADD.W	D1,(A6)+ODESX1	; D1 <-- au milieu de l'cran	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; MMMENUINIT >;===========/; Initialise pour le menu du milieu.; in	-; out	A4.L	^table des paramtres; mod	D7.W, A4.LMMMENUINIT:	LOAD.L	A4,#(A6)+OMPAMI	; A4 <-- ^paramtres	CLR.L	(A4)+(LMM*0)+OMMINA	CLR.L	(A4)+(LMM*1)+OMMINA	CLR.L	(A4)+(LMM*2)+OMMINA	CLR.L	(A4)+(LMM*3)+OMMINA	CLR.L	(A4)+(LMM*4)+OMMINA	CLR.L	(A4)+(LMM*5)+OMMINA	RET;------------\\; MMMENUCHOIX >;============/; Choix dans le menu du milieu.; in	A4.L	^table des paramtres; out	D3.W	touche presse;	D7.W	erreur; mod	D3.L, D7.WMMMENUCHOIX:	PUSHM.L	D4,A3	LOAD.L	A3,#R16"MMENU$	; A3 <-- ^mmenu	CALL	_MMENUS		; choix selon mmenus ...	JUMP,NE EXIT$	LOAD.W	D4,(A4)+(LMM*0)+OMMSEL	JUMP,EQ RIEN$	COMP.W	D4,#1	JUMP',EQ FILE$	COMP.W	D4,#2	JUMP',EQ EDIT$	COMP.W	D4,#3	JUMP',EQ SHOW$	COMP.W	D4,#4	JUMP',EQ OPER$	COMP.W	D4,#5	JUMP',EQ DEF$	JUMP	RIEN$FILE$:	LOAD.W	D4,(A4)+(LMM*1)+OMMSEL	LOAD.L	A4,#R16"KFILE$	JUMP'	KEY$EDIT$:	LOAD.W	D4,(A4)+(LMM*2)+OMMSEL	LOAD.L	A4,#R16"KEDIT$	JUMP'	KEY$SHOW$:	LOAD.W	D4,(A4)+(LMM*3)+OMMSEL	LOAD.L	A4,#R16"KSHOW$	JUMP'	KEY$OPER$:	LOAD.W	D4,(A4)+(LMM*4)+OMMSEL	LOAD.L	A4,#R16"KOPER$	JUMP'	KEY$DEF$:	LOAD.W	D4,(A4)+(LMM*5)+OMMSEL	LOAD.L	A4,#R16"KDEF$	JUMP'	KEY$RIEN$:	CLR.L	D3	JUMP'	EXIT$KEY$:	SL.W	D4,#1	CLR.L	D3	LOAD.W	D3,(A4)+(D4.W)	; D3 <-- touche presseEXIT$:	POPM.L	D4,A3	TEST.W	D7		; retour EQ/NE	RETKFILE$:	.W	F1	.W	F2	.W	F3	.W	F15	.W	F0KEDIT$:	.W	UNDO	.W	F14	.W	HELPKSHOW$:	.W	H'100*(2^BCHANGE)+'A	.W	H'100*(2^BCHANGE)+'G	.W	H'100*(2^BCHANGE)+'R	.W	H'100*(2^BCHANGE)+'SKOPER$:	.W	H'100*(2^BPROGRA)+'FKDEF$:	.W	H'100*(2^BPROGRA)+'P	.W	H'100*(2^BPROGRA)+'U	.W	H'100*(2^BPROGRA)+'S	.W	H'100*(2^BPROGRA)+'OMMENU$:	.ASCIZ	" "	.B	-1	.BW	-2,MFILE$-MMENU$	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOFILE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  fichier"	.BW	-2,MEDIT$-MMENU$	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOEDIT	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  dition"	.BW	-2,MSHOW$-MMENU$	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSHOW	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  vue"	.B	-1	.BW	-2,MOPER$-MMENU$	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOOPER	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  opration"	.BW	-2,MDEF$-MMENU$	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODEF	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  dfinitions"	.B	0MFILE$:	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOPREND	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  prend.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOAJOUTE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  ajoute.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSAUVE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  sauve.."	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOPRINT	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  imprime.."	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOQUITTE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  quitte.."	.B	0MEDIT$:	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUNDO	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  annule"	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOEFFACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  efface.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOHELP	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  aide.."	.B	0MSHOW$:	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOMVUE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  affichage.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOGRID	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  grille.."	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOCOLONNES	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  colonnes.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOHORVERT	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  contraintes.."	.B	0MOPER$:	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOFRAGMENT	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  fragmente.."	.B	0MDEF$:	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODEFPAGE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  page.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODEFUNIT	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  unit.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODEFMOUS	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  souris.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODEFOBJ	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  objets.."	.B	0	.EVEN;---------\\; WORKPAGE >;=========/; Travaille dans une nouvelle page.; Si WORKPAGE est excut, il faut toujours faire WORKCALQUE aprs !; in	(A6)+OPAGE.W	page o travailler (0..n); out	-; mod	D7.WWORKPAGE:	PUSHM.L	D3,D4,A5	LOAD.L	A5,#(A6)+OIDPAG	CALL	_GROUPNBPAGE	; D4 <-- nb total de pages	LOAD.W	(A5)+OIDHTV,D4	LOAD.W	D3,(A6)+OPAGE	COMP.W	D3,D4		; dpasse la dernire page ?	JUMP',LO MAX$		; non => MAX$	LOAD.W	D3,D4	DEC.W	D3		; D3 <-- dernire page possibleMAX$:	LOAD.W	(A6)+OPAGE,D3	LOAD.W	(A5)+OIDPOSV,D3	CALL	_INDUPDATE	; mj l'indicateur des pages	POPM.L	D3,D4,A5	RET;-----------\\; WORKCALQUE >;===========/; Travaille dans un nouveau calque.; in	(A6)+OCALQ.W	calque o travailler (0..n); out	-; mod	D7.WWORKCALQUE:	PUSHM.L	D3,D4,A5	LOAD.L	A5,#(A6)+OIDCAL	CALL	_GROUPNBCALQUE	; D4 <-- nb total de calques	LOAD.W	(A5)+OIDHTV,D4	LOAD.W	D3,(A6)+OCALQ	COMP.W	D3,D4		; dpasse le dernier calque ?	JUMP',LO MAX$		; non => MAX$	LOAD.W	D3,D4	DEC.W	D3		; D3 <-- dernier calque possibleMAX$:	LOAD.W	(A6)+OCALQ,D3	SUB.W	D3,(A5)+OIDHTV	NEG.W	D3	DEC.W	D3		; D3 <-- le dernier calque devient le premier (*)	LOAD.W	(A5)+OIDPOSV,D3	LOAD.L	D4,(A6)+OCALCA	TCLR.L	D4:D3		; D4 <-- ce calque doit tre visible !	LOAD.L	(A6)+OCALCA,D4	CALL	_INDUPDATE	; mj l'indicateur des calques	POPM.L	D3,D4,A5	RET;  (*)	Les calques sont numrots dans l'ordre inverse;	par-rapport  l'arbre :;	;	 Dans      Nom    Position;	l'arbre;	-------------------------------------------------;	   0        D     dessous (dessin en premier);	   1        C     ..;	   2        B     ..;	   3        A     dessus  (dessin en dernier);		.END