	.CHAP	OPPOLYRDBOX.ASI;--------\\; DBOXDEF >;========/; Choix du polygone rgulier.; in	A4.32	^objet; out	D3.32	dernire touche (F1/F0);	D7.16	erreur; mod	D3.32, D7.16DBOXDEF:	PUSHM.32 D0..D2|D4|D5|A1..A5	MOVE.32	A0,A5		; A5 <-- ^variables globales	MOVE.32	A4,A1		; A1 <-- ^objet	MOVE.32	#R16^TDBOX$,A2	MOVE.16	#DB_MEMPT,D7	PAGE_	DBOX		; mj ^table dbox	MOVE.32	#R16^DBDFDRAWC,A2	MOVE.16	#DB_MEMAFC,D7	PAGE_	DBOX		; mj ^routine d'affichage	MOVE.16	{A1}+OOBNS,{A0}+ODBP1	MOVE.16	{A1}+OOBET,{A0}+ODBP2	MOVE.32	{A1}+OOBFA,D4	; D4 <-- fanions	MOVE.32	#R16^TDBOX_DEF,A2	MOVE.16	#2**BDBSAV,D2	; D2 <-- mode	MOVE.16	#DB_OPEN,D7	PAGE_	DBOX		; ouvre la DBOX	JUMP,NE EXIT$	CLR.16	D2AFF$:	MOVE.16	#DB_GET,D7	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	MOVE.16	#DB_AFF,D7	PAGE_	DBOX		; affiche le paramtre	INC.16	D2	COMP.16	#2,D2	JUMP,LO AFF$	CLR.16	D2UPD$:	PUSH.32	D4	MOVE.16	D2,D1	TEST.32	D4:#BPOLYET1	JUMP,BS	R8^UPD5$	MOVE.16	#2**BDBGCLABEL.OR.200,D2	DBOX_	GETCO	LIB	?SETCURS	MOVE.32	#R16^TX0$,A3	LIB	?AFTEXT	MOVE.16	#2**BDBGCLABEL.OR.2**BDBGCGREY.OR.201,D2	DBOX_	GETCO	MOVE.16	#2**BDBGCLABEL.OR.2**BDBGCGREY.OR.101,D2	DBOX_	GETCO	CLR.16	D1	JUMP	R8^UPD9$UPD5$:	MOVE.16	#2**BDBGCLABEL.OR.200,D2	DBOX_	GETCO	LIB	?SETCURS	MOVE.32	#R16^TX1$,A3	LIB	?AFTEXT	MOVE.16	#2**BDBGCLABEL.OR.2**BDBGCFULL.OR.201,D2	DBOX_	GETCO	MOVE.16	#2**BDBGCLABEL.OR.2**BDBGCFULL.OR.101,D2	DBOX_	GETCO	MOVE.16	#1,D2	MOVE.16	#DB_GET,D7	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	MOVE.16	#DB_AFF,D7	PAGE_	DBOX		; affiche le paramtreUPD9$:	MOVE.16	D1,D2	POP.32	D4NLINE$:	TEST.32	D4:#BPOLYET0	JUMP,BC	R8^NLINE2$	CLR.16	D2NLINE2$:	MOVE.16	#DB_GET,D7	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	MOVE.16	#DB_MEDIT,D7	PAGE_	DBOXDRAW$:	CALL	DBDFDRAW	; dessine dans la dboxLOOP$:	MOVE.16	#MI_SCMO,D7	PAGE_	MISC		; remet la souris	DBOX_	EDIT		; attend une action ...	MOVE.16	#DB_ZEROCR,D7	PAGE_	DBOX		; remplace <CR> par <0>	PUSH.32	A1	MOVE.32	#R16^TKEY_DEF,A1	MOVE.16	#2**BDBCCMM.OR.2**BDBCCFF,D1	DBOX_	CALLC	POP.32	A1	COMP.16	#KEYMGR,D3	; bouton souris relach ?	JUMP,EQ LOOP$		; oui => LOOP$	COMP.16	#KEYMGP,D3	JUMP,EQ CLIC$	COMP.16	#F1,D3	JUMP,EQ OK$	COMP.16	#F0,D3	JUMP,EQ END$	COMP.16	#UNDO,D3	JUMP,EQ	 R8^UNDO$	COMP.16	#CLEAR,D3	JUMP,EQ	 R8^UNDO$	COMP.16	#CR,D3	JUMP,EQ	 R8^RETURN$	COMP.16	#ENTER,D3	JUMP,EQ	 R8^ENTER$	MOVE.16	D3,D1	AND.16	#16'FF00,D1	COMP.16	#KEYDBOX,D1	JUMP,EQ KEYDBOX$BIP$:	MOVE.8	#BIPLIT,D3	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	MOVE.32	A3,A4	CLR.8	{A4}	JUMP	LOOP$RETURN$:			; RETURN =>	MOVE.16	#DB_PUT,D7	PAGE_	DBOX	JUMP,NE BIP$	INC.16	D2		; D2 <-- paramtre suivant	COMP.16	#2,D2	JUMP,LO NLINE$	CLR.16	D2	JUMP	NLINE$ENTER$:	MOVE.16	#DB_PUT,D7	PAGE_	DBOX	JUMP,NE BIP$	MOVE.16	#DB_GET,D7	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	JUMP	DRAW$KEYDBOX$:			; KEYDBOX =>	MOVE.16	#DB_PUT,D7	PAGE_	DBOX	JUMP,NE BIP$	COMP.8	#100,D3	JUMP,HS	 R8^CLINE$	JUMP	UPD$CLINE$:	CLR.16	D2	MOVE.8	D3,D2	SUB.16	#100,D2	JUMP	NLINE$CLIC$:	MOVE.32	D4,{A0}+ODBFAN	MOVE.16	#DB_CLIC,D7	PAGE_	DBOX	JUMP,EQ LOOP$	JUMP	DRAW$OK$:	MOVE.16	#DB_PUT,D7	PAGE_	DBOX	JUMP,NE BIP$	MOVE.16	{A0}+ODBP1,D1	MOVE.16	D1,{A1}+OOBNS	COMP.16	#11,D1	JUMP,LO	R8^OK2$	MOVE.16	D1,{A1}+OOBNEOK2$:	MOVE.16	{A0}+ODBP2,{A1}+OOBET	MOVE.32	D4,{A1}+OOBFAEND$:	MOVE.16	#DB_CLOSE,D7	PAGE_	DBOX		; ferme la DBOXEXIT$:	POPM.32	D0..D2|D4|D5|A1..A5	TEST.16	D7		; retour EQ/NE	RETTX0$:	.ASCIZ	"Nombre de cts   "TX1$:	.ASCIZ	"Nombre de branches"	.EVENTDBOX$:	.16	ODBP1,DBTYPN,3,50,1,2**BDBGCLABEL.OR.100,0,2+2	.16	ODBP2,DBTYPN,0,100,5,2**BDBGCLABEL.OR.101,1,3+2	.16	-1;----------\\; DBDFDRAWC >;----------/; Affiche une petite flche de test pendant le DB_CLIC.; in	D2.16	mode (CLRDOT/SETDOT); out	-; mod	D7.16DBDFDRAWC:	PUSHM.32 D4|A0	COMP.16	#SETDOT,D2	JUMP,NE R8^EXIT$	MOVE.32	A5,A0	MOVE.32	{A0}+ODBFAN,D4	CALL	DBDFDRAWEXIT$:	POPM.32	D4|A0	RET;---------\\; DBDFDRAW >;---------/; Dessine un polygone/toile dans la dbox.; in	D4.32	fanions; out	-; mod	D7.16DBDFDRAW:	PUSHM.32 D1..D4|A2|A4	MOVE.32	#{A0}+OPROV,A4	; A4 <-- ^objet provisoire	MOVE.32	D4,{A4}+OOBFA	MOVE.16	{A0}+ODBP1,{A4}+OOBNS	MOVE.16	{A0}+ODBP2,{A4}+OOBET	CLR.32	D3	CLR.32	D4	LIB	?DRMDEF	MOVE.16	#2**BDBGCLABEL.OR.50,D2	DBOX_	GETCO	MOVE.32	D3,{A4}+OOBP1	PUSH.32	D3	MOVE.16	#2**BDBGCLABEL.OR.51,D2	DBOX_	GETCO	MOVE.32	D3,{A4}+OOBP2	POP.32	D1	SUB.16	D3,D1		; D1 <-- rayon	DEC.16	D3	SWAP.32	D3	SUB.16	D1,D3	DEC.16	D3	SWAP.32	D3	MOVE.16	D1,D4	SL.16	#1,D4	ADD.16	#2,D4	SWAP.32	D4	MOVE.16	D1,D4	SL.16	#1,D4	ADD.16	#2,D4	MOVE.16	#CLRDOT,D2	LIB	?DRTRAME	; efface l'emplacement	MOVE.32	#R16^DRAWxSEG,A2	MOVE.16	#SETDOT,D2	CALL	DRAWEXESOMMETS	; dessine dans la dbox	POPM.32	D1..D4|A2|A4	RETTDBOX_DEF:	.16	L10$-TDBOX_DEF	.16	L20$-TDBOX_DEF	.16	0,0L10$:	.8	ODBLCIRCLE,BPOLYET0.OR.2**7,KEYDBOX/16'100,BPOLYET0	.ASCIZ	" polygone rgulier"	.8	ODBCR	.8	ODBLCIRCLE,BPOLYET1.OR.2**7,KEYDBOX/16'100,BPOLYET1	.ASCIZ	" toile"	.8	ODBCR,ODBCR	.8	ODBLABEL,200	.8	ODBTEXT	.ASCIZ	"Nombre de cts         "	.8	ODBLABEL,100	.8	ODBCLINE,(2+2).OR.2**7,KEYDBOX/16'100,100,TDBNORM	.8	ODBCR	.8	ODBTABX,36	.8	ODBLABEL,51	.8	ODBTEXT,0	.8	ODBTABX,36+10	.8	ODBLABEL,50	.8	ODBTEXT,0	.8	ODBTABX,36+10+10+1	.8	ODBCR	.8	ODBLABEL,201	.8	ODBTEXT	.ASCIZ	"Longueur d'une branche  "	.8	ODBLABEL,101	.8	ODBCLINE,(3+2).OR.2**7,KEYDBOX/16'100,101,TDBNORM	.8	ODBTEXT	.ASCIZ	"  %"	.8	ODBCR,ODBCR,ODBCR	.8	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.8	ODBTEXT	.ASCIZ	"  "	.8	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.8	0L20$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_DEF:	.16	F1,F2,F3,0,DOKF1-TKEY_DEF	.16	F0,F13,F14,F15,0,DOKF0-TKEY_DEF	.16	KEYMGR,KEYMMR,KEYMDR,0,DOKMGR-TKEY_DEF	.16	KEYMGP,KEYMMP,KEYMDP,0,DOKMGP-TKEY_DEF	.16	0;--------\\; DOK...  >;========/DOKMGR:	MOVE.16	#KEYMGR,D3	RETDOKMGP:	MOVE.16	#KEYMGP,D3	RETDOKF0:	MOVE.16	#F0,D3	RETDOKF1:	MOVE.16	#F1,D3	RETDOKF4:	MOVE.16	#F4,D3	RETDOKF7:	MOVE.16	#F7,D3	RETDOKF10:	MOVE.16	#F10,D3	RETDOKF13:	MOVE.16	#F13,D3	RET	.END