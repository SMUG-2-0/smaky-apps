	.SBTTL	OPTEXTCAR.ASI;-----------\\; CARJUSTPUT >;===========/; Modifie la justification du paragraphe courant.; in	D6.L	canal BUTX;	D2.W	justification (0..n); out	-; mod	D7.WCARJUSTPUT:	PUSHM.L	D1..D5	CALL	_BUTX_GETPOS	; D4 <-- position du curseur	LOAD.L	D1,D4	LOAD.W	D4,D2	RR.L	D4,#32-CCJUSHI	; D4 <-- info 1	LOAD.L	D2,#CCJUMSK	; D2 <-- masque 1	CLR.L	D3		; D3 <-- masque 2	CLR.L	D5		; D5 <-- info 2	CALL	_BUTX_INFOMASK	CLR.L	D2		; D2 <-- nb de caractresALOOP$:	CALL	_BUTX_AVANCE	; D3/D4/D5 <-- caractre suivant	JUMP',NE AEND$	INC.L	D2		; D2 <-- un caractre de plus	COMP.B	D3,#CR	JUMP,NE ALOOP$AEND$:	LOAD.L	D4,D1	CALL	_BUTX_SETPOS	; revient o on taitRLOOP$:	CALL	_BUTX_RECULE	; D3/D4/D5 <-- caractre	JUMP',NE REND$	COMP.B	D3,#CR	JUMP',EQ RENDA$	INC.L	D2		; D2 <-- un caractre de plus	JUMP	RLOOP$RENDA$:	CALL	_BUTX_AVANCE	; D3/D4/D5 <-- saute le CRREND$:	LOAD.L	D4,D2		; D4 <-- nb de caractres	CALL	_BUTX_MODINFO	; modifie tout	LOAD.L	D4,D1	CALL	_BUTX_SETPOS	; revient o on tait	POPM.L	D1..D5	RET;--------\\; CARLINK >;========/; Fusionne deux pavs de texte.; in	A4.L	^objet  lier;	A3.L	^racine objet pre; out	-; mod	D7.WCARLINK:	PUSHM.L	D3..D6,A3,A4	EX.L	A3,A4		; A3 <-- ^objet  lier	LOAD.W	D7,#MI_GETDATA	PAGE_	MISC		; A4 <-- ^objet pre	CALL	CARENDPALL	; D4 <-- position fin (pre)	JUMP',NE END$	LOAD.L	D6,(A4)+OOBCHT	CALL	_BUTX_SETPOS	; va o insrer dans le pre	CALL	_BUTX_RECULE	; D3/D4/D5 <-- caractre prcdent	JUMP',NE POS$	COMP.B	D3,#PEOT	; est-on aprs un PEOT ?	JUMP',EQ POS$		; oui => POS$	CALL	_BUTX_AVANCEPOS$:	LOAD.L	D6,(A3)+OOBCHT	CLR.L	D4	CALL	_BUTX_SETPOS	; revient au dbutLOOP$:	LOAD.L	D6,(A3)+OOBCHT	CALL	_BUTX_AVANCE	; D3/D4/D5 <-- caractre	JUMP',NE END$	COMP.B	D3,#PEOT	JUMP',EQ EOT$	LOAD.L	D6,(A4)+OOBCHT	CALL	_BUTX_INSERT	; insre le caractre chez le pre	JUMP,EQ LOOP$	JUMP'	END$EOT$:;	LOAD.L	D6,(A3)+OOBCHT	CALL	_BUTX_RECULE	; D3/D4/D5 <-- recule le PEOTEND$:	LOAD.L	D6,(A3)+OOBCHT	CALL	_BUTX_CLOSE	LOAD.L	(A3)+OOBCHT,(A4)+OOBCHT	CALL	CARMODPAVE	; annule la prjustification	EX.L	A3,A4	CALL	CARMODPAVE	; annule la prjustification	POPM.L	D3..D6,A3,A4	RET;----------\\; CARUNLINK >;==========/; Spare un pav de texte.; in	A4.L	^objet  sparer; out	-; mod	D7.WCARUNLINK:	PUSH.L	D6	CALL	_BUTX_OPEN	; D6 <-- nouveau canal BUTX	JUMP',NE EXIT$	LOAD.L	(A4)+OOBCHT,D6	CALL	CARMODPAVE	; annule la prjustificationEXIT$:	POP.L	D6	RET;----------\\; CARIFCURS >;==========/; Regarde si le curseur est dans ce pav.; in	A4.L	^objet texte; out	D7.W	erreur (si pas dans ce pav); mod	D7.WCARIFCURS:	PUSHM.L	D3,D4,D6,A3	LOAD.L	D6,(A4)+OOBCHT	CALL	_BUTX_GETPOS	; D4 <-- position du curseur	LOAD.L	D3,D4	CALL	CARENDPALL	; D4 <-- position fin (pre)	JUMP',NE EXIT$	LOAD.W	D7,#1		; D7 <-- curseur pas ici	COMP.L	D3,D4		; curseur plus loin ?	JUMP',HS EXIT$		; oui => EXIT$	LOAD.L	A3,(A4)+OOBPPJ	; A3 <-- ^table OPJxxx	COMP.L	D3,(A3)+OPJPDL	; curseur moins loin ?	JUMP',LO EXIT$		; oui => EXIT$	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4,D6,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; CARMODSPY >;==========/; Annule la prjustification le moins possible en fonction des; renseignements fournis par les espions.; in	A4.L	^objet texte; out	-; mod	D7.WCARMODSPY:	PUSHM.L	D4,A3,A4	TEST.L	(A4)+OOBPPJ	; prjustification encore valable ?	JUMP',EQ EXIT$		; non => EXIT$	LOAD.L	D4,(A5)+OSPYLII	; D4 <-- limite infrieure des modifications	COMP.L	D4,#-1		; y a-t-il une limite ?	JUMP',EQ EXIT$		; non => EXIT$	CALL	CARPJSEARCH	; A3 <-- ^dans OPJxxx	JUMP',NE ERROR$	CALL	CARPJPREV	; A3 <-- ^ligne prcdente	LOAD.W	(A3)+OPJNBC,#-1	; invalide  partir de la ligne prcdenteNLOOP$:	CALL	BASNEXTPAVE	; A4 <-- ^pav suivant	JUMP',NE EXIT$	CALL	CARMODPAVE	; annule la prjustification	JUMP	NLOOP$ERROR$:	CALL	CARMODPALL	; annule toutes les prjustificationsEXIT$:	LOAD.L	(A5)+OSPYLII,#-1 ; rz les espions	POPM.L	D4,A3,A4	RET;-----------\\; CARENDPALL >;===========/; Cherche la position de la fin d'un pav, qui servira de dbut; pour le pav suivant.; in	A4.L	^objet texte; out	D4.L	position fin du pav (dans BUTX);	D7.W	erreur; mod	D4.L, D7.WCARENDPALL:	CALL	CARINIPT	; initialise pour CARGETPT	CALL	CARENDPAVE	; D4 <-- position fin	JUMP',EQ EXIT$	CALL	CARCOUPEPALL	; prjustifie le pav	JUMP',NE EXIT$	CALL	CARENDPAVE	; D4 <-- position finEXIT$:	TEST.W	D7		; retour EQ/NE	RET;------------\\; CARPJSEARCH >;============/; Cherche une position dans les tables de prjustification.; Si les tables n'existent pas, ou sont partiellement invalides,; recalcule ce qui est ncessaire.; in	A4.L	^objet texte;	D4.L	position cherche; out	A4.L	^objet texte;	A3.L	^dans OPJxxx;	D7.W	erreur; mod	D7.W, A3.L, A4.LCARPJSEARCH:	PUSHM.L	D1..D4	LOAD.L	D1,D4		; D1 <-- position cherche; Cherche le pav dans lequel se trouve la position cherche.SEARCH$:	TEST.L	(A4)+OOBPPJ	; table OPJxxx existe ?	JUMP',NE PTL$	CALL	CARCOUPEPALL	; calcule la table OPJxxx	JUMP,NE EXIT$PTL$:	LOAD.L	A3,(A4)+OOBPPJ	; A3 <-- ^table OPJxxx	LOAD.L	D3,(A3)+OPJPDL	; D3 <-- position dbut du pav	COMP.L	D1,D3		; cherche une position avant ce pav ?	JUMP',HS LOOP$		; non => LOOP$	CALL	BASPREVPAVE	; A4 <-- ^pav prcdent	JUMP,EQ SEARCH$	JUMP	EXIT$; Cherche la bonne ligne dans le pav.LOOP$:	CALL	CARPJVALID	; valide l'information (si ncessaire)	CLR.L	D2	LOAD.W	D2,(A3)+OPJNBC	; D2 <-- nb de caractres dans la ligne	JUMP',EQ NEXT$		; fin => NEXT$	ADD.L	D3,D2		; D3 <-- position dbut ligne suivante	COMP.L	D1,D3		; curseur dans cette ligne ?	JUMP',LO OK$		; oui => OK$	LOAD.L	A3,#(A3)+LPJ	; A3 <-- ^suivant	JUMP	LOOP$NEXT$:	CALL	BASNEXTPAVE	; A4 <-- ^pav suivant	JUMP,EQ SEARCH$; Cherche la dernire ligne du dernier pav.LAST$:	CALL	CARPJPREV	; A3 <-- ^ligne prcdente	JUMP',NE IFCR$	TEST.W	(A3)+OPJNBC	; est-ce un pav vide ?	JUMP,EQ LAST$		; oui => LAST$IFCR$:	COMP.B	(A3)+OPJEOL,#CR	JUMP',NE OK$	LOAD.L	A3,#(A3)+LPJ	; A3 <-- ^suivantOK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; CARPJNEXT >;==========/; Cherche la ligne suivante dans une table de prjustification.; Passe automatiquement  l'objet suivant si ncessaire !; Un pav entirement vide est considr comme ayant une seule; ligne de longueur nulle (OPJNBC=0).; La nouvelle ligne est valide si ncessaire.; in	A4.L	^objet texte;	A3.L	^dans OPJxxx; out	A4.L	^objet texte;	A3.L	^ligne suivante;	D7.W	erreur; mod	D7.W, A3.L, A4.LCARPJNEXT:	TEST.W	(A3)+OPJNBC	; dernire ligne ?	JUMP',EQ NEXT$		; oui => NEXT$	LOAD.L	A3,#(A3)+LPJ	; A3 <-- ^suivant	CALL	CARPJVALID	; valide l'information (si ncessaire)	TEST.W	(A3)+OPJNBC	; dernire ligne ?	JUMP',NE OK$		; non => OK$	LOAD.L	A3,#(A3)-LPJNEXT$:	CALL	BASNEXTPAVE	; A4 <-- ^pav suivant	JUMP',NE EOT$	TEST.L	(A4)+OOBPPJ	; table OPJxxx existe ?	JUMP',NE PTL$		; oui => PTL$	CALL	CARCOUPEPALL	; calcule la table OPJxxx	JUMP',NE EXIT$PTL$:	LOAD.L	A3,(A4)+OOBPPJ	; A3 <-- ^table OPJxxx	CALL	CARPJVALID	; valide l'information (si ncessaire)OK$:	CLR.W	D7		; D7 <-- trouv	JUMP'	EXIT$EOT$:	LOAD.W	D7,#1		; D7 <-- pas trouvEXIT$:	TEST.W	D7		; retour EQ/NE	RET;----------\\; CARPJPREV >;==========/; Cherche la ligne prcdente dans une table de prjustification.; Passe automatiquement  l'objet prcdent si ncessaire !; Un pav entirement vide est considr comme ayant une seule; ligne de longueur nulle (OPJNBC=0).; La nouvelle ligne est toujours valide (forcment), sans qu'il; soit ncessaire de faire des CARPJVALID ou des CARCOUPEPALL.; in	A4.L	^objet texte;	A3.L	^dans OPJxxx; out	A4.L	^objet texte;	A3.L	^ligne prcdente;	D7.W	erreur; mod	D7.W, A3.L, A4.LCARPJPREV:	COMP.L	A3,(A4)+OOBPPJ	; est-on au tout dbut de la table ?	JUMP',NE PREV$		; non => PREV$	CALL	BASPREVPAVE	; A4 <-- ^pav prcdent	JUMP',NE EOT$	TEST.L	(A4)+OOBPPJ	; table OPJxxx existe ?	JUMP',EQ EOT$		; non => EOT$	LOAD.L	A3,(A4)+OOBPPJ	; A3 <-- ^table OPJxxxLAST$:	TEST.W	(A3)+OPJNBC	; a-t-on atteint le dernier ?	JUMP',EQ PREV$		; oui => PREV$	LOAD.L	A3,#(A3)+LPJ	; A3 <-- ^dernier	JUMP	LAST$PREV$:	COMP.L	A3,(A4)+OOBPPJ	; est-on au tout dbut de la table ?	JUMP',EQ OK$		; oui => OK$	LOAD.L	A3,#(A3)-LPJ	; A3 <-- ^prcdentOK$:	CLR.W	D7		; D7 <-- trouv	JUMP'	EXIT$EOT$:	LOAD.W	D7,#1		; D7 <-- pas trouvEXIT$:	TEST.W	D7		; retour EQ/NE	RET;-------------\\; CARCOUPEPALL >;=============/; Prjustifie tout un pav de texte, en gnrant la table correspondante (OPJxxx).; Prjustifie tous les pavs prcdents de la chane si ncessaire.; Le curseur n'est pas dplac.; in	A4.L	^objet texte; out	D7.W	erreur; mod	D7.WCARCOUPEPALL:	PUSHM.L	D2..D4,D6,A4	LOAD.L	D6,(A4)+OOBCHT	CALL	_BUTX_POSSAVE	; D4 <-- no de la position	LOAD.W	D3,D4	CLR.W	D2		; D2 <-- nb de pavs reculsPLOOP$:	CALL	BASPREVPAVE	; A4 <-- ^pav prcdent	JUMP',NE BEGIN$	INC.W	D2		; D2 <-- un pav recul de plus	CALL	CARENDPAVE	; D4 <-- position fin	JUMP',EQ POS$	JUMP	PLOOP$BEGIN$:	CLR.L	D4		; D4 <-- depuis le dbut	CALL	_BUTX_SETPOS	; va au dbut du texte	INC.W	D2	JUMP'	NCOUPE$POS$:	CALL	_BUTX_SETPOS	; va au dbut du pav (= fin du prcdent)NLOOP$:	CALL	BASNEXTPAVE	; A4 <-- ^pav suivantNCOUPE$:	DEC.W	D2	JUMP',EQ LAST$	CALL	CARCOUPEPTOUT	; prjustifie tout un pav	JUMP',NE EXIT$	JUMP	NLOOP$LAST$:	CALL	CARCOUPEPMIN	; prjustifie le minimum d'un pavEXIT$:	PUSH.W	D7	LOAD.W	D4,D3	CALL	_BUTX_POSEND	; revient o l'on tait	POP.W	D7	POPM.L	D2..D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------------\\; CARCOUPEPTOUT >;--------------/; Prjustifie tout un pav de texte, en gnrant la table correspondante (OPJxxx).; Si le pav ne contient qu'une ligne, elle a le droit de dborder du bas !; En entre, le curseur est au dbut du pav. En sortie, il est au dbut du; pav suivant.; in	A4.L	^objet texte; out	D7.W	erreur; mod	D7.WCARCOUPEPTOUT:	PUSH.L	A3	CALL	CARPOSDIM	; cherche position/dimensions du pav	CALL	CARNEWTL	; cre une nouvelle table OPJxxx	JUMP',NE EXIT$	LOAD.L	A3,(A4)+OOBPPJ	; A3 <-- ^table OPJxxx	CALL	_BUTX_GETPOS	; D4 <-- position	LOAD.L	(A3)+OPJPDL,D4LOOP$:	CALL	CARCOUPEONE	; coupe une ligne	TEST.W	(A3)+OPJNBC	; est-on arriv  la dernire ligne ?	JUMP',EQ OK$		; oui => OK$	LOAD.L	A3,#(A3)+LPJ	; A3 <-- ^suivant	JUMP	LOOP$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	A3	TEST.W	D7		; retour EQ/NE	RET;-------------\\; CARCOUPEPMIN >;-------------/; Prjustifie le minimum d'un pav de texte, en gnrant la table correspondante (OPJxxx).; En entre, le curseur est au dbut du pav. En sortie, il n'est pas dplac.; in	A4.L	^objet texte; out	D7.W	erreur; mod	D7.WCARCOUPEPMIN:	PUSH.L	A3	CALL	CARPOSDIM	; cherche position/dimensions du pav	CALL	CARNEWTL	; cre une nouvelle table OPJxxx	JUMP',NE EXIT$	LOAD.L	A3,(A4)+OOBPPJ	; A3 <-- ^table OPJxxx	CALL	_BUTX_GETPOS	; D4 <-- position	LOAD.L	(A3)+OPJPDL,D4	LOAD.W	(A3)+OPJNBC,#-1	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; CARNEWTL >;---------/; Rserve de la mmoire pour un nouveau buffer OPJxxx.; in	A4.L	^objet texte; out	D7.W	erreur; mod	D7.WCARNEWTL:	PUSHM.L	D0..D4,A1..A4	CALL	CARMODPAVE	; libre la table OPJxxx	LOAD.L	A1,A4		; A1 <-- ^objet; Cherche l'interligne minimal dans D2.W.	CLR.W	D3	LOAD.W	D2,#-1LOOP$:	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D0,#IDENTJUST	LOAD.W	D1,#opDGETDIM	PAGE_	OBJCALL		; A2 <-- ^table de justification	JUMP',NE LAST$	TEST.B	(A2)+OJSNAME	; justification utilise ?	JUMP',EQ NEXT$		; non => NEXT$	CALL	CARJUSTITL	; D4 <-- interligne de base	COMP.W	D2,D4	JUMP',LS NEXT$	LOAD.W	D2,D4		; D2 <-- interligne le plus petitNEXT$:	INC.W	D3		; D3 <-- justification suivante	JUMP	LOOP$LAST$:	TEST.W	D2	JUMP',EQ DEF$	COMP.W	D2,#-1	JUMP',NE GETMEM$DEF$:	LOAD.W	D2,#20*FACMMPT; Calcule le nombre maximal de lignes possibles.GETMEM$:	CLR.L	D4	LOAD.W	D4,(A5)+OTXDIM+0 ; D4 <-- hauteur maximale du pav	DIV.WU	D4,D2		; D4 <-- nb max de lignes possibles	ADD.W	D4,#10		; D4 <-- p'tite rserve !	LOAD.W	(A1)+OOBNPJ,D4	INC.W	D4		; D4 <-- place pour terminateur	MUL.WU	D4,#LPJ	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^nouveau buffer OPJxxx	JUMP',NE EXIT$	LOAD.L	(A1)+OOBPPJ,A4EXIT$:	POPM.L	D0..D4,A1..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; CARMODPALL >;===========/; Annule la prjustification de tous les pavs de texte.; in	A4.L	^objet texte; out	-; mod	D7.WCARMODPALL:	PUSHM.L	A3,A4	CALL	CARMODPAVE	; annule la prjustification	LOAD.L	A3,A4; Cherche tous les pavs prcdents.PLOOP$:	CALL	BASPREVPAVE	; A4 <-- ^pav prcdent	JUMP',NE NEXT$	CALL	CARMODPAVE	; annule la prjustification	JUMP	PLOOP$; Cherche tous les pavs suivants.NEXT$:	LOAD.L	A4,A3NLOOP$:	CALL	BASNEXTPAVE	; A4 <-- ^pav suivant	JUMP',NE EXIT$	CALL	CARMODPAVE	; annule la prjustification	JUMP	NLOOP$EXIT$:	POPM.L	A3,A4	RET;-----------\\; CARMODPAVE >;===========/; Annule la prjustification d'un pav de texte.; in	A4.L	^objet texte; out	-; mod	D7.WCARMODPAVE:	PUSHM.L	D1,A1,A4	LOAD.L	A1,A4		; A1 <-- ^objet	TEST.L	(A1)+OOBPPJ	JUMP',EQ EXIT$	LOAD.L	A4,(A1)+OOBPPJ	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire OPJxxx	CLR.L	(A1)+OOBPPJEXIT$:	POPM.L	D1,A1,A4	RET;-----------\\; CARENDPAVE >;===========/; Cherche la position de la fin d'un pav, qui servira de dbut; pour le pav suivant.; in	A4.L	^objet texte; out	D4.L	position fin du pav (dans BUTX);	D7.W	erreur; mod	D4.L, D7.WCARENDPAVE:	PUSH.L	A3	LOAD.W	D7,#1	TEST.L	(A4)+OOBPPJ	; pav dj prjustifi ?	JUMP',EQ EXIT$		; non => EXIT$	LOAD.L	A3,(A4)+OOBPPJ	; A3 <-- ^table OPJxxxLOOP$:	CALL	CARPJVALID	; valide l'information (si ncessaire)	TEST.W	(A3)+OPJNBC	JUMP',EQ END$	LOAD.L	A3,#(A3)+LPJ	; A3 <-- ^suivant	JUMP	LOOP$END$:	LOAD.L	D4,(A3)+OPJPDL	; D4 <-- position fin	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	A3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; CARPJVALID >;===========/; Valide (si ncessaire) une informartion de prjustification.; in	A4.L	^objet texte;	A3.L	^dans OPJxxx; out	D7.W	erreur; mod	D7.WCARPJVALID:	COMP.W	(A3)+OPJNBC,#-1	; information valide ?	JUMP',NE QUIT$		; oui => QUIT$	PUSHM.L	D3,D4	CALL	_BUTX_POSSAVE	; D4 <-- no de la position	LOAD.W	D3,D4	LOAD.L	D4,(A3)+OPJPDL	CALL	_BUTX_SETPOS	; va au dbut de la ligne	CALL	CARCOUPEONE	; coupe la ligne	LOAD.W	D4,D3	CALL	_BUTX_POSEND	; revient o l'on tait	POPM.L	D3,D4QUIT$:	RET;------------\\; CARCOUPEONE >;============/; Prjustifie une ligne d'un pav de texte, en gnrant la table correspondante (OPJxxx).; Si le pav ne contient qu'une ligne, elle a le droit de dborder du bas !; En entre, le curseur est au dbut de la ligne. En sortie, il est au dbut de; la ligne suivante.; in	A4.L	^objet texte;	A3.L	^dans OPJxxx; out	-; mod	D7.WCARCOUPEONE:	PUSHM.L	D0..D4,D6,A1,A2	LOAD.L	D6,(A4)+OOBCHT	TSET.B	(A3)+OPJFLG:#BPJFLFIRST	CLR.W	(A3)+OPJIND	PUSHM.L	A3,A4	CALL	CARPJPREV	; A3/A4 <-- ^ligne prcdente	LOAD.L	A1,A3		; A1 <-- ^ligne prcdente	POPM.L	A3,A4	TEST.W	D7		; est-ce la premire ligne du texte ?	JUMP',NE FIRST$		; oui => FIRST$	COMP.B	(A1)+OPJEOL,#CR	JUMP',EQ FIRST$	TCLR.B	(A3)+OPJFLG:#BPJFLFIRST	LOAD.W	(A3)+OPJIND,(A1)+OPJINDFIRST$:	CALL	CARPOSDIM	; cherche position/dimensions du pav	LOAD.L	D0,A3	SUB.L	D0,(A4)+OOBPPJ	DIV.WU	D0,#LPJ		; D0 <-- rang de la ligne (0..n)	CLR.W	D1		; D1 <-- position relative en Y	TEST.W	D0		; premire ligne ?	JUMP',EQ POSY$		; oui => POSY$	LOAD.W	D1,(A3)-LPJ+OPJPYR	ADD.W	D1,(A3)-LPJ+OPJIL ; D1 <-- position relative en YPOSY$:	LOAD.W	(A3)+OPJPYR,D1	CALL	CARSRCPJUST	; A2 <-- ^table de justification	LOAD.L	(A3)+OPJJUS,A2	; OPJJUS <-- ^table de justification	TCLR.B	(A3)+OPJFLG:#BPJFLAFF ; affichage pas (encore) fait	TEST.W	D0		; premire ligne ?	JUMP',EQ FLINE$		; oui => FLINE$	COMP.B	(A3)-LPJ+OPJEOL,#EOP ; passe au pav suivant ?	JUMP,EQ END$		; oui => END$FLINE$:	COMP.W	D0,(A4)+OOBNPJ	; est-ce que la table est pleine ?	JUMP,HS END$		; oui => END$	LOAD.W	D4,(A5)+OTXDIM+2 ; D4 <-- largeur  disposition	CALL	CARCOUPELINE	; dtermine o couper dans la ligne	CLR.L	D2	LOAD.W	D2,(A3)+OPJNBC	; D2 <-- nb de caractres  avancer	JUMP',EQ END$	CALL	CARMAXH1H2	; cherche h1 et h2 max	ADD.W	D1,(A3)+OPJIL	; D1 <-- position suivante en Y	COMP.W	D1,(A5)+OTXDIM+0 ; dpasse le bas du pav ?	JUMP',LO NEXT$		; non => NEXT$	TEST.W	D0		; est-on dans la premire ligne ?	JUMP',NE END$		; non => END$NEXT$:	LOAD.L	D4,(A3)+OPJPDL	ADD.L	D4,D2	CALL	_BUTX_SETPOS	; va au dbut de la ligne suivante	LOAD.L	(A3)+LPJ+OPJPDL,D4	LOAD.W	(A3)+LPJ+OPJNBC,#-1	JUMP'	EXIT$; Met encore quelques informations dans la ligne terminatrice (aprs la; dernire), ce qui est utile au cas o le curseur s'y trouve !END$:	CLR.W	(A3)+OPJNBC	; met le terminateur	CLR.W	(A3)+OPJLX	TEST.W	D0	JUMP',EQ EMPTY$	LOAD.W	(A3)+OPJH1,(A3)-LPJ+OPJH1	LOAD.W	(A3)+OPJH2,(A3)-LPJ+OPJH2	LOAD.W	(A3)+OPJBL,(A3)-LPJ+OPJBL	LOAD.W	(A3)+OPJIL,(A3)-LPJ+OPJIL	JUMP'	EXIT$EMPTY$:	CLR.W	D2	CALL	CARMAXH1H2	; cherche h1 et h2 max;	JUMP'	EXIT$EXIT$:	POPM.L	D0..D4,D6,A1,A2	RET;----------\\; CARPOSDIM >;==========/; Cherche la position et les dimensions d'un pav de texte.; in	A4.L		^objet texte; out	(A5)+OTXPOS.L	coin sup/gauche;	(A5)+OTXDIM.L	dimensions (dy;dx); mod	D7.WCARPOSDIM:	PUSHM.L	D3,D4	LOAD.L	D3,(A4)+OOBP1	LOAD.L	D4,(A4)+OOBP3	SUB.W	D4,D3	JUMP',NC OKX$	NEG.W	D4	SUB.W	D3,D4OKX$:	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	JUMP',NC OKY$	NEG.W	D4	SUB.W	D3,D4OKY$:	SWAP.W	D3	SWAP.W	D4	COMP.L	D3,(A4)+OOBP1	JUMP',EQ OKP$	LOAD.W	D1,(A4)+OOBA+0	JUMP',EQ OKP$	EX.L	D4,D3	CALL	GETPX	EX.L	D3,D4OKP$:	LOAD.L	(A5)+OTXPOS,D3	LOAD.L	(A5)+OTXDIM,D4	POPM.L	D3,D4	RET;-------------\\; CARCOUPELINE >;=============/; Dtermine o il faut couper dans une longue ligne.; Cette routine est la base de tous les modes de justification.; N'avance pas le curseur dans la ligne !; in	A4.L		^objet texte;	A3.L		^dans OPJ*;	D4.W		largeur maximale [obj]; out	(A3)+OPJNBC.W	nb de caractre  avancer (0..n);	(A3)+OPJNBS.W	nb d'espaces (0..n);	(A3)+OPJIND.W	position indentation [obj];	(A3)+OPJLX.W	largeur de la ligne [obj];	(A3)+OPJEOL.B	info eol, voir (*); mod	D7.W; (*)	;	| = o couper;;	                 |  OPJEOL  |OPJNBS|OPJNBC |        |;	 exemple         | info eol | nbsp | nbcar | justif | affiche;	-----------------|----------|------|-------|--------|----------;	 abc def |ghi    |  SPACE   |  1   |   8   |  oui   | rien;	 abcdef|ghi      |  0       |  0   |   6   |  oui   | rien;	 abc-|def        |  0       |  0   |   4   |  oui   | rien;	 construc|tion   |  tiret   |  0   |   8   |  oui   | tiret;	 abc|<TAB>def    |  TAB     |  0   |   3   |  non   | rien;	 abc<CR>|def     |  CR      |  0   |   4   |  non   | rien;	 abc<EOP>|def    |  EOP     |  0   |   4   |  non   | rien;	 abc<PEOT>|      |  PEOT    |  0   |   4   |  non   | rien;	 abc| "eot"      |  PEOT    |  0   |   3   |  non   | rien	.PC	PCVAR	.LOC	0OCCLPDL:.BLKB	2		; no position dbut de la ligneOCCLPFL:.BLKB	2		; no position fin de la ligneOCCLOFD:.BLKB	2		; offset pour le dbut ( gauche)OCCLLGM:.BLKB	2		; largeur maximaleOCCLNBC:.BLKB	2		; nombre de caractres dans le motLCCL:	.PC	PCCODECARCOUPELINE:	PUSHM.L	D0..D5,A2	SUB.L	SP,#LCCL	; SP <-- ^variables locales	LOAD.L	A2,(A3)+OPJJUS	; A2 <-- ^table de justification	LOAD.W	D3,(A3)+OPJIND	; D3 <-- indentation	JUMP',NE RENF$	LOAD.W	D3,(A2)+OJSESPG	TEST.B	(A3)+OPJFLG:#BPJFLFIRST ; premire ligne du paragraphe ?	JUMP',BC RENF$		; non => RENF$	ADD.W	D3,(A2)+OJSESPR	; D3 <-- tient compte du renfoncementRENF$:	LOAD.W	(SP)+OCCLOFD,D3	; OCCLOFD <-- offset dbut	ADD.W	D3,(A2)+OJSESPD	SUB.W	D4,D3	LOAD.W	(SP)+OCCLLGM,D4	; OCCLLGM <-- lg max  disposition	CALL	_BUTX_POSSAVE	; D4 <-- no de la position	LOAD.W	(SP)+OCCLPDL,D4	CLR.W	(SP)+OCCLNBC	CLR.W	(A3)+OPJNBS	CLR.W	(A3)+OPJCNJ	CLR.W	D1		; D1 <-- position dans la ligne	TEST.W	(SP)+OCCLLGM	; longueur plausible ?	JUMP,LE EOL0$		; non => EOL0$SLOOP$:	COMP.W	D1,(SP)+OCCLLGM	; largeur maximale atteinte ?	JUMP,HI OUTL$		; oui => OUTL$	CALL	_BUTX_AVANCE	; D3/D4/D5 <-- caractre suivant	JUMP,NE EOT$	COMP.B	D3,#CR	JUMP,EQ EOL$	COMP.B	D3,#EOP	JUMP,EQ EOL$	COMP.B	D3,#PEOT	JUMP,EQ EOL$	COMP.B	D3,#TAB	JUMP,EQ TAB$	INC.W	(SP)+OCCLNBC	; OCCLNBC <-- +1 caractre	CALL	CARCHASSE	; D5 <-- chasse	ADD.W	D1,D5		; D1 <-- avance dans la ligne	COMP.B	D3,#SPACE	JUMP,EQ SLOOP$CLOOP$:	COMP.W	D1,(SP)+OCCLLGM	; largeur maximale atteinte ?	JUMP,HI OUTL$		; oui => OUTL$	CALL	_BUTX_AVANCE	; D3/D4/D5 <-- caractre suivant	JUMP,NE EOT$	COMP.B	D3,#CR	JUMP,EQ EOL$	COMP.B	D3,#EOP	JUMP,EQ EOL$	COMP.B	D3,#PEOT	JUMP,EQ EOL$	COMP.B	D3,#TAB	JUMP,EQ TAB$	INC.W	(SP)+OCCLNBC	; OCCLNBC <-- +1 caractre	CALL	CARCHASSE	; D5 <-- chasse	ADD.W	D1,D5		; D1 <-- avance dans la ligne	COMP.B	D3,#SPACE	JUMP,NE CLOOP$	CLR.W	(SP)+OCCLNBC	; OCCLNBC <-- rz avance dans mot	INC.W	(A3)+OPJNBS	; OPJNBS <-- +1 espace	JUMP	SLOOP$TAB$:	LOAD.W	D3,D1	ADD.W	D1,(SP)+OCCLOFD	; D1 <-- tient compte marge gauche/renfoncement	CALL	TABNEXT		; D1 <-- position plus loin	SUB.W	D1,(SP)+OCCLOFD	COMP.W	D1,(SP)+OCCLLGM	; largeur maximale atteinte ?	JUMP',HI TABEND$	; oui => TABEND$	CLR.W	(SP)+OCCLNBC	; OCCLNBC <-- rz avance dans mot	CLR.W	(A3)+OPJNBS	; OPJNBS <-- on justifie depuis l	CALL	_BUTX_GETPOS	; D4 <-- position	SUB.L	D4,(A3)+OPJPDL	; D4 <-- avance (nb car)	LOAD.W	(A3)+OPJCNJ,D4	; OPJCNJ <-- nb de caractres non justifis	LOAD.L	D3,D1	SWAP.W	D3		; D3 <-- type de tabulateur (ICORGTAB?)	COMP.W	D3,#ICORGTABI	; indentateur ?	JUMP,NE SLOOP$		; non => SLOOP$	LOAD.W	D3,D1	ADD.W	D3,(SP)+OCCLOFD	; D3 <-- tient compte marge gauche/renfoncement	LOAD.W	(A3)+OPJIND,D3	; OPJIND <-- position dernier indentateur rencontr	JUMP	SLOOP$TABEND$:	LOAD.W	D1,D3		; D1 <-- position avant le tabulateur	CALL	_BUTX_RECULE	; D3/D4/D5 <-- recule le tabulateur	LOAD.B	D3,#TAB		; D3 <-- info eol	JUMP	END$OUTL$:	TEST.W	(A3)+OPJNBS	; un seul mot ?	JUMP',NE CMGO$		; non => CMGO$C1GO$:				; oui =>	CALL	_BUTX_RECULE	; D3/D4/D5 <-- caractre prcdent	CALL	CARCHASSE	; D5 <-- chasse du caractre	SUB.W	D1,D5		; D1 <-- recule dans la ligne	CALL	_BUTX_POSSAVE	; D4 <-- no de la position	LOAD.W	(SP)+OCCLPFL,D4	LOAD.W	D4,(SP)+OCCLPDL	; D4 <-- no position dbut ligne	CALL	_BUTX_POSBEGIN	; revient au dbut de la ligne	TEST.B	(A2)+OJSMODE:#BJSMDM ; autorise les divisions dans les mots ?	JUMP',BC C1NOT$		; non => C1NOT$	LOAD.W	D2,(SP)+OCCLLGM	; D2 <-- lg max coupable	LOAD.W	D3,D2		; D3 <-- largeur totale	CALL	CARCOUPEMOT	; essaye de couper dans le mot suivant	JUMP',NE C1NOT$	LOAD.W	D4,(SP)+OCCLPFL	; D4 <-- no position fin ligne	CALL	_BUTX_POSCANCEL	LOAD.W	D1,D2		; D1 <-- largeur de la ligne	JUMP'	COUPE$C1NOT$:	LOAD.W	D4,(SP)+OCCLPFL	; D4 <-- no position fin ligne	CALL	_BUTX_POSEND	; va  la fin de la ligne	JUMP	EOL0$CMGO$:	DEC.W	(A3)+OPJNBS	; OPJNBS <-- ne compte pas le dernier espace	LOAD.W	D2,(SP)+OCCLNBC	; D2 <-- nb de caractres dans le dernier mot	JUMP',EQ CMREND$CMRLOOP$:	CALL	_BUTX_RECULE	; D3/D4/D5 <-- caractre prcdent	CALL	CARCHASSE	; D5 <-- chasse du caractre	SUB.W	D1,D5		; D1 <-- recule dans la ligne	DEC.W	D2	JUMP,NE CMRLOOP$CMREND$:	LOAD.W	D2,(SP)+OCCLLGM	SUB.W	D2,D1		; D2 <-- lg max coupable	CALL	_BUTX_RECULE	; D3/D4/D5 <-- caractre prcdent (espace)	CALL	CARCHASSE	; D5 <-- chasse du dernier espace	SUB.W	D1,D5		; D1 <-- n'affiche pas le dernier espace	PUSH.L	D5	CALL	_BUTX_AVANCE	; annule le RECULE !	POP.L	D5	TEST.B	(A2)+OJSMODE:#BJSMDM ; autorise les divisions dans les mots ?	JUMP',BC EOLSP$		; non => EOLSP$	LOAD.W	D3,(SP)+OCCLLGM	; D3 <-- largeur totale	CALL	CARCOUPEMOT	; essaye de couper dans le mot suivant	JUMP',NE EOLSP$	INC.W	(A3)+OPJNBS	; OPJNBS <-- un mot de plus	ADD.W	D1,D5		; D1 <-- ajoute le dernier espace	ADD.W	D1,D2		; D1 <-- resteCOUPE$:	LOAD.B	D3,#'-		; D3 <-- info eol (faudra ajouter tiret)	TEST.L	D2:#16		; tiret dj dans le mot ?	JUMP',BC END$		; non => END$EOL0$:	CLR.B	D3		; D3 <-- info eol	JUMP'	END$EOT$:	LOAD.B	D3,#PEOT	; D3 <-- info eol	JUMP'	END$EOLSP$:	LOAD.B	D3,#SPACE	; D3 <-- info eol;	JUMP'	END$EOL$:END$:	LOAD.B	(A3)+OPJEOL,D3	; OPJEOL <-- info eol	LOAD.W	(A3)+OPJLX,D1	CALL	_BUTX_GETPOS	; D4 <-- position	SUB.L	D4,(A3)+OPJPDL	; D4 <-- avance (nb car)	LOAD.W	(A3)+OPJNBC,D4	; OPJNBC <-- nb de caractres  avancer	LOAD.W	D4,(SP)+OCCLPDL	; D4 <-- no position dbut ligne	CALL	_BUTX_POSEND	; revient au dbut de la ligne	ADD.L	SP,#LCCL	; POP variables locales	POPM.L	D0..D5,A2	RET;------------\\; CARCOUPEMOT >;------------/; Essaye de couper dans un mot.; in	A4.L	^objet texte;	A3.L	^dans OPJ*;	D2.W	lg max coupable;	D3.W	lg totale de la ligne; out	D2.W	lg rcupre grce  la coupure;		si 2^16 = 1 --> tiret dj dans le mot;	D7.W	ok/erreur; mod	D2.L, D7.W	.PC	PCVAR	.LOC	0OCCMPOS:.BLKB	4		; position dbut motOCCMPDM:.BLKB	2		; no position dbut du motOCCMLGC:.BLKB	2		; largeur max coupableOCCMJUS:.BLKB	4		; ^table de justificationLCCM:	.PC	PCCODECARCOUPEMOT:	PUSHM.L	D0,D1,D3..D5,A1..A4	SUB.L	SP,#LCCM	; SP <-- ^variables locales	LOAD.L	A1,A4		; A1 <-- ^objet	LOAD.L	A2,(A3)+OPJJUS	; A2 <-- ^table de justification	LOAD.L	(SP)+OCCMJUS,A2	CALL	_BUTX_POSSAVE	LOAD.W	(SP)+OCCMPDM,D4	; OCCMPDM <-- no position dbut mot	CALL	_BUTX_GETPOS	LOAD.L	(SP)+OCCMPOS,D4	; OCCMPOS <-- position dbut mot	LOAD.W	(SP)+OCCMLGC,D2	; OCCMLGC <-- lg max coupable	JUMP,LE ERROR$	LOAD.W	D1,D2	MUL.WU	D1,#100	DIV.WU	D1,D3		; D1 <-- lg max coupable en %	COMP.W	D1,(A2)+OJSPVID	JUMP,LO ERROR$	LOAD.L	A3,#(A5)+OBUMOT	; A3 <-- ^buffer pour mot	LOAD.L	A2,#(A5)+OBULMO	; A2 <-- ^buffer pour lg caractres	LOAD.W	D1,#LBUMOT-1	; D1 <-- nb car. max pour le mot	CLR.W	D0		; D0 <-- position dans le mot	CLR.W	D2		; D2 <-- compte nb car. avancsPLOOP$:	CALL	_BUTX_AVANCE	; D3/D4/D5 <-- caractre suivant	JUMP',NE PEND$	COMP.B	D3,#SPACE	; fin du mot ?	JUMP',EQ PEND$		; oui => PEND$	COMP.B	D3,#TAB	JUMP',EQ PEND$	COMP.B	D3,#CR	JUMP',EQ PEND$	COMP.B	D3,#EOP	JUMP',EQ PEND$	COMP.B	D3,#PEOT	JUMP',EQ PEND$	INC.W	D2		; D2 <-- +1 caractre avanc	LOAD.W	(A2+),D0	; OBULMO <-- position	PUSH.L	A2	LOAD.L	A2,(SP)+OCCMJUS+4	CALL	CARCHASSE	; D5 <-- chasse du caractre	POP.L	A2	ADD.W	D0,D5		; D0 <-- position dans le mot	CALL	_BUTX_NOSUPPL	; D3 <-- caractre < 128 !	LOAD.B	(A3+),D3	; OBUMOT <-- un caractre	DEC.W	D1	JUMP,NE	PLOOP$	JUMP	ERROR$PEND$:	TEST.W	D2	JUMP,EQ ERROR$	LOAD.L	A3,#(A5)+OBUMOT	; A3 <-- ^mot	LOAD.W	D3,D2		; D3 <-- lg mot	LOAD.L	A4,#(A5)+OBUCOUP ; A4 <-- ^buffer	LOAD.W	D4,#LBUCOUP	; D4 <-- lg buffer	COUPE_	HASH		; cherche la liste des coupures	JUMP,NE ERROR$; Cherche la coupure optimale dans la liste rendue.	CLR.W	D0SLAST$:	INC.W	D0	TEST.B	(A4+)	JUMP,NE	SLAST$	DEC.L	A4		; A4 <-- ^dernire coupure	LOAD.L	A2,#(A5)+OBULMO	; A2 <-- ^buffer pour lg caractresSLOOP$:	DEC.W	D0		; encore une coupure possible ?	JUMP,EQ ERROR$		; non => ERROR$	CLR.L	D2	LOAD.B	D2,(-A4)	; D2 <-- position coupure (nb car)	JUMP,EQ ERROR$	JUMP',NS TIRET$				; coupe en ajoutant un tiret =>	SL.W	D2,#1	LOAD.W	D1,(A2)+(D2.W)	; D1 <-- lg du mot jusque l	SR.W	D2,#1	LOAD.L	D4,(SP)+OCCMPOS	; D4 <-- position dbut mot	ADD.L	D4,D2		; D4 <-- position du futur tiret	CALL	_BUTX_SETPOS	; va o ira le tiret	CALL	_BUTX_RECULE	; D3/D4/D5 <-- caractre avant le tiret	LOAD.B	D3,#'-	EX.L	A1,A4	PUSH.L	A2	LOAD.L	A2,(SP)+OCCMJUS+4	CALL	CARCHASSE	; D5 <-- chasse du tiret	POP.L	A2	EX.L	A4,A1	ADD.W	D1,D5		; D1 <-- lg du mot avec le tiret	COMP.W	D1,(SP)+OCCMLGC	; reste assez de place en bout de ligne ?	JUMP,HI SLOOP$		; non => SLOOP$	TCLR.L	D2:#16		; D2 <-- faudra ajouter un tiret	JUMP'	COUPE$TIRET$:				; coupe sans ajouter de tiret =>	TCLR.L	D2:#7	SL.W	D2,#1	LOAD.W	D1,(A2)+(D2.W)	; D1 <-- lg du mot jusque l	SR.W	D2,#1	COMP.W	D1,(SP)+OCCMLGC	; reste assez de place en bout de ligne ?	JUMP,HI SLOOP$		; non => SLOOP$	TSET.L	D2:#16		; D2 <-- tiret dj dans le motCOUPE$:	LOAD.W	D4,(SP)+OCCMPDM	; D4 <-- no position dbut mot	CALL	_BUTX_POSEND	; revient au dbut du motCPOS$:	CALL	_BUTX_AVANCE	; avance jusqu' la coupure	DEC.W	D2	JUMP,NE CPOS$	LOAD.W	D2,D1		; D2 <-- lg rcupre	CLR.W	D7		; D7 <-- coupure effectue	JUMP'	EXIT$ERROR$:	LOAD.W	D4,(SP)+OCCMPDM	; D4 <-- no position dbut mot	CALL	_BUTX_POSEND	; revient o l'on tait	LOAD.W	D7,#1		; D7 <-- coupure pas faite !EXIT$:	ADD.L	SP,#LCCM	; POP variables locales	POPM.L	D0,D1,D3..D5,A1..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; CARMAXH1H2 >;===========/; Cherche les valeurs maximales pour h1 et h2.; in	A4.L		^objet;	A3.L		^dans OPJ*;	D2.W		nb de caractre  avancer (0..n);	D0.W		rang de la ligne dans le pav (0..n); out	(A3)+OPJH1.W	h1 max;	(A3)+OPJH2.W	h2 max;	(A3)+OPJBL.W	ligne de base;	(A3)+OPJIL.W	interligne; mod	D7.W	.PC	PCVAR	.LOC	0OCMARLI:.BLKB	2		; rang de la ligne (0..n)OCMAPDL:.BLKB	2		; no position dbut ligneOCMANBC:.BLKB	2		; nb de caractresOCMAH1C:.BLKB	2		; h1 caractreOCMAH2C:.BLKB	2		; h2 caractreOCMAH1R:.BLKB	2		; h1 rfrence "E"OCMAH2R:.BLKB	2		; h2 rfrence "p"OCMAHIE:.BLKB	2		; +/- hauteur si indice/exposantOCMAIF1:.BLKB	4		; info 1OCMAIF2:.BLKB	4		; info 2LCMA:	.PC	PCCODECARMAXH1H2:	PUSHM.L	D0..D5,A1,A2	SUB.L	SP,#LCMA	; SP <-- ^variables locales	LOAD.L	A1,A4		; A1 <-- ^objet	LOAD.L	A2,(A3)+OPJJUS	; A2 <-- ^table de justification	LOAD.W	(SP)+OCMARLI,D0	; OCMARLI <-- rang de la ligne	CALL	_BUTX_POSSAVE	; D4 <-- no de la position	LOAD.W	(SP)+OCMAPDL,D4	; OCMAPDL <-- no position dbut ligne	CLR.W	(SP)+OCMAH1C	; OCMAH1C <-- h1 max	CLR.W	(SP)+OCMAH2C	; OCMAH2C <-- h2 max	CLR.W	(SP)+OCMAH1R	; OCMAH1R <-- h1 max	CLR.W	(SP)+OCMAH2R	; OCMAH2R <-- h2 max	TEST.W	D2		; D2 <-- nb de caractres	JUMP,EQ END$	LOAD.W	(SP)+OCMANBC,D2; Calcule les hauteurs h1/h2 maximales et de rfrence ("E"/"p").	LOAD.L	(SP)+OCMAIF1,#-1	CLR.L	(SP)+OCMAIF2LOOP$:	CALL	_BUTX_AVANCE	; D3/D4/D5 <-- caractre suivant	JUMP,NE END$	COMP.L	D4,(SP)+OCMAIF1	JUMP',NE CHANGE$	COMP.L	D5,(SP)+OCMAIF2	; toujours le mme gencar ?	JUMP,EQ SAME$		; oui => SAME$CHANGE$:	LOAD.L	(SP)+OCMAIF1,D4	LOAD.L	(SP)+OCMAIF2,D5	LOAD.B	D1,D3		; D1 <-- caractre;	LOAD.L	D4,(SP)+OCMAIF1;	LOAD.L	D5,(SP)+OCMAIF2	LOAD.B	D3,#'E	CALL	CARDIM		; D3/D4/D5 <-- min/max/chasse	SWAP.W	D3	LOAD.W	D0,D3		; D0 <-- h1 de "E"	LOAD.L	D4,(SP)+OCMAIF1	LOAD.L	D5,(SP)+OCMAIF2	LOAD.B	D3,#'p	CALL	CARDIM		; D3/D4/D5 <-- min/max/chasse	SWAP.W	D4		; D4 <-- h2 de "p"	LOAD.W	D3,D0		; D3 <-- h1 de "E"	CLR.W	D5		; D5 <-- normal	TEST.B	(A2)+OJSILFL+2:#BJSILAI-8 ; auto indice/exposant ?	JUMP',BC EXP$		; non => EXP$	LOAD.L	D0,(SP)+OCMAIF1	AND.L	D0,#CCEXMSK;	SR.L	D0,#CCEXSHI	SWAP.W	D0		; D0 <-- rang de l'exposant (0..2)	TEST.W	D0	JUMP',EQ EXP$	CALL	CAREXPY		; D5 <-- position relative (+y)	COMP.W	D0,#2	JUMP',EQ EXP$	NEG.W	D5		; D5 <-- position relative (-y)EXP$:	LOAD.W	(SP)+OCMAHIE,D5	ADD.W	D3,D5		; D3 <-- h1 selon exposant/indice	JUMP',NC H1REX$	CLR.W	D3H1REX$:	ADD.W	D4,D5		; D4 <-- h2 selon exposant/indice	JUMP',NC H2REX$	CLR.W	D4H2REX$:	COMP.W	D3,(SP)+OCMAH1R	JUMP',LS H1R$	LOAD.W	(SP)+OCMAH1R,D3	; OCMAH1R <-- h1 maxH1R$:	COMP.W	D4,(SP)+OCMAH2R	JUMP',LS H2R$	LOAD.W	(SP)+OCMAH2R,D4	; OCMAH2R <-- h2 maxH2R$:	LOAD.L	D4,(SP)+OCMAIF1	LOAD.L	D5,(SP)+OCMAIF2	LOAD.B	D3,D1SAME$:	CALL	CARDIM		; D3/D4/D5 <-- min/max/chasse	SWAP.W	D3		; D3 <-- h1 du caractre	SWAP.W	D4		; D4 <-- h2 du caractre	LOAD.W	D5,(SP)+OCMAHIE	ADD.W	D3,D5		; D3 <-- h1 selon exposant/indice	JUMP',NC H1CEX$	CLR.W	D3H1CEX$:	ADD.W	D4,D5		; D4 <-- h2 selon exposant/indice	JUMP',NC H2CEX$	CLR.W	D4H2CEX$:	COMP.W	D3,(SP)+OCMAH1C	JUMP',LS H1C$	LOAD.W	(SP)+OCMAH1C,D3	; OCMAH1C <-- h1 maxH1C$:	COMP.W	D4,(SP)+OCMAH2C	JUMP',LS H2C$	LOAD.W	(SP)+OCMAH2C,D4	; OCMAH2C <-- h2 maxH2C$:	DEC.W	D2		; encore un caractre ?	JUMP,NE LOOP$		; oui => LOOP$; Si la ligne est vide, cherche des hauteurs h1/h2 par dfaut.END$:	LOAD.W	D2,(SP)+OCMAH1R	OR.W	D2,(SP)+OCMAH2R	; h1 et h2 nuls ?	JUMP',NE NONULL$	; non => NONULL$	CLR.L	D4	CLR.L	D5	LOAD.B	D3,#'E	CALL	CARDIM		; D3/D4/D5 <-- min/max/chasse	SWAP.W	D3		; D3 <-- h1 de "E"	LOAD.W	(SP)+OCMAH1R,D3	LOAD.W	(SP)+OCMAH1C,D3	CLR.L	D4	CLR.L	D5	LOAD.B	D3,#'p	CALL	CARDIM		; D3/D4/D5 <-- min/max/chasse	SWAP.W	D4		; D4 <-- h2 de "p"	LOAD.W	(SP)+OCMAH2R,D4	LOAD.W	(SP)+OCMAH2C,D4NONULL$:	LOAD.W	(A3)+OPJH1,(SP)+OCMAH1C	LOAD.W	(A3)+OPJH2,(SP)+OCMAH2C; Calcule OPJIL et OPJBL en fonction des hauteurs h1/h2 trouves.	TEST.B	(A3)+OPJFLG:#BPJFLFIRST ; premire ligne du paragraphe ?	JUMP',BC NOFIRST$	; non => NOFIRST$	LOAD.W	D4,(A2)+OJSESPH	ADD.W	(SP)+OCMAH1R,D4NOFIRST$:	COMP.B	(A3)+OPJEOL,#CR ; dernire ligne du paragraphe ?	JUMP',NE NOLAST$	; non => NOLAST$	LOAD.W	D4,(A2)+OJSESPB	ADD.W	(SP)+OCMAH2R,D4NOLAST$:	TEST.W	(SP)+OCMARLI	; est-on dans la premire ligne du pav ?	JUMP',NE SUITE$		; non => SUITE$FIRST$:	TEST.B	(A2)+OJSILFL+2:#BJSILAC-8 ; auto grands caractres ?	JUMP',BS FAUTO$		; oui => FAUTO$	CALL	CARJUSTITL	; D4 <-- interligne de base	LOAD.W	(A3)+OPJBL,D4	ADD.W	D4,(SP)+OCMAH2R	LOAD.W	(A3)+OPJIL,D4	JUMP	EXIT$FAUTO$:	CALL	CARJUSTITL	; D4 <-- interligne de base	COMP.W	D4,(SP)+OCMAH1R	JUMP',HS FAIL$	LOAD.W	D4,(SP)+OCMAH1RFAIL$:	LOAD.W	(A3)+OPJBL,D4	ADD.W	D4,(SP)+OCMAH2R	LOAD.W	(A3)+OPJIL,D4	JUMP'	EXIT$SUITE$:	PUSH.L	A2	LOAD.L	A2,(A3)-LPJ+OPJJUS ; A2 <-- ^table de justification ligne prcdente	CALL	CARJUSTITL	; D4 <-- interligne de base ligne prcdente	POP.L	A2	TEST.B	(A2)+OJSILFL+2:#BJSILAC-8 ; auto grands caractres ?	JUMP',BC SIL$		; non => SIL$	LOAD.W	D3,(A3)-LPJ+OPJIL	SUB.W	D3,(A3)-LPJ+OPJBL	ADD.W	D3,(SP)+OCMAH1R	COMP.W	D4,D3	JUMP',HS SIL$	LOAD.W	D4,D3SIL$:	ADD.W	D4,(A3)-LPJ+OPJBL	SUB.W	D4,(A3)-LPJ+OPJIL	LOAD.W	(A3)+OPJBL,D4	ADD.W	D4,(SP)+OCMAH2R	LOAD.W	(A3)+OPJIL,D4;	JUMP'	EXIT$EXIT$:	LOAD.W	D4,(SP)+OCMAPDL	; D4 <-- no position dbut ligne	CALL	_BUTX_POSEND	; revient au dbut de la ligne	ADD.L	SP,#LCMA	; POP variables locales	POPM.L	D0..D5,A1,A2	RET;--------\\; CAREXPY >;========/; Cherche la hauteur pour un indice/exposant.; in	A1.L	^objet;	A2.L	^table de justification; out	D5.W	position relative (y); mod	D5.L, D7.WCAREXPY:	PUSHM.L	D3,D4,A3,A4	CLR.W	D5	LOAD.W	D3,(A2)+OJSCHAR	; D3 <-- caractre (0..n)	CALL	CARGETPT	; A3/A4/D3/D4 <-- ^gencar/^chasses/h1;h2/interl	JUMP',NE EXIT$	SWAP.W	D3		; D3 <-- h1 du caractre ordinaire	MUL.WU	D3,(A2)+OJSEXPY	DIV.WU	D3,#100	LOAD.W	D5,D3		; D5 <-- position relativeEXIT$:	POPM.L	D3,D4,A3,A4	RET;-----------\\; CARJUSTITL >;===========/; Cherche l'interligne de base  utiliser.; in	A1.L	^objet;	A2.L	^table de justification; out	D4.W	interligne [obj]; mod	D4.L, D7.WCARJUSTITL:	PUSHM.L	D2,D3,A3,A4	LOAD.L	D2,(A2)+OJSILFL	; D2 <-- flags	LOAD.W	D4,(A2)+OJSILVA	; D4 <-- valeur de l'interligne	TEST.L	D2:#BJSILV	JUMP',BS FACT$	LOAD.W	D3,(A2)+OJSCHAR	; D3 <-- caractre (0..n)	CALL	CARGETPT	; A3/A4/D3/D4 <-- ^gencar/^chasses/h1;h2/interl	JUMP',EQ FACT$	LOAD.W	D4,#20*FACMMPT	; D4 <-- interligne par dfautFACT$:	TEST.L	D2:#BJSIL10	JUMP',BS EXIT$	LOAD.W	D3,#05	TEST.L	D2:#BJSIL05	JUMP',BS MUL$	LOAD.W	D3,#08	TEST.L	D2:#BJSIL08	JUMP',BS MUL$	LOAD.W	D3,#12	TEST.L	D2:#BJSIL12	JUMP',BS MUL$	LOAD.W	D3,#15	TEST.L	D2:#BJSIL15	JUMP',BS MUL$	LOAD.W	D3,#20MUL$:	MUL.WU	D4,D3	DIV.WU	D4,#10		; D4 <-- interligne selon facteur 1.2, 1.5 ou 2EXIT$:	POPM.L	D2,D3,A3,A4	RET;------------\\; CARSRCPJUST >;============/; Cherche la table de justification pour une ligne donne.; in	-; out	A2.L	^table de justification; mod	D7.WCARSRCPJUST:	PUSHM.L	D0..D3,A4	CALL	CARSRCNJUST	; D2 <-- justification	LOAD.W	D3,D2		; D3 <-- numro de la justification	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D0,#IDENTJUST	LOAD.W	D1,#opDGETDIM	PAGE_	OBJCALL		; A2 <-- ^table de justification	POPM.L	D0..D3,A4	RET;------------\\; CARSRCNJUST >;============/; Cherche la justification d'un caractre donn (l o est le curseur).; in	-; out	D2.W	justification (0..n); mod	D2.L, D7.WCARSRCNJUST:	PUSHM.L	D0,D1,D3..D5,A4	CALL	_BUTX_POSSAVE	; D4 <-- no de la position	PUSH.W	D4	CALL	_BUTX_AVANCE	; D3/D4/D5 <-- caractre suivant	JUMP',EQ CHAR$	CALL	_BUTX_RECULE	; D3/D4/D5 <-- caractre prcdent	JUMP',NE DEF$	COMP.B	D3,#CR	JUMP',NE CHAR$DEF$:	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D0,#IDENTJUST	LOAD.W	D1,#opDGET	PAGE_	OBJCALL		; D3 <-- justification slectionne	LOAD.W	D4,D3	JUMP'	EXIT$CHAR$:	AND.L	D4,#CCJUMSK	RL.L	D4,#32-CCJUSHIEXIT$:	LOAD.W	D2,D4		; D2 <-- justification	POP.W	D4	CALL	_BUTX_POSEND	; revient o on tait	POPM.L	D0,D1,D3..D5,A4	RET;-------------\\; CARCHASSETAB >;=============/; Donne la chasse d'un caractre, en tenant compte des tabulateurs.; in	A4.L	^objet;	A2.L	^table de justification;	D2.W	position dans la ligne;	D3.B	caractre;	D4.L	info 1;	D5.L	info 2; out	D5.W	chasse (dx);	D7.W	erreur; mod	D5.L, D7.WCARCHASSETAB:	COMP.B	D3,#TAB	JUMP',NE CARCHASSE	PUSH.L	D1	LOAD.W	D1,D2	SUB.W	D1,(A5)+OTXPOS+2	CALL	TABNEXT		; D1 <-- position suivante	ADD.W	D1,(A5)+OTXPOS+2	LOAD.W	D5,D1	SUB.W	D5,D2		; D5 <-- chasse du tabulateur	POP.L	D1	RET;----------\\; CARCHASSE >;==========/; Donne la chasse d'un caractre.; in	A4.L	^objet;	A2.L	^table de justification;	D3.B	caractre;	D4.L	info 1;	D5.L	info 2; out	D5.W	chasse (dx);	D7.W	erreur; mod	D5.L, D7.WCARCHASSE:	PUSHM.L	D1..D4,A1,A3,A4	LOAD.L	A1,A4		; A1 <-- ^objet	LOAD.W	D1,(A2)+OJSITCA	; D4 <-- intercaractre	CLR.W	D2	LOAD.B	D2,D3		; D2 <-- caractre	LOAD.L	D3,D4		; D3 <-- info1	AND.W	D3,#CCGCMSK;	SR.W	D3,#CCGCSHI	; D3 <-- numro du gencar	CALL	CARGETPT	; A3/A4/D3/D4 <-- ^gencar/^chasses/h1;h2/interl	JUMP',NE ERROR$	COMP.B	D2,#CADRATIN	; cadratin ?	JUMP',NE 10$		; non => 10$	LOAD.B	D2,#SPACE	; oui => comme un espace10$:	COMP.B	D2,#CR		; fin de ligne ?	JUMP',NE 11$		; non => 11$	LOAD.B	D2,#SPACE	; oui => comme un espace11$:	COMP.B	D2,#EOP		; fin de ligne ?	JUMP',NE 12$		; non => 12$	LOAD.B	D2,#SPACE	; oui => comme un espace12$:	SL.W	D2,#1	LOAD.W	D5,(A4)+(D2.W)	; D5 <-- largeur du caractre	ADD.W	D5,D1		; D5 <-- ajoute l'intercaractre	JUMP',NC EXIT$ERROR$:	CLR.W	D5		; D5 <-- largeur nulleEXIT$:	POPM.L	D1..D4,A1,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-------\\; CARDIM >;=======/; Donne les dimensions de la bote d'un caractre.; in	A4.L	^objet;	A2.L	^table de justification;	D3.B	caractre;	D4.L	info 1;	D5.L	info 2; out	D3.L	min (dy;dx);	D4.L	max (dy;dx);	D5.W	chasse (dx);	D7.W	erreur; mod	D3.L, D4.L, D5.L, D7.WCARDIM:	PUSHM.L	D1,D2,A1,A3,A4	LOAD.L	A1,A4		; A1 <-- ^objet	LOAD.W	D1,(A2)+OJSITCA	; D4 <-- intercaractre	CLR.W	D2	LOAD.B	D2,D3		; D2 <-- caractre	LOAD.L	D3,D4		; D3 <-- info1	AND.W	D3,#CCGCMSK;	SR.W	D3,#CCGCSHI	; D3 <-- numro du gencar	CALL	CARGETPT	; A3/A4/D3/D4 <-- ^gencar/^chasses/h1;h2/interl	JUMP',NE ERROR$	COMP.B	D2,#CADRATIN	; cadratin ?	JUMP',NE 10$		; non => 10$	LOAD.B	D2,#SPACE	; oui => comme un espace10$:	COMP.B	D2,#CR		; fin de ligne ?	JUMP',NE 11$		; non => 11$	LOAD.B	D2,#SPACE	; oui => comme un espace11$:	COMP.B	D2,#EOP		; fin de ligne ?	JUMP',NE 12$		; non => 12$	LOAD.B	D2,#SPACE	; oui => comme un espace12$:	SL.W	D2,#1	LOAD.L	A3,#(A4)+256*2*2	LOAD.W	D3,(A3)+(D2.W)	; D3 <-- Ymin	SWAP.W	D3	LOAD.L	A3,#(A4)+256*2*1	LOAD.W	D3,(A3)+(D2.W)	; D3 <-- Xmin	LOAD.L	A3,#(A4)+256*2*4	LOAD.W	D4,(A3)+(D2.W)	; D4 <-- Ymax	SWAP.W	D4	LOAD.L	A3,#(A4)+256*2*3	LOAD.W	D4,(A3)+(D2.W)	; D4 <-- Xmax	LOAD.W	D5,(A4)+(D2.W)	; D5 <-- largeur du caractre	ADD.W	D5,D1		; D5 <-- ajoute l'intercaractre	JUMP',NC EXIT$ERROR$:	CLR.L	D3	CLR.L	D4	CLR.W	D5		; D5 <-- largeur nulleEXIT$:	POPM.L	D1,D2,A1,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; CARINIPT >;---------/; Initialise pour CARGETPT.; in	-; out	-; mod	D7.WCARINIPT:	PUSHM.L	D4,A4	LOAD.W	(A5)+OTXLCH,#-1	LOAD.L	A4,#(A5)+OTXLCG	LOAD.W	D4,#16-1LOOP$:	CLR.L	(A4+)		; rz ^gencar	CLR.L	(A4+)		; rz angle	DECJ.W,NMO D4,LOOP$	POPM.L	D4,A4	RET;---------\\; CARGETPT >;---------/; Donne qq paramtres sur le caractre.; in	A1.L	^objet;	A2.L	^table de justification;	D3.W	numro du caractre; out	A3.L	^gencar bitmap (et non descripteur, pour DR_CHARQ !);	A4.L	^table de chasse   [obj];	D3.L	hauteurs (h1;h2)   [obj];	D4.L	couleur;interligne [obj];	D7.W	erreur; mod	D3.L, D4.L, D7.W, A3.L, A4.LCARGETPT:	PUSHM.L	D0..D2,A2	COMP.B	D3,#-1	JUMP',NE DEF$	LOAD.W	D3,(A2)+OJSCHAR	; D3 <-- caractre par dfaut du paragrapheDEF$:	LOAD.W	D2,D3		; D2 <-- numro du caractre	COMP.W	D3,(A5)+OTXLCH	; est-ce toujours le mme caractre ?	JUMP',EQ SAME$		; oui => SAME$	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D0,#IDENTCHAR	LOAD.W	D1,#opDGETDIM	PAGE_	OBJCALL		; A2/A3/A4/D3/D4 <-- paramtres	JUMP',NE EXIT$	LOAD.W	(A5)+OTXLCH,D2	LOAD.L	(A5)+OTXLCD,A3	LOAD.L	(A5)+OTXLCC,A4	LOAD.L	(A5)+OTXLCJ,D3	LOAD.L	(A5)+OTXLCI,D4	JUMP'	BITMAP$SAME$:	LOAD.L	A3,(A5)+OTXLCD	; A3 <-- ^descripteur	LOAD.L	A4,(A5)+OTXLCC	; A4 <-- ^chasses	LOAD.L	D3,(A5)+OTXLCJ	; D3 <-- h1/h2	LOAD.L	D4,(A5)+OTXLCI	; D4 <-- couleur;interligneBITMAP$:	LOAD.L	D1,(A1)+OOBA	; D1 <-- angle de rotation	LOAD.L	A2,#(A5)+OTXLCG	SL.W	D2,#3		; D2 <-- *(4+4)	ADD.W	A2,D2		; A2 <-- ^dans OTXLCG	TEST.L	(A2)		; ^gencar bitmap existe ?	JUMP',EQ GETPGC$	; non => GETPGC$	COMP.L	D1,(A2)+4	; angle correct ?	JUMP',EQ TAKE$		; oui => TAKE$GETPGC$:	PUSH.L	A4	LOAD.L	A4,A3		; A4 <-- ^descripteur;	LOAD.L	D1,(A1)+OOBA	; D1 <-- angle de rotation	LOAD.W	D7,#DR_GETPGC	; A3 <-- ^gencar bitmap	PAGE_	DRAW	POPM.L	A4	JUMP',NE EXIT$	LOAD.L	(A2),A3		; OTXLCG <-- ^gencar	LOAD.L	(A2)+4,D1	; OTXLCG <-- angleTAKE$:	LOAD.L	A3,(A2)		; A3 <-- ^gencar bitmap	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D2,A2	TEST.W	D7		; retour EQ/NE	RET	.END