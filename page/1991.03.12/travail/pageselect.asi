	.SBTTL	PAGESELECT.ASI;----------\\; SELSELECT >;==========/; Slectionne un ou plusieurs objets.; in	D4.L	position de la souris (y;x);	A1.L	^routine pour objets  exclure (*); out	D7.W	erreur; mod	D7.WSELSELECT:	PUSHM.L	D2..D4,D6,A4	CALL	DETOBJET	; souris sur un objet ?	JUMP,EQ ONE$		; oui => ONE$ZONE$:	LOAD.L	(A6)+OZONY1,D4	LOAD.L	(A6)+OZONY2,D4;;?	SET.B	(A6)+OCCMO	; n'enlve pas le rticule !	LOAD.W	D2,#1		; D2 <-- open	CALL	DESISHIFTZ	; dessine le premier rectangle	CALL	_SCMO		; remet la sourisZLOOP$:;;?	LOAD.W	D3,#ICORETICULE	CLR.W	D3		; D3 <-- bte flche !	CALL	_SELMO		; utilise le bon lutin	CALL	_DESINFXY	; affiche X= et Y= dans les informations	LOAD.W	D2,#2		; D2 <-- shift	CALL	DESISHIFTZ	; fait tourner le traitill	CALL	_WAITMOVES	; attend dplacement ...	JUMP,NE ZSEL$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE ZLOOP$	CALL	_CONVSCROBJ	; D4 <-- point o est la souris	JUMP,NE ZLOOP$	COMP.L	D4,(A6)+OZONY2	; position change ?	JUMP,EQ ZLOOP$		; non => ZLOOP$				; oui =>	LOAD.W	D2,#3		; D2 <-- close	CALL	DESISHIFTZ	; efface l'ancien rectangle	LOAD.L	(A6)+OZONY2,D4	LOAD.W	D2,#1		; D2 <-- open	CALL	DESISHIFTZ	; dessine le nouveau rectangle	JUMP	ZLOOP$ZSEL$:	CALL	_NBMOUSE	; D3 <-- nombre de boutons presss	COMP.W	D3,#2	JUMP',HS ZCHG$	LOAD.W	D2,#3		; D2 <-- close	CALL	DESISHIFTZ	; efface le dernier rectangle;;?	CLR.B	(A6)+OCCMO	; enlve le rticule !	LOAD.L	A4,#0		; A4 <-- encore aucun objet slectionn	CALL	ZONESELECT	; slectionne tous les objets inclus	JUMP,NE EXIT$	LOAD.W	D7,#ERPBIP	LOAD.W	D4,(A6)+OZONNS	; D4 <-- nb d'objets slectionns	JUMP,EQ EXIT$	ADD.W	(A6)+OSELNB,D4	; OSELNB <-- nb d'objets slectionns	LOAD.L	(A6)+OSELPS,A4	; OSELPS <-- ^premier objet slectionn	JUMP	OK$ZCHG$:	LOAD.W	D2,#3		; D2 <-- close	CALL	DESISHIFTZ	; efface le dernier rectangle;;?	CLR.B	(A6)+OCCMO	; enlve le rticule !ONE$:	CLR.W	D3		; D3 <-- bte flche !	CALL	_SELMO		; utilise le bon lutin	CALL	HANDSELECT	; slectionne un objet ...	JUMP,NE EXIT$	COMP.L	A4,#0		; changement de la touche COPY ?	JUMP',NE OSEL$		; non => OSEL$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE EXIT$	CALL	_CONVSCROBJ	; D4 <-- position [obj]	JUMP,NE EXIT$	JUMP	ZONE$OSEL$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BS OSUB$	CALL	DESCLEAR	; efface l'objet	CALL	_LSTO_HEXTEND	; tend l'objet	JUMP',EQ OADD$	PUSH.W	D7	CALL	DESSET		; redessine l'objet	POP.W	D7	JUMP'	EXIT$OSUB$:	LOAD.W	D7,#ERPBIP	COMP.W	(A6)+OSELNB,#1	; dslectionne le dernier objet ?	JUMP',EQ EXIT$		; oui => EXIT$	CALL	_LSTO_HCOMPACT	; compactifie l'objet	CALL	DESSET		; redessine l'objet	CALL	SELOBJMAJ	; met  jour la slection	JUMP'	OK$OADD$:	INC.W	(A6)+OSELNB	COMP.W	(A6)+OSELNB,#1	JUMP',NE OK$	LOAD.L	(A6)+OSELPS,A4	; OSELPS <-- ^objet slectionOK$:	SET.B	(A6)+OMAJ	; mise  jour sur disque ncessaire	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; SELOBJMAJ >;==========/; Met  jour la slection en fonction des objets effectivement slectionns.; in	-; out	-; mod	D7.WSELOBJMAJ:	PUSH.L	A4	CLR.L	(A6)+OSELPS	CLR.W	(A6)+OSELNB	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	INC.W	(A6)+OSELNB	; OSELNB <-- un objet de plus	TEST.L	(A6)+OSELPS	; premier objet dj trouv ?	JUMP',NE NEXT$		; oui => NEXT$	LOAD.L	(A6)+OSELPS,A4	; OSELPS <-- ^premier objet slectionNEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	POP.L	A4	RET;--------\\; SELOPEN >;========/; Ouvre la slection.; Allume tous les objets, le rectangle de slection et les poignes.; in	-; out	D7.W	erreur; mod	D7.WSELOPEN:	PUSHM.L	D1..D4,A2..A4	CALL	WDOOPEN		; dessine dans la swdo	CLR.L	(A6)+OLIMB1	CLR.L	(A6)+OLIMB2OTHER$:	COMP.W	(A6)+OSELNB,#1	JUMP',NE NOONE$	LOAD.L	A4,(A6)+OSELPS	; A4 <-- ^objet	LOAD.W	(A6)+OICOID,(A4)+OobjIDENT ; OICOID <-- identificateur	LOAD.W	D1,#opHANDICOLIST	CALL	_OBJCALLD	; A3 <-- ^liste des icnes, A2 <-- ^table des softkeys	LOAD.L	(A6)+OICOPH,A3	; OICOPH <-- ^liste des icnes	LOAD.L	(A6)+OICOPS,A2	; OICOPS <-- ^table des soft-keysNOONE$:	LOAD.W	D3,(A6)+OOUTIL	COMP.W	D3,#ICOOCRAYON	JUMP,EQ CRAYON$	COMP.W	D3,#ICOOLOUPE	JUMP,EQ LOUPE$	COMP.W	D3,#ICOOMAIN	JUMP,EQ MAIN$	COMP.W	D3,#ICOOFLECHE	JUMP',EQ FLECHE$	COMP.W	D3,#ICOOOPER	JUMP,EQ OPER$	COMP.W	D3,#ICOOGROUPE	JUMP,EQ GROUPE$	COMP.W	D3,#ICOOPLAN	JUMP,EQ PLAN$	JUMP	OK$FLECHE$:	COMP.W	(A6)+OSELNB,#1	JUMP,NE MULTI$	LOAD.L	A4,(A6)+OSELPS	; A4 <-- ^objet	CALL	HANDUNDOCOPY	; copie de l'objet	CALL	_LSTA_POS	; met  jour la position absolue	LIB	?AFTIM	.B	MAPTT	.B	-1-B'10001000	.B	1	.B	0	.EVEN	LOAD.W	D3,D2	LOAD.L	D2,#2^BVUECLR!2^BVUETTT!2^BVUEPROV!2^BVUEPROVE	CALL	DESOBJET	; teint l'objet, mais garde l'original	LOAD.W	D2,D3	LOAD.W	D3,#HANDMOVEOPEN	LOAD.W	D1,#opHANDMOVE	CALL	_OBJCALLD	; ouvre le dplacement	LOAD.L	D2,#2^BVUESET!2^BVUEPROV!2^BVUEPROVE	CALL	DESOBJET	; allume l'objet	CALL	_GROUPBBFILS	; D3/D4 <-- bbox des fils	LOAD.L	(A6)+OLIMB1,D3	LOAD.L	(A6)+OLIMB2,D4	CLR.L	(A6)+OPOISDD	; somme des dplacements nulle	JUMP	OK$CRAYON$:	COMP.W	(A6)+OSELNB,#1	JUMP',NE NOCRAY$	LOAD.L	A4,(A6)+OSELPS	; A4 <-- ^objet	COMP.W	(A4)+OobjIDENT,#IDENTFGROUP	JUMP',LO NOCRAY$	COMP.W	(A4)+OobjIDENT,#IDENTLGROUP	JUMP',LO MULTI$NOCRAY$:	LOAD.W	(A6)+OOUTIL,#ICOOFLECHE ; crayon interdit si ce n'est pas un groupe !	JUMP	OTHER$MULTI$:LOUPE$:MAIN$:GROUPE$:PLAN$:	CALL	SELUNDOCOPY	; copie de tous les objets slectionns	JUMP	OK$OPER$:	CALL	ZONESELFILS	; slectionne aussi tous les fils	JUMP,NE ERROR$	CALL	SELUNDOCOPY	; copie de tous les objets slectionns	CALL	ZONEABS		; rend tous les objets absolus !	CLR.B	(A6)+OZONDE	LOAD.W	D4,#ZONEMOVEDEFORME	CALL	ZONEMOVEH	; D4 <-- zro si dformation possible	TEST.W	D4	JUMP',EQ OPDEF$	SET.B	(A6)+OZONDE	COMP.W	(A6)+OOPER,#ICOZDEFORME	JUMP',NE OPDEF$	LOAD.W	(A6)+OOPER,#ICOZZOOMOPDEF$:	CLR.B	(A6)+OZONDB	LOAD.W	D4,#ZONEMOVEDEFBEZ	CALL	ZONEMOVEH	; D4 <-- zro si dformation possible	TEST.W	D4	JUMP',EQ OPDEFBZ$	SET.B	(A6)+OZONDB	COMP.W	(A6)+OOPER,#ICOZDEFBEZ	JUMP',NE OPDEFBZ$	LOAD.W	(A6)+OOPER,#ICOZZOOMOPDEFBZ$:	COMP.W	(A6)+OOPER,#ICOZDEFORME	JUMP',EQ DEFORME$	COMP.W	(A6)+OOPER,#ICOZDEFBEZ	JUMP',EQ DEFBEZ$	COMP.W	(A6)+OOPER,#ICOZZOOM	JUMP',NE OEND$ZOOM$:	CLR.B	(A6)+OZONHB	LOAD.W	D4,#ZONEMOVEHOMOT	CALL	ZONEMOVEH	; D4 <-- zro si dformation possible	TEST.W	D4	JUMP',EQ OEND$	SET.B	(A6)+OZONHB	; OZONHB <-- homothtie bloque	SET.B	(A6)+OZONHO	; OZONHO <-- homothtie	JUMP'	OEND$DEFBEZ$:	CALL	ZONEQREDUCE	; calcule une zone la plus petite possible	CALL	ZONEQDBHOR	; ajuste les poignes secondaires horizontales	CALL	ZONEQDBVER	; ajuste les poignes secondaires verticalesDEFORME$:	CALL	ZONEMOVEB	; dbut du dplacementOEND$:;	JUMP'	OK$OK$:	CALL	SELOPLIDF	; OSELID <-- identificateurs de dfinition	LOAD.L	A4,(A6)+OSELPS	; A4 <-- ^objet	CALL	HANDLIMIT	; OLIMP1/P2 <-- P1/P2 limites	CALL	ZONEQREDUCE	; calcule une zone la plus petite possible	CALL	SELRECSET	; allume le rectangle de slection	CALL	SELPOISET	; allume toutes les poignes	CLR.W	D7		; D7 <-- okERROR$:	PUSH.W	D7	CALL	WDOCLOSE	; fin du dessin dans la swdo	POP.W	D7	POPM.L	D1..D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; SELOPLIDF >;----------/; Fait la liste de tous les objets de dfinitions utiliss par; les objets slectionns.; in	-; out	-; mod	D7.WSELOPLIDF:	PUSHM.L	D0..D4,A2..A4	PUSH.L	(A6)+OAPOS	LOAD.L	A2,#(A6)+OSELID	LOAD.W	D2,#NBISTATE+1-1CLEAR$:	CLR.W	(A2+)		; OSELID <-- table vide	DECJ.W,NMO D2,CLEAR$	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP,NE EXIT$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP,BC NEXT$	LOAD.W	D0,(A4)+OobjIDENT	LOAD.W	D1,#opIDENTSTATE	EX.L	A3,A4	CALL	_OBJCALL	; A3 <-- ^liste des identificateurs	EX.L	A4,A3	TEST.W	D7	JUMP,NE NEXT$IDENT$:	LOAD.W	D3,(A3+)	; D3 <-- identificateur suivant	JUMP,EQ IDENT$	COMP.W	D3,#-1		; fin de la table ?	JUMP',EQ NEXT$		; oui => NEXT$	LOAD.L	A2,#(A6)+OSELID	CLR.W	D2PUT$:	TEST.W	(A2)	JUMP',EQ NEW$	COMP.W	D3,(A2+)	; dj mis dans la table ?	JUMP,EQ IDENT$		; oui => IDENT$	INC.W	D2	JUMP	PUT$NEW$:	COMP.W	D2,#NBISTATE	JUMP',HS EXIT$	LOAD.W	(A2+),D3	; OSELID <-- identificateur	CLR.W	(A2)		; OSELID <-- terminateur	JUMP	IDENT$NEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	POP.L	(A6)+OAPOS	POPM.L	D0..D4,A2..A4	RET;---------\\; SELCLOSE >;=========/; Ferme la slection.; Eteint tous les objets, le rectangle de slection et les poignes.; Les objets restent slectionns !; in	D2.W	0 => normal;		1 => annule; out	-; mod	D7.WSELCLOSE:	PUSHM.L	D1..D4,A4	CALL	WDOOPEN		; dessine dans la swdo	CALL	SELPOICLR	; teint toutes les poignes	CALL	SELRECCLR	; teint le rectangle de slection	LOAD.W	D3,(A6)+OOUTIL	COMP.W	D3,#ICOOCRAYON	JUMP,EQ CRAYON$	COMP.W	D3,#ICOOLOUPE	JUMP,EQ LOUPE$	COMP.W	D3,#ICOOMAIN	JUMP,EQ MAIN$	COMP.W	D3,#ICOOFLECHE	JUMP',EQ FLECHE$	COMP.W	D3,#ICOOOPER	JUMP,EQ OPER$	COMP.W	D3,#ICOOGROUPE	JUMP,EQ GROUPE$	COMP.W	D3,#ICOOPLAN	JUMP,EQ PLAN$	JUMP	EXIT$FLECHE$:	COMP.W	(A6)+OSELNB,#1	JUMP,NE MULTI$	LOAD.L	A4,(A6)+OSELPS	; A4 <-- ^objet	LOAD.W	D3,D2	LOAD.L	D2,#2^BVUECLR!2^BVUEPROV!2^BVUEPROVE	CALL	DESOBJET	; teint l'objet	LOAD.W	D2,D3	LOAD.W	D3,#HANDMOVECLOSE ; D3 <-- fin	LOAD.W	D1,#opHANDMOVE	CALL	_OBJCALLD	; ferme le dplacement	LOAD.W	D1,#opGETBBOX	CALL	_OBJCALLD	; D3/D4 <-- bounding box	LOAD.L	(A4)+OobjBBOX1,D3	LOAD.L	(A4)+OobjBBOX2,D4	TEST.W	D2		; annule ?	JUMP',NE OBACK$		; oui => OBACK$	LOAD.L	D2,#2^BVUESET!2^BVUEPROV!2^BVUEPROVE	CALL	DESOBJET	; allume l'objet	CALL	SELINICLR	; teint l'objet initial	JUMP	FLUSH$OBACK$:	LOAD.L	D2,#2^BVUECLR!2^BVUEPROV!2^BVUEPROVI	CALL	DESOBJET	; teint l'intrieur de l'objet	CALL	HANDCLRFILS	; teint tous les fils	CALL	HANDUNDOBACK	; reprend l'objet original	LOAD.L	D4,(A6)+OPOISDD	; D4 <-- somme de tous les dplacements	NEG.W	D4	SWAP.W	D4	NEG.W	D4	SWAP.W	D4	CALL	_GROUPDFILS	; dplace tous les fils (pour qu'ils restent immoblies)	LIB	?AFTIM	.B	MAPTT	.B	B'10001000	.B	1	.B	0	.EVEN	LOAD.L	D2,#2^BVUECLR!2^BVUETTT!2^BVUEPROV!2^BVUEPROVE	CALL	DESOBJET	; teint l'objet initial	JUMP	EXIT$CRAYON$:MULTI$:LOUPE$:MAIN$:GROUPE$:PLAN$:	TEST.W	D2	JUMP,EQ FLUSH$	CALL	SELOBJCLR	; teint tous les objets	CALL	SELUNDOBACK	; reprend tous les objets originaux	JUMP	EXIT$OPER$:	COMP.W	(A6)+OOPER,#ICOZDEFORME	JUMP',EQ OPDEF$	COMP.W	(A6)+OOPER,#ICOZDEFBEZ	JUMP',NE OPEND$OPDEF$:	CALL	ZONEMOVEE	; fin du dplacementOPEND$:	TEST.W	D2	JUMP',NE OPBACK$	CALL	ZONEREL		; rend tous les objets relatifs	CALL	ZONEDESELFILS	; dslectionne aussi tous les fils	JUMP'	EXIT$OPBACK$:	CALL	SELOBJCLR	; teint tous les objets	CALL	SELUNDOBACK	; reprend tous les objets originaux	JUMP'	EXIT$FLUSH$:	CALL	SELUNDOFLUSH	; annule tous les objets copisEXIT$:	CALL	WDOCLOSE	; fin du dessin dans la swdo	POPM.L	D1..D4,A4	RET;------------\\; SELUNDOCOPY >;============/; Copie tous les objets slectionns.; in	-; out	D7.W	erreur; mod	D7.WSELUNDOCOPY:	PUSH.L	A4	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	CALL	HANDUNDOCOPY	; copie un objet	JUMP',NE EXIT$NEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; SELUNDOBACK >;============/; Remet tous les objets slectionns dans leur tat initial.; in	-; out	-; mod	D7.WSELUNDOBACK:	PUSH.L	A4	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	CALL	HANDUNDOBACK	; remet dans l'tat initialNEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	POP.L	A4	RET;-------------\\; SELUNDOFLUSH >;=============/; Annule tous les objets copis.; in	-; out	-; mod	D7.WSELUNDOFLUSH:	PUSH.L	A4	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	CALL	HANDUNDOFLUSH	; annule une copieNEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	POP.L	A4	RET;-----------\\; SELTERMINE >;===========/; Dslectionne tous les objets slectionns.; in	-; out	-; mod	D7.WSELTERMINE:	PUSH.L	A4	COMP.W	(A6)+OOUTIL,#ICOOFLECHE	JUMP',NE MULTI$FLECHE$:	COMP.W	(A6)+OSELNB,#1	JUMP',NE MULTI$	LOAD.L	A4,(A6)+OSELPS	; A4 <-- ^objet	CALL	_LSTO_HCOMPACT	; compactifie l'objet	CALL	DESSET		; redessine l'objet	JUMP'	EXIT$MULTI$:	CALL	ZONEDESELECT	; dslectionne toutEXIT$:	POP.L	A4	RET;--------\\; SELINFO >;========/; Affiche les informations.; in	-; out	-; mod	D7.WSELINFO:	PUSHM.L	D1,A4	COMP.W	(A6)+OOUTIL,#ICOOFLECHE	JUMP',NE NBOBJ$FLECHE$:	COMP.W	(A6)+OSELNB,#1	JUMP',NE NBOBJ$	LOAD.L	A4,(A6)+OSELPS	; A4 <-- ^objet	LOAD.W	D1,#opHANDINFO	CALL	_DESINFOBJ	; affiche les informations	JUMP'	EXIT$NBOBJ$:	CALL	_DESINFSEL	; affiche les informationsEXIT$:	POPM.L	D1,A4	RET;----------\\; SELINFOXY >;==========/; Affiche les informations X= Y=.; in	-; out	-; mod	D7.WSELINFOXY:	COMP.W	(A6)+OOUTIL,#ICOOFLECHE	JUMP',NE XY$FLECHE$:	COMP.W	(A6)+OSELNB,#1	JUMP',EQ EXIT$XY$:	CALL	_DESINFXY	; affiche X= et Y= dans les informationsEXIT$:	RET;------------\\; SELINFOMOVE >;============/; Affiche les informations pendant un dplacement.; in	-; out	-; mod	D7.WSELINFOMOVE:	PUSHM.L	D1,A4	COMP.W	(A6)+OOUTIL,#ICOOFLECHE	JUMP',NE XY$FLECHE$:	COMP.W	(A6)+OSELNB,#1	JUMP',NE XY$	LOAD.L	A4,(A6)+OSELPS	; A4 <-- ^objet	LOAD.W	D1,#opHANDINFO	CALL	_DESINFOBJ	; affiche les informations	JUMP'	EXIT$XY$:	CALL	_DESINFXY	; affiche X= et Y= dans les informationsEXIT$:	POPM.L	D1,A4	RET;--------\\; SELICOM >;========/; Cherche la bonne icne pour la souris.; in	D4.L	position de la souris (y;x)  [scr]; out	D3.W	icne pour la souris (lutin); mod	D7.WSELICOM:	PUSHM.L	D1,D2,D4,A2..A4	LOAD.W	D3,(A6)+OOUTIL	COMP.W	D3,#ICOOFLECHE	JUMP,NE EXIT$FLECHE$:	COMP.W	(A6)+OSELNB,#1	JUMP,NE EXIT$	LOAD.L	A4,(A6)+OSELPS	; A4 <-- ^objet	LOAD.W	D1,#opEDITICOLIST	CALL	_OBJCALLD	; A2/A3 <-- ^soft-keys/^icnes (objet ditable ?)	JUMP',NE NOEDIT$	; non => NOEDIT$	CALL	SELDETECT	; D2 <-- poigne montre	JUMP',EQ NORM$	CALL	_CONVSCROBJ	; D4 <-- point o est la souris [obj]	JUMP',NE NORM$	LOAD.L	D1,D4	LOAD.L	D2,D4	CALL	_LSTA_BBOX	; D3/D4 <-- bbox absolue	CALL	_RECTTEST	; souris dans l'objet ?	JUMP',EQ NORM$		; non => NORM$	LOAD.W	D3,#ICOOEDIT	JUMP'	EXIT$NOEDIT$:	LOAD.W	D1,#opHANDICOOUTIL	CALL	_OBJCALLD	; D3 <-- icne pour la souris	JUMP',EQ EXIT$NORM$:	LOAD.W	D3,#ICOOFLECHE;	JUMP'	EXIT$EXIT$:	POPM.L	D1,D2,D4,A2..A4	RET;---------\\; SELICONE >;=========/; Agit dans une icne spciale.; in	D3.W	icne clique; out	D7.W	erreur; mod	D7.WSELICONE:	PUSHM.L	D0..D5,A2,A4	COMP.W	D3,#ICOOLOUPEP	JUMP,EQ LOUPECH$	COMP.W	D3,#ICOOLOUPEM	JUMP,EQ LOUPECH$	COMP.W	D3,#ICOZPLUS	JUMP,EQ OPER$	COMP.W	D3,#ICOZMOINS	JUMP,EQ OPER$	COMP.W	D3,#ICOT90	JUMP,EQ OPER$	COMP.W	D3,#ICOT180	JUMP,EQ OPER$	COMP.W	D3,#ICOT270	JUMP,EQ OPER$	COMP.W	D3,#ICOMVERT	JUMP,EQ OPER$	COMP.W	D3,#ICOMHORIZ	JUMP,EQ OPER$	COMP.W	D3,#ICODQQ	JUMP,EQ OPER$	COMP.W	D3,#ICODTRAH	JUMP,EQ OPER$	COMP.W	D3,#ICODTRAV	JUMP,EQ OPER$	COMP.W	D3,#ICODPARH	JUMP,EQ OPER$	COMP.W	D3,#ICODPARV	JUMP,EQ OPER$	COMP.W	D3,#ICOBQQ	JUMP,EQ OPER$	COMP.W	D3,#ICOBHORIZ	JUMP,EQ OPER$	COMP.W	D3,#ICOBVERTI	JUMP,EQ OPER$	COMP.W	D3,#ICOBSYMH	JUMP,EQ BSYM$	COMP.W	D3,#ICOBSYMV	JUMP,EQ BSYM$	COMP.W	D3,#ICOBSYMVI	JUMP,EQ BSYM$	COMP.W	D3,#ICOZHOMOT	JUMP,EQ ZHOMOT$	COMP.W	D3,#ICODEVANT	JUMP,EQ PLANDEV$	COMP.W	D3,#ICODERRIERE	JUMP,EQ PLANDER$	COMP.W	D3,#ICOODEVANT	JUMP,EQ PLANCH$	COMP.W	D3,#ICOODERRIERE	JUMP,EQ PLANCH$	COMP.W	D3,#ICOFUP	JUMP,EQ FUP$	COMP.W	D3,#ICOFDOWN	JUMP,EQ FDOWN$	COMP.W	D3,#ICOOBJET+0	JUMP',LO INIT2$	COMP.W	D3,#ICOOBJET+NBIOBJET	JUMP',LO OBJET$INIT2$:	COMP.W	D3,#ICOSTATE+0	JUMP',LO INIT3$	COMP.W	D3,#ICOSTATE+NBISTATE	JUMP,LO STATE$INIT3$:	COMP.W	D3,#ICOALLST+0	JUMP',LO INIT4$	COMP.W	D3,#ICOALLST+NBISTATE	JUMP,LO ALLST$INIT4$:	JUMP	BIP$; Clic dans un objet lorsque le crayon est allum.OBJET$:	COMP.W	D3,(A6)+OOBJET	JUMP,EQ BIP$	LOAD.W	(A6)+OOBJET,D3	LOAD.W	D3,#ICOSTATE	LOAD.W	D4,#NBISTATE-1OBST$:	CALL	_KSTICONE	; supprime l'tat de l'icne	INC.W	D3	DECJ.W,NMO D4,OBST$	CALL	_UPDICONE	; met  jour les icnes	JUMP	OK$; Clic dans une icne de dfinition pour crer un nouvel objet.STATE$:	LOAD.W	D2,D3	SUB.W	D3,#ICOSTATE	; D3 <-- 0..n	LOAD.W	D0,(A6)+OOBJET	ADD.W	D0,(A6)+OICOFO	SUB.W	D0,#ICOOBJET	CALL	_OBJGETID	; D0 <-- identificateur de l'objet	JUMP,NE BIP$	LOAD.W	D1,#opIDENTSTATE ; D1 <-- mthode	CALL	_OBJCALL	; A4 <-- ^identificateurs des tats	JUMP,NE BIP$STATE2$:	DEC.W	D3	JUMP',NS STATE3$	COMP.W	(A4+),#-1	JUMP,NE STATE2$	JUMP	BIP$STATE3$:	LOAD.W	D3,(A4)		; D3 <-- identificateur	COMP.W	D3,#ICOVIDE	JUMP,EQ BIP$	LOAD.W	D1,#opMODSTATE	CALL	_OBJCALL	; modifie l'tat ...	JUMP,NE BIP$	ADD.W	(A6)+OGBBOX,D4	; OGBBOX <-- nb de modifications	LOAD.W	D3,D2		; D3 <-- icne	CALL	_DESICONEONE	; redessine une icne	JUMP	OK$; Clic dans une icne de dfinition lorsque plusieurs objets sont slectionns.ALLST$:	LOAD.W	D2,D3		; D2 <-- icne	LOAD.W	D0,D3	SUB.W	D0,#ICOALLST	; D0 <-- 0..n	SL.W	D0,#1	LOAD.L	A4,#(A6)+OSELID	; A4 <-- ^identificateurs de dfinition	LOAD.W	D0,(A4)+(D0.W)	; D0 <-- identificateur de dfinition	JUMP,EQ BIP$	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D1,#opDSELECT	CALL	_OBJCALL	; choix d'un tat ...	JUMP,NE EXIT$	ADD.W	(A6)+OGBBOX,D4	; OGBBOX <-- nb de modifications	COMP.W	D3,#F1	JUMP,NE EXIT$	LOAD.W	D3,D2	CALL	_DESICONEONE	; redessine l'icne	CALL	WDOOPEN		; dessine dans la swdo	CALL	SELPOICLR	; teint les poignes	LOAD.W	D3,D0	CALL	ZONEMODIF	; modifie toute la zone	CALL	SELPOISET	; allume les poignes	CALL	WDOCLOSE	; fin du dessin dans la swdo	JUMP	OK$; Montre les objets prcdents.FUP$:	TEST.W	(A6)+OICOFO	JUMP,EQ BIP$	LOAD.W	D4,#4-1	ADD.W	D4,(A6)+OICOSY	MUL.WU	D4,#3	SUB.W	(A6)+OICOFO,D4	JUMP'	FMAJ$; Montre les objets suivants.FDOWN$:	LOAD.W	D4,#4-1	ADD.W	D4,(A6)+OICOSY	MUL.WU	D4,#3	ADD.W	(A6)+OICOFO,D4	CALL	_OBJGETNB	; D4 <-- nombre d'objets connects	SUB.W	D4,(A6)+OICOFO	ADD.W	D4,#ICOOBJET+0	COMP.W	D4,(A6)+OOBJET	JUMP',HI FMAJ$	DEC.W	D4	LOAD.W	(A6)+OOBJET,D4FMAJ$:	CALL	_DESICONE	; redessine les icnes	CALL	_MAJICONE	; met  jour les icnes variables	JUMP	OK$; Clic dans une icne d'une opration spcifique.LOUPECH$:	COMP.W	D3,(A6)+OLOUPE	JUMP,EQ BIP$	LOAD.W	(A6)+OLOUPE,D3	JUMP	OK$OPER$:	CALL	WDOOPEN		; dessine dans la swdo	CALL	SELPOICLR	; teint les poignes	CALL	SELRECCLR	; teint la zone	CALL	ZONEQOPER	; opration selon icne	CALL	SELIFDSP	; chane dans la mme page ?	CALL	SELRECSET	; allume la zone	CALL	SELPOISET	; allume les poignes	CALL	WDOCLOSE	; fin du dessin dans la swdo	JUMP	OK$BSYM$:	COMP.W	D3,(A6)+OZONDFC	JUMP',NE BSYM2$	CLR.W	D3BSYM2$:	LOAD.W	(A6)+OZONDFC,D3	JUMP'	OK$ZHOMOT$:	TEST.B	(A6)+OZONHB	; homothtie bloque ?	JUMP',NE BIP$		; oui => BIP$	NOT.B	(A6)+OZONHO	JUMP'	OK$PLANCH$:	COMP.W	D3,(A6)+OPLAN	JUMP',EQ BIP$	LOAD.W	(A6)+OPLAN,D3	JUMP'	OK$PLANDEV$:	LOAD.L	A4,(A6)+OSELPS	CALL	_LSTA_OLD	; A4 <-- ^frre an	CALL	_GROUPDEVANT	; met devant le frre an	JUMP',NE BIP$	JUMP'	OK$PLANDER$:	LOAD.L	A4,(A6)+OSELPS	CALL	_LSTA_YOUNG	; A4 <-- ^frre benjamin	CALL	_GROUPDERRIERE	; met derrire le frre benjamin	JUMP',NE BIP$	JUMP'	OK$BIP$:	LOAD.W	D7,#1	JUMP'	EXIT$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D5,A2,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; SELDETECT >;==========/; Dtecte dans quelle poigne est la souris.; in	D4.L	position de la souris (y;x)  [scr]; out	D2.W	rang de la poigne (0..n);	D7.W	erreur; mod	D2.L, D7.WSELDETECT:	PUSHM.L	D1,D3,D4,A4	LOAD.W	D3,(A6)+OOUTIL	COMP.W	D3,#ICOOFLECHE	JUMP',EQ FLECHE$	COMP.W	D3,#ICOOOPER	JUMP,EQ OPER$	JUMP	ERROR$FLECHE$:	COMP.W	(A6)+OSELNB,#1	JUMP,NE MULTI$	LOAD.L	A4,(A6)+OSELPS	; A4 <-- ^objet	CALL	HANDDETECT	; D2 <-- rang de la poigne	JUMP',NE OERROR$	LOAD.W	D1,#opHANDICOOUTIL	CALL	_OBJCALLD	; D3 <-- icne pour la souris	COMP.W	D3,#ICOHADD	; outil = ajoute poigne ?	JUMP,EQ ERROR$		; oui => ERROR$	COMP.W	D3,#ICOHNEW	; outil = nouvelle courbe ?	JUMP,EQ ERROR$		; oui => ERROR$	COMP.W	D3,#ICOHLINE	; outil = transforme ligne ?	JUMP,EQ ERROR$		; oui => ERROR$	COMP.W	D3,#ICOHCURVE	; outil = transforme courbe ?	JUMP,EQ ERROR$		; oui => ERROR$	JUMP	OK$OERROR$:	LOAD.W	D1,#opHANDICOOUTIL	CALL	_OBJCALLD	; D3 <-- icne pour la souris;	LOAD.W	D2,#-1		; D2 <-- rang spcial	COMP.W	D3,#ICOHADD	; outil = ajoute poigne ?	JUMP,EQ OK$	COMP.W	D3,#ICOHNEW	; outil = nouvelle courbe ?	JUMP,EQ OK$	COMP.W	D3,#ICOHLINE	; outil = transforme ligne ?	JUMP,EQ OK$	COMP.W	D3,#ICOHCURVE	; outil = transforme courbe ?	JUMP,EQ OK$	JUMP	ERROR$MULTI$:	CLR.W	D2		; D2 <-- rang de la poigne	LOAD.L	D3,D4	LOAD.L	D4,(A6)+OZONYC	CALL	_CONVOBJSCR	; D4 <-- position [scr]	JUMP',NE EXIT$	SUB.W	D4,#DPOIGNEE	COMP.W	D3,D4		; trop  gauche ?	JUMP',LT ERROR$	ADD.W	D4,#DPOIGNEE*2	COMP.W	D3,D4		; trop  droite ?	JUMP',GE ERROR$	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,#DPOIGNEE	COMP.W	D3,D4		; trop haut ?	JUMP',LT ERROR$	ADD.W	D4,#DPOIGNEE*2	COMP.W	D3,D4		; trop bas ?	JUMP',GE ERROR$	JUMP'	OK$OPER$:	CALL	ZONEQHDETECT	; D2 <-- poigne	JUMP'	EXIT$ERROR$:	LOAD.W	D7,#1	JUMP'	EXIT$OK$:	CLR.W	D7EXIT$:	POPM.L	D1,D3,D4,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; SELBEGIN >;=========/; Dbut du dplacement d'une poigne.; in	D2.W	rang de la poigne  dplacer (0..n);	D4.L	position de la souris (y;x); out	-; mod	D7.WSELBEGIN:	PUSHM.L	D1..D4,A4	PUSH.L	(A6)+OAPOS	CALL	WDOOPEN		; dessine dans la swdo	CALL	SELPOICLR	; teint toutes les poignes	LOAD.W	D3,(A6)+OOUTIL	COMP.W	D3,#ICOOOPER	JUMP,EQ OPER$	COMP.W	D3,#ICOOFLECHE	JUMP',EQ FLECHE$	JUMP	EXIT$FLECHE$:	COMP.W	(A6)+OSELNB,#1	JUMP,NE MULTI$	LOAD.L	A4,(A6)+OSELPS	; A4 <-- ^objet	PUSH.L	D4	LOAD.L	D4,#-1	COMP.W	D2,#-1		; rang spcial ?	JUMP',EQ OOPEN$	LOAD.W	D1,#opHANDGET	CALL	_OBJCALLD	; D3/D4 <-- icne/position	ADD.W	D4,(A6)+OAPOS+2	SWAP.W	D4	ADD.W	D4,(A6)+OAPOS+0	SWAP.W	D4OOPEN$:	CALL	HVOPEN		; contrainte: fixe le point initial	POP.L	D4	LOAD.W	D3,D2	LOAD.L	D2,#2^BVUECLR!2^BVUEPROV!2^BVUEPROVI	CALL	DESOBJET	; teint l'intrieur de l'objet	LOAD.W	D2,D3	SUB.W	D4,(A6)+OAPOS+2	SWAP.W	D4	SUB.W	D4,(A6)+OAPOS+0	SWAP.W	D4	LOAD.W	D3,#HANDMOVEBEGIN	LOAD.W	D1,#opHANDMOVE	CALL	_OBJCALLD	; dbut	LOAD.L	(A6)+OPOILB1,(A4)+OobjBBOX1	TEST.W	D2		; centre de gravit dplac ?	JUMP,NE EXIT$		; non => EXIT$				; oui =>	CALL	HANDCLRFILS	; teint tous les fils	JUMP	EXIT$MULTI$:	LOAD.L	D4,(A6)+OZONYC	CALL	HVOPEN		; contrainte: fixe le point initial	CALL	ZONEMOVEBF	; dbut du dplacement	JUMP'	EXIT$OPER$:	CALL	ZONEQHPOS	; D3/D4 <-- type/position	JUMP',NE EXIT$	CALL	HVOPEN		; contrainte: fixe le point initial	COMP.W	(A6)+OOPER,#ICOZDEFORME	JUMP',EQ EXIT$	COMP.W	(A6)+OOPER,#ICOZDEFBEZ	JUMP',EQ EXIT$	CALL	ZONEQHMARKSET	; allume les marques	CALL	ZONEMOVEB	; dbut du dplacement;	JUMP'	EXIT$EXIT$:	CALL	WDOCLOSE	; fin du dessin dans la swdo	POP.L	(A6)+OAPOS	POPM.L	D1..D4,A4	RET;--------\\; SELDRAG >;========/; Dplacement d'une poigne.; in	D2.W	rang de la poigne  dplacer (0..n);	D3.W	0 => dplace tout;		1 => dplace jusqu' ce que la souris bouge (vnement);	D4.L	position de la souris (y;x); out	D3.W	touche presse;	D7.W	erreur (si aucun vnement); mod	D3.L, D7.WSELDRAG:	PUSHM.L	D0..D2,D4,D5,A1,A4	CALL	WDOOPEN		; dessine dans la swdo	LOAD.W	D1,D3		; D1 <-- mode de dplacement	LOAD.W	D3,(A6)+OOUTIL	COMP.W	D3,#ICOOOPER	JUMP,EQ OPER$	COMP.W	D3,#ICOOFLECHE	JUMP',EQ FLECHE$	JUMP	EXIT$FLECHE$:	COMP.W	(A6)+OSELNB,#1	JUMP,NE MULTI$	LOAD.L	A4,(A6)+OSELPS	; A4 <-- ^objet	SUB.W	D4,(A6)+OAPOS+2	SWAP.W	D4	SUB.W	D4,(A6)+OAPOS+0	SWAP.W	D4	LOAD.W	D1,#opHANDICOOUTIL	CALL	_OBJCALLD	; D3 <-- icne pour la souris	JUMP',NE ONE2$	COMP.W	D3,#ICOHMOVE	JUMP',EQ ONE2$	COMP.W	D3,#ICOHNEW	JUMP,NE ONESP$ONE2$:	LOAD.L	D0,D4		; D0 <-- nouvelle position	LOAD.W	D1,#opHANDGET	CALL	_OBJCALLD	; D4 <-- ancienne position	EX.L	D4,D0		; D0/D4 <-- ancienne/nouvelle position	LOAD.W	D3,D2		; D3 <-- poigne	LOAD.L	D2,#2^BVUECLR!2^BVUEPROV!2^BVUEPROVE!2^BVUEPROVH	CALL	DESOBJET	; teint l'objet	LOAD.W	D2,D3	LOAD.W	D3,#HANDMOVEDRAG	LOAD.W	D1,#opHANDMOVE	CALL	_OBJCALLD	; dplace  la nouvelle position	TEST.W	D2		; dplace la poigne centrale ?	JUMP,NE ONE4$		; non => ONE4$				; oui =>	LOAD.L	D5,D4	SUB.W	D5,D0	SWAP.W	D0	SWAP.W	D5	SUB.W	D5,D0		; D5 <-- +/- dplacement	SWAP.W	D0	SWAP.W	D5	ADD.W	(A4)+OobjBBOX1+2,D5	ADD.W	(A4)+OobjBBOX2+2,D5	SWAP.W	D5	ADD.W	(A4)+OobjBBOX1+0,D5	ADD.W	(A4)+OobjBBOX2+0,D5	SWAP.W	D5	PUSH.L	(A6)+OLIMB1	PUSH.L	(A6)+OLIMB2	CLR.L	(A6)+OLIMB1	CLR.L	(A6)+OLIMB2	; pas de test pour les fils !	CALL	HANDPOSOKQ	; nouvelle position ok (rapidement) ?	POP.L	(A6)+OLIMB2	POP.L	(A6)+OLIMB1	TEST.W	D7	JUMP,EQ ONE9$		; oui => ONE9$	LOAD.L	D4,D0		; D4 <-- ancienne position	LOAD.W	D3,#HANDMOVEDRAG	LOAD.W	D1,#opHANDMOVE	CALL	_OBJCALLD	; redplace  l'ancienne position	SUB.W	(A4)+OobjBBOX1+2,D5	SUB.W	(A4)+OobjBBOX2+2,D5	SWAP.W	D5	SUB.W	(A4)+OobjBBOX1+0,D5	SUB.W	(A4)+OobjBBOX2+0,D5	SWAP.W	D5	ADD.W	D4,(A6)+OAPOS+2	SWAP.W	D4	ADD.W	D4,(A6)+OAPOS+0	SWAP.W	D4	CALL	_CONVOBJSCR	; D4 <-- position [scr]	JUMP,NE ONE9$	SUB.W	D4,(A6)+OLUPX	SWAP.W	D4	SUB.W	D4,(A6)+OLUPY	SWAP.W	D4	CALL	_PMOUSE		; dplace la souris !	JUMP	ONE9$ONE4$:	CALL	HANDPOSOK	; nouvelle position ok ?	JUMP',EQ ONE9$		; oui => ONE9$	LOAD.L	D4,D0		; D4 <-- ancienne position	LOAD.W	D3,#HANDMOVEDRAG	LOAD.W	D1,#opHANDMOVE	CALL	_OBJCALLD	; redplace  l'ancienne position	ADD.W	D4,(A6)+OAPOS+2	SWAP.W	D4	ADD.W	D4,(A6)+OAPOS+0	SWAP.W	D4	CALL	_CONVOBJSCR	; D4 <-- position [scr]	JUMP',NE ONE9$	SUB.W	D4,(A6)+OLUPX	SWAP.W	D4	SUB.W	D4,(A6)+OLUPY	SWAP.W	D4	CALL	_PMOUSE		; dplace la souris !ONE9$:	LOAD.W	D3,D2		; D3 <-- poigne	LOAD.L	D2,#2^BVUESET!2^BVUEPROV!2^BVUEPROVE!2^BVUEPROVH	CALL	DESOBJET	; allume l'objet;	LOAD.W	D2,D3	LOAD.W	D7,#1		; D7 <-- pas d'vnement	JUMP	EXIT$ONESP$:	LOAD.W	D3,#HANDMOVEDRAG	LOAD.W	D1,#opHANDMOVE	CALL	_OBJCALLD	; dplace  la nouvelle position	LOAD.W	D7,#1		; D7 <-- pas d'vnement	JUMP	EXIT$MULTI$:	TEST.W	D1	JUMP',EQ MALL$	PUSH.W	(A6)+OOPER	LOAD.W	(A6)+OOPER,#ICOZZOOM	LOAD.L	A1,#R16"ZONEMOVEDFM	CALL	ZONEQHDRAG	POP.W	(A6)+OOPER	JUMP'	EXIT$MALL$:	PUSH.W	(A6)+OOPER	LOAD.W	(A6)+OOPER,#ICOZZOOM	LOAD.L	A1,#R16"ZONEMOVEDF	CALL	ZONEQHDRAG	POP.W	(A6)+OOPER	LOAD.W	D7,#1		; D7 <-- pas d'vnement	JUMP'	EXIT$OPER$:	TEST.W	D1	JUMP',EQ OPALL$	LOAD.L	A1,#R16"ZONEMOVEDM	CALL	ZONEQHDRAG	JUMP'	EXIT$OPALL$:	LOAD.L	A1,#R16"ZONEMOVED	CALL	ZONEQHDRAG	LOAD.W	D7,#1		; D7 <-- pas d'vnement;	JUMP'	EXIT$EXIT$:	PUSH.W	D7	CALL	WDOCLOSE	; fin du dessin dans la swdo	POP.W	D7	POPM.L	D0..D2,D4,D5,A1,A4	TEST.W	D7		; retour EQ/NE	RET;-------\\; SELEND >;=======/; Fin du dplacement d'une poigne.; in	D2.W	rang de la poigne  dplacer (0..n); out	D7.W	erreur; mod	D7.WSELEND:	PUSHM.L	D1..D4,A4	PUSH.L	(A6)+OAPOS	CALL	WDOOPEN		; dessine dans la swdo	LOAD.W	D3,(A6)+OOUTIL	COMP.W	D3,#ICOOOPER	JUMP,EQ OPER$	COMP.W	D3,#ICOOFLECHE	JUMP',EQ FLECHE$	JUMP	OK$FLECHE$:	COMP.W	(A6)+OSELNB,#1	JUMP,NE MULTI$	LOAD.L	A4,(A6)+OSELPS	; A4 <-- ^objet	LOAD.W	D3,D2	LOAD.L	D2,#2^BVUECLR!2^BVUEPROV!2^BVUEPROVE	CALL	DESOBJET	; teint l'objet	LOAD.W	D2,D3	LOAD.W	D3,#HANDMOVEEND	LOAD.W	D1,#opHANDMOVE	CALL	_OBJCALLD	; fin	LOAD.W	D3,D2	LOAD.L	D2,#2^BVUESET!2^BVUEPROV!2^BVUEPROVE!2^BVUEPROVI	CALL	DESOBJET	; allume l'extrieur et l'intrieur de l'objet	LOAD.W	D2,D3	LOAD.W	D1,#opGETBBOX	CALL	_OBJCALLD	; D3/D4 <-- bounding box	LOAD.L	(A4)+OobjBBOX1,D3	LOAD.L	(A4)+OobjBBOX2,D4	PUSH.W	D7	CALL	_LSTA_NB	; D4 <-- nb de fils	TEST.W	D4		; y a-t-il des fils ?	JUMP',EQ OEND$		; non => OEND$	TEST.W	D2		; centre de gravit dplac ?	JUMP',EQ OFILS$		; oui => OFILS$	LOAD.L	D4,(A6)+OPOILB1	; D4 <-- ancien P1 bbox	SUB.W	D4,D3	ADD.W	(A6)+OPOISDD+2,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	ADD.W	(A6)+OPOISDD+0,D4;	SWAP.W	D3	SWAP.W	D4		; D4 <-- contre-dplacement	CALL	_GROUPDFILS	; dplace tous les fils (pour qu'ils restent immoblies)	JUMP'	OEND$OFILS$:	CALL	_GROUPBBFILS	; D3/D4 <-- bbox des fils	LOAD.L	(A6)+OLIMB1,D3	LOAD.L	(A6)+OLIMB2,D4	CALL	HANDSETFILS	; allume tous les filsOEND$:	POP.W	D7	JUMP'	EXIT$MULTI$:	CALL	ZONEMOVEEF	; fin du dplacement	JUMP'	OK$OPER$:	COMP.W	(A6)+OOPER,#ICOZDEFORME	JUMP',EQ OK$	COMP.W	(A6)+OOPER,#ICOZDEFBEZ	JUMP',EQ OK$	CALL	ZONEQHMARKCLR	; teint les marques	CALL	ZONEMOVEE	; fin du dplacement;	JUMP'	OK$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	PUSH.W	D7	CALL	HVCLOSE		; contrainte: termine	TEST.W	D2		; centre de gravit dplac ?	JUMP',EQ NODSP$		; oui => NODSP$	CALL	SELIFDSP	; chane dans la mme page ?NODSP$:	CALL	SELPOISET	; allume toutes les poignes	CALL	WDOCLOSE	; fin du dessin dans la swdo	POP.W	D7	POP.L	(A6)+OAPOS	POPM.L	D1..D4,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; SELIFDSP >;---------/; Regarde si l'un des objet slectionn (mme s'il s'agit du fils d'un; groupe) fait partie d'une chane prsente dans la mme page.; Si oui, indique qu'il faudra tout redessiner !; in	-; out	-; mod	D7.WSELIFDSP:	PUSHM.L	D3,D4,D6,A3,A4	PUSH.L	(A6)+OAPOS	LOAD.W	D3,(A6)+OPAGE	; D3 <-- page visible	LOAD.W	D4,(A6)+OCALQ	; D4 <-- calque visible	LOAD.L	D6,(A6)+OOBACH	; D6 <-- canal de l'arbre des objets	CALL	_LSTA_BEGIN	; A4 <-- ^lment de base	LOAD.L	A3,A4		; A3 <-- ^lment pre	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	CALL	_LSTA_NB	; D4 <-- nb de fils	INC.W	D4		; D4 <-- compte aussi le preFILS$:	CALL	SUITEIFDSP	; suite de la chane dans la mme page ?	JUMP',EQ REDRAW$	; oui => REDRAW$	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,NE EXIT$	DEC.W	D4	JUMP,NE FILS$	JUMP	LOOP$NEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$	JUMP'	EXIT$REDRAW$:	INC.W	(A6)+OGDRAW	; il faudra tout redessinerEXIT$:	POP.L	(A6)+OAPOS	POPM.L	D3,D4,D6,A3,A4	RET;----------\\; SELGETREF >;==========/; Donne une rfrence en fonction de la position des objets slectionns.; in	-; out	D4.L	rfrence (y;x); mod	D4.L, D7.WSELGETREF:	PUSHM.L	D1..D3,A4	COMP.W	(A6)+OOUTIL,#ICOOFLECHE	JUMP',NE MULTI$FLECHE$:	COMP.W	(A6)+OSELNB,#1	JUMP',NE MULTI$	LOAD.L	A4,(A6)+OSELPS	; A4 <-- ^objet	CLR.W	D2		; D2 <-- poigne "cdg"	LOAD.W	D1,#opHANDGET	CALL	_OBJCALLD	; D3/D4 <-- icne/position	JUMP'	EXIT$MULTI$:	LOAD.L	D4,(A6)+OZONYC	; D4 <-- rfrenceEXIT$:	POPM.L	D1..D3,A4	RET;----------\\; SELINISET >;==========/;----------\\; SELINICLR >;==========/; Allume ou teint l'objet initial.; in	-; out	-; mod	D7.WSELINISET:	PUSH.L	D2	LOAD.L	D2,#2^BVUESET!2^BVUETTT!2^BVUEPROV!2^BVUEPROVE	CALL'	SELINISETCLR	POP.L	D2	RETSELINICLR:	PUSH.L	D2	LOAD.L	D2,#2^BVUECLR!2^BVUETTT!2^BVUEPROV!2^BVUEPROVE	CALL'	SELINISETCLR	POP.L	D2	RETSELINISETCLR:	PUSH.L	A4	COMP.W	(A6)+OOUTIL,#ICOOFLECHE	JUMP',NE EXIT$	COMP.W	(A6)+OSELNB,#1	JUMP',NE EXIT$	LOAD.L	A4,(A6)+OSELPS	; A4 <-- ^objet	CALL	HANDUNDOEX	; dessine selon la copie	LIB	?AFTIM	.B	MAPTT	.B	B'10001000	.B	1	.B	0	.EVEN	CALL	DESOBJET	; allume/teint l'objet initial	CALL	HANDUNDOEX	; dessine selon l'originalEXIT$:	POP.L	A4	RET;----------\\; SELOBJSET >;==========/;----------\\; SELOBJCLR >;==========/; Allume ou teint tous les objets slectionns.; in	-; out	-; mod	D7.WSELOBJSET:	PUSH.L	D2	LOAD.L	D2,#2^BVUESET!2^BVUEPROV!2^BVUEPROVE!2^BVUEPROVI	CALL'	SELOBJSETCLR	POP.L	D2	RETSELOBJCLR:	PUSH.L	D2	LOAD.L	D2,#2^BVUECLR!2^BVUEPROV!2^BVUEPROVE!2^BVUEPROVI	CALL'	SELOBJSETCLR	POP.L	D2	RETSELOBJSETCLR:	PUSHM.L	D1,D3,A4	PUSH.L	(A6)+OAPOS	CALL	WDOOPEN		; dessine dans la swdo	LOAD.W	D3,(A6)+OOUTIL	COMP.W	D3,#ICOOCRAYON	JUMP',EQ CRAYON$	COMP.W	D3,#ICOOLOUPE	JUMP',EQ LOUPE$	COMP.W	D3,#ICOOMAIN	JUMP',EQ MAIN$	COMP.W	D3,#ICOOFLECHE	JUMP',EQ FLECHE$	COMP.W	D3,#ICOOOPER	JUMP,EQ OPER$	COMP.W	D3,#ICOOGROUPE	JUMP',EQ GROUPE$	COMP.W	D3,#ICOOPLAN	JUMP',EQ PLAN$	JUMP	EXIT$FLECHE$:	COMP.W	(A6)+OSELNB,#1	JUMP',NE MULTI$	PUSH.L	(A6)+OAPOS	LOAD.L	A4,(A6)+OSELPS	; A4 <-- ^objet	CALL	DESOBJETF	; allume l'objet et ses fils	POP.L	(A6)+OAPOS	JUMP	EXIT$CRAYON$:MULTI$:LOUPE$:MAIN$:GROUPE$:PLAN$:	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$MLOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC MNEXT$	CALL	DESOBJETF	; allume l'objet et ses filsMNEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ MLOOP$	JUMP'	EXIT$OPER$:	CALL	_LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$OLOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC ONEXT$	CALL	DESOBJET	; allume l'objetONEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ OLOOP$;	JUMP'	EXIT$EXIT$:	CALL	WDOCLOSE	; fin du dessin dans la swdo	POP.L	(A6)+OAPOS	POPM.L	D1,D3,A4	RET;----------\\; SELRECSET >;==========/;----------\\; SELRECCLR >;==========/; Allume ou teint le rectangle de slection.; in	-; out	-; mod	D7.WSELRECSET:SELRECCLR:	PUSHM.L	D2..D6	PUSH.L	(A6)+OAPOS	LOAD.W	D3,(A6)+OOUTIL	COMP.W	D3,#ICOOCRAYON	JUMP',EQ CRAYON$	COMP.W	D3,#ICOOLOUPE	JUMP',EQ LOUPE$	COMP.W	D3,#ICOOMAIN	JUMP',EQ MAIN$	COMP.W	D3,#ICOOFLECHE	JUMP',EQ FLECHE$	COMP.W	D3,#ICOOOPER	JUMP',EQ OPER$	COMP.W	D3,#ICOOGROUPE	JUMP',EQ GROUPE$	COMP.W	D3,#ICOOPLAN	JUMP',EQ PLAN$	JUMP	EXIT$FLECHE$:	COMP.W	(A6)+OSELNB,#1	JUMP,EQ	EXIT$CRAYON$:MULTI$:LOUPE$:MAIN$:GROUPE$:PLAN$:OPER$:	CLR.L	(A6)+OAPOS	CALL	WDOOPEN		; dessine dans la swdo	PUSH.L	D4	LOAD.L	D4,#H'10000*COLOR_PAFPAGE+COLOR_PACDRAW	CALL	DRCOLORINIT	POP.L	D4	LIB	?AFTIM	.B	MAPTT	.B	B'11001100	; traitill	.B	1		; chelle	.B	0	.EVEN	LOAD.L	D2,#INVDOT!TTTDOT	COMP.W	D3,#ICOOOPER	JUMP',NE RECT$	COMP.W	(A6)+OOPER,#ICOZDEFBEZ	JUMP',EQ DEFBEZ$RECT$:	LOAD.L	D3,(A6)+OZONY1	LOAD.L	D4,(A6)+OZONY3	CALL	DRLINEM	LOAD.L	D3,D4	LOAD.L	D4,(A6)+OZONY2	CALL	DRLINEM	LOAD.L	D3,D4	LOAD.L	D4,(A6)+OZONY4	CALL	DRLINEM	LOAD.L	D3,D4	LOAD.L	D4,(A6)+OZONY1	CALL	DRLINEM	JUMP	END$DEFBEZ$:	LOAD.L	D3,(A6)+OZONY1	LOAD.L	D4,(A6)+OZONY13	LOAD.L	D5,(A6)+OZONY31	LOAD.L	D6,(A6)+OZONY3	CALL	DRBEZIER	LOAD.L	D3,D6	LOAD.L	D4,(A6)+OZONY32	LOAD.L	D5,(A6)+OZONY23	LOAD.L	D6,(A6)+OZONY2	CALL	DRBEZIER	LOAD.L	D3,D6	LOAD.L	D4,(A6)+OZONY24	LOAD.L	D5,(A6)+OZONY42	LOAD.L	D6,(A6)+OZONY4	CALL	DRBEZIER	LOAD.L	D3,D6	LOAD.L	D4,(A6)+OZONY41	LOAD.L	D5,(A6)+OZONY14	LOAD.L	D6,(A6)+OZONY1	CALL	DRBEZIER	LOAD.L	D2,#INVDOT	COMP.W	(A6)+OZONDFB,#ICOBVERTI	JUMP',EQ DEFBEZH$	LOAD.L	D3,(A6)+OZONY1	LOAD.L	D4,(A6)+OZONY13	CALL	DRLINEM	LOAD.L	D3,(A6)+OZONY3	LOAD.L	D4,(A6)+OZONY31	CALL	DRLINEM	LOAD.L	D3,(A6)+OZONY2	LOAD.L	D4,(A6)+OZONY24	CALL	DRLINEM	LOAD.L	D3,(A6)+OZONY4	LOAD.L	D4,(A6)+OZONY42	CALL	DRLINEMDEFBEZH$:	COMP.W	(A6)+OZONDFB,#ICOBHORIZ	JUMP',EQ END$	LOAD.L	D3,(A6)+OZONY1	LOAD.L	D4,(A6)+OZONY14	CALL	DRLINEM	LOAD.L	D3,(A6)+OZONY3	LOAD.L	D4,(A6)+OZONY32	CALL	DRLINEM	LOAD.L	D3,(A6)+OZONY2	LOAD.L	D4,(A6)+OZONY23	CALL	DRLINEM	LOAD.L	D3,(A6)+OZONY4	LOAD.L	D4,(A6)+OZONY41	CALL	DRLINEMEND$:	CALL	WDOCLOSE	; fin du dessin dans la swdoEXIT$:	POP.L	(A6)+OAPOS	POPM.L	D2..D6	RET;----------\\; SELPOISET >;==========/; Allume toutes les poignes.; Allume les poignes dans l'ordre dcroissant, afin que la poigne; zro (CDG) soit toujours dessus !; in	-; out	-; mod	D7.WSELPOISET:	PUSHM.L	D1..D4,A4	CALL	WDOOPEN		; dessine dans la swdo	LOAD.W	D3,(A6)+OOUTIL	COMP.W	D3,#ICOOFLECHE	JUMP',EQ FLECHE$	COMP.W	D3,#ICOOOPER	JUMP,EQ OPER$	JUMP	EXIT$FLECHE$:	COMP.W	(A6)+OSELNB,#1	JUMP',NE MULTI$	LOAD.L	A4,(A6)+OSELPS	; A4 <-- ^objet	LOAD.W	D2,#MAXPOIGNEE+1FLOOP$:	DEC.W	D2		; D2 <-- poigne prcdente	JUMP,NS EXIT$	LOAD.W	D1,#opHANDGET	CALL	_OBJCALLD	; D3/D4 <-- icne/position	JUMP,NE FLOOP$	ADD.W	D4,(A6)+OAPOS+2	SWAP.W	D4	ADD.W	D4,(A6)+OAPOS+0	SWAP.W	D4	CALL	HANDSETONE	; allume une poigne	JUMP	FLOOP$MULTI$:	CLR.W	D2		; D2 <-- poigne initiale	LOAD.W	D3,#ICOHANDCDG	LOAD.L	D4,(A6)+OZONYC	CALL	HANDSETONE	; allume une poigne	JUMP'	EXIT$OPER$:	LOAD.W	D2,#12		; D2 <-- poigne initialeOLOOP$:	CALL	ZONEQHPOS	; D3/D4 <-- type/position	JUMP',NE ONEXT$	CALL	HANDSETONE	; allume une poigneONEXT$:	DEC.W	D2	JUMP,NC OLOOP$;	JUMP'	EXIT$EXIT$:	CALL	WDOCLOSE	; fin du dessin dans la swdo	POPM.L	D1..D4,A4	RET;----------\\; SELPOICLR >;==========/; Eteint toutes les poignes.; Eteint les poignes dans l'ordre inverse de SELPOISET, afin de rsoudre; correctement le cas des poignes superposes !; in	-; out	-; mod	D7.WSELPOICLR:	PUSHM.L	D1..D4,A4	CALL	WDOOPEN		; dessine dans la swdo	LOAD.W	D3,(A6)+OOUTIL	COMP.W	D3,#ICOOFLECHE	JUMP',EQ FLECHE$	COMP.W	D3,#ICOOOPER	JUMP,EQ OPER$	JUMP	EXIT$FLECHE$:	COMP.W	(A6)+OSELNB,#1	JUMP',NE MULTI$	LOAD.L	A4,(A6)+OSELPS	; A4 <-- ^objet	LOAD.W	D2,#-1FLOOP$:	INC.W	D2		; D2 <-- poigne suivante	LOAD.W	D1,#opHANDGET	CALL	_OBJCALLD	; D3/D4 <-- icne/position	JUMP',EQ FSET$	COMP.W	D7,#ERPAHANDDNE	JUMP,EQ FLOOP$	JUMP	EXIT$FSET$:	ADD.W	D4,(A6)+OAPOS+2	SWAP.W	D4	ADD.W	D4,(A6)+OAPOS+0	SWAP.W	D4	CALL	HANDCLRONE	; teint une poigne	JUMP	FLOOP$MULTI$:	CLR.W	D2		; D2 <-- poigne initiale	LOAD.W	D3,#ICOHANDCDG	LOAD.L	D4,(A6)+OZONYC	CALL	HANDCLRONE	; teint une poigne	JUMP'	EXIT$OPER$:	CLR.W	D2		; D2 <-- poigne initialeOLOOP$:	CALL	ZONEQHPOS	; D3/D4 <-- type/position	JUMP',NE ONEXT$	CALL	HANDCLRONE	; teint une poigneONEXT$:	INC.W	D2	COMP.W	D2,#13	JUMP,LO OLOOP$;	JUMP'	EXIT$EXIT$:	CALL	WDOCLOSE	; fin du dessin dans la swdo	POPM.L	D1..D4,A4	RET;--------\\; GETOPER >;========/; Donne l'opration de transformation effectue.; in	-; out	D4.W	opration (ICOZ*); mod	D4.L, D7.WGETOPER:	LOAD.W	D4,(A6)+OOPEXT	; D4 <-- opration effectue	CLR.W	D7		; retour EQ	RET	.END