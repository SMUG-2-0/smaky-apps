	.SBTTL	PAGEINDIC.ASI;--------\\; INDDRAW >;========/; Dessine un indicateur vide.; in	A5.L	^variables de l'indicateur; out	-; mod	D7.WINDDRAW:	PUSHM.L	D2..D4,A4,A5	PUSH.L	D4	LOAD.L	D4,#H'10000*COLOR_PAFDRAW+COLOR_PACDRAW	CALL	__DRCOLORINIT	POP.L	D4	LOAD.L	A4,#(A6)+OASTMP	LOAD.W	(A4)+OSCDEBO,(A5)+OIDDEBO	LOAD.W	(A4)+OSCDEBL,(A5)+OIDDEBL	LOAD.W	D4,(A5)+OIDHTR	SUB.W	D4,#(LGSCROLL-1)*2	LOAD.W	(A4)+OSCHTR,D4	LOAD.B	(A4)+OSCHOR,(A5)+OIDHOR	CLR.B	(A4)+OSCPAGE	EX.L	A5,A4	SCROLL_	DRAW		; dessine une cage d'ascenseur !	EX.L	A4,A5	CLR.L	D4	LOAD.W	D4,(A5)+OIDHTR	DIV.WU	D4,#LGSCROLL	SUB.W	D4,#4-1	LOAD.W	(A5)+OIDNBV,D4	LOAD.W	D2,#SETDOT	LOAD.W	D3,(A5)+OIDDEBL	SWAP.W	D3	LOAD.W	D3,(A5)+OIDDEBO	ADD.W	D3,(A5)+OIDHTR	SUB.W	D3,#LGSCROLL+LGSCROLL-1	LOAD.L	A4,#R16"NEW$	CALL	IDDMOTIF	ADD.W	D3,#LGSCROLL-1	LOAD.L	A4,#R16"CLR$	CALL	IDDMOTIF	POPM.L	D2..D4,A4,A5	RETNEW$:	.W	5,9	.W	-2,0	.W	0,-5	.W	+7,0	.W	0,+2	.W	+2,0	.W	0,+5	.W	-7,0	.W	0,-5	.W	+5,0	.W	0,0CLR$:	.W	4,4	.W	+7,+7	.W	-3,-3	.W	0,-1	.W	+3,-3	.W	-8,+8	.W	0,0;---------\\; IDDMOTIF >;---------/; Dessine un petit motif.; in	A4.L	^table;	D3.L	dpart (y;x);	D2.W	mode de dessin; out	-; mod	D7.WIDDMOTIF:	PUSHM.L	D3,D4,A4	TEST.B	(A5)+OIDHOR	JUMP',T HOR$	SWAP.W	D3HOR$:	LOAD.L	D4,#H'10000*(LGSCROLL-1)+(LGSCROLL-1)	LIB	?DRRECT	SWAP.W	D3	ADD.W	D3,(A4+)	SWAP.W	D3	ADD.W	D3,(A4+)LOOP$:	LOAD.L	D4,(A4+)	JUMP',EQ EXIT$	LIB	?DRSEG	JUMP	LOOP$EXIT$:	POPM.L	D3,D4,A4	RET;-----------\\; INDMOVESEL >;===========/; Dplace un indicateur pendant une slection.; in	A5.L	^variables de l'indicateur;	D4.L	position de la souris (y;x); out	D3.W	case o dplacer (0..n);	D7.W	erreur (si 2 => dplace); mod	D3.L, D7.WINDMOVESEL:	PUSHM.L	D0..D2,D4	PUSH.L	D4	LOAD.L	D4,#H'10000*COLOR_PAFDRAW+COLOR_PACDRAW	CALL	__DRCOLORINIT	POP.L	D4	CALL	IDDET		; D3 <-- rang de la case montre	JUMP,NE EXIT$	TEST.W	D3	JUMP,NS ERROR$	COMP.W	D3,(A5)+OIDPOSV	; clic dans la case dj allume ?	JUMP,NE ERROR$		; non => ERROR$; Dplace la case slectionne dans une autre case.	COMP.W	(A5)+OIDHTV,#1	JUMP,LS ERROR$	CALL	IDINV		; teint la case flche	LOAD.W	D2,#-1DLOOP$:	CALL	SCMO		; remet la souris	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP,NE DEND$	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE DLOOP$	CALL	IDDET		; D3 <-- case o est la souris	LOAD.W	D4,#-1		; D4 <-- -1 (recule)	COMP.W	D3,#-2	JUMP',EQ DMOVE$	NEG.W	D4		; D4 <-- +1 (avance)	COMP.W	D3,#-3	JUMP',EQ DMOVE$	TEST.W	D3	JUMP',NS DNOT$	COMP.W	D3,(A5)+OIDPOSV	JUMP',NE DINV$DNOT$:	LOAD.W	D3,#-1DINV$:	COMP.W	D3,D2	JUMP,EQ DLOOP$	EX.L	D2,D3	CALL	IDINV		; teint l'ancienne case	LOAD.W	D3,D2	CALL	IDINV		; allume la nouvelle case	JUMP	DLOOP$DMOVE$:	CALL	IDINV		; allume la flche	LOAD.W	D0,D3	LOAD.W	D3,D2	CALL	IDINV		; teint l'ancienne case	LOAD.W	D2,D4		; D2 <-- dplacement (-1,+1)	LOAD.W	D1,#50/2	; D1 <-- dlai initialDMLOOP$:	LOAD.W	D3,(A5)+OIDPAF	ADD.W	D3,D2	JUMP',NC DMMIN$	CLR.W	D3DMMIN$:	LOAD.W	D4,(A5)+OIDHTV	SUB.W	D4,(A5)+OIDNBV	JUMP',NC DMLIT$	CLR.W	D4DMLIT$:	COMP.W	D3,D4	JUMP',LS DMMAX$	LOAD.W	D3,D4DMMAX$:	COMP.W	D3,(A5)+OIDPAF	JUMP',EQ DMWAIT$	LOAD.W	(A5)+OIDPAF,D3	CALL	IDDUPDATESEL	; redessine l'indicateurDMWAIT$:	CALL	SCMO		; remet la souris	LOAD.W	D4,D1	NTREL	?SETTIM	MUL.WU	D1,#4	DIV.WU	D1,#5		; D1 <-- dlai de rptition	LIB	?GETKEY		; attend souris ...	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP,NE DMLOOP$	COMP.W	D3,#KEYMPO	JUMP',NE DMERROR$	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE DMWAIT$	CALL	IDDET		; D3 <-- case o est la souris	COMP.W	D3,D0		; toujours dans la mme flche ?	JUMP,EQ DMWAIT$		; oui => DMWAIT$	LOAD.W	D3,D0	CALL	IDINV		; teint la flche	LOAD.W	D2,#-1	JUMP	DLOOP$DMERROR$:	LOAD.W	D3,D0	CALL	IDINV		; teint la flche	CALL	INDUPDATESEL	; redessine l'indicateur	JUMP	ERROR$DEND$:	LOAD.W	D3,D2	CALL	IDINV		; teint la dernire case	LOAD.W	D7,#2		; D7 <-- dplacement	TEST.W	D3	JUMP',NC EXIT$	CALL	INDUPDATE	; redessine l'indicateur;	JUMP'	ERROR$ERROR$:	LOAD.W	D3,#-1		; D3 <-- pas dans une caseOK$:	CLR.W	D7EXIT$:	POPM.L	D0..D2,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; INDMOVE >;========/; Dplace un indicateur.; in	A5.L	^variables de l'indicateur;	D4.L	position de la souris (y;x); out	D3.W	case slectionne (0..n);	D7.W	erreur (si 2 => dplace); mod	D3.L, D7.WINDMOVE:	PUSHM.L	D0..D2,D4	PUSH.L	D4	LOAD.L	D4,#H'10000*COLOR_PAFDRAW+COLOR_PACDRAW	CALL	__DRCOLORINIT	POP.L	D4	CALL	IDDET		; D3 <-- rang de la case montre	JUMP,NE EXIT$	LOAD.W	D2,#-1		; D2 <-- -1 (recule)	COMP.W	D3,#-2	JUMP,EQ ARROW$	NEG.W	D2		; D2 <-- +1 (avance)	COMP.W	D3,#-3	JUMP,EQ ARROW$	COMP.W	D3,#-4		; nouvelle page ?	JUMP,EQ ICONE$	COMP.W	D3,#-5		; dtruit page ?	JUMP,EQ ICONE$	COMP.W	D3,(A5)+OIDPOSV	; clic dans la case dj allume ?	JUMP,NE ICONE$		; non => ICONE$; Dplace la case slectionne entre deux autres cases.	COMP.W	(A5)+OIDHTV,#1	JUMP,LS ERROR$	CALL	IDDARROW	; dessine une flche	LOAD.W	D2,#-1DLOOP$:	CALL	SCMO		; remet la souris	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP,NE DEND$	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE DLOOP$	CALL	IDDETi		; D3 <-- case o est la souris	LOAD.W	D4,#-1		; D4 <-- -1 (recule)	COMP.W	D3,#-2	JUMP',EQ DMOVE$	NEG.W	D4		; D4 <-- +1 (avance)	COMP.W	D3,#-3	JUMP',EQ DMOVE$	LOAD.W	D4,(A5)+OIDPOSV	COMP.W	D3,D4	JUMP',EQ DNOT$	INC.W	D4	COMP.W	D3,D4	JUMP',NE DINV$DNOT$:	LOAD.W	D3,#-1DINV$:	COMP.W	D3,D2	JUMP,EQ DLOOP$	EX.L	D2,D3	CALL	IDINVi		; teint l'ancienne case	LOAD.W	D3,D2	CALL	IDINVi		; allume la nouvelle case	JUMP	DLOOP$DMOVE$:	CALL	IDINV		; allume la flche	LOAD.W	D0,D3	LOAD.W	D3,D2	CALL	IDINVi		; teint l'ancienne case	LOAD.W	D2,D4		; D2 <-- dplacement (-1,+1)	LOAD.W	D1,#50/2	; D1 <-- dlai initialDMLOOP$:	LOAD.W	D3,(A5)+OIDPAF	ADD.W	D3,D2	JUMP',NC DMMIN$	CLR.W	D3DMMIN$:	LOAD.W	D4,(A5)+OIDHTV	SUB.W	D4,(A5)+OIDNBV	JUMP',NC DMLIT$	CLR.W	D4DMLIT$:	COMP.W	D3,D4	JUMP',LS DMMAX$	LOAD.W	D3,D4DMMAX$:	COMP.W	D3,(A5)+OIDPAF	JUMP',EQ DMWAIT$	LOAD.W	(A5)+OIDPAF,D3	CALL	IDDUPDATESEL	; redessine l'indicateurDMWAIT$:	CALL	SCMO		; remet la souris	LOAD.W	D4,D1	NTREL	?SETTIM	MUL.WU	D1,#4	DIV.WU	D1,#5		; D1 <-- dlai de rptition	LIB	?GETKEY		; attend souris ...	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP,NE DMLOOP$	COMP.W	D3,#KEYMPO	JUMP',NE DMERROR$	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE DMWAIT$	CALL	IDDETi		; D3 <-- case o est la souris	COMP.W	D3,D0		; toujours dans la mme flche ?	JUMP,EQ DMWAIT$		; oui => DMWAIT$	LOAD.W	D3,D0	CALL	IDINV		; teint la flche	LOAD.W	D2,#-1	JUMP	DLOOP$DMERROR$:	LOAD.W	D3,D0	CALL	IDINV		; teint la flche	CALL	INDUPDATE	; redessine l'indicateur	JUMP	ERROR$DEND$:	LOAD.W	D3,D2	CALL	IDINVi		; teint la dernire case	LOAD.W	D7,#2		; D7 <-- dplacement	TEST.W	D3	JUMP,NC EXIT$	CALL	INDUPDATE	; redessine l'indicateur	JUMP	ERROR$; Dplace dans la direction de la flche tant que le bouton est; maintenu press, avec une acclration croissante.ARROW$:	CALL	IDINV		; allume la flche	LOAD.W	D0,D3	LOAD.W	D1,#50/2	; D1 <-- dlai initialALOOP$:	LOAD.W	D3,(A5)+OIDPOSV	ADD.W	D3,D2	JUMP',NC AMIN$	CLR.W	D3AMIN$:	COMP.W	D3,(A5)+OIDHTV	JUMP',LO AMAX$	LOAD.W	D3,(A5)+OIDHTV	DEC.W	D3AMAX$:	COMP.W	D3,(A5)+OIDPOSV	JUMP',EQ AWAIT$	LOAD.W	(A5)+OIDPOSV,D3	CALL	INDUPDATE	; redessine l'indicateurAWAIT$:	LOAD.W	D4,D1	NTREL	?SETTIM	MUL.WU	D1,#4	DIV.WU	D1,#5		; D1 <-- dlai de rptition	LIB	?GETCAR		; attend bouton souris ...	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	JUMP,NE ALOOP$	LOAD.W	D3,D0	CALL	IDINV		; teint la flche	LOAD.W	D3,(A5)+OIDPOSV	JUMP	OK$; Garde l'icne allume jusqu' ce que le bouton soit relch.; Si la souris est dplace ailleur, l'icne initiale est simplement teinte.ICONE$:	CALL	IDINV		; allume la premire icne	LOAD.W	D1,D3	LOAD.W	D2,D3ILOOP$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP',NE IEND$	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE ILOOP$	CALL	IDDET		; D3 <-- case o est la souris	COMP.W	D3,D2	JUMP,EQ ILOOP$	COMP.W	D3,D1		; est-ce l'icne initiale ?	JUMP',EQ IINV$		; oui => IINV$	LOAD.W	D3,#-1		; D3 <-- teint !IINV$:	EX.L	D2,D3	CALL	IDINV		; teint l'ancienne case	LOAD.W	D3,D2	CALL	IDINV		; allume la nouvelle case	JUMP	ILOOP$IEND$:	LOAD.W	D3,D2	CALL	IDINV		; teint la dernire case	COMP.W	D3,#-1	JUMP',EQ ERROR$	TEST.W	D3	JUMP',NS OK$	LOAD.W	(A5)+OIDPOSV,D3	CALL	INDUPDATE	; redessine l'indicateur	JUMP'	OK$ERROR$:	LOAD.W	D3,#-1		; D3 <-- pas dans une caseOK$:	CLR.W	D7EXIT$:	POPM.L	D0..D2,D4	TEST.W	D7		; retour EQ/NE	RET;-------------\\; INDUPDATESEL >;=============/; Met  jour un indicateur pendant une slection.; in	A5.L	^variables de l'indicateur; out	-; mod	D7.WINDUPDATESEL:	PUSH.W	D3	PUSH.L	D4	LOAD.L	D4,#H'10000*COLOR_PAFDRAW+COLOR_PACDRAW	CALL	__DRCOLORINIT	POP.L	D4	CALL	IDDPAF		; calcule la premire case  afficher	CALL	IDDUPDATESEL	; met  jour l'indicateur	LOAD.W	D3,(A5)+OIDPOSV	CALL	IDINV		; inverse la case slectionne	POP.W	D3	RET;----------\\; INDUPDATE >;==========/; Met  jour un indicateur.; in	A5.L	^variables de l'indicateur; out	-; mod	D7.WINDUPDATE:	PUSH.L	D4	LOAD.L	D4,#H'10000*COLOR_PAFDRAW+COLOR_PACDRAW	CALL	__DRCOLORINIT	POP.L	D4	CALL	IDDPAF		; calcule la premire case  afficher	CALL	IDDUPDATE	; met  jour l'indicateur	RET;-------\\; IDDPAF >;-------/; Calcule la premire case  afficher.; in	A5.L	^variables de l'indicateur; out	-; mod	D7.WIDDPAF:	PUSHM.L	D2,D3	LOAD.W	D3,(A5)+OIDPOSV	LOAD.W	D2,(A5)+OIDNBV	SR.W	D2,#1		; D2 <-- nb visible /2	ADD.W	D3,D2	COMP.W	D3,(A5)+OIDHTV	JUMP',LO MAXX$	LOAD.W	D3,(A5)+OIDHTV	DEC.W	D3MAXX$:	LOAD.W	D2,(A5)+OIDNBV	DEC.W	D2		; D2 <-- nb visible -1	SUB.W	D3,D2	JUMP',NC MINX$	CLR.W	D3MINX$:	LOAD.W	(A5)+OIDPAF,D3	POPM.L	D2,D3	RET;-------------\\; IDDUPDATESEL >;-------------/; Met  jour l'indicateur pendant une slection.; in	A5.L	^variables de l'indicateur; out	-; mod	D7.WIDDUPDATESEL:	PUSHM.L	D2..D4	LOAD.W	D3,(A5)+OIDPAF	; D3 <-- rang de la premire case	LOAD.W	D2,(A5)+OIDNBV	; D2 <-- nb de cases  afficherLOOP$:	COMP.W	D3,(A5)+OIDHTV	JUMP',HS END$	COMP.W	D3,(A5)+OIDPOSV	JUMP',NE NORM$	COMP.W	(A5)+OIDHTV,#1	JUMP',LS NORM$	CALL	IDDARROW	; affiche une flche	JUMP'	NEXT$NORM$:	CALL	IDDCEL		; affiche une caseNEXT$:	INC.W	D3		; D3 <-- case suivante	DEC.W	D2	JUMP,NE LOOP$END$:	POPM.L	D2..D4	RET;----------\\; IDDUPDATE >;----------/; Met  jour l'indicateur.; in	A5.L	^variables de l'indicateur; out	-; mod	D7.WIDDUPDATE:	PUSHM.L	D2..D4	LOAD.W	D4,(A5)+OIDDEBL	SWAP.W	D4	LOAD.W	D4,(A5)+OIDDEBO	ADD.W	D4,#LGSCROLL-1	LOAD.W	D3,(A5)+OIDPAF	; D3 <-- rang de la premire case	LOAD.W	D2,(A5)+OIDNBV	; D2 <-- nb de cases  afficherLOOP$:	COMP.W	D3,(A5)+OIDHTV	JUMP',HS GREY$	CALL	IDDCEL		; affiche une case	INC.W	D3		; D3 <-- case suivante	ADD.W	D4,#LGSCROLL	; D4 <-- position suivante	DEC.W	D2	JUMP,NE LOOP$	JUMP'	END$GREY$:	LOAD.L	D3,D4	LOAD.L	D4,#H'55AA55AA	; D4 <-- trame	TEST.B	(A0)+ODFMOD:#BFBLANC ; cran  fond blanc ?	JUMP',BC GDEF$		; non => GDEF$	LOAD.L	D4,#H'00110044	; D4 <-- trame plus claireGDEF$:	CALL	DRMDEF		; dfini une trame grise	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	LOAD.W	D4,(A5)+OIDDEBO	ADD.W	D4,(A5)+OIDHTR	SUB.W	D4,#(LGSCROLL*3)-2	SUB.W	D4,D3	JUMP',LE END$	SWAP.W	D4	LOAD.W	D4,#LGSCROLL-2	SWAP.W	D4	TEST.B	(A5)+OIDHOR	JUMP',T GHOR$	SWAP.W	D3	SWAP.W	D4GHOR$:	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; grise la finEND$:	LOAD.W	D3,(A5)+OIDPOSV	CALL	IDINV		; inverse la case slectionne	POPM.L	D2..D4	RET;--------\\; IDINVi  >;--------/; Inverse une case intermdiaire o dplacer.; in	A5.L	^variables de l'indicateur;	D3.W	rang  (0..n); out	-; mod	D7.WIDINVi:	PUSHM.L	D2..D4	LOAD.L	D4,#-1	CALL	DRMDEF	TEST.W	D3	JUMP,NS EXIT$	INC.W	(A5)+OIDNBV	CALL	IDPOS		; D4 <-- position	DEC.W	(A5)+OIDNBV	TEST.W	D7	JUMP,NE EXIT$	LOAD.W	D2,#INVDOT	LOAD.L	D3,D4	SUB.W	D3,#5	SWAP.W	D3	SUB.W	D3,#4	SWAP.W	D3	LOAD.L	D4,#H'10000*2+11	PUSH.L	D3	TEST.B	(A5)+OIDHOR	JUMP',T HOR1$	SWAP.W	D3	SWAP.W	D4HOR1$:	LIB	?DRTRAME	; inverse une case	POP.L	D3	INC.W	D3	SWAP.W	D3	ADD.W	D3,#2	SWAP.W	D3	LOAD.L	D4,#H'10000*2+9	PUSH.L	D3	TEST.B	(A5)+OIDHOR	JUMP',T HOR2$	SWAP.W	D3	SWAP.W	D4HOR2$:	LIB	?DRTRAME	; inverse une case	POP.L	D3	INC.W	D3	SWAP.W	D3	ADD.W	D3,#3	SWAP.W	D3	LOAD.L	D4,#H'10000*2+7	PUSH.L	D3	TEST.B	(A5)+OIDHOR	JUMP',T HOR3$	SWAP.W	D3	SWAP.W	D4HOR3$:	LIB	?DRTRAME	; inverse une case	POP.L	D3	INC.W	D3	SWAP.W	D3	ADD.W	D3,#2	SWAP.W	D3	LOAD.L	D4,#H'10000*2+5	PUSH.L	D3	TEST.B	(A5)+OIDHOR	JUMP',T HOR4$	SWAP.W	D3	SWAP.W	D4HOR4$:	LIB	?DRTRAME	; inverse une case	POP.L	D3	INC.W	D3	SWAP.W	D3	ADD.W	D3,#2	SWAP.W	D3	LOAD.L	D4,#H'10000*2+3;	PUSH.L	D3	TEST.B	(A5)+OIDHOR	JUMP',T HOR5$	SWAP.W	D3	SWAP.W	D4HOR5$:	LIB	?DRTRAME	; inverse une case;	POP.L	D3EXIT$:	POPM.L	D2..D4	RET;--------\\; IDINV   >;--------/; Inverse une case.; in	A5.L	^variables de l'indicateur;	D3.W	rang  (0..n,-1,-2,-3,-4,-5); out	-; mod	D7.WIDINV:	PUSHM.L	D2..D4	LOAD.L	D4,#-1	CALL	DRMDEF	CALL	IDPOS		; D4 <-- position	JUMP',NE EXIT$	LOAD.W	D2,D3	LOAD.L	D3,D4	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	LOAD.L	D4,#H'10000*(LGSCROLL-2)+(LGSCROLL-2)	TEST.W	D2	JUMP',NS INV$	INC.W	D4INV$:	TEST.B	(A5)+OIDHOR	JUMP',T HOR$	SWAP.W	D3	SWAP.W	D4HOR$:	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	; inverse une caseEXIT$:	POPM.L	D2..D4	RET;--------\\; IDDETi  >;--------/; Dtecte dans quelle case intermdiaire est la souris.; in	A5.L	^variables de l'indicateur;	D4.L	position de la souris (y;x); out	D3.W	rang de la case (0..n,-1,-2,-3);	D7.W	erreur; mod	D3.L, D7.WIDDETi:	PUSH.L	D4	TEST.B	(A5)+OIDHOR	JUMP',T HOR$	SWAP.W	D4HOR$:	SWAP.W	D4	SUB.W	D4,(A5)+OIDDEBL	JUMP',LO OUT$	COMP.W	D4,#LGSCROLL	JUMP',HS OUT$	CLR.W	D4	SWAP.W	D4	LOAD.W	D3,(A5)+OIDDEBO	ADD.W	D3,(A5)+OIDHTR	SUB.W	D3,#(LGSCROLL*2)+(LGSCROLL/2)	COMP.W	D4,D3	JUMP',HS RIGHT$	LOAD.W	D3,(A5)+OIDDEBO	ADD.W	D3,#LGSCROLL/2	SUB.W	D4,D3	JUMP',LO LEFT$	DIV.WU	D4,#LGSCROLL	ADD.W	D4,(A5)+OIDPAF	COMP.W	D4,(A5)+OIDHTV	JUMP',HI OUT$	LOAD.W	D3,D4	JUMP'	OK$LEFT$:	LOAD.W	D3,#-2	JUMP'	OK$RIGHT$:	LOAD.W	D3,#-3;	JUMP'	OK$OK$:	CLR.W	D7	JUMP'	EXIT$OUT$:	LOAD.W	D3,#-1	LOAD.W	D7,#1EXIT$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; IDDET   >;--------/; Dtecte dans quelle case est la souris.; in	A5.L	^variables de l'indicateur;	D4.L	position de la souris (y;x); out	D3.W	rang de la case (0..n,-1,-2,-3,-4,-5);	D7.W	erreur; mod	D3.L, D7.WIDDET:	PUSH.L	D4	TEST.B	(A5)+OIDHOR	JUMP',T HOR$	SWAP.W	D4HOR$:	SWAP.W	D4	SUB.W	D4,(A5)+OIDDEBL	JUMP',LO OUT$	COMP.W	D4,#LGSCROLL	JUMP',HS OUT$	CLR.W	D4	SWAP.W	D4	SUB.W	D4,(A5)+OIDDEBO	JUMP',NS OUT$	LOAD.W	D3,(A5)+OIDHTR	COMP.W	D4,D3	JUMP',HS OUT$	SUB.W	D3,#(LGSCROLL*3)-2	COMP.W	D4,D3	JUMP',HS RIGHT$	SUB.W	D4,#LGSCROLL-1	JUMP',NS LEFT$	DIV.WU	D4,#LGSCROLL	COMP.W	D4,(A5)+OIDNBV	JUMP',HS OUT$	ADD.W	D4,(A5)+OIDPAF	COMP.W	D4,(A5)+OIDHTV	JUMP',HS OUT$	LOAD.W	D3,D4	JUMP'	OK$LEFT$:	LOAD.W	D3,#-2	JUMP'	OK$RIGHT$:	SUB.W	D4,D3	AND.L	D4,#H'FFFF	DIV.WU	D4,#LGSCROLL-1	; D4 <-- 0..2	NEG.W	D4		; D4 <-- 0..-2	SUB.W	D4,#3		; D4 <-- -3..-5	LOAD.W	D3,D4		; D3 <-- -3..-5;	JUMP'	OK$OK$:	CLR.W	D7	JUMP'	EXIT$OUT$:	LOAD.W	D3,#-1	LOAD.W	D7,#1EXIT$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; IDDCEL  >;========/; Dessine une case.; in	D3.W	rang  (0..n); out	-; mod	D7.WIDDCEL:	PUSHM.L	D2..D4	CALL	IDPOS		; D4 <-- position	JUMP',NE EXIT$	LOAD.L	D2,D4	CLR.L	D4	CALL	DRMDEF	LOAD.L	D4,D2	PUSHM.L	D3,D4	LOAD.L	D3,D4	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	LOAD.L	D4,#H'10000*(LGSCROLL-2)+(LGSCROLL-1)	TEST.B	(A5)+OIDHOR	JUMP',T THOR$	SWAP.W	D3	SWAP.W	D4THOR$:	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface l'emplacement	POPM.L	D3,D4	TEST.B	(A5)+OIDHOR	JUMP',F LETTRE$CHIFFRE$:	INC.W	D3		; D3 <-- 1..n	CALL	IDDCHIFFRE	; dessine le chiffre	JUMP'	LINE$LETTRE$:	CALL	IDDLETTRE	; dessine la lettre;	JUMP'	LINE$LINE$:	LOAD.L	D3,D4	ADD.W	D3,#LGSCROLL	LOAD.L	D4,#H'10000*LGSCROLL	TEST.B	(A5)+OIDHOR	JUMP',T LHOR$	SWAP.W	D3	SWAP.W	D4LHOR$:	LOAD.W	D2,#SETDOT	LIB	?DRSEG		; dessine le trait vertical  droiteEXIT$:	POPM.L	D2..D4	RET;---------\\; IDDARROW >;=========/; Dessine une flche dans une case.; in	D3.W	rang  (0..n); out	-; mod	D7.WIDDARROW:	PUSHM.L	D1..D5,A2..A4	CALL	CCMO		; enlve la souris	CALL	IDPOS		; D4 <-- position	JUMP',NE EXIT$	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4	LOAD.L	A3,#R16"ARRH$	LOAD.L	D2,#H'10000*14+15	TEST.B	(A5)+OIDHOR	JUMP',T HOR$	LOAD.L	A3,#R16"ARRV$	SWAP.W	D2	SWAP.W	D4HOR$:	CLR.L	D3	LOAD.W	D5,#2	LOAD.L	A4,#0	LOAD.W	D1,#LOADDOT	LOAD.L	A2,A0	GRA_	RASTER		; dessine la flcheEXIT$:	POPM.L	D1..D5,A2..A4	RETARRH$:	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000100000100000	.W	B'0001100000110000	.W	B'0011100000111000	.W	B'0111111111111100	.W	B'1111111111111110	.W	B'1111111111111110	.W	B'0111111111111100	.W	B'0011100000111000	.W	B'0001100000110000	.W	B'0000100000100000	.W	B'0000000000000000	.W	B'0000000000000000ARRV$:	.W	B'0000001100000000	.W	B'0000011110000000	.W	B'0000111111000000	.W	B'0001111111100000	.W	B'0011111111110000	.W	B'0000011110000000	.W	B'0000011110000000	.W	B'0000011110000000	.W	B'0000011110000000	.W	B'0000011110000000	.W	B'0011111111110000	.W	B'0001111111100000	.W	B'0000111111000000	.W	B'0000011110000000	.W	B'0000001100000000;-----------\\; IDDCHIFFRE >;===========/; Dessine un petit chiffre.; in	D3.W	chiffre (0..999);	D4.L	position (y;x); out	-; mod	D7.WIDDCHIFFRE:	PUSHM.L	D1..D4	COMP.W	D3,#999	JUMP,HI EXIT$	LOAD.W	D2,#1	COMP.W	D3,#999	JUMP',HI ADDX$	LOAD.W	D2,#3	COMP.W	D3,#99	JUMP',HI ADDX$	LOAD.W	D2,#5	COMP.W	D3,#9	JUMP',HI ADDX$	LOAD.W	D2,#7ADDX$:	ADD.W	D4,D2		; D4 <-- centre en X	SWAP.W	D4	ADD.W	D4,#4		; D4 <-- centre en Y	SWAP.W	D4	LOAD.L	D2,D4	CLR.L	D4	LOAD.W	D4,D3	LIB	?BINBCD		; D4 <-- chiffre en BCD	EX.L	D2,D4	LOAD.L	D1,#4LOOP$:	RL.W	D2,#4		; D2 <-- pousse d'un digit	LOAD.W	D3,D2	AND.W	D3,#B'1111	; D3 <-- digit	JUMP',NE DIGIT$	COMP.W	D1,#1		; est-ce le dernier digit (units) ?	JUMP',EQ DIGIT$		; oui => DIGIT$	TEST.L	D1:#16		; dj affich qq chose ?	JUMP',BC NEXT$		; non => NEXT$DIGIT$:	CALL	IDDDIGIT	; dessine un digit	ADD.W	D4,#3+1		; D4 <-- position suivante	TSET.L	D1:#16		; D1 <-- signale affich qq choseNEXT$:	DEC.W	D1	JUMP,NE LOOP$EXIT$:	POPM.L	D1..D4	RET;----------\\; IDDLETTRE >;==========/; Dessine une petite lettre.; in	D3.W	lettre (0..25);	D4.L	position (y;x); out	-; mod	D7.WIDDLETTRE:	PUSHM.L	D2,D4	COMP.W	D3,#26	JUMP',HS EXIT$	ADD.W	D4,#4	SWAP.W	D4	ADD.W	D4,#6	LOAD.L	D2,(A6)+OCALCA	TEST.L	D2:D3		; calque cach ?	JUMP',BC DRAW$		; non => DRAW$				; oui =>	SUB.W	D4,#2	LOAD.W	D3,#26		; D2 <-- signe spcialDRAW$:	CALL	IDDDIGITEXIT$:	POPM.L	D2,D4	RET;---------\\; IDDDIGIT >;---------/; Dessine un digit.; in	D3.W	chiffre (0..9) ou lettre (0..25);	D4.L	position (y;x); out	-; mod	D7.WIDDDIGIT:	PUSHM.L	D1..D5,A2..A4	CALL	CCMO		; enlve la souris	LOAD.L	A3,#R16"MAT09$	LOAD.L	D2,#H'10000*8+3	TEST.B	(A5)+OIDHOR	JUMP',T HOR$	LOAD.L	A3,#R16"MATAZ$	LOAD.L	D2,#H'10000*8+8HOR$:	MUL.WU	D3,#8	ADD.L	A3,D3		; A3 <-- ^matrice du chiffre	CLR.L	D3	LOAD.W	D5,#1	LOAD.L	A4,#0	LOAD.W	D1,#LOADDOT	LOAD.L	A2,A0	GRA_	RASTER		; dessine le digit	POPM.L	D1..D5,A2..A4	RETMAT09$:	.B	B'01000000	.B	B'10100000	.B	B'10100000	.B	B'10100000	.B	B'10100000	.B	B'101