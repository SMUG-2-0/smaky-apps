	.SBTTL	OPLISTAFF.ASI;--------\\; AFFCELS >;========/; Affiche toutes les cellules d'une liste.; in	A1.L	^objet liste;	D2.L	mode de dessin (si zro => place le curseur); out	-; mod	D7.WAFFCELS:	PUSHM.L	D1,D2	LOAD.L	(A5)+OAFMOD,D2	; OAFMOD <-- mode de dessin	PUSH.L	(A5)+OTECCE	PUSH.W	(A5)+OTECUR	PUSH.L	(A5)+OTEPCE	LOAD.L	(A5)+OAFCCE,(A5)+OTECCE	LOAD.W	(A5)+OAFCUR,(A5)+OTECUR	LOAD.L	(A5)+OAFCP1,#-1	; curseur pas encore trouv	LOAD.W	(A5)+OAFLCA,#-1	CLR.L	D1LOOPY$:	CLR.W	D1LOOPX$:	CALL	AFFCELSONE	; affiche une cellule	INC.W	D1	COMP.W	D1,(A1)+OOBNBX	JUMP,LO LOOPX$	SWAP.W	D1	INC.W	D1	LOAD.W	D2,D1	SWAP.W	D1	COMP.W	D2,(A1)+OOBNBY	JUMP,LO LOOPY$	POP.L	(A5)+OTEPCE	POP.W	(A5)+OTECUR	POP.L	(A5)+OTECCE	POPM.L	D1,D2	RET;-----------\\; AFFCELSONE >;-----------/; Affiche une cellule.; in	A1.L	^objet liste;	D1.L	coordonne de la cellule (y;x); out	-; mod	D7.WAFFCELSONE:	PUSHM.L	D2..D5	CALL	AFFUSECEL	; travaille dans la bonne cellule	JUMP',NE EXIT$	CALL	AFFLGCEL	; D4 <-- largeur de la cellule	LOAD.W	D2,D4	CALL	AFFGETPOS	; D3/D4 <-- P1/P2	CALL	AFFJUSTPOS	; D4 <-- PaAFF$:	CALL	AFFSETCURS	; mmorise v. le curseur	CALL	TXAVANCE	; D3 <-- caractre suivant	JUMP',NE CURS$	CALL	AFFONECAR	; affiche un caractre	LOAD.L	D5,D4	CALL	AFFLGCAR	; D4 <-- largeur du caractre	ADD.W	D5,D4	LOAD.L	D4,D5	JUMP	AFF$CURS$:	CALL	AFFSETCURS	; mmorise v. le curseurEXIT$:	POPM.L	D2..D5	RET;----------\\; AFFDETCEL >;==========/; Dtecte dans quelle cellule est la souris.; in	D4.L	position de la souris (y;x); out	D1.L	coordonne de la cellule (y;x);	D2.W	position du curseur (0..n);	D7.W	erreur; mod	D1.L, D2.L, D7.WAFFDETCEL:	PUSHM.L	D3..D6,A4	PUSH.L	(A5)+OTECCE	PUSH.W	(A5)+OTECUR	PUSH.L	(A5)+OTEPCE	LOAD.L	A4,A1		; A4 <-- ^objet	LOAD.W	D1,(A4)+OOBA+0	CALL	INVANGLE	CALL	GETPX	LOAD.W	D6,D4		; D6 <-- position en X	LOAD.L	D5,D4	SWAP.W	D5		; D5 <-- position en Y	CLR.W	D7	CLR.L	D1LOOPY$:	CLR.W	D1LOOPX$:	CALL	AFFGETPOS	; D3/D4 <-- P1/P2	COMP.W	D6,D3	JUMP',LO NEXT$	COMP.W	D6,D4	JUMP',HS NEXT$	SWAP.W	D3	SWAP.W	D4	COMP.W	D5,D3	JUMP',LO NEXT$	COMP.W	D5,D4	JUMP',LO FOUND$NEXT$:	INC.W	D1	COMP.W	D1,(A1)+OOBNBX	JUMP,LO LOOPX$	SWAP.W	D1	INC.W	D1	LOAD.W	D3,D1	SWAP.W	D1	COMP.W	D3,(A1)+OOBNBY	JUMP,LO LOOPY$	LOAD.W	D7,#1	JUMP'	EXIT$FOUND$:	LOAD.W	(A5)+OAFLCA,#-1	CALL	AFFUSECEL	; travaille dans la bonne cellule	JUMP',NE EXIT$	CALL	AFFLGCEL	; D4 <-- largeur de la cellule	LOAD.W	D2,D4	CALL	AFFGETPOS	; D3/D4 <-- P1/P2	CALL	AFFJUSTPOS	; D4 <-- Pa	CLR.W	D2LOOPC$:	CALL	TXAVANCE	; D3 <-- caractre suivant	JUMP',NE END$	LOAD.L	D5,D4	CALL	AFFLGCAR	EX.L	D4,D5		; D5 <-- largeur du caractre	LOAD.W	D3,D5	SR.W	D3,#1	ADD.W	D3,D4	COMP.W	D6,D3	JUMP',LO END$	ADD.W	D4,D5		; D4 <-- position suivante	INC.W	D2		; D2 <-- avance le "curseur"	JUMP	LOOPC$END$:	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	(A5)+OTEPCE	POP.W	(A5)+OTECUR	POP.L	(A5)+OTECCE	POPM.L	D3..D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; AFFBBOX >;========/; Calcule la bbox d'une liste.; in	A1.L	^objet liste; out	D3.L	P1 (y;x);	D4.L	P2 (y;x); mod	D3.L, D4.L, D7.WAFFBBOX:	PUSHM.L	D1,D2,D5,D6	PUSH.L	(A5)+OTECCE	PUSH.W	(A5)+OTECUR	PUSH.L	(A5)+OTEPCE	LOAD.L	D3,(A1)+OOBP1	LOAD.L	D4,(A1)+OOBP3	CALL	ORDONNE		; D3/D4 <-- dans l'ordre	LOAD.L	D5,D3	LOAD.L	D6,D4	LOAD.W	(A5)+OAFLCA,#-1	CLR.L	D1LOOPY$:	CLR.W	D1LOOPX$:	CALL	AFFBBOXONE	; D3/D4 <-- P1/P2	JUMP',NE NEXT$	PUSH.L	D1	LOAD.L	D1,D5	LOAD.L	D2,D6	LOAD.W	D7,#MA_RECTOR	PAGE_	MATH	LOAD.L	D5,D3	LOAD.L	D6,D4	POP.L	D1NEXT$:	INC.W	D1	COMP.W	D1,(A1)+OOBNBX	JUMP,LO LOOPX$	SWAP.W	D1	INC.W	D1	LOAD.W	D2,D1	SWAP.W	D1	COMP.W	D2,(A1)+OOBNBY	JUMP,LO LOOPY$	POP.L	(A5)+OTEPCE	POP.W	(A5)+OTECUR	POP.L	(A5)+OTECCE	LOAD.W	D1,(A1)+OOBA+0	; D1 <-- angle	JUMP,EQ NOROT$	LOAD.L	D3,(A1)+OOBP1	; D3 <-- centre	LOAD.L	D4,D5	LIB	?CALCPSYM	; D4 <-- P4 tourn autour du centre	PUSH.L	D4	LOAD.L	D4,D6	LIB	?CALCPSYM	; D4 <-- P4 tourn autour du centre	PUSH.L	D4	LOAD.L	D4,D5	LOAD.W	D4,D6	LIB	?CALCPSYM	; D4 <-- P4 tourn autour du centre	PUSH.L	D4	LOAD.L	D4,D6	LOAD.W	D4,D5	LIB	?CALCPSYM	; D4 <-- P4 tourn autour du centre	LOAD.L	D3,D4	POP.L	D1	LOAD.L	D2,D1	LOAD.W	D7,#MA_RECTOR	PAGE_	MATH	POP.L	D1	LOAD.L	D2,D1	LOAD.W	D7,#MA_RECTOR	PAGE_	MATH	POP.L	D1	LOAD.L	D2,D1	LOAD.W	D7,#MA_RECTOR	PAGE_	MATH	LOAD.L	D5,D3	LOAD.L	D6,D4NOROT$:	CALL	AFFBBOXPEN	; D4 <-- dimensions du pinceau (dy;dx)	SUB.W	D5,D4	ADD.W	D6,D4	INC.W	D6	SWAP.W	D4	SWAP.W	D5	SWAP.W	D6	SUB.W	D5,D4	ADD.W	D6,D4	INC.W	D6;	SWAP.W	D4	SWAP.W	D5	SWAP.W	D6	LOAD.L	D3,D5	LOAD.L	D4,D6	POPM.L	D1,D2,D5,D6	RET;-----------\\; AFFBBOXONE >;-----------/; Calcule la bbox d'une cellule, sans tenir compte de la rotation.; in	A1.L	^objet liste;	D1.L	coordonne de la cellule (y;x); out	D3.L	P1 (y;x) ;	D4.L	P2 (y;x);	D7.W	erreur; mod	D3.L, D4.L, D7.WAFFBBOXONE:	PUSHM.L	D1,D2,D5,A3,A4	CALL	AFFUSECEL	; travaille dans la bonne cellule	JUMP,NE EXIT$	CALL	AFFLGCEL	; D4 <-- largeur de la cellule	LOAD.W	D2,D4	CALL	AFFGETPOS	; D3/D4 <-- P1/P2	CALL	AFFJUSTPOS	; D4 <-- Pa	LOAD.L	D1,D4	LOAD.L	D2,D4	LOAD.L	A4,(A5)+OAFPCM	; A4 <-- ^table chasse,xmin,ymin,xmax,ymaxLOOP$:	CALL	TXAVANCE	; D3 <-- caractre suivant	JUMP,NE END$	LOAD.W	D5,D3	SL.W	D5,#1		; D5 <-- caractre *2 (car tables de .W)	PUSH.L	D4	LOAD.L	D3,D4	LOAD.L	A3,#(A4)+(512*1)	SUB.W	D3,(A3)+(D5.W)	LOAD.L	A3,#(A4)+(512*2)	SWAP.W	D3	SUB.W	D3,(A3)+(D5.W)	; D3 <-- P1 du caractre	SWAP.W	D3	LOAD.L	A3,#(A4)+(512*3)	ADD.W	D4,(A3)+(D5.W)	LOAD.L	A3,#(A4)+(512*4)	SWAP.W	D4	ADD.W	D4,(A3)+(D5.W)	; D4 <-- P2 du caractre	SWAP.W	D4	LOAD.W	D7,#MA_RECTOR	PAGE_	MATH	LOAD.L	D1,D3	LOAD.L	D2,D4	POP.L	D4	ADD.W	D4,(A4)+(D5.W)	; D4 <-- position suivante	JUMP	LOOP$END$:	LOAD.L	D3,D1	LOAD.L	D4,D2	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1,D2,D5,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; AFFBBOXPEN >;-----------/; Cherche les dimensions maximales du pinceau.; in	A1.L	^objet liste; out	D4.L	dimensions maximales (dy;dx); mod	D4.L, D7.WAFFBBOXPEN:	PUSHM.L	D2,D3,D5,A2	CLR.L	D5		; D5 <-- dimensions maximales	LOAD.L	A2,(A1)+OOBPCE	; A2 <-- ^cellules	CLR.L	D2LOOPY$:	CLR.W	D2LOOPX$:	CLR.W	D3	LOAD.B	D3,(A2)+OCETRH	; D3 <-- numro du pinceau	CALL	AFFBBOXPENONE	; D5 <-- dimensions maximales	CLR.W	D3	LOAD.B	D3,(A2)+OCETRB	; D3 <-- numro du pinceau	CALL	AFFBBOXPENONE	; D5 <-- dimensions maximales	CLR.W	D3	LOAD.B	D3,(A2)+OCETRG	; D3 <-- numro du pinceau	CALL	AFFBBOXPENONE	; D5 <-- dimensions maximales	CLR.W	D3	LOAD.B	D3,(A2)+OCETRD	; D3 <-- numro du pinceau	CALL	AFFBBOXPENONE	; D5 <-- dimensions maximalesNEXT$:	LOAD.L	A2,#(A2)+LCE	; A2 <-- ^cellule suivante	INC.W	D2	COMP.W	D2,(A1)+OOBNBX	JUMP,LO LOOPX$	SWAP.W	D2	INC.W	D2	LOAD.W	D3,D2	SWAP.W	D2	COMP.W	D3,(A1)+OOBNBY	JUMP,LO LOOPY$	LOAD.L	D4,D5	TEST.W	D4	JUMP',NE OKX$	INC.W	D4OKX$:	SWAP.W	D4	TEST.W	D4	JUMP',NE OKY$	INC.W	D4OKY$:	SWAP.W	D4	POPM.L	D2,D3,D5,A2	RET;--------------\\; AFFBBOXPENONE >;--------------/; Cherche les dimensions d'un pinceau.; in	D3.W	numro du pinceau;	D5.L	dimensions maximales (dy;dx); out	D5.L	dimensions maximales (dy;dx); mod	D5.L, D7.WAFFBBOXPENONE:	PUSHM.L	D0,D1,D4,A4	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D0,#IDENTPEN	LOAD.W	D1,#opDGETDIM	PAGE_	OBJCALL		; D4 <-- demi-dimensions (dy;dx)	JUMP',NE EXIT$	COMP.W	D5,D4	JUMP',HS OKX$	LOAD.W	D5,D4OKX$:	SWAP.W	D4	SWAP.W	D5	COMP.W	D5,D4	JUMP',HS OKY$	LOAD.W	D5,D4OKY$:;	SWAP.W	D4	SWAP.W	D5EXIT$:	POPM.L	D0,D1,D4,A4	RET;-----------\\; AFFJUSTPOS >;-----------/; Calcule la position o afficher.; in	A1.L	^objet;	D2.W	largeur du texte (dx);	D3.L	P1 (y;x);	D4.L	P2 (y;x); out	D4.L	Pa (y;x) dbut o afficher; mod	D4.L, D7.WAFFJUSTPOS:	PUSHM.L	D0..D3,A2	LOAD.L	A2,(A5)+OTEPCE	; A2 <-- ^cellule	CLR.W	D0	LOAD.B	D0,(A2)+OCEPOH	; D0 <-- positionnement horizontal (0..100)	LOAD.W	D1,D4	SUB.W	D1,D3		; D1 <-- largeur de la cellule	COMP.B	(A2)+OCEJUS,#4	; align sur la virgule ?	JUMP',EQ ALIGN$	COMP.B	(A2)+OCEJUS,#3	; align sur le point ?	JUMP',EQ ALIGN$	COMP.B	(A2)+OCEJUS,#2	; centr ?	JUMP',EQ CENTER$	COMP.B	(A2)+OCEJUS,#1	; drapeau  gauche ?	JUMP',EQ LEFT$RIGHT$:	MUL.WA	D1,D0	DIV.WA	D1,#100	JUMP'	POSX$LEFT$:ALIGN$:	MUL.WA	D1,D0	DIV.WA	D1,#100	SUB.W	D1,D2	JUMP'	POSX$CENTER$:	MUL.WA	D1,D0	DIV.WA	D1,#100	ASR.W	D2,#1	SUB.W	D1,D2;	JUMP'	POSX$POSX$:	LOAD.W	D4,D3	ADD.W	D4,D1		; D4 <-- Pa (x)	SWAP.W	D3	SWAP.W	D4	CLR.W	D0	LOAD.B	D0,(A2)+OCEPOV	; D0 <-- positionnement vertical (0..100)	LOAD.W	D1,D4	SUB.W	D1,D3		; D1 <-- hauteur de la cellule	MUL.WA	D1,D0	DIV.WA	D1,#100	LOAD.W	D4,D1	ADD.W	D4,D3	LOAD.W	D2,(A5)+OAFMH1	ADD.W	D2,(A5)+OAFMH2	SR.W	D2,#1	SUB.W	D4,D2	ADD.W	D4,(A5)+OAFMH1	; D4 <-- Pa (y)	SWAP.W	D4;	SWAP.W	D3	POPM.L	D0..D3,A2	RET;-----------\\; AFFSETCURS >;-----------/; Mmorise la position du curseur.; in	A1.L	^objet liste;	D4.L	position (y;x); out	-; mod	D7.WAFFSETCURS:	PUSHM.L	D1..D4	LOAD.L	D1,(A5)+OAFCCE	COMP.L	D1,(A5)+OTECCE	; est-on dans la bonne cellule ?	JUMP',NE EXIT$	LOAD.W	D1,(A5)+OAFCUR	COMP.W	D1,(A5)+OTECUR	; est-on sur le curseur ?	JUMP',NE EXIT$	LOAD.L	D2,D4	SWAP.W	D4	SUB.W	D4,(A5)+OAFMH1	SWAP.W	D4	LOAD.W	D1,(A1)+OOBA+0	; D1 <-- angle	JUMP',EQ CP1$	LOAD.L	D3,(A1)+OOBP1	; D3 <-- centre	LIB	?CALCPSYM	; D4 <-- P4 tourn autour du centreCP1$:	LOAD.L	(A5)+OAFCP1,D4	LOAD.L	D4,D2	SWAP.W	D4	ADD.W	D4,(A5)+OAFMH2	SWAP.W	D4	LOAD.W	D1,(A1)+OOBA+0	; D1 <-- angle	JUMP',EQ CP2$	LOAD.L	D3,(A1)+OOBP1	; D3 <-- centre	LIB	?CALCPSYM	; D4 <-- P4 tourn autour du centreCP2$:	LOAD.L	(A5)+OAFCP2,D4EXIT$:	POPM.L	D1..D4	RET;----------\\; AFFONECAR >;----------/; Affiche un caractre.; in	A1.L	^objet liste;	D3.W	caractre;	D4.L	position (y;x); out	-; mod	D7.WAFFONECAR:	PUSHM.L	D1..D4,A4	TEST.L	(A5)+OAFMOD	JUMP',EQ EXIT$	LOAD.W	D1,(A1)+OOBA+0	; D1 <-- angle	JUMP',EQ DRAW$	PUSH.W	D3	LOAD.L	D3,(A1)+OOBP1	; D3 <-- centre	LIB	?CALCPSYM	; D4 <-- P4 tourn autour du centre	POP.W	D3DRAW$:	LOAD.L	D2,(A5)+OAFMOD	; D2 <-- mode de dessin	LOAD.L	A4,(A5)+OAFPGB	; A4 <-- ^gencat bitmap	LOAD.W	D7,#DR_CHARQ	PAGE_	DRAW		; affiche un caractreEXIT$:	POPM.L	D1..D4,A4	RET;----------\\; AFFINVCEL >;==========/; Inverse une ou plusieurs cellules.; in	A1.L	^objet liste;	D1.L	coordonne de la cellule (y;x);	D2.L	coordonne de la cellule (y;x); out	-; mod	D7.WAFFINVCEL:	PUSHM.L	D0..D4,A4	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	CALL	AFFGETPOS	; D3/D4 <-- P1/P2	PUSHM.L	D3,D4	LOAD.L	D1,D2	CALL	AFFGETPOS	; D3/D4 <-- P1/P2	POPM.L	D1,D2	LOAD.W	D7,#MA_RECTOR	PAGE_	MATH		; D3/D4 <-- le "ou" des deux rectangles	LOAD.L	D0,D3	LOAD.L	D2,D4	LOAD.W	D7,#DR_POLYOPEN	PAGE_	DRAW	JUMP,NE EXIT$	LOAD.L	A4,A1		; A4 <-- ^objet	LOAD.W	D1,(A4)+OOBA+0	; D1 <-- angle de rotation	LOAD.L	D4,D0	CALL	GETPX	LOAD.L	D3,D4		; D3 <-- P1	LOAD.L	D4,D0	LOAD.W	D4,D2	CALL	GETPX		; D4 <-- P2	LOAD.W	D7,#DR_POLYLINE	PAGE_	DRAW	JUMP',NE EXIT$	LOAD.L	D3,D4		; D3 <-- P2	LOAD.L	D4,D2	CALL	GETPX		; D4 <-- P3	LOAD.W	D7,#DR_POLYLINE	PAGE_	DRAW	JUMP',NE EXIT$	LOAD.L	D3,D4		; D3 <-- P3	LOAD.L	D4,D2	LOAD.W	D4,D0	CALL	GETPX		; D4 <-- P4	LOAD.W	D7,#DR_POLYLINE	PAGE_	DRAW	JUMP',NE EXIT$	LOAD.L	D3,D4		; D3 <-- P4	LOAD.L	D4,D0	CALL	GETPX		; D4 <-- P1	LOAD.W	D7,#DR_POLYLINE	PAGE_	DRAW	JUMP',NE EXIT$	LOAD.W	D2,#INVDOT	LOAD.W	D7,#DR_POLYCLOSE	PAGE_	DRAW		; inverse une celluleEXIT$:	POPM.L	D0..D4,A4	RET;----------\\; AFFGETPOS >;----------/; Donne la position d'une cellule, sans tenir compte de la rotation.; in	A1.L	^objet liste;	D1.L	coordonne de la cellule (y;x); out	D3.L	P1 (y;x);	D4.L	P2 (y;x); mod	D3.L, D4.LAFFGETPOS:	PUSH.L	D1	CALL	AFFGETPI	; D3 <-- P1	LOAD.L	D4,D3	INC.W	D1	SWAP.W	D1	INC.W	D1	SWAP.W	D1	CALL	AFFGETPI	; D3 <-- P2	EX.L	D3,D4	CALL	ORDONNE		; D3/D4 <-- dans l'ordre	POP.L	D1	RET;---------\\; AFFGETPI >;---------/; Cherche une intersection, sans tenir compte de la rotation.; in	A1.L	^objet liste;	D1.L	coordonne de la cellule (y;x); out	D3.L	Pi (y;x); mod	D3.L, D7.WAFFGETPI:	PUSHM.L	D2,D4,A3	LOAD.W	D4,(A1)+OOBP1+2	LOAD.W	D2,D1	JUMP',EQ DEBX$	MUL.WU	D2,#LCO	LOAD.L	A3,(A1)+OOBPLX	LOAD.W	D2,(A3)+(D2.L)-2	LOAD.W	D4,(A1)+OOBP3+2	SUB.W	D4,(A1)+OOBP1+2	MUL.WA	D4,D2	DIV.WA	D4,#FRAMAX	ADD.W	D4,(A1)+OOBP1+2DEBX$:	LOAD.W	D3,(A1)+OOBP1+0	LOAD.L	D2,D1	SWAP.W	D2	TEST.W	D2	JUMP',EQ DEBY$	MUL.WU	D2,#LCO	LOAD.L	A3,(A1)+OOBPLY	LOAD.W	D2,(A3)+(D2.L)-2	LOAD.W	D3,(A1)+OOBP3+0	SUB.W	D3,(A1)+OOBP1+0	MUL.WA	D3,D2	DIV.WA	D3,#FRAMAX	ADD.W	D3,(A1)+OOBP1+0DEBY$:	SWAP.W	D3	LOAD.W	D3,D4	POPM.L	D2,D4,A3	RET;---------\\; AFFLGCEL >;---------/; Donne la largeur d'une cellule.; in	A1.L	^objet liste; out	D4.W	largeur de la cellule; mod	D4.L, D7.WAFFLGCEL:	PUSHM.L	D1..D3,A2	PUSH.W	(A5)+OTECUR	; stack <-- position du curseur	LOAD.L	A2,(A5)+OTEPCE	; A2 <-- ^cellule	LOAD.B	D1,#'.	COMP.B	(A2)+OCEJUS,#3	; allign sur le point ?	JUMP',EQ JUST$	LOAD.B	D1,#',	COMP.B	(A2)+OCEJUS,#4	; allign sur la virgule ?	JUMP',EQ JUST$	CLR.B	D1JUST$:	CLR.W	D4	CALL	TXPOSITIONNE	; revient au dbut	CLR.W	D2LOOP$:	CALL	TXAVANCE	; D3 <-- caractre suivant	JUMP',NE EXIT$	COMP.B	D3,D1	JUMP',EQ EXIT$	CALL	AFFLGCAR	; D4 <-- largeur du caractre	ADD.W	D2,D4	JUMP	LOOP$EXIT$:	LOAD.W	D4,D2		; D4 <-- largeur totale	POP.W	(A5)+OTECUR	; remet le curseur o il tait	POPM.L	D1..D3,A2	RET;---------\\; AFFLGCAR >;---------/; Donne la largeur d'un caractre.; in	D3.W	caractre; out	D4.W	largeur du caractre; mod	D4.L, D7.WAFFLGCAR:	PUSHM.L	D3,A4	LOAD.L	A4,(A5)+OAFPCM	; A4 <-- ^table chasse,xmin,ymin,xmax,ymax	SL.W	D3,#1	LOAD.W	D4,(A4)+(D3.W)	; D4 <-- largeur du caractre	POPM.L	D3,A4	RET;----------\\; AFFUSECEL >;----------/; Travaille dans une cellule.; in	A1.L	^objet liste;	D1.L	coordonne de la cellule (y;x); out	D7.W	erreur; mod	D7.WAFFUSECEL:	PUSHM.L	D0..D4,A2..A4	CALL	TXGETPCE	; A2 <-- ^cellule	JUMP,NE EXIT$	LOAD.L	(A5)+OTECCE,D1	LOAD.L	(A5)+OTEPCE,A2	CLR.W	(A5)+OTECUR	; curseur au dbut	CLR.W	D3	LOAD.B	D3,(A2)+OCECAR	; D3 <-- caractre utilis	COMP.W	D3,(A5)+OAFLCA	; utilisait dj ce mme caractre ?	JUMP',EQ EXIT$		; oui => EXIT$	LOAD.W	(A5)+OAFLCA,D3	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D0,#IDENTCHAR	LOAD.W	D1,#opDGETDIM	PAGE_	OBJCALL		; A2/A3/A4/D3/D4 <-- paramtres	JUMP',NE EXIT$	LOAD.L	(A5)+OAFPGD,A3	; OAFPGD <-- ^gencar descripteur (odgbm*)	LOAD.L	(A5)+OAFPCM,A4	; OAFPCM <-- ^table chasse,xmin,ymin,xmax,ymax	LOAD.W	(A5)+OAFMH2,D3	SWAP.W	D3	LOAD.W	(A5)+OAFMH1,D3	LOAD.L	A4,A3		; A4 <-- ^descripteur	LOAD.L	D1,(A1)+OOBA	; D1 <-- angle de rotation	LOAD.W	D7,#DR_GETPGC	; A3 <-- ^gencar bitmap	PAGE_	DRAW	JUMP',NE EXIT$	LOAD.L	(A5)+OAFPGB,A3	; OAFPGB <-- ^gencar bitmap (oxcbm*)EXIT$:	POPM.L	D0..D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; ORDONNE >;--------/; Ordonne P1 et P3 pour que P1 soit en haut  gauche et; P3 en bas  droite.; in	D3.L	P1 (y;x);	D4.L	P3 (y;x); out	D3.L	P1 (y;x);	D4.L	P3 (y;x); mod	D3.L, D4.L, D7.WORDONNE:	PUSH.L	D2	COMP.W	D3,D4	JUMP',LE SWAPX$	LOAD.W	D2,D3	LOAD.W	D3,D4	LOAD.W	D4,D2SWAPX$:	SWAP.W	D3	SWAP.W	D4	COMP.W	D3,D4	JUMP',LE SWAPY$	LOAD.W	D2,D3	LOAD.W	D3,D4	LOAD.W	D4,D2SWAPY$:	SWAP.W	D3	SWAP.W	D4	POP.L	D2	RET	.END