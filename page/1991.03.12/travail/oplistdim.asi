	.SBTTL	OPLISTDIM.ASI;----------\\; DIMCHANGE >;==========/; Change le nombre de lignes/colonnes d'un objet.; in	A4.L	^objet;	D4.L	nouvelles dimensions (ny;nx); out	D7.W	erreur; mod	D7.WDIMCHANGE:	PUSHM.L	D0..D4,A0..A4	LOAD.L	A3,A4		; A3 <-- ^objet	LOAD.L	D0,D4		; D0 <-- nouvelles dimensions	LOAD.W	D1,#MTYPCP	LOAD.L	A0,#0	LOAD.W	D4,D0	COMP.W	D4,(A3)+OOBNBX	JUMP',EQ NOPLX$	MUL.WU	D4,#LCO	GESMEM	?GETMEM	JUMP,NE EXIT$	LOAD.L	A0,A4		; A0 <-- ^table des largeurs	LOAD.W	D4,D0	CALL	DIMGENXY	; gnre la table des largeursNOPLX$:	LOAD.L	A1,#0	LOAD.L	D4,D0	SWAP.W	D4	COMP.W	D4,(A3)+OOBNBY	JUMP',EQ NOPLY$	MUL.WU	D4,#LCO	GESMEM	?GETMEM	JUMP,NE EXIT$	LOAD.L	A1,A4		; A1 <-- ^table des hauteurs	LOAD.L	D4,D0	SWAP.W	D4	CALL	DIMGENXY	; gnre la table des hauteursNOPLY$:	LOAD.L	D4,D0	SWAP.W	D4	MUL.WU	D4,D0	MUL.WU	D4,#LCE	GESMEM	?GETMEM	JUMP,NE EXIT$	LOAD.L	A2,A4		; A2 <-- ^table des cellules	LOAD.W	D1,D0	COMP.W	D1,(A3)+OOBNBX	JUMP',HS OKX$	LOAD.W	D1,(A3)+OOBNBXOKX$:	LOAD.L	D2,D0	SWAP.W	D2	COMP.W	D2,(A3)+OOBNBY	JUMP',HS OKY$	LOAD.W	D2,(A3)+OOBNBYOKY$:	CLR.L	D3LOOPY$:	CLR.W	D3LOOPX$:	CALL	DIMINICEL	; initialise une nouvelle cellule	INC.W	D3	COMP.W	D3,D1	JUMP,LO LOOPX$	SWAP.W	D3	INC.W	D3	LOAD.W	D4,D3	SWAP.W	D3	COMP.W	D4,D2	JUMP,LO LOOPY$	COMP.L	A0,#0	JUMP',EQ PLX2$	TEST.L	(A3)+OOBPLX	JUMP',EQ PLX1$	LOAD.L	A4,(A3)+OOBPLX	GESMEM	?GIVMEMPLX1$:	LOAD.L	(A3)+OOBPLX,A0PLX2$:	COMP.L	A1,#0	JUMP',EQ PLY2$	TEST.L	(A3)+OOBPLY	JUMP',EQ PLY1$	LOAD.L	A4,(A3)+OOBPLY	GESMEM	?GIVMEMPLY1$:	LOAD.L	(A3)+OOBPLY,A1PLY2$:	TEST.L	(A3)+OOBPCE	JUMP',EQ PCE$	LOAD.L	A4,(A3)+OOBPCE	GESMEM	?GIVMEMPCE$:	LOAD.L	(A3)+OOBPCE,A2	LOAD.L	D4,D0	LOAD.W	(A3)+OOBNBX,D4	SWAP.W	D4	LOAD.W	(A3)+OOBNBY,D4	LOAD.L	D4,D0	SWAP.W	D4	MUL.WU	D4,D0	LOAD.W	(A3)+OOBNBT,D4	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D4,A0..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DIMGENXY >;---------/; Gnre une table des largeurs/hauteurs.; in	A4.L	^table des largeurs/hauteurs;	D4.W	nb de lignes/colonnes; out	-; mod	D7.WDIMGENXY:	PUSHM.L	D2,D3,A4	CLR.W	D3LOOP$:	INC.W	D3		; D3 <-- rang suivant	LOAD.W	D2,D3	MUL.WU	D2,#FRAMAX	DIV.WU	D2,D4		; D2 <-- (rang*FRAMAX) / nb	LOAD.W	(A4)+OCOFRA,D2	ADD.L	A4,#LCO	COMP.W	D3,D4	JUMP,LO LOOP$	POPM.L	D2,D3,A4	RET;----------\\; DIMINICEL >;----------/; Initialise une nouvelle cellule.; in	A3.L	^objet;	A2.L	^nouvelle table des cellules;	D0.L	nouvelles dimensions (ny;nx);	D3.L	coordonnes (y;x); out	-; mod	D7.WDIMINICEL:	PUSHM.L	D0..D3,A1,A2,A4	LOAD.L	D1,D3	SWAP.W	D1	MUL.WU	D1,D0	ADD.W	D1,D3	MUL.WU	D1,#LCE	ADD.L	A2,D1		; A2 <-- ^nouvelle cellule	COMP.W	D3,D0	JUMP,HS KILL$	SWAP.W	D0	SWAP.W	D3	COMP.W	D3,D0	JUMP,HS KILLSW$	SWAP.W	D0	SWAP.W	D3	TEST.L	(A3)+OOBPCE	; existe-t-il d'anciennes cellules ?	JUMP,EQ CREATE$		; non => CREATE$	COMP.W	D3,(A3)+OOBNBX	JUMP',HS INIT$	SWAP.W	D3	COMP.W	D3,(A3)+OOBNBY	JUMP',HS INITSW$	SWAP.W	D3; Transfre l'ancienne cellule dans la nouvelle.	LOAD.L	D1,D3	SWAP.W	D1	MUL.WU	D1,(A3)+OOBNBX	ADD.W	D1,D3	MUL.WU	D1,#LCE	LOAD.L	A1,(A3)+OOBPCE	ADD.L	A1,D1		; A1 <-- ^ancienne cellule	LOAD.W	D1,#(LCE/2)-1XFER$:	LOAD.W	(A2+),(A1+)	; nouvelle cellule <-- ancienne cellule	DECJ.W,NMO D1,XFER$	JUMP	EXIT$; Initialise une nouvelle cellule d'aprs l'ancienne cellule la plus proche.INITSW$:	SWAP.W	D3INIT$:	LOAD.L	D1,D3	SWAP.W	D1	COMP.W	D1,(A3)+OOBNBY	JUMP',LO IOKY$	LOAD.W	D1,(A3)+OOBNBY	DEC.W	D1IOKY$:	MUL.WU	D1,(A3)+OOBNBX	COMP.W	D3,(A3)+OOBNBX	JUMP',LO IOKX$	LOAD.W	D3,(A3)+OOBNBX	DEC.W	D3IOKX$:	ADD.W	D1,D3	MUL.WU	D1,#LCE	LOAD.L	A1,(A3)+OOBPCE	ADD.L	A1,D1		; A1 <-- ^ancienne cellule	LOAD.W	D1,#(LCE/2)-1IXFER$:	LOAD.W	(A2+),(A1+)	; nouvelle cellule <-- ancienne cellule	DECJ.W,NMO D1,IXFER$	CLR.L	(A2)-LCE+OCEPTX	; la nouvelle cellule n'a pas de texte !	JUMP	EXIT$; Supprime le texte d'une ancienne cellule qui disparatra.KILLSW$:	SWAP.W	D0	SWAP.W	D3KILL$:	TEST.L	(A3)+OOBPCE	JUMP,EQ EXIT$	COMP.W	D3,(A3)+OOBNBX	JUMP,HS EXIT$	SWAP.W	D3	COMP.W	D3,(A3)+OOBNBY	JUMP,HS EXIT$	SWAP.W	D3	LOAD.L	D1,D3	SWAP.W	D1	MUL.WU	D1,(A3)+OOBNBX	ADD.W	D1,D3	MUL.WU	D1,#LCE	LOAD.L	A1,(A3)+OOBPCE	ADD.L	A1,D1		; A1 <-- ^ancienne cellule	TEST.L	(A1)+OCEPTX	JUMP,EQ EXIT$	LOAD.L	A4,(A1)+OCEPTX	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	CLR.L	(A1)+OCEPTX	JUMP	EXIT$; Cre une nouvelle cellule de toute pice.CREATE$:	LOAD.L	A4,A2	LOAD.W	D1,#(LCE/2)-1CCLR$:	CLR.W	(A4+)		; rempli la nouvelle cellule de zro	DECJ.W,NMO D1,CCLR$	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D0,#IDENTPEN	LOAD.W	D1,#opDGET	PAGE_	OBJCALL		; D3 <-- numro du pinceau	JUMP',NE CPEN$	LOAD.B	(A2)+OCETRG,D3	LOAD.B	(A2)+OCETRD,D3	LOAD.B	(A2)+OCETRH,D3	LOAD.B	(A2)+OCETRB,D3CPEN$:	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D0,#IDENTTRAME	LOAD.W	D1,#opDGET	PAGE_	OBJCALL		; D3 <-- numro de la trame	JUMP',NE CTRAME$	LOAD.B	(A2)+OCETRA,D3CTRAME$:	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D0,#IDENTCHAR	LOAD.W	D1,#opDGET	PAGE_	OBJCALL		; D3 <-- numro du caractre	JUMP',NE CCHAR$	LOAD.B	(A2)+OCECAR,D3CCHAR$:	LOAD.B	(A2)+OCEPOH,#10	LOAD.B	(A2)+OCEPOV,#50EXIT$:	POPM.L	D0..D3,A1,A2,A4	RET;--------\\; DIMEGAL >;========/; Egalise quelques lignes/colonnes.; in	A4.L	^table des largeurs/hauteurs;	D1.W	dbut;	D2.W	fin; out	-; mod	D7.WDIMEGAL:	PUSHM.L	D0..D4,A4	CLR.W	D3	LOAD.W	D0,D1	JUMP',EQ BEGIN$	MUL.WU	D0,#LCO	LOAD.W	D3,(A4)+(D0.L)-LCO+OCOFRA ; D3 <-- fraction initialeBEGIN$:	LOAD.W	D0,D2	MUL.WU	D0,#LCO	LOAD.W	D4,(A4)+(D0.L)+OCOFRA ; D4 <-- fraction terminale	LOAD.W	D0,D1	MUL.WU	D0,#LCO	ADD.L	A4,D0	SUB.W	D2,D1	INC.W	D2	LOAD.W	D1,#1LOOP$:	LOAD.W	D0,D4	SUB.W	D0,D3	MUL.WU	D0,D1	DIV.WU	D0,D2	ADD.W	D0,D3	LOAD.W	(A4)+OCOFRA,D0	ADD.L	A4,#LCO	INC.W	D1	COMP.W	D1,D2	JUMP,LO LOOP$	POPM.L	D0..D4,A4	RET;--------\\; DIMSORT >;========/; Trie une table des largeurs/hauteurs.; Utilise le vieil algorithme "bubble-sort", suffisamment rapide ici !; in	A4.L	^table des largeurs/hauteurs;	D4.W	nb de lignes/colonnes; out	-; mod	D7.WDIMSORT:	PUSHM.L	D1..D3,A3	COMP.W	D4,#1	JUMP',LS EXIT$PASS$:	LOAD.L	A3,A4		; A3 <-- ^table	LOAD.W	D3,D4		; D3 <-- nb d'lments	SUB.W	D3,#1+1	CLR.W	D2		; D2 <-- aucune permutationSORT$:	LOAD.W	D1,(A3)+OCOFRA	COMP.W	D1,(A3)+OCOFRA+LCO	JUMP',LS NEXT$	LOAD.W	(A3)+OCOFRA,(A3)+OCOFRA+LCO	LOAD.W	(A3)+OCOFRA+LCO,D1	INC.W	D2		; une permutation de plusNEXT$:	ADD.L	A3,#LCO		; A3 <-- ^lment suivant	DECJ.W,NMO D3,SORT$	TEST.W	D2		; y a-t-il eu des permutations ?	JUMP,NE PASS$		; oui => PASS$EXIT$:	POPM.L	D1..D3,A3	RET	.END