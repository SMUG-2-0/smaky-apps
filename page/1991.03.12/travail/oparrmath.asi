	.SBTTL	OPARRMATH.ASI;---------\\; MAFLECHE >;=========/; Calcule les points d'une flche quelconque.; in	A4.L	^dfinition;	A3.L	^buffer;	D2.L	mode de dessin;	D3.L	P1(y;x);	D4.L	P2(y;x); out	D3.W	nb de droites; mod	D3.L, D7.WMAFLECHE:	PUSHM.L	D1,D2,D4,A2,A3	CLR.L	(A5)+OBUFB	; garde tous les points	LOAD.L	A2,A3		; A2 <-- ^premier point	ADD.L	A3,#4	LOAD.L	D1,(A4)+OFLEFA	; D1 <-- fanions	EX.L	D3,D4	TEST.L	D1:#BFLEi1	JUMP',BS ARRi$	TEST.L	D1:#BFLEe1	JUMP',BS ARRe$	CALL	MAFLECHErien	CALL	MAPROVrien	JUMP'	ARR$ARRi$:	CALL	MAFLECHEint	CALL	MAPROVint	JUMP'	ARR$ARRe$:	CALL	MAFLECHEext	CALL	MAPROVext;	JUMP'	ARR$ARR$:	EX.L	D3,D4	TEST.L	D1:#BFLEi2	JUMP',BS DEPi$	TEST.L	D1:#BFLEe2	JUMP',BS DEPe$	CALL	MAFLECHErien	CALL	MAPROVrien	JUMP'	DEP$DEPi$:	CALL	MAFLECHEint	CALL	MAPROVint	JUMP'	DEP$DEPe$:	CALL	MAFLECHEext	CALL	MAPROVext;	JUMP'	DEP$DEP$:	LOAD.L	(A2),(-A3)	LOAD.L	D3,A3	SUB.L	D3,A2	SR.L	D3,#3		; D3 <-- nb de droites	LOAD.L	D1,(A5)+OBUFB	; D1 <-- droites  supprimer	JUMP',EQ EXIT$	LOAD.L	A3,A2	LOAD.W	D2,D3KLOOP$:	RR.L	D1,#1	JUMP',CS KSUPP$	LOAD.L	(A3+),(A2+)	LOAD.L	(A3+),(A2+)	JUMP'	KNEXT$KSUPP$:	ADD.L	A2,#4+4	DEC.W	D3;	JUMP'	KNEXT$KNEXT$:	DEC.W	D2	JUMP,NE KLOOP$EXIT$:	POPM.L	D1,D2,D4,A2,A3	RET;----------\\; MAPROVint >;==========/; Simplifie ventuellement le trac d'une flche intrieure.; in	A4.L	^dfinition;	A3.L	^aprs P3..P7;	A2.L	^dbut;	D2.L	mode de dessin; out	-; mod	D7.WMAPROVint:	PUSHM.L	D0,D1	TEST.L	D2:#BVUETRAME	JUMP',BS EXIT$	LOAD.L	D1,(A5)+OBUFB	LOAD.L	D0,A3	SUB.L	D0,A2	SUB.L	D0,#4	SR.L	D0,#3		; D0 <-- rang	TEST.W	(A4)+OFLEPa+0	; paisseur nulle ?	JUMP',NE RFOK$		; non => RFOK$	TSET.L	D1:D0	TEST.W	(A4)+OFLEPa+2	; renfoncement nul ?	JUMP',NE RFOK$		; non => RFOK$	DEC.W	D0	TSET.L	D1:D0	SUB.W	D0,#3	TSET.L	D1:D0RFOK$:	LOAD.L	(A5)+OBUFB,D1EXIT$:	POPM.L	D0,D1	RET;------------\\; MAFLECHEint >;============/; Calcule les cinq points d'une flche intrieure.; in	A4.L	^dfinition;	A3.L	^buffer;	D3.L	P1(y;x);	D4.L	P2(y;x); out	A3.L	^plus loin (P3..P7); mod	D7.W, A3.L;	;	                |<---Db-->|;	                |  |<-Da->|;	             P4 o  |      |;	                 \\|      |;	                P3\|\     |;	     |-------------o  \   |;	     |         Pb Pa    \ |;	  P2 o----------o--o------o P1=P5;	     |                  /;	     |-------------o  /;	                P7/ /;	                 //;	             P6 o	.PC	PCVAR	.LOC	0OFIPa:	.BLKB	4		; Pa(y;x)OFIDa:	.BLKB	4		; Da(y;x)OFIPb:	.BLKB	4		; Pb(y;x)OFIDb:	.BLKB	4		; Db(y;x)LFI:	.PC	PCCODEMAFLECHEint:	PUSHM.L	D0..D4	LOAD.L	SP,#(SP)-LFI	; SP <-- ^variables	LOAD.L	D0,D3	LOAD.L	D1,D4	LOAD.L	D3,D1	SUB.W	D3,D0	SWAP.W	D3	SWAP.W	D0	SUB.W	D3,D0	SWAP.W	D3	SWAP.W	D0	LOAD.W	D2,(A4)+OFLEPa+2	CALL	MAPYTHA		; D4 <-- Pa(y;x);;?	LOAD.L	D3,D4	ADD.W	D4,D0	SWAP.W	D4	SWAP.W	D0	ADD.W	D4,D0	SWAP.W	D4	SWAP.W	D0	LOAD.L	(SP)+OFIPa,D4	SWAP.W	D3	NEG.W	D3	LOAD.W	D2,(A4)+OFLEPa+0	CALL	MAPYTHA		; D4 <-- Da(y;x)	LOAD.L	(SP)+OFIDa,D4	LOAD.L	D3,D1	SUB.W	D3,D0	SWAP.W	D3	SWAP.W	D0	SUB.W	D3,D0	SWAP.W	D3	SWAP.W	D0	LOAD.W	D2,(A4)+OFLEPb+2	CALL	MAPYTHA		; D4 <-- Pb(y;x);;?	LOAD.L	D3,D4	ADD.W	D4,D0	SWAP.W	D4	SWAP.W	D0	ADD.W	D4,D0	SWAP.W	D4	SWAP.W	D0	LOAD.L	(SP)+OFIPb,D4	SWAP.W	D3	NEG.W	D3	LOAD.W	D2,(A4)+OFLEPb+0	CALL	MAPYTHA		; D4 <-- Db(y;x)	LOAD.L	(SP)+OFIDb,D4	LOAD.L	D3,(SP)+OFIPa	ADD.W	D3,(SP)+OFIDa+2	SWAP.W	D3	ADD.W	D3,(SP)+OFIDa+0	SWAP.W	D3	LOAD.L	(A3+),D3	; buffer <-- P3(y;x)	LOAD.L	(A3+),D3	; buffer <-- P3(y;x)	LOAD.L	D3,(SP)+OFIPb	ADD.W	D3,(SP)+OFIDb+2	SWAP.W	D3	ADD.W	D3,(SP)+OFIDb+0	SWAP.W	D3	LOAD.L	(A3+),D3	; buffer <-- P4(y;x)	LOAD.L	(A3+),D3	; buffer <-- P4(y;x)	LOAD.L	(A3+),D0	; buffer <-- P5=P1(y;x)	LOAD.L	(A3+),D0	; buffer <-- P5=P1(y;x)	LOAD.L	D3,(SP)+OFIPb	SUB.W	D3,(SP)+OFIDb+2	SWAP.W	D3	SUB.W	D3,(SP)+OFIDb+0	SWAP.W	D3	LOAD.L	(A3+),D3	; buffer <-- P6(y;x)	LOAD.L	(A3+),D3	; buffer <-- P6(y;x)	LOAD.L	D3,(SP)+OFIPa	SUB.W	D3,(SP)+OFIDa+2	SWAP.W	D3	SUB.W	D3,(SP)+OFIDa+0	SWAP.W	D3	LOAD.L	(A3+),D3	; buffer <-- P7(y;x)	LOAD.L	(A3+),D3	; buffer <-- P7(y;x)EXIT$:	LOAD.L	SP,#(SP)+LFI	; SP <-- enlve variables	POPM.L	D0..D4	RET;----------\\; MAPROVext >;==========/; Simplifie ventuellement le trac d'une flche extrieure.; in	A4.L	^dfinition;	A3.L	^aprs P3..P10;	A2.L	^dbut;	D2.L	mode de dessin; out	-; mod	D7.WMAPROVext:	PUSHM.L	D0,D1	TEST.L	D2:#BVUETRAME	JUMP',BS EXIT$	LOAD.L	D1,(A5)+OBUFB	LOAD.L	D0,A3	SUB.L	D0,A2	SUB.L	D0,#4	SR.L	D0,#3		; D0 <-- rang	TEST.W	(A4)+OFLEPa+0	; paisseur nulle ?	JUMP',NE RFOK$		; non => RFOK$	TSET.L	D1:D0	SUB.W	D0,#3	TSET.L	D1:D0	DEC.W	D0	TSET.L	D1:D0	ADD.W	D0,#3+1	TEST.W	(A4)+OFLEPa+2	; renfoncement nul ?	JUMP',NE RFOK$		; non => RFOK$	SUB.W	D0,#2	TSET.L	D1:D0	SUB.W	D0,#4	TSET.L	D1:D0RFOK$:	LOAD.L	(A5)+OBUFB,D1EXIT$:	POPM.L	D0,D1	RET;------------\\; MAFLECHEext >;============/; Calcule les huit points d'une flche extrieure.; in	A4.L	^dfinition;	A3.L	^buffer;	D3.L	P1(y;x);	D4.L	P2(y;x); out	A3.L	^plus loin (P3..P10); mod	D7.W, A3.L;	             De |<------------>|;	             Db |<------>|     |;	             Da |<--->|  |     |;	             Dc |<>|  |  |     |;	                |  |  |  o P4  |;	                |  |  |((|     |;	                |P3| (|(P5     |;	     |----------|--o  o--|-----o P6;	     |         P1 Pc Pa Pb    Pe;	  P2 o----------o--o--o--o-----o;	     |                         |;	     |-------------o  o--------o P7;	                 P10 ( (P8;	                       (( ;	                         o P9	.PC	PCVAR	.LOC	0OFEFPc:	.BLKB	4		; FPc(y;x)OFEPa:	.BLKB	4		; Pa(y;x)OFEDa:	.BLKB	4		; Da(y;x)OFEPb:	.BLKB	4		; Pb(y;x)OFEDb:	.BLKB	4		; Db(y;x)OFEPc:	.BLKB	4		; Pc(y;x)OFEDc:	.BLKB	4		; Dc(y;x)OFEPe:	.BLKB	4		; Pe(y;x)OFEDe:	.BLKB	4		; De(y;x)LFE:	.PC	PCCODEMAFLECHEext:	PUSHM.L	D0..D4	LOAD.L	SP,#(SP)-LFE	; SP <-- ^variables	LOAD.L	D0,D3	LOAD.L	D1,D4	LOAD.W	D4,(A4)+OFLEPa+0	TEST.W	(A4)+OFLEPb+0	JUMP',EQ ZEROc$	MUL.WU	D4,(A4)+OFLEPb+2	DIV.WU	D4,(A4)+OFLEPb+0ZEROc$:	LOAD.W	(SP)+OFEFPc+2,D4	LOAD.W	(SP)+OFEFPc+0,(A4)+OFLEPa+0	LOAD.L	D3,D0	SUB.W	D3,D1	SWAP.W	D3	SWAP.W	D1	SUB.W	D3,D1	SWAP.W	D3	SWAP.W	D1	LOAD.W	D2,(A4)+OFLEPa+2	CALL	MAPYTHA		; D4 <-- Pa(y;x);;?	LOAD.L	D3,D4	ADD.W	D4,D0	SWAP.W	D4	SWAP.W	D0	ADD.W	D4,D0	SWAP.W	D4	SWAP.W	D0	LOAD.L	(SP)+OFEPa,D4	NEG.W	D3	SWAP.W	D3	LOAD.W	D2,(A4)+OFLEPa+0	CALL	MAPYTHA		; D4 <-- Da(y;x)	LOAD.L	(SP)+OFEDa,D4	LOAD.L	D3,D0	SUB.W	D3,D1	SWAP.W	D3	SWAP.W	D1	SUB.W	D3,D1	SWAP.W	D3	SWAP.W	D1	LOAD.W	D2,(A4)+OFLEPb+2	CALL	MAPYTHA		; D4 <-- Pb(y;x);;?	LOAD.L	D3,D4	ADD.W	D4,D0	SWAP.W	D4	SWAP.W	D0	ADD.W	D4,D0	SWAP.W	D4	SWAP.W	D0	LOAD.L	(SP)+OFEPb,D4	NEG.W	D3	SWAP.W	D3	LOAD.W	D2,(A4)+OFLEPb+0	CALL	MAPYTHA		; D4 <-- Db(y;x)	LOAD.L	(SP)+OFEDb,D4	LOAD.L	D3,D0	SUB.W	D3,D1	SWAP.W	D3	SWAP.W	D1	SUB.W	D3,D1	SWAP.W	D3	SWAP.W	D1	LOAD.W	D2,(SP)+OFEFPc+2	CALL	MAPYTHA		; D4 <-- Pc(y;x);;?	LOAD.L	D3,D4	ADD.W	D4,D0	SWAP.W	D4	SWAP.W	D0	ADD.W	D4,D0	SWAP.W	D4	SWAP.W	D0	LOAD.L	(SP)+OFEPc,D4	NEG.W	D3	SWAP.W	D3	LOAD.W	D2,(SP)+OFEFPc+0	CALL	MAPYTHA		; D4 <-- Dc(y;x)	LOAD.L	(SP)+OFEDc,D4	LOAD.L	D3,D0	SUB.W	D3,D1	SWAP.W	D3	SWAP.W	D1	SUB.W	D3,D1	SWAP.W	D3	SWAP.W	D1	LOAD.W	D2,(A4)+OFLEPe	CALL	MAPYTHA		; D4 <-- Pe(y;x);;?	LOAD.L	D3,D4	ADD.W	D4,D0	SWAP.W	D4	SWAP.W	D0	ADD.W	D4,D0	SWAP.W	D4	SWAP.W	D0	LOAD.L	(SP)+OFEPe,D4	NEG.W	D3	SWAP.W	D3	LOAD.W	D2,(A4)+OFLEPa+0	CALL	MAPYTHA		; D4 <-- De(y;x)	LOAD.L	(SP)+OFEDe,D4	LOAD.L	D3,(SP)+OFEPc	ADD.W	D3,(SP)+OFEDc+2	SWAP.W	D3	ADD.W	D3,(SP)+OFEDc+0	SWAP.W	D3	LOAD.L	(A3+),D3	; buffer <-- P3(y;x)	LOAD.L	(A3+),D3	; buffer <-- P3(y;x)	LOAD.L	D3,(SP)+OFEPb	ADD.W	D3,(SP)+OFEDb+2	SWAP.W	D3	ADD.W	D3,(SP)+OFEDb+0	SWAP.W	D3	LOAD.L	(A3+),D3	; buffer <-- P4(y;x)	LOAD.L	(A3+),D3	; buffer <-- P4(y;x)	LOAD.L	D3,(SP)+OFEPa	ADD.W	D3,(SP)+OFEDa+2	SWAP.W	D3	ADD.W	D3,(SP)+OFEDa+0	SWAP.W	D3	LOAD.L	(A3+),D3	; buffer <-- P5(y;x)	LOAD.L	(A3+),D3	; buffer <-- P5(y;x)	LOAD.L	D3,(SP)+OFEPe	ADD.W	D3,(SP)+OFEDe+2	SWAP.W	D3	ADD.W	D3,(SP)+OFEDe+0	SWAP.W	D3	LOAD.L	(A3+),D3	; buffer <-- P6(y;x)	LOAD.L	(A3+),D3	; buffer <-- P6(y;x)	LOAD.L	D3,(SP)+OFEPe	SUB.W	D3,(SP)+OFEDe+2	SWAP.W	D3	SUB.W	D3,(SP)+OFEDe+0	SWAP.W	D3	LOAD.L	(A3+),D3	; buffer <-- P7(y;x)	LOAD.L	(A3+),D3	; buffer <-- P7(y;x)	LOAD.L	D3,(SP)+OFEPa	SUB.W	D3,(SP)+OFEDa+2	SWAP.W	D3	SUB.W	D3,(SP)+OFEDa+0	SWAP.W	D3	LOAD.L	(A3+),D3	; buffer <-- P8(y;x)	LOAD.L	(A3+),D3	; buffer <-- P8(y;x)	LOAD.L	D3,(SP)+OFEPb	SUB.W	D3,(SP)+OFEDb+2	SWAP.W	D3	SUB.W	D3,(SP)+OFEDb+0	SWAP.W	D3	LOAD.L	(A3+),D3	; buffer <-- P9(y;x)	LOAD.L	(A3+),D3	; buffer <-- P9(y;x)	LOAD.L	D3,(SP)+OFEPc	SUB.W	D3,(SP)+OFEDc+2	SWAP.W	D3	SUB.W	D3,(SP)+OFEDc+0	SWAP.W	D3	LOAD.L	(A3+),D3	; buffer <-- P10(y;x)	LOAD.L	(A3+),D3	; buffer <-- P10(y;x)EXIT$:	LOAD.L	SP,#(SP)+LFE	; SP <-- enlve variables	POPM.L	D0..D4	RET;-----------\\; MAPROVrien >;===========/; Simplifie ventuellement le trac d'une droite.; in	A4.L	^dfinition;	A3.L	^aprs P3..P4;	A2.L	^dbut;	D2.L	mode de dessin; out	-; mod	D7.WMAPROVrien:	PUSHM.L	D0,D1	TEST.L	D2:#BVUETRAME	JUMP',BS EXIT$	LOAD.L	D1,(A5)+OBUFB	LOAD.L	D0,A3	SUB.L	D0,A2	SUB.L	D0,#4	SR.L	D0,#3		; D0 <-- rang	TEST.W	(A4)+OFLEPa+0	; paisseur nulle ?	JUMP',NE EPOK$		; non => EPOK$	TSET.L	D1:D0	DEC.W	D0	TSET.L	D1:D0EPOK$:	LOAD.L	(A5)+OBUFB,D1EXIT$:	POPM.L	D0,D1	RET;-------------\\; MAFLECHErien >;=============/; Calcule les deux points d'une droite (rectangle).; in	A4.L	^dfinition;	A3.L	^buffer;	D3.L	P1(y;x);	D4.L	P2(y;x); out	A3.L	^plus loin (P3..P4); mod	D7.W, A3.L;	     |--------------------o P3;	     |                    |;	  P2 o--------------------o P1;	     |                    |;	     |--------------------o P4MAFLECHErien:	PUSHM.L	D0..D4	LOAD.L	D0,D3	LOAD.L	D1,D4	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	NEG.W	D3	SWAP.W	D3	LOAD.W	D2,(A4)+OFLEPa+0	CALL	MAPYTHA		; D4 <-- P3(y;x)	LOAD.L	D3,D0	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A3+),D3	; buffer <-- P3(y;x)	LOAD.L	(A3+),D3	; buffer <-- P3(y;x)	LOAD.L	D3,D0	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A3+),D3	; buffer <-- P4(y;x)	LOAD.L	(A3+),D3	; buffer <-- P4(y;x)EXIT$:	POPM.L	D0..D4	RET;--------\\; MAPYTHA >;--------/; Calcul les coordonnes du point D4(y;x) en fonction du point D3(y;x); et de la longueur D2 sur l'hypotnuse.;		         o D3(y;x);		        /|;		       / |;		      /  |;		     /   |;		    o D4(y;x);		   /|    |;		D2/ |    |;		 /  |    |;		o---------;	      (0;0); in	D2.W	longueur;	D3.L	y;x; out	D4.L	y;x; mod	D4.L, D7.WMAPYTHA:	PUSHM.L	D0,D1	CALL	MAHYPO		; D4 <-- hypothnuse	TEST.W	D4	JUMP',NE NONUL$	CLR.L	D4	JUMP'	EXIT$NONUL$:	SWAP.W	D3	LOAD.W	D1,D2	MUL.WA	D1,D3	DIV.WA	D1,D4		; D1 <-- y	SWAP.W	D3	LOAD.W	D0,D2	MUL.WA	D0,D3	DIV.WA	D0,D4		; D0 <-- x	LOAD.W	D4,D1	SWAP.W	D4	LOAD.W	D4,D0EXIT$:	POPM.L	D0,D1	RET;-------\\; MAHYPO >;-------/; Calcule l'hypothnuse d'un triangle rectangle.; Cet appel permet, par exemple, de trouver le rayon d'un cercle; en fonction de la position de la souris.; L'astuce consiste  calculer la racine carr par itrations !;;	         Px;	     |-------/;	     |      /;	     |     /;	  Py |    /;	     |   / H;	     |  /;	     | /;	     |/;;	H = SQR( Px^2 + Py^2 );; Pour minimiser les itrations, on utilise les constatations suivantes :;;	H > MAX(Px,Py);	H < Px+Py; in	D3.L	P(y,x); out	D4.W	H; mod	D4.L, D7.WMAHYPO:	PUSHM.L	D0..D3	LOAD.W	D4,D3		; D4 <-- Px	SWAP.W	D3		; D3 <-- Py	TEST.W	D4	JUMP',NC 10$	NEG.W	D4		; D4 <-- |Px|10$:	TEST.W	D3	JUMP',NC 12$	NEG.W	D3		; D3 <-- |Py|12$:	LOAD.W	D0,D4	COMP.W	D0,D3	JUMP',HS 14$	LOAD.W	D0,D3		; D0=Bi <-- MAX(Px,Py)14$:	LOAD.W	D1,D3	ADD.W	D1,D4		; D1=Bs <-- Px+Py	MUL.WU	D3,D3	MUL.WU	D4,D4	ADD.L	D4,D3		; D4 <-- Px^2 + Py^220$:	COMP.W	D0,D1		; borne infrieure = borne suprieure ?	JUMP',EQ 80$		; oui => 80$	DEC.W	D1	COMP.W	D0,D1		; borne infrieure ~ borne suprieure ?	JUMP',EQ 80$		; oui => 80$	INC.W	D1	LOAD.W	D2,D1	SUB.W	D2,D0	SR.W	D2,#1	ADD.W	D2,D0		; D2=Bx <-- Bi+(Bs-Bi)/2	LOAD.W	D3,D2	MUL.WU	D3,D3		; D3 <-- Bx^2	COMP.L	D3,D4		; Bx^2 = Px^2 + Py^2  ?	JUMP',EQ 70$	JUMP',HI 40$	LOAD.W	D0,D2		; D0=Bi <-- Bx	JUMP	20$40$:	LOAD.W	D1,D2		; D1=Bs <-- Bx	JUMP	20$70$:	LOAD.W	D0,D280$:	LOAD.W	D4,D0		; D4 <-- H	POPM.L	D0..D3	RET	.END