	.TITLE	UNIT2.ASC	.PROC	M680002	.REF	SMAKYUNITMM	=	1		; millimtresUNITCM	=	2		; centimtresUNITIN	=	3		; poucesUNITPI	=	4		; points internes	.LOC	0OLINE:	.BLKB	100ORESUL:	.BLKB	100LGVAR:	.LOC	0START:	LOAD.L	A6,#R16"VARLOOP:	LIB	?AFTIM	.ASCIZ	"<CR><CR>Donnez un nombre : "	.EVEN	LOAD.L	A3,#(A6)+OLINE	LOAD.W	D3,#100	LIB	?GETLINE	COMP.W	D3,#CR	JUMP,NE FINI	LOAD.L	A4,#(A6)+OLINE	CALL	GETUNUM	LIB	?AFTIM	.ASCIZ	"<CR>Valeur relle = "	.EVEN	LIB	?AFX8	LIB	?AFTIM	.ASCIZ	"<CR>Unit         = "	.EVEN	EX.L	D3,D4	LIB	?AFX4	EX.L	D3,D4	CALL	CONVUNITOBJ	LIB	?AFTIM	.ASCIZ	"<CR>CONVUNITOBJ   = "	.EVEN	LIB	?AFX4	CALL	CONVOBJUNIT	LIB	?AFTIM	.ASCIZ	"<CR>CONVOBJUNIT   = "	.EVEN	LIB	?AFX8	LOAD.L	A4,#(A6)+ORESUL	CALL	PUTUNUM	CLR.B	(A4)	LIB	?AFTIM	.ASCIZ	"<CR>PUTUNUM       = "	.EVEN	LOAD.L	A3,#(A6)+ORESUL	LIB	?AFTEXT	JUMP	LOOPFINI:	EXIT;--------\\; PUTUNUM >;========/; Met un nombre rel dans un buffer.; in	D3.W	unit (UNITxx);	D4.L	nombre BCD [unit];	A4.L	^buffer; out	A4.L	^plus loin; mod	D7.W, A4.LPUTUNUM:	PUSHM.L	D1..D4	LOAD.W	D1,D3		; D1 <-- unit	LIB	?BCDBIN		; D4 <-- valeur en binaire	LOAD.L	D2,#500	COMP.W	D1,#UNITMM	JUMP',EQ RND$;	LOAD.L	D2,#500	COMP.W	D1,#UNITCM	JUMP',EQ RND$;	LOAD.L	D2,#500	COMP.W	D1,#UNITIN	JUMP',EQ RND$	CLR.L	D2RND$:	ADD.L	D4,D2	LIB	?BINBCD		; D4 <-- valeur en BCD	LOAD.L	D2,#H'10000*2+3	COMP.W	D1,#UNITMM	JUMP',EQ ILOOP$	LOAD.L	D2,#H'10000*3+2	COMP.W	D1,#UNITCM	JUMP',EQ ILOOP$;	LOAD.L	D2,#H'10000*3+2	COMP.W	D1,#UNITIN	JUMP',EQ ILOOP$	LOAD.L	D2,#H'10000*0+8ILOOP$:	RL.L	D4,#4		; D4 <-- pousse d'un digit	LOAD.B	D3,D4	AND.B	D3,#H'0F	; D3 <-- 0..9	JUMP',NE IPUT$		; si 1..9 => IPUT$	COMP.B	D2,#1		; dernier digit ?	JUMP',EQ IPUT$		; oui => IPUT$	TEST.L	D2:#10		; zro significatif ?	JUMP',BC ISKIP$		; non => ISKIP$IPUT$:	ADD.B	D3,#'0		; D3 <-- '0..'9	LOAD.B	(A4+),D3	TSET.L	D2:#10ISKIP$:	DEC.B	D2	JUMP,NE	ILOOP$	SWAP.W	D2		; D2 <-- nb digits partie fractionnaire	TEST.W	D2	JUMP',EQ FEND$	LOAD.B	(A4+),#'.	; buffer <-- "."FLOOP$:	RL.L	D4,#4		; D4 <-- pousse d'un digit	LOAD.B	D3,D4	AND.B	D3,#H'0F	; D3 <-- 0..9	ADD.B	D3,#'0		; D3 <-- '0..'9	LOAD.B	(A4+),D3	TSET.L	D2:#10	DEC.B	D2	JUMP,NE	FLOOP$FEND$:	LOAD.W	D3,D1	CALL	PUTUNIT		; buffer <-- unit	POPM.L	D1..D4	RET;--------\\; GETUNUM >;========/; Donne un nombre rel.; in	A4.L	^dans buffer; out	A4.L	^plus loin;	D4.L	nombre BCD [unit];	D3.W	unit (UNITxx); mod	D3.L, D4.L, A4.LGETUNUM:	PUSHM.L	D1,D2	CLR.L	D4		; D4 <-- futur nombre BCD	CLR.L	D2		; D2 <-- nb dcimales + flagsLOOP$:	LOAD.B	D3,(A4+)	COMP.B	D3,#'.	JUMP',EQ FRAC$	COMP.B	D3,#',	JUMP',EQ FRAC$	SUB.B	D3,#'0	JUMP',LO END$	COMP.B	D3,#9		; D3 <-- 0..9	JUMP',HI END$	SL.L	D4,#4		; D4 <-- pousse d'un digit (4 bits)	OR.B	D4,D3		; D4 <-- met le nouveau digit	TEST.L	D2:#16		; "." rencontr ?	JUMP,BC LOOP$		; non => LOOP$	INC.B	D2		; D2 <-- une dcimale de plus	JUMP	LOOP$FRAC$:	TSET.L	D2:#16		; D2 <-- "." rencontr	JUMP	LOOP$END$:	DEC.L	A4	CALL	GETUNIT		; D3 <-- unit	LOAD.W	D1,#5		; D1 <-- nb de dcimales si "mm"	COMP.W	D3,#UNITMM	JUMP',EQ UNIT$	LOAD.W	D1,#6		; D1 <-- nb de dcimales si "cm"	COMP.W	D3,#UNITCM	JUMP',EQ UNIT$;	LOAD.W	D1,#6		; D1 <-- nb de dcimales si "in"	COMP.W	D3,#UNITIN	JUMP',EQ UNIT$	CLR.W	D1		; D1 <-- nb de dcimales si rienUNIT$:	SUB.W	D1,D2		; D1 <-- nb de dcimales manquantes	JUMP',EQ EXIT$	JUMP',NS TOO$	SL.W	D1,#2		; D4 <-- *4 (car 4 bits/digit)	SL.L	D4,D1		; D4 <-- comble les dcimales manquantes	JUMP'	EXIT$TOO$:	NEG.W	D1	SL.W	D1,#2		; D4 <-- *4 (car 4 bits/digit)	SR.L	D4,D1		; D4 <-- enlve les dcimales superfluesEXIT$:	POPM.L	D1,D2	RET;--------\\; PUTANUM >;========/; Met un nombre dcimal dans un buffer.; in	D4.L	nombre;	A4.L	^dans buffer; out	A4.L	^plus loin; mod	A4.LPUTANUM:	PUSHM.L	D2,D3,D4	LIB	?BINBCD		; D4 <-- nombre BCD	LOAD.W	D2,#8		; D2 <-- nb digits + flags10$:	RL.L	D4,#4		; D4 <-- pousse d'un digit	LOAD.B	D3,D4	AND.B	D3,#H'0F	; D3 <-- 0..9	JUMP',NE 40$		; si 1..9 => 40$	COMP.B	D2,#1		; dernier digit ?	JUMP',EQ 40$		; oui => 40$	TEST.L	D2:#10		; zro significatif ?	JUMP',BC 50$		; non => 50$40$:	ADD.B	D3,#'0		; D3 <-- '0..'9	LOAD.B	(A4+),D3	TSET.L	D2:#1050$:	DEC.B	D2	JUMP,NE	10$	POPM.L	D2,D3,D4	RET;--------\\; GETANUM >;========/; Donne un nombre dcimal.; in	A4.L	^dans buffer; out	A4.L	^plus loin;	D4.L	nombre; mod	D4.L, A4.LGETANUM:	PUSHM.L	D2,D3	CLR.L	D4		; D4 <-- futur nombre10$:	CLR.L	D3	LOAD.B	D3,(A4+)	COMP.B	D3,#'0	JUMP',LO 50$	COMP.B	D3,#'9	JUMP',HI 50$	SUB.B	D3,#'0		; D3 <-- 0..9	SL.L	D4,#1	LOAD.L	D2,D4	SL.L	D4,#2	ADD.L	D4,D2		; D4 <-- pousse d'un digit (*10)	ADD.L	D4,D3		; D4 <-- ajoute nouveau digit	JUMP	10$50$:	DEC.L	A4		; D4 <-- ^terminateur	POPM.L	D2,D3	RET;------------\\; CONVOBJUNIT >;============/; Conversion d'une valeur objet --> unit quelconque.; La valeur BCD est compose de 8 digits comme suit :;;	|---|---|---|---|---|---|---|---|;	| 1 | 2 | 3 | 4 | 5 | 6 | 7 | 8 |  <--  D4.L;	|---|---|---|---|---|---|---|---|;;	 <--------------i-------------->   si rien;	 <----i----> <--f--> <----t---->   si "mm";	 <--i--> <----f----> <----t---->   si "cm";	 <--i--> <----f----> <----t---->   si "in";;	i:	partie entire;	f:	partie fractionnaire visible;	t:	partie fractionnaire invisible; in	D3.W	unit voulue (UNITxx);	D4.W	valeur entire [obj]; out	D4.L	valeur BCD [unit]; mod	D4.L, D7.WCONVOBJUNIT:	COMP.W	D3,#UNITMM	JUMP',EQ MM$	COMP.W	D3,#UNITCM	JUMP',EQ CM$	COMP.W	D3,#UNITIN	JUMP',EQ IN$	AND.L	D4,#H'FFFF	JUMP'	EXIT$MM$:	MUL.WU	D4,#2117	; 2116.7 = (25.4*10^5)/1200	JUMP'	EXIT$CM$:	MUL.WU	D4,#2117	; 2116.7 = (2.54*10^6)/1200	JUMP'	EXIT$IN$:	MUL.WU	D4,#833		; 833.33 = 10^6/1200;	JUMP'	EXIT$EXIT$:	LIB	?BINBCD		; D4 <-- 8 digits BCD	RET;------------\\; CONVUNITOBJ >;============/; Conversion d'une valeur unit quelconque --> objet.; in	D3.W	unit voulue (UNITxx);	D4.L	valeur BCD [unit]; out	D4.W	valeur entire [obj]; mod	D4.L, D7.WCONVUNITOBJ:	LIB	?BCDBIN		; D4 <-- valeur binaire	COMP.W	D3,#UNITMM	JUMP',EQ MM$	COMP.W	D3,#UNITCM	JUMP',EQ CM$	COMP.W	D3,#UNITIN	JUMP',EQ IN$	JUMP'	EXIT$MM$:	ADD.L	D4,#2117/2	DIV.WU	D4,#2117	; 2116.7 = (25.4*10^5)/1200	JUMP'	EXIT$CM$:	ADD.L	D4,#2117/2	DIV.WU	D4,#2117	; 2116.7 = (2.54*10^6)/1200	JUMP'	EXIT$IN$:	ADD.L	D4,#833/2	DIV.WU	D4,#833		; 833.33 = 10^6/1200;	JUMP'	EXIT$EXIT$:	RET;--------\\; PUTUNIT >;--------/; Met une unit dans le buffer.; in	D3.W	unit (UNITxx);	A4.L	^dans buffer; out	A4.L	^plus loin; mod	D7.W, A4.LPUTUNIT:	PUSH.L	A3	LOAD.L	A3,#R16"TAUNIT-4LOOP$:	ADD.L	A3,#4		; A3 <-- ^suivant	TEST.W	(A3)		; fin de la table ?	JUMP',EQ EXIT$		; oui => EXIT$	COMP.W	D3,(A3)	JUMP,NE LOOP$	LOAD.B	(A4+),(A3)+2	; buffer <-- premier caractre	LOAD.B	(A4+),(A3)+3	; buffer <-- deuxime caractreEXIT$:	POP.L	A3	RET;--------\\; GETUNIT >;--------/; Donne une unit.; in	A4.L	^dans buffer; out	A4.L	^plus loin;	D3.W	unit; mod	D3.L, D7.W, A4.LGETUNIT:	PUSHM.L	D1,D2,A3	LOAD.B	D3,(A4)	LIB	?MINMAJ	LOAD.B	D1,D3		; D1 <-- premire lettre	LOAD.B	D3,(A4)+1	LIB	?MINMAJ	LOAD.B	D2,D3		; D2 <-- deuxime lettre	CLR.W	D3		; D3 <-- rien trouv	COMP.B	D1,#'A	JUMP',LO EXIT$	COMP.B	D1,#'Z	JUMP',HI EXIT$	ADD.B	D1,#'a-'A	COMP.B	D2,#'A	JUMP',LO EXIT$	COMP.B	D2,#'Z	JUMP',HI EXIT$	ADD.B	D2,#'a-'A	LOAD.L	A3,#R16"TAUNIT-4LOOP$:	ADD.L	A3,#4		; A3 <-- ^suivant	TEST.W	(A3)		; fin de la table ?	JUMP',EQ EXIT$		; oui => EXIT$	COMP.B	D1,(A3)+2	; premire lettre trouve ?	JUMP,NE LOOP$		; non => LOOP$	COMP.B	D2,(A3)+3	; deuxime lettre trouve ?	JUMP,NE LOOP$		; non => LOOP$	LOAD.W	D3,(A3)		; D3 <-- unit	ADD.L	A4,#2		; A4 <-- saute les deux lettresEXIT$:	POPM.L	D1,D2,A3	RETTAUNIT:	.W	UNITMM	.ASCII	"mm"	.W	UNITCM	.ASCII	"cm"	.W	UNITIN	.ASCII	"in"	.W	UNITPI	.ASCII	"pi"	.W	0;-------\\; FIXMUL >;=======/; in	D1.L	nombre  virgule fixe no 1;	D2.L	nombre  virgule fixe no 2; out	D0.L	nombre  virgule fixe rsultant;	VS	si dpassement de capacit (dans ce cas D0=max_fix ou min_fix selon signes); mod	D0.LFIXMUL:	PUSHM.L	D1,D2,D4,D5,D6	CALL	TOPOSITIF	LOAD.L	D4,#H'00010000	COMP.L	D1,D4		; D1 = 1.0 ?	JUMP',NE D1DIFF0$	; non => D2 = 1.0 ?	LOAD.L	D1,D2	JUMP'	MUL10$D1DIFF0$:	COMP.L	D2,D4		; D2 = 1.0 ?	JUMP',NE DIFFZERO$MUL10$:	CLR.L	D0	CLR.L	D4	LOAD.W	D4,D1	SWAP.W	D4	SWAP.W	D1	LOAD.W	D0,D1		; (D0;D4) = rsultat	JUMP'	LONGTOFIX$DIFFZERO$:	LOAD.W	D4,D2	MUL.WU	D4,D1		; D4 <-- D1.fract * D2.fract	SWAP.W	D2	LOAD.W	D5,D2	MUL.WU	D5,D1		; D5 <-- D1.fract * D2.int	SWAP.W	D1	LOAD.W	D0,D2	MUL.WU	D0,D1		; D0 <-- D1.int * D2.int	SWAP.W	D2	MUL.WU	D2,D1		; D2 <-- D1.int * D2.fract	ADD.L	D2,D5		; mid	CLR.L	D5	LOAD.W	D5,D2	SWAP.W	D5		; mid * 2**16	LOAD.W	D2,D5		; #0	SWAP.W	D2	ADD.L	D4,D5		; + low	ADDX.L	D0,D2		; mid.31..W + high + carry				; (D0;D4): rsultatLONGTOFIX$:	SWAP.W	D0	TEST.W	D0		; high word <> 0 ?	JUMP',NE SETMAX$	; oui => met la val. maximum	SWAP.W	D4	LOAD.W	D0,D4		; low res. word	TEST.L	D4		; high bit reste = 0 ?	JUMP',PL NOTROUND$	INC.L	D0		; inc res.fract	JUMP',CS SETMAX$NOTROUND$:	TEST.L	D0		; bit de signe dj mis ?	JUMP',MI SETMAX$	; ==> dbordement !	TEST.B	D6		; (VC)	JUMP',EQ EXIT$	NEG.L	D0		; met rsultat ngatif selon D1 et D2.in (VC)	JUMP'	EXIT$SETMAX$:	LOAD.L	D0,#H'00000001	RR.L	D0,#1	TEST.B	D6	JUMP',NE RTNOV$	DEC.L	D0RTNOV$:	SETV			; met le bit overflowEXIT$:	POPM.L	D1,D2,D4,D5,D6	RET;-------\\; FIXDIV >;=======/; in	D1.L	nombre  virgule fixe numrateur;	D2.L	nombre  virgule fixe dnominateur; out	D0.L	nombre  virgule fixe rsultant;	VS	si dpassement de capacit (dans ce cas D0=max_fix ou min_fix selon signes); mod	D0.LFIXDIV:	PUSHM.L	D1..D6	EX.L	D1,D2	COMP.L	D2,D1	JUMP,EQ	EQUAL$	CALL	TOPOSITIF	LOAD.L	D4,D2	TEST.L	D1		; /0 ?	JUMP',NE DODIV$		; nonOVERFLOW$:	LOAD.L	D0,#H'7FFFFFFF	TEST.B	D6		; remet ngatif si l'tait	JUMP',EQ POSOV$	INC.L	D0POSOV$:	SETV	JUMP	EXIT$DODIV$:	LOAD.L	D2,D1		; Dnom	CLR.L	D1	LOAD.L	D0,D4		; Num	CALL	INTDIV32	; Num/Denom: DIV.64 D2,(D1&D0) --> D3.L reste D4.L	JUMP,VS	OVERFLOW$	LOAD.W	D5,D3	SWAP.W	D5		; --> entier	CLR.L	D1		; reste * 2**16	SWAP.W	D4	LOAD.W	D1,D4	LOAD.L	D0,D4	CLR.W	D0	CALL	INTDIV32	; reste*2**16/ Denom	LOAD.W	D5,D3		; --> fraction	LOAD.L	D0,D5	TEST.L	D4	JUMP',PL NOROUND$	INC.L	D5	JUMP,CS	OVERFLOW$NOROUND$:	TEST.L	D5	JUMP,NS	OVERFLOW$PUTSIGN$:	TEST.B	D6		; remet ngatif si l'tait (VC)	JUMP',EQ POS$	NEG.L	D0		; (VC)POS$:	JUMP'	EXIT$EQUAL$:	LOAD.L	D0,#1	SWAP.W	D0		; (VC)EXIT$:	POPM.L	D1..D6	RETTOPOSITIF:	TEST.L	D1	SET.B,MI D6	JUMP',PL POS1$	NEG.L	D1POS1$:	TEST.L	D2	JUMP',PL POS2$	NEG.L	D2	NOT.B	D6POS2$:	RET;---------\\; INTDIV32 >;=========/; Module de division 64/32 --> 32 bits (non-sign).;	-------------------;	 D3 <-- D1&D0 / D2;	 D4 <-- reste;	-------------------; ATTENTION: pas de test de division par zro !; in	D1&D0.L	numrateur (64 bits non-sign);	D2.L	dnominateur (32 bits non-sign); out	D3.L	rsultat (32 bits non-sign);	D4.L	reste (32 bits non-sign);	VS	overflow; mod	D3.L, D4.LINTDIV32:	PUSHM.L D0,D1	LOAD.W	D4,#32-1	; D4 <-- dcompteur de bouclesLOOP$:	SETX	RLX.L	D0	RLX.L	D1	JUMP',CS ERROR$	SUB.L	D1,D2	JUMP',HS NEXT$	ADD.L	D1,D2	TCLR.L	D0:#0		; bit 0 si rtablissementNEXT$:	DECJ.W,NMO D4,LOOP$	COMP.L	D1,D2		; reste >= diviseur ?	JUMP',HS ERROR$	LOAD.L	D3,D0		; D3 <-- quotient	LOAD.L	D4,D1		; D4 <-- reste,	 F <-- V=0	JUMP'	EXIT$ERROR$:	SETV			; F <-- V=1EXIT$:	POPM.L	D0,D1	RETVAR:	.FILLB	LGVAR,0	.END	START