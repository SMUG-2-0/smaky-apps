	.SBTTL	PAGEDRAW.ASI;----------\\; DESREFAIT >;==========/; Refait si ncessaire les bbox et le dessin complet.; in	-; out	D7.W	erreur (si rien refait); mod	D7.WDESREFAIT:	PUSHM.L	D1..D4,D6,A4	PUSH.L	(A6)+OAPOS	TEST.W	(A6)+OGBBOX	; faut-il recalculer les bbox ?	JUMP',EQ DRAW$		; non => DRAW$	LOAD.W	D3,#-1		; D3 <-- toutes les pages	LOAD.L	D6,(A6)+OOBACH	; D6 <-- canal de l'arbre des objets	CALL	_1LSTA_FIRST	; A4 <-- ^premier objet	JUMP',NE BEND$BLOOP$:	LOAD.W	D3,#EDITNPMODIF	LOAD.W	D1,#opEDITNEXTPREV	CALL	_1OBJCALLD	; indique compltement chang (pour TEXT)	LOAD.W	D1,#opGETBBOX	CALL	_1OBJCALLD	; D3/D4 <-- bounding box	JUMP',NE BNEXT$	LOAD.L	(A4)+OobjBBOX1,D3	LOAD.L	(A4)+OobjBBOX2,D4BNEXT$:	CALL	_1LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ BLOOP$BEND$:	CLR.W	(A6)+OGBBOX	; toutes les bbox recalcules	INC.W	(A6)+OGDRAW	; faudra tout redessiner !DRAW$:	LOAD.W	D7,#1		; D7 <-- rien refait	TEST.W	(A6)+OGDRAW	; faut-il tout redessiner ?	JUMP',EQ EXIT$		; non => EXIT$				; oui =>	CALL	DESOBJETS	; redessine tous les objets	CLR.W	(A6)+OGDRAW	; dessin refait	CLR.W	D7		; D7 <-- dessin refaitEXIT$:	POP.L	(A6)+OAPOS	POPM.L	D1..D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DEMOBJETS >;==========/; Dessine tous les objets, aprs un dplacement de la partie visible.; in	D4.L	ancienne position de ODESY1 (y;x); out	-; mod	D7.WDEMOBJETS:	PUSHM.L	D3,D4; Essaye de scroller la fentre selon le dplacement.	SUB.W	D4,(A6)+ODESX1	SWAP.W	D4	SUB.W	D4,(A6)+ODESY1	SWAP.W	D4	LOAD.L	D3,D4		; D3 <-- dplacement [obj]	CALL	_1SCALEP		; D4 <-- dplacement [scr]	TEST.L	D4		; qq chose  dplacer ?	JUMP,EQ EXIT$		; non => EXIT$	CALL	SCROLLWDO	; essaye de scroller	JUMP,NE ALL$	LOAD.L	D4,D3		; D4 <-- dplacement [obj]; Redessine la partie verticale  gauche ou  droite.	PUSH.L	D4	CALL	WDOSAV		; sauve les dfinitions de la fentre	TEST.W	D4	JUMP',EQ HEND$	JUMP',NS HNEG$	LOAD.W	D3,(A6)+ODESX1	ADD.W	D4,D3	JUMP'	HDRAW$HNEG$:	LOAD.W	D3,(A6)+ODESX2	ADD.W	D3,D4	LOAD.W	D4,(A6)+ODESX2	TEST.W	(A6)+OSCALE	; agrandissement ?	JUMP',LE HDRAW$		; non => HDRAW$	DEC.W	D3HDRAW$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,(A6)+ODESY1	LOAD.W	D4,(A6)+ODESY2	SWAP.W	D4	SWAP.W	D3	CALL	WDODEF		; dimensione la fentre selon objet	CALL	DESOBJETS	; redessine tous les objetsHEND$:	CALL	WDOGET		; restitue les dfinitions de la fentre	POP.L	D4; Redessine la partie horizontale en haut ou en bas.	CALL	WDOSAV		; sauve les dfinitions de la fentre	SWAP.W	D4	TEST.W	D4	JUMP',EQ VEND$	JUMP',NS VNEG$	LOAD.W	D3,(A6)+ODESY1	ADD.W	D4,D3	JUMP'	VDRAW$VNEG$:	LOAD.W	D3,(A6)+ODESY2	ADD.W	D3,D4	LOAD.W	D4,(A6)+ODESY2	TEST.W	(A6)+OSCALE	; agrandissement ?	JUMP',LE VDRAW$		; non => VDRAW$	DEC.W	D3VDRAW$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,(A6)+ODESX1	LOAD.W	D4,(A6)+ODESX2	CALL	WDODEF		; dimensione la fentre selon objet	CALL	DESOBJETS	; redessine tous les objetsVEND$:	CALL	WDOGET		; restitue les dfinitions de la fentre	JUMP'	EXIT$; Redessine tous les objets, normalement.ALL$:	CALL	DESOBJETS	; redessine tous les objetsEXIT$:	POPM.L	D3,D4	RET;----------\\; SCROLLWDO >;----------/; Essaye de scroller la fentre.; in	D4.L	+/- dplacement (y;x); out	D7.W	erreur; mod	D7.WSCROLLWDO:	PUSHM.L	D3,D4,A3	LOAD.W	D7,#ERDIOUT	; D7 <-- dplacement trop grand	LOAD.W	D3,D4	JUMP',NC POSX$	NEG.W	D3POSX$:	ADD.W	D3,(A6)+OWDOX1	COMP.W	D3,(A6)+OWDOX2	; dplacement horizontal trop grand ?	JUMP,HS EXIT$		; oui => EXIT$	LOAD.L	D3,D4	SWAP.W	D3	TEST.W	D3	JUMP',NC POSY$	NEG.W	D3POSY$:	ADD.W	D3,(A6)+OWDOY1	COMP.W	D3,(A6)+OWDOY2	; dplacement vertical trop grand ?	JUMP,HS EXIT$		; oui => EXIT$	CALL	WDOOPEN		; dessine dans la swdo	CALL	_1CCMO		; enlve la souris	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWRASTER	CLR.L	(A3)+1	CLR.L	(A3)+5	SWAP.W	D4	LOAD.L	(A3)+11,D4	CLR.L	(A3)+15	LOAD.W	D4,(A6)+OWDOX2	SUB.W	D4,(A6)+OWDOX1	LOAD.W	(A3)+21,D4	LOAD.W	D4,(A6)+OWDOY2	SUB.W	D4,(A6)+OWDOY1	LOAD.W	(A3)+23,D4	LOAD.B	(A3)+25,#LOADDOT	LOAD.W	D3,#26	LIB	?STRING		; hop, on scrolle !	CALL	WDOCLOSE	; fin du dessin dans la swdo	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; DESOBJETS >;==========/; Dessine tous les objets.; in	-; out	-; mod	D7.WDESOBJETS:	PUSHM.L	D3,D4,D6,A4	PUSH.L	(A6)+OAPOS	CALL	WDOOPEN		; dessine dans la swdo	CALL	_1CCMO		; enlve la souris	TEST.B	(A6)+OIFPPS	; impression PostScript en cours ?	JUMP',T	PPS$		; oui => PPS$	PUSH.L	D4	LOAD.L	D4,#H'10000*COLORFPAGE+COLORCDRAW	CALL	DRCOLORINIT	POP.L	D4	LOAD.B	D3,#EOP	LIB	?AFCAR		; efface toute la swdo	CALL	_1MAJOUTPAGE	; grise les parties inutilisesPPS$:	CALL	DESMODEL	; dessine la page modle si ncessaire	LOAD.L	D3,(A6)+OGRID	; D1 <-- mode de la grille	TEST.L	D3:#BGRIDGRF	JUMP',BC NODOWN$	CALL	MAJGRILLE	; dessine la grille dessousNODOWN$:	CLR.W	D4		; D4 <-- premier calqueCALQUE$:	CALL	IFCALCA		; calque cach ?	JUMP',NE NODRAW$	; oui => NODRAW$	LOAD.W	D3,(A6)+OPAGE	; D3 <-- page visible	LOAD.L	D6,(A6)+OOBACH	; D6 <-- canal de l'arbre des objets	CALL	_1LSTA_FIRST	; A4 <-- ^premier objet	JUMP',NE NODRAW$	CALL	MAJOBJETS	; dessine tous les objets d'un calqueNODRAW$:	INC.W	D4	COMP.W	D4,(A6)+OIDCAL+OIDHTV	JUMP,LO CALQUE$	LOAD.L	D3,(A6)+OGRID	; D3 <-- mode de la grille	TEST.L	D3:#BGRIDGRL	JUMP',BC NOUP$	CALL	MAJGRILLE	; dessine la grille dessusNOUP$:	CALL	MAJMARGES	; dessine les marges dessus	CALL	MAJCOLONNES	; dessine les colonnes dessus	CALL	DESSELECT	; dessine tous les objets slectionns	CALL	WDOCLOSE	; fin du dessin dans la swdo	POP.L	(A6)+OAPOS	POPM.L	D3,D4,D6,A4	RET;----------\\; DESSELECT >;----------/; Redessine tous les objets slectionns.;;  (*)	S'il y a un seul objet slectionn avec ses poignes;	personnelles, il faut toujours tenter de le redessiner;	(sans tester sa bbox), car les poignes secondaires;	dpassent de la bbox (cas de l'objet CURVE) !; in	-; out	-; mod	D7.WDESSELECT:	PUSHM.L	D1..D4,A4	TEST.B	(A6)+OIFPRI	; impression en cours ?	JUMP,T	EXIT$		; oui => EXIT$	CALL	_1LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP,NE EXIT$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC EDIT$; Dessine un objet tendu, c'est--dire slectionn.	CALL	_1LSTA_NB	; D4 <-- nb de fils	INC.W	D4		; D4 <-- compte aussi le preXFILS$:	COMP.W	(A6)+OOUTIL,#ICOOFLECHE	JUMP',NE XCLIP$	COMP.W	(A6)+OSELNB,#1	; voir remarque (*)	JUMP',EQ XDRAW$XCLIP$:	CALL	CLIPOBJET	; objet apparat dans la fentre ?	JUMP',NE XRIEN$		; non => XRIEN$XDRAW$:	PUSH.L	D4	LOAD.L	D4,#H'10000*COLORFPAGE+COLORSELECT	CALL	DRCOLORINIT	POP.L	D4	CALL	_1LSTA_POS	; met  jour OAPOS	LOAD.L	D2,#2^BVUESET!2^BVUEPROV!2^BVUEPROVI!2^BVUEPROVE	LOAD.W	D1,#opDRAW	CALL	_1OBJCALLD	; dessine l'objetXRIEN$:	CALL	_1LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,NE EXIT$	DEC.W	D4	JUMP,NE XFILS$	JUMP	LOOP$EDIT$:	TEST.B	(A4)+OobjFLAGS:#BobjEDIT	JUMP',BC NEXT$; Dessine un objet en dition.	CALL	_1LSTA_NB	; D4 <-- nb de fils	INC.W	D4		; D4 <-- compte aussi le preEFILS$:	CALL	CLIPOBJET	; objet apparat dans la fentre ?	JUMP',NE ERIEN$		; non => ERIEN$	LOAD.W	D1,#opEDITDRAW	CALL	_1OBJCALLD	; dessine l'objetERIEN$:	CALL	_1LSTA_NEXT	; A4 <-- ^objet suivant	JUMP',NE EXIT$	DEC.W	D4	JUMP,NE EFILS$	JUMP	LOOP$NEXT$:	CALL	_1LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	POPM.L	D1..D4,A4	RET;---------\\; DESCLEAR >;=========/; Efface un objet dans la fentre de dessin.; in	A4.L	^objet; out	-; mod	D7.WDESCLEAR:	PUSHM.L	D2..D4,D6,A3,A4	PUSH.L	(A6)+OAPOS	CALL	WDOSAV		; sauve les dfinitions de la fentre	CALL	_1LSTA_BBOX	; D3/D4 <-- bbox absolue	CALL	WDODEF		; dimensione la fentre selon objet	JUMP,NE EXIT$	CALL	WDOOPEN		; dessine dans la swdo	LOAD.L	D2,(A6)+OVUE	LOAD.W	D2,#2^BVUECLR	CALL	DESOBJETF	; efface l'objet et ses fils	LOAD.L	A3,A4		; A3 <-- ^objet effac	CALL	DESMODEL	; dessine la page modle si ncessaire	LOAD.L	D3,(A6)+OGRID	; D3 <-- mode de la grille	TEST.L	D3:#BGRIDGRF	JUMP',BC NODOWN$	CALL	MAJGRILLE	; dessine la grille dessousNODOWN$:	CLR.W	D4		; D4 <-- premier calqueCALQUE$:	CALL	IFCALCA		; calque cach ?	JUMP',NE END$		; oui => END$	LOAD.W	D3,(A6)+OPAGE	; D3 <-- page visible	LOAD.L	D6,(A6)+OOBACH	; D6 <-- canal de l'arbre des objets	CALL	_1LSTA_FIRST	; A4 <-- ^premier objet	JUMP',NE END$	LOAD.L	D2,(A6)+OVUE	LOAD.W	D2,#2^BVUESET	; D2 <-- mode dfinitif	COMP.W	D4,(A6)+OCALQ	; est-ce le calque actif ?	JUMP',EQ LOOP$		; oui => LOOP$	SWAP.W	D2	RR.W	D2,#8		; D2 <-- bits si autre calque	SWAP.W	D2LOOP$:	COMP.L	A4,A3		; est-ce l'objet effac ?	JUMP',EQ RIEN$		; oui => RIEN$	CALL	DESOBJET	; dessine un objet	JUMP',NE RIEN$	CALL	_1LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$	JUMP'	END$RIEN$:	CALL	_1LSTA_NEXTF	; A4 <-- ^objet suivant (frre)	JUMP,EQ LOOP$END$:	INC.W	D4	COMP.W	D4,(A6)+OIDCAL+OIDHTV	JUMP,LO CALQUE$	LOAD.L	D3,(A6)+OGRID	; D3 <-- mode de la grille	TEST.L	D3:#BGRIDGRL	JUMP',BC NOUP$	CALL	MAJGRILLE	; dessine la grille dessusNOUP$:	CALL	MAJMARGES	; dessine les marges dessus	CALL	MAJCOLONNES	; dessine les colonnes dessus	CALL	WDOCLOSE	; fin du dessin dans la swdoEXIT$:	CALL	WDOGET		; restitue les dfinitions de la fentre	POP.L	(A6)+OAPOS	POPM.L	D2..D4,D6,A3,A4	RET;-------\\; DESSET >;=======/; Dessine un objet dans la fentre de dessin.; Redessine seulement les objets placs en-dessus.; in	A4.L	^objet; out	-; mod	D7.WDESSET:	PUSHM.L	D3,D4	PUSH.L	(A6)+OAPOS	CALL	WDOSAV		; sauve les dfinitions de la fentre	CALL	_1LSTA_BBOX	; D3/D4 <-- bbox absolue	CALL	WDODEF		; dimensione la fentre selon objet	JUMP,NE EXIT$	CALL	WDOOPEN		; dessine dans la swdo	PUSH.L	A4	CALL	_1LSTA_PCFIRST	; A4 <-- ^premier objet (met  jour OARLIM !)	POP.L	A4	LOAD.W	D4,(A6)+OCALQ	; D4 <-- calque actif	CALL	MAJOBJETS	; met  jour le reste du calque	CALL	DESUPCALQUE	; met  jour les calques au-dessus	LOAD.L	D3,(A6)+OGRID	; D1 <-- mode de la grille	TEST.L	D3:#BGRIDGRL	JUMP',BC NOUP$	CALL	MAJGRILLE	; dessine la grille dessusNOUP$:	CALL	MAJMARGES	; dessine les marges dessus	CALL	MAJCOLONNES	; dessine les colonnes dessus	CALL	WDOCLOSE	; fin du dessin dans la swdoEXIT$:	CALL	WDOGET		; restitue les dfinitions de la fentre	POP.L	(A6)+OAPOS	POPM.L	D3,D4	RET;----------\\; DESSETALL >;==========/; Dessine un objet dans la fentre de dessin.; Redessine tous les objets, mme ceux placs en-dessous.; in	A4.L	^objet; out	-; mod	D7.WDESSETALL:	PUSHM.L	D3,D4	PUSH.L	(A6)+OAPOS	CALL	_1LSTA_BBOX	; D3/D4 <-- bbox absolue	CALL	DESALLWDO	; redessine toute la fentre	POP.L	(A6)+OAPOS	POPM.L	D3,D4	RET;----------\\; DESALLWDO >;==========/; Redessine tous les objets situs dans une fentre.; in	D3.L	P1 wdo;	D4.L	P2 wdo; out	-; mod	D7.WDESALLWDO:	PUSHM.L	D3,D4,D6,A4	PUSH.L	(A6)+OAPOS	CALL	DESREFAIT	; refait le dessin si ncessaire	JUMP,EQ EXIT$		; si refait => EXIT$	CALL	WDOSAV		; sauve les dfinitions de la fentre	CALL	WDODEF		; dimensione la fentre selon objet	JUMP,NE ERROR$	CALL	WDOOPEN		; dessine dans la swdo	PUSH.L	D4	LOAD.L	D4,#H'10000*COLORFPAGE+COLORCDRAW	CALL	DRCOLORINIT	POP.L	D4	CALL	_1CCMO		; enlve la souris	LOAD.B	D3,#EOP	LIB	?AFCAR		; efface toute la swdo	CALL	DESMODEL	; dessine la page modle si ncessaire	LOAD.L	D3,(A6)+OGRID	; D1 <-- mode de la grille	TEST.L	D3:#BGRIDGRF	JUMP',BC NODOWN$	CALL	MAJGRILLE	; dessine la grille dessousNODOWN$:	CLR.W	D4		; D4 <-- premier calqueCALQUE$:	CALL	IFCALCA		; calque cach ?	JUMP',NE NODRAW$	; oui => NODRAW$	LOAD.W	D3,(A6)+OPAGE	; D3 <-- page visible	LOAD.L	D6,(A6)+OOBACH	; D6 <-- canal de l'arbre des objets	CALL	_1LSTA_FIRST	; A4 <-- ^premier objet	JUMP',NE NODRAW$	CALL	MAJOBJETS	; dessine tous les objets d'un calqueNODRAW$:	INC.W	D4	COMP.W	D4,(A6)+OIDCAL+OIDHTV	JUMP,LO CALQUE$	LOAD.L	D3,(A6)+OGRID	; D1 <-- mode de la grille	TEST.L	D3:#BGRIDGRL	JUMP',BC NOUP$	CALL	MAJGRILLE	; dessine la grille dessusNOUP$:	CALL	MAJMARGES	; dessine les marges dessus	CALL	MAJCOLONNES	; dessine les colonnes dessus	CALL	WDOCLOSE	; fin du dessin dans la swdoERROR$:	CALL	WDOGET		; restitue les dfinitions de la fentreEXIT$:	POP.L	(A6)+OAPOS	POPM.L	D3,D4,D6,A4	RET;------------\\; DESUPCALQUE >;============/; Met  jour tous les calques au-dessus du calque actif.; in	-; out	-; mod	D7.WDESUPCALQUE:	PUSHM.L	D3,D4,D6,A4	PUSH.L	(A6)+OAPOS	LOAD.W	D4,(A6)+OCALQ	; D4 <-- calque actifLOOP$:	INC.W	D4		; D4 <-- calque suivant	COMP.W	D4,(A6)+OIDCAL+OIDHTV	JUMP',HS EXIT$	CALL	IFCALCA		; calque cach ?	JUMP,NE LOOP$		; oui => LOOP$	LOAD.W	D3,(A6)+OPAGE	; D3 <-- page visible	LOAD.L	D6,(A6)+OOBACH	; D6 <-- canal de l'arbre des objets	CALL	_1LSTA_FIRST	; A4 <-- ^premier objet	JUMP,NE LOOP$	CALL	MAJOBJETS	; dessine tous les objets d'un calque	JUMP	LOOP$EXIT$:	POP.L	(A6)+OAPOS	POPM.L	D3,D4,D6,A4	RET;--------\\; IFCALCA >;--------/; Vrifie si un calque est cach.; in	D4.W	calque (0..n); out	D7.W	erreur (si cach); mod	D7.WIFCALCA:	PUSHM.L	D3,D4	CLR.W	D7		; D7 <-- calque visible	SUB.W	D4,(A6)+OIDCAL+OIDHTV	NEG.W	D4	DEC.W	D4	LOAD.L	D3,(A6)+OCALCA	TEST.L	D3:D4		; calque cach ?	JUMP',BC EXIT$		; non => EXIT$	LOAD.W	D7,#1		; D7 <-- calque cachEXIT$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; MAJOBJETS >;----------/; Met  jour tous les objets dans la fentre de dessin.; in	A4.L	^premier objet;	D4.W	calque (0..n); out	-; mod	D7.WMAJOBJETS:	PUSHM.L	D1,D2,D4,A4	LOAD.L	D2,(A6)+OVUE	LOAD.W	D2,#2^BVUESET	; D2 <-- mode dfinitif	COMP.W	D4,(A6)+OCALQ	; est-ce le calque actif ?	JUMP',EQ LOOP$		; oui => LOOP$	SWAP.W	D2	RR.W	D2,#8		; D2 <-- bits si autre calque	SWAP.W	D2LOOP$:	TEST.B	(A6)+OIFMODEL	; dessin d'une page modle ?	JUMP',F DRAW$		; non => DRAW$	LOAD.W	D1,#opCRIFEMPTY	CALL	_1OBJCALLD	; D4 <-- zro si objet vide	JUMP',NE DRAW$	TEST.L	D4		; objet (ex. pav de texte) vide ?	JUMP',EQ NEXT$		; oui => NEXT$DRAW$:	CALL	DESOBJET	; dessine un objet	JUMP',EQ NEXT$		; ok => NEXT$				; rien =>	CALL	_1LSTA_NEXTF	; A4 <-- ^objet suivant (frre)	JUMP,EQ LOOP$	JUMP'	EXIT$NEXT$:	CALL	_1LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	POPM.L	D1,D2,D4,A4	RET;-----------\\; DESISHIFTZ >;===========/; Inverse le rectangle de slection de zone.; in	D2.W	mode (1=dbut, 2=milieu, 3=fin); out	-; mod	D7.WDESISHIFTZ:	PUSH.L	(A6)+OAPOS	CLR.L	(A6)+OAPOS	CALL	WDOOPEN		; dessine dans la swdo	SET.B	(A6)+OZONDR	CALL	DESISHIFT	; inverse le rectangle	CLR.B	(A6)+OZONDR	CALL	WDOCLOSE	; fin du dessin dans la swdo	POP.L	(A6)+OAPOS	RET;----------\\; DESISHIFT >;==========/; Inverse un objet slectionn, avec effet tournant brevet !; in	A4.L	^objet quelconque;	D2.W	mode (1=dbut, 2=milieu, 3=fin); out	-; mod	D7.WDESISHIFT:	PUSHM.L	D2..D5,A3	PUSH.L	D4	LOAD.L	D4,#H'10000*COLORFPAGE+COLORSELECT	CALL	DRCOLORINIT	POP.L	D4	TEST.B	(A6)+OZONDR	; dessine la zone ?	JUMP',T GO$		; oui => GO$	COMP.L	A4,#0	JUMP,EQ EXIT$GO$:	COMP.W	D2,#1	JUMP',EQ OPEN$	COMP.W	D2,#2	JUMP',EQ SHIFT$	COMP.W	D2,#3	JUMP',EQ CLOSE$	JUMP	EXIT$OPEN$:	NTREL	?GETSYTIME	; D4 <-- temps processeus (mod D2..D5 !)	LOAD.L	(A6)+OMAPTP,D4	LOAD.B	D3,(A6)+OMAPNB	LOAD.B	D2,#B'10001000	RL.B	D2,D3	LOAD.B	(A6)+OMAPTT,D2	LOAD.B	D2,#B'00001111	RL.B	D2,D3	JUMP	DRAW$SHIFT$:	NTREL	?GETSYTIME	; D4 <-- temps processeus (mod D2..D5 !)	LOAD.L	D5,D4	SUB.L	D4,(A6)+OMAPTP	COMP.L	D4,#250		; s'est-il coul un minimum de temps ?	JUMP,LO EXIT$		; non => EXIT$	LOAD.L	(A6)+OMAPTP,D5	LOAD.W	D3,#1	COMP.W	D4,#250*2	; s'est-il coul vraiment longtemps ?	JUMP',LO SHIFT2$	; non => SHIFT2$	INC.W	D3		; oui => tourne plus vite !SHIFT2$:	LOAD.B	D2,(A6)+OMAPTT	RL.B	D2,#1	LOAD.B	D4,D2	COMP.W	D3,#1	JUMP',EQ SHIFT3$	RL.B	D4,#1	OR.B	D2,D4SHIFT3$:	LOAD.B	(A6)+OMAPTT,D4	ADD.B	(A6)+OMAPNB,D3	JUMP'	DRAW$CLOSE$:	LOAD.B	D2,#B'00001111	LOAD.B	D3,(A6)+OMAPNB	RL.B	D2,D3;	JUMP'	DRAW$DRAW$:	LOAD.L	A3,#(A6)+OBUDIS	LOAD.B	(A3)+0,#MAPTT	LOAD.B	(A3)+1,D2	; map	LOAD.B	(A3)+2,#1	; chelle	LOAD.W	D3,#3	LIB	?STRING	TEST.B	(A6)+OZONDR	; dessine la zone ?	JUMP',T ZONE$		; oui => ZONE$	LOAD.L	D2,#2^BVUESHIFT!2^BVUEPROV!2^BVUEPROVE	CALL	DESOBJET	; dessine l'objet;;?	CALL	DESOBJETF	; dessine l'objet et ses fils	JUMP'	EXIT$ZONE$:	LOAD.L	D2,#INVDOT!TTTDOT	LOAD.L	D3,(A6)+OZONY1	LOAD.L	D4,D3	LOAD.W	D4,(A6)+OZONX2	CALL	DRLINEM	LOAD.L	D3,D4	LOAD.L	D4,(A6)+OZONY2	CALL	DRLINEM	LOAD.L	D3,D4	LOAD.L	D4,D3	LOAD.W	D4,(A6)+OZONX1	CALL	DRLINEM	LOAD.L	D3,D4	LOAD.L	D4,(A6)+OZONY1	CALL	DRLINEMEXIT$:	POPM.L	D2..D5,A3	RET;----------\\; DESOBJETF >;==========/; Dessine un objet quelconque, et tous ses fils.; in	A4.L	^objet quelconque;	D2.L	mode de dessin (SETDOT/CLRDOT/INVDOT,etc.); out	-; mod	D7.WDESOBJETF:	PUSH.W	D1	TEST.L	D2:#BVUEPROV	; mode provisoire ?	JUMP',BS PROV$		; oui => PROV$	TEST.L	D2:#BVUESHIFT	; mode provisoire ?	JUMP',BS PROV$		; oui => PROV$	CALL	CLIPOBJET	; objet apparat dans la fentre ?	JUMP',NE RIEN$		; non => RIEN$	TEST.B	(A6)+OIFPRI	; impression en cours ?	JUMP',T	DRAW$		; oui => DRAW$	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BS RIEN$	TEST.B	(A4)+OobjFLAGS:#BobjEDIT	JUMP',BS RIEN$	TEST.B	(A4)+OobjFLAGS:#BobjCREATE	JUMP',BS RIEN$	JUMP'	DRAW$PROV$:	PUSH.L	D4	LOAD.L	D4,#H'10000*COLORFPAGE+COLORSELECT	CALL	DRCOLORINIT	POP.L	D4DRAW$:	CALL	WDOOPEN		; dessine dans la swdo	LOAD.W	D1,#opDRAW	CALL	_1OBJCALLDF	; dessine l'objet et tous ses fils	CALL	WDOCLOSE	; fin du dessin dans la swdo	CLR.W	D7	JUMP'	EXIT$RIEN$:	LOAD.W	D7,#1EXIT$:	POP.W	D1	TEST.W	D7		; retour EQ/NE	RET;---------\\; DESOBJET >;=========/; Dessine un objet quelconque.; in	A4.L	^objet quelconque;	D2.L	mode de dessin (SETDOT/CLRDOT/INVDOT,etc.); out	D7.W	erreur (si rien dessin); mod	D7.WDESOBJET:	PUSH.W	D1	TEST.L	D2:#BVUEPROV	; mode provisoire ?	JUMP',BS PROV$		; oui => PROV$	TEST.L	D2:#BVUESHIFT	; mode provisoire ?	JUMP',BS PROV$		; oui => PROV$	CALL	CLIPOBJET	; objet apparat dans la fentre ?	JUMP',NE RIEN$		; non => RIEN$	TEST.B	(A6)+OIFPRI	; impression en cours ?	JUMP',T	DRAW$		; oui => DRAW$	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BS RIEN$	TEST.B	(A4)+OobjFLAGS:#BobjEDIT	JUMP',BS RIEN$	TEST.B	(A4)+OobjFLAGS:#BobjCREATE	JUMP',BS RIEN$	JUMP'	DRAW$PROV$:	PUSH.L	D4	LOAD.L	D4,#H'10000*COLORFPAGE+COLORSELECT	CALL	DRCOLORINIT	POP.L	D4DRAW$:	CALL	WDOOPEN		; dessine dans la swdo	CALL	_1LSTA_POS	; met  jour OAPOS	LOAD.W	D1,#opDRAW	CALL	_1OBJCALLD	; dessine l'objet	CALL	WDOCLOSE	; fin du dessin dans la swdo	CLR.W	D7	JUMP'	EXIT$RIEN$:	LOAD.W	D7,#1EXIT$:	POP.W	D1	TEST.W	D7		; retour EQ/NE	RET;---------\\; DETOBJET >;=========/; Cherche sur quel objet est la souris.; in	D4.L	position de la souris (y;x);	A1.L	^routine pour objets  exclure (*); out	A4.L	^objet o est la souris/nil;	D7.W	erreur; mod	D7.W, A4.L; Routine (*) :; in	A4.L	^objet; out	D7.W	erreur si objet  exclure; mod	D7.WDETOBJET:	PUSHM.L	D0..D5,A2,A3	LIB	?GETSHIFT	; D3 <-- touches super-shift	LOAD.B	(A6)+OSELSS,D3	LOAD.W	D5,D4		; D5 <-- Px	LOAD.L	D3,D4	SWAP.W	D3		; D3 <-- Py	CALL	GETDETM	LOAD.W	D2,D4		; D2 <-- marge de dtection selon chelle	CALL	_1LSTA_PCLAST	; A4 <-- ^dernier objet	JUMP',NE NOTFOUND$LOOP$:	COMP.L	A1,#0	JUMP',EQ BBOX$	CALL	(A1)		; objet  exclure ?	JUMP',NE NEXT$		; oui => NEXT$BBOX$:	PUSH.L	D3	CALL	_1LSTA_BBOX	; D3/D4 <-- bbox absolue	LOAD.L	D0,D3	LOAD.L	D1,D4	POP.L	D3	SUB.W	D0,D2	COMP.W	D5,D0	JUMP',LT NEXT$	ADD.W	D1,D2	COMP.W	D5,D1	JUMP',GE NEXT$	SWAP.W	D0	SWAP.W	D1	SUB.W	D0,D2	COMP.W	D3,D0	JUMP',LT NEXT$	ADD.W	D1,D2	COMP.W	D3,D1	JUMP',GE NEXT$	LOAD.W	D1,#opEDITICOLIST	CALL	_1OBJCALLD	; A2/A3 <-- ^soft-keys/^liste des icnes	JUMP',EQ EXIT$		; oui => EXIT$	LOAD.W	D4,D3	SUB.W	D4,(A6)+OAPOS+0	SWAP.W	D4	LOAD.W	D4,D5	SUB.W	D4,(A6)+OAPOS+2	; D4 <-- position relative de la souris	LOAD.W	D1,#opDETECT	CALL	_1OBJCALLD	; souris sur l'objet ?	JUMP',EQ EXIT$		; oui => EXIT$NEXT$:	CALL	_1LSTA_PREV	; A4 <-- ^objet prcdent	JUMP,EQ LOOP$NOTFOUND$:	LOAD.L	A4,#0		; A4 <-- nilEXIT$:	POPM.L	D0..D5,A2,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; DEEOBJET >;=========/; Cherche sur quel objet est la souris, pour l'diter.; in	D4.L	position de la souris (y;x); out	A4.L	^objet o est la souris/nil;	D7.W	erreur; mod	D7.W, A4.LDEEOBJET:	PUSHM.L	D0..D5,A2,A3	LOAD.W	D5,D4		; D5 <-- Px	LOAD.L	D3,D4	SWAP.W	D3		; D3 <-- Py	CALL	GETDETM	LOAD.W	D2,D4		; D2 <-- marge de dtection selon chelle	CALL	_1LSTA_PCLAST	; A4 <-- ^dernier objet	JUMP',NE NOTFOUND$LOOP$:	PUSH.L	D3	CALL	_1LSTA_BBOX	; D3/D4 <-- bbox absolue	LOAD.L	D0,D3	LOAD.L	D1,D4	POP.L	D3	SUB.W	D0,D2	COMP.W	D5,D0	JUMP',LT NEXT$	ADD.W	D1,D2	COMP.W	D5,D1	JUMP',GE NEXT$	SWAP.W	D0	SWAP.W	D1	SUB.W	D0,D2	COMP.W	D3,D0	JUMP',LT NEXT$	ADD.W	D1,D2	COMP.W	D3,D1	JUMP',GE NEXT$	LOAD.W	D1,#opEDITICOLIST	CALL	_1OBJCALLD	; A2/A3 <-- ^soft-keys/^liste des icnes	JUMP',EQ EXIT$		; oui => EXIT$NEXT$:	CALL	_1LSTA_PREV	; A4 <-- ^objet prcdent	JUMP,EQ LOOP$NOTFOUND$:	LOAD.L	A4,#0		; A4 <-- nilEXIT$:	POPM.L	D0..D5,A2,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; GETDETM >;========/; Donne la marge de dtection.; in	-; out	D4.W	marge de dtection [obj]; mod	D4.L, D7.WGETDETM:	LOAD.W	D4,(A6)+ODETM	; D4 <-- marge de dtection	CALL	_1SCALEN		; D4 <-- marge de dtection selon chelle	TEST.W	D4	JUMP',NE EXIT$	INC.W	D4EXIT$:	RET;----------\\; CLIPOBJET >;==========/; Regarde si un objet apparat, mme partiellement, dans une fentre; rectangulaire donne dans D3/D4.; in	A4.L	^objet quelconque; out	D7.W	EQ => reconvrement;		NE => aucun recouvrement; mod	D7.WCLIPOBJET:	PUSHM.L	D1..D4	LOAD.L	D1,(A6)+ODESY1	; D1 <-- coin sup/gauche	LOAD.L	D2,(A6)+ODESY2	; D2 <-- coin inf/droite	CALL	_1LSTA_BBOX	; D3/D4 <-- bbox absolue	LOAD.W	D7,#ERDIOUT	; D7 <-- pas de recouvrement	COMP.W	D1,D4	JUMP',GE EXIT$	COMP.W	D2,D3	JUMP',LT EXIT$	SWAP.W	D1	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	COMP.W	D1,D4	JUMP',GE EXIT$	COMP.W	D2,D3	JUMP',LT EXIT$	CLR.W	D7		; D7 <-- recouvrementEXIT$:	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DESMODEL >;=========/; Dessine la page modle en fond.; in	-; out	-; mod	D7.WDESMODEL:	PUSHM.L	D1..D4,D6,A3,A4	LOAD.L	D6,(A6)+OOBACH	; D6 <-- canal de l'arbre des objets	LOAD.W	D3,(A6)+OPAGE	LOAD.W	D4,#-1	CALL	_1LSTA_BEGIN	; A4 <-- ^objet page	JUMP,NE EXIT$	TEST.L	(A4)+OobjPDATA	JUMP,EQ EXIT$	LOAD.L	A4,(A4)+OobjPDATA ; A4 <-- ^instance de l'objet page	LOAD.L	D4,(A4)+OIPFLG	; D4 <-- flags	TEST.L	D4:#BIPNORM	JUMP,BS EXIT$	CLR.W	D2		; D2 <-- page modle "G"	TEST.L	D4:#BIPG	JUMP',BS PAGE$	INC.W	D2		; D2 <-- page modle "D"	TEST.L	D4:#BIPD	JUMP',BS PAGE$	INC.W	D2		; D2 <-- page modle "X"	TEST.L	D4:#BIPX	JUMP',BS PAGE$	TEST.L	D4:#BIPGD	JUMP,BC EXIT$	CLR.W	D2		; D2 <-- page modle "G"	TEST.B	(A6)+OPAGE+1:#0	; page pair ?	JUMP',BC PAGE$		; oui => PAGE$	INC.W	D2		; D2 <-- page modle "D"PAGE$:	LOAD.W	D1,(A6)+OPAGE	PUSH.W	(A6)+OCALQ	PUSH.L	(A6)+OCALCA	LOAD.W	(A6)+OCALQ,#-1	; on est dans aucun calque !	CLR.L	(A6)+OCALCA	; tous les calques sont visibles	CLR.W	D4		; D4 <-- premier calqueCLOOP$:	LOAD.W	(A6)+OPAGE,D2	; utilise la page modle	LOAD.W	D3,(A6)+OPAGE	; D3 <-- page visible	CALL	_1LSTA_FIRST	; A4 <-- ^premier objet	JUMP',NE END$	LOAD.W	(A6)+OPAGE,D1	; utilise la page normale	SET.B	(A6)+OIFMODEL	CALL	MAJOBJETS	; dessine tous les objets d'un calque	CLR.B	(A6)+OIFMODEL	INC.W	D4	JUMP	CLOOP$END$:	POP.L	(A6)+OCALCA	POP.W	(A6)+OCALQ	LOAD.W	(A6)+OPAGE,D1EXIT$:	POPM.L	D1..D4,D6,A3,A4	RET;----------\\; MAJGRILLE >;==========/; Met  jour la grille.; in	-; out	-; mod	D7.WMAJGRILLE:	PUSHM.L	D0..D6,A0..A2	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	CALL	_1CCMO		; enlve la souris	LOAD.L	D2,(A6)+OGRID	LOAD.W	D1,#2	TEST.L	D2:#BGRIDMU2	JUMP',BS SUBDIV$	LOAD.W	D1,#3	TEST.L	D2:#BGRIDMU3	JUMP',BS SUBDIV$	LOAD.W	D1,#4	TEST.L	D2:#BGRIDMU4	JUMP',BS SUBDIV$	LOAD.W	D1,#5	TEST.L	D2:#BGRIDMU5	JUMP',BS SUBDIV$	LOAD.W	D1,#6	TEST.L	D2:#BGRIDMU6	JUMP',BS SUBDIV$	LOAD.W	D1,#8		; D1 <-- subdivisionSUBDIV$:	LOAD.W	D0,(A6)+OPAS	; D0 <-- pas	LOAD.W	D4,D0	CALL	_1SCALEP		; D4 <-- ~pas [scr]	COMP.W	D4,#3		; assez grand ?	JUMP',HS SUBOK$		; oui => SUBOK$	MUL.WU	D0,D1		; D0 <-- pas*subdivision	LOAD.W	D1,#1		; D1 <-- plus de subdivision	LOAD.W	D4,D0	CALL	_1SCALEP		; D4 <-- ~pas [scr]	COMP.W	D4,#3		; vraiment trop petit ?	JUMP,LO EXIT$		; oui => EXIT$SUBOK$:	CLR.L	D3	LOAD.W	D3,(A6)+ODESY1	DIV.WU	D3,D0	CLR.L	D6	LOAD.W	D6,D3		; D6 <-- numro de la ligne	SWAP.W	D3	TEST.W	D3	JUMP',EQ RNDY$	SUB.W	D3,D0	NEG.W	D3	INC.W	D6RNDY$:	CLR.L	D5	LOAD.W	D5,(A6)+ODESY2	SUB.W	D5,(A6)+ODESY1	SUB.W	D5,D3	ADD.W	D5,D0	DEC.W	D5	DIV.WU	D5,D0		; D5 <-- nb de lignes en Y	JUMP,EQ EXIT$	TEST.B	(A2)+ODFCMD	; cran couleur ?	JUMP,NE COLOR$		; oui => COLOR$LOOPY$:	PUSHM.L	D0,D3,D5,D6	LOAD.W	D4,(A6)+OSCALE	; D4 <-- chelle	JUMP',EQ POSY$	JUMP',NS POSYN$	MUL.WA	D3,D4		; D3 <-- position initiale en Y [scr]	JUMP'	POSY$POSYN$:	NEG.W	D4		; D4 <-- |chelle|	CONV.LA.WA D3	DIV.WA	D3,D4		; D3 <-- position initiale en Y [scr]POSY$:	ADD.W	D3,(A2)+ODFWBY	; D3 <-- coordonne Y absolue dans bitmap	MUL.WU	D3,(A2)+ODFIIY	LOAD.W	D5,D0		; D5 <-- pas normal	DIV.WU	D6,D1	SWAP.W	D6	TEST.W	D6	JUMP',EQ FINEY$	MUL.WU	D5,D1		; D5 <-- pas plus grossierFINEY$:	CLR.L	D4	LOAD.W	D4,(A6)+ODESX1	DIV.WU	D4,D5	SWAP.W	D4	TEST.W	D4	JUMP',EQ RNDX$	SUB.W	D4,D5	NEG.W	D4RNDX$:	CLR.L	D2	LOAD.W	D2,(A6)+ODESX2	SUB.W	D2,(A6)+ODESX1	SUB.W	D2,D4	ADD.W	D2,D5	DEC.W	D2	DIV.WU	D2,D5		; D2 <-- nb de points en X	JUMP',EQ NEXTY$LOOPX$:	LOAD.W	D6,D4	LOAD.W	D0,(A6)+OSCALE	; D0 <-- chelle	JUMP',EQ POSX$	JUMP',NS POSXN$	MUL.WA	D6,D0		; D6 <-- position en X [scr]	JUMP'	POSX$POSXN$:	NEG.W	D0		; D0 <-- |chelle|	CONV.LA.WA D6	DIV.WA	D6,D0		; D6 <-- position en X [scr]POSX$:	ADD.W	D6,(A2)+ODFWBX	; D6 <-- coordonne X absolue dans bitmap	LOAD.B	D0,D6	NOT.B	D0		; bits inverss (7..0) !	SR.W	D6,#3		; D6 <-- dcale coordonne X	LOAD.L	A0,(A2)+ODFABS	; A0 <-- adresse dbut cran	ADD.W	A0,D6		; A0 <-- adresse dans l'cran selon X	ADD.L	A0,D3		; A0 <-- adresse dans l'cran selon Y	TSET.B	(A0):D0		; allume un point	ADD.W	D4,D5		; D4 <-- position suivante en X	DEC.W	D2	JUMP,NE LOOPX$NEXTY$:	POPM.L	D0,D3,D5,D6	ADD.W	D3,D0		; D3 <-- position suivante en Y	INC.W	D6		; D6 <-- ligne suivante	DEC.W	D5	JUMP,NE LOOPY$	JUMP	EXIT$COLOR$:	LOAD.L	D4,#COLORGRID	CALL	DRCOLORINIT	LOAD.L	A1,(A6)+ODOT	; A1 <-- ^routine GRA2_DOTCLOOPY$:	PUSHM.L	D0,D3,D5,D6	LOAD.W	D4,(A6)+OSCALE	; D4 <-- chelle	JUMP',EQ CPOSY$	JUMP',NS CPOSYN$	MUL.WA	D3,D4		; D3 <-- position initiale en Y [scr]	JUMP'	CPOSY$CPOSYN$:	NEG.W	D4		; D4 <-- |chelle|	CONV.LA.WA D3	DIV.WA	D3,D4		; D3 <-- position initiale en Y [scr]CPOSY$:	LOAD.W	D5,D0		; D5 <-- pas normal	DIV.WU	D6,D1	SWAP.W	D6	TEST.W	D6	JUMP',EQ CFINEY$	MUL.WU	D5,D1		; D5 <-- pas plus grossierCFINEY$:	CLR.L	D4	LOAD.W	D4,(A6)+ODESX1	DIV.WU	D4,D5	SWAP.W	D4	TEST.W	D4	JUMP',EQ CRNDX$	SUB.W	D4,D5	NEG.W	D4CRNDX$:	CLR.L	D2	LOAD.W	D2,(A6)+ODESX2	SUB.W	D2,(A6)+ODESX1	SUB.W	D2,D4	ADD.W	D2,D5	DEC.W	D2	DIV.WU	D2,D5		; D2 <-- nb de points en X	JUMP',EQ CNEXTY$CLOOPX$:	LOAD.W	D6,D4	LOAD.W	D0,(A6)+OSCALE	; D0 <-- chelle	JUMP',EQ CPOSX$	JUMP',NS CPOSXN$	MUL.WA	D6,D0		; D6 <-- position en X [scr]	JUMP'	CPOSX$CPOSXN$:	NEG.W	D0		; D0 <-- |chelle|	CONV.LA.WA D6	DIV.WA	D6,D0		; D6 <-- position en X [scr]CPOSX$:	PUSHM.L	D1,D4	LOAD.W	D4,D3	SWAP.W	D4	LOAD.W	D4,D6	LOAD.W	D1,#SETDOT	CALL	(A1)		; GRA2_DOT, allume un point en couleur	POPM.L	D1,D4	ADD.W	D4,D5		; D4 <-- position suivante en X	DEC.W	D2	JUMP,NE CLOOPX$CNEXTY$:	POPM.L	D0,D3,D5,D6	ADD.W	D3,D0		; D3 <-- position suivante en Y	INC.W	D6		; D6 <-- ligne suivante	DEC.W	D5	JUMP,NE CLOOPY$EXIT$:	POPM.L	D0..D6,A0..A2	RET;----------\\; MAJMARGES >;==========/; Dessine les marges.; in	-; out	-; mod	D7.WMAJMARGES:	PUSHM.L	D1..D4	PUSH.L	(A6)+OAPOS	CLR.L	(A6)+OAPOS	TEST.B	(A6)+OVUE+0:#BVUEREPMARG-24	JUMP',BC EXIT$	TEST.B	(A6)+OIFPRI	; impression en cours ?	JUMP',T	EXIT$		; oui => EXIT$	PUSH.L	D4	LOAD.L	D4,#H'10000*COLORFPAGE+COLORCDRAW	CALL	DRCOLORINIT	POP.L	D4	LOAD.W	D2,#SETDOT!TTTDOT	LOAD.B	D1,#B'00111111	LOAD.W	D3,(A6)+ODESMS	SWAP.W	D3	LOAD.W	D3,(A6)+ODESMG	LOAD.W	D4,(A6)+ODESYD	SUB.W	D4,(A6)+ODESMI	SWAP.W	D4	LOAD.W	D4,(A6)+ODESXD	SUB.W	D4,(A6)+ODESMD	CALL	DRRECTHV	; dessine le rectangle des margesEXIT$:	POP.L	(A6)+OAPOS	POPM.L	D1..D4	RET;------------\\; MAJCOLONNES >;============/; Dessine les colonnes.; in	-; out	-; mod	D7.WMAJCOLONNES:	PUSHM.L	D0..D5	PUSH.L	(A6)+OAPOS	CLR.L	(A6)+OAPOS	TEST.B	(A6)+OVUE+0:#BVUEREPCOL-24	JUMP,BC EXIT$	TEST.B	(A6)+OIFPRI	; impression en cours ?	JUMP,T	EXIT$		; oui => EXIT$	PUSH.L	D4	LOAD.L	D4,#H'10000*COLORFPAGE+COLORCDRAW	CALL	DRCOLORINIT	POP.L	D4	LOAD.W	D2,#SETDOT!TTTDOT	LOAD.B	D1,#B'00111111	CLR.L	D5	LOAD.W	D5,(A6)+ODESXD	SUB.W	D5,(A6)+ODESMG	SUB.W	D5,(A6)+ODESMD	; D5 <-- largeur pour toutes les colonnes	LOAD.W	D3,(A6)+OCOLES	LOAD.W	D4,(A6)+OCOLNB	DEC.W	D4	JUMP,LE EXIT$	MUL.WU	D3,D4		; D3 <-- largeur de toutes les gouttires	SUB.W	D5,D3		; D5 <-- largeur sans les gouttires	JUMP,LE EXIT$	DIV.WU	D5,(A6)+OCOLNB	; D5 <-- largeur d'une colonne	LOAD.W	D3,(A6)+ODESMS	; D3 <-- origine en Y	SWAP.W	D3	LOAD.W	D3,(A6)+ODESMG	; D3 <-- origine en X	LOAD.W	D4,(A6)+ODESYD	SUB.W	D4,(A6)+ODESMI	; D4 <-- bas	SWAP.W	D4	LOAD.W	D0,(A6)+OCOLNB	; D0 <-- nb de colonnes	TEST.B	(A6)+OVUE+0:#BVUEREPMARG-24	JUMP',BS MARG$RLOOP$:	LOAD.W	D4,D3	ADD.W	D4,D5		; D4 <-- droite	CALL	DRRECTHV	; dessine une colonne	ADD.W	D3,D5	ADD.W	D3,(A6)+OCOLES	; D3 <-- origine suivante en X	DEC.W	D0	JUMP,NE RLOOP$	JUMP'	EXIT$MARG$:	COMP.W	D0,#1		; une seule colonne ?	JUMP',EQ EXIT$		; oui => EXIT$MLOOP$:	COMP.W	D0,(A6)+OCOLNB	; est-on dans la premire colonne ?	JUMP',EQ MLEFT$		; oui => MLEFT$	LOAD.W	D4,D3	CALL	DRLINEV		; dessine la ligne verticale de gaucheMLEFT$:	ADD.W	D3,D5	COMP.W	D0,#1		; est-on dans la dernire colonne ?	JUMP',EQ MRIGHT$	; oui => MRIGHT$	LOAD.W	D4,D3	CALL	DRLINEV		; dessine la ligne verticale de droiteMRIGHT$:	ADD.W	D3,(A6)+OCOLES	; D3 <-- origine suivante en X	DEC.W	D0	JUMP,NE MLOOP$;	JUMP'	EXIT$EXIT$:	POP.L	(A6)+OAPOS	POPM.L	D0..D5	RET;-------\\; GETCOL >;=======/; Donne la position et les dimensions d'une colonne.; in	D2.W	rang de la colonne (0..n); out	D3.L	P1 (y;x);	D4.L	P2 (y;x);	D7.W	erreur; mod	D3.L, D4.L, D7.WGETCOL:	PUSHM.L	D2,A4	LOAD.W	D7,#1		; D7 <-- n'existe pas	COMP.W	(A6)+OCOLNB,#1	JUMP',LE ONE$	COMP.W	D2,(A6)+OCOLNB	JUMP',HS EXIT$	LOAD.L	A4,#(A6)+OCOLPX	SL.W	D2,#2	LOAD.W	D3,(A4)+(D2.W)	LOAD.W	D4,(A4)+(D2.W)+2	JUMP'	OK$ONE$:	TEST.W	D2	JUMP',NE EXIT$	LOAD.W	D3,(A6)+ODESMG	; D3 <-- dbut en X	LOAD.W	D4,(A6)+ODESXD	SUB.W	D4,(A6)+ODESMD	; D4 <-- fin en XOK$:	SWAP.W	D3	LOAD.W	D3,(A6)+ODESMS	; D3 <-- dbut en Y	SWAP.W	D3	SWAP.W	D4	LOAD.W	D4,(A6)+ODESYD	SUB.W	D4,(A6)+ODESMI	; D4 <-- fin en Y	SWAP.W	D4	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DRRECTHV >;=========/; Dessine un rectangle horizontal/vertical, avec clipping rapide.; in	D3.L	coin sup/gauche (y;x);	D4.L	coin inf/droite (y;x);	D2.W	mode de dessin;	D1.B	map si traitill; out	-; mod	D7.WDRRECTHV:	PUSHM.L	D3..D6	LOAD.W	D5,D4	SUB.W	D5,D3		; D5 <-- largeur	LOAD.L	D6,D4	SWAP.W	D6	SWAP.W	D3	SUB.W	D6,D3		; D6 <-- hauteur	SWAP.W	D3	LOAD.L	D4,D3	ADD.W	D4,D5	CALL	DRLINEH	LOAD.L	D3,D4	SWAP.W	D4	ADD.W	D4,D6	SWAP.W	D4	CALL	DRLINEV	LOAD.L	D3,D4	SUB.W	D4,D5	CALL	DRLINEH	LOAD.L	D3,D4	SWAP.W	D4	SUB.W	D4,D6	SWAP.W	D4	CALL	DRLINEV	POPM.L	D3..D6	RET;--------\\; DRLINEH >;========/; Dessine une ligne droite horizontale, avec clipping rapide.; in	D3.L	dpart (y;x);	D4.L	arrive (y;x);	D2.W	mode de dessin;	D1.B	map si traitill; out	-; mod	D7.WDRLINEH:	PUSHM.L	D0,D1,D3,D4,A2	SWAP.W	D3	COMP.W	D3,(A6)+ODESY1	JUMP',LT EXIT$	COMP.W	D3,(A6)+ODESY2	JUMP',GE EXIT$	SWAP.W	D3	COMP.W	D3,D4	JUMP',LE GD$	EX.L	D3,D4GD$:	COMP.W	D3,(A6)+ODESX2	JUMP',GE EXIT$	LOAD.W	D0,D3	COMP.W	D3,(A6)+ODESX1	JUMP',GE P1$	LOAD.W	D3,(A6)+ODESX1P1$:	SUB.W	D0,D3	NEG.W	D0		; D0 <-- avance  cause clipping [obj]	COMP.W	D4,(A6)+ODESX1	JUMP',LT EXIT$	COMP.W	D4,(A6)+ODESX2	JUMP',LT P2$	LOAD.W	D4,(A6)+ODESX2P2$:	TEST.L	D2:#BTTTDOT	; dessine un traitill ?	JUMP',BC DRAW$		; non => DRAW$	EX.L	D4,D0	CALL	_1SCALEPBIG	; D0 <-- avance  cause clipping [scr]	EX.L	D0,D4	AND.B	D0,#B'111	; D0 <-- avance (0..7)	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	RR.B	D1,D0	LOAD.B	(A2)+ODFTTM,D1	LOAD.B	(A2)+ODFTTS,#1	CLR.W	(A2)+ODFPT1DRAW$:	CALL	DRLINE		; dessine une ligne verticaleEXIT$:	POPM.L	D0,D1,D3,D4,A2	RET;--------\\; DRLINEV >;========/; Dessine une ligne droite verticale, avec clipping rapide.; in	D3.L	dpart (y;x);	D4.L	arrive (y;x);	D2.W	mode de dessin;	D1.B	map si traitill; out	-; mod	D7.WDRLINEV:	PUSHM.L	D0,D1,D3,D4,A2	COMP.W	D3,(A6)+ODESX1	JUMP,LT EXIT$	COMP.W	D3,(A6)+ODESX2	JUMP,GE EXIT$	SWAP.W	D3	SWAP.W	D4	COMP.W	D3,D4	JUMP',LE HB$	EX.L	D3,D4HB$:	COMP.W	D3,(A6)+ODESY2	JUMP',GE EXIT$	LOAD.W	D0,D3	COMP.W	D3,(A6)+ODESY1	JUMP',GE P1$	LOAD.W	D3,(A6)+ODESY1P1$:	SUB.W	D0,D3	NEG.W	D0		; D0 <-- avance  cause clipping [obj]	COMP.W	D4,(A6)+ODESY1	JUMP',LT EXIT$	COMP.W	D4,(A6)+ODESY2	JUMP',LT P2$	LOAD.W	D4,(A6)+ODESY2P2$:	SWAP.W	D4	SWAP.W	D3	TEST.L	D2:#BTTTDOT	; dessine un traitill ?	JUMP',BC DRAW$		; non => DRAW$	EX.L	D4,D0	CALL	_1SCALEPBIG	; D0 <-- avance  cause clipping [scr]	EX.L	D0,D4	AND.B	D0,#B'111	; D0 <-- avance (0..7)	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	RR.B	D1,D0	LOAD.B	(A2)+ODFTTM,D1	LOAD.B	(A2)+ODFTTS,#1	CLR.W	(A2)+ODFPT1DRAW$:	CALL	DRLINE		; dessine une ligne verticaleEXIT$:	POPM.L	D0,D1,D3,D4,A2	RET;-------\\; DRLINE >;=======/; Dessine une ligne droite.; in	D3.L	dpart (y;x);	D4.L	arrive (y;x);	D2.W	mode de dessin; out	-; mod	D7.WDRLINE:	PUSHM.L	D0..D4,A1,A2	TEST.B	(A6)+OIFPPS	; impression PostScript en cours ?	JUMP,T	PPS$		; oui => PPS$	TEST.B	(A6)+OIFFRAG	; fragmentation en cours ?	JUMP,T	FRAG$		; oui => FRAG$	EX.L	D3,D4	CALL	_1CONVOBJDRAW	; D3 <- position [scr]	JUMP,NE EXIT$	EX.L	D4,D3	CALL	_1CONVOBJDRAW	; D4 <- position [scr]	JUMP,NE EXIT$	TEST.L	(A6)+OBMABS	; bitmap existe ?	JUMP',NE BITMAP$	; oui => BITMAP$	CALL	_1CCMO		; enlve la souris	JUMP'	DRAW$BITMAP$:	CALL	DRBMBBOXQ	; bitmap <-- indique o l'on va dessinerDRAW$:	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	EX.L	D3,D4	LOAD.W	D1,D2		; D1 <-- mode de dessin	LOAD.L	A1,(A6)+OLINE	CALL	(A1)		; GRA2_LINE, dessine une ligne	JUMP'	EXIT$PPS$:	PUSH.L	D3	LOAD.W	D0,#IDENTPEN	LOAD.W	D1,#opDGETUSE	CALL	_1OBJCALL	; D3 <-- pinceau utilis	LOAD.W	D1,D3		; D1 <-- pinceau utilis	POP.L	D3	LOAD.L	A2,(A6)+OCAPAGEPS	PPS_	DRLINE	JUMP'	EXIT$FRAG$:	LOAD.W	D2,#2+4+4	; D2 <-- lg ncessaire	CALL	FRAGBUFF	; A2 <-- ^buffer	JUMP',NE EXIT$	LOAD.W	(A2+),#IDFRAGLINE	LOAD.L	(A2+),D3	LOAD.L	(A2+),D4EXIT$:	POPM.L	D0..D4,A1,A2	RET;--------\\; DRLINEM >;========/; Dessine une ligne droite, sans enlever la souris.; ATTENTION: Cet appel est plus lent que DRLINE !; in	D3.L	dpart (y;x);	D4.L	arrive (y;x);	D2.W	mode de dessin; out	-; mod	D7.WDRLINEM:	PUSHM.L	D3,D4	EX.L	D3,D4	CALL	_1CONVOBJDRAW	; D3 <- position [scr]	JUMP',NE EXIT$	EX.L	D4,D3	CALL	_1CONVOBJDRAW	; D4 <- position [scr]	JUMP',NE EXIT$	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LIB	?DRSEG		; passe par $DIS pour laisser la sourisEXIT$:	POPM.L	D3,D4	RET;--------\\; DRTRAME >;========/; Dessine une trame rectangulaire.; in	D3.L	dpart (y;x);	D4.L	arrive (y;x);	D2.W	mode de dessin; out	-; mod	D7.WDRTRAME:	PUSHM.L	D3,D4	EX.L	D3,D4	CALL	_1CONVOBJDRAW	; D3 <- position [scr]	JUMP',NE EXIT$	EX.L	D4,D3	CALL	_1CONVOBJDRAW	; D4 <- position [scr]	JUMP',NE EXIT$	SUB.W	D4,D3	JUMP',EQ EXIT$	JUMP',NC OKX$	NEG.W	D4	SUB.W	D3,D4OKX$:	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	JUMP',EQ EXIT$	JUMP',NC OKY$	NEG.W	D4	SUB.W	D3,D4OKY$:	SWAP.W	D3	SWAP.W	D4	LIB	?DRTRAME	; passe par $DIS pour laisser la sourisEXIT$:	POPM.L	D3,D4	RET;--------\\; DRCROIX >;========/; Dessine une croix (+).; in	D3.L	centre (y;x);	D4.W	demi-longueur [scr];		 si 2^15 = 1 --> cercle en plus;	D2.W	mode de dessin; out	-; mod	D7.WDRCROIX:	PUSHM.L	D0..D4,A1,A2	CALL	_1CCMO		; enlve la souris	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.W	D1,D2		; D1 <-- mode	LOAD.W	D2,D4		; D2 <-- longueur	TCLR.L	D2:#15	LOAD.W	D0,D4		; D0 <-- bit pour cercle	LOAD.L	D4,D3	CALL	_1CONVOBJDRAW	; D4 <- position [scr]	JUMP,NE EXIT$	LOAD.L	D3,D4	SUB.W	D3,D2	ADD.W	D4,D2	PUSHM.L	D3,D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	EX.L	D3,D4	LOAD.L	A1,(A6)+OLINE	CALL	(A1)		; GRA2_LINE, dessine une ligne	POPM.L	D3,D4	SUB.W	D4,D2	LOAD.L	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D2	ADD.W	D4,D2	SWAP.W	D4	SWAP.W	D3	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	EX.L	D3,D4;	LOAD.L	A1,(A6)+OLINE	CALL	(A1)		; GRA2_LINE, dessine une ligne	TEST.L	D0:#15	JUMP',BC EXIT$	SWAP.W	D4	ADD.W	D4,D2	SWAP.W	D4	LOAD.W	D3,D2	SR.W	D3,#1		; D3 <-- rayon (=1/2 longueur)	LOAD.W	D2,#-1		; D2 <-- tous les octants	LOAD.L	A1,(A6)+OCIRC	CALL	(A1)		; GRA2_CIRCLE, dessine un cercleEXIT$:	POPM.L	D0..D4,A1,A2	RET;---------\\; DRCIRCLE >;=========/; Dessine un cercle.; in	D3.L	centre (y;x);	D4.W	rayon (r);	D2.W	mode de dessin; out	-; mod	D7.WDRCIRCLE:	PUSHM.L	D1..D4,A1,A2	CALL	_1CCMO		; enlve la souris	EX.L	D3,D4	CALL	_1CONVOBJDRAW	; D3 <- position [scr]	JUMP',NE EXIT$	EX.L	D4,D3	CALL	_1SCALEP		; D4 <- rayon [scr]	JUMP',NE EXIT$	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	EX.L	D3,D4	LOAD.W	D1,D2		; D1 <-- mode de dessin	LOAD.W	D2,#-1		; D2 <-- tous les octants	LOAD.L	A1,(A6)+OCIRC	CALL	(A1)		; GRA2_CIRCLE, dessine un cercleEXIT$:	POPM.L	D1..D4,A1,A2	RET;-----------\\; DRPOLYOPEN >;===========/; Dbute le dessin d'un polygone rempli.; in	-; out	D7.W	erreur; mod	D7.WDRPOLYOPEN:	PUSHM.L	D3,A2	TEST.B	(A6)+OIFPPS	; impression PostScript en cours ?	JUMP',T	PPS$		; oui => PPS$	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.L	SP,#(SP)-(8+2)	; rserve place pour cliprect+erreur	LOAD.L	D3,(A2)+ODFFY	LOAD.L	(SP)+2,D3	ADD.W	D3,(A2)+ODFFDX	SWAP.W	D3	ADD.W	D3,(A2)+ODFFDY	SWAP.W	D3	LOAD.L	(SP)+2+4,D3	PUSH.L	(A6)+ORGNID	; stack <-- ^identificateur rgion	PUSH.W	#GFILLXOR+GFILLINTERIOR ; stack <-- mode	PUSH.L	#(SP)+2+4+2	; stack <-- ^cliprect	GMI_	OPENRGN	POP.W	D7		; D7 <-- erreur	ADD.L	SP,#8		; SP <-- reprend place pour cliprect	JUMP'	EXIT$PPS$:	LOAD.L	A2,(A6)+OCAPAGEPS	PPS_	DRPOLYOPEN;	JUMP'	EXIT$EXIT$:	POPM.L	D3,A2;	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DRPOLYLINE >;===========/; Dfini une nouvelle ligne d'un polygone rempli.; in	D3.L	dpart (y;x);	D4.L	arrive (y;x); out	D7.W	erreur; mod	D7.WDRPOLYLINE:	PUSHM.L	D3,D4,A2,A5	TEST.B	(A6)+OIFPPS	; impression PostScript en cours ?	JUMP,T	PPS$		; oui => PPS$	TEST.L	(A6)+OBMABS	; bitmap existe ?	JUMP',EQ DRAW$		; non => DRAW$	CALL	DRBMBBOXQ	; bitmap <-- indique o l'on va dessinerDRAW$:	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	EX.L	D3,D4	CALL	_1CONVOBJDRAW	; D3 <- position [scr]	JUMP',NE EXIT$	EX.L	D4,D3	CALL	_1CONVOBJDRAW	; D4 <- position [scr]	JUMP',NE EXIT$	ADD.W	D3,(A2)+ODFFX	SWAP.W	D3	ADD.W	D3,(A2)+ODFFY	SWAP.W	D3	ADD.W	D4,(A2)+ODFFX	SWAP.W	D4	ADD.W	D4,(A2)+ODFFY	SWAP.W	D4	SUB.L	SP,#2	PUSH.L	(A6)+ORGNID	PUSH.L	D3	PUSH.L	D4	GMI_	PUTLINE	POP.W	D7	JUMP'	EXIT$PPS$:	LOAD.L	A2,(A6)+OCAPAGEPS	PPS_	DRPOLYLINE;	JUMP'	EXIT$EXIT$:	POPM.L	D3,D4,A2,A5	TEST.W	D7		; retour EQ/NE	RET;------------\\; DRPOLYCLOSE >;============/; Dessine le polygone rempli dfini.; in	D2.W	mode de dessin; out	D7.W	erreur; mod	D7.WDRPOLYCLOSE:	PUSHM.L	D0..D4,A1..A4	TEST.B	(A6)+OIFPPS	; impression PostScript en cours ?	JUMP',T	PPS$		; oui => PPS$	TEST.L	(A6)+OBMABS	; bitmap existe ?	JUMP',NE DRAW$		; oui => DRAW$	CALL	_1CCMO		; non => enlve la sourisDRAW$:	SUB.L	SP,#2	PUSH.L	(A6)+ORGNID	GMI_	CLOSERGN	POP.W	D7	JUMP',NE EXIT$	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.L	(A2)+ODFCRG,(A6)+ORGNID	LOAD.L	A4,#(A2)+ODFTRA	; A4 <-- ^trame utilisateur	CLR.L	D4	LOAD.L	D3,(A2)+ODFFDY	LOAD.W	D1,D2		; D1 <-- mode de dessin	LOAD.L	A1,(A6)+OTRAME	CALL	(A1)		; GRA2_TRAME, dessine la trame	CLR.L	(A2)+ODFCRG	JUMP'	EXIT$PPS$:	LOAD.W	D0,#IDENTTRAME	LOAD.W	D1,#opDGETUSE	CALL	_1OBJCALL	; D3 <-- trame utilise	LOAD.W	D1,D3		; D1 <-- trame utilise	LOAD.L	A2,(A6)+OCAPAGEPS	PPS_	DRPOLYCLOSE;	JUMP'	EXIT$EXIT$:	POPM.L	D0..D4,A1..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DRCOLORDEF >;===========/; Initialise les couleurs par dfaut.; in	-; out	-; mod	D7.WDRCOLORDEF:	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE INIT$		; oui => INIT$	RETINIT$:	PUSH.L	D4	LOAD.L	D4,#H'10000*COLORFDRAW+COLORCDRAW	CALL'	DRCOLORINIT	POP.L	D4	RET;------------\\; DRCOLORINIT >;============/; Initialise les couleurs pour dessiner.; in	D4.L	couleurs relatives (clr,set); out	-; mod	D7.WDRCOLORINIT:	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE INIT$		; oui => INIT$	RETINIT$:	PUSHM.L	D3,D4,A3	LOAD.L	A3,#(A6)+OBUDIS	CLR.W	D3	TEST.W	D4	JUMP',EQ SR$	COMP.W	D4,#-1	JUMP',NE SRF$	LOAD.W	D4,#COLORFPAGESRF$:	LOAD.W	(A3+),#COLORSR	CLR.W	(A3+)	LOAD.W	(A3+),D4	ADD.W	D3,#6SR$:	SWAP.W	D4	TEST.W	D4	JUMP',EQ CR$	COMP.W	D4,#-1	JUMP',NE CRF$	LOAD.W	D4,#COLORFPAGECRF$:	LOAD.W	(A3+),#COLORCR	CLR.W	(A3+)	LOAD.W	(A3+),D4	ADD.W	D3,#6CR$:	TEST.W	D3	JUMP',EQ EXIT$	LOAD.L	A3,#(A6)+OBUDIS	LIB	?STRING		; spcifie les couleursEXIT$:	POPM.L	D3,D4,A3	RET;------------\\; DRCOLORCONV >;============/; Conversion d'une couleur absolue (RGB) en une couleur; de la palette (0..15 sur SMAKY-300).; in	A4.L	^couleur RGB; out	D4.L	couleur de la palette (0..15);	D7.W	erreur; mod	D4.L, D7.WDRCOLORCONV:	PUSHM.L	D2,D3,D6,A3	TEST.B	(A6)+OIFPRI	; impression en cours ?	JUMP',T PRINT$		; oui => PRINT$DIS$:	LOAD.L	D6,(A0)+ODFCPF	; D6 <-- canal pour TCOLOR	CLR.L	D3		; D3 <-- mode	TCOL_	SRCCLUT		; D4 <-- couleur de la palette	JUMP	EXIT$PRINT$:	LOAD.L	D4,(A6)+OPRINT	; D4 <-- mode d'impression	TEST.L	D4:#BPRIQB	JUMP,BS BLACK$	LOAD.W	D2,#0		; D2 <-- offset pour rouge	TEST.L	D4:#BPRIQC	JUMP',BS CMY$	LOAD.W	D2,#2		; D2 <-- offset pour vert	TEST.L	D4:#BPRIQM	JUMP',BS CMY$	LOAD.W	D2,#4		; D2 <-- offset pour bleu	TEST.L	D4:#BPRIQY	JUMP,BC DIS$CMY$:	CLR.L	D4		; D4 <-- blanc	LOAD.W	D3,(A4)+0	COMP.W	D3,(A4)+2	JUMP',NE CCOL$	COMP.W	D3,(A4)+4	; couleur grise ?	JUMP,EQ EXIT$		; oui => EXIT$ (blanc)CCOL$:	LOAD.W	D4,(A4)+(D2.W)	; D4 <-- rouge, vert ou bleu	SR.W	D4,#8		; D4 <-- 0..255	SUB.W	D4,#255	NEG.W	D4		; D4 <-- 255..0	MUL.WU	D4,(A0)+ODFCNB	; D4 <-- *16	SR.L	D4,#8		; D4 <-- /256	JUMP	EXIT$BLACK$:	LOAD.W	D4,(A4)+0	COMP.W	D4,(A4)+2	JUMP',NE BCOL$	COMP.W	D4,(A4)+4	; couleur grise ?	JUMP',NE BCOL$	SR.W	D4,#8		; D4 <-- 0..255	JUMP'	BPUT$BCOL$:	SUB.L	SP,#6	LOAD.L	A3,SP		; A3 <-- ^p'tit buffer sur le stack	ICOL_	RGBHSV		; buffer <-- couleur HSV	LOAD.W	D4,(A3)+4	; D4 <-- intensit (0..255)	ADD.L	SP,#6BPUT$:	SUB.W	D4,#255	NEG.W	D4		; D4 <-- 255..0	MUL.WU	D4,(A0)+ODFCNB	; D4 <-- *16	SR.L	D4,#8		; D4 <-- /256;	JUMP'	EXIT$EXIT$:	POPM.L	D2,D3,D6,A3	TEST.W	D7		; retour EQ/NE	RET;-------------\\; DRBMOPENMODE >;=============/; Spcifie le mode d'ouverture du bitmap.; A utiliser avant BMOPEN* !; in	D4.L	mode d'ouverture;		 :#0 -> couleur; out	-; mod	D7.WDRBMOPENMODE:	PUSH.L	D4	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',NE INIT$		; oui => INIT$	TCLR.L	D4:#0		; D4 <-- couleur impossibleINIT$:	LOAD.L	(A6)+OBMMODE,D4	POP.L	D4	CLR.W	D7		; retour EQ	RET;---------\\; DRBMOPEN >;=========/; Dbut du dessin dans un bitmap pour l'objet slectionn.; in	-; out	D7.W	erreur; mod	D7.WDRBMOPEN:	PUSHM.L	D3,D4,A4	LOAD.L	A4,(A6)+OSELPS	; A4 <-- ^objet slection	CALL	_1LSTA_BBOX	; D3/D4 <-- bbox absolue	CALL	WDOSAV		; sauve les dfinitions de la fentre	CALL'	DRBMOPENQQ	POPM.L	D3,D4,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; DRBMOPENDIM >;============/; Dbut du dessin dans un bitmap pour un objet quelconque.; in	D3.L	P1 (y;x)  [obj];	D4.L	P2 (y;x)  [obj]; out	D7.W	erreur; mod	D7.WDRBMOPENDIM:	CALL	WDOSAV		; sauve les dfinitions de la fentre	JUMP'	DRBMOPENQQ;------------\\; DRBMOPENPLY >;============/; Dbut du dessin dans un bitmap pour un objet quelconque.; Permet de dessiner jusqu'en haut de la fentre (pour les rgles).; in	D3.L	P1 (y;x)  [obj];	D4.L	P2 (y;x)  [obj]; out	D7.W	erreur; mod	D7.WDRBMOPENPLY:	CALL	WDOSAV		; sauve les dfinitions de la fentre	CALL	WDOPLUSY	; permet de dessiner jusqu'en haut;	JUMP'	DRBMOPENQQ;-----------\\; DRBMOPENQQ >;-----------/; Dbut du dessin dans un bitmap pour un objet quelconque.; in	D3.L	P1 (y;x)  [obj];	D4.L	P2 (y;x)  [obj]; out	D7.W	erreur; mod	D7.WDRBMOPENQQ:	PUSHM.L	D1..D4,A2,A4	CALL	WDODEF		; dimensione la fentre selon objet	JUMP,NE ERROR2$	CALL	WDOOPEN2	; dessine dans la swdo	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.W	D4,(A2)+ODFFDX	ADD.W	D4,#16-1	SR.W	D4,#4	SL.W	D4,#1	TEST.B	(A6)+OBMMODE+3:#0 ; bitmap couleur ?	JUMP',BC GETMEM$	CLR.W	D3	LOAD.B	D3,(A2)+ODFCNP	; D3 <-- nb de bits/pixel (1,4)	MUL.WU	D4,D3GETMEM$:	LOAD.W	D2,D4		; D2 <-- Iy	MUL.WU	D4,(A2)+ODFFDY	ADD.L	D4,#32	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- demande mmoire pour le bitmap	JUMP,NE ERROR1$	LOAD.L	(A6)+OBMABS,(A2)+ODFABS	LOAD.L	(A6)+OBMY,(A2)+ODFY	LOAD.L	(A6)+OBMDY,(A2)+ODFDY	LOAD.L	(A6)+OBMFY,(A2)+ODFFY	LOAD.L	(A6)+OBMFDY,(A2)+ODFFDY	LOAD.W	(A6)+OBMIIY,(A2)+ODFIIY	LOAD.B	(A6)+OBMCMD,(A2)+ODFCMD	TEST.B	(A6)+OBMMODE+3:#0 ; bitmap couleur ?	JUMP',BC NOCOUL$	LOAD.B	(A2)+ODFCMD,#2	; ODFCMD <-- dessinne en mmoire en couleurNOCOUL$:	LOAD.L	(A2)+ODFABS,A4	; ODFABS <-- ^bitmap	CLR.L	(A2)+ODFY	CLR.L	(A2)+ODFFY	CLR.L	(A2)+ODFWBY	LOAD.L	D3,(A2)+ODFFDY	LOAD.L	(A2)+ODFDY,D3	LOAD.L	(A2)+ODFWEY,D3	LOAD.W	(A2)+ODFIIY,D2	; ODFIIY <-- largeur en bytes	SR.L	D4,#5		; D4 <-- /32 car 8x.L	DEC.W	D4		; D4 <-- -1 car NMO	CLR.L	D3CLEAR$:	LOAD.L	(A4+),D3	; efface tout le bitmap	LOAD.L	(A4+),D3	LOAD.L	(A4+),D3	LOAD.L	(A4+),D3	LOAD.L	(A4+),D3	LOAD.L	(A4+),D3	LOAD.L	(A4+),D3	LOAD.L	(A4+),D3	DECJ.W,NMO D4,CLEAR$	LOAD.L	(A6)+OBMBB1,#H'7FFF7FFF	LOAD.L	(A6)+OBMBB2,#H'80008000	JUMP'	EXIT$ERROR1$:	PUSH.W	D7	CALL	WDOCLOSE2	; fin du dessin dans la swdo	POP.W	D7ERROR2$:	CALL	WDOGET		; restitue les dfinitions de la fentreEXIT$:	CLR.L	(A6)+OBMMODE	; annule le mode (BMOPENMODE)	POPM.L	D1..D4,A2,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DRBMBBOX >;=========/; Indique o l'on dessine dans le bitmap.; in	D3.L	p1 (y;x)  [obj];	D4.L	p2 (y;x)  [obj]; out	-; mod	D7.WDRBMBBOX:	PUSHM.L	D1..D4	EX.L	D4,D3	CALL	_1CONVOBJDRAW	; D3 <- position [scr]	JUMP',NE EXIT$	EX.L	D3,D4	CALL	_1CONVOBJDRAW	; D4 <- position [scr]	JUMP',NE EXIT$	LOAD.L	D1,(A6)+OBMBB1	LOAD.L	D2,(A6)+OBMBB2	CALL	_1RECTOR		; D3/D4 <-- rectangle union	LOAD.L	(A6)+OBMBB1,D3	LOAD.L	(A6)+OBMBB2,D4EXIT$:	POPM.L	D1..D4	RET;----------\\; DRBMBBOXQ >;==========/; Indique o l'on dessine dans le bitmap.; in	D3.L	p1 (y;x)  [scr];	D4.L	p2 (y;x)  [scr]; out	-; mod	D7.WDRBMBBOXQ:	PUSHM.L	D1..D4	LOAD.L	D1,(A6)+OBMBB1	LOAD.L	D2,(A6)+OBMBB2	CALL	_1RECTOR		; D3/D4 <-- rectangle union	LOAD.L	(A6)+OBMBB1,D3	LOAD.L	(A6)+OBMBB2,D4	POPM.L	D1..D4	RET;-----------\\; DRBMUPDALL >;===========/; Indique qu'il faudra tout mettre  jour le bitmap.; in	-; out	-; mod	D7.WDRBMUPDALL:	PUSH.L	A2	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	CLR.L	(A6)+OBMBB1	LOAD.L	(A6)+OBMBB2,(A2)+ODFFDY	POP.L	A2	RET;----------\\; DRBMCLOSE >;==========/; Fin du dessin dans un bitmap.; in	-; out	-; mod	D7.WDRBMCLOSE:	PUSHM.L	D0..D5,A0..A4	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.L	A3,(A2)+ODFABS	; A3 <-- ^source (bitmap)	LOAD.L	D2,(A2)+ODFFDY	LOAD.W	D5,(A2)+ODFIIY	; D5 <-- Ix source	LOAD.B	D0,(A2)+ODFCMD	; D0 <-- mode (0,1,2)	LOAD.L	(A2)+ODFABS,(A6)+OBMABS	LOAD.L	(A2)+ODFY,(A6)+OBMY	LOAD.L	(A2)+ODFDY,(A6)+OBMDY	LOAD.L	(A2)+ODFFY,(A6)+OBMFY	LOAD.L	(A2)+ODFFDY,(A6)+OBMFDY	LOAD.W	(A2)+ODFIIY,(A6)+OBMIIY	LOAD.B	(A2)+ODFCMD,(A6)+OBMCMD	LOAD.L	D3,(A2)+ODFFY	LOAD.L	D4,(A2)+ODFFDY	LOAD.L	A0,A2		; A0 <-- ^descripteur de la fentre	CALL	GRADIMWDO	; dimensionne swdo	COMP.L	(A6)+OBMBB1,#H'7FFF7FFF	JUMP',NE DRAW$	COMP.L	(A6)+OBMBB2,#H'80008000	JUMP',EQ FLUSH$DRAW$:	CALL	_1CCMO		; enlve la souris	CLR.L	D1	LOAD.L	D3,(A6)+OBMBB1	; D3 <-- p1 o dessin	LOAD.L	D4,(A6)+OBMBB2	; D4 <-- p2 o dessin	CALL	_1RECTAND	; D3/D4 <-- rectangle dans la swdo	LOAD.L	D2,D4		; D3 <-- position source	SUB.W	D2,D3	JUMP',EQ FLUSH$	SWAP.W	D2	SWAP.W	D3	SUB.W	D2,D3		; D2 <-- dimensions	JUMP',EQ FLUSH$	SWAP.W	D2	SWAP.W	D3	LOAD.L	D4,D3		; D4 <-- position destination	LOAD.L	A4,#0		; A4 <-- ^destination (dans l'cran)	COMP.B	D0,#2		; bitmap couleur ?	JUMP',EQ COLOR$		; oui => COLOR$	LOAD.W	D1,#LOADDOT	; D1 <-- mode;	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+ORASTER	CALL	(A1)		; GRA_RASTER, dessine le bitmap	JUMP'	FLUSH$COLOR$:	LOAD.W	D1,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL;	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OCRASTER	CALL	(A1)		; GRA_CRASTER, dessine le bitmapFLUSH$:	LOAD.L	A4,A3	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le bitmap	CLR.L	(A6)+OBMABS	CALL	WDOCLOSE2	; fin du dessin dans la swdo	CALL	WDOGET		; restitue les dfinitions de la fentre	POPM.L	D0..D5,A0..A4	RET;------------\\; DRSCOPENPLY >;============/; Dbut du dessin dans l'cran pour un objet quelconque.; Permet de dessiner jusqu'en haut de la fentre (pour les rgles).; in	D3.L	P1 (y;x)  [obj];	D4.L	P2 (y;x)  [obj]; out	D7.W	erreur; mod	D7.WDRSCOPENPLY:	CALL	WDOSAV		; sauve les dfinitions de la fentre	CALL	WDOPLUSY	; permet de dessiner jusqu'en haut	CALL	WDODEF		; dimensione la fentre selon objet	JUMP',NE ERROR$	CALL	WDOOPEN2	; dessine dans la swdo	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$ERROR$:	CALL	WDOGET		; restitue les dfinitions de la fentreEXIT$:	TEST.W	D7		; retour EQ/NE	RET;----------\\; DRSCCLOSE >;==========/; Fin du dessin dans l'cran.; in	-; out	-; mod	D7.WDRSCCLOSE:	CALL	WDOCLOSE2	; fin du dessin dans la swdo	CALL	WDOGET		; restitue les dfinitions de la fentre	RET;------------\\; DRBMVISUPLY >;============/; Dplace P1/P2 pour les rendre visibles.; Est utilis pour que les rgles soient toujours visibles, en; haut de la fentre (dans le cadre et les informations).; in	D3.L	P1 (y;x)  [obj];	D4.L	P2 (y;x)  [obj]; out	D3.L	P1 (y;x)  [obj];	D4.L	P2 (y;x)  [obj]; mod	D3.L, D4.L, D7.WDRBMVISUPLY:	PUSH.L	D2	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,(A6)+ODESY1	SUB.W	D2,D4	JUMP',LE OK$	ADD.W	D3,D2		; D3 <-- descend P1(y)	ADD.W	D4,D2		; D4 <-- descend P2(y)OK$:	SWAP.W	D4	SWAP.W	D3	POP.L	D2	RET;---------\\; DRPUTICO >;=========/; Transfre une icne dans le gencar IPP21.; in	A4.L	^dx,dy,icne;	D3.W	code de l'icne (ICOUSER..127); out	-; mod	D7.WDRPUTICO:	PUSHM.L	D3,D4,A2..A4	LOAD.L	A3,(A6)+OPGICO	; A3 <-- ^gencar IPP21	LOAD.L	A2,A3		; A2 <-- ^gencar des icnes	MUL.WU	D3,(A3)+OGCMSB	ADD.L	D3,#OGCMAT	ADD.L	A2,D3		; A2 <-- ^bonne matrice	CLR.W	D3	LOAD.B	D3,(A4+)	; D3 <-- largeur	ADD.W	D3,#8-1	SR.W	D3,#3		; D3 <-- largeur en bytes	CLR.W	D4	LOAD.B	D4,(A4+)	; D4 <-- hauteur	COMP.W	D4,#GCICY	JUMP',LS LOOPY$	SUB.W	D4,#GCICY	SR.W	D4,#1	MUL.WU	D4,D3	ADD.L	A4,D4		; A4 <-- saute qq lignes	LOAD.W	D4,#GCICYLOOPY$:	PUSHM.L	D3,A2	CLR.L	(A2)LOOPX$:	LOAD.B	(A2+),(A4+)	; gencar <-- une ligne	DEC.W	D3	JUMP,NE LOOPX$	POPM.L	D3,A2	ADD.L	A2,#GCICX/8	; A2 <-- ^ligne suivante	DEC.W	D4	JUMP,NE LOOPY$	POPM.L	D3,D4,A2..A4	CLR.W	D7		; retour EQ	RET;-----------\\; GETOFTRAME >;===========/; Donne l'offset permettant de dessiner une trame.; in	-; out	D3.L	offset pour trame; mod	D3.L, D7.WGETOFTRAME:	PUSH.L	D4	LOAD.L	D4,(A6)+ODESY1	CALL	_1SCALEP	LOAD.L	D3,(A0)+ODFFY	SUB.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	POP.L	D4	CLR.W	D7		; retour EQ	RET;---------\\; CHGSCALE >;=========/; Modifie l'chelle courante.; in	D4.W	nouvelle chelle (1=100%); out	D4.W	ancienne chelle; mod	D4.L, D7.WCHGSCALE:	PUSH.L	D3	LOAD.W	D3,(A6)+OSCALE	; D3 <-- chelle	TEST.B	(A6)+OIFPRI	; impression en cours ?	JUMP',F	GET$		; non => GET$	TNOT.L	D3:#15GET$:	CLR.B	(A6)+OIFPRI	; pas d'impression	TEST.L	D4:#15	JUMP',BS NEG$	TEST.L	D4:#14	JUMP',BC NORM$	JUMP'	PRINT$NEG$:	TEST.L	D4:#14	JUMP',BS NORM$PRINT$:	TNOT.L	D4:#15	SET.B	(A6)+OIFPRI	; impression en coursNORM$:	COMP.W	D4,#1	JUMP',NE PUT$	LOAD.W	D4,(A6)+OSCA100PUT$:	LOAD.W	(A6)+OSCALE,D4	LOAD.W	D4,D3		; D4 <-- ancienne	POP.L	D3	CLR.W	D7		; retour EQ	RET;---------\\; GETSCALE >;=========/; Donne l'chelle courante.; in	-; out	D4.W	chelle; mod	D4.L, D7.WGETSCALE:	LOAD.W	D4,(A6)+OSCALE	; D4 <-- chelle	TEST.B	(A6)+OIFPRI	; impression en cours ?	JUMP',F	EXIT$		; non => EXIT$	TNOT.L	D4:#15EXIT$:	CLR.W	D7		; retour EQ	RET;---------\\; PUTSCALE >;=========/; Modifie l'chelle courante.; in	D4.W	nouvelle chelle (1=100%); out	-; mod	D7.WPUTSCALE:	PUSH.W	D4	CLR.B	(A6)+OIFPRI	; pas d'impression	TEST.L	D4:#15	JUMP',BS NEG$	TEST.L	D4:#14	JUMP',BC NORM$	JUMP'	PRINT$NEG$:	TEST.L	D4:#14	JUMP',BS NORM$PRINT$:	TNOT.L	D4:#15	SET.B	(A6)+OIFPRI	; impression en coursNORM$:	COMP.W	D4,#1	JUMP',NE PUT$	LOAD.W	D4,(A6)+OSCA100PUT$:	LOAD.W	(A6)+OSCALE,D4	POP.W	D4	CLR.W	D7		; retour EQ	RET;---------\\; WDOPLUSY >;=========/; Permet de dessiner jusqu'en haut de la fentre !; in	-; out	-; mod	D7.WWDOPLUSY:	PUSH.L	D4	LOAD.W	D4,(A6)+OWDOY1	CALL	_1SCALEN		; D4 <-- distance [obj]	SUB.W	(A6)+ODESY1,D4	CLR.W	(A6)+OWDOY1	POP.L	D4	RET;---------\\; WDOUOPEN >;=========/; Ouvre une fentre utilisateur en zro.; in	D3.L	P1 (y;x)  [scr];	D4.L	P2 (y;x)  [scr]; out	-; mod	D7.WWDOUOPEN:	PUSHM.L	D3,D4	CALL	WDOSAV		; sauve les dfinitions	CLR.L	(A6)+OAPOS	LOAD.L	(A6)+OWDOY1,D3	LOAD.L	(A6)+OWDOY2,D4	CLR.L	(A6)+ODESY1	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- dimensions [scr]	SWAP.W	D3	SWAP.W	D4	CALL	_1SCALEN		; D4 <-- dimensions [obj]	LOAD.L	(A6)+ODESY2,D4	CALL	WDOOPEN2	; ouvre une swdoEXIT$:	POPM.L	D3,D4	RET;----------\\; WDOUCLOSE >;==========/; Ferme une fentre utilisateur en zro.; in	-; out	-; mod	D7.WWDOUCLOSE:	CALL	WDOCLOSE2	; ferme swdo	CALL	WDOGET		; restitue les dfinitions	RET;--------\\; WDOSAV  >;========/; Sauve les dfinitions de la fentre.; in	-; out	-; mod	-WDOSAV:	PUSH.L	A4	LOAD.L	A4,#(A6)+OWCOPY	ADD.W	A4,(A6)+OWNCOPY	LOAD.L	(A4+),(A6)+ODESY1	LOAD.L	(A4+),(A6)+ODESY2	LOAD.L	(A4+),(A6)+OWDOY1	LOAD.L	(A4+),(A6)+OWDOY2	LOAD.L	(A4+),(A6)+OAPOS	ADD.W	(A6)+OWNCOPY,#4*5	POP.L	A4	RET;--------\\; WDOGET  >;========/; Restitue les dfinitions de la fentre.; in	-; out	-; mod	-WDOGET:	PUSH.L	A4	TEST.W	(A6)+OWNCOPY	JUMP',EQ EXIT$	SUB.W	(A6)+OWNCOPY,#4*5	LOAD.L	A4,#(A6)+OWCOPY	ADD.W	A4,(A6)+OWNCOPY	LOAD.L	(A6)+ODESY1,(A4+)	LOAD.L	(A6)+ODESY2,(A4+)	LOAD.L	(A6)+OWDOY1,(A4+)	LOAD.L	(A6)+OWDOY2,(A4+)	LOAD.L	(A6)+OAPOS,(A4+)EXIT$:	POP.L	A4	RET;--------\\; WDODEF  >;========/; Dfinit la fentre en fonction d'un rectangle.; in	D3.L	P1 (y;x)  [obj];	D4.L	P2 (y;x)  [obj]; out	D7.W	erreur; mod	D7.WWDODEF:	PUSHM.L	D1..D4	LOAD.L	D1,(A6)+ODESY1	LOAD.L	D2,(A6)+ODESY2	CALL	_1RECTAND	; D3/D4 <-- rectangle dans ODESY1/ODESY2;;?	LOAD.L	D2,D3	EX.L	D3,D4	CALL	_1RNDDPOSSCALE	; D3 <-- position arrondie (contre en bas)	EX.L	D4,D3;;?	ADD.W	D4,D2;;?	SUB.W	D4,D3;;?	SWAP.W	D2;;?	SWAP.W	D3;;?	SWAP.W	D4;;?	ADD.W	D4,D2;;?	SUB.W	D4,D3;;?	SWAP.W	D2;;?	SWAP.W	D3;;?	SWAP.W	D4	CALL	_1RNDUPOSSCALE	; D4 <-- position arrondie (contre en haut)	LOAD.L	D1,D3	LOAD.L	D2,D4	EX.L	D3,D4	CALL	_1CONVOBJSCR	EX.L	D4,D3	CALL	_1CONVOBJSCR	LOAD.W	D7,#1	COMP.W	D3,D4	JUMP',EQ EXIT$	SWAP.W	D3	SWAP.W	D4	COMP.W	D3,D4	JUMP',EQ EXIT$	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A6)+ODESY1,D1	LOAD.L	(A6)+ODESY2,D2	LOAD.L	D1,(A6)+OWDOY1	LOAD.L	D2,(A6)+OWDOY2	CALL	_1RECTAND	; D3/D4 <-- rectangle dans OWDOY1/OWDOY2	LOAD.L	(A6)+OWDOY1,D3	LOAD.L	(A6)+OWDOY2,D4	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WDOOPEN >;========/; Utilise la swdo de dessin, si ncessaire.; in	-; out	-; mod	D7.WWDOOPEN:	INC.W	(A6)+OWUSE	COMP.W	(A6)+OWUSE,#1	JUMP',EQ WDOOPEN2	RETWDOOPEN2:	PUSHM.L	D3,D4,A0,A3	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre	LOAD.L	A3,#(A6)+OWTPD	; A3 <-- ^stack des positions/dimensions	LOAD.W	D3,(A6)+OWNPD	; D3 <-- "SP"	ADD.W	(A6)+OWNPD,#8	LOAD.L	(A3)+(D3.W)+0,(A0)+ODFFY	LOAD.L	(A3)+(D3.W)+4,(A0)+ODFFDY	LOAD.L	D3,(A6)+OWDOY1	; D3 <-- coin sup/gauche	LOAD.L	D4,(A6)+OWDOY2	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- dimensions	SWAP.W	D3	SWAP.W	D4	CALL	GRADIMWDO	; dimensionne swdo	POPM.L	D3,D4,A0,A3	RET;---------\\; WDOCLOSE >;=========/; Ferme la swdo de dessin, si ncessaire.; in	-; out	-; mod	D7.WWDOCLOSE:	DEC.W	(A6)+OWUSE	JUMP',EQ WDOCLOSE2	RETWDOCLOSE2:	PUSHM.L	D3,D4,A0,A3	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre	LOAD.L	A3,#(A6)+OWTPD	; A3 <-- ^stack des positions/dimensions	LOAD.W	D3,(A6)+OWNPD	; D3 <-- "SP"	JUMP',EQ EXIT$	SUB.W	D3,#8	LOAD.W	(A6)+OWNPD,D3	LOAD.L	D4,(A3)+(D3.W)+4 ; D4 <-- dimensions	LOAD.L	D3,(A3)+(D3.W)+0 ; D3 <-- position	CALL	GRADIMWDO	; dimensionne swdoEXIT$:	POPM.L	D3,D4,A0,A3	RET;----------\\; GRADIMWDO >;----------/; Dimensionne rapidement une swdo, sans passer par DIMWDO !; in	A0.L	^descripteur fentre;	D3.L	position (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WGRADIMWDO:	PUSH.L	D4	LOAD.L	(A0)+ODFFY,D3	LOAD.L	(A0)+ODFFDY,D4	LOAD.W	D4,(A0)+ODFX	ADD.W	D4,(A0)+ODFFX	LOAD.W	(A0)+ODFWBX,D4	; init min X	ADD.W	D4,(A0)+ODFFDX	LOAD.W	(A0)+ODFWEX,D4	; init max X	LOAD.W	D4,(A0)+ODFY	ADD.W	D4,(A0)+ODFFY	LOAD.W	(A0)+ODFWBY,D4	; init min Y	ADD.W	D4,(A0)+ODFFDY	LOAD.W	(A0)+ODFWEY,D4	; init max Y	POP.L	D4	RET;--------\\; ORDONNE >;========/; Ordonne P1 et P2 pour que P1 soit toujours en haut  gauche de P2.; in	D3/D4	P1/P2; out	D3/D4	P1/P2; mod	D3.L, D4.LORDONNE:	PUSH.W	D2	COMP.W	D3,D4	JUMP',LE NOEXX$	LOAD.W	D2,D3	LOAD.W	D3,D4		; EX.W D3,D4	LOAD.W	D4,D2NOEXX$:	SWAP.W	D3	SWAP.W	D4	COMP.W	D3,D4	JUMP',LE NOEXY$	LOAD.W	D2,D3	LOAD.W	D3,D4		; EX.W D3,D4	LOAD.W	D4,D2NOEXY$:	SWAP.W	D3	SWAP.W	D4	POP.W	D2	RET	.END