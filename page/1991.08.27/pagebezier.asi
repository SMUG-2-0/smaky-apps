	.SBTTL	PAGEBEZIER.ASI;---------\\; DRBEZIER >;=========/; Dessine une courbe de Bzier.; in	D3.L	P1 (y;x);	D4.L	C1 (y;x);	D5.L	C2 (y;x);	D6.L	P2 (y;x);	D2.W	mode de dessin; out	-; mod	D7.WDRBEZIER:	PUSHM.L	D0,D1,A2,A5	TEST.B	(A6)+OIFPPS	; impression PostScript en cours ?	JUMP',T	PPS$		; oui => PPS$	TEST.B	(A6)+OIFFRAG	; fragmentation en cours ?	JUMP',T	FRAG$		; oui => FRAG$	LOAD.W	(A6)+OBZMOD,D2	; OBZMOD <-- mode de dessin	LOAD.L	A5,#R16"DRBZLINE ; A5 <-- ^routine "line"	CALL	BZIDRAW		; dessine la courbe	JUMP'	EXIT$PPS$:	PUSH.L	D3	LOAD.W	D0,#IDENTPEN	LOAD.W	D1,#opDGETUSE	CALL	_2OBJCALL	; D3 <-- pinceau utilis	LOAD.W	D1,D3		; D1 <-- pinceau utilis	POP.L	D3	LOAD.L	A2,(A6)+OCAPAGEPS	PPS_	DRBEZIER	JUMP'	EXIT$FRAG$:	LOAD.W	D2,#2+4+4+4+4	; D2 <-- lg ncessaire	CALL	FRAGBUFF	; A2 <-- ^buffer	JUMP',NE EXIT$	LOAD.W	(A2+),#IDFRAGCURVE	LOAD.L	(A2+),D3	LOAD.L	(A2+),D4	LOAD.L	(A2+),D5	LOAD.L	(A2+),D6EXIT$:	POPM.L	D0,D1,A2,A5	RET;---------\\; DRBZLINE >;---------/; Trace une droite appartenant  une courbe de Bzier.; in	D0/D1	dpart  (x;y);	D2/D3	arrive (x;y); out	-; mod	D7.WDRBZLINE:	PUSHM.L	D2..D4	LOAD.L	D4,D3		; D4 <-- arrive (y)	SWAP.W	D2	LOAD.W	D4,D2		; D4 <-- arrive (x)	LOAD.L	D3,D1		; D3 <-- dpart (y)	SWAP.W	D0	LOAD.W	D3,D0		; D3 <-- dpart (x)	SWAP.W	D0	COMP.L	D3,D4		; dpart = arrive ?	JUMP',EQ EXIT$		; oui => EXIT$	LOAD.W	D2,(A6)+OBZMOD	; D2 <-- mode de dessin	CALL	DRLINE		; trace une ligne droite	COMP.W	D2,#INVDOT!TTTDOT ; traitill invers ?	JUMP',NE EXIT$		; non => EXIT$	TSET.B	(A6)+OBZMOD+1:#BNCTDOT ; plus de rz du traitillEXIT$:	POPM.L	D2..D4	RET;-------------\\; DRPOLYBEZIER >;=============/; Dfini une nouvelle courbe d'un polygone rempli.; in	D3.L	P1 (y;x);	D4.L	C1 (y;x);	D5.L	C2 (y;x);	D6.L	P2 (y;x); out	-; mod	D7.WDRPOLYBEZIER:	PUSHM.L	A2,A5	TEST.B	(A6)+OIFPPS	; impression PostScript en cours ?	JUMP',T	PPS$		; oui => PPS$	LOAD.L	A5,#R16"DRBZPOLYLINE ; A5 <-- ^routine "line"	CALL	BZIDRAW		; dessine la courbe	JUMP'	EXIT$PPS$:	LOAD.L	A2,(A6)+OCAPAGEPS	PPS_	DRPOLYBEZIER;	JUMP'	EXIT$EXIT$:	POPM.L	A2,A5	RET;-------------\\; DRBZPOLYLINE >;-------------/; Trace une droite appartenant  une courbe de Bzier.; in	D0/D1	dpart  (x;y);	D2/D3	arrive (x;y); out	-; mod	D7.WDRBZPOLYLINE:	PUSHM.L	D3,D4	LOAD.L	D4,D3		; D4 <-- arrive (y)	SWAP.W	D2	LOAD.W	D4,D2		; D4 <-- arrive (x)	SWAP.W	D2	LOAD.L	D3,D1		; D3 <-- dpart (y)	SWAP.W	D0	LOAD.W	D3,D0		; D3 <-- dpart (x)	SWAP.W	D0	COMP.L	D3,D4		; dpart = arrive ?	JUMP',EQ EXIT$		; oui => EXIT$	CALL	DRPOLYLINE	; trace une ligne droiteEXIT$:	POPM.L	D3,D4	RET;----------\\; DETBEZIER >;==========/; Dtection pour voir si la souris est sur une courbe de Bzier.; in	D2.W	marge de dtection (0..n);	D3.L	P1 (y;x);	D4.L	C1 (y;x);	D5.L	C2 (y;x);	D6.L	P2 (y;x);	D1.L	position de la souris (y;x); out	D7.W	erreur; mod	D7.WDETBEZIER:	PUSH.L	A5	LOAD.W	(A6)+OBZDMA,D2	; OBZDMA <-- marge	LOAD.L	(A6)+OBZDPM,D1	; OBZDPM <-- position de la souris	CLR.W	(A6)+OBZDNB	; OBZDNB <-- nb d'intersections	LOAD.L	A5,#R16"DETBZLINE ; A5 <-- ^routine "line"	CALL	BZIDRAW		; dessine la courbe	CLR.W	D7		; D7 <-- ok	TEST.W	(A6)+OBZDNB	; au moins une intersection ?	JUMP',NE EXIT$		; oui => EXIT$	LOAD.W	D7,#ERDIOUT	; D7 <-- en dehors de la droiteEXIT$:	POP.L	A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DETBZLINE >;----------/; Dtection pour voir si la souris est sur une droite d'une courbe de Bzier.; in	D0/D1	dpart  (x;y);	D2/D3	arrive (x;y); out	-; mod	D7.WDETBZLINE:	PUSHM.L	D2..D5	LOAD.L	D4,D3		; D4 <-- arrive (y)	SWAP.W	D2	LOAD.W	D4,D2		; D4 <-- arrive (x);	SWAP.W	D2	LOAD.L	D3,D1		; D3 <-- dpart (y)	SWAP.W	D0	LOAD.W	D3,D0		; D3 <-- dpart (x)	SWAP.W	D0	LOAD.W	D2,(A6)+OBZDMA	; D2 <-- marge	LOAD.L	D5,(A6)+OBZDPM	; D5 <-- position de la souris	CALL	_2DETLINE	; souris le long de la droite ?	JUMP',NE EXIT$	INC.W	(A6)+OBZDNB	; OBZDNB <-- une intersection de plusEXIT$:	POPM.L	D2..D5	RET;-----------\\; BBOXBEZIER >;===========/; Calcule la "bounding box" d'une courbe de Bzier.; in	D3.L	P1 (y;x);	D4.L	C1 (y;x);	D5.L	C2 (y;x);	D6.L	P2 (y;x); out	D3.L	P1 (y;x) coin sup/gauche;	D4.L	P2 (y;x) coin inf/droite; mod	D3.L, D4.L, D7.WBBOXBEZIER:	PUSH.L	A5	LOAD.L	(A6)+OBZBB1,#H'7FFF7FFF	LOAD.L	(A6)+OBZBB2,#H'80008000	LOAD.L	A5,#R16"BBOXBZLINE ; A5 <-- ^routine "line"	CALL	BZIDRAW		; dessine la courbe	LOAD.L	D3,(A6)+OBZBB1	LOAD.L	D4,(A6)+OBZBB2	POP.L	A5	RET;-----------\\; BBOXBZLINE >;-----------/; Calcule la "bounding box" d'une ligne d'une courbe de Bzier.; in	D0/D1	dpart  (x;y);	D2/D3	arrive (x;y); out	-; mod	D7.WBBOXBZLINE:	PUSHM.L	D1..D4	LOAD.L	D4,D3		; D4 <-- arrive (y)	SWAP.W	D2	LOAD.W	D4,D2		; D4 <-- arrive (x);	SWAP.W	D2	LOAD.L	D3,D1		; D3 <-- dpart (y)	SWAP.W	D0	LOAD.W	D3,D0		; D3 <-- dpart (x)	SWAP.W	D0	COMP.W	D3,D4	JUMP',LE BBOX1$	LOAD.W	D1,D3	LOAD.W	D3,D4	LOAD.W	D4,D1BBOX1$:	SWAP.W	D3	SWAP.W	D4	COMP.W	D3,D4	JUMP',LE BBOX2$	LOAD.W	D1,D3	LOAD.W	D3,D4	LOAD.W	D4,D1BBOX2$:	SWAP.W	D3	SWAP.W	D4	LOAD.L	D1,(A6)+OBZBB1	LOAD.L	D2,(A6)+OBZBB2	CALL	_2RECTOR	; D3/D4 <-- rectangle englobant	LOAD.L	(A6)+OBZBB1,D3	LOAD.L	(A6)+OBZBB2,D4	POPM.L	D1..D4	RET;--------\\; BZIDRAW >;========/; "Dessine" une courbe de bezier avec des nombres entiers.; in	D3.L	P1 (y;x);	D4.L	C1 (y;x);	D5.L	C2 (y;x);	D6.L	P2 (y;x);	A5.L	^routine "line", voir (*); out	-; mod	D7.WBZIDRAW:	PUSHM.L	D0..D3,A4	COMP.L	D3,D4		; P1 = C1 ?	JUMP',NE CURVE$	COMP.L	D5,D6		; P2 = C2 ?	JUMP,EQ	LINE$CURVE$:	COMP.L	D3,D6		; P1 = P2 ?	JUMP,EQ EXIT$		; oui => EXIT$	SUB.L	SP,#LBZ	LOAD.L	A4,SP		; A4 <-- ^variables sur le stack	LOAD.W	(A4)+OBZP1X+0,D3	SWAP.W	D3	LOAD.W	(A4)+OBZP1Y+0,D3	SWAP.W	D3	LOAD.W	(A4)+OBZC1X+0,D4	SWAP.W	D4	LOAD.W	(A4)+OBZC1Y+0,D4	SWAP.W	D4	LOAD.W	(A4)+OBZC2X+0,D5	SWAP.W	D5	LOAD.W	(A4)+OBZC2Y+0,D5	SWAP.W	D5	LOAD.W	(A4)+OBZP2X+0,D6	SWAP.W	D6	LOAD.W	(A4)+OBZP2Y+0,D6	SWAP.W	D6	LOAD.W	D3,#CHOUIA05	; D3 <-- p'tit chouia (0.5)	LOAD.W	(A4)+OBZP1X+2,D3	LOAD.W	(A4)+OBZP1Y+2,D3	LOAD.W	(A4)+OBZC1X+2,D3	LOAD.W	(A4)+OBZC1Y+2,D3	LOAD.W	(A4)+OBZC2X+2,D3	LOAD.W	(A4)+OBZC2Y+2,D3	LOAD.W	(A4)+OBZP2X+2,D3	LOAD.W	(A4)+OBZP2Y+2,D3	CALL	BZRDRAW		; "dessine" la courbe	ADD.L	SP,#LBZ	JUMP'	EXIT$LINE$:	LOAD.W	D0,D3	SWAP.W	D0	LOAD.W	D0,#CHOUIA05	LOAD.L	D1,D3	LOAD.W	D1,D0	LOAD.W	D2,D6	SWAP.W	D2	LOAD.W	D2,#CHOUIA05	LOAD.L	D3,D6	LOAD.W	D3,D0	CALL	(A5)		; "dessine" une droiteEXIT$:	POPM.L	D0..D3,A4	RET;--------\\; BZRDRAW >;========/; "Dessine" une courbe de bezier avec des nombres rels.; in	A4.L	^OBZxxx;	A5.L	^routine "line", voir (*); out	-; mod	D7.W; (*)	Routine "line" :; in	D0/D1	dpart  (x;y);	D2/D3	arrive (x;y); out	-; mod	D7.WBZRDRAW:	PUSHM.L	D0..D5; Calcule une valeur approximative correspondant ; la distance P1C1 + C1C2 + C2P2.	LOAD.L	D3,(A4)+OBZP1X	SUB.L	D3,(A4)+OBZC1X	JUMP',NC POS1$	NEG.L	D3POS1$:	LOAD.L	D4,D3	LOAD.L	D3,(A4)+OBZP1Y	SUB.L	D3,(A4)+OBZC1Y	JUMP',NC POS2$	NEG.L	D3POS2$:	ADD.L	D4,D3	LOAD.L	D3,(A4)+OBZC1X	SUB.L	D3,(A4)+OBZC2X	JUMP',NC POS3$	NEG.L	D3POS3$:	ADD.L	D4,D3	LOAD.L	D3,(A4)+OBZC1Y	SUB.L	D3,(A4)+OBZC2Y	JUMP',NC POS4$	NEG.L	D3POS4$:	ADD.L	D4,D3	LOAD.L	D3,(A4)+OBZC2X	SUB.L	D3,(A4)+OBZP2X	JUMP',NC POS5$	NEG.L	D3POS5$:	ADD.L	D4,D3	LOAD.L	D3,(A4)+OBZC2Y	SUB.L	D3,(A4)+OBZP2Y	JUMP',NC POS6$	NEG.L	D3POS6$:	ADD.L	D4,D3		; D4 <-- distance approximative	SWAP.W	D4	LOAD.W	D7,#MA_SCALEP	PAGE_	MATH		; D4 <-- distance selon chelle; Calcule l'incrment en fonction de la distance; approximative (totalement empyrique) !	LOAD.W	D5,#1	COMP.W	D4,#2560	JUMP',HS STEP$	LOAD.W	D5,#2	COMP.W	D4,#1280	JUMP',HS STEP$	LOAD.W	D5,#4	COMP.W	D4,#640	JUMP',HS STEP$	LOAD.W	D5,#8	COMP.W	D4,#320	JUMP',HS STEP$	LOAD.W	D5,#16	COMP.W	D4,#160	JUMP',HS STEP$	LOAD.W	D5,#32	COMP.W	D4,#80	JUMP',HS STEP$	LOAD.W	D5,#64STEP$:; Calcule tous les points de la courbe de bzier.	CLR.W	D4		; D4 <-- rang initial	LOAD.L	D0,(A4)+OBZP1X	LOAD.L	D1,(A4)+OBZP1Y	; D0/D1 <-- dpartLOOP$:	CALL	BZRPOINT	; D2/D3 <-- point	CALL	(A5)		; trace un segment de droite	LOAD.L	D0,D2	LOAD.L	D1,D3	ADD.W	D4,D5		; D4 <-- rang suivant	COMP.W	D4,#256		; a-t-on fini ?	JUMP,LS LOOP$		; non => LOOP$	POPM.L	D0..D5	RET;---------\\; BZRPOINT >;---------/; Calcule un point rel quelconque situ sur une courbe de bzier.; in	A4.L	^OBZxxx;	D4.W	rang (0..256); out	D2/D3	point (x;y); mod	D2.L, D3.L, D7.WBZRPOINT:	PUSHM.L	D0,D1,D4,A2,A3	LOAD.L	A3,#R16"BZTABLE$	LOAD.L	A2,A3	LOAD.W	D3,#256	SUB.W	D3,D4	SL.W	D4,#2	SL.W	D3,#2	ADD.W	A3,D4		; A3 <-- ^table, depuis le dbut	ADD.W	A2,D3		; A2 <-- ^table, depuis la fin	LOAD.L	D1,(A4)+OBZP1Y	CLR.L	D2	LOAD.W	D2,(A3)+0	SL.L	D2,#1	CALL	_1FIXMUL	; D0 <-- D1*D2	LOAD.L	D3,D0	LOAD.L	D1,(A4)+OBZC1Y	CLR.L	D2	LOAD.W	D2,(A3)+2	SL.L	D2,#1	CALL	_1FIXMUL	; D0 <-- D1*D2	ADD.L	D3,D0	LOAD.L	D1,(A4)+OBZC2Y	CLR.L	D2	LOAD.W	D2,(A2)+2	SL.L	D2,#1	CALL	_1FIXMUL	; D0 <-- D1*D2	ADD.L	D3,D0	LOAD.L	D1,(A4)+OBZP2Y	CLR.L	D2	LOAD.W	D2,(A2)+0	SL.L	D2,#1	CALL	_1FIXMUL	; D0 <-- D1*D2	ADD.L	D3,D0	LOAD.L	D1,(A4)+OBZP1X	CLR.L	D2	LOAD.W	D2,(A3)+0	SL.L	D2,#1	CALL	_1FIXMUL	; D0 <-- D1*D2	LOAD.L	D4,D0	LOAD.L	D1,(A4)+OBZC1X	CLR.L	D2	LOAD.W	D2,(A3)+2	SL.L	D2,#1	CALL	_1FIXMUL	; D0 <-- D1*D2	ADD.L	D4,D0	LOAD.L	D1,(A4)+OBZC2X	CLR.L	D2	LOAD.W	D2,(A2)+2	SL.L	D2,#1	CALL	_1FIXMUL	; D0 <-- D1*D2	ADD.L	D4,D0	LOAD.L	D1,(A4)+OBZP2X	CLR.L	D2	LOAD.W	D2,(A2)+0	SL.L	D2,#1	CALL	_1FIXMUL	; D0 <-- D1*D2	ADD.L	D4,D0	LOAD.L	D2,D4	POPM.L	D0,D1,D4,A2,A3	RET;	1re colonne:	((1-t)^3)*m;	2me colonne:	(3t*(1-t)^2)*m;	avec:		0 < t < 1;			m = (2^15)-1 = 32767BZTABLE$:	.W	32767	0	; t=0/256	.W	32385	381	; t=1/256	.W	32005	756	; t=2/256	.W	31628	1125	; ...	.W	31255	1488	.W	30884	1846	.W	30517	2197	.W	30152	2543	.W	29790	2883	.W	29431	3217	.W	29075	3546	.W	28722	3869	.W	28372	4186	.W	28024	4498	.W	27680	4804	.W	27338	5105	.W	26999	5400	.W	26663	5690	.W	26330	5974	.W	25999	6253	.W	25672	6527	.W	25347	6795	.W	25024	7058	.W	24705	7316	.W	24388	7569	.W	24074	7816	.W	23763	8059	.W	23454	8296	.W	23148	8528	.W	22845	8756	.W	22545	8978	.W	22247	9195	.W	21951	9408	.W	21659	9615	.W	21369	9818	.W	21081	10016	.W	20796	10209	.W	20514	10397	.W	20234	10581	.W	19957	10760	.W	19682	10935	.W	19410	11104	.W	19141	11270	.W	18874	11431	.W	18609	11587	.W	18347	11739	.W	18087	11886	.W	17830	12029	.W	17575	12168	.W	17323	12302	.W	17073	12432	.W	16826	12558	.W	16581	12679	.W	16338	12797	.W	16098	12910	.W	15860	13019	.W	15625	13125	.W	15391	13226	.W	15160	13323	.W	14932	13416	.W	14706	13505	.W	14482	13591	.W	14260	13672	.W	14041	13750	.W	13824	13824	.W	13609	13894	.W	13396	13960	.W	13186	14023	.W	12977	14082	.W	12771	14137	.W	12568	14189	.W	12366	14238	.W	12167	14283	.W	11969	14324	.W	11774	14362	.W	11581	14396	.W	11390	14428	.W	11201	14456	.W	11015	14480	.W	10830	14501	.W	10648	14520	.W	10467	14534	.W	10289	14546	.W	10112	14555	.W	9938	14560	.W	9766	14563	.W	9595	14562	.W	9427	14559	.W	9261	14553	.W	9096	14543	.W	8934	14531	.W	8773	14516	.W	8615	14498	.W	8458	14478	.W	8304	14454	.W	8151	14428	.W	8000	14400	.W	7851	14368	.W	7703	14334	.W	7558	14298	.W	7415	14259	.W	7273	14217	.W	7133	14174	.W	6995	14127	.W	6859	14079	.W	6724	14028	.W	6592	13974	.W	6461	13919	.W	6331	13861	.W	6204	13801	.W	6078	13738	.W	5954	13674	.W	5832	13608	.W	5711	13539	.W	5592	13469	.W	5475	13396	.W	5359	13321	.W	5245	13245	.W	5133	13167	.W	5022	13087	.W	4913	13005	.W	4805	12921	.W	4699	12835	.W	4595	12748	.W	4492	12659	.W	4391	12569	.W	4291	12477	.W	4193	12383	.W	4096	12288	.W	4001	12191	.W	3907	12093	.W	3815	11993	.W	3724	11892	.W	3634	11790