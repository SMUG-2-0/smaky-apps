	.SBTTL	OPARRMATRIX.ASI;--------\\; XopDUSE >;========/; Donne la liste des points pour une flche.; in	A0.L	canal;	A4.L	^table des flches/nil si par dfaut;	D2.L	mode de dessin;	D3.W	numro de la flche (si 2^15=1, pas de liste);	D4.L	dpart (y;x);	D5.L	arrive (y;x); out	A3.L	^liste des droites (Pd,Pa);	D3.W	nb de droites (1..n);	D4.L	pinceau;trame;	D7.W	erreur; mod	D3.L, D4.L, D7.W, A3.LXopDUSE:	PUSHM.L	D1,A4,A5	LOAD.L	A5,A0		; A5 <-- ^variables globales	COMP.L	A4,#0		; objet par dfaut ?	JUMP',NE NODEF$		; non => NODEF$	LOAD.L	A4,(A5)+OPDEF	; A4 <-- ^objet flche par dfautNODEF$:	LOAD.W	D1,D3	TCLR.L	D3:#15	MUL.WU	D3,#LDFLE	ADD.L	A4,D3		; A4 <-- ^flche	CLR.W	D3	TEST.L	D1:#15	JUMP',BS NOLIST$	LOAD.L	D3,D4		; D3 <-- dpart	LOAD.L	D4,D5		; D4 <-- arrive	LOAD.L	A3,#(A5)+OBUFP	; A3 <-- ^buffer des points	CALL	MAFLECHE	; OBUFP <-- pointsNOLIST$:	LOAD.W	D4,(A4)+OFLEPEN	; D4 <-- pinceau	SWAP.W	D4	LOAD.W	D4,(A4)+OFLETRA	; D4 <-- trame	CLR.W	D7		; D7 <-- ok	POPM.L	D1,A4,A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; PTDUSE  >;========/; Donne la liste des points pour une flche.; in	A4.L	^table des flches;	D3.W	numro de la flche;	D4.L	dpart (y;x);	D5.L	arrive (y;x); out	A3.L	^liste des droites (Pd,Pa);	D3.W	nb de droites (1..n);	D4.L	pinceau;trame;	D7.W	erreur; mod	D3.L, D4.L, D7.W, A3.LPTDUSE:	PUSHM.L	D2,A4	MUL.WU	D3,#LDFLE	ADD.L	A4,D3		; A4 <-- ^flche	LOAD.L	D3,D4		; D3 <-- dpart	LOAD.L	D4,D5		; D4 <-- arrive	LOAD.L	A3,#(A5)+OBUFP	; A3 <-- ^buffer des points	LOAD.L	D2,#2^BVUETRAME	CALL	MAFLECHE	; OBUFP <-- points	LOAD.W	D4,(A4)+OFLEPEN	; D4 <-- pinceau	SWAP.W	D4	LOAD.W	D4,(A4)+OFLETRA	; D4 <-- trame	CLR.W	D7		; D7 <-- ok	POPM.L	D2,A4	TEST.W	D7		; retour EQ/NE	RET	.END