	.SBTTL	OPIMAGIO.ASI;----------\\; IOIMALOAD >;==========/; Charge une image en mmoire.; in	A3.L	^nom de l'image;	A4.L	^objet image; out	A3.L	^en-tte + CLUT;	A4.L	^image;	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	A4.L, D7.W, A3.L, A4.LIOIMALOADSC:	TEST.B	(A4)+OOBFIM:#BIMSCAN	JUMP,BS IOIMASCANIOIMALOAD:	PUSHM.L	D0..D3,D6,A1,A2	LOAD.W	D7,#MI_WAITMOUSE	PAGE_	MISC		; souris: met le sablier	LOAD.W	D3,#2^BOPRD	; D3 <-- mode d'ouverture	FOS	?OPEN		; ouvre l'image	JUMP,NE EXIT$	LOAD.L	A4,#(A5)+OBHEAD	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE		; lit l'en-tte	JUMP',EQ HEAD$	PUSH.W	D7	FOS	?CLOSE	POP.W	D7	JUMP	EXIT$HEAD$:	LOAD.L	A2,A4		; A2 <-- ^en-tte lue dans OBHEAD;	LOAD.L	D4,#LGHIMA	ADD.L	D4,(A2)+OIMLGC	; D4 <-- place pour la CLUT	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour l'en-tte et la CLUT	JUMP,NE EXIT$	LOAD.L	A3,A4	LOAD.W	D4,#(LGHIMA/2)-1HXFER$:	LOAD.W	(A3+),(A2+)	; buffer <-- en-tte	DECJ.W,NMO D4,HXFER$	LOAD.L	A2,A4		; A2 <-- ^en-tte	LOAD.L	D4,(A2)+OIMLGC	; D4 <-- longueur de la CLUT	JUMP',EQ CLUT$	LOAD.L	A4,#(A2)+LGHIMA	FOS	?RDBYTE		; lit la CLUT	JUMP,NE CLOSE$CLUT$:	LOAD.W	D0,(A2)+OIMDLX	; D0 <-- largeur de l'image	LOAD.W	D1,(A2)+OIMDLY	; D1 <-- hauteur de l'image	CLR.W	D2	LOAD.B	D2,(A2)+OIMBIP	; D2 <-- nb de bits/pixel	LOAD.W	D4,D0	ADD.W	D4,#8-1	SR.W	D4,#3		; D4 <-- largeur en bytes	MUL.WU	D4,D2		; D4 <-- * nb bits/pixel	MUL.WU	D4,D1		; D4 <-- largeur*hauteur/8	ADD.L	D4,#IMLBUF	; D4 <-- rserve pour codage	PUSH.W	D1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour toute l'image	POPM.W	D1	JUMP,NE CLOSE$	LOAD.L	A1,#(A4)+IMLBUF	; A1 <-- ^image	LOAD.L	D4,(A2)+OIMNBB	; D4 <-- longueur  lire	TEST.B	(A2)+OIMCOD	; image code ?	JUMP',NE 30$		; oui => 30$				; non =>	LOAD.L	A4,A1	FOS	?RDBYTE		; lit toute l'image dcode	JUMP,NE GIVDATA$	JUMP'	35$30$:	FOS	?RDBYTE		; lit toute l'image code	JUMP',NE GIVDATA$	LOAD.L	A3,A1	CALL	DECOIMA		; dcode l'image ...	JUMP',NE GIVDATA$35$:	FOS	?CLOSE		; ferme l'image	JUMP',NE GIVHEAD$	LOAD.L	A3,A2		; A3 <-- ^en-tte	LOAD.L	A4,A1		; A4 <-- ^image	LOAD.W	D4,D1	SWAP.W	D4	LOAD.W	D4,D0		; D4 <-- dimensions de l'image	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$GIVDATA$:	PUSH.W	D7	LOAD.L	A4,#(A1)-IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'image	POP.W	D7CLOSE$:	PUSH.W	D7	FOS	?CLOSE		; ferme l'image	POP.W	D7GIVHEAD$:	PUSHM.L	D7,A4	LOAD.L	A4,A2	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend le buffer pour l'en-tte	POPM.L	D7,A4EXIT$:	POPM.L	D0..D3,D6,A1,A2	TEST.W	D7		; retour EQ/NE	RET;----------\\; IOIMABLOC >;==========/; Charge une image depuis le bloc-notes.; in	A4.L	^objet image; out	A3.L	^en-tte;	A4.L	^image;	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	A4.L, D7.W, A3.L, A4.LIOIMABLOC:	PUSHM.L	D0,D1,D3,A1,A2	LOAD.W	D7,#MI_WAITMOUSE	PAGE_	MISC		; souris: met le sablier	LOAD.L	D4,#LGHIMA	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour l'en-tte	JUMP,NE EXIT$	LOAD.L	A2,A4		; A2 <-- ^en-tte	LOAD.L	D3,#H'1000000*'I+H'10000*'M+H'100*'A+H'1*'G	BLOC_	RDOPEN		; ouvre le bloc-notes	JUMP,NE GIVHEAD$	LOAD.L	A4,A2	BLOC_	RDDATA		; lit l'en-tte	JUMP,NE CLOSE$	LOAD.W	D0,(A2)+OIMDLX	; D0 <-- largeur de l'image	LOAD.W	D1,(A2)+OIMDLY	; D1 <-- hauteur de l'image	LOAD.W	D4,D0	SR.W	D4,#3	MUL.WU	D4,D1		; D4 <-- largeur*hauteur/8	ADD.L	D4,#IMLBUF	; D4 <-- rserve pour codage	PUSH.W	D1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour toute l'image	POPM.W	D1	JUMP,NE CLOSE$	LOAD.L	A1,#(A4)+IMLBUF	; A1 <-- ^image	LOAD.L	D4,(A2)+OIMNBB	; D4 <-- longueur  lire	TEST.B	(A2)+OIMCOD	; image code ?	JUMP',NE 30$		; oui => 30$				; non =>	LOAD.L	A4,A1	BLOC_	RDDATA		; lit toute l'image dcode	JUMP,NE GIVDATA$	JUMP'	35$30$:	BLOC_	RDDATA		; lit toute l'image code	JUMP',NE GIVDATA$	LOAD.L	A3,A1	CALL	DECOIMA		; dcode l'image ...	JUMP',NE GIVDATA$35$:	BLOC_	RDCLOSE		; ferme le bloc-notes	JUMP',NE GIVHEAD$	LOAD.L	A3,A2		; A3 <-- ^en-tte	LOAD.L	A4,A1		; A4 <-- ^image	LOAD.W	D4,D1	SWAP.W	D4	LOAD.W	D4,D0		; D4 <-- dimensions de l'image	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$GIVDATA$:	PUSH.W	D7	LOAD.L	A4,#(A1)-IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'image	POP.W	D7CLOSE$:	PUSH.W	D7	BLOC_	RDCLOSE		; ferme le bloc-notes	POP.W	D7GIVHEAD$:	PUSHM.L	D7,A4	LOAD.L	A4,A2	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend le buffer pour l'en-tete	POPM.L	D7,A4EXIT$:	POPM.L	D0,D1,D3,A1,A2	TEST.W	D7		; retour EQ/NE	RET;----------\\; IOIMASCAN >;==========/; Scanne une image en mmoire.; in	-; out	A3.L	^en-tte;	A4.L	^image;	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	A4.L, D7.W, A3.L, A4.LIOIMASCAN:	PUSHM.L	D1..D3,D5,D6,A2	LOAD.W	D7,#ERKSTO	LOAD.L	D6,(A0)+OCASCAN	; D6 <-- canal SCAN	JUMP,EQ	EXIT9$		; scanner absent => EXIT9$	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX		; prpare l'ouverture de la DBOX	LIB	?GETWDO	LOAD.W	D1,D5		; D1 <-- swdo initiale	LIB	?GETDIM		; D4 <-- dimensions de tout l'cran	CLR.L	D3	LIB	?CREWDO	LIB	?USEWDO		; utilise tout l'cran	LOAD.B	D3,#SAVWDO	LIB	?AFCAR		; sauve tout l'cran	JUMP',NE SAVKO$	LOAD.L	D4,#-1		; D4 <-- dimensions maximales	CLR.L	D3		; D3 <-- mode	SCAN_	READ		; A4/D4/D5 <-- ^image/dimensions/iy ...	LOAD.L	A2,A4		; A2 <-- ^image	LOAD.L	D2,D4		; D2 <-- dimensions	LOAD.B	D3,#GETWDO	LIB	?AFCAR		; restitue tout l'cran	CLR.W	D7SAVKO$:	PUSHM.L	D5,D7	LIB	?GETWDO	EX.L	D5,D1	LIB	?USEWDO		; utilise la swdo initiale	LOAD.W	D5,D1	LIB	?KILWDO	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX		; prpare la fermeture de la DBOX	POPM.L	D5,D7	TEST.W	D7	JUMP,NE	EXIT8$	LOAD.W	D7,#ERKSTO	TEST.L	D2		; y a-t-il une image lue ?	JUMP,EQ	EXIT8$		; non => EXIT8$	LOAD.L	D4,#LGHIMA	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour l'en-tte	JUMP,NE EXIT8$	GESMEM	?CLEARMEM	LOAD.L	A3,A4		; A3 <-- ^en-tte	LOAD.B	(A3)+OIMTYP,#H'81;	LOAD.B	(A3)+OIMCOD,#H'00	LOAD.B	(A3)+OIMBIP,#H'01	LOAD.B	(A3)+OIMDIR,#H'02	ADD.W	D2,#16-1	AND.B	D2,#B'11110000	LOAD.W	(A3)+OIMDLX,D2	SWAP.W	D2	LOAD.W	(A3)+OIMDLY,D2	MUL.WU	D5,D2	LOAD.L	(A3)+OIMNBB,D5	LOAD.L	D4,D5	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande un buffer pour l'image	JUMP,NE EXIT7$	PUSH.L	A4XFER$:	LOAD.B	(A4+),(A2+)	DEC.L	D4	JUMP,NE	XFER$	POP.L	A4	LOAD.W	D4,(A3)+OIMDLY	SWAP.W	D4	LOAD.W	D4,(A3)+OIMDLX	; D4 <-- dimensions	JUMP'	EXIT8$EXIT7$:	PUSH.W	D7	LOAD.W	D1,#MTYPCP	LOAD.L	A4,A3	GESMEM	?GIVMEM		; libre l'en-tte	POP.W	D7EXIT8$:	PUSH.W	D7	SCAN_	RELEASE		; libre l'image lue	POP.W	D7EXIT9$:	POPM.L	D1..D3,D5,D6,A2	TEST.W	D7		; retour EQ/NE	RET;----------\\; IOIMAKILL >;==========/; Libre la mmoire d'une image.; in	A3.L	^en-tte;	A4.L	^image; out	-; mod	-IOIMAKILL:	PUSHM.L	D1,D7,A4	LOAD.L	A4,#(A4)-IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'image	LOAD.L	A4,A3;	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend la mmoire de l'en-tte	POPM.L	D1,D7,A4	RET;--------\\; AFIMAGE >;========/; Affiche une image.; in	A4.L	^objet;	D2.W	mode; out	-; mod	D7.WAFIMAGE:	PUSHM.L	D0..D6,A2..A4	CALL	CALCMATRICE	; calcule la matrice (D4 <-- coin sup/gauche)	JUMP,NE EXIT$	LOAD.L	A2,(A4)+OOBPET	; A2 <-- ^en-tte	CLR.W	D0	LOAD.B	D0,(A2)+OIMBIP	; D0 <-- nb de bits/pixel	COMP.W	D0,#1		; image couleur ?	JUMP',NE COLOR$		; oui => COLOR$	CLR.L	D3		; D3 <-- origine source	LOAD.W	D5,(A4)+OOBDMA+2	ADD.W	D5,#8-1	SR.W	D5,#3		; D5 <-- Iy source	LOAD.L	A3,(A4)+OOBPMA	; A3 <-- ^source (matrice stretche)	COMP.L	A3,#0	JUMP',NE PTS$	LOAD.L	A3,(A4)+OOBPIM	; A3 <-- ^source (image)PTS$:	LOAD.W	D1,D2		; D1 <-- mode	LOAD.L	D2,(A4)+OOBDMA	; D2 <-- dimensions (dy;dx)	CLR.L	D6	LOAD.L	A4,#0		; A4 <-- ^destination (cran)	LOAD.L	A2,A0		; A2 <-- ^descripteur fentre	GRA_	RASTER		; affiche l'image noir/blanc	JUMP'	OK$COLOR$:	CLR.L	D3		; D3 <-- origine source	LOAD.W	D5,(A4)+OOBDMA+2	ADD.W	D5,#8-1	SR.W	D5,#3	MUL.WU	D5,D0		; D5 <-- Iy source	LOAD.L	A3,(A4)+OOBPMA	; A3 <-- ^source (matrice stretche)	COMP.L	A3,#0	JUMP',EQ OK$	LOAD.W	D1,D2		; D1 <-- mode	OR.W	D1,#2^BSRCCOUL	LOAD.L	D2,(A4)+OOBDMA	; D2 <-- dimensions (dy;dx)	CLR.L	D6	LOAD.L	A4,#0		; A4 <-- ^destination (cran)	LOAD.L	A2,A0		; A2 <-- ^descripteur fentre	GRA_	CRASTER		; affiche l'image couleurOK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; CALCMATRICE >;------------/; Calcule la matrice stretche.; in	A4.L	^objet image; out	D4.L	coin sup/gauche (y;x)  [scr];	D7.W	erreur; mod	D4.L, D7.WCALCMATRICE:	PUSHM.L	D0..D3,A0,A3,A4	LOAD.W	D7,#1	TEST.L	(A4)+OOBPIM	; image existe ?	JUMP,EQ EXIT$		; non => EXIT$	CALL	XopGETBBOX	; D3/D4 <-- bounding bbox	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.L	D0,D3		; D0 <-- coin sup/gauche	LOAD.L	D2,D4		; D2 <-- coin inf/droite	TEST.L	(A4)+OOBPMA	; matrice existe ?	JUMP',EQ CREATE$	; non => CREATE$	LOAD.W	D7,#DR_GETSCALE	PAGE_	DRAW		; D4 <-- chelle actuelle	COMP.W	D4,(A4)+OOBSMA	; mme chelle ?	JUMP',NE CREATE$	; non => CREATE$	LOAD.W	D4,(A4)+OOBA	COMP.W	D4,(A4)+OOBAMA	; mme angle ?	JUMP',NE CREATE$	; non => CREATE$	CALL	CALCDIM		; D4 <-- dimensions de l'image	COMP.L	D4,(A4)+OOBDMA	; mmes dimensions ?	JUMP,EQ OK$		; oui => OK$CREATE$:	LOAD.L	A3,A4		; A3 <-- ^objet	TEST.L	(A3)+OOBPMA	JUMP',EQ NOREL$	LOAD.L	A4,(A3)+OOBPMA	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la matrice	CLR.L	(A3)+OOBPMANOREL$:	LOAD.L	A4,A3		; A4 <-- ^objet	CALL	CALCDIM		; D4 <-- dimensions de l'image	LOAD.L	(A3)+OOBDMA,D4	COMP.L	D4,(A3)+OOBDIM	; exactement les mmes dimensions ?	JUMP,EQ	OK$		; oui => OK$	ADD.W	D4,#8-1	SR.W	D4,#3	LOAD.L	D3,D4	SWAP.W	D3		; D3 <-- hauteur	INC.W	D3		; D3 <-- une ligne de rserve !	MUL.WU	D4,D3	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^nouvelle matrice	JUMP,NE EXIT$	GESMEM	?CLEARMEM	LOAD.L	(A3)+OOBPMA,A4	LOAD.L	A4,A3		; A4 <-- ^objet	LOAD.L	A0,#(A5)+OVARST	; A0 <-- ^variables pour "stretch"	LOAD.L	(A0)+OSTRSPT,(A4)+OOBPIM	LOAD.W	D4,(A4)+OOBDIM+2	ADD.W	D4,#8-1	SR.W	D4,#3	LOAD.W	(A0)+OSTRSDX,D4	CLR.L	(A0)+OSTRS0	LOAD.L	D4,(A4)+OOBDIM	DEC.W	D4		; D4 <-- -1 car OSTRS2 doit tre inclu !	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.L	(A0)+OSTRS2,D4	LOAD.L	(A0)+OSTRDPT,(A4)+OOBPMA	LOAD.W	D4,(A4)+OOBDMA+2	ADD.W	D4,#8-1	SR.W	D4,#3	LOAD.W	(A0)+OSTRDDX,D4	CALL	GETP1	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	LOAD.W	D7,#MA_SCALEP	PAGE_	MATH		; D4 <-- dimensions selon chelle	LOAD.L	(A0)+OSTRD0,D4	CALL	GETP2	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	LOAD.W	D7,#MA_SCALEP	PAGE_	MATH		; D4 <-- dimensions selon chelle	LOAD.L	(A0)+OSTRD1,D4	CALL	GETP3	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	LOAD.W	D7,#MA_SCALEP	PAGE_	MATH		; D4 <-- dimensions selon chelle	LOAD.L	(A0)+OSTRD2,D4	CALL	GETP4	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	LOAD.W	D7,#MA_SCALEP	PAGE_	MATH		; D4 <-- dimensions selon chelle	LOAD.L	(A0)+OSTRD3,D4	LOAD.W	(A0)+OSTRTYP,#1	; nouveau mode (OSTRD2 exclu)	ST_	RECT		; hop, vive les dformations ...	LOAD.W	D7,#DR_GETSCALE	PAGE_	DRAW		; D4 <-- chelle actuelle	LOAD.W	(A4)+OOBSMA,D4	; OOBSMA <-- chelle actuelle	LOAD.W	(A4)+OOBAMA,(A4)+OOBA ; OOBAMA <-- angle actuelOK$:	LOAD.L	D4,D0	LOAD.W	D7,#MA_OBJDRAW	PAGE_	MATH		; D4 <-- coin sup/gauche (y;x)	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D3,A0,A3,A4	TEST.W	D7		; retour EQ/NE	RET.IF 0	PUSHM.L	D0..D3,A0..A4	LOAD.L	A1,#0		; A1 <-- pas de bitmap couleur	LOAD.W	D7,#1	TEST.L	(A4)+OOBPIM	; image existe ?	JUMP,EQ EXIT$		; non => EXIT$	CALL	XopGETBBOX	; D3/D4 <-- bounding bbox	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.L	D0,D3		; D0 <-- coin sup/gauche	LOAD.L	D2,D4		; D2 <-- coin inf/droite	TEST.L	(A4)+OOBPMA	; matrice existe ?	JUMP',EQ CREATE$	; non => CREATE$	LOAD.W	D7,#DR_GETSCALE	PAGE_	DRAW		; D4 <-- chelle actuelle	COMP.W	D4,(A4)+OOBSMA	; mme chelle ?	JUMP',NE CREATE$	; non => CREATE$	LOAD.W	D4,(A4)+OOBA	COMP.W	D4,(A4)+OOBAMA	; mme angle ?	JUMP',NE CREATE$	; non => CREATE$	CALL	CALCDIM		; D4 <-- dimensions de l'image	COMP.L	D4,(A4)+OOBDMA	; mmes dimensions ?	JUMP,EQ OK$		; oui => OK$CREATE$:	LOAD.L	A2,(A4)+OOBPET	; A2 <-- ^en-tte	LOAD.L	A3,A4		; A3 <-- ^objet	TEST.L	(A3)+OOBPMA	JUMP',EQ NOREL$	LOAD.L	A4,(A3)+OOBPMA	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la matrice	CLR.L	(A3)+OOBPMANOREL$:	LOAD.L	A4,A3		; A4 <-- ^objet	CALL	CALCDIM		; D4 <-- dimensions de l'image	LOAD.L	(A3)+OOBDMA,D4	CLR.W	D2	LOAD.B	D2,(A2)+OIMBIP	; D2 <-- nb de bits/pixel	COMP.W	D2,#1		; image couleur ?	JUMP',NE GETMEM$	; oui => GETMEM$	COMP.L	D4,(A3)+OOBDIM	; exactement les mmes dimensions ?	JUMP,EQ	OK$		; oui => OK$GETMEM$:	ADD.W	D4,#8-1	SR.W	D4,#3	LOAD.L	D3,D4	SWAP.W	D3		; D3 <-- hauteur	INC.W	D3		; D3 <-- une ligne de rserve !	MUL.WU	D4,D2	MUL.WU	D4,D3	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^nouvelle matrice	JUMP,NE EXIT$	GESMEM	?CLEARMEM	LOAD.L	(A3)+OOBPMA,A4	COMP.W	D2,#1		; image couleur ?	JUMP,EQ STR$		; non => STR$	LOAD.W	D4,(A3)+OOBDIM+2	ADD.W	D4,#8-1	SR.W	D4,#3	MUL.WU	D4,D2	MUL.WU	D4,(A3)+OOBDIM+0	ADD.L	D4,#32	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^nouvelle matrice	JUMP,NE EXIT$	LOAD.L	A1,A4		; A1 <-- ^bitmap couleur	LOAD.L	A0,(A3)+OOBPIM	SR.L	D4,#2+3		; D4 <-- /32CXFER$:	LOAD.L	(A4+),(A0+)	; bitmap couleur <-- image	LOAD.L	(A4+),(A0+)	LOAD.L	(A4+),(A0+)	LOAD.L	(A4+),(A0+)	LOAD.L	(A4+),(A0+)	LOAD.L	(A4+),(A0+)	LOAD.L	(A4+),(A0+)	LOAD.L	(A4+),(A0+)	DEC.L	D4	JUMP,NE CXFER$	PUSHM.L	D2,D5,D6,A3	CLR.L	D3		; D3 <-- coin sup/gauche	LOAD.L	D4,(A3)+OOBDIM	; D4 <-- coin inf/droite	LOAD.W	D6,D2		; D6 <-- nb de bits/pixel	LOAD.W	D5,D4	ADD.W	D5,#8-1	SR.W	D5,#3	MUL.WU	D5,D6		; D5 <-- Iy	LOAD.L	A4,A1		; A4 <-- ^bitmap couleur	LOAD.L	A3,#(A2)+LGHIMA	; A3 <-- ^CLUT	LOAD.L	A0,(A5)+OPDDIS	; A0 <-- ^descripteur de fentre	CLR.L	D2		; D2 <-- mode	ICOL_	CONVC		; conversion des couleurs	POPM.L	D2,D5,D6,A3STR$:	LOAD.L	A4,A3		; A4 <-- ^objet	LOAD.L	A0,#(A5)+OVARST	; A0 <-- ^variables pour "stretch"	LOAD.L	(A0)+OSTRSPT,(A4)+OOBPIM	COMP.W	D2,#1	JUMP',EQ SPT$	LOAD.L	(A0)+OSTRSPT,A1SPT$:	LOAD.W	D4,(A4)+OOBDIM+2	ADD.W	D4,#8-1	SR.W	D4,#3	LOAD.W	(A0)+OSTRSDX,D4	CLR.L	(A0)+OSTRS0	LOAD.L	D4,(A4)+OOBDIM	DEC.W	D4		; D4 <-- -1 car OSTRS2 doit tre inclu !	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.L	(A0)+OSTRS2,D4	LOAD.L	(A0)+OSTRDPT,(A4)+OOBPMA	LOAD.W	D4,(A4)+OOBDMA+2	ADD.W	D4,#8-1	SR.W	D4,#3	MUL.WU	D4,D2	LOAD.W	(A0)+OSTRDDX,D4	CALL	GETP1	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	LOAD.W	D7,#MA_SCALEP	PAGE_	MATH		; D4 <-- dimensions selon chelle	LOAD.L	(A0)+OSTRD0,D4	CALL	GETP2	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	LOAD.W	D7,#MA_SCALEP	PAGE_	MATH		; D4 <-- dimensions selon chelle	LOAD.L	(A0)+OSTRD1,D4	CALL	GETP3	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	LOAD.W	D7,#MA_SCALEP	PAGE_	MATH		; D4 <-- dimensions selon chelle	LOAD.L	(A0)+OSTRD2,D4	CALL	GETP4	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	LOAD.W	D7,#MA_SCALEP	PAGE_	MATH		; D4 <-- dimensions selon chelle	LOAD.L	(A0)+OSTRD3,D4	LOAD.W	(A0)+OSTRTYP,#1	; nouveau mode (OSTRD2 exclu)	COMP.W	D2,#1	JUMP',EQ SGO$	LOAD.W	(A0)+OSTRTYP,#2	; nouveau mode couleur	LOAD.W	(A0)+OSTPIXEL,D2SGO$:	ST_	RECT		; hop, vive les dformations ...	LOAD.W	D7,#DR_GETSCALE	PAGE_	DRAW		; D4 <-- chelle actuelle	LOAD.W	(A4)+OOBSMA,D4	; OOBSMA <-- chelle actuelle	LOAD.W	(A4)+OOBAMA,(A4)+OOBA ; OOBAMA <-- angle actuelOK$:	LOAD.L	D4,D0	LOAD.W	D7,#MA_OBJDRAW	PAGE_	MATH		; D4 <-- coin sup/gauche (y;x)	CLR.W	D7		; D7 <-- ok	COMP.L	A1,#0		; bitmap couleur existe ?	JUMP',EQ EXIT$		; non => EXIT$	PUSH.W	D7	LOAD.L	A4,A1	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le bitmap couleur	POP.W	D7EXIT$:	POPM.L	D0..D3,A0..A4	TEST.W	D7		; retour EQ/NE	RET.ENDIF;--------\\; CALCDIM >;--------/; Calcule les dimensions de l'image.; in	D0.L	coin sup/gauche;	D2.L	coin inf/droite;	A4.L	^objet image; out	D4.L	dimensions (dy;dx); mod	D4.L, D7.WCALCDIM:	PUSHM.L	D3	LOAD.L	D4,D2	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	SUB.W	D4,D0	SWAP.W	D0	SWAP.W	D4	LOAD.W	D7,#MA_SCALEP	PAGE_	MATH		; D4 <-- dimensions selon chelle.IF 0	LOAD.W	D3,D4	MUL.WU	D3,#1000	DIV.WU	D3,(A4)+OOBDIM+2	COMP.W	D3,#1000-15	; admet un cart de +/-1.5%	JUMP',LO EXIT$	COMP.W	D3,#1000+15	JUMP',HS EXIT$	LOAD.L	D3,D4	SWAP.W	D3	MUL.WU	D3,#1000	DIV.WU	D3,(A4)+OOBDIM+0	COMP.W	D3,#1000-15	; admet un cart de +/-1.5%	JUMP',LO EXIT$	COMP.W	D3,#1000+15	JUMP',HS EXIT$	LOAD.L	D4,(A4)+OOBDIM	; D4 <-- dimensions exactes.ENDIFEXIT$:	POPM.L	D3	RET;--------\\; DECOIMA >;========/; Dcode une image.; in	A2.L	^en-tte;	A3.L	^buffer pour image dcode;	A4.L	^image code; out	D7.W; mod	D7.WDECOIMA:	PUSHM.L	D3,D4	PUSH.W	(A2)+OIMDLX	PUSH.B	(A2)+OIMBIP	CLR.W	D4	LOAD.B	D4,(A2)+OIMBIP	LOAD.W	D3,(A2)+OIMDLX	MUL.WU	D3,D4	LOAD.W	(A2)+OIMDLX,D3	LOAD.B	(A2)+OIMBIP,#1	GRA_	DECOIMA		; dcode l'image	POP.B	(A2)+OIMBIP	POP.W	(A2)+OIMDLX	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CODEIMA >;========/; Code une image.; in	A2.L	^en-tte;	A3.L	^image dcode;	A4.L	^buffer pour image code; out	D7.W	erreur; mod	D7.WCODEIMA:	PUSHM.L	D3,D4	PUSH.W	(A2)+OIMDLX	PUSH.B	(A2)+OIMBIP	CLR.W	D4	LOAD.B	D4,(A2)+OIMBIP	LOAD.W	D3,(A2)+OIMDLX	MUL.WU	D3,D4	LOAD.W	(A2)+OIMDLX,D3	LOAD.B	(A2)+OIMBIP,#1	GRA_	CODEIMA		; code l'image	POP.B	(A2)+OIMBIP	POP.W	(A2)+OIMDLX	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET	.END