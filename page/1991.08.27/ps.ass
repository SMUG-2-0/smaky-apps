	.TITLE	PS.ASSLBUNAME	=	50		; lg max d'un nom de fichierNBRX	=	10		; nb de rectangles en XNBRY	=	4		; nb de rectangles en Y; Caractre; ---------NBCAR	=	16		; nb de caractres; Descripteur d'un caractre; --------------------------	.PC	PCVAR	.LOC	0OCARNM:	.BLKB	16		; nom de la fonctionOCARDE:	.BLKB	ldgbm		; descripteur du gencar bitmapOCARPL:	.BLKB	4		; ^chasse,xmin,ymin,xmax,ymax [obj]OCARH1:	.BLKB	2		; h1 [obj]OCARH2:	.BLKB	2		; h2 [obj]OCARIL:	.BLKB	2		; interligne [obj]	.BLKB	22		; rserveLDCAR:; Descripteur d'une table des caractres; --------------------------------------	.PC	PCVAR	.LOC	0OTACLST:.BLKB	LDCAR*NBCAR	; liste des caractresOTACSEL:.BLKB	2		; caractre slectionnOTACFAN:.BLKB	4		; fanions BFANAFF	=  0		;  afficheLTACIO:OTACNAM:.BLKB	LBUNAME		; nom du fichier des caractresLTAC:; Pinceaux; --------; Descripteur d'un pinceau; ------------------------	.PC	PCVAR	.LOC	0OPENFA:	.BLKB	4		; fanions BPENCE	=  0			;  cercle BPENEL	=  1			;  ellipse BPENCA	=  2			;  carr BPENRE	=  3			;  rectangle BPENCO	=  8			;  continu BPENTT	=  9			;  pointillOPENLY:	.BLKB	2		; hauteurOPENLX:	.BLKB	2		; largeurOPENT1:	.BLKB	2		; trait 1OPENT2:	.BLKB	2		; trou  1OPENT3:	.BLKB	2		; trait 2OPENT4:	.BLKB	2		; trou  2OPENT5:	.BLKB	2		; trait 3OPENT6:	.BLKB	2		; trou  3OPENT7:	.BLKB	2		; trait 4OPENT8:	.BLKB	2		; trou  4OPENCO:	.BLKB	2		; couleur	.BLKB	6		; rserveLDPEN:; Descripteur d'une table des pinceaux; ------------------------------------	.PC	PCVAR	.LOC	0OTAPLST:.BLKB	LDPEN*NBRX*NBRY	; liste des pinceauxOTAPSEL:.BLKB	2		; pinceau slectionnLTAPIO:OTAPNAM:.BLKB	LBUNAME		; nom du fichier des pinceauxLTAP:; Trames; ------; Descripteur d'une trame; -----------------------	.PC	PCVAR	.LOC	0OTRAFA:	.BLKB	4		; fanions BTRAGR	=  0			;  gris BTRAHA	=  1			;  hachure BTRAPC	=  8			;  petits points carrs BTRAGC	=  9			;  gros points carrs BTRAGO	=  10			;  gros points ronds BTRAQC	=  15			;  en quinconce BTRATR	=  16			;  transparent BTRAD2	=  24			;  2me droite BTRADH	=  25			;  2me droite - BTRADO	=  26			;  2me droite / BTRADV	=  27			;  2me droite | BTRADI	=  28			;  2me droite \OTRAGP:	.BLKB	2		; intensit de gris en %OTRADI:	.BLKB	2		; dimensions des grainsOTRAI1:	.BLKB	2		; inclinaison 1OTRAD1:	.BLKB	2		; distance 1OTRAE1:	.BLKB	2		; paisseur 1OTRAE2:	.BLKB	2		; paisseur 2OTRACC:	.BLKB	2		; couleur chairOTRACF:	.BLKB	2		; couleur fond	.BLKB	4		; rserveLDTRA:; Descripteur d'une table des trames; ----------------------------------	.PC	PCVAR	.LOC	0OTATLST:.BLKB	LDTRA*NBRX*NBRY	; liste des tramesOTATSEL:.BLKB	2		; trame slectionneLTATIO:OTATNAM:.BLKB	LBUNAME		; nom du fichier des tramesLTAT:	.END