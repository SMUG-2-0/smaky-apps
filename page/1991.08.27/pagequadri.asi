	.SBTTL	PAGEQUADRI.ASINBCOUL	=	16		; nb de couleurs;-----------\\; QUADMIROIR >;===========/; Effectue rapidement le miroir d'un bitmap..; La largeur doit tre multiple de 16 !; in	A0.L	^descripteur bitmap; out	-; mod	D7.WQUADMIROIR:	PUSHM.L	D2..D6,A2..A5; Construit une table de 256 valeurs 0..n avec les bits 0  7 permuts.	LOAD.L	A2,#(A6)+OBUDIS	; A2 <-- ^buffer temporaire	CLR.B	D2LOOPT$:	LOAD.B	D3,D2	LOAD.W	D5,#8-1LOOPB$:	RRX.B	D3		; permute les bits 7 <--> 0	RLX.B	D4	DECJ.W,NMO D5,LOOPB$	LOAD.B	(A2+),D4	; OBUDIS <-- 0..n avec les bits permuts	INC.B	D2	JUMP,NE LOOPT$; Inverse le bitmap ligne par ligne, depuis les deux bouts  la fois.	LOAD.L	A2,#(A6)+OBUDIS	; A2 <-- ^table de conversion	LOAD.L	A5,(A0)+ODFABS	; A5 <-- ^dbut du bitmap	LOAD.W	D6,(A0)+ODFDY	; D6 <-- nb de lignesLOOPY$:	LOAD.L	A3,A5		; A3 <-- ^dbut ligne	LOAD.L	A4,A5	LOAD.W	D5,(A0)+ODFIIY	; D5 <-- largeur en bytes	ADD.W	A4,D5		; A4 <-- ^fin ligne	SR.W	D5,#1		; D5 <-- /2 car jusqu'au milieu	DEC.W	D5		; D5 <-- -1  cause NMO	CLR.W	D3	CLR.W	D4LOOPX$:	LOAD.B	D3,(A3)		; D3 <-- byte dbut ligne	LOAD.B	D4,(-A4)	; D4 <-- byte fin ligne	LOAD.B	(A3+),(A2)+(D4.W)	LOAD.B	(A4),(A2)+(D3.W)	DECJ.W,NMO D5,LOOPX$	ADD.W	A5,(A0)+ODFIIY	; A4 <-- ^ligne suivante	DEC.W	D6	JUMP,NE LOOPY$	POPM.L	D2..D6,A2..A5	RET;---------\\; QUADCONV >;=========/; Conversion d'une matrice couleur en matrice noir/blanc, en; extrayant une couleur de base pour imprimer en quadrichromie.; Les couleurs sont simules par des trames 4x4 inclines de; 0, 15, 45 ou 75 degrs dont l'intensit varie en fonction; de la couleur demande (les trames 4x4 inclines sont elles-; mmes simules par des trames 4x16 droites).; in	D2.W	couleur demande (0..4);		 0 -> noir;		 1 -> cyan;		 2 -> magenta;		 3 -> jaune;		 4 -> RGB;	A4.L	^image couleur;	D4.L	dimensions (dy;dx);	D5.W	Iy bitmap;	A5.L	^buffer pour image noir/blanc (=A4 possible);	D6.W	nb de bits/pixel (#4);	A0.L	^descripteur fentre; out	D7.W	erreur; mod	D7.WQUADCONV:	PUSHM.L	D0..D5,A2..A5	LOAD.W	D7,#1		; D7 <-- erreur	COMP.W	D6,#4		; 4 bits/pixel ?	JUMP,NE EXIT$		; non => EXIT$ (vraiment navr)	CALL	QUADCALC	; A2/A3 <-- ^table du filtre/^trames	CLR.W	D2		; D2 <-- Y initial dans trameLOOPY$:	PUSHM.L	D4,A4	CLR.W	D3		; D3 <-- X initial dans destination	LOAD.W	D0,#15		; D0 <-- X initial dans trameLOOPX$:	DEC.W	D3		; D3 <-- X suivant dans destination	TCLR.B	(A5):D3	CLR.W	D1	LOAD.B	D1,(A4)	SR.W	D1,#4	LOAD.B	D1,(A2)+(D1.W)	; D1 <-- intensit (0..15)	SL.W	D1,#3		; D1 <-- *8	ADD.W	D1,D2		; D1 <-- ajoute Y	LOAD.W	D1,(A3)+(D1.W)	; D1 <-- trame	TEST.L	D1:D0	JUMP',BC WHITE0$	TSET.B	(A5):D3WHITE0$:	DEC.W	D0		; D0 <-- X suivant dans trame	DEC.W	D3		; D3 <-- X suivant dans destination	TCLR.B	(A5):D3	LOAD.B	D1,(A4+)	AND.W	D1,#B'00001111	LOAD.B	D1,(A2)+(D1.W)	; D1 <-- intensit (0..15)	SL.W	D1,#3		; D1 <-- *8	ADD.W	D1,D2		; D1 <-- ajoute Y	LOAD.W	D1,(A3)+(D1.W)	; D1 <-- trame	TEST.L	D1:D0	JUMP',BC WHITE1$	TSET.B	(A5):D3WHITE1$:	DEC.W	D0		; D0 <-- X suivant dans trame	AND.W	D0,#B'1111	AND.W	D3,#B'111	JUMP',NE SKIP$	INC.L	A5		; A5 <-- ^byte suivantSKIP$:	SUB.W	D4,#2	JUMP,NE LOOPX$	POPM.L	D4,A4	ADD.W	A4,D5		; A4 <-- ^ligne suivante	ADD.W	D2,#2		; D2 <-- Y suivant dans trame	AND.W	D2,#B'110	; D2 <-- 0,2,4,6	SWAP.W	D4	DEC.W	D4	LOAD.W	D0,D4	SWAP.W	D4	TEST.W	D0	JUMP,NE LOOPY$	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; QUADCALC >;---------/; Calcule la table du filtre.; in	D2.W	couleur demande (0..4);		 0 -> noir;		 1 -> cyan;		 2 -> magenta;		 3 -> jaune;		 4 -> RGB; out	A2.L	^filtre (16 valeurs .B de 0..15);	A3.L	^16 trames de 4x16; mod	D7.W, A2.L, A3.LQUADCALC:	PUSHM.L	D1..D4,D6,A1,A4	LOAD.L	A1,#R16"QTRA75	; A1 <-- ^trames 75 degrs	COMP.W	D2,#1	JUMP',EQ GO$	LOAD.L	A1,#R16"QTRA45	; A1 <-- ^trames 45 degrs	COMP.W	D2,#2	JUMP',EQ GO$	LOAD.L	A1,#R16"QTRA15	; A1 <-- ^trames 15 degrs	COMP.W	D2,#3	JUMP',EQ GO$	LOAD.L	A1,#R16"QTRA0	; A1 <-- ^trames 0 degrsGO$:	LOAD.L	D6,(A0)+ODFCPF	; D6 <-- canal pour TCOLOR	LOAD.L	A2,#(A6)+OBUDIS+20	CLR.L	D1	COMP.W	D2,#4	JUMP',EQ RGBLOOP$CLOOP$:	LOAD.B	(A2+),D1	; buffer <-- une couleur	INC.W	D1	COMP.W	D1,#NBCOUL	JUMP,LO CLOOP$	JUMP	END$RGBLOOP$:	LOAD.L	D4,D1	LOAD.L	A3,#(A6)+OBUDIS+0	LOAD.L	D3,#2^BTCFORCE!2^BTCGIVE	TCOL_	SRCCLUT		; OBUDIS+0 <-- couleur RGB	CLR.L	D4	LOAD.W	D4,(A3+)	; D4 <-- rouge	CLR.L	D3	LOAD.W	D3,(A3+)	; D3 <-- vert	ADD.L	D4,D3	CLR.L	D3	LOAD.W	D3,(A3+)	; D3 <-- bleu	ADD.L	D4,D3	DIV.WU	D4,#((2^16)*3)/16	COMP.B	D4,#16	JUMP',LO RGBPUT$	LOAD.B	D4,#16-1RGBPUT$:	SUB.B	D4,#16-1	NEG.B	D4	LOAD.B	(A2+),D4	; buffer <-- une couleur	INC.W	D1	COMP.W	D1,#NBCOUL	JUMP,LO RGBLOOP$;	JUMP	END$END$:	LOAD.L	A2,#(A6)+OBUDIS+20	LOAD.L	A3,A1		; A3 <-- ^trames 4x16	POPM.L	D1..D4,D6,A1,A4	RET; Trames pour faire la sparation des couleurs en quadrichromie; -------------------------------------------------------------; Trames avec un angle de 0 degrs :QTRA0:					; 0	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000					; 1	.W	B'0000000000000000	.W	B'0100010001000100	.W	B'0000000000000000	.W	B'0000000000000000					; 2	.W	B'0000000000000000	.W	B'0110011001100110	.W	B'0000000000000000	.W	B'0000000000000000					; 3	.W	B'0000000000000000	.W	B'0110011001100110	.W	B'0010001000100010	.W	B'0000000000000000					; 4	.W	B'0000000000000000	.W	B'0110011001100110	.W	B'0110011001100110	.W	B'0000000000000000					; 5	.W	B'0000000000000000	.W	B'0111011101110111	.W	B'0110011001100110	.W	B'0000000000000000					; 6	.W	B'0000000000000000	.W	B'0111011101110111	.W	B'1110111011101110	.W	B'0000000000000000					; 7	.W	B'0100010001000100	.W	B'0111011101110111	.W	B'1110111011101110	.W	B'0000000000000000					; 8	.W	B'0100010001000100	.W	B'0111011101110111	.W	B'1110111011101110	.W	B'0010001000100010					; 9	.W	B'0100010001000100	.W	B'0111011101110111	.W	B'1111111111111111	.W	B'0010001000100010					; 10	.W	B'0100010001000100	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'0010001000100010					; 11	.W	B'0110011001100110	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'0010001000100010					; 12	.W	B'0110011001100110	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'0110011001100110					; 13	.W	B'0111011101110111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'0110011001100110					; 14	.W	B'0111011101110111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1110111011101110					; 15	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111; Trames avec un angle de 15 degrs :QTRA15:					; 0	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000					; 1	.W	B'0000000000010000	.W	B'0000000000000001	.W	B'0001000000000000	.W	B'0000000100000000					; 2	.W	B'0000000000011000	.W	B'1000000000000001	.W	B'0001100000000000	.W	B'0000000110000000					; 3	.W	B'0000000010011000	.W	B'1000000000001001	.W	B'1001100000000000	.W	B'0000100110000000					; 4	.W	B'0000000110011000	.W	B'1000000000011001	.W	B'1001100000000001	.W	B'0001100110000000					; 5	.W	B'0000000110011100	.W	B'1100000000011001	.W	B'1001110000000001	.W	B'0001100111000000					; 6	.W	B'0000001110011100	.W	B'1100000000111001	.W	B'1001110000000011	.W	B'0011100111000000					; 7	.W	B'0000001110011101	.W	B'1101000000111001	.W	B'1001110100000011	.W	B'0011100111010000					; 8	.W	B'0000101110011101	.W	B'1101000010111001	.W	B'1001110100001011	.W	B'1011100111010000					; 9	.W	B'0000101111011101	.W	B'1101000010111101	.W	B'1101110100001011	.W	B'1011110111010000					; 10	.W	B'0000101111111101	.W	B'1101000010111111	.W	B'1111110100001011	.W	B'1011111111010000					; 11	.W	B'1000101111111101	.W	B'1101100010111111	.W	B'1111110110001011	.W	B'1011111111011000					; 12	.W	B'1001101111111101	.W	B'1101100110111111	.W	B'1111110110011011	.W	B'1011111111011001					; 13	.W	B'1101101111111101	.W	B'1101110110111111	.W	B'1111110111011011	.W	B'1011111111011101					; 14	.W	B'1111101111111101	.W	B'1101111110111111	.W	B'1111110111111011	.W	B'1011111111011111					; 15	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111; Trames avec un angle de 45 degrs :QTRA45:					; 0	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000					; 1	.W	B'0000000000000000	.W	B'0000100000001000	.W	B'0000000000000000	.W	B'1000000010000000					; 2	.W	B'0000000000000000	.W	B'0000110000001100	.W	B'0000000000000000	.W	B'1100000011000000					; 3	.W	B'0100000001000000	.W	B'0000110000001100	.W	B'0000010000000100	.W	B'1100000011000000					; 4	.W	B'1100000011000000	.W	B'0000110000001100	.W	B'0000110000001100	.W	B'1100000011000000					; 5	.W	B'1100000011000000	.W	B'0000111000001110	.W	B'0000110000001100	.W	B'1110000011100000					; 6	.W	B'1100000111000001	.W	B'0000111000001110	.W	B'0001110000011100	.W	B'1110000011100000					; 7	.W	B'1100100111001001	.W	B'0000111000001110	.W	B'1001110010011100	.W	B'1110000011100000					; 8	.W	B'1100100111001001	.W	B'0100111001001110	.W	B'1001110010011100	.W	B'1110010011100100					; 9	.W	B'1110100111101001	.W	B'0100111001001110	.W	B'1001111010011110	.W	B'1110010011100100					; 10	.W	B'1110100111101001	.W	B'0101111001011110	.W	B'1001111010011110	.W	B'1110010111100101					; 11	.W	B'1110110111101101	.W	B'0101111001011110	.W	B'1101111011011110	.W	B'1110010111100101					; 12	.W	B'1110110111101101	.W	B'1101111011011110	.W	B'1101111011011110	.W	B'1110110111101101					; 13	.W	B'1110111111101111	.W	B'1101111011011110	.W	B'1111111011111110	.W	B'1110110111101101					; 14	.W	B'1110111111101111	.W	B'1101111111011111	.W	B'1111111011111110	.W	B'1111110111111101					; 15	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111; Trames avec un angle de 75 degrs :QTRA75:					; 0	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000	.W	B'0000000000000000					; 1	.W	B'0000000000000100	.W	B'0000000001000000	.W	B'0000010000000000	.W	B'0100000000000000					; 2	.W	B'0000000000000110	.W	B'0000000001100000	.W	B'0000011000000000	.W	B'0110000000000000					; 3	.W	B'0010000000000110	.W	B'0000000001100010	.W	B'0000011000100000	.W	B'0110001000000000					; 4	.W	B'0110000000000110	.W	B'0000000001100110	.W	B'0000011001100000	.W	B'0110011000000000					; 5	.W	B'0110000000000111	.W	B'0000000001110110	.W	B'0000011101100000	.W	B'0111011000000000					; 6	.W	B'1110000000000111	.W	B'0000000001111110	.W	B'0000011111100000	.W	B'0111111000000000					; 7	.W	B'1110000001000111	.W	B'0000010001111110	.W	B'0100011111100000	.W	B'0111111000000100					; 8	.W	B'1110001001000111	.W	B'0010010001111110	.W	B'0100011111100010	.W	B'0111111000100100					; 9	.W	B'1111001001000111	.W	B'0010010001111111	.W	B'0100011111110010	.W	B'0111111100100100					; 10	.W	B'1111001001001111	.W	B'0010010011111111	.W	B'0100111111110010	.W	B'1111111100100100					; 11	.W	B'1111001001101111	.W	B'0010011011111111	.W	B'0110111111110010	.W	B'1111111100100110					; 12	.W	B'1111011001101111	.W	B'0110011011111111	.W	B'0110111111110110	.W	B'1111111101100110					; 13	.W	B'1111011001111111	.W	B'0110011111111111	.W	B'0111111111110110	.W	B'1111111101100111					; 14	.W	B'1111111001111111	.W	B'1110011111111111	.W	B'0111111111111110	.W	B'1111111111100111					; 15	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.W	B'1111111111111111	.END