;	Mthodes fournies par le programme PAGE lui-mme;	------------------------------------------------DF_SEARCH	=	1		; cherche un objet de dfinitionDF_GETULIST	=	10		; donne la liste des tats d'utilisationDR_LINE		=	1		; dessine une ligneDR_LINEM	=	2		; dessine une ligne (plus lent)DR_TRAME	=	3		; dessine une trameDR_CROIX	=	4		; dessine une croixDR_CIRCLE	=	5		; dessine un cercleDR_BEZIER	=	6		; dessine une courbe de BzierDR_RECTHV	=	7		; dessine un rectangle horizontal/verticalDR_POLYOPEN	=	10		; commence la df. d'un chemin de clippingDR_POLYLINE	=	11		; ajoute une ligne au chemin de clippingDR_POLYCLOSE	=	12		; termine la df. d'un chemin de clippingDR_POLYBEZIER	=	13		; ajoute une courbe de Bzier au chemin de clippingDR_GETPGC	=	20		; cherche un gencar bitmap selon descripteurDR_CHAR		=	21		; affiche un caractreDR_CHARQ	=	22		; affiche rapidement un caractreDR_BMOPEN	=	30		; dbut du dessin dans un bitmap (initialisation)DR_BMCLOSE	=	31		; fin du dessin dans un bitmap (affiche contenu)DR_BMUPDALL	=	32		; indique que tout le bitmap devra tre mis  jourDR_BMBBOX	=	33		; indique o l'on dessine dans un bitmapDR_BMOPENDIM	=	34		; dbut du dessin dans un bitmap (initialisation)DR_SCOPENPLY	=	35		; dbut du dessin dans l'cran (rgle)DR_SCCLOSE	=	36		; fin du dessin dans l'cranDR_BMOPENPLY	=	37		; dbut du dessin dans un bitmap (initialisation)DR_BMVISUPLY	=	38		; dplace P1/P2 pour les rendre visibles (rgles)DR_BMOPENMODE	=	39		; mode pour BMOEN*DR_PUTICO	=	40		; transfre une icne dans IPP21DR_WDOOPEN	=	50		; utilise la sous-fentre de dessinDR_WDOCLOSE	=	51		; ferme la sous-fentre de dessinDR_WDOUOPEN	=	52		; utilise une sous-fentre n'importe oDR_WDOUCLOSE	=	53		; ferme une sous-fentre n'importe oDR_COLORDEF	=	60		; remet les couleurs par dfautDR_COLORINIT	=	61		; choix des couleurs pour dessinerDR_GETOFTRAME	=	100		; donne l'offset permettant de dessiner une trameDR_GETPRINT	=	101		; rend le mode d'impressionDR_GETRESOL	=	102		; rend la rsolution de l'imprimanteDR_GETCOL	=	103		; donne position/dimension d'une colonneDR_GETDETM	=	104		; donne la marge de dtectionDR_GETOPER	=	105		; donne l'opration de transformation effectueDR_GETPAGE	=	106		; donne le numro de la page couranteDR_GETSCALE	=	110		; rend l'chelle couranteDR_PUTSCALE	=	111		; impose l'chelle couranteDR_CHGSCALE	=	112		; modifie l'chelle couranteDB_OPEN		=	1		; ouvre la bote de dialogue (fait aussi DB_OPEN1)DB_OPEN1	=	2		; souris normale, sauve tat de la sous-fentreDB_CLOSE	=	3		; ferme la bote de dialogue (fait aussi DB_CLOSE1)DB_CLOSE1	=	4		; rcupre tat prcdent DB_OPEN1DB_POS5		=	5		; centre selon icnes de gauche => D5.32DB_POS3		=	6		; centre selon icnes de gauche => D3.32DB_ZEROCR	=	10		; remplace un <CR> par un <0> dans une ligneDB_ERCALL	=	11		; appel DBOX_ERCALLDB_MEMPT	=	20		; mmorise le ^table DBOXDB_MEDIT	=	21		; dite la bonne ligneDB_AFF		=	22		; affiche un paramtre ditableDB_GET		=	23		; rend le contenu d'un paramtre ditableDB_PUT		=	24		; met  jour un paramtre ditableDB_CLIC		=	25		; incrmente v. un paramtre ditableDB_MEMAFC	=	26		; donne la routine d'affichage pour DB_CLICDB_HLINE	=	30		; dessine un trait horizontal dans la bote de dialogueDB_RSK		=	31		; redessine les soft-keysDB_IMALOAD	=	40		; charge une imageDB_IMASHOW	=	41		; affiche une imageDB_IMAKILL	=	42		; supprime une image chargeDB_ERROR	=	50		; affiche une erreurMI_CCMO		=	1		; efface le curseur de la sourisMI_SCMO		=	2		; affiche le curseur de la sourisMI_WAITMOUSE	=	3		; souris en mode sablierMI_NORMMOUSE	=	4		; souris en mode normalMI_MMENUS	=	10		; attend un choix dans un mouse-menu hirarchiqueMI_WAITEVENT	=	20		; attend un vnement, avec timeoutMI_TESTEVENT	=	21		; teste si un vnement est l, sans le lireMI_PUTUNUM	=	30		; met un nombre avec des units dans un bufferMI_GETUNUM	=	31		; donne un nombre avec des unitsMI_PUTANUM	=	32		; met un nombre dcimal dans un bufferMI_GETANUM	=	33		; donne un nombre dcimalMI_OBJCALLD	=	40		; comme OBJCALL, avec ^objetMI_GETDATA	=	41		; cherche le data d'un objetMI_GETROOT	=	42		; cherche la racine du dernier objet utilisMI_GIVMEM	=	43		; libre toute la mmoire possibleMI_EDITVISU	=	50		; dplace la partie visible (curseur visible)MI_IFVIEWHIDE	=	60		; active/dsactive le mcanisme "opVIEWHIDE"MA_FIXMUL	=	10		; multiplication avec virgule fixeMA_FIXDIV	=	11		; division avec virgule fixeMA_INTMUL32	=	20		; multiplication 32 * 32 => 64 (non sign)MA_INTDIV32	=	21		; division 64/32 => 32 + reste (non sign, div 0 pas test)MA_DETLINE	=	30		; regarde si on est sur une ligneMA_DETBEZIER	=	31		; regarde si on est sur une courbe de BzierMA_SCALEP	=	40		; tient compte de l'chelle positivementMA_SCALEN	=	41		; tient compte de l'chelle ngativementMA_OBJDRAW	=	42		; coordonnes objet --> coordonnes cran (pour afficher)MA_OBJSCR	=	43		; coordonnes objet --> coordonnes cranMA_SCROBJ	=	44		; coordonnes cran --> coordonnes objetMA_RECTOR	=	50		; union de deux "bounding-box"MA_RECTAND	=	51		; intersection de deux "bounding-box"MA_RECTTEST	=	52		; teste si un rectangle est inclu dans l'autreMA_BBOXBEZIER	=	60		; calcule la "bounding-box" d'une courbe de BzierIO_RDOPEN	=	10		; ouverture d'un fichier en lectureIO_RDCLOSE	=	11		; fermeture du fichierIO_RDONE	=	12		; lit un caractre (bufferis)IO_RDMANY	=	13		; lit n caractres (bufferis)IO_WROPEN	=	20		; ouverture d'un fichier en criture exclusiveIO_WRCLOSE	=	21		; fermeture du fichierIO_WRONE	=	22		; crit un caractre (bufferis)IO_WRMANY	=	23		; crit n caractres (bufferis)IO_WRASSFILE	=	26		; ajoute un fichier dans le fichier "!"IO_DICOLOAD	=	50		; charge le dictionnaireIO_DICOSTATUS	=	51		; cherche le statusIO_MESSGETPT	=	60		; donne le pointeur pour les messagesPAGE_OBJCALL	=	16'ABC0		; appelle un module objetPAGE_DEF	=	16'ABC1		; gestion des modules objet de dfinitionPAGE_DRAW	=	16'ABC2		; facilits pour le dessinPAGE_DBOX	=	16'ABC3		; facilits pour les botes de dialoguePAGE_MISC	=	16'ABC4		; divers (souris, etc..)PAGE_MATH	=	16'ABC5		; lments mathmatiquesPAGE_IO		=	16'ABC6		; facilits d'entres/sorties;--------------\\; _PAGE_OBJCALL >;==============/; Appelle une mthode d'un module-objet.; Une erreur est rendue si la mthode n'existe pas,; ou si le module-objet n'est pas connect.; in	D0.16	identificateur du module-objet;	D1.16	mthode;	+	selon mthode; out	+	selon mthode;	D7.16	erreur; mod	D7.16, +;------------\\; MI_OBJCALLD >;============/; Appel identique  OBJCALL, mais pour une mthode utilisant; le pointeur  l'objet.; in	D1.16	mthode;	A4.32	^racine de l'objet;	+	selon mthode; out	+	selon mthode;	D7.16	erreur; mod	D7.16, +;-----------\\; MI_GETDATA >;===========/; Cherche le data d'un objet.; in	A4.32	^racine d'un objet; out	A4.32	^data de l'objet; mod	D7.16, A4.32;-----------\\; MI_GETROOT >;===========/; Cherche la racine du dernier objet utilis.; in	-; out	A4.32	^racine de l'objet; mod	D7.16, A4.32;----------\\; MI_GETMEM >;==========/; Demande de la mmoire sur le compte du prosessus courant (MTYPCP),; en librant la mmoire superflue des autres objets si ncessaire; (en utilisant la mthode opCRGIVMEM).; in	D4.32	longueur; out	A4.32	^mmoire;	D7.16	erreur; mod	D7.16, A4.32;----------\\; MI_GIVMEM >;==========/; Libre toute la mmoire possible, en appelant la mthode opCRGIVMEM; pour tous les objets existants. La mmoire de l'objet appelant n'est; pas libre !; in	-; out	-; mod	D7.16;----------\\; _PAGE_DEF >;==========/; Gestion des objets de dfinition.; in	D7.16	sous-appel;	+	selon appel; out	+	selon appel;	D7.16	erreur; mod	D7.16, +;----------\\; DF_SEARCH >;==========/; Cherche un objet de dfinition.; in	D4.16	identificateur; out	A4.32	^objet;	D7.16	erreur; mod	D7.16, A4.32;------------\\; DF_GETULIST >;============/; Donne la liste des tats d'utilisation.; in	D3.16	identificateur;	A4.32	^buffer pour tats (0=pas utilis);	D4.16	lg buffer; out	-; mod	D7.16;-----------\\; _PAGE_DRAW >;===========/; in	D7.16	sous-appel;	+	selon appel; out	+	selon appel;	D7.16	erreur; mod	D7.16, +; REMARQUE:	Le mode de dessin est le mode propos dans GRA2, soit;		les modes habituels (SETDOT, CLRDOT, INVDOT..) sauf le;		mode LOADDOT qui doit tre banni.;--------\\; DR_LINE >;========/; Dessine ou imprime une ligne droite (voir *).; in	D3.32	dpart (y;x);	D4.32	arrive (y;x);	D2.16	mode de dessin; out	-; mod	D7.16;----------\\; DR_BEZIER >;==========/; Dessine ou imprime une courbe de Bzier (voir *).; in	D3.32	P1 (y;x);	D4.32	C1 (y;x);	D5.32	C2 (y;x);	D6.32	P2 (y;x);	D2.16	mode de dessin; out	-; mod	D7.16;----------\\; DR_RECTHV >;==========/; Dessine un rectangle horizontal/vertical, avec clipping rapide (voir *).; in	D3.32	coin sup/gauche (y;x);	D4.32	coin inf/droite (y;x);	D2.16	mode de dessin;	D1.8	map si traitill; out	-; mod	D7.16;---------\\; DR_LINEM >;=========/; Dessine une ligne droite, sans endommager la souris.; Cet appel est plus lent que DRLINE, car il passe par la librairie,; $DIS puis GRA. Il faut l'utiliser lors d'un dplacement interractif; avec la souris !; in	D3.32	dpart (y;x);	D4.32	arrive (y;x);	D2.16	mode de dessin; out	-; mod	D7.16;---------\\; DR_TRAME >;=========/; Dessine une trame rectangulaire, sans endommager la souris.; A utiliser, par exemple, pour mettre en vidence une zone dans; un texte.; in	D3.32	dpart (y;x);	D4.32	arrive (y;x);	D2.16	mode de dessin; out	-; mod	D7.16;---------\\; DR_CROIX >;=========/; Dessine une croix (+) (voir *).; A utiliser pour dessiner des poignes spciales, avec la mthode; "opHANDMOVE" par exemple.; in	D3.32	centre (y;x);	D4.16	demi-longueur [scr];		 si 2**15 set --> cercle en plus;	D2.16	mode de dessin; out	-; mod	D7.16;----------\\; DR_CIRCLE >;==========/; Dessine un cercle (voir *).; in	D3.32	centre (y;x);	D4.16	rayon (r);	D2.16	mode de dessin; out	-; mod	D7.16; (*)	Tous ces appels enlvent la souris (MI_CCMO).;	Il ne faut donc pas oublier MI_SCMO lorsque le;	dessin est termin !;------------\\; DR_POLYOPEN >;============/; Dbute le dessin d'un polygone rempli.; in	-; out	D7.16	erreur; mod	D7.16;------------\\; DR_POLYLINE >;============/; Dfinit une nouvelle ligne d'un polygone rempli.; in	D3.32	dpart (y;x);	D4.32	arrive (y;x); out	D7.16	erreur; mod	D7.16;--------------\\; DR_POLYBEZIER >;==============/; Dfini une nouvelle courbe d'un polygone rempli.; in	D3.32	P1 (y;x);	D4.32	C1 (y;x);	D5.32	C2 (y;x);	D6.32	P2 (y;x); out	-; mod	D7.16;-------------\\; DR_POLYCLOSE >;=============/; Dessine le polygone rempli dfini.; in	D2.16	mode de dessin; out	D7.16	erreur; mod	D7.16;----------\\; DR_GETPGC >;==========/; Cherche un gencar bitmap d'aprs son descripteur.; in	A4.32	^descripteur du caractre (odgbm*);	D1.32	angle de rotation (degrs rels); out	A3.32	^gencar bitmap;	D7.16	erreur; mod	D7.16, A3.32;---------\\; DR_CHAR  >;=========/; Dessine un caractre.; in	D3.16	code du caractre;	D4.32	position du centre (y;x);	D2.16	mode de dessin;	D1.32	angle de rotation (degrs rels);	A4.32	^descripteur du caractre (odgbm*); out	D7.16	erreur; mod	D7.16;---------\\; DR_CHARQ >;=========/; Dessine un caractre rapidement.; in	D3.16	code du caractre;	D4.32	position du centre (y;x);	D2.16	mode de dessin;	A4.32	^gencar bitmap (!); out	D7.16	erreur; mod	D7.16;--------------\\; DR_BMOPENMODE >;==============/; Spcifie le mode d'ouverture du bitmap.; A utiliser avant BMOPEN* !; in	A0.32	^descripteur fentre;	D4.32	mode d'ouverture;		 :#0 -> couleur; out	-; mod	D7.16;----------\\; DR_BMOPEN >;==========/; Dbut du dessin dans un bitmap.; in	A4.32	^objet; out	D7.16	erreur; mod	D7.16;-------------\\; DR_BMOPENDIM >;=============/; Dbut du dessin dans un bitmap pour un objet quelconque.; in	D3.32	P1 (y;x)  [obj];	D4.32	P2 (y;x)  [obj]; out	D7.16	erreur; mod	D7.16;-------------\\; DR_BMOPENPLY >;=============/; Dbut du dessin dans un bitmap pour un objet quelconque.; Permet de dessiner jusqu'en haut de la fentre (pour les rgles).; in	D3.32	P1 (y;x)  [obj];	D4.32	P2 (y;x)  [obj]; out	D7.16	erreur; mod	D7.16;----------\\; DR_BMBBOX >;==========/; Indique o l'on dessine dans le bitmap.; in	D3.32	p1 (y;x)  [obj];	D4.32	p2 (y;x)  [obj]; out	-; mod	D7.16;-----------\\; DR_BMBBOXQ >;===========/; Indique o l'on dessine dans le bitmap.; in	D3.32	p1 (y;x)  [scr];	D4.32	p2 (y;x)  [scr]; out	-; mod	D7.16;------------\\; DR_BMUPDALL >;============/; Indique qu'il faudra tout mettre  jour le bitmap.; in	-; out	-; mod	D7.16;-----------\\; DR_BMCLOSE >;===========/; Fin du dessin dans un bitmap.; in	-; out	-; mod	D7.16;-----------\\; DR_BMFLUSH >;===========/; Libre les bitmaps.; in	-; out	-; mod	D7.16;-------------\\; DR_BMVISUPLY >;=============/; Dplace P1/P2 pour les rendre visibles.; Est utilis pour que les rgles soient toujours visibles, en; haut de la fentre (dans le cadre et les informations).; in	D3.32	P1 (y;x)  [obj];	D4.32	P2 (y;x)  [obj]; out	D3.32	P1 (y;x)  [obj];	D4.32	P2 (y;x)  [obj]; mod	D3.32, D4.32, D7.16;-------------\\; DR_SCOPENPLY >;=============/; Dbut du dessin dans l'cran pour un objet quelconque.; Permet de dessiner jusqu'en haut de la fentre (pour les rgles).; in	D3.32	P1 (y;x)  [obj];	D4.32	P2 (y;x)  [obj]; out	D7.16	erreur; mod	D7.16;-----------\\; DR_SCCLOSE >;===========/; Fin du dessin dans l'cran.; in	-; out	-; mod	D7.16;----------\\; DR_PUTICO >;==========/; Transfre une icne dans le gencar IPP21.; in	A4.32	^dx,dy,icne;	D3.16	code de l'icne (ICOUSER..127); out	-; mod	D7.16;-----------\\; DR_WDOOPEN >;===========/; Utilise la swdo de dessin, si ncessaire.; in	-; out	-; mod	D7.16;------------\\; DR_WDOCLOSE >;============/; Ferme la swdo de dessin, si ncessaire.; in	A0.32	^descripteur de la fentre; out	-; mod	D7.16;------------\\; DR_WDOUOPEN >;============/; Ouvre une fentre utilisateur n'importe o.; in	D3.32	P1 (y;x)  [scr];	D4.32	P2 (y;x)  [scr]; out	-; mod	D7.16;-------------\\; DR_WDOUCLOSE >;=============/; Ferme une fentre utilisateur.; in	-; out	-; mod	D7.16;------------\\; DR_COLORDEF >;============/; Initialise les couleurs par dfaut.; in	-; out	-; mod	D7.16;-------------\\; DR_COLORINIT >;=============/; Initialise les couleurs pour dessiner.; Chaque partie .16 de D4 peut valoir :;   0	-->	ne change pas la couleur;  -1	-->	couleur du fond (COLORFPAGE); in	A0.32	^descripteur fentre;	D4.32	couleurs relatives (clr;set); out	-; mod	D7.16;--------------\\; DR_GETOFTRAME >;==============/; Donne l'offset permettant de dessiner une trame.; in	-; out	D3.32	offset pour trame; mod	D3.32, D7.16;------------\\; DR_GETSCALE >;============/; Donne l'chelle courante.; in	-; out	D4.16	chelle; mod	D4.32, D7.16;------------\\; DR_PUTSCALE >;============/; Modifie l'chelle courante.; in	D4.16	nouvelle chelle (1=100%); out	-; mod	D7.16;------------\\; DR_CHGSCALE >;============/; Modifie l'chelle courante.; in	D4.16	nouvelle chelle (1=100%); out	D4.16	ancienne chelle; mod	D4.32, D7.16;------------\\; DR_GETPRINT >;============/; Donne le mode d'impression.; in	-; out	D4.32	mode d'impression (BPRIxxx); mod	D4.32, D7.16;------------\\; DR_GETRESOL >;============/; Lit le status de l'imprimante.; in	-; out	D3.32	facteurs d'chelle (P2;P1);	D7.16	erreur; mod	D3.32, D7.16;----------\\; DR_GETCOL >;==========/; Donne la position et les dimensions d'une colonne.; in	D2.16	rang de la colonne (0..n); out	D3.32	P1 (y;x);	D4.32	P2 (y;x);	D7.16	erreur; mod	D3.32, D4.32, D7.16;-----------\\; DR_GETDETM >;===========/; Donne la marge de dtection.; in	-; out	D4.16	marge de dtection [obj]; mod	D4.32, D7.16;-----------\\; DR_GETOPER >;===========/; Donne l'opration de transformation effectue.; in	-; out	D4.16	opration (ICOZ*); mod	D4.32, D7.16;-----------\\; DR_GETPAGE >;===========/; Donne le numro de la page courante.; in	-; out	D4.16	page courante (0..n); mod	D4.32, D7.16;-----------\\; _PAGE_DBOX >;===========/; in	D7.16	sous-appel;	+	selon appel; out	+	selon appel;	D7.16	erreur; mod	D7.16, +;--------\\; DB_OPEN >;========/; Ouvre une dbox, sauve le fond, etc..; in	A2.32	table;	D2.16	mode; out	D5.32	canal;	D7.16	erreur; mod	D5.32, D7.16;---------\\; DB_OPEN1 >;=========/; Sauve le fond, met la flche ok, etc..; in	-; out	D7.16	erreur; mod	D7.16;---------\\; DB_CLOSE >;=========/; Ferme une dbox, reprend le fond, rcupre la souris, etc..; in	D5.32	canal; out	D7.16	erreur; mod	D7.16;----------\\; DB_CLOSE1 >;==========/; Ferme une dbox, reprend le fond, rcupre la souris, etc..; in	-; out	D7.16	erreur; mod	D7.16;--------\\; DB_POS5 >;========/; Centre ventuellement les dbox selon les icnes de gauche.; in	D2.16	mode d'ouverture; out	D2.16	mode d'ouverture;	D5.32	position (y;x); mod	D2.32, D5.32, D7.16;--------\\; DB_POS3 >;========/; Centre ventuellement les dbox selon les icnes de gauche.; in	D2.16	mode d'ouverture; out	D2.16	mode d'ouverture;	D3.32	position (y;x); mod	D2.32, D3.32, D7.16;-----------\\; DB_ZEROCR  >;===========/; Remplace le terminateur <CR> par <0>.; Utile aprs DBOX_EDIT par exemple !; in	A3.32	^chane termine par <CR> ou <0>; out	A3.32	^chane termine par <0>; mod	-;-----------\\; DB_ERCALL  >;===========/; Excute un appel systme en essayant de rsoudre qq problmes.; in	D0.32	code de l'appel (par exemple #FOS?OPEN);	+ selon appel; out	+ selon appel;	D7.16	erreur (ERKSTO si annule); mod	D7.16;---------\\; DB_MEMPT >;=========/; Donne le ^ la table de la dbox.; in	A2.32	^table de la dbox; out	-; mod	D7.16;----------\\; DB_MEMAFC >;==========/; Donne le ^ la routine d'affichage que PAGE utilisera pendant le DB_CLIC.; in	A2.32	^routine (*); out	-; mod	D7.16; Dfinition de la routine (*) :;; in	D2.16	mode (CLRDOT/SETDOT);	D5.32	canal dbox;	A5.32	^variables pour put/get; out	-; mod	D7.16;---------\\; DB_MEDIT >;=========/; Donne la bonne valeur  DBOX_MEDIT.; in	D2.16	rang (0..n);	D5.32	canal dbox; out	-; mod	D7.16;-------\\; DB_AFF >;=======/; Affiche un paramtre ditable.; in	A3.32	^dbut ligne;	D2.16	rang (0..n);	D5.32	canal dbox; out	-; mod	D7.16;-------\\; DB_GET >;=======/; Donne le contenu d'un paramtre ditable.; in	D2.16	rang (0..n);	D5.32	canal dbox;	A5.32	^variables pour put/get; out	A3.32	^dbut ligne;	A4.32	^curseur dans ligne; mod	D7.16, A3.32, A4.32;-------\\; DB_PUT >;=======/; Met  jour un paramtre ditable.; in	A3.32	^dbut ligne;	D2.16	rang (0..n);	D5.32	canal dbox;	A5.32	^variables pour put/get; out	D7.16	erreur; mod	D7.16;--------\\; DB_CLIC >;========/; Incrmente un paramtre ditable, si la souris est sur une flche +/-.; in	A3.32	^dbut ligne;	D2.16	rang (0..n);	D5.32	canal dbox;	A5.32	^variables pour put/get; out	D2.16	rang (0..n);	A3.32	^dbut ligne;	A4.32	^curseur dans ligne; mod	D2.32, D7.16, A3.32, A4.32;---------\\; DB_HLINE >;=========/; Trace une ligne horizontale dans une dbox.; in	D2.16	rang de l'objet; out	D3.32	position d'arrive; mod	D3.32, D7.16;-------\\; DB_RSK >;=======/; Refait les soft-keys.; in	A2.32	^table DBOX; out	-; mod	D7.16;-----------\\; DB_IMALOAD >;===========/; Charge une image en mmoire.; in	A3.32	^nom de l'image; out	A4.32	^image;	D4.32	dimensions (dy;dx);	D7.16	erreur; mod	A4.32, D7.16, A4.32;-----------\\; DB_IMASHOW >;===========/; Affiche une image dans la (sous-)fentre.; Si elle est trop petite, elle est centre au milieu de l'cran.; Si elle est trop grande, on affiche sa partie centrale.; in	A4.32	^image;	D4.32	dimensions (dy;dx);	D3.32	coin sup/gauche (y;x); out	-; mod	D7.16;-----------\\; DB_IMAKILL >;===========/; Libre la mmoire d'une image.; in	A4.32	^image; out	-; mod	-;---------\\; DB_ERROR >;=========/; Affiche une erreur.; in	D4.16	erreur  afficher; out	D7.16	erreur; mod	D7.16;-----------\\; _PAGE_MISC >;===========/; in	D7.16	sous-appel;	+	selon appel; out	+	selon appel;	D7.16	erreur; mod	D7.16, +;-----------\\; MI_MMENUS  >;===========/; Attend un choix selon un mmenu hirarchique.; in	A3.32	^mmenu;	A4.32	^paramtres; out	D7.16	erreur; mod	D7.16;-------------\\; MI_WAITEVENT >;=============/; Attend un vnement, avec timeout.; in	D3.16	timeout; out	D3.32	touche presse;	D4.32	position souris (si D3=KEYM?P);	D7.16	NE si timeout; mod	D3.32, D4.32, D7.16;-------------\\; MI_TESTEVENT >;=============/; Teste si un vnement est l, sans le lire.; in	-; out	D3.32	touche presse;	D4.32	position souris (si D3=KEYM?P);	D7.16	erreur; mod	D3.32, D4.32, D7.16;------------\\; MI_EDITVISU >;============/; Dplace la partie visible (si ncessaire) pour que le curseur; soit visible.; in	A4.32	^objet texte; out	-; mod	D7.16;--------------\\; MI_IFVIEWHIDE >;==============/; Active ou dsactive le mcanisme "opVIEWHIDE".; Les mthodes "opVIEWHIDE" ne sont excutes,  chaque changement de; page, que si MI_IFVIEWHIDE avec D3=1  t fait (par exemple par la; mthode "opOPEN" d'un objet).; in	D3.16	0=dsactive, 1=active; out	-; mod	D7.16;-----------\\; MI_PUTUNUM >;===========/; Met un nombre avec des units dans un buffer.; in	D4.16	nombre [obj];	A4.32	^buffer; out	A4.32	^plus loin; mod	D7.16, A4.32;-----------\\; MI_GETUNUM >;===========/; Donne un nombre avec des units.; in	A4.32	^dans buffer; out	A4.32	^plus loin;	D4.16	nombre [obj]; mod	D4.32, D7.16, A4.32;-----------\\; MI_PUTANUM >;===========/; Met un nombre dcimal dans un buffer.; in	D4.32	nombre;	A4.32	^dans buffer; out	A4.32	^plus loin; mod	A4.32;-----------\\; MI_GETANUM >;===========/; Donne un nombre dcimal.; in	A4.32	^dans buffer; out	A4.32	^plus loin;	D4.32	nombre; mod	D4.32, A4.32;-----------\\; MI_CCMO    >;===========/; Enlve la souris.; in	-; out	-; mod	D7.16;-----------\\; MI_SCMO    >;===========/; Remet la souris.; in	-; out	-; mod	D7.16;-------------\\; MI_WAITMOUSE >;=============/; Met la souris en attente (sablier).; in	-; out	-; mod	-;-------------\\; MI_NORMMOUSE >;=============/; Remet la flche de la souris.; in	-; out	-; mod	-;-----------\\; _PAGE_MATH >;===========/; in	D7.16	sous-appel;	+	selon appel; out	+	selon appel;	D7.16	erreur; mod	D7.16, +;-----------\\; MA_RECTAND >;===========/; Effectue un "et" (intersection) entre deux rectangles.; in	D1/D2	P1/P2 rectangle A;	D3/D4	P1/P2 rectangle B; out	D3/D4	P1/P2 rectangle A & B; mod	D3.32, D4.32;-----------\\; MA_RECTOR  >;===========/; Effectue un "ou" (union) entre deux rectangles.; in	D1/D2	P1/P2 rectangle A;	D3/D4	P1/P2 rectangle B; out	D3/D4	P1/P2 rectangle A ! B; mod	D3.32, D4.32;------------\\; MA_RECTTEST >;============/; Teste si un rectangle B est inclu dans un rectangle A.; in	D1/D2	P1/P2 rectangle A;	D3/D4	P1/P2 rectangle B; out	D7.16	nb de points de B inclus dans A; mod	D7.16;-----------\\; MA_DETLINE >;===========/; Dtection fine (et lente) pour voir si la souris est dans une droite.; Pour calculer la distance entre un point et une droite, utilise la; formule suivante :;	         Ly * (Px-Dx);	l = Py - ------------ - Dy;	              Lx; Avec :;	Px/Py: position de la souris;	Dx/Dy: origine de la droite;	Lx/Ly: dimensions de la droite; Remarque :;	Si Lx < Ly => on inverse X/Y dans la formule !;	Si Lx ou Ly est nul => on accepte de toute faon; in	D2.16	marge de dtection (0..n);	D3.32	P1 (y;x);	D4.32	P2 (y;x);	D5.32	position de la souris (y;x); out	D7.16	erreur; mod	D7.16;-------------\\; MA_DETBEZIER >;=============/; Dtection pour voir si la souris est sur une courbe de Bzier.; in	D2.16	marge de dtection (0..n);	D3.32	P1 (y;x);	D4.32	C1 (y;x);	D5.32	C2 (y;x);	D6.32	P2 (y;x);	D1.32	position de la souris (y;x); out	D7.16	erreur; mod	D7.16;--------------\\; MA_BBOXBEZIER >;==============/; Calcule la "bounding box" d'une courbe de Bzier.; in	D3.32	P1 (y;x);	D4.32	C1 (y;x);	D5.32	C2 (y;x);	D6.32	P2 (y;x); out	D3.32	P1 (y;x) coin sup/gauche;	D4.32	P2 (y;x) coin inf/droite; mod	D3.32, D4.32, D7.16;----------\\; MA_FIXMUL >;==========/; in	D1.32	nombre  virgule fixe no 1;	D2.32	nombre  virgule fixe no 2; out	D0.32	nombre  virgule fixe rsultant;	VS	si dpassement de capacit (dans ce cas D0=max_fix ou min_fix selon signes); mod	D0.32;----------\\; MA_FIXDIV >;==========/; in	D1.32	nombre  virgule fixe numrateur;	D2.32	nombre  virgule fixe dnominateur; out	D0.32	nombre  virgule fixe rsultant;	VS	si dpassement de capacit (dans ce cas D0=max_fix ou min_fix selon signes); mod	D0.32;------------\\; MA_INTMUL32 >;============/; Module de multiplication 32*32 --> 64 bits (non-sign).;	-------------------;	 D1&D0 <-- D2 * D3;	-------------------; in	D2.32	multiplicande (32 bits non-sign);	D3.32	multiplicateur (32 bits non-sign); out	D1&D0.32	rsultat (64 bits non-sign); mod	D0.32, D1.32;------------\\; MA_INTDIV32 >;============/; Module de division 64/32 --> 32 bits (non-sign).;	-------------------;	 D3 <-- D1&D0 / D2;	 D4 <-- reste;	-------------------; ATTENTION: pas de test de division par zro !; in	D1&D0.32	numrateur (64 bits non-sign);	D2.32	dnominateur (32 bits non-sign); out	D3.32	rsultat (32 bits non-sign);	D4.32	reste (32 bits non-sign);	VS	overflow; mod	D3.32, D4.32;	Dfinition des units utilises;	-------------------------------;	;	Par dfinition, un point interne [obj] mesure 0.02mm, quelque soit l'imprimante.;	;	        Xpt;	Xmm = ------;	        50;	;	           Xpt;	Xin = ------------;	        50 * 25.4;	;	           Xpt;	Xdi = -------------;	       50 * 0.3759;	;	        6 * Xpt;	Xpi = -----------;	       50 * 25.4;	;	             Xpt;	Xci = ------------------;	       12 * 50 * 0.3759;	;	Une coordonne est code sur 16 bits signs. Dans la page, les;	nombres doivent tre positifs. Il en rsulte les limites suivantes :;	;	0 < Xpt < 2^15;	0 < Xmm < 655.36;	0 < Xin < 25.8;	;	Donc, la plus grande dimension est de 655mm ou 25.8in !;	;	Choix de la rsolution  utiliser pour l'affichage  l'chelle 100% :;	;	SMAKY       pt    mm    pt/mm;	------------------------------;	SM324.x    864   230     3.76;	SM324.y   1024   300     3.41   moyenne = 3.59;	;	SM100.x    640   220     2.91;	SM100.y    400   142     2.82   moyenne = 2.87;	;	;	SCALE  pt/mm     SM324   SM100;	-------------------------------;	 +4   200.00     5600%   7200%;	 +3   150.00     4200%   5400%;	 +2   100.00     2800%   3600%;	  0    50.00     1400%   1800%   <---  [scr] = [obj];	 -2    25.00      700%    900%;	 -3    12.50      467%    600%;	 -4    12.50      350%    450%;	 -6     8.33      233%    300%;	 -8     6.25      175%    225%;	-12     4.17      117%    150%;	-14     3.57      100%    129%   <---  100% sur SMAKY 324;	-16     3.13       88%    113%;	-18     2.78       78%    100%   <---  100% sur SMAKY 100;	-24     2.08       58%     75%;	-32     1.56       44%     56%;	-48     1.04       29%     38%;	-64     0.78       22%     28%;--------------\\; MA_CONVSCROBJ >;==============/; Conversion d'une coordonne cran --> objet.; in	D4.32	coordonne cran (y;x); out	D4.32	coordonne objet (y;x);	D7.16	erreur; mod	D4.32, D7.16;--------------\\; MA_CONVOBJSCR >;==============/; Conversion d'une coordonne objet --> cran.; in	D4.32	coordonne objet (y;x); out	D4.32	coordonne cran (y;x);	D7.16	erreur; mod	D4.32, D7.16;---------------\\; MA_CONVOBJDRAW >;===============/; Conversion d'une coordonne objet --> cran pour dessiner.; in	D4.32	coordonne objet (y;x); out	D4.32	coordonne cran (y;x);	D7.16	erreur; mod	D4.32, D7.16;----------\\; MA_SCALEN >;==========/; Tient compte de l'chelle ngativement.; in	D4.32	(y;x); out	D4.32	(y;x) plus petit si n:1;	D7.16	erreur; mod	D4.32, D7.16;----------\\; MA_SCALEP >;==========/; Tient compte de l'chelle positivement.; in	D4.32	(y;x); out	D4.32	(y;x) plus grand si n:1;	D7.16	erreur; mod	D4.32, D7.16;---------\\; _PAGE_IO >;=========/; in	D7.16	sous-appel;	+	selon appel; out	+	selon appel;	D7.16	erreur; mod	D7.16, +;-----------\\; IO_RDOPEN  >;===========/; Ouvre le fichier en entre.; in	A3.32	^nom du fichier; out	D7.16	erreur; mod	D7.16;-----------\\; IO_RDMANY  >;===========/; Lit plusieurs bytes dans le fichier en entre.; in	A4.32	^buffer;	D4.16	nombre de bytes  lire; out	{A4}++	bytes lus;	D4.16	nombre de bytes lus;	D7.16	erreur; mod	D4.32, D7.16;-----------\\; IO_RDONE   >;===========/; Lit un byte dans le fichier d'entre.; in	-; out	D3.8	byte lu;	D7.16	erreur; mod	D3.32, D7.16;-----------\\; IO_RDCLOSE >;===========/; Ferme le fichier en entre.; in	D7.16	ok/erreur; out	D7.16	erreur; mod	D7.16;-----------\\; IO_WROPEN  >;===========/; Ouvre le fichier en sortie.; in	A3.32	^nom du fichier; out	D7.16	erreur; mod	D7.16;-----------\\; IO_WRMANY  >;===========/; Ecrit plusieurs bytes dans le fichier de sortie.; in	A4.32	^bytes  crire;	D4.16	nombre de bytes  crire; out	D7.16	erreur; mod	D7.16;-----------\\; IO_WRONE   >;===========/; Ecrit un byte dans le fichier de sortie.; in	D3.8	byte  crire; out	D7.16	erreur; mod	D7.16;-----------\\; IO_WRCLOSE >;===========/; Ecrit le reste du fichier de sortie, puis ferme.; in	D7.16	ok/erreur; out	D7.16	erreur; mod	D7.16;-------------\\; IO_WRASSFILE >;=============/; Ajoute un nom de fichier dans le fichier "!PAGE".; Si ce nom y est dj, il n'est pas ajout.; in	A3.32	^nom  ajouter dans "!PAGE"; out	D7.16	erreur; mod	D7.16;------------\\; IO_DICOLOAD >;============/; Donne le canal du dictionnaire, en le chargeant au pralable; si ncessaire.; in	-; out	D6.32	canal DICO;	D7.16	erreur; mod	D6.32, D7.16;--------------\\; IO_DICOSTATUS >;==============/; Donne l'tat de chargement du dictionnaire.; in	-; out	D4.16	0 => dictionnaire pas charg;	D7.16	erreur si module DICO absent; mod	D4.32, D7.16;-------------\\; IO_MESSGETPT >;=============/; Donne le pointeur pour les messages.; in	-; out	A4.32	adresse donne par "PAGE adresse/X", voir (**);	D7.16	erreur; mod	D7.16, A4.32; (**);	{A4}+0.32	^BAL des messages reus par PAGE;	{A4}+4.32	^BAL des messages envoys depuis PAGE;	{A4}+8		 dfinir