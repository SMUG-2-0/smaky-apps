	.SBTTL	PAGELST.ASI; Descripteur d'une racine; ------------------------		.PC	PCVAR		.LOC	0OobjIDENT:	.BLKB	2		; identificateurOobjBBOX1:	.BLKB	4		; P1 bounding boxOobjBBOX2:	.BLKB	4		; P2 bounding boxOobjFLAGS:	.BLKB	1		; flags BobjEXTEND	=  0			;  objet tendu BobjEDIT	=  1			;  objet dit BobjCREATE	=  2			;  objet en cours de cration BobjABS	=  3			;  coordonnes absolues BobjFLAG	=  4			;  flag divers		.BLKB	1		; rserveOobjPPERE:	.BLKB	4		; ^preOobjPPFILS:	.BLKB	4		; ^premier fils (benjamin)OobjPDFILS:	.BLKB	4		; ^dernier fils (an)OobjPSFRERE:	.BLKB	4		; ^suivant frreOobjPPFRERE:	.BLKB	4		; ^prcdent frreOobjNB:		.BLKB	2		; nb d'lmentsOobjPDATA:	.BLKB	4		; ^instance de l'objetOobjPCOPY:	.BLKB	4		; ^copie de l'instance de l'objetLobj:		.PC	PCCODE;----------\\; LSTA_OPEN >;==========/; Plante un nouvel arbre prt  l'emploi.; in	-; out	D6.L	canal de l'arbre;	D7.W	erreur; mod	D6.L, D7.WLSTA_OPEN:	PUSHM.L	D4,A4	LOAD.W	D4,#Lobj	LOAD.L	A4,#0		; A4 <-- insre  la tte	LOAD.L	D6,(A6)+ORALCH	CALL	LST_INSERT	; A4 <-- ^racine de l'arbre	JUMP',NE EXIT$	LOAD.L	D6,A4		; D6 <-- canal de l'arbreEXIT$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; LSTA_CLOSE >;===========/; Dracine dfinitivement un bel arbre.; L'arbre doit tre entirement vide !; in	D6.L	canal de l'arbre; out	D7.W	erreur; mod	D7.WLSTA_CLOSE:	PUSHM.L	D6,A4	LOAD.L	A4,D6		; A4 <-- ^racine de l'arbre	LOAD.W	D7,#1	TEST.L	(A4)+OobjPPFILS	JUMP',NE EXIT$	TEST.L	(A4)+OobjPDFILS	JUMP',NE EXIT$	LOAD.L	D6,(A6)+ORALCH	CALL	LST_REMOVE	; supprime la racine de l'arbreEXIT$:	POPM.L	D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; LSTA_NB >;========/; Donne le nombre de fils d'un pre; in	A4.L	^objet pre; out	D4.W	nb de fils; mod	D4.L, D7.WLSTA_NB:	LOAD.W	D4,(A4)+OobjNB	; D4 <-- nb de fils	RET;------------\\; LSTA_INSERT >;============/; Insre un nouvel lment dans l'arbre.; in	D6.L	canal de l'arbre;	D4.W	longueur de l'lment;	A3.L	^lment pre (si zro => selon A4.L);	A4.L	^lment frre cadet (si zro =>  la tte); out	A4.L	^lment initialis avec des zro;	D7.W	erreur; mod	D7.W, A4.LLSTA_INSERT:	PUSHM.L	D3..D6,A1..A3	LOAD.L	D5,D6	LOAD.L	A1,A3	LOAD.L	A2,A4	LOAD.W	D3,D4	LOAD.W	D4,#Lobj	LOAD.L	A4,#0	LOAD.L	D6,(A6)+ORALCH	CALL	LST_INSERT	; A4 <-- ^lment racine	JUMP,NE EXIT$	LOAD.W	D4,D3		; D4 <-- lg pour data	JUMP',EQ NODATA$	LOAD.L	A3,A4	LOAD.L	A4,#0	LOAD.L	D6,(A6)+ODALCH	CALL	LST_INSERT	; A4 <-- ^lment data	JUMP,NE ERRMEM$	LOAD.L	(A3)+OobjPDATA,A4	LOAD.L	A4,A3NODATA$:	COMP.L	A1,#0	JUMP',NE PERE$	COMP.L	A2,#0	JUMP',NE FRERE$	LOAD.L	A1,D5		; A1 <-- ^prePERE$:	LOAD.L	A3,A1		; A3 <-- ^pre	CALL	ARBREADDFI	; ajoute un fils au pre	JUMP'	OK$FRERE$:	LOAD.L	A3,A2		; A3 <-- ^frre cadet	CALL	ARBREADDFA	; ajoute un frre an au fils;	JUMP'	OK$OK$:	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$ERRMEM$:	PUSH.W	D7	LOAD.L	A4,A3	LOAD.L	D6,(A6)+ORALCH	CALL	LST_REMOVE	; supprime l'lment racine	POP.W	D7EXIT$:	POPM.L	D3..D6,A1..A3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; LSTA_FLUSH >;===========/; Supprime tous les fils d'un lment dans l'arbre.; L'lment lui-mme (le pre) est conserv !; in	A4.L	^lment; out	-; mod	D7.WLSTA_FLUSH:	PUSHM.L	D4,A3,A4	LOAD.L	A3,A4		; A3 <-- ^preLOOP$:	LOAD.L	D4,(A3)+OobjPPFILS	JUMP',EQ EXIT$	LOAD.L	A4,D4		; A4 <-- ^fils benjamin	CALL	LSTA_REMOVE	; supprime un fils	JUMP	LOOP$EXIT$:	POPM.L	D4,A3,A4	RET;------------\\; LSTA_REMOVE >;============/; Supprime un lment dans l'arbre.; Si l'lment a des fils, petits-fils, etc., ils sont tous supprims !; in	A4.L	^lment  supprimer; out	-; mod	D7.WLSTA_REMOVE:	PUSHM.L	D4,A3,A4	LOAD.L	A3,A4		; A3 <-- ^preLOOP$:	LOAD.L	A4,A3		; A4 <-- ^pre	TEST.L	(A4)+OobjPDFILS	; y a-t-il un fils ?	JUMP',EQ PERE$		; non => PERE$FILS$:	LOAD.L	D4,(A4)+OobjPDFILS	JUMP',EQ KILL$	LOAD.L	A4,D4		; A4 <-- ^fils	JUMP	FILS$KILL$:	CALL'	ARBREREMOVE	; supprime un fils	JUMP	LOOP$PERE$:	CALL'	ARBREREMOVE	; supprime le pre	POPM.L	D4,A3,A4	RET;------------\\; ARBREREMOVE >;------------/; Supprime un lment dans l'arbre.; L'lment ne doit plus avoir de fils !; in	A4.L	^lment  supprimer; out	-; mod	D7.WARBREREMOVE:	PUSHM.L	D1,D6,A3,A4	CALL	_3SUITEREMOVE	; enlve v. de la chane	LOAD.W	D1,#opCRCLOSE	CALL	OBJCALLD	; ferme l'objet	CALL	ARBRESUB	; enlve de l'arbre	TEST.L	(A4)+OobjPDATA	JUMP',EQ NODATA$	LOAD.L	A3,A4	LOAD.L	A4,(A3)+OobjPDATA	LOAD.L	D6,(A6)+ODALCH	CALL	LST_REMOVE	; libre l'lment data	LOAD.L	A4,A3NODATA$:	LOAD.L	D6,(A6)+ORALCH	CALL	LST_REMOVE	; libre l'lment racine	POPM.L	D1,D6,A3,A4	RET;----------\\; LSTA_EXFC >;==========/; Permute deux frres. Le frre an devient le cadet !; in	A3.L	^frre cadet;	A4.L	^frre an; out	-; mod	D7.WLSTA_EXFC:	CALL	ARBRESUB	; enlve de l'arbre	CALL	ARBREADDFC	; ajoute en tant que fils cadet	RET;----------\\; LSTA_EXFA >;==========/; Permute deux frres. Le frre an devient le cadet !; in	A3.L	^frre cadet;	A4.L	^frre an; out	-; mod	D7.WLSTA_EXFA:	CALL	ARBRESUB	; enlve de l'arbre	CALL	ARBREADDFA	; ajoute en tant que fils cadet	RET;----------\\; LSTA_HEAD >;==========/; Place un lment au dbut de l'arbre.; in	D6.L	canal de l'arbre;	A4.L	^lment; out	D7.W	erreur; mod	D7.WLSTA_HEAD:	PUSHM.L	A3,A4	TEST.L	(A4)+OobjPSFRERE	JUMP',NE HEAD$	TEST.L	(A4)+OobjPPFRERE	JUMP',EQ OK$HEAD$:	CALL	ARBRESUB	; enlve de l'arbre	LOAD.L	A3,(A4)+OobjPPERE  ; A3 <-- ^pre	LOAD.L	A3,(A3)+OobjPPFILS ; A3 <-- ^fils benjamin	CALL	ARBREADDFC	; ajoute en tant que fils cadetOK$:	CLR.W	D7		; D7 <-- ok	POPM.L	A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; LSTA_TAIL >;==========/; Place un lment  la fin de l'arbre.; in	D6.L	canal de l'arbre;	A4.L	^lment; out	D7.W	erreur; mod	D7.WLSTA_TAIL:	PUSHM.L	A3,A4	TEST.L	(A4)+OobjPSFRERE	JUMP',NE HEAD$	TEST.L	(A4)+OobjPPFRERE	JUMP',EQ OK$HEAD$:	CALL	ARBRESUB	; enlve de l'arbre	LOAD.L	A3,(A4)+OobjPPERE  ; A3 <-- ^pre	LOAD.L	A3,(A3)+OobjPDFILS ; A3 <-- ^fils an	CALL	ARBREADDFA	; ajoute en tant que fils anOK$:	CLR.W	D7		; D7 <-- ok	POPM.L	A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; LSTA_FILS >;==========/; Regarde si un lment est (petit-)fils d'un pre, c'est--dire; s'il fait partie de la descendance du pre.; in	A3.L	^lment pre;	A4.L	^lment suppos (petit-)fils; out	D7.W	erreur (si pas de la mme descendance); mod	D7.WLSTA_FILS:	PUSHM.L	D4,A4	LOAD.L	D7,#1LOOP$:	LOAD.L	D4,(A4)+OobjPPERE ; pre existe ?	JUMP',EQ EXIT$		; non => EXIT$	LOAD.L	A4,D4		; A4 <-- ^pre	COMP.L	A4,A3		; a-t-on trouv le pre ?	JUMP,NE LOOP$		; non => LOOP$	CLR.W	D7		; D7 <-- filsEXIT$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; LSTA_FRERE >;===========/; Regarde si deux lments sont frres.; in	A3.L	^lment;	A4.L	^lment; out	D7.W	erreur (si pas frres); mod	D7.WLSTA_FRERE:	PUSH.L	D4	LOAD.W	D7,#1	LOAD.L	D4,(A4)+OobjPPERE	COMP.L	D4,(A3)+OobjPPERE ; ont-ils le mme pre ?	JUMP',NE EXIT$	CLR.W	D7EXIT$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; LSTA_BBOX >;==========/; Donne la "bounding box" absolue d'un objet.; in	A4.L	^racine de l'objet; out	D3/D4	bbox (p1/p2); mod	D3.L, D4.L, D7.WLSTA_BBOX:	CALL'	LSTA_POS	; met  jour OAPOSLSTA_BBOXQ:	LOAD.L	D3,(A4)+OobjBBOX1	LOAD.L	D4,(A4)+OobjBBOX2 ; D3/D4 <-- bbox relative au pre	TEST.B	(A4)+OobjFLAGS:#BobjABS	JUMP',BS EXIT$	ADD.W	D3,(A6)+OAPOS+2	ADD.W	D4,(A6)+OAPOS+2	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,(A6)+OAPOS+0	ADD.W	D4,(A6)+OAPOS+0	SWAP.W	D3	SWAP.W	D4EXIT$:	RET;---------\\; LSTA_POS >;=========/; Met  jour la position absolue en fonction d'un objet.; in	A4.L	^racine de l'objet; out	-; mod	D7.WLSTA_POS:	PUSHM.L	D3,D4,A4	CLR.L	D3	TEST.B	(A4)+OobjFLAGS:#BobjABS	JUMP',BS END$LOOP$:	LOAD.L	D4,(A4)+OobjPPERE	JUMP',EQ END$	LOAD.L	A4,D4		; A4 <-- ^pre	ADD.W	D3,(A4)+OobjBBOX1+2	SWAP.W	D3	ADD.W	D3,(A4)+OobjBBOX1+0	SWAP.W	D3	JUMP	LOOP$END$:	LOAD.L	(A6)+OAPOS,D3	; OAPOS <-- position absolue	POPM.L	D3,D4,A4	RET;-----------\\; LSTA_YOUNG >;===========/; Cherche le frre benjamin d'un objet.; in	A4.L	^lment; out	A4.L	^lment frre benjamin; mod	D7.W, A4.LLSTA_YOUNG:	LOAD.L	A4,(A4)+OobjPPERE	LOAD.L	A4,(A4)+OobjPPFILS	RET;---------\\; LSTA_OLD >;=========/; Cherche le frre an d'un objet.; in	A4.L	^lment; out	A4.L	^lment frre an; mod	D7.W, A4.LLSTA_OLD:	LOAD.L	A4,(A4)+OobjPPERE	LOAD.L	A4,(A4)+OobjPDFILS	RET;--------------\\; LSTA_PCSEARCH >;==============/; Cherche dans quelle page et dans quel calque se trouve un objet quelconque.; in	A4.L	^lment; out	D3.W	page (0..n,-1);	D4.W	calque (0..n,-1); mod	D3.L, D4.L, D7.WLSTA_PCSEARCH:	PUSHM.L	D2,A2..A4	LOAD.W	D3,#-1		; D3 <-- page inconnue	LOAD.W	D4,D3		; D4 <-- calque inconnu	LOAD.L	A2,#0	LOAD.L	A3,#0FLOOP$:	LOAD.L	D2,(A4)+OobjPPERE ; pre existe ?	JUMP',EQ CALQ$		; non => CALQ$	LOAD.L	A2,A3		; A2/A3/A4 <-- "fifo"	LOAD.L	A3,A4	LOAD.L	A4,D2		; A4 <-- ^pre	JUMP	FLOOP$CALQ$:	COMP.L	A2,#0	JUMP',EQ PAGE$CLOOP$:	INC.W	D4	LOAD.L	D2,(A2)+OobjPPFRERE ; frre cadet existe ?	JUMP',EQ PAGE$		; non => PAGE$	LOAD.L	A2,D2		; A2 <-- ^frre cadet	JUMP	CLOOP$PAGE$:	COMP.L	A3,#0	JUMP',EQ EXIT$PLOOP$:	INC.W	D3	LOAD.L	D2,(A3)+OobjPPFRERE ; frre cadet existe ?	JUMP',EQ EXIT$		; non => EXIT$	LOAD.L	A3,D2		; A3 <-- ^frre cadet	JUMP	PLOOP$EXIT$:	POPM.L	D2,A2..A4	TEST.W	D7		; retour EQ/NE	RET;-------------\\; LSTA_PCFIRST >;=============/; Cherche le premier lment dans la page et le calque courant.; in	-; out	A4.L	^premier lment;	D7.W	erreur; mod	D7.W, A4.LLSTA_PCFIRST:	PUSHM.L	D3,D4,D6	LOAD.W	D3,(A6)+OPAGE	; D3 <-- page visible	LOAD.W	D4,(A6)+OCALQ	; D4 <-- calque visible	LOAD.L	D6,(A6)+OOBACH	; D6 <-- canal de l'arbre des objets	CALL'	LSTA_FIRST	; A4 <-- ^lment de base	POPM.L	D3,D4,D6	TEST.W	D7		; retour EQ/NE	RET;-----------\\; LSTA_FIRST >;===========/; Cherche le premier lment dans une page et dans un calque.; in	D6.L	canal de l'arbre;	D3.W	page (0..n,-1);	D4.W	calque (0..n,-1); out	A4.L	^premier lment;	D7.W	erreur; mod	D7.W, A4.LLSTA_FIRST:	CALL	LSTA_BEGIN	; A4 <-- ^lment de base	JUMP',NE EXIT$	CALL	LSTA_NEXT	; A4 <-- ^premier lmentEXIT$:	TEST.W	D7		; retour EQ/NE	RET;------------\\; LSTA_PCLAST >;============/; Cherche le dernier lment dans la page et le calque courant.; in	-; out	A4.L	^dernier lment;	D7.W	erreur; mod	D7.W, A4.LLSTA_PCLAST:	PUSHM.L	D3,D4,D6	LOAD.W	D3,(A6)+OPAGE	; D3 <-- page visible	LOAD.W	D4,(A6)+OCALQ	; D4 <-- calque visible	LOAD.L	D6,(A6)+OOBACH	; D6 <-- canal de l'arbre des objets	CALL'	LSTA_LAST	; A4 <-- ^lment de base	POPM.L	D3,D4,D6	TEST.W	D7		; retour EQ/NE	RET;----------\\; LSTA_LAST >;==========/; Cherche le dernier lment (celui  la fin de l'arbre).; in	D6.L	canal de l'arbre;	D3.W	page (0..n,-1);	D4.W	calque (0..n,-1); out	A4.L	^dernier lment;	D7.W	erreur; mod	D7.W, A4.LLSTA_LAST:	PUSHM.L	D3,D4	CALL	LSTA_BEGIN	; A4 <-- ^lment de base	JUMP',NE EXIT$	LOAD.W	D7,#1		; D7 <-- aucun lment	TEST.L	(A4)+OobjPDFILS	JUMP',EQ EXIT$	CLR.W	D7		; D7 <-- okLOOP$:	LOAD.L	D4,(A4)+OobjPDFILS	JUMP',EQ EXIT$	LOAD.L	D3,(A4)+OobjBBOX1	ADD.W	(A6)+OAPOS+2,D3	SWAP.W	D3	ADD.W	(A6)+OAPOS+0,D3	LOAD.L	A4,D4		; A4 <-- ^fils an	JUMP	LOOP$EXIT$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; LSTA_BEGIN >;===========/; Cherche l'lment de base dans une page et dans un calque.; in	D6.L	canal de l'arbre;	D3.W	page (0..n,-1);	D4.W	calque (0..n,-1); out	A4.L	^lment de base;	D7.W	erreur; mod	D7.W, A4.LLSTA_BEGIN:	PUSHM.L	D2..D4	CLR.L	(A6)+OAPOS	LOAD.L	A4,D6		; A4 <-- ^document	COMP.W	D3,#-1		; cherche une page donne ?	JUMP',EQ FOUND$		; non => FOUND$	LOAD.L	D2,(A4)+OobjPPFILS	JUMP',EQ ERROR$	LOAD.L	A4,D2		; A4 <-- ^premire pagePLOOP$:	DEC.W	D3	JUMP',NS PEND$	LOAD.L	D2,(A4)+OobjPSFRERE	JUMP',EQ ERROR$	LOAD.L	A4,D2		; A4 <-- ^page suivante	JUMP	PLOOP$PEND$:	COMP.W	D4,#-1		; cherche un calque donn ?	JUMP',EQ FOUND$		; non => FOUND$	LOAD.L	D2,(A4)+OobjPPFILS	JUMP',EQ ERROR$	LOAD.L	A4,D2		; A4 <-- ^premier calqueCLOOP$:	DEC.W	D4	JUMP',NS FOUND$	LOAD.L	D2,(A4)+OobjPSFRERE	JUMP',EQ ERROR$	LOAD.L	A4,D2		; A4 <-- ^calque suivant	JUMP	CLOOP$FOUND$:	LOAD.L	(A6)+OARLIM,A4	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$ERROR$:	LOAD.W	D7,#1		; D7 <-- aucun lmentEXIT$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; LSTA_NEXTF >;===========/; Cherche l'objet suivant dans un arbre, sans tenir compte des fils ventuels.; in	A4.L	^racine de l'objet; out	A4.L	^racine de l'objet suivant;	D7.W	erreur; mod	D7.W, A4.LLSTA_NEXTF:	PUSHM.L	D3,D4NEXT$:	LOAD.L	D4,(A4)+OobjPSFRERE	JUMP',NE FRERE$	LOAD.L	D4,(A4)+OobjPPERE	JUMP',NE PERE$ERROR$:	LOAD.W	D7,#1		; D7 <-- pas de suivant	JUMP'	EXIT$PERE$:	COMP.L	D4,(A6)+OARLIM	; a-t-on atteint la limite ?	JUMP,EQ ERROR$		; oui => ERROR$	LOAD.L	A4,D4		; A4 <-- ^pre	LOAD.L	D3,(A4)+OobjBBOX1	SUB.W	(A6)+OAPOS+2,D3	SWAP.W	D3	SUB.W	(A6)+OAPOS+0,D3	JUMP	NEXT$FRERE$:	COMP.L	D4,(A6)+OARLIM	; a-t-on atteint la limite ?	JUMP,EQ ERROR$		; oui => ERROR$	LOAD.L	A4,D4		; A4 <-- ^frre suivant	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; LSTA_NEXT >;==========/; Cherche l'objet suivant dans un arbre.; in	A4.L	^racine de l'objet; out	A4.L	^racine de l'objet suivant;	D7.W	erreur; mod	D7.W, A4.LLSTA_NEXT:	PUSHM.L	D3,D4	LOAD.L	D4,(A4)+OobjPPFILS	JUMP',NE FILS$NEXT$:	LOAD.L	D4,(A4)+OobjPSFRERE	JUMP',NE FRERE$	LOAD.L	D4,(A4)+OobjPPERE	JUMP',NE PERE$ERROR$:	LOAD.W	D7,#1		; D7 <-- pas de suivant	JUMP'	EXIT$PERE$:	COMP.L	D4,(A6)+OARLIM	; a-t-on atteint la limite ?	JUMP,EQ ERROR$		; oui => ERROR$	LOAD.L	A4,D4		; A4 <-- ^pre	LOAD.L	D3,(A4)+OobjBBOX1	SUB.W	(A6)+OAPOS+2,D3	SWAP.W	D3	SUB.W	(A6)+OAPOS+0,D3	JUMP	NEXT$FILS$:	LOAD.L	D3,(A4)+OobjBBOX1	ADD.W	(A6)+OAPOS+2,D3	SWAP.W	D3	ADD.W	(A6)+OAPOS+0,D3FRERE$:	COMP.L	D4,(A6)+OARLIM	; a-t-on atteint la limite ?	JUMP,EQ ERROR$		; oui => ERROR$	LOAD.L	A4,D4		; A4 <-- ^premier fils ou frre suivant	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; LSTA_PREVP >;===========/; Cherche le pre d'un objet.; in	A4.L	^racine de l'objet; out	A4.L	^racine du pre;	D7.W	erreur; mod	D7.W, A4.LLSTA_PREVP:	LOAD.W	D7,#1		; D7 <-- pas de pre	TEST.L	(A4)+OobjPPERE	; pre existe ?	JUMP',EQ EXIT$		; non => EXIT$	LOAD.L	A4,(A4)+OobjPPERE ; A4 <-- ^pre	COMP.L	A4,(A6)+OARLIM	; a-t-on atteint la limite ?	JUMP',EQ EXIT$		; oui => EXIT$	CLR.W	D7		; D7 <-- okEXIT$:	TEST.W	D7		; retour EQ/NE	RET;----------\\; LSTA_PREV >;==========/; Cherche l'objet prcdent dans un arbre.; in	A4.L	^racine de l'objet; out	A4.L	^racine de l'objet prcdent;	D7.W	erreur; mod	D7.W, A4.LLSTA_PREV:	PUSHM.L	D3,D4	CLR.W	D7		; D7 <-- ok	LOAD.L	D4,(A4)+OobjPPFRERE	JUMP',NE FRERE$	LOAD.L	D4,(A4)+OobjPPERE	JUMP',NE PERE$ERROR$:	LOAD.W	D7,#1		; D7 <-- pas de prcdent	JUMP'	EXIT$FRERE$:	LOAD.L	A4,D4		; A4 <-- ^frre cadetFILS$:	LOAD.L	D4,(A4)+OobjPDFILS	JUMP',EQ EXIT$	LOAD.L	D3,(A4)+OobjBBOX1	ADD.W	(A6)+OAPOS+2,D3	SWAP.W	D3	ADD.W	(A6)+OAPOS+0,D3	LOAD.L	A4,D4		; A4 <-- ^fils an	JUMP	FILS$PERE$:	COMP.L	D4,(A6)+OARLIM	; a-t-on atteint la limite ?	JUMP,EQ ERROR$		; oui => ERROR$	LOAD.L	A4,D4		; A4 <-- ^pre	LOAD.L	D3,(A4)+OobjBBOX1	SUB.W	(A6)+OAPOS+2,D3	SWAP.W	D3	SUB.W	(A6)+OAPOS+0,D3EXIT$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ARBREADDFI >;-----------/; Ajoute un lment fils dans l'arbre.; Si le pre a dj des fils, l'lment ajout sera le fils an !; in	A4.L	^lment fils ( ajouter);	A3.L	^lment pre (rfrence); out	-; mod	D7.WARBREADDFI:	PUSHM.L	D4,A3	TEST.L	(A3)+OobjPDFILS	; est-ce que le pre a dj un fils ?	JUMP',NE FILS$		; oui => FILS$	CLR.L	(A4)+OobjPSFRERE	CLR.L	(A4)+OobjPPFRERE	LOAD.L	(A4)+OobjPPERE,A3	LOAD.L	(A3)+OobjPPFILS,A4	LOAD.L	(A3)+OobjPDFILS,A4	LOAD.W	D4,(A4)+OobjNB	INC.W	D4		; D4 <-- nb d'objets ajouts	LOAD.L	A3,A4ADD$:	TEST.L	(A3)+OobjPPERE	JUMP',EQ EXIT$	LOAD.L	A3,(A3)+OobjPPERE	ADD.W	(A3)+OobjNB,D4	; qq objets de plus	JUMP	ADD$FILS$:	LOAD.L	A3,(A3)+OobjPDFILS ; A3 <-- ^fils an	CALL	ARBREADDFA	; ajoute un frre an au filsEXIT$:	POPM.L	D4,A3	RET;-----------\\; ARBREADDFC >;-----------/; Ajoute un lment frre cadet dans l'arbre.; in	A4.L	^lment frre cadet ( ajouter);	A3.L	^lment frre an  (rfrence); out	-; mod	D7.WARBREADDFC:	PUSHM.L	D4,A2,A3	LOAD.L	(A4)+OobjPPERE,(A3)+OobjPPERE ; y z'on le mme pre	TEST.L	(A3)+OobjPPFRERE	JUMP',EQ NOCADET$	LOAD.L	A2,(A3)+OobjPPFRERE	LOAD.L	(A4)+OobjPSFRERE,A3	LOAD.L	(A4)+OobjPPFRERE,A2	LOAD.L	(A2)+OobjPSFRERE,A4	LOAD.L	(A3)+OobjPPFRERE,A4	JUMP'	OK$NOCADET$:	CLR.L	(A4)+OobjPPFRERE	LOAD.L	(A4)+OobjPSFRERE,A3	LOAD.L	(A3)+OobjPPFRERE,A4	LOAD.L	A2,(A3)+OobjPPERE	LOAD.L	(A2)+OobjPPFILS,A4;	JUMP'	OK$OK$:	LOAD.W	D4,(A4)+OobjNB	INC.W	D4		; D4 <-- nb d'objets ajouts	LOAD.L	A3,A4ADD$:	TEST.L	(A3)+OobjPPERE	JUMP',EQ EXIT$	LOAD.L	A3,(A3)+OobjPPERE	ADD.W	(A3)+OobjNB,D4	; qq objets de plus	JUMP	ADD$EXIT$:	POPM.L	D4,A2,A3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ARBREADDFA >;-----------/; Ajoute un lment frre an dans l'arbre.; in	A4.L	^lment frre an  ( ajouter);	A3.L	^lment frre cadet (rfrence); out	-; mod	D7.WARBREADDFA:	PUSHM.L	D4,A2,A3	LOAD.L	(A4)+OobjPPERE,(A3)+OobjPPERE ; y z'on le mme pre	TEST.L	(A3)+OobjPSFRERE	JUMP',EQ NOAINE$	LOAD.L	A2,(A3)+OobjPSFRERE	LOAD.L	(A4)+OobjPSFRERE,A2	LOAD.L	(A4)+OobjPPFRERE,A3	LOAD.L	(A3)+OobjPSFRERE,A4	LOAD.L	(A2)+OobjPPFRERE,A4	JUMP'	OK$NOAINE$:	CLR.L	(A4)+OobjPSFRERE	LOAD.L	(A4)+OobjPPFRERE,A3	LOAD.L	(A3)+OobjPSFRERE,A4	LOAD.L	A2,(A3)+OobjPPERE	LOAD.L	(A2)+OobjPDFILS,A4;	JUMP'	OK$OK$:	LOAD.W	D4,(A4)+OobjNB	INC.W	D4		; D4 <-- nb d'objets ajouts	LOAD.L	A3,A4ADD$:	TEST.L	(A3)+OobjPPERE	JUMP',EQ EXIT$	LOAD.L	A3,(A3)+OobjPPERE	ADD.W	(A3)+OobjNB,D4	; qq objets de plus	JUMP	ADD$EXIT$:	POPM.L	D4,A2,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; ARBRESUB >;---------/; Enlve un lment dans l'arbre.; in	A4.L	^lment  enlever; out	-; mod	D7.WARBRESUB:	PUSHM.L	D4,A1..A3	LOAD.W	D4,(A4)+OobjNB	INC.W	D4		; D4 <-- nb d'objets enlevs	LOAD.L	A3,A4SUB$:	TEST.L	(A3)+OobjPPERE	JUMP',EQ REM$	LOAD.L	A3,(A3)+OobjPPERE	SUB.W	(A3)+OobjNB,D4	; qq objets de moins	JUMP	SUB$REM$:	LOAD.L	A1,(A4)+OobjPPERE   ; A1 <-- ^pre	LOAD.L	A2,(A4)+OobjPPFRERE ; A2 <-- ^frre cadet	LOAD.L	A3,(A4)+OobjPSFRERE ; A3 <-- ^frre an	COMP.L	A2,#0	JUMP',EQ NOCADET$	LOAD.L	(A2)+OobjPSFRERE,A3	JUMP'	CADET$NOCADET$:	LOAD.L	(A1)+OobjPPFILS,A3CADET$:	COMP.L	A3,#0	JUMP',EQ NOAINE$	LOAD.L	(A3)+OobjPPFRERE,A2	JUMP'	AINE$NOAINE$:	LOAD.L	(A1)+OobjPDFILS,A2AINE$:	POPM.L	D4,A1..A3	RET;-------------\\; LSTO_HEXTEND >;=============/; Etend un objet quelconque pour les poignes.; in	A4.L	^objet; out	D7.W	erreur; mod	D7.WLSTO_HEXTEND:	PUSHM.L	D1,D3,D4,D6,A3,A4	LOAD.L	D6,(A6)+ODALCH	; D6 <-- canal de la liste des datas	LOAD.W	D1,#opHANDLGEXT	CALL	OBJCALLD	; D3/D4 <-- lg compact/tendu	JUMP',NE EXIT$	LOAD.L	A3,A4		; A3 <-- ^racine objet compact	LOAD.L	A4,#0		; A4 <-- insre  la tte	CALL	LST_INSERT	; A4 <-- ^data objet tendu	JUMP',NE EXIT$	TSET.B	(A3)+OobjFLAGS:#BobjEXTEND	PUSHM.L	A3,A4	LOAD.L	A3,(A3)+OobjPDATA ; A3 <-- ^data objet compact	SR.W	D3,#1		; D3 <-- /2 car .W	DEC.W	D3		; D3 <-- -1 car NMOXFER$:	LOAD.W	(A4+),(A3+)	; objet tendu <-- objet compact	DECJ.W,NMO D3,XFER$	POPM.L	A3,A4	LOAD.L	D4,A4	LOAD.L	A4,(A3)+OobjPDATA	LOAD.L	(A3)+OobjPDATA,D4	CALL	LST_REMOVE	; supprime le data de l'objet compactEXIT$:	POPM.L	D1,D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------------\\; LSTO_HCOMPACT >;==============/; Compacte un objet quelconque aprs les poignes.; in	A4.L	^objet; out	D7.W	erreur; mod	D7.WLSTO_HCOMPACT:	PUSHM.L	D1,D3,D4,D6,A3,A4	LOAD.L	D6,(A6)+ODALCH	; D6 <-- canal de la liste des datas	LOAD.W	D1,#opHANDLGCOM	CALL	OBJCALLD	; D3/D4 <-- lg tendu/compact	JUMP',NE EXIT$	LOAD.L	A3,A4		; A3 <-- ^racine objet tendu	LOAD.L	A4,#0		; A4 <-- insre  la tte	CALL	LST_INSERT	; A4 <-- ^data objet compact	JUMP',NE EXIT$	TCLR.B	(A3)+OobjFLAGS:#BobjEXTEND	PUSHM.L	A3,A4	LOAD.L	A3,(A3)+OobjPDATA ; A3 <-- ^data objet tendu	SR.W	D4,#1		; D4 <-- /2 car .W	DEC.W	D4		; D4 <-- -1 car NMOXFER$:	LOAD.W	(A4+),(A3+)	; objet compact <-- objet tendu	DECJ.W,NMO D4,XFER$	POPM.L	A3,A4	LOAD.L	D4,A4	LOAD.L	A4,(A3)+OobjPDATA	LOAD.L	(A3)+OobjPDATA,D4	CALL	LST_REMOVE	; supprime l'objet tendu	LOAD.L	A4,A3	LOAD.W	D1,#opGETBBOX	CALL	OBJCALLD	; D3/D4 <-- bounding box	LOAD.L	(A4)+OobjBBOX1,D3	LOAD.L	(A4)+OobjBBOX2,D4EXIT$:	POPM.L	D1,D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------------\\; LSTO_CCOMPACT >;==============/; Compacte un objet quelconque aprs sa cration.; in	A4.L	^objet; out	D7.W	erreur; mod	D7.WLSTO_CCOMPACT:	PUSHM.L	D1,D3,D4,D6,A3,A4	LOAD.L	D6,(A6)+ODALCH	; D6 <-- canal de la liste des datas	TCLR.B	(A4)+OobjFLAGS:#BobjCREATE	LOAD.W	D1,#opCRLGCOM	CALL	OBJCALLD	; D3/D4 <-- lg tendu/compact	JUMP,NE EXIT$	COMP.W	D3,D4		; lg tendu = lg compact ?	JUMP',EQ BBOX$		; oui => BBOX$	LOAD.L	A3,A4		; A3 <-- ^racine objet tendu	LOAD.L	A4,#0		; A4 <-- insre  la tte	CALL	LST_INSERT	; A4 <-- ^data objet compact	JUMP',NE EXIT$	PUSHM.L	A3,A4	LOAD.L	A3,(A3)+OobjPDATA ; A3 <-- ^data objet tendu	SR.W	D4,#1		; D4 <-- /2 car .W	DEC.W	D4		; D4 <-- -1 car NMOXFER$:	LOAD.W	(A4+),(A3+)	; objet compact <-- objet tendu	DECJ.W,NMO D4,XFER$	POPM.L	A3,A4	LOAD.L	D4,A4	LOAD.L	A4,(A3)+OobjPDATA	LOAD.L	(A3)+OobjPDATA,D4	CALL	LST_REMOVE	; supprime l'objet tendu	LOAD.L	A4,A3BBOX$:	LOAD.W	D1,#opGETBBOX	CALL	OBJCALLD	; D3/D4 <-- bounding box	LOAD.L	(A4)+OobjBBOX1,D3	LOAD.L	(A4)+OobjBBOX2,D4EXIT$:	POPM.L	D1,D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;	--------------------------------------;		(C) 1989 - Daniel Roux;	--------------------------------------; Module de gestion de listes d'lments avec les proprits suivantes :;;  1)	Une liste peut contenir un nombre quelconque d'lments,;	limit seulement par la taille mmoire du SMAKY.;;  2)	Chaque lment peut avoir une longueur diffrente, comprise;	entre 1 et 65'000 bytes.;;  3)	Un lment peut contenir des pointeurs, car il n'est jamais;	dplac. Il est ainsi ais de raliser des listes de listes !;;  4)	La liste est ordonne, avec une tte et une queue. Par dfaut,;	un lment est insr  la tte. Un lment peut tre rapidement;	plac en tte ou en queue de liste.;;  5)	La mmoire est rserve et libre automatiquement, non pas;	pour chaque lment, mais pour un ensemble d'lments. On;	spcifie la longueur d'un bloc mmoire lors de l'ouverture.;	Toutefois, un lment peut trs bien tre plus grand que la;	longueur d'un bloc mmoire.;;  6)	En plus de la taille d'un lment, les listes utilisent 12 bytes;	pour chaque lment.; Une liste est matrialise par deux chanes :;;	OlistUSE	chane des lments utiliss;	OlistFREE	chane des lments libres;; Un lment est chan soit dans la chane des libres, soit dans la; chane des utiliss. Jamais dans les deux, et jamais dans aucune.; Les lments libres sont tris en fonction de leurs adresses; (queue -> adresses basses et tte -> adresses hautes). Ceci permet; de garantir que, quelque soit l'ordre, deux lments contigus librs; pourront toujours fusionner en un seul lment, afin d'viter le; morcellement de la mmoire. En effet, il n'est prvu aucun "ramasse; miettes" visant  compacter les lments utiliss pour n'avoir plus; qu'un seul grand trou. De toute faon, ceci n'est pas souhaitable,; car les lments peuvent contenir des pointeurs  d'autres lments.;;;	      descripteur d'une chane vide;	   +---------------+;	   |               |;	   |   +-------+   |;	   +-->|     o-|---+     NEXT;	       +-------+;	   +---|-o     |<--+     PREV;	   |   +-------+   |;	   |               |;	   +---------------+;;;	      descripteur       lment         lment;	   +-----------------------------------------------+;	   |                                               |;	   |   +-------+       +-------+       +-------+   |;	   +-->|     o-|------>|     o-|------>|     o-|---+     OlichNEXT;	       +-------+       +-------+       +-------+;	   +---|-o     |<------|-o     |<------|-o     |<--+     OlichPREV;	   |   +-------+       +-------+       +-------+   |;	   |                   |       |       |       |   |     OlichLGDATA;	   |                   +-------+       +-------+   |;	   |                   |       |       |       |   |     OlichLGBMEM;	   |                   +-------+       +-------+   |;	   |              A4-->|       |       |       |   |;	   |                   |  ...  |       |  ...  |   |     donnes de l'lment;	   |                   |       |       |       |   |;	   |                   |       |       +-------+   |;	   |                   +-------+                   |;	   |                                               |;	   +-----------------------------------------------+; Descripteur d'une chane; ------------------------		.PC	PCVARLlich		=	4+4+2+2		.LOC	-LlichOlichNEXT:	.BLKB	4		; ^suivantOlichPREV:	.BLKB	4		; ^prcdentOlichLGDATA:	.BLKB	2		; longueur lmentOlichLGBMEM:	.BLKB	2		; longueur bloc mmoire; Descripteur d'une liste; -----------------------		.PC	PCVARLlist		=	2+4+2+Llich+Llich		.LOC	-LlistOlistLGBMEM:	.BLKB	2		; longueur pour bloc mmoireOlistMODE:	.BLKB	4		; mode de la listeOlistNB:	.BLKB	2		; nb d'lments		.BLKB	Llich		; chane des libresOlistFREE:		.BLKB	Llich		; chane des utiliss (doit tre en dernier)OlistUSE:		.PC	PCCODE;---------\\; LST_OPEN >;=========/; Ouvre une nouvelle liste vide.; in	D3.L	mode (zro par dfaut);	D4.W	longueur d'un bloc mmoire;		 0 => longueur standard (1000 bytes);		-1 => maximum possible (65522 bytes); out	D6.L	canal de la liste;	D7.W	erreur; mod	D6.L, D7.WLST_OPEN:	PUSHM.L	D1..D4,A4,A6	TEST.W	D4	JUMP',NE DEF$	LOAD.W	D4,#1000		; D4 <-- longueur par dfautDEF$:	COMP.W	D4,#(2^16)-Llich-2	JUMP',LS MAX$	LOAD.W	D4,#(2^16)-Llich-2MAX$:	INC.W	D4	TCLR.L	D4:#0			; D4 <-- arrondi au multiple de 2 suprieur	ADD.W	D4,#Llich	LOAD.W	D2,D4	LOAD.L	D4,#Llist		; D4 <-- lg pour descripteur	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM			; A4 <-- mmoire pour descripteur liste	JUMP',NE EXIT$	LOAD.L	A6,#(A4)+Llist		; A6 <-- ^descripteur	LOAD.L	(A6)+OlistMODE,D3	; OlistMODE <-- mode (inutilis)	LOAD.W	(A6)+OlistLGBMEM,D2	; OlistLGBMEM <-- lg d'un bloc mmoire	CLR.W	(A6)+OlistNB		; OlistNB <-- aucun lment	LOAD.L	A4,#(A6)+OlistFREE	LOAD.L	(A4)+OlichNEXT,A4	; chane des libres vide	LOAD.L	(A4)+OlichPREV,A4	LOAD.L	(A6)+OlichNEXT,A6	; chane des utiliss vide	LOAD.L	(A6)+OlichPREV,A6	LOAD.L	D6,A6			; D6 <-- canalEXIT$:	POPM.L	D1..D4,A4,A6	TEST.W	D7			; retour EQ/NE	RET;----------\\; LST_CLOSE >;==========/; Termine l'utilisation d'une liste.; Si la liste contient encore des lments, ils sont supprims,; et les blocs mmoires correspondants sont librs.; in	D6.L	canal de la liste; out	-; mod	D7.WLST_CLOSE:	PUSHM.L	D1,A3,A4,A6	LOAD.L	A6,D6			; A6 <-- ^descripteur listeLOOP$:	LOAD.L	A4,(A6)+OlichPREV	COMP.L	A4,A6			; dbut de la liste ?	JUMP',EQ END$			; oui => END$					; non =>	CALL	LST_REMOVE		; libre un lment	JUMP	LOOP$END$:	LOAD.L	A4,#(A6)-Llist	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM			; libre mmoire pour descripteur liste	POPM.L	D1,A3,A4,A6	RET;-------\\; LST_NB >;=======/; Donne le nombre d'lments contenus dans une liste.; in	D6.L	canal de la liste; out	D4.W	nb d'lments; mod	D4.L, D7.WLST_NB:	PUSH.L	A6	LOAD.L	A6,D6			; A6 <-- ^descripteur liste	LOAD.W	D4,(A6)+OlistNB		; D4 <-- nb d'lments	POP.L	A6	CLR.W	D7			; D7 <-- retour EQ	RET;-----------\\; LST_INSERT >;===========/; Ajoute un lment n'importe o dans la liste.; Si cela est ncessaire, un nouveau bloc mmoire est allou.; in	D4.W	longueur de l'lment;	A4.L	^lment avant lequel insrer (si zro =>  la tte);	D6.L	canal de la liste; out	A4.L	^lment initialis avec des zro;	D7.W	erreur; mod	D7.W, A4.LLST_INSERT:	PUSHM.L	D1..D4,A0..A3,A6	LOAD.L	A6,D6			; A6 <-- ^descripteur liste	INC.W	D4	TCLR.L	D4:#0			; D4 <-- arrondi au multiple de 2 suprieur	ADD.W	D4,#Llich		; D4 <-- lg pour l'lment	LOAD.W	D2,D4	LOAD.L	A0,A4; Cherche un trou ayant exactement la bonne longueur en parcourant; la chane des lments libres.SAME$:	LOAD.W	D4,D2	LOAD.L	A3,#(A6)+OlistFREE	LOAD.L	A4,(A3)+OlichPREVSLOOP$:	COMP.L	A4,A3			; fin de la chane ?	JUMP',EQ DOUBLE$		; oui => DOUBLE$	COMP.W	D4,(A4)+OlichLGDATA	; juste la bonne place ici ?	JUMP',EQ SREPL$			; oui => SREPL$	LOAD.L	A4,(A4)+OlichPREV	; A4 <-- ^suivant	JUMP	SLOOP$; Cherche un trou pouvant se transformer en deux (un lment suivi d'un trou); en parcourant la chane des lments libres.DOUBLE$:	ADD.W	D4,#Llich		; D4 <-- lg minimale pour ddoubler un lment;	LOAD.L	A3,#(A6)+OlistFREE	LOAD.L	A4,(A3)+OlichPREVDLOOP$:	COMP.L	A4,A3			; fin de la chane ?	JUMP',EQ NEW$			; oui => NEW$	COMP.W	D4,(A4)+OlichLGDATA	; assez (mais trop) de place ici ?	JUMP',LS DREPL$			; oui => DREPL$	LOAD.L	A4,(A4)+OlichPREV	; A4 <-- ^suivant	JUMP	DLOOP$NEW$:	CLR.L	D4	LOAD.W	D4,(A6)+OlistLGBMEM	; D4 <-- longueur d'un bloc	COMP.W	D4,D2			; lment  ajouter plus grand ?	JUMP',HS NBIG$			; non => NBIG$	LOAD.W	D4,D2			; D4 <-- longueur ncessaire pour l'lmentNBIG$:	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM			; demande mmoire pour nouveau bloc	JUMP,NE EXIT$	LOAD.L	A4,#(A4)+Llich	LOAD.W	(A4)+OlichLGDATA,D4	LOAD.W	(A4)+OlichLGBMEM,D4	CALL	ADDFREE			; ajoute  la chane des libres	JUMP	SAME$; Remplace le trou par un lment ayant exactement la mme longueur.SREPL$:					; juste la place =>	CALL	SUBLINK			; enlve de la chane des libres	JUMP'	REPL$; Remplace le trou par un lment suivit d'un trou plus petit.DREPL$:					; trop de place =>	SUB.W	D4,#Llich		; D4 <-- lg pour l'lment	LOAD.L	A3,(A4)+OlichNEXT	LOAD.L	A2,(A4)+OlichPREV	LOAD.L	A1,#(A4)+(D4.W)	LOAD.W	D3,(A4)+OlichLGDATA	SUB.W	D3,D4	LOAD.W	(A1)+OlichLGDATA,D3	CLR.W	(A1)+OlichLGBMEM	LOAD.L	(A1)+OlichPREV,A2	LOAD.L	(A1)+OlichNEXT,A3	LOAD.L	(A3)+OlichPREV,A1	LOAD.L	(A2)+OlichNEXT,A1	LOAD.W	(A4)+OlichLGDATA,D4REPL$:	LOAD.L	A3,A6			; A3 <-- ajoute  la fin de la chane (devant)	COMP.L	A0,#0	JUMP',EQ REND$	LOAD.L	A3,A0			; A3 <-- ajoute n'importe oREND$:	CALL	ADDLINK			; ajoute  la chane des utiliss	INC.W	(A6)+OlistNB		; OlistNB <-- un lment de plus; Rempli l'lment avec des zros.	LOAD.L	A3,A4			; A3 <-- ^dbut du data	LOAD.W	D4,(A4)+OlichLGDATA	; D4 <-- lg de l'lment	SUB.W	D4,#Llich		; D4 <-- n'efface pas le dbut	SR.W	D4,#1			; D4 <-- /2 car .W	DEC.W	D4			; D4 <-- -1 car NMO	CLR.W	D3			; D3 <-- pour effacer plus vite que CLR.W (A3+) !CLEAR$:	LOAD.W	(A3+),D3		; efface le data	DECJ.W,NMO D4,CLEAR$	CLR.W	D7			; D7 <-- okEXIT$:	POPM.L	D1..D4,A0..A3,A6	TEST.W	D7			; retour EQ/NE	RET;-----------\\; LST_REMOVE >;===========/; Supprime un lment dans la liste.; S'il existe un bloc mmoire ne contenant plus aucun lment,; il est libr.; in	A4.L	^lment;	D6.L	canal de la liste; out	D7.W	erreur; mod	D7.WLST_REMOVE:	PUSHM.L	D1,A4,A6	LOAD.L	A6,D6			; A6 <-- ^descripteur liste	CALL	SUBLINK			; enlve de la chane des utiliss	CALL	ADDFREE			; ajoute  la chane des libres	DEC.W	(A6)+OlistNB		; OlistNB <-- un lment de moins; Essaye plusieurs fois d'appondre le trou au suivant et/ou; au prcdent.LOOP$:	CALL	APPEND			; essaye d'appondre deux trous	JUMP,NE LOOP$			; si fait qq chose => essaye encore; Regarde s'il faut rendre une tranche mmoire.	LOAD.W	D1,(A4)+OlichLGDATA	COMP.W	D1,(A4)+OlichLGBMEM	JUMP',NE EXIT$	CALL	SUBLINK			; supprime de la chane des libres	LOAD.L	A4,#(A4)-Llich	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM			; rend la tranche mmoireEXIT$:	POPM.L	D1,A4,A6	CLR.W	D7			; retour EQ	RET;--------\\; ADDFREE >;--------/; Ajoute un lment dans la liste des libres.; Cherche l'endroit o ajouter dans la chane des libres, pour; que cette chane soit trie en fonction des adresses.; in	A4.L	^lment; out	-; mod	-ADDFREE:	PUSHM.L	A2,A3	LOAD.L	A2,#(A6)+OlistFREE	LOAD.L	A3,(A2)+OlichPREVLOOP$:	COMP.L	A3,A2			; dbut de la chane ?	JUMP',EQ END$			; oui => END$	COMP.L	A4,A3	JUMP',HI END$	LOAD.L	A3,(A3)+OlichPREV	; A3 <-- ^prcdent	JUMP	LOOP$END$:	LOAD.L	A3,(A3)+OlichNEXT	; A3 <-- ^suivant	CALL	ADDLINK			; ajoute  la chane des libres	POPM.L	A2,A3	RET;--------\\; APPEND  >;--------/; Tente d'appondre un trou au suivant et/ou au prcdent.; in	A4.L	^trou; out	A4.L	^trou appondu avec un autre;	D7.W	EQ => rien n'a t appondu; mod	D7.W, A4.LAPPEND:	PUSHM.L	D3,A2,A3	CLR.W	D7			; D7 <-- rien fait; Si l'lment devenu trou est suivi d'un autre trou, fusionne les deux; trous en un seul.NEXT$:	LOAD.L	A3,A4	ADD.W	A3,(A4)+OlichLGDATA	COMP.L	A3,(A4)+OlichPREV	; trou juste aprs ?	JUMP',NE NEXT2$			; non => NEXT2$					; oui =>	LOAD.W	D3,(A3)+OlichLGDATA	ADD.W	(A4)+OlichLGDATA,D3	LOAD.L	A2,(A3)+OlichPREV	LOAD.L	(A4)+OlichPREV,A2	LOAD.L	(A2)+OlichNEXT,A4	INC.W	D7			; D7 <-- deux trous appondus	JUMP'	PREV$NEXT2$:	LOAD.L	A3,A4	ADD.W	A3,(A4)+OlichLGDATA	COMP.L	A3,(A4)+OlichNEXT	; trou juste aprs ?	JUMP',NE PREV$			; non => PREV$					; oui =>	LOAD.W	D3,(A3)+OlichLGDATA	ADD.W	(A4)+OlichLGDATA,D3	LOAD.L	A2,(A3)+OlichNEXT	LOAD.L	(A4)+OlichNEXT,A2	LOAD.L	(A2)+OlichPREV,A4	INC.W	D7			; D7 <-- deux trous appondus; Si l'lment devenu trou est prcd d'un autre trou, fusionne les deux; trous en un seul.PREV$:	LOAD.L	A3,(A4)+OlichPREV	ADD.W	A3,(A3)+OlichLGDATA	COMP.L	A3,A4			; trou juste avant ?	JUMP',NE PREV2$			; non => PREV2$					; oui =>	LOAD.L	A3,(A4)+OlichPREV	LOAD.W	D3,(A4)+OlichLGDATA	ADD.W	(A3)+OlichLGDATA,D3	LOAD.L	A2,(A4)+OlichNEXT	LOAD.L	(A3)+OlichNEXT,A2	LOAD.L	(A2)+OlichPREV,A3	LOAD.L	A4,A3	INC.W	D7			; D7 <-- deux trous appondus	JUMP'	EXIT$PREV2$:	LOAD.L	A3,(A4)+OlichNEXT	ADD.W	A3,(A3)+OlichLGDATA	COMP.L	A3,A4			; trou juste avant ?	JUMP',NE EXIT$			; non => EXIT$					; oui =>	LOAD.L	A3,(A4)+OlichNEXT	LOAD.W	D3,(A4)+OlichLGDATA	ADD.W	(A3)+OlichLGDATA,D3	LOAD.L	A2,(A4)+OlichPREV	LOAD.L	(A3)+OlichPREV,A2	LOAD.L	(A2)+OlichNEXT,A3	LOAD.L	A4,A3	INC.W	D7			; D7 <-- deux trous appondusEXIT$:	POPM.L	D3,A2,A3	TEST.W	D7			; retour EQ/NE	RET;---------\\; LST_HEAD >;=========/; Place un lment en tte de liste.; in	A4.L	^lment;	D6.L	canal de la liste; out	D7.W	erreur; mod	D7.WLST_HEAD:	PUSHM.L	A3,A4,A6	LOAD.L	A6,D6			; A6 <-- ^descripteur liste	CALL	SUBLINK			; supprime de la chane	LOAD.L	A3,(A6)+OlichNEXT	CALL	ADDLINK			; remet au dbut de la chane	POPM.L	A3,A4,A6	CLR.W	D7			; D7 <-- ok	RET;---------\\; LST_TAIL >;=========/; Place un lment en queue de liste.; in	A4.L	^lment;	D6.L	canal de la liste; out	D7.W	erreur; mod	D7.WLST_TAIL:	PUSHM.L	A3,A4,A6	LOAD.L	A6,D6			; A6 <-- ^descripteur liste	CALL	SUBLINK			; supprime de la chane	LOAD.L	A3,A6			; A3 <-- ajoute  la fin de la chane	CALL	ADDLINK			; remet  la fin de la chane	POPM.L	A3,A4,A6	CLR.W	D7			; D7 <-- ok	RET;----------\\; LST_FIRST >;==========/; Cherche le premier lment (celui  la queue de la liste).; in	D6.L	canal de la liste; out	A4.L	^premier lment;	D7.W	erreur; mod	D7.W, A4.LLST_FIRST:	LOAD.L	A4,D6			; A4 <-- ^descripteur liste	COMP.L	A4,(A4)+OlichNEXT	; premier lment existe ?	JUMP',EQ ERROR$			; non => ERROR$	LOAD.L	A4,(A4)+OlichNEXT	; A4 <-- ^lment	CLR.W	D7			; D7 <-- ok	RETERROR$:	LOAD.W	D7,#1			; D7 <-- erreur	RET;---------\\; LST_LAST >;=========/; Cherche le dernier lment (celui  la tte de la liste).; in	D6.L	canal de la liste; out	A4.L	^dernier lment;	D7.W	erreur; mod	D7.W, A4.LLST_LAST:	LOAD.L	A4,D6			; A4 <-- ^descripteur liste	COMP.L	A4,(A4)+OlichPREV	; dernier lment existe ?	JUMP',EQ ERROR$			; non => ERROR$	LOAD.L	A4,(A4)+OlichPREV	CLR.W	D7			; D7 <-- ok	RETERROR$:	LOAD.W	D7,#1			; D7 <-- erreur	RET;---------\\; LST_NEXT >;=========/; Cherche l'lment suivant, en allant de la queue  la tte de la liste.; in	A4.L	^lment;	D6.L	canal de la liste; out	A4.L	^lment suivant;	D7.W	erreur; mod	D7.W, A4.LLST_NEXT:	COMP.L	D6,(A4)+OlichNEXT	; est-on  la fin ?	JUMP',EQ ERROR$			; oui => ERROR$					; non =>	LOAD.L	A4,(A4)+OlichNEXT	; A4 <-- ^lment suivant	CLR.W	D7			; D7 <-- ok	RETERROR$:	LOAD.W	D7,#1			; D7 <-- erreur	RET;---------\\; LST_PREV >;=========/; Cherche l'lment prcdent, en allant de la tte  la queue de la liste.; in	A4.L	^lment;	D6.L	canal de la liste; out	A4.L	^lment prcdent;	D7.W	erreur; mod	D7.W, A4.LLST_PREV:	COMP.L	D6,(A4)+OlichPREV	; est-on au dbut ?	JUMP',EQ ERROR$			; oui => ERROR$					; non =>	LOAD.L	A4,(A4)+OlichPREV	; A4 <-- ^lment prcdent	CLR.W	D7			; D7 <-- ok	RETERROR$:	LOAD.W	D7,#1			; D7 <-- erreur	RET;--------\\; ADDLINK >;--------/; Ajoute un lment dans une chane.; in	A3.L	^lment de base (ou n'importe lequel);	A4.L	^lment  ajouter; out	-; mod	-ADDLINK:	PUSH.L	A2	LOAD.L	A2,(A3)+OlichPREV	LOAD.L	(A3)+OlichPREV,A4	LOAD.L	(A2)+OlichNEXT,A4	LOAD.L	(A4)+OlichPREV,A2	LOAD.L	(A4)+OlichNEXT,A3	POP.L	A2	RET;--------\\; SUBLINK >;--------/; Supprime un lment dans une chane.; in	A4.L	^lment  supprimer; out	-; mod	-SUBLINK:	PUSHM.L	A2,A3	LOAD.L	A2,(A4)+OlichNEXT	; A2 <-- ^lment suivant	LOAD.L	A3,(A4)+OlichPREV	; A3 <-- ^lment prcdent	LOAD.L	(A2)+OlichPREV,A3	LOAD.L	(A3)+OlichNEXT,A2	POPM.L	A2,A3	RET	.END