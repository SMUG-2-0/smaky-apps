	.TITLE	TPRINT.ASC	.PROC	M680002	.REF	SMAKY	.REF	MODULES	.LOC	0OCHPRINTA:.BLKB	2		; canal du module PRINTAOCAPRINT:.BLKB	4		; canal du interne PRINTOSTPRI:	.BLKB	LGPRI0OFACX:	.BLKB	2OFACY:	.BLKB	2OMMX:	.BLKB	2OMMY:	.BLKB	2LGVAR:	.LOC	0START:	LOAD.L	A6,#R16"VAR	LOAD.L	A3,#R16"NMPRINTA	LOAD.W	D3,#PRINTA_FIRST	LIB_	OPEN	JUMP',NE 30$	LOAD.W	(A6)+OCHPRINTA,D1	CLR.L	D3	PRINTA_	OPEN	JUMP,NE ERFAT	LOAD.L	(A6)+OCAPRINT,A230$:	CALL	PRINTRESOL	; lit le status de l'imprimante	LIB	?AFX8	LIB	?AFCR	LOAD.W	D4,D3	AND.L	D4,#H'FFFF	LOAD.W	D3,#5	CLR.W	D2	LIB	?AFDEC	LIB	?AFCRFINI:	TEST.L	(A6)+OCAPRINT	JUMP',EQ 50$	LOAD.L	A2,(A6)+OCAPRINT	PRINTA_	CLOSE	LOAD.W	D1,(A6)+OCHPRINTA	LIB_	CLOSE50$:ERFAT:	EXIT;-----------\\; PRINTRESOL >;===========/; Lit le status de l'imprimante.; in	-; out	D4.L	dimensions (pt);	D3.W	rsolution de l'imprimante (pt/in);	D7.W	erreur; mod	D3.L, D4.L, D7.WPRINTRESOL:	PUSHM.L	D1,D2,A2..A4	LOAD.L	A2,(A6)+OCAPRINT	LOAD.L	D4,#LGPRI0	; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OSTPRI	; A4 <-- ^buffer	PRINTA_	RSTATUS		; OPRSTA <-- status de l'imprimante	JUMP',NE EXIT$	LOAD.W	D4,(A4)+OPRHTP	SUB.W	D4,(A4)+OPRMGS	SUB.W	D4,(A4)+OPRMGI	MUL.WU	D4,#8	DIV.WU	D4,(A4)+OPRGLX	SWAP.W	D4		; D4 <-- hauteur (pt)	LOAD.W	D3,(A4)+OPRLGP	MUL.WU	D3,#8	DIV.WU	D3,(A4)+OPRGLX	LOAD.W	D4,D3		; D4 <-- largeur (pt)	LOAD.W	D1,(A4)+OPRUMX+2	MUL.WU	D1,(A4)+OPRGLX	LOAD.L	D2,D1	SR.W	D2,#1	LOAD.L	D3,#254000*8	ADD.L	D3,D2	DIV.WU	D3,D1		; D3 <-- rsolution (pt/in)EXIT$:	POPM.L	D1,D2,A2..A4	TEST.W	D7		; retour EQ/NE	RETNMPRINTA:	.ASCIZ	"PRINTA"		.EVENVAR:	.FILLB	LGVAR,0	.END	START