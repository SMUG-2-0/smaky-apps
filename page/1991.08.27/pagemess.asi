	.SBTTL	PAGEMESS.ASI;------------\\; MESSWAITKEY >;============/; Attend une touche clavier/souris.; in	-; out	D3.L	touche presse;	D7.W	erreur; mod	D3.L, D7.WMESSWAITKEY:	PUSH.L	D4	LOAD.W	D4,#10	NTREL	?SETTIM	LIB	?GETKEY		; attend clavier/souris ...	PUSH.W	D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POP.W	D7	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;------------\\; MESSWAITBAL >;============/; Attend un message de la BAL.; in	-; out	A4.L	^message;	D4.L	lg message;	D7.W	erreur; mod	D4.L, D7.W, A4.LMESSWAITBAL:	PUSHM.L	D3,A5	LOAD.W	D4,#2	NTREL	?SETTIM	LOAD.L	A4,(A6)+OPLMES	; A4 <-- ^variables passes  PAGE	LOAD.L	A5,(A4)+0	; A5 <-- ^bal	LOAD.L	A4,#(A6)+OIOTM	; A4 <-- ^buffer	LOAD.L	D4,#LTMIO	; D4 <-- lg max attendue	LOAD.W	D3,#2^BMSCOPY	; D3 <-- mode	NTREL	?GETMS		; OBALMS <-- attend un message ...	PUSHM.L	D4,D7	LOAD.W	D4,#-1	NTREL	?SETTIM	POPM.L	D4,D7	POPM.L	D3,A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; MESSSNDBAL >;===========/; Envoie un message  tous les objets concerns.; in	A4.L	^message;	D4.L	lg message; out	-; mod	D7.WMESSSNDBAL:	PUSHM.L	D0,D1,D3,A3,A4	LOAD.L	A3,A4		; A3 <-- ^message	LOAD.L	D3,D4		; D3 <-- lg message	CALL	_1LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$LOOP$:	LOAD.W	D0,(A4)+OobjIDENT	COMP.W	D0,(A3)		; est-ce le bon identificateur ?	JUMP',NE NEXT$		; non => NEXT$	LOAD.W	D1,#opMESSGET	CALL	_1OBJCALLD	; envoie le messageNEXT$:	CALL	_1LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	POPM.L	D0,D1,D3,A3,A4	RET;----------\\; MESSGETPT >;==========/; Donne le pointeur pour les messages.; in	-; out	A4.L	adresse donne par "PAGE adresse/X";	D7.W	erreur; mod	D7.W, A4.LMESSGETPT:	LOAD.L	A4,(A6)+OPLMES	CLR.W	D7		; retour EQ/NE	RET	.END