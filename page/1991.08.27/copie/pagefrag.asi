	.SBTTL	PAGEFRAG.ASI;-----------\\; FRAGSELECT >;===========/; Fragmente tous les objets slectionns.; in	-; out	D7.W	erreur; mod	D7.WFRAGSELECT:	PUSHM.L	D0..D4,D6,A4	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D0,#IDENTPEN	LOAD.W	D1,#opDGET	CALL	_OBJCALL	; D3 <-- pinceau slectionn	PUSH.W	D3;	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D0,#IDENTTRAME;	LOAD.W	D1,#opDGET	CALL	_OBJCALL	; D3 <-- trame slectionne	PUSH.W	D3	CALL	WDOOPEN		; dessine dans la swdo	CALL	GETACH		; D6 <-- canal de l'arbre des objetsFIRST$:	CALL	_LSTA_FIRST	; A4 <-- ^premier objet	JUMP,NE EXIT$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP,BC NEXT$	LOAD.W	D0,(A4)+OobjIDENT	LOAD.W	D3,#IDENTPEN	LOAD.W	D1,#opGETDEF	CALL	_OBJCALLD	; D4 <-- pinceau utilis	JUMP',EQ PEN$	CLR.W	D4		; D4 <-- pinceau zro !PEN$:	PUSHM.L	D0,A4	LOAD.W	D0,D3	LOAD.W	D3,D4	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D1,#opDPUT	CALL	_OBJCALL	; slectionne le pinceau	POPM.L	D0,A4	LOAD.W	D3,#IDENTTRAME	LOAD.W	D1,#opGETDEF	CALL	_OBJCALLD	; D4 <-- trame utilise	JUMP',EQ TRAME$	CLR.W	D4		; D4 <-- trame zro !TRAME$:	PUSHM.L	D0,A4	LOAD.W	D0,D3	LOAD.W	D3,D4	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D1,#opDPUT	CALL	_OBJCALL	; slectionne la trame	POPM.L	D0,A4	CALL	FRAGONEOBJ	; fragmente l'objet	JUMP	FIRST$NEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	CALL	WDOCLOSE	; fin du dessin dans la swdo	POP.W	D3	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D0,#IDENTTRAME	LOAD.W	D1,#opDPUT	CALL	_OBJCALL	; re-slectionne la trame	POP.W	D3;	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D0,#IDENTPEN;	LOAD.W	D1,#opDPUT	CALL	_OBJCALL	; re-slectionne le pinceau	POPM.L	D0..D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; FRAGONEOBJ >;-----------/; Fragmente puis dslectionne un objet.; in	A4.L	^objet  fragmenter; out	D7.W	erreur; mod	D7.WFRAGONEOBJ:	PUSHM.L	D1..D6,A2..A4	CALL	FRAGBEGIN	; dbut de la fragmentation	JUMP,NE	EXIT$	SET.B	(A6)+OIFFRAG;;?	LOAD.L	D2,#2^BVUEPROV!2^BVUEPROVI	LOAD.L	D2,#2^BVUESET	LOAD.W	D1,#opDRAW	CALL	_OBJCALLD	; fragmente l'objet	CLR.B	(A6)+OIFFRAG	LOAD.L	A2,A4		; A2 <-- ^objet	LOAD.L	D6,(A6)+OFRACH	; D6 <-- canal de la liste de fragmentation	CALL	_LST_FIRST	; A4 <-- ^premier lmentLOOP$:	CALL	FRAGSEARCH	; D3/D4 <-- ident/nb	CALL	FRAGLIST	; A3/D4 <-- ^liste/nb	CALL	FRAGONLYBZ	; transforme les droites	CALL	FRAGCREATE	; cre un objet	JUMP',NE ERROR$	EX.L	A3,A4	CALL	_LST_LAST	; A3 <-- ^dernier lment	EX.L	A3,A4	COMP.L	A4,A3		; est-on sur le dernier lment ?	JUMP,NE LOOP$		; non => LOOP$END$:	CALL	GETACH		; D6 <-- canal de l'arbre des objets	LOAD.L	A4,A2		; A4 <-- ^objet	LOAD.W	D1,#opCRCLOSE	CALL	_OBJCALLD	; ferme l'objet fragment	CALL	_LSTA_REMOVE	; enlve l'objet fragment	CLR.W	D7		; D7 <-- ok	JUMP'	CLOSE$ERROR$:	PUSH.W	D7	CALL	GETACH		; D6 <-- canal de l'arbre des objets	LOAD.L	A4,A2		; A4 <-- ^objet	CALL	_LSTO_HCOMPACT	; compactifie l'objet	POP.W	D7CLOSE$:	PUSH.W	D7	CALL	FRAGEND		; fin de la fragmentation	POP.W	D7EXIT$:	POPM.L	D1..D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; FRAGSEARCH >;-----------/; Cherche plusieurs lments identiques et contigs.; in	A4.L	^premier lment; out	D3.W	identificateur des lments;	D4.W	nb d'lments (1..n); mod	D3.L, D4.L, D7.WFRAGSEARCH:	PUSHM.L	D2,D6,A4	LOAD.L	D6,(A6)+OFRACH	; D6 <-- canal de la liste de fragmentation	LOAD.W	D3,(A4)		; D3 <-- identificateur du premier lment	CLR.W	D4		; D4 <-- nb d'lments	COMP.W	D3,#IDFRAGCURVE	JUMP',EQ LLOOP$	COMP.W	D3,#IDFRAGCHCURVE	JUMP',EQ CCLOOP$	COMP.W	D3,#IDFRAGCHEND	JUMP',EQ CELOOP$LLOOP$:	INC.W	D4		; D4 <-- un lment de plus	LOAD.L	D2,(A4)+2+4	; D2 <-- point suivant	COMP.W	(A4),#IDFRAGLINE	JUMP',EQ LPS$	LOAD.L	D2,(A4)+2+4+4+4	; D2 <-- point suivantLPS$:	CALL	_LST_NEXT	; A4 <-- ^lment suivant	JUMP',NE END$	COMP.W	(A4),#IDFRAGLINE	JUMP',EQ LCONT$	COMP.W	(A4),#IDFRAGCURVE	JUMP',NE END$	LOAD.W	D3,#IDFRAGCURVELCONT$:	COMP.L	D2,(A4)+2	; lment contigu ?	JUMP',NE END$		; non => END$	JUMP	LLOOP$CCLOOP$:	INC.W	D4		; D4 <-- un lment de plus	CALL	_LST_NEXT	; A4 <-- ^lment suivant	JUMP',NE END$	COMP.W	D3,(A4)		; mme identificateur d'lment ?	JUMP',NE END$		; non => END$	JUMP	CCLOOP$CELOOP$:	INC.W	D4		; D4 <-- un lment de plus;	JUMP'	END$END$:	TEST.B	(A6)+OFRAFA+3:#1 ; fragmente uniquement en courbes ?	JUMP',BC EXIT$		; non => EXIT$	COMP.W	D3,#IDFRAGLINE	JUMP',NE EXIT$	LOAD.W	D3,#IDFRAGCURVEEXIT$:	POPM.L	D2,D6,A4	RET;---------\\; FRAGLIST >;---------/; Prpare la liste des points.; in	A4.L	^premier lment;	D3.W	identificateur des lments;	D4.W	nb d'lments (1..n); out	A4.L	^lment suivant;	A3.L	^liste;	D4.W	nb de points; mod	D4.L, D7.W, A3.L, A4.LFRAGLIST:	PUSHM.L	D3,D6,A1,A2	LOAD.L	D6,(A6)+OFRACH	; D6 <-- canal de la liste de fragmentation	LOAD.L	A3,#(A6)+OIOTM	; A3 <-- ^grand buffer	LOAD.L	A2,A3	COMP.W	D3,#IDFRAGCURVE	JUMP',EQ CURVE$	COMP.W	D3,#IDFRAGCHCURVE	JUMP,EQ CHCURVE$	COMP.W	D3,#IDFRAGCHEND	JUMP,EQ CHEND$LLOOP$:	LOAD.L	(A2+),(A4)+2	LOAD.L	(A2),(A4)+2+4	CALL	_LST_NEXT	; A4 <-- ^lment suivant	DEC.W	D4	JUMP,NE	LLOOP$	ADD.L	A2,#4	JUMP	END$CURVE$:	LOAD.L	(A2+),(A4)+2CLOOP$:	COMP.W	(A4),#IDFRAGCURVE	JUMP',EQ CCURVE$	LOAD.L	(A2+),(A4)+2	LOAD.L	(A2+),(A4)+2	LOAD.L	(A2+),(A4)+2+4	LOAD.L	(A2),(A4)+2+4	JUMP'	CNEXT$CCURVE$:	LOAD.L	(A2+),(A4)+2	LOAD.L	(A2+),(A4)+2+4	LOAD.L	(A2+),(A4)+2+4+4	LOAD.L	(A2),(A4)+2+4+4+4CNEXT$:	CALL	_LST_NEXT	; A4 <-- ^lment suivant	DEC.W	D4	JUMP,NE	CLOOP$	LOAD.L	(A2)+4,(A2)	ADD.L	A2,#8	LOAD.L	D3,(A3)+4	COMP.L	D3,(A2)-8	; premier point = dernier point ?	JUMP,NE END$		; non => END$	LOAD.L	(A3)+0,(A2)-12	LOAD.L	(A2)-4,(A3)+8	JUMP	END$CHCURVE$:	LOAD.L	A1,A2		; A1 <-- ^premier point	LOAD.L	(A2+),(A4)+2	JUMP'	CHCCONT$CHCLOOP$:	LOAD.L	D3,(A4)+2	COMP.L	D3,(A2)		; est-ce contigu ?	JUMP',EQ CHCCONT$	; oui => CHCCONT$	LOAD.L	(A2)+4,(A2)	ADD.L	A2,#8	LOAD.L	D3,(A1)+4	COMP.L	D3,(A2)-8	; premier point = dernier point ?	JUMP',NE CHCLOC$	; non => CHCLOC$	LOAD.L	(A1)+0,(A2)-12	LOAD.L	(A2)-4,(A1)+8CHCLOC$:	LOAD.L	D3,#ENDLOC	LOAD.L	(A2+),D3	LOAD.L	(A2+),D3	LOAD.L	(A2+),D3	LOAD.L	A1,A2		; A1 <-- ^premier point	LOAD.L	(A2+),(A4)+2CHCCONT$:	LOAD.L	(A2+),(A4)+2	LOAD.L	(A2+),(A4)+2+4	LOAD.L	(A2+),(A4)+2+4+4	LOAD.L	(A2),(A4)+2+4+4+4	CALL	_LST_NEXT	; A4 <-- ^lment suivant	DEC.W	D4	JUMP,NE	CHCLOOP$	LOAD.L	(A2)+4,(A2)	ADD.L	A2,#8	LOAD.L	D3,(A1)+4	COMP.L	D3,(A2)-8	; premier point = dernier point ?	JUMP',NE END$		; non => END$	LOAD.L	(A1)+0,(A2)-12	LOAD.L	(A2)-4,(A1)+8	JUMP'	END$CHEND$:	CALL	_LST_NEXT	; A4 <-- ^lment suivant	DEC.W	D4	JUMP,NE	CHEND$;	JUMP'	END$END$:	LOAD.L	D4,A2	SUB.L	D4,A3	SR.L	D4,#2		; D4 <-- nb de points	POPM.L	D3,D6,A1,A2	RET;-----------\\; FRAGONLYBZ >;-----------/; Transforme toutes les droites en courbes si ncessaire.; in	A3.L	^buffer des points;	D4.W	nb de points; out	-; mod	D7.WFRAGONLYBZ:	PUSHM.L	D3,D4,A3,A4	TEST.B	(A6)+OFRAFA+3:#1 ; fragmente uniquement en courbes ?	JUMP,BC EXIT$	LOAD.L	A4,A3LOOP$:	LOAD.L	D3,(A3)+4	COMP.L	D3,#ENDLOC	JUMP',EQ NEXT$	COMP.L	D3,(A3)+8	; P1 = C1 ?	JUMP',NE NEXT$	LOAD.L	D3,(A3)+16	COMP.L	D3,#ENDLOC	JUMP',EQ NEXT$	COMP.L	D3,(A3)+12	; P2 = C2 ?	JUMP',NE NEXT$	LOAD.L	D3,(A3)+16	SUB.W	D3,(A3)+4+2	ASR.W	D3,#2	ADD.W	D3,(A3)+4+2	SWAP.W	D3	SUB.W	D3,(A3)+4+0	ASR.W	D3,#2	ADD.W	D3,(A3)+4+0	SWAP.W	D3	LOAD.L	(A3)+8,D3	LOAD.L	D3,(A3)+4	SUB.W	D3,(A3)+16+2	ASR.W	D3,#2	ADD.W	D3,(A3)+16+2	SWAP.W	D3	SUB.W	D3,(A3)+16+0	ASR.W	D3,#2	ADD.W	D3,(A3)+16+0	SWAP.W	D3	LOAD.L	(A3)+12,D3NEXT$:	LOAD.L	A3,#(A3)+12	SUB.W	D4,#3	COMP.W	D4,#3	JUMP,GT LOOP$	LOAD.L	D3,(A3)+4	COMP.L	D3,(A4)+4	; courbe ferme ?	JUMP',NE EXIT$		; non => EXIT$	LOAD.L	(A4)+0,(A3)+0	LOAD.L	(A3)+8,(A4)+8EXIT$:	POPM.L	D3,D4,A3,A4	RET;-----------\\; FRAGCREATE >;-----------/; Cre un objet d'aprs une liste de points.; in	A3.L	^buffer des points;	D4.W	nb de points;	A2.L	^objet  fragmenter;	D3.W	identificateur de l'objet  crer; out	D7.W	erreur; mod	D7.WFRAGCREATE:	PUSHM.L	D0..D4,D6,A4	CALL	GETACH		; D6 <-- canal de l'arbre des objets	LOAD.W	D2,D4		; D2 <-- nb de points	JUMP',EQ OK$	LOAD.W	D0,#IDENTCURVE	COMP.W	D3,#IDFRAGCURVE	JUMP',EQ IDENT$	COMP.W	D3,#IDFRAGCHCURVE	JUMP',EQ IDENT$	LOAD.W	D0,#IDENTPOLYIDENT$:	LOAD.W	D1,#opCRGETLG	CALL	_OBJCALL	; D4 <-- longueur ncessaire	JUMP,NE EXIT$	PUSH.L	A3	LOAD.L	A3,#0	LOAD.L	A4,A2		; A4 <-- ^o insrer	CALL	_LSTA_INSERT	; A4 <-- ^nouvel objet	POPM.L	A3	JUMP,NE EXIT$	LOAD.W	(A4)+OobjIDENT,D0	SET.B	(A6)+OMAJ	; mise  jour sur disque ncessaire	LOAD.W	D1,#opCRINIT	CALL	_OBJCALLD	; initialise l'objet	JUMP',NE DEL$	LOAD.W	D4,D2		; D4 <-- nb de points	LOAD.W	D3,#CRMOVELIST	; D3 <-- donne une liste	LOAD.W	D1,#opCRMOVE	CALL	_OBJCALLD	; cre selon la liste	JUMP',NE DEL$	CALL	_LSTO_CCOMPACT	; A4 <-- ^objet compactOK$:	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$DEL$:	PUSH.W	D7	LOAD.W	D1,#opCRCLOSE	CALL	_OBJCALLD	; ferme l'objet fragment	CALL	_LSTA_REMOVE	; enlve l'objet fragment	POP.W	D7EXIT$:	POPM.L	D0..D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; FRAGBEGIN >;----------/; Dbut des oprations de fragmentations.; in	-; out	D7.W	erreur; mod	D7.WFRAGBEGIN:	PUSHM.L	D3,D4,D6	CLR.L	D3		; D3 <-- mode	CLR.W	D4		; D4 <-- lg par dfaut	CALL	_LST_OPEN	; ouvre une nouvelle liste	JUMP',NE EXIT$	LOAD.L	(A6)+OFRACH,D6	; OFRACH <-- canal de la liste de fragmentationEXIT$:	POPM.L	D3,D4,D6	TEST.W	D7		; retour EQ/NE	RET;---------\\; FRAGBUFF >;---------/; Donne de la mmoire pour la fragmentation suivante.; in	D2.W	lg ncessaire; out	A2.L	^buffer;	D7.W	erreur; mod	D7.W, A2.LFRAGBUFF:	PUSHM.L	D4,D6,A4	LOAD.W	D4,D2		; D4 <-- lg	LOAD.L	A4,#0		; A4 <-- insre  la tte	LOAD.L	D6,(A6)+OFRACH	; D6 <-- canal de la liste de fragmentation	CALL	_LST_INSERT	; A4 <-- ^lment nouveau	JUMP',NE EXIT$	LOAD.L	A2,A4		; A2 <-- ^o mettre le dataEXIT$:	POPM.L	D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; FRAGEND >;--------/; Fin des oprations de fragmentations.; in	-; out	-; mod	D7.WFRAGEND:	PUSH.L	D6	LOAD.L	D6,(A6)+OFRACH	; D6 <-- canal de la liste de fragmentation	JUMP',EQ EXIT$	CALL	_LST_CLOSE	; libre toute la liste	CLR.L	(A6)+OFRACH	; plus de liste de fragmentationEXIT$:	POP.L	D6	RET	.END