	.SBTTL	PAGEDBOX.ASI;----------\\; DBOXEDITO >;==========/; Edite un nom de fichier en sortie.; in	A3.L	^nom du fichier;	D4.L	fanions par dfaut;	D2.W	mode; out	D2.W	mode;	D3.W	dernire touche (F1/F4/F0);	D7.W	erreur; mod	D2.L, D3.L, D7.WDBOXEDITO:	PUSHM.L	D1,D4,D5,A2..A5	TEST.B	(A3)		; nom du fichier existe ?	JUMP',EQ 10$		; non => 10$				; oui =>	CLR.W	D7		; D7 <-- ok	LOAD.W	D3,#F1		; D3 <-- comme si (SAUVE)	TEST.L	D2:#BDBAUTO	; mode automatique ?	JUMP,BS	EXIT$		; oui => EXIT$10$:	CALL	DBOXOPEN1	LOAD.W	D4,D2		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"TEXPA	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_SAUVE	; D1 <-- code du sous-appel	TSET.L	D2:#BDBEXTEND	; D2 <-- sous-appel d'extension	TSET.L	D2:#BDBSAV	; D2 <-- sauve le fond	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1	TEST.L	D2:#BDBNMAJ	JUMP',BC 30$	TSET.L	D3:#BDBIONMAJ	; D3 <-- touche (MET A JOUR) grise30$:	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	LOAD.W	D2,D4		; D2 <-- nouveau mode (fanions)	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7EXIT$:	POPM.L	D1,D4,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXEDITE >;==========/; Edite un nom de fichier en sortie (extraction).; in	A3.L	^nom du fichier;	D4.L	fanions; out	D4.L	fanions;	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITE:	PUSHM.L	D1,D2,D5,A2..A5	CALL	DBOXOPEN1	TEST.L	D4	JUMP',NE FANOK$	LOAD.L	D4,#2^15FANOK$:	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A2,#R16"TDBOX_EDITE	LOAD.L	A3,#R16"TDBOX_IOL	LOAD.L	A4,#R16"TEXEX	; A4 <-- ^critre de recherche (extensions)	LOAD.W	D1,#DBOX_EXTRAIT; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOOBJ!2^BDBIOEXTM	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7	POPM.L	D1,D2,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX_EDITE:	.B	LDBOX_EDITE	.B	ODBLCIRCLE,15!2^7,0,1	.ASCIZ	" sauve une partie de page (.LPAGE)"	.B	ODBCR	.B	ODBLCIRCLE,14!2^7,0,1	.ASCIZ	" sauve une image DESSIN4  (.IMAGE)"	.B	ODBCRLDBOX_EDITE = .-TDBOX_EDITE-1	.EVEN;----------\\; DBOXEDITI >;==========/; Edite un nom de fichier en entre (prend).; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITI:	PUSHM.L	D1,D2,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.L	A4,#R16"TEXPA	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_PREND	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7EXIT$:	POPM.L	D1,D2,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBOXEDITA >;==========/; Edite un nom de fichier en entre (ajoute).; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXEDITA:	PUSHM.L	D1,D2,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IOL	LOAD.L	A4,#R16"TEXLPA	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_AJOUTE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUFILE!2^BDBIOEXT1	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7EXIT$:	POPM.L	D1,D2,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBOXSAVE >;=========/; Sauve le gencar selon le choix de l'utilisateur.; in	D0.W	mode (0=quitte, 1=nouveau texte); out	D7.W	0	=> ok, on peut quitter;		1	=> (ANNULE), donc on reste;		autre	=> erreur grve; mod	D7.WDBOXSAVE:	PUSHM.L	D1..D5,A2..A5	TEST.B	(A6)+OMAJ	; mise  jour ncessaire ?	JUMP,F	80$		; non => 80$ (quitte, snif)				; oui =>	CALL	DBOXOPEN1	CLR.L	D3		; D3 <-- numro de la zone	TEST.B	D0	JUMP',NE 25$	TSET.L	D3:#BDBIOQUIT	; D3 <-- texte "avant de quitter"25$:	LOAD.L	A5,#(A6)+OBUNAME; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_MAJ	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7	COMP.W	D3,#F0		; ANNULE ?	JUMP',EQ 85$	COMP.W	D3,#F4		; NON ?	JUMP',EQ 80$	LOAD.W	D2,#2^BDBAUTO	; D2 <-- mode automatique	CALL	SAUVETOUT	; sauve tout sur disque	JUMP'	EXIT$80$:	CLR.W	D7		; D7 <-- quitte	JUMP'	EXIT$85$:	LOAD.W	D7,#1		; D7 <-- resteEXIT$:	POPM.L	D1..D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXQUITTE >;===========/; Demande si l'on veut quitter DESSIN.; in	-; out	D3.W	dernire touche (F1/F4);	D7.W	erreur; mod	D3.L, D7.WDBOXQUITTE:	PUSHM.L	D1,D2,D4,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_QUITTE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	CLR.L	D3	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7EXIT$:	POPM.L	D1,D2,D4,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBOXEFFACE >;===========/; Demande s'il faut effacer le gencar.; in	-; out	D3.W	dernire touche (F1/F4);	D7.W	erreur; mod	D3.L, D7.WDBOXEFFACE:	PUSHM.L	D1,D2,D4,D5,A2..A5	CALL	DBOXOPEN1	CLR.L	D4		; D4 <-- fanions	CLR.L	D3		; D3 <-- numro de la zone	LOAD.L	A5,#(A6)+OBUNAME; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IO	LOAD.W	D1,#DBOX_EFFACE	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	CALL	DBOXPOS5	; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7	POPM.L	D1,D2,D4,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBOXDEFPAGE >;============/; Demande les dfinitions de page.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXDEFPAGE:	PUSHM.L	D0..D2,D4,D5,A0..A5	PUSH.L	(A6)+ODESYD	PUSH.W	(A6)+ODESMG	PUSH.W	(A6)+ODESMD	PUSH.W	(A6)+ODESMS	PUSH.W	(A6)+ODESMI	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur fentre	LOAD.L	A5,A6		; A5 <-- ^variables pour put/get	LOAD.L	A2,#R16"TDBOX$	CALL	DBOXMEMPT	LOAD.L	A2,#R16"DBDFPPINV	CALL	DBOXMEMAFC	LOAD.L	A2,#R16"TDBOX_DEFPAGE	LOAD.W	D2,#2^BDBSAV	CLR.L	D4	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	CALL	DBDFPDRAW	; dessine la scroll-list	CALL	DBDFPPINIT	; initialise la pageDIM$:	CLR.W	(A6)+ODBPA1	CLR.W	(A6)+ODBPA2	CLR.W	(A6)+ODBPA3	CLR.W	(A6)+ODBPA4	CALL	GETPRIDIM	; D4/D3/D2 <-- dimensions/marges hard	JUMP',NE DIM2$	LOAD.W	(A6)+ODBPA1,D3	SWAP.W	D3	LOAD.W	(A6)+ODBPA3,D3	LOAD.W	(A6)+ODBPA2,D2	SWAP.W	D2	LOAD.W	(A6)+ODBPA4,D2DIM2$:	CLR.W	D2REFAIT$:	PUSH.W	D2	CLR.W	D2AFF$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXAFF		; affiche le paramtre	INC.W	D2	COMP.W	D2,#6	JUMP,LO AFF$	POP.W	D2NLINE$:	CALL	DBDFPPINV	; allume la pageNLINEP$:	CALL	DBDFPUPDATE	; mj la scroll-liste	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXMEDITLOOP$:	DBOX_	EDIT		; attend action ...	CALL	ZEROCR	LOAD.L	A1,#R16"TKEY_DEFPAGE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ DAC$	COMP.W	D3,#F4	JUMP,EQ CHOIX$	COMP.W	D3,#F0	JUMP,EQ CANCEL$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#CLEAR	JUMP',EQ UNDO$	COMP.W	D3,#CR	JUMP',EQ RETURN$	COMP.W	D3,#ENTER	JUMP',EQ RETURN$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP',EQ KEYDBOX$	JUMP'	BIP$BIPP$:	CALL	DBDFPPINV	; allume la pageBIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	CALL	DBDFPPINV	; efface la page	CALL	DBOXPUT	JUMP,NE BIPP$	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,#6	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$KEYDBOX$:			; KEYDBOX =>	CALL	DBDFPPINV	; efface la page	CALL	DBOXPUT	JUMP,NE BIPP$	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$CLIC$:	LOAD.W	D7,#DB_CLIC	PAGE_	DBOX	JUMP,EQ NLINEP$	CALL	DBDFPPINV	; efface la page	LIB	?IFMOUSE	; D4 <-- position de la souris (y;x)	JUMP,NE BIPP$	SUB.W	D4,(A0)+ODFFX	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	SWAP.W	D4	CALL	DBDFPMOVE	; dplace la scroll-liste ...	JUMP,EQ REFAIT$	CALL	DBDFPPINV	; allume la page	CALL	DBDFPPMOVE	; dplace la page ...	JUMP,EQ NLINEP$	JUMP	BIP$CHOIX$:	CALL	DBDFPPINV	; efface la page	CALL	DBOXPUT	JUMP,NE BIPP$	LOAD.L	A2,(A6)+OCAPRINT	CLR.L	D3	PRINTA_	SELECTION	; choix prsentation/papier/imprimante ...	LOAD.L	A2,#R16"TDBOX_DEFPAGE	CALL	DBOXRSK		; refait les soft-keys	CALL	GETPRIDIP	; D4/D3/D2 <-- dimensions/marges prsentation	JUMP,NE BIPP$	LOAD.W	(A6)+ODESXD,D4	SWAP.W	D4	LOAD.W	(A6)+ODESYD,D4	LOAD.W	(A6)+ODESMG,D3	SWAP.W	D3	LOAD.W	(A6)+ODESMS,D3	LOAD.W	(A6)+ODESMD,D2	SWAP.W	D2	LOAD.W	(A6)+ODESMI,D2	JUMP	DIM$DAC$:				; D'ACCORD =>	CALL	DBDFPPINV	; efface la page	CALL	DBOXPUT	JUMP,NE BIPP$	ADD.L	SP,#2+2+2+2+4	CALL	DBOXCLOSE	; ferme la DBOX	JUMP'	EXIT$CANCEL$:			; ANNULE =>	POP.W	(A6)+ODESMI	POP.W	(A6)+ODESMS	POP.W	(A6)+ODESMD	POP.W	(A6)+ODESMG	POP.L	(A6)+ODESYD	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A0..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	ODESXD,DBTYPU,1000*FACMMPT,(2^15)-1,100*FACMMPT,2^BDBGCLABEL!100,0,8+2	.W	ODESYD,DBTYPU,1000*FACMMPT,(2^15)-1,100*FACMMPT,2^BDBGCLABEL!101,1,8+2	.W	ODESMG,DBTYPU!2^14,ODBPA1,(2^15)-1,10*FACMMPT,2^BDBGCLABEL!102,2,8+2	.W	ODESMD,DBTYPU!2^14,ODBPA2,(2^15)-1,10*FACMMPT,2^BDBGCLABEL!103,3,8+2	.W	ODESMS,DBTYPU!2^14,ODBPA3,(2^15)-1,10*FACMMPT,2^BDBGCLABEL!104,4,8+2	.W	ODESMI,DBTYPU!2^14,ODBPA4,(2^15)-1,10*FACMMPT,2^BDBGCLABEL!105,5,8+2	.W	-1;----------\\; DBDFPDRAW >;----------/; Dessine la scroll-liste.; in	-; out	-; mod	D7.WDBDFPDRAW:	PUSHM.L	D2..D4,A5	LOAD.L	A5,#(A6)+ODBSLV	; A5 <-- ^variables scroll-liste	LOAD.W	D2,#200!2^BDBGCLABEL	DBOX_	GETCO	SWAP.W	D3	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,(A0)+ODFC2Y	SWAP.W	D3	LOAD.L	(A5)+OSLPOS,D3	LOAD.W	D2,#201!2^BDBGCLABEL	DBOX_	GETCO	SUB.W	D3,(A5)+OSLPOS+2	SWAP.W	D3	ADD.W	D3,(A0)+ODFC2Y	SUB.W	D3,(A5)+OSLPOS+0	SWAP.W	D3	LOAD.L	(A5)+OSLDIM,D3	CLR.B	(A5)+OSLVID	CLR.B	(A5)+OSLHOR	SCROLL_	LDRAW		; dessine la scroll-liste	LOAD.W	(A5)+OSLCYS,#-1	POPM.L	D2..D4,A5	RET;------------\\; DBDFPUPDATE >;------------/; Dessine la scroll-liste.; in	-; out	-; mod	D7.WDBDFPUPDATE:	PUSHM.L	D2..D4,A3,A5	LOAD.L	A5,#(A6)+ODBSLV	; A5 <-- ^variables scroll-liste;;?	COMP.W	(A5)+OSLCYS,#LDBDFPPAP-1;;?	JUMP,EQ EXIT$	LOAD.L	A3,#R16"TDBDFPPAP	CLR.W	D3LOOP$:	LOAD.W	D4,(A3)+28	SUB.W	D4,#10*FACMMPT	COMP.W	D4,(A6)+ODESXD	JUMP',HS NEXT$	ADD.W	D4,#20*FACMMPT	COMP.W	D4,(A6)+ODESXD	JUMP',LO NEXT$	LOAD.W	D4,(A3)+30	SUB.W	D4,#10*FACMMPT	COMP.W	D4,(A6)+ODESYD	JUMP',HS NEXT$	ADD.W	D4,#20*FACMMPT	COMP.W	D4,(A6)+ODESYD	JUMP',HS FOUND$NEXT$:	LOAD.L	A3,#(A3)+32	; A3 <-- ^papier suivant	INC.W	D3	COMP.W	D3,#LDBDFPPAP-1	JUMP,LO LOOP$FOUND$:	COMP.W	D3,(A5)+OSLCYS	; est-ce cette case dj slectionne ?	JUMP',EQ EXIT$		; oui => EXIT$	LOAD.W	(A5)+OSLCYS,D3	LOAD.W	(A5)+OSLCYN,#LDBDFPPAP	LOAD.L	A3,#R16"DBDFPGET	LOAD.L	(A5)+OSLADL,A3	SCROLL_	LUPDATE		; dessine le contenuEXIT$:	POPM.L	D2..D4,A3,A5	RET;---------\\; DBDFPGET >;---------/; Donne le texte  mettre dans la scroll-liste.; in	D3.W	rang de la case (0..n); out	A3.L	^contenu;	D3.W	ligne; mod	D3.L, D7.W, A3.LDBDFPGET:	LOAD.L	A3,#R16"TDBDFPPAP	MUL.WU	D3,#32	ADD.L	A3,D3		; A3 <-- ^texte	CLR.W	D3	LOAD.B	D3,(A3)+27	; D3 <-- ligne	CLR.W	D7		; retour EQ	RET;----------\\; DBDFPMOVE >;----------/; Dplace la scroll-liste.; in	D4.L	position de la souris (y;x); out	D7.W	erreur; mod	D7.WDBDFPMOVE:	PUSHM.L	D3,A3,A5	LOAD.L	A5,#(A6)+ODBSLV	; A5 <-- ^variables scroll-liste	SCROLL_	LMOVE		; dplace la scroll-liste	JUMP',NE EXIT$	LOAD.W	D3,(A5)+OSLCYS	CALL	DBDFPGET	; A3 <-- ^contenu de la case choisie	TEST.W	(A3)+28	JUMP',EQ EXIT$	LOAD.W	(A6)+ODESXD,(A3)+28	LOAD.W	(A6)+ODESYD,(A3)+30EXIT$:	POPM.L	D3,A3,A5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBDFPPINIT >;-----------/; Initialise la page.; in	-; out	-; mod	D7.WDBDFPPINIT:	PUSHM.L	D2..D4	LOAD.W	D2,#202!2^BDBGCLABEL	DBOX_	GETCO	ADD.W	D3,#4	SWAP.W	D3	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,(A0)+ODFC2Y	SWAP.W	D3	LOAD.L	(A6)+ODBDPC,D3	LOAD.W	D2,#203!2^BDBGCLABEL	DBOX_	GETCO	SUB.W	D3,(A6)+ODBDPC+2	LOAD.L	D4,#(2^15)-1	DIV.WU	D4,D3	LOAD.W	(A6)+ODBDPF,D4	LIB	?AFTIM	.B	MAPTT	.B	B'10001000	.B	1	.B	0	.EVEN	LOAD.L	D4,#(2^15)-1	DIV.WU	D4,(A6)+ODBDPF	LOAD.W	D3,D4	SWAP.W	D4	LOAD.W	D4,D3	LOAD.L	D3,(A6)+ODBDPC	LOAD.W	D2,#INVDOT!TTTDOT	LIB	?DRRECT	POPM.L	D2..D4	RET;-----------\\; DBDFPPMOVE >;-----------/; Dplace une poigne.; in	D4.L	position de la souris (y;x); out	D7.W	erreur; mod	D7.WDBDFPPMOVE:	PUSHM.L	D2..D4	CALL	DBDFPPDET	; D2 <-- poigne o est la souris	JUMP',NE EXIT$LOOP$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP',NE EXIT$	LIB	?IFMOUSE	; D4 <-- position de la souris (y;x)	JUMP,NE LOOP$	SUB.W	D4,(A0)+ODFFX	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	SWAP.W	D4	LOAD.L	D3,D4	CALL	DBDFPPINV	; efface l'ancien	CALL	DBDFPPDEP	CALL	DBDFPPINV	; allume le nouveau	JUMP	LOOP$EXIT$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBDFPPDET >;----------/; Dtecte dans quelle poigne est la souris.; in	D4.L	position de la souris (y;x); out	D2.W	rang (0..2);	D7.W	erreur; mod	D2.L, D7.WDBDFPPDET:	PUSHM.L	D3..D5	LOAD.L	D5,D4		; D4 <-- position en X	SWAP.W	D5		; D5 <-- position en Y	CLR.W	D2LOOP$:	CALL	DBDFPPPOS	; D3 <-- position poigne	SUB.W	D3,#5	COMP.W	D4,D3	JUMP',LT NEXT$	ADD.W	D3,#5+5	COMP.W	D4,D3	JUMP',GE NEXT$	SWAP.W	D3	SUB.W	D3,#5	COMP.W	D5,D3	JUMP',LT NEXT$	ADD.W	D3,#5+5	COMP.W	D5,D3	JUMP',GE NEXT$	CLR.W	D7		; D7 <-- trouv	JUMP'	EXIT$NEXT$:	INC.W	D2	COMP.W	D2,#5	JUMP,LO LOOP$	LOAD.W	D7,#1EXIT$:	POPM.L	D3..D5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBDFPPINV >;----------/; Inverse la page.; in	-; out	-; mod	D7.WDBDFPPINV:	PUSHM.L	D1..D4	LIB	?AFTIM	.B	MAPTT	.B	B'10101010	.B	1	.B	0	.EVEN	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	CLR.W	D2	CALL	DBDFPPPOS	; D3 <-- position poigne	LOAD.L	D4,D3	LOAD.L	D3,(A6)+ODBDPC	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRRECT	LOAD.W	D2,#2	CALL	DBDFPPPOS	; D3 <-- position poigne	LOAD.W	D4,D3	LOAD.W	D2,#4	CALL	DBDFPPPOS	; D3 <-- position poigne	SUB.W	D4,D3	PUSH.W	D3	PUSH.W	D4	LOAD.W	D2,#3	CALL	DBDFPPPOS	; D3 <-- position poigne	SWAP.W	D3	LOAD.W	D4,D3	LOAD.W	D2,#1	CALL	DBDFPPPOS	; D3 <-- position poigne	SWAP.W	D3	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	POP.W	D4	POP.W	D3	LOAD.W	D2,#INVDOT!TTTDOT	LIB	?DRRECT	CLR.W	D1LOOP$:	LOAD.W	D2,D1	CALL	DBDFPPPOS	; D3 <-- position poigne	SUB.W	D3,#3	SWAP.W	D3	SUB.W	D3,#3	SWAP.W	D3	LOAD.L	D4,#H'10000*7+7	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	; inverse une poigne	INC.W	D1	COMP.W	D1,#5	JUMP,LO LOOP$	POPM.L	D1..D4	RET;----------\\; DBDFPPDEP >;----------/; Dplace une poigne.; in	D3.L	nouvelle position (y;x);	D2.W	rang (0..2); out	-; mod	D7.WDBDFPPDEP:	PUSHM.L	D2..D4,A3,A4	SUB.W	D3,(A6)+ODBDPC+2	JUMP',NC OKX1$	CLR.W	D3OKX1$:	LOAD.W	D4,D3	MUL.WU	D4,(A6)+ODBDPF	COMP.L	D4,#(2^15)-1	JUMP',LS OKX2$	LOAD.W	D4,#(2^15)-1OKX2$:	LOAD.W	D3,D4	SWAP.W	D3	SUB.W	D3,(A6)+ODBDPC+0	JUMP',NC OKY1$	CLR.W	D3OKY1$:	LOAD.W	D4,D3	MUL.WU	D4,(A6)+ODBDPF	COMP.L	D4,#(2^15)-1	JUMP',LS OKY2$	LOAD.W	D4,#(2^15)-1OKY2$:	LOAD.W	D3,D4	SWAP.W	D3	COMP.W	D2,#1	JUMP',EQ P1$	COMP.W	D2,#2	JUMP',EQ P2$	COMP.W	D2,#3	JUMP,EQ P3$	COMP.W	D2,#4	JUMP,EQ P4$P0$:	LOAD.L	(A6)+ODESYD,D3	CLR.W	D2	CALL	DBOXGET	CALL	DBOXAFF	LOAD.W	D2,#1	CALL	DBOXGET	CALL	DBOXAFF	JUMP	EXIT$P1$:	SWAP.W	D3	COMP.W	D3,(A6)+ODBPA3	JUMP',GE P1OK$	LOAD.W	D3,(A6)+ODBPA3P1OK$:	LOAD.W	(A6)+ODESMS,D3	LOAD.W	D2,#4	CALL	DBOXGET	CALL	DBOXAFF	JUMP	EXIT$P2$:	SUB.W	D3,(A6)+ODESXD	NEG.W	D3	COMP.W	D3,(A6)+ODBPA2	JUMP',GE P2OK$	LOAD.W	D3,(A6)+ODBPA2P2OK$:	LOAD.W	(A6)+ODESMD,D3	LOAD.W	D2,#3	CALL	DBOXGET	CALL	DBOXAFF	JUMP'	EXIT$P3$:	SWAP.W	D3	SUB.W	D3,(A6)+ODESYD	NEG.W	D3	COMP.W	D3,(A6)+ODBPA4	JUMP',GE P3OK$	LOAD.W	D3,(A6)+ODBPA4P3OK$:	LOAD.W	(A6)+ODESMI,D3	LOAD.W	D2,#5	CALL	DBOXGET	CALL	DBOXAFF	JUMP'	EXIT$P4$:	COMP.W	D3,(A6)+ODBPA1	JUMP',GE P4OK$	LOAD.W	D3,(A6)+ODBPA1P4OK$:	LOAD.W	(A6)+ODESMG,D3	LOAD.W	D2,#2	CALL	DBOXGET	CALL	DBOXAFF;	JUMP'	EXIT$EXIT$:	POPM.L	D2..D4,A3,A4	RET;----------\\; DBDFPPPOS >;----------/; Donne la position d'une poigne.; in	D2.W	rang (0..2); out	D3.L	position (y;x); mod	D3.L, D7.WDBDFPPPOS:	PUSH.L	D4	COMP.W	D2,#1	JUMP',EQ P1$	COMP.W	D2,#2	JUMP',EQ P2$	COMP.W	D2,#3	JUMP',EQ P3$	COMP.W	D2,#4	JUMP',EQ P4$P0$:	LOAD.L	D3,(A6)+ODESYD	JUMP'	EXIT$P1$:	LOAD.W	D3,(A6)+ODESMS	SWAP.W	D3	LOAD.W	D3,(A6)+ODESXD	SR.W	D3,#1	JUMP'	EXIT$P2$:	LOAD.W	D3,(A6)+ODESYD	SR.W	D3,#1	SWAP.W	D3	LOAD.W	D3,(A6)+ODESXD	SUB.W	D3,(A6)+ODESMD	JUMP'	EXIT$P3$:	LOAD.W	D3,(A6)+ODESYD	SUB.W	D3,(A6)+ODESMI	SWAP.W	D3	LOAD.W	D3,(A6)+ODESXD	SR.W	D3,#1	JUMP'	EXIT$P4$:	LOAD.W	D3,(A6)+ODESYD	SR.W	D3,#1	SWAP.W	D3	LOAD.W	D3,(A6)+ODESMG;	JUMP'	EXIT$EXIT$:	CLR.L	D4	LOAD.W	D4,D3	DIV.WU	D4,(A6)+ODBDPF	LOAD.W	D3,D4	ADD.W	D3,(A6)+ODBDPC+2	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,D3	DIV.WU	D4,(A6)+ODBDPF	LOAD.W	D3,D4	ADD.W	D3,(A6)+ODBDPC+0	SWAP.W	D3	POP.L	D4	RETTDBDFPPAP:	.ASCIZ	"A2 vertical               "	.B	0	.W	4200*FACMMPT,5940*FACMMPT	.ASCIZ	"A2 horizontal             "	.B	0	.W	5940*FACMMPT,4200*FACMMPT	.ASCIZ	"A3 vertical               "	.B	0	.W	2970*FACMMPT,4200*FACMMPT	.ASCIZ	"A3 horizontal             "	.B	0	.W	4200*FACMMPT,2970*FACMMPT	.ASCIZ	"A4 vertical               "	.B	0	.W	2100*FACMMPT,2970*FACMMPT	.ASCIZ	"A4 horizontal             "	.B	0	.W	2970*FACMMPT,2100*FACMMPT	.ASCIZ	"A5 vertical               "	.B	0	.W	1480*FACMMPT,2100*FACMMPT	.ASCIZ	"A5 horizontal             "	.B	0	.W	2100*FACMMPT,1480*FACMMPT	.ASCIZ	"A6 vertical               "	.B	0	.W	1050*FACMMPT,1480*FACMMPT	.ASCIZ	"A6 horizontal             "	.B	1	.W	1480*FACMMPT,1050*FACMMPT	.ASCIZ	"B5 vertical               "	.B	0	.W	1760*FACMMPT,2500*FACMMPT	.ASCIZ	"B5 horizontal             "	.B	0	.W	2500*FACMMPT,1760*FACMMPT	.ASCIZ	"B6 vertical               "	.B	0	.W	1250*FACMMPT,1760*FACMMPT	.ASCIZ	"B6 horizontal             "	.B	1	.W	1760*FACMMPT,1250*FACMMPT	.ASCIZ	"C5 vertical               "	.B	0	.W	1620*FACMMPT,2290*FACMMPT	.ASCIZ	"C5 horizontal             "	.B	0	.W	2290*FACMMPT,1620*FACMMPT	.ASCIZ	"C6 vertical               "	.B	0	.W	1140*FACMMPT,1620*FACMMPT	.ASCIZ	"C6 horizontal             "	.B	1	.W	1620*FACMMPT,1140*FACMMPT	.ASCIZ	"E6 vertical               "	.B	0	.W	1400*FACMMPT,2000*FACMMPT	.ASCIZ	"E6 horizontal             "	.B	1	.W	2000*FACMMPT,1400*FACMMPT	.ASCIZ	"US letter vertical        "	.B	0	.W	2160*FACMMPT,2790*FACMMPT	.ASCIZ	"US letter horizontal      "	.B	1	.W	2790*FACMMPT,2160*FACMMPT	.ASCIZ	"autre ...                 "	.B	0	.W	0,0LDBDFPPAP =	(.-TDBDFPPAP)/32TDBOX_DEFPAGE:	.W	10$-TDBOX_DEFPAGE	.W	20$-TDBOX_DEFPAGE	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Format d'une page :"	.B	ODBTABX,24+2	.B	ODBTEXT	.ASCIZ	"Largeur"	.B	ODBLABEL,100	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTABX,24+2+22	.B	ODBLABEL,202	.B	ODBTEXT,0	.B	ODBTABX,24+2+22+24+1	.B	ODBCR,ODBCR	.B	ODBLABEL,200	.B	ODBTEXT,0	.B	ODBTABX,24+2	.B	ODBTEXT	.ASCIZ	"Hauteur"	.B	ODBLABEL,101	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,101,TDBNORM	.B	ODBCR,ODBCR,ODBCR	.B	ODBTABX,24+2	.B	ODBTEXT	.ASCIZ	"Marges :"	.B	ODBCR,ODBCR	.B	ODBTABX,24+2	.B	ODBTEXT	.ASCIZ	"Gauche "	.B	ODBLABEL,102	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,102,TDBNORM	.B	ODBCR,ODBCR	.B	ODBTABX,24+2	.B	ODBTEXT	.ASCIZ	"Droite "	.B	ODBLABEL,103	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,103,TDBNORM	.B	ODBCR,ODBCR	.B	ODBTABX,24+2	.B	ODBTEXT	.ASCIZ	"Sup.   "	.B	ODBLABEL,104	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,104,TDBNORM	.B	ODBTABX,24	.B	ODBLABEL,201	.B	ODBTEXT,0	.B	ODBTABX,24+2+22+24-1	.B	ODBLABEL,203	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	" "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	ODBTABX,24+2	.B	ODBTEXT	.ASCIZ	"Inf.   "	.B	ODBLABEL,105	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,105,TDBNORM	.B	ODBTABX,24+2+22	.B	ODBBOX,0,F4,TDBOMBRE	.ASCIZ	"   CHOIX IMPRIMANTE   "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Choix"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_DEFPAGE:	.W	F1,F2,F3,0		DOKF1-TKEY_DEFPAGE	.W	F4,F5,F6,0		DOKF4-TKEY_DEFPAGE	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_DEFPAGE	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_DEFPAGE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_DEFPAGE	.W	0;------------\\; DBOXDEFUNIT >;============/; Demande les dfinitions d'unit.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXDEFUNIT:	PUSHM.L	D1,D2,D4,D5,A1..A4	CLR.L	D4	LOAD.W	D3,(A6)+OUNIT	TSET.L	D4:D3	LOAD.L	A2,#R16"TDBOX_DEFUNIT	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$LOOP$:	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_DEFUNIT	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP',EQ DAC$	COMP.W	D3,#F0	JUMP',EQ CANCEL$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$DAC$:				; D'ACCORD =>	LOAD.W	D1,#-1ULOOP$:	INC.W	D1	RR.W	D4,#1	JUMP,CC ULOOP$	LOAD.W	(A6)+OUNIT,D1CANCEL$:			; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_DEFUNIT:	.W	10$-TDBOX_DEFUNIT	.W	20$-TDBOX_DEFUNIT	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Dfinition de l'unit de travail :"	.B	ODBCR,ODBCR	.B	ODBLCIRCLE,UNITMM	.ASCIZ	" mm  (millimtre)"	.B	ODBTABX,26	.B	ODBLCIRCLE,UNITDI	.ASCIZ	" di  (didot)"	.B	ODBCR	.B	ODBLCIRCLE,UNITCM	.ASCIZ	" cm  (centimtre)"	.B	ODBTABX,26	.B	ODBLCIRCLE,UNITCI	.ASCIZ	" ci  (cicro)"	.B	ODBCR	.B	ODBLCIRCLE,UNITIN	.ASCIZ	" in  (pouce)"	.B	ODBTABX,26	.B	ODBLCIRCLE,UNITPI	.ASCIZ	" pi  (pica)"	.B	ODBCR	.B	ODBLCIRCLE,UNITPT	.ASCIZ	" pt  (point interne)"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	"  ANNULE  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_DEFUNIT:	.W	F1,F2,F3,CR,0		DOKF1-TKEY_DEFUNIT	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_DEFUNIT	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_DEFUNIT	.W	0;------------\\; DBOXDEFMOUS >;============/; Demande les dfinitions pour la souris.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXDEFMOUS:	PUSHM.L	D1,D2,D4,D5,A1..A4	CLR.L	D4	LOAD.W	D4,(A6)+ODEF	; D4 <-- dfinitions gnrales	LOAD.L	A2,#R16"TDBOX_DEFMOUS	LOAD.W	D2,#2^BDBSAV	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$LOOP$:	DBOX_	EDIT		; attend action ...	LOAD.L	A1,#R16"TKEY_DEFMOUS	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP',EQ DAC$	COMP.W	D3,#F0	JUMP',EQ CANCEL$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$DAC$:				; D'ACCORD =>	LOAD.W	(A6)+ODEF,D4	; ODEF <-- dfinitions gnralesCANCEL$:			; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_DEFMOUS:	.W	10$-TDBOX_DEFMOUS	.W	20$-TDBOX_DEFMOUS	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Dfinitions pour la souris :"	.B	ODBCR,ODBCR	.B	ODBSQUARE,BDEFOGD	.ASCIZ	" boutons gauche et droite --<'>> 2 outils"	.B	ODBCR	.B	ODBSQUARE,BDEFMDC	.ASCIZ	" mmorise la dernire case";;?	.B	ODBCR;;?	.B	ODBSQUARE,BDEFRET;;?	.ASCIZ	" rticule"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	"  ANNULE  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_DEFMOUS:	.W	F1,F2,F3,CR,0		DOKF1-TKEY_DEFMOUS	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_DEFMOUS	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_DEFMOUS	.W	0;-----------\\; DBOXDEFOBJ >;===========/; Demande les dfinitions pour les objets.; in	-; out	D3.W	dernire touche;	A3.L	^noms des objets;	D7.W	erreur; mod	D3.L, D7.W, A3.LDBOXDEFOBJ:	PUSHM.L	D0..D2,D4,D5,A0..A2,A4,A5	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur fentre	LOAD.L	A2,#R16"TDBOX_DEFOBJ	LOAD.W	D2,#2^BDBSAV	CLR.L	D4	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	CALL	DBDFOLIST	; A2/D2 <-- liste des objets	JUMP,NE CANCEL$	CALL	DBDFODRAW	; dessine la scroll-list	CALL	DBDFOUPDATE	; mj la scroll-listFAN$:	LOAD.W	D2,#100!2^BDBGCLABEL!2^BDBGCFULL	LOAD.W	D1,#B'01	; D1 <-- fanion "n'utilise pas"	LOAD.W	D3,(A6)+ODBSLV+OSLCYS	CALL	DBDFOGET	; A3 <-- ^case	TEST.B	(A3)+7		; objet utilis ?	JUMP',EQ GREY$		; non => GREY$	LOAD.W	D1,#B'10	; D1 <-- fanion "utilise"	TEST.B	(A3)+19		; objet dconnectable ?	JUMP',EQ GREY$	LOAD.W	D2,#100!2^BDBGCLABEL!2^BDBGCGREYGREY$:	DBOX_	GETCO		; grise/dgrise "n'utilise pas"	LOAD.W	D2,D1		; D2 <-- fanionsLOOP$:	LOAD.L	D4,D2	DBOX_	EDIT		; attend action ...	LOAD.L	D2,D4	LOAD.L	A1,#R16"TKEY_DEFOBJ	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP',EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ DAC$	COMP.W	D3,#F0	JUMP,EQ CANCEL$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP',EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$KEYDBOX$:			; KEYDBOX =>	LOAD.W	D4,D3	LOAD.W	D3,(A6)+ODBSLV+OSLCYS	CALL	DBDFOGET	; A3 <-- ^case	CLR.B	(A3)+7		; objet libre	TEST.B	D4	JUMP',EQ KEYDB2$	LOAD.B	(A3)+7,#SPACE	; objet utilisKEYDB2$:	CALL	DBDFOUPDATE	; mj la scroll-list	JUMP	LOOP$CLIC$:	LIB	?IFMOUSE	; D4 <-- position de la souris (y;x)	JUMP,NE BIP$	SUB.W	D4,(A0)+ODFFX	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	SWAP.W	D4	CALL	DBDFOMOVE	; dplace la scroll-liste ...	JUMP,NE BIP$	JUMP	FAN$DAC$:				; D'ACCORD =>	LOAD.L	A3,#(A6)+OIOBH+OHNOBJ	LOAD.L	A4,#(A6)+OIOTM	LOAD.W	D4,(A6)+ODBSLV+OSLCYN	JUMP',EQ DAC5$DAC1$:	TEST.B	(A4)+7		; objet utilis ?	JUMP',EQ DAC4$	LOAD.L	A2,A4DAC2$:	LOAD.B	D3,(A2+)	COMP.B	D3,#SPACE	JUMP',EQ DAC3$	LOAD.B	(A3+),D3	JUMP	DAC2$DAC3$:	CLR.B	(A3+)DAC4$:	LOAD.L	A4,#(A4)+20	DEC.W	D4	JUMP,NE DAC1$DAC5$:	CLR.B	(A3+)	LOAD.L	A3,#(A6)+OIOBH+OHNOBJ	LOAD.W	D3,#F1CANCEL$:			; ANNULE =>	PUSH.W	D7	CALL	DBOXCLOSE	; ferme la DBOX	POP.W	D7EXIT$:	POPM.L	D0..D2,D4,D5,A0..A2,A4,A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBDFOLIST >;----------/; Fait la liste de tous les objets dans le dossier systme.; in	-; out	A2.L	^liste;	D2.W	nb de fichiers trouvs (0..n);	D7.W	erreur; mod	D2.L, D7.W, A2.LDBDFOLIST:	PUSHM.L	D1,D3..D6,A1,A3,A4	CALL	WAITMOUSE	; met le sablier	LOAD.L	A3,#R16"DIR$	LOAD.L	A4,#R16"CRIT$	LOAD.W	D3,#2^BOPSYS	FOS	?LISTOPEN	JUMP',NE EXIT9$	LOAD.W	D7,#ERFDNE	LOAD.W	D2,D4		; D2 <-- nb de fichiers trouvs	JUMP',EQ EXIT8$	LOAD.L	A1,#(A6)+OIOTM	; A1 <-- ^liste	LOAD.W	D1,D2LOOP$:	FOS	?LISTNXT	; A3/A4 <-- ^nom/^arguments	JUMP',NE EXIT8$	LOAD.L	A4,A1	LOAD.L	A2,#R16"DEF$NAME1$:	LOAD.B	(A4+),(A2+)	JUMP,NE NAME1$	LOAD.L	A4,A1	ADD.L	A3,#4		; A3 <-- saute "GRA_"NAME2$:	LOAD.B	D3,(A3+)	COMP.B	D3,#'.	JUMP',EQ NAME4$	LOAD.B	(A4+),D3	JUMP	NAME2$NAME4$:	LOAD.L	A1,#(A1)+20	DEC.W	D1	JUMP,NE LOOP$	LOAD.L	A2,#(A6)+OIOTM	; A2 <-- ^liste	CALL	DBDFOUSE	CLR.W	D7		; D7 <-- okEXIT8$:	PUSH.W	D7	FOS	?LISTCLOSE	POP.W	D7EXIT9$:	CALL	NORMMOUSE	; enlve le sablier	POPM.L	D1,D3..D6,A1,A3,A4	TEST.W	D7		; retour EQ/NE	RETDIR$:	.ASCIZ	""CRIT$:	.ASCIZ	"GRA_*.OPAGE"DEF$:	.ASCIZ	"      : utilise"	.EVEN;---------\\; DBDFOUSE >;---------/; Indique quels sont les objets utiliss.; in	A2.L	^liste;	D2.W	nb de fichiers trouvs (0..n); out	-; mod	D7.WDBDFOUSE:	PUSHM.L	D0..D3,D6,A2..A4	LOAD.L	A3,A2	TEST.W	D2	JUMP',EQ EXIT$LOOP$:	CLR.B	(A3)+19		; objet dconnectable	LOAD.W	D3,#TYPOBEDIT	CALL	OBJIFCON	; objet connect ?	JUMP',EQ CON$		; oui => CON$	CLR.B	(A3)+7		; objet libre	JUMP'	NEXT$CON$:	LOAD.L	A2,#(A6)+OOBACH	LOAD.W	D1,#MAXCALQUE-1CLOOP$:	LOAD.L	D6,(A2+)	; D6 <-- canal du calque	CALL	_LSTA_FIRST	; A4 <-- ^premier objet	JUMP',NE CNEXT$OLOOP$:	COMP.W	D0,(A4)+OobjIDENT	JUMP',EQ USE$	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ OLOOP$CNEXT$:	DECJ.W,NMO D1,CLOOP$	JUMP'	NEXT$USE$:	SET.B	(A3)+19		; objet impossible  dconnecterNEXT$:	LOAD.L	A3,#(A3)+20	DEC.W	D2	JUMP,NE LOOP$EXIT$:	POPM.L	D0..D3,D6,A2..A4	RET;----------\\; DBDFODRAW >;----------/; Dessine la scroll-liste.; in	A2.L	^liste;	D2.W	nb de fichiers trouvs (0..n); out	-; mod	D7.WDBDFODRAW:	PUSHM.L	D2..D4,A5	LOAD.L	A5,#(A6)+ODBSLV	; A5 <-- ^variables scroll-liste	LOAD.W	(A5)+OSLCYN,D2	CLR.W	(A5)+OSLCYS	LOAD.W	D2,#200!2^BDBGCLABEL	DBOX_	GETCO	SWAP.W	D3	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,(A0)+ODFC2Y	SWAP.W	D3	LOAD.L	(A5)+OSLPOS,D3	LOAD.W	D2,#201!2^BDBGCLABEL	DBOX_	GETCO	SUB.W	D3,(A5)+OSLPOS+2	SWAP.W	D3	ADD.W	D3,(A0)+ODFC2Y	SUB.W	D3,(A5)+OSLPOS+0	SWAP.W	D3	LOAD.L	(A5)+OSLDIM,D3	CLR.B	(A5)+OSLVID	CLR.B	(A5)+OSLHOR	SCROLL_	LDRAW		; dessine la scroll-liste	POPM.L	D2..D4,A5	RET;------------\\; DBDFOUPDATE >;------------/; Dessine la scroll-liste.; in	-; out	-; mod	D7.WDBDFOUPDATE:	PUSHM.L	A3,A5	LOAD.L	A5,#(A6)+ODBSLV	; A5 <-- ^variables scroll-liste	LOAD.L	A3,#R16"DBDFOGET	LOAD.L	(A5)+OSLADL,A3	SCROLL_	LUPDATE		; dessine le contenu	POPM.L	A3,A5	RET;---------\\; DBDFOGET >;---------/; Donne le texte  mettre dans la scroll-liste.; in	D3.W	rang de la case (0..n); out	A3.L	^contenu;	D3.W	ligne; mod	D3.L, D7.W, A3.LDBDFOGET:	LOAD.L	A3,#(A6)+OIOTM	MUL.WU	D3,#20	ADD.L	A3,D3	CLR.W	D3	CLR.W	D7		; retour EQ	RET;----------\\; DBDFOMOVE >;----------/; Dplace la scroll-liste.; in	D4.L	position de la souris (y;x);	D2.L	fanions; out	D2.L	fanions;	D7.W	erreur; mod	D2.L, D7.WDBDFOMOVE:	PUSH.L	A5	LOAD.L	A5,#(A6)+ODBSLV	; A5 <-- ^variables scroll-liste	SCROLL_	LMOVE		; dplace la scroll-liste	POP.L	A5	TEST.W	D7		; retour EQ/NE	RETTDBOX_DEFOBJ:	.W	10$-TDBOX_DEFOBJ	.W	20$-TDBOX_DEFOBJ	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Choix des objets  utiliser :"	.B	ODBCR,ODBCR	.B	ODBLABEL,200	.B	ODBTEXT,0	.B	ODBCR,ODBCR,ODBCR	.B	ODBTABX,19+3	.B	ODBLCIRCLE,1!2^7,KEYDBOX/H'100,1	.ASCIZ	" utilise"	.B	ODBCR	.B	ODBTABX,19+3	.B	ODBLABEL,100	.B	ODBLCIRCLE,0!2^7,KEYDBOX/H'100,0	.ASCIZ	" n'utilise pas"	.B	ODBCR,ODBCR,ODBCR	.B	ODBTABX,19	.B	ODBLABEL,201	.B	ODBTEXT,0	.B	ODBCR,ODBCR,ODBCR2	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" UTILISE "	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Utilise"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_DEFOBJ:	.W	F1,F2,F3,0		DOKF1-TKEY_DEFOBJ	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_DEFOBJ	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_DEFOBJ	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_DEFOBJ	.W	0;---------\\; DBOXGRID >;=========/; Demande le pas et la grille.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXGRID:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.L	A5,A6		; A5 <-- ^variables pour put/get	LOAD.L	A2,#R16"TDBOX$	CALL	DBOXMEMPT	LOAD.L	A2,#R16"TDBOX_GRID	LOAD.W	D2,#2^BDBSAV	LOAD.L	D4,(A6)+OGRID	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	PUSH.L	D4	LOAD.W	D2,#SETDOT	LOAD.W	D3,(A0)+ODFCX	MUL.WU	D3,#25+1-1	LOAD.W	D4,(A0)+ODFCY	MUL.WU	D4,#7	SUB.W	D4,#5	SWAP.W	D4	LIB	?DRSEG	LOAD.W	D3,(A0)+ODFCY	MUL.WU	D3,#7	SUB.W	D3,#5	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	LIB	?DRSEG	LOAD.W	D3,(A0)+ODFCY	MUL.WU	D3,#11	SUB.W	D3,#5	SWAP.W	D3	LIB	?DRSEG	POP.L	D4	CLR.W	D2REFAIT$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXAFF		; affiche le paramtreNLINE$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre;	CALL	DBOXMEDITSUBD$:	CALL	DBGRSUBD	; affieche la subdivisionLOOP$:	DBOX_	EDIT		; attend action ...	CALL	ZEROCR	LOAD.L	A1,#R16"TKEY_GRID	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ DAC$	COMP.W	D3,#F0	JUMP,EQ CANCEL$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEYDBOX$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	SUBD$KEYDBOX$:	CALL	DBOXPUT	JUMP,NE BIP$	COMP.W	D3,#KEYDBOX+100	JUMP,EQ SUBD$	LOAD.L	D1,#H'FFFFFF00	COMP.B	D3,#8	JUMP',LO KEYDBOX2$	LOAD.L	D1,#H'FFFF00FF	COMP.B	D3,#16	JUMP',LO KEYDBOX2$	LOAD.L	D1,#H'FF00FFFF;	COMP.B	D3,#24;	JUMP',LO KEYDBOX2$;	LOAD.L	D1,#H'00FFFFFFKEYDBOX2$:	AND.L	D4,D1		; D4 <-- teint toute la range	TSET.L	D4:D3		; D4 <-- allume juste le bon	JUMP	SUBD$CLIC$:	LOAD.W	D7,#DB_CLIC	PAGE_	DBOX	JUMP,NE BIP$	TSET.L	D4:#BGRIDPAN	TCLR.L	D4:#BGRIDPAX	TEST.W	(A6)+OPAS	JUMP,EQ NLINE$	TCLR.L	D4:#BGRIDPAN	TSET.L	D4:#BGRIDPAX	JUMP	NLINE$DAC$:				; D'ACCORD =>	CALL	DBOXPUT	JUMP,NE BIP$	LOAD.L	(A6)+OGRID,D4CANCEL$:			; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	OPAS,DBTYPU,0,1000*FACMMPT,10*FACMMPT,2^BDBGCLABEL!100,0,8+2	.W	-1;---------\\; DBGRSUBD >;---------/; Affiche la dimension d'une subdivision.; in	D5.L	canal dbox;	D4.L	fanions; out	-; mod	D7.WDBGRSUBD:	PUSHM.L	D1..D4,A3,A4	LOAD.L	D1,D4	LOAD.W	D2,#200!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A6)+OBUDIS	LOAD.L	A4,A3	LOAD.B	(A4+),#'(	LOAD.W	D4,#2	TEST.L	D1:#BGRIDMU2	JUMP',BS SUBDIV$	LOAD.W	D4,#3	TEST.L	D1:#BGRIDMU3	JUMP',BS SUBDIV$	LOAD.W	D4,#4	TEST.L	D1:#BGRIDMU4	JUMP',BS SUBDIV$	LOAD.W	D4,#5	TEST.L	D1:#BGRIDMU5	JUMP',BS SUBDIV$	LOAD.W	D4,#6	TEST.L	D1:#BGRIDMU6	JUMP',BS SUBDIV$	LOAD.W	D4,#8		; D1 <-- subdivisionSUBDIV$:	MUL.WU	D4,(A6)+OPAS	; D4 <-- pas*subdivision	CALL	PUTUNUM	LOAD.B	(A4+),#')	LOAD.B	(A4+),#EFLI	LOAD.L	D3,A4	SUB.L	D3,A3	LIB	?STRING	POPM.L	D1..D4,A3,A4	RETTDBOX_GRID:	.W	10$-TDBOX_GRID	.W	20$-TDBOX_GRID	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Magntisme :"	.B	ODBTABX,25	.B	ODBTEXT	.ASCIZ	"Grille :"	.B	ODBCR,ODBCR2	.B	ODBLCIRCLE,BGRIDPAN!2^7!2^6,KEYDBOX/H'100,BGRIDPAN	.ASCIZ	" aucun"	.B	ODBTABX,25	.B	ODBLCIRCLE,BGRIDGRN!2^7!2^6,KEYDBOX/H'100,BGRIDGRN	.ASCIZ	" invisible"	.B	ODBCR	.B	ODBTABX,25	.B	ODBLCIRCLE,BGRIDGRL!2^7!2^6,KEYDBOX/H'100,BGRIDGRL	.ASCIZ	" dessus"	.B	ODBCR	.B	ODBLCIRCLE,BGRIDPAX!2^7!2^6,KEYDBOX/H'100,BGRIDPAX	.ASCIZ	" pas "	.B	ODBLABEL,100	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTABX,25	.B	ODBLCIRCLE,BGRIDGRF!2^7!2^6,KEYDBOX/H'100,BGRIDGRF	.ASCIZ	" dessous"	.B	ODBCR,ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Subdivisions :"	.B	ODBTABX,28	.B	ODBLABEL,200	.B	ODBTEXT,0	.B	ODBCR,ODBCR2	.B	ODBLCIRCLE,BGRIDMU2!2^7!2^6,KEYDBOX/H'100,BGRIDMU2	.ASCIZ	" 2"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBLCIRCLE,BGRIDMU3!2^7!2^6,KEYDBOX/H'100,BGRIDMU3	.ASCIZ	" 3"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBLCIRCLE,BGRIDMU4!2^7!2^6,KEYDBOX/H'100,BGRIDMU4	.ASCIZ	" 4"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBLCIRCLE,BGRIDMU5!2^7!2^6,KEYDBOX/H'100,BGRIDMU5	.ASCIZ	" 5"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBLCIRCLE,BGRIDMU6!2^7!2^6,KEYDBOX/H'100,BGRIDMU6	.ASCIZ	" 6"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBLCIRCLE,BGRIDMU8!2^7!2^6,KEYDBOX/H'100,BGRIDMU8	.ASCIZ	" 8"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	"  ANNULE  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_GRID:	.W	F1,F2,F3,CR,0		DOKF1-TKEY_GRID	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_GRID	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_GRID	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_GRID	.W	0;--------\\; DBOXVUE >;========/; Choisi le mode pour la vue.; in	-; out	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXVUE:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_VUE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+OVUE	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP',NE EXIT$	PUSH.L	D4	LOAD.W	D3,(A0)+ODFCX	MUL.WU	D3,#24-1	LOAD.W	D4,(A0)+ODFCY	MUL.WU	D4,#6	ADD.W	D4,#4	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRSEG	CLR.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	LIB	?DRSEG	POP.L	D4LOOP$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_VUE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP',EQ USE$	COMP.W	D3,#F0	JUMP',EQ END$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$USE$:	LOAD.L	(A6)+OVUE,D4END$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_VUE:	.W	10$-TDBOX_VUE	.W	20$-TDBOX_VUE	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Calque actif :"	.B	ODBTABX,24	.B	ODBTEXT	.ASCIZ	"Autres calques :"	.B	ODBCR,ODBCR2	.B	ODBSQUARE,BVUEPEN	.ASCIZ	" traits rels"	.B	ODBTABX,24	.B	ODBSQUARE,BVUECPEN	.ASCIZ	" traits rels"	.B	ODBCR	.B	ODBSQUARE,BVUETRAME	.ASCIZ	" trames relles"	.B	ODBTABX,24	.B	ODBSQUARE,BVUECTRAME	.ASCIZ	" trames relles"	.B	ODBCR	.B	ODBSQUARE,BVUECHAR	.ASCIZ	" caractres rels"	.B	ODBTABX,24	.B	ODBSQUARE,BVUECCHAR	.ASCIZ	" caractres rels"	.B	ODBCR,ODBCR2	.B	ODBCR	.B	ODBSQUARE,BVUEREPMARG	.ASCIZ	" repres pour les marges"	.B	ODBCR	.B	ODBSQUARE,BVUEREPCOL	.ASCIZ	" repres pour les colonnes"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_VUE:	.W	F1,F2,F3,0		DOKF1-TKEY_VUE	.W	F0,F13,F14,F15,0	DOKF0-TKEY_VUE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_VUE	.W	0;-----------\\; DBOXCALQUE >;===========/; Choisi les calques visibles.; in	-; out	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXCALQUE:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_CALQUE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+OCALQUE	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$	LOAD.L	D0,D4	LOAD.W	D2,#100!2^BDBGCLABEL	DBOX_	GETCO	AND.L	D3,#H'FFFF	LOAD.W	D4,(A0)+ODFCY	MUL.WU	D4,#3+4+2+1	SWAP.W	D4	CLR.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRSEG	CLR.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	LIB	?DRSEG	JUMP	KEYDBOX$LOOP$:	LOAD.L	D4,D0	DBOX_	EDIT		; attend une action ...	LOAD.L	D0,D4	LOAD.L	A1,#R16"TKEY_CALQUE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP,EQ USE$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#F4	JUMP',EQ ALL$	COMP.W	D3,#F6	JUMP',EQ ACTIF$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP',EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$ALL$:	LOAD.W	D0,#-1	JUMP'	KEYDBOX$ACTIF$:	LOAD.L	D1,D0	SWAP.W	D1	LOAD.W	D0,D1;	JUMP	KEYDBOX$KEYDBOX$:	LOAD.W	D2,#BCALCA0!2^BDBGCLABEL!2^BDBGCFULL	TEST.L	D0:#BCALCV0	JUMP',BS V0$	LOAD.W	D2,#BCALCA0!2^BDBGCLABEL!2^BDBGCGREY	TCLR.L	D0:#BCALCA0V0$:	DBOX_	GETCO	LOAD.W	D2,#BCALCA1!2^BDBGCLABEL!2^BDBGCFULL	TEST.L	D0:#BCALCV1	JUMP',BS V1$	LOAD.W	D2,#BCALCA1!2^BDBGCLABEL!2^BDBGCGREY	TCLR.L	D0:#BCALCA1V1$:	DBOX_	GETCO	LOAD.W	D2,#BCALCA2!2^BDBGCLABEL!2^BDBGCFULL	TEST.L	D0:#BCALCV2	JUMP',BS V2$	LOAD.W	D2,#BCALCA2!2^BDBGCLABEL!2^BDBGCGREY	TCLR.L	D0:#BCALCA2V2$:	DBOX_	GETCO	LOAD.W	D2,#BCALCA3!2^BDBGCLABEL!2^BDBGCFULL	TEST.L	D0:#BCALCV3	JUMP',BS V3$	LOAD.W	D2,#BCALCA3!2^BDBGCLABEL!2^BDBGCGREY	TCLR.L	D0:#BCALCA3V3$:	DBOX_	GETCO	LOAD.W	D2,#BCALCA4!2^BDBGCLABEL!2^BDBGCFULL	TEST.L	D0:#BCALCV4	JUMP',BS V4$	LOAD.W	D2,#BCALCA4!2^BDBGCLABEL!2^BDBGCGREY	TCLR.L	D0:#BCALCA4V4$:	DBOX_	GETCO	LOAD.W	D2,#BCALCA5!2^BDBGCLABEL!2^BDBGCFULL	TEST.L	D0:#BCALCV5	JUMP',BS V5$	LOAD.W	D2,#BCALCA5!2^BDBGCLABEL!2^BDBGCGREY	TCLR.L	D0:#BCALCA5V5$:	DBOX_	GETCO	LOAD.W	D2,#BCALCA6!2^BDBGCLABEL!2^BDBGCFULL	TEST.L	D0:#BCALCV6	JUMP',BS V6$	LOAD.W	D2,#BCALCA6!2^BDBGCLABEL!2^BDBGCGREY	TCLR.L	D0:#BCALCA6V6$:	DBOX_	GETCO	LOAD.W	D2,#BCALCA7!2^BDBGCLABEL!2^BDBGCFULL	TEST.L	D0:#BCALCV7	JUMP',BS V7$	LOAD.W	D2,#BCALCA7!2^BDBGCLABEL!2^BDBGCGREY	TCLR.L	D0:#BCALCA7V7$:	DBOX_	GETCO	LOAD.W	D2,#200!2^BDBGCLABEL!2^BDBGCGREY	TEST.W	D0	JUMP',EQ VDAC$	LOAD.L	D1,D0	SWAP.W	D1	TEST.W	D1	JUMP',EQ VDAC$	LOAD.W	D2,#200!2^BDBGCLABEL!2^BDBGCFULLVDAC$:	DBOX_	GETCO	JUMP	LOOP$USE$:	TEST.W	D0	JUMP,EQ BIP$	LOAD.L	D1,D0	SWAP.W	D1	TEST.W	D1	JUMP,EQ BIP$	LOAD.L	(A6)+OCALQUE,D0	SWAP.W	D0	LOAD.W	D1,#-1ACT$:	INC.W	D1	RR.W	D0,#1	JUMP,CC ACT$	LOAD.W	(A6)+OCALACT,D1END$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_CALQUE:	.W	10$-TDBOX_CALQUE	.W	20$-TDBOX_CALQUE	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Calques visibles :"	.B	ODBTABX,20	.B	ODBLABEL,100	.B	ODBTEXT,0	.B	ODBTABX,22	.B	ODBTEXT	.ASCIZ	"Calque actif :"	.B	ODBTABX,22+20	.B	ODBCR,ODBCR	.B	ODBSQUARE,BCALCV7!2^7,KEYDBOX/H'100,BCALCV7	.ASCIZ	" A"	.B	ODBTABX,8	.B	ODBSQUARE,BCALCV3!2^7,KEYDBOX/H'100,BCALCV3	.ASCIZ	" E"	.B	ODBTABX,22	.B	ODBLABEL,BCALCA7	.B	ODBLCIRCLE,BCALCA7!2^7,KEYDBOX/H'100,BCALCA7	.ASCIZ	" A"	.B	ODBTABX,22+8	.B	ODBLABEL,BCALCA3	.B	ODBLCIRCLE,BCALCA3!2^7,KEYDBOX/H'100,BCALCA3	.ASCIZ	" E"	.B	ODBCR	.B	ODBSQUARE,BCALCV6!2^7,KEYDBOX/H'100,BCALCV6	.ASCIZ	" B"	.B	ODBTABX,8	.B	ODBSQUARE,BCALCV2!2^7,KEYDBOX/H'100,BCALCV2	.ASCIZ	" F"	.B	ODBTABX,22	.B	ODBLABEL,BCALCA6	.B	ODBLCIRCLE,BCALCA6!2^7,KEYDBOX/H'100,BCALCA6	.ASCIZ	" B"	.B	ODBTABX,22+8	.B	ODBLABEL,BCALCA2	.B	ODBLCIRCLE,BCALCA2!2^7,KEYDBOX/H'100,BCALCA2	.ASCIZ	" F"	.B	ODBCR	.B	ODBSQUARE,BCALCV5!2^7,KEYDBOX/H'100,BCALCV5	.ASCIZ	" C"	.B	ODBTABX,8	.B	ODBSQUARE,BCALCV1!2^7,KEYDBOX/H'100,BCALCV1	.ASCIZ	" G"	.B	ODBTABX,22	.B	ODBLABEL,BCALCA5	.B	ODBLCIRCLE,BCALCA5!2^7,KEYDBOX/H'100,BCALCA5	.ASCIZ	" C"	.B	ODBTABX,22+8	.B	ODBLABEL,BCALCA1	.B	ODBLCIRCLE,BCALCA1!2^7,KEYDBOX/H'100,BCALCA1	.ASCIZ	" G"	.B	ODBCR	.B	ODBSQUARE,BCALCV4!2^7,KEYDBOX/H'100,BCALCV4	.ASCIZ	" D"	.B	ODBTABX,8	.B	ODBSQUARE,BCALCV0!2^7,KEYDBOX/H'100,BCALCV0	.ASCIZ	" H"	.B	ODBTABX,22	.B	ODBLABEL,BCALCA4	.B	ODBLCIRCLE,BCALCA4!2^7,KEYDBOX/H'100,BCALCA4	.ASCIZ	" D"	.B	ODBTABX,22+8	.B	ODBLABEL,BCALCA0	.B	ODBLCIRCLE,BCALCA0!2^7,KEYDBOX/H'100,BCALCA0	.ASCIZ	" H"	.B	ODBCR,ODBCR	.B	ODBBOX,0,F4,TDBOMBRE	.ASCIZ	" TOUS "	.B	ODBBOX,0,F6,TDBOMBRE	.ASCIZ	" UN "	.B	ODBCR,ODBCR,ODBCR	.B	ODBLABEL,200	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	" Tous        Un  "		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_CALQUE:	.W	F1,F2,F3,0		DOKF1-TKEY_CALQUE	.W	F0,F13,F14,F15,0	DOKF0-TKEY_CALQUE	.W	F4,0			DOKF4-TKEY_CALQUE	.W	F6,0			DOKF6-TKEY_CALQUE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_CALQUE	.W	0;-------------\\; DBOXCOLONNES >;=============/; Demande le nombre de colonnes.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXCOLONNES:	PUSHM.L	D0..D2,D4,D5,A1..A5	LOAD.L	A5,A6		; A5 <-- ^variables pour put/get	LOAD.L	A2,#R16"TDBOX$	CALL	DBOXMEMPT	LOAD.L	A2,#R16"TDBOX_COLONNES	LOAD.W	D2,#2^BDBSAV	LOAD.L	D4,(A6)+OCOLFA	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	LOAD.W	D2,#2^BDBGCLABEL!200	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	LOAD.W	D2,#2^BDBGCLABEL!201	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	LOAD.W	D2,#2^BDBGCLABEL!202	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	CLR.W	D2REFAIT$:	PUSH.W	D2	CLR.W	D2AFF$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXAFF		; affiche le paramtre	INC.W	D2	COMP.W	D2,#2	JUMP,LO AFF$	POP.W	D2NLINE$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXMEDITLOOP$:	DBOX_	EDIT		; attend action ...	CALL	ZEROCR	LOAD.L	A1,#R16"TKEY_COLONNES	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ DAC$	COMP.W	D3,#F0	JUMP,EQ CANCEL$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#CLEAR	JUMP',EQ UNDO$	COMP.W	D3,#CR	JUMP',EQ RETURN$	COMP.W	D3,#ENTER	JUMP',EQ RETURN$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP',EQ KEYDBOX$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	CALL	DBOXPUT	JUMP,NE BIP$	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,#2	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$KEYDBOX$:			; KEYDBOX =>	CALL	DBOXPUT	JUMP,NE BIP$	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$CLIC$:	LOAD.W	D7,#DB_CLIC	PAGE_	DBOX	JUMP,NE BIP$	JUMP	NLINE$DAC$:				; D'ACCORD =>	CALL	DBOXPUT	JUMP,NE BIP$	LOAD.L	(A6)+OCOLFA,D4	CALL	DBCOPX		; OCOLPX <-- position X des colonnes	TEST.L	D4:#BCOLMAGN	JUMP',BC CANCEL$	TSET.B	(A6)+OVUE+0:#BVUEREPCOL-24CANCEL$:			; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A1..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	OCOLNB,DBTYPN,1,10,1,2^BDBGCLABEL!100,0,3+2	.W	OCOLES,DBTYPU,0,1000*FACMMPT,10*FACMMPT,2^BDBGCLABEL!101,1,8+2	.W	-1;-------\\; DBCOPX >;-------/; Calcule les positions en X des diffrentes colonnes.; in	-; out	-; mod	D7.WDBCOPX:	PUSHM.L	D2..D4,A4	LOAD.L	A4,#(A6)+OCOLPX	CLR.L	D2	LOAD.W	D2,(A6)+ODESXD	SUB.W	D2,(A6)+ODESMG	SUB.W	D2,(A6)+ODESMD	; D2 <-- largeur pour toutes les colonnes	LOAD.W	D3,(A6)+OCOLES	LOAD.W	D4,(A6)+OCOLNB	DEC.W	D4	JUMP',LE ONE$	MUL.WU	D3,D4		; D3 <-- largeur de toutes les gouttires	SUB.W	D2,D3		; D2 <-- largeur sans les gouttires	JUMP',LE ONE$	DIV.WU	D2,(A6)+OCOLNB	; D2 <-- largeur d'une colonne	LOAD.W	D3,(A6)+ODESMG	; D3 <-- origine en X	LOAD.W	D4,(A6)+OCOLNB	; D4 <-- nb de colonnesLOOP$:	LOAD.W	(A4+),D3	; OCOLPX <-- dbut colonne	ADD.W	D3,D2	LOAD.W	(A4+),D3	; OCOLPX <-- fin colonne	ADD.W	D3,(A6)+OCOLES	; D3 <-- origine suivante en X	DEC.W	D4	JUMP,NE LOOP$	JUMP'	END$ONE$:	LOAD.W	(A4+),(A6)+ODESMG	LOAD.W	D3,(A6)+ODESXD	SUB.W	D3,(A6)+ODESMD	LOAD.W	(A4+),D3END$:	LOAD.W	(A4),#-1	; OCOLPX <-- terminateur	POPM.L	D2..D4,A4	RETTDBOX_COLONNES:	.W	10$-TDBOX_COLONNES	.W	20$-TDBOX_COLONNES	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Repres pour les colonnes :"	.B	ODBCR	.B	ODBLABEL,200	.B	ODBTEXT,0	.B	ODBCR,ODBCR2	.B	ODBTEXT	.ASCIZ	"Nombre de colonnes "	.B	ODBLABEL,100	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Gouttires         "	.B	ODBLABEL,101	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,101,TDBNORM	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCR	.B	ODBLABEL,201	.B	ODBTEXT,0	.B	ODBCR	.B	ODBSQUARE,BCOLMAGN	.ASCIZ	" repres magntiques"	.B	ODBCR	.B	ODBLABEL,202	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	"  ANNULE  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_COLONNES:	.W	F1,F2,F3,0		DOKF1-TKEY_COLONNES	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_COLONNES	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_COLONNES	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_COLONNES	.W	0;------------\\; DBOXHORVERT >;============/; Demande les contraintes horizontal/vertical.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXHORVERT:	PUSHM.L	D0..D2,D4,D5,A1..A5	LOAD.L	A5,A6		; A5 <-- ^variables pour put/get	LOAD.L	A2,#R16"TDBOX$	CALL	DBOXMEMPT	LOAD.L	A2,#R16"TDBOX_HORVERT	LOAD.W	D2,#2^BDBSAV	LOAD.L	D4,(A6)+OHVFAN	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	LOAD.W	D2,#2^BDBGCLABEL!200	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	LOAD.W	D2,#2^BDBGCLABEL!201	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	CLR.W	D2REFAIT$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXAFF		; affiche le paramtreNLINE$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre;	CALL	DBOXMEDITLOOP$:	DBOX_	EDIT		; attend action ...	CALL	ZEROCR	LOAD.L	A1,#R16"TKEY_HORVERT	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ DAC$	COMP.W	D3,#F0	JUMP,EQ CANCEL$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#CLEAR	JUMP',EQ UNDO$	COMP.W	D3,#CR	JUMP',EQ RETURN$	COMP.W	D3,#ENTER	JUMP',EQ RETURN$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP',EQ KEYDBOX$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	JUMP	NLINE$KEYDBOX$:			; KEYDBOX =>	CALL	DBOXPUT	JUMP,NE BIP$	COMP.W	D3,#KEYDBOX+100	JUMP',EQ CLIC2$	LOAD.L	D1,#H'FFFFFF00	COMP.B	D3,#8	JUMP',LO KEYDBOX2$	LOAD.L	D1,#H'FFFF00FF;	COMP.B	D3,#16;	JUMP',LO KEYDBOX2$;	LOAD.L	D1,#H'FF00FFFF;	COMP.B	D3,#24;	JUMP',LO KEYDBOX2$;	LOAD.L	D1,#H'00FFFFFFKEYDBOX2$:	AND.L	D4,D1		; D4 <-- teint toute la range	TSET.L	D4:D3		; D4 <-- allume juste le bon	JUMP	NLINE$CLIC$:	LOAD.W	D7,#DB_CLIC	PAGE_	DBOX	JUMP,NE BIP$CLIC2$:	TCLR.L	D4:#BHV090	TSET.L	D4:#BHVAUTRE	JUMP	NLINE$DAC$:				; D'ACCORD =>	CALL	DBOXPUT	JUMP,NE BIP$	LOAD.L	(A6)+OHVFAN,D4CANCEL$:			; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A1..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	OHVVAL,DBTYPN,10,90,5,2^BDBGCLABEL!100,0,3+2	.W	-1TDBOX_HORVERT:	.W	10$-TDBOX_HORVERT	.W	20$-TDBOX_HORVERT	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Contraintes sur le dplacement de la souris : "	.B	ODBCR,ODBCR	.B	ODBLCIRCLE,BHV090!2^7!2^6,KEYDBOX/H'100,BHV090	.ASCIZ	" horizontal/vertical"	.B	ODBCR	.B	ODBLCIRCLE,BHVAUTRE!2^7!2^6,KEYDBOX/H'100,BHVAUTRE	.ASCIZ	" autre  ...........  "	.B	ODBLABEL,100	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTEXT	.ASCIZ	"  degrs"	.B	ODBCR,ODBCR2	.B	ODBLABEL,200	.B	ODBTEXT,0	.B	ODBCR	.B	ODBLCIRCLE,BHVNON!2^7!2^6,KEYDBOX/H'100,BHVNON	.ASCIZ	" pas de contrainte"	.B	ODBCR	.B	ODBLCIRCLE,BHVCURSOR!2^7!2^6,KEYDBOX/H'100,BHVCURSOR	.ASCIZ	" contrainte si touche (CURSOR) enfonce"	.B	ODBCR	.B	ODBLCIRCLE,BHVOUI!2^7!2^6,KEYDBOX/H'100,BHVOUI	.ASCIZ	" contrainte permanente"	.B	ODBCR,ODBCR2	.B	ODBSQUARE,BHVSHOW	.ASCIZ	" montre les contraintes"	.B	ODBCR	.B	ODBLABEL,201	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	"  ANNULE  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_HORVERT:	.W	F1,F2,F3,0		DOKF1-TKEY_HORVERT	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_HORVERT	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_HORVERT	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_HORVERT	.W	0;-------------\\; DBOXDIMIMAGE >;=============/; Demande les dimensions pour une image.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WDBOXDIMIMAGE:	PUSHM.L	D0..D2,D4,D5,A1..A5	LOAD.L	A5,A6		; A5 <-- ^variables pour put/get	LOAD.L	A2,#R16"TDBOX$	CALL	DBOXMEMPT	LOAD.L	A2,#R16"TDBOX_DIMIMAGE	LOAD.W	D2,#2^BDBSAV	LOAD.L	D4,(A6)+OFADIM	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE	EXIT$	PUSH.L	D4	LOAD.W	D3,(A0)+ODFCX	MUL.WU	D3,#30	LOAD.W	D4,(A0)+ODFCY	MUL.WU	D4,#9	SWAP.W	D4	CLR.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRSEG	CLR.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	LIB	?DRSEG	POP.L	D4	CLR.W	D2REFAIT$:	PUSH.W	D2	CLR.W	D2AFF$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXAFF		; affiche le paramtre	INC.W	D2	COMP.W	D2,#1	JUMP,LO AFF$	POP.W	D2NLINE$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXMEDITLOOP$:	DBOX_	EDIT		; attend action ...	CALL	ZEROCR	LOAD.L	A1,#R16"TKEY_DIMIMAGE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ DAC$	COMP.W	D3,#F0	JUMP,EQ CANCEL$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#CLEAR	JUMP',EQ UNDO$	COMP.W	D3,#CR	JUMP',EQ RETURN$	COMP.W	D3,#ENTER	JUMP',EQ RETURN$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP',EQ KEYDBOX$BIP$:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	CALL	DBOXPUT	JUMP,NE BIP$	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,#1	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$KEYDBOX$:			; KEYDBOX =>	CALL	DBOXPUT	JUMP,NE BIP$	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$CLIC$:	LOAD.W	D7,#DB_CLIC	PAGE_	DBOX	JUMP,NE BIP$	JUMP	NLINE$DAC$:				; D'ACCORD =>	CALL	DBOXPUT	JUMP,NE BIP$	LOAD.L	(A6)+OFADIM,D4CANCEL$:			; ANNULE =>	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A1..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	ODBIMX,DBTYPN,16,5000,10,2^BDBGCLABEL!100,0,4+2	.W	-1TDBOX_DIMIMAGE:	.W	10$-TDBOX_DIMIMAGE	.W	20$-TDBOX_DIMIMAGE	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Dimensions de l'image :"	.B	ODBTABX,30	.B	ODBTEXT	.ASCIZ	"Trames grises : "	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Largeur "	.B	ODBLABEL,100	.B	ODBCLINE,(4+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTEXT	.ASCIZ	"   [point]"	.B	ODBTABX,30	.B	ODBLCIRCLE,BPRIGX1	.ASCIZ	" x 1"	.B	ODBCR	.B	ODBTABX,30	.B	ODBLCIRCLE,BPRIGX2	.ASCIZ	" x 2"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"(La hauteur est calcule"	.B	ODBTABX,30	.B	ODBLCIRCLE,BPRIGX3	.ASCIZ	" x 3"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"pour que l'image conserve"	.B	ODBTABX,30	.B	ODBLCIRCLE,BPRIGX4	.ASCIZ	" x 4"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"ses proportions)"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	"  SAUVE  "	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	"  ANNULE  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Sauve"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_DIMIMAGE:	.W	F1,F2,F3,0		DOKF1-TKEY_DIMIMAGE	.W	F0,F13,F14,F15,END,0	DOKF0-TKEY_DIMIMAGE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_DIMIMAGE	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_DIMIMAGE	.W	0;----------\\; DBOXPRINT >;==========/; Choisi le mode pour l'impression.; in	-; out	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXPRINT:	PUSHM.L	D1,D2,D4,D5,A1..A5	LOAD.L	A5,A6		; A5 <-- ^variables pour put/get	LOAD.L	A2,#R16"TDBOX$	CALL	DBOXMEMPT	LOAD.L	A2,#R16"TDBOX_PRINT	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.L	D4,(A6)+OPRINT	; D4 <-- fanions	CALL	DBOXOPEN	; ouvre la DBOX	JUMP,NE EXIT$	PUSH.L	D4	LOAD.W	D2,#200!2^BDBGCLABEL	DBOX_	GETCO	AND.L	D3,#H'FFFF	LOAD.W	D4,(A0)+ODFCY	MUL.WU	D4,#3+4+1	SUB.W	D4,#8	SWAP.W	D4	CLR.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRSEG	CLR.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	LIB	?DRSEG	LOAD.W	D2,#201!2^BDBGCLABEL	DBOX_	GETCO	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	CLR.W	D3	LOAD.W	D2,#SETDOT	LIB	?DRSEG	POP.L	D4	CLR.W	D2REFAIT$:	PUSH.W	D2	CLR.W	D2AFF$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXAFF		; affiche le paramtre	INC.W	D2	COMP.W	D2,#2	JUMP,LO AFF$	POP.W	D2NLINE$:	CALL	DBOXGET		; A3/A4 <-- ^dbut/fin paramtre	CALL	DBOXMEDITLOOP$:	DBOX_	EDIT		; attend action ...	CALL	ZEROCR	LOAD.L	A1,#R16"TKEY_PRINT	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP,EQ USE$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#CLEAR	JUMP',EQ UNDO$	COMP.W	D3,#CR	JUMP',EQ RETURN$	COMP.W	D3,#ENTER	JUMP',EQ RETURN$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP',EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	CALL	DBOXPUT	JUMP,NE BIP$	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,#2	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$KEYDBOX$:			; KEYDBOX =>	CALL	DBOXPUT	JUMP,NE BIP$	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$USE$:	CALL	DBOXPUT	JUMP,NE BIP$	TEST.W	(A6)+OPRSC1	JUMP,EQ BIP$	JUMP',LE OK$	TEST.W	(A6)+OPRSC2	JUMP,EQ BIP$	JUMP',LE OK$	LOAD.W	D7,#ERPPSCA	; D7 <-- trop grand	LOAD.W	D2,(A6)+ODESXD	MUL.WU	D2,(A6)+OPRSC2	DIV.WU	D2,(A6)+OPRSC1	JUMP',NS END$	JUMP',VS END$	LOAD.W	D2,(A6)+ODESYD	MUL.WU	D2,(A6)+OPRSC2	DIV.WU	D2,(A6)+OPRSC1	JUMP',NS END$	JUMP',VS END$OK$:	CLR.W	D7	LOAD.L	(A6)+OPRINT,D4END$:	PUSH.W	D7	CALL	DBOXCLOSE	; ferme la DBOX	POP.W	D7EXIT$:	POPM.L	D1,D2,D4,D5,A1..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	OPRSC1,DBTYPUF,0,1000*FACMMPT,0,2^BDBGCLABEL!100,0,8+2	.W	OPRSC2,DBTYPUF,0,1000*FACMMPT,0,2^BDBGCLABEL!101,1,8+2	.W	-1TDBOX_PRINT:	.W	10$-TDBOX_PRINT	.W	20$-TDBOX_PRINT	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Calques  imprimer :"	.B	ODBTABX,24	.B	ODBLABEL,200	.B	ODBTEXT,0	.B	ODBTABX,26	.B	ODBTEXT	.ASCIZ	"Trames grises : "	.B	ODBCR,ODBCR2	.B	ODBSQUARE,BPRIC7	.ASCIZ	" A"	.B	ODBTABX,8	.B	ODBSQUARE,BPRIC3	.ASCIZ	" E"	.B	ODBTABX,26	.B	ODBLCIRCLE,BPRIGX1	.ASCIZ	" x 1"	.B	ODBCR	.B	ODBSQUARE,BPRIC6	.ASCIZ	" B"	.B	ODBTABX,8	.B	ODBSQUARE,BPRIC2	.ASCIZ	" F"	.B	ODBTABX,26	.B	ODBLCIRCLE,BPRIGX2	.ASCIZ	" x 2"	.B	ODBCR	.B	ODBSQUARE,BPRIC5	.ASCIZ	" C"	.B	ODBTABX,8	.B	ODBSQUARE,BPRIC1	.ASCIZ	" G"	.B	ODBTABX,26	.B	ODBLCIRCLE,BPRIGX3	.ASCIZ	" x 3"	.B	ODBCR	.B	ODBSQUARE,BPRIC4	.ASCIZ	" D"	.B	ODBTABX,8	.B	ODBSQUARE,BPRIC0	.ASCIZ	" H"	.B	ODBTABX,26	.B	ODBLCIRCLE,BPRIGX4	.ASCIZ	" x 4"	.B	ODBCR,ODBCR	.B	ODBTABX,14	.B	ODBTEXT	.ASCIZ	"cran"	.B	ODBTABX,14+12+5	.B	ODBTEXT	.ASCIZ	"papier"	.B	ODBCR2	.B	ODBTEXT	.ASCIZ	"Changement"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"d'chelle :  "	.B	ODBLABEL,100	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTEXT	.ASCIZ	" --<'>> "	.B	ODBLABEL,101	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,101,TDBNORM	.B	ODBCR	.B	ODBLABEL,201	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" IMPRIME "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBSQUARE,BPRIPS	.ASCIZ	" PostScript"	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Imprime"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_PRINT:	.W	F1,F2,F3,0		DOKF1-TKEY_PRINT	.W	F0,F13,F14,F15,0	DOKF0-TKEY_PRINT	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_PRINT	.W	0;-------------\\; DBOXFRAGMENT >;=============/; Faut-il fragmenter ?; in	D4.L	fanions; out	D3.L	dernire touche (F1/F4);	D4.L	fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXFRAGMENT:	PUSHM.L	D1,D2,D5,A1..A4	LIB	?BUZZ	LOAD.L	A2,#R16"TDBOX_FRAGMENT	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBOXOPEN	; ouvre la DBOX	JUMP',NE EXIT$LOOP$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_FRAGMENT	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP',EQ QUIT$	COMP.W	D3,#F13	JUMP',EQ QUIT$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$QUIT$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_FRAGMENT:	.W	10$-TDBOX_FRAGMENT	.W	20$-TDBOX_FRAGMENT	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Fragmente les objets slectionns."	.B	ODBCR,ODBCR2	.B	ODBTEXT	.ASCIZ	"ATTENTION:  Cette opration est"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"            irrversible !"	.B	ODBCR,ODBCR	.B	ODBLCIRCLE,0	.ASCIZ	" droites et courbes de Bzier"	.B	ODBCR	.B	ODBLCIRCLE,1	.ASCIZ	" uniquement des courbes"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBNORM	.ASCIZ	" FRAGMENTE "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F13,TDBMEV	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Fragmente"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_FRAGMENT:	.W	F1,F2,F3,0		DOKF1-TKEY_FRAGMENT	.W	F13,F14,F15,0		DOKF13-TKEY_FRAGMENT	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_FRAGMENT	.W	0;----------\\; DBOXIOREV >;==========/; Avertissement ...; in	-; out	D3.L	dernire touche (F1/F4);	D7.W	erreur; mod	D3.L, D7.WDBOXIOREV:	PUSHM.L	D1,D2,D4,D5,A1..A4	LIB	?BUZZ	LOAD.L	A2,#R16"TDBOX_IOREV	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4	CALL	DBOXOPEN	; ouvre la DBOX	JUMP',NE EXIT$LOOP$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_IOREV	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP',EQ QUIT$	COMP.W	D3,#F4	JUMP',EQ QUIT$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$QUIT$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_IOREV:	.W	10$-TDBOX_IOREV	.W	20$-TDBOX_IOREV	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"<AFINV> ATTENTION : <AFDIR>"	.B	ODBCR,ODBCR2	.B	ODBTEXT	.ASCIZ	"De nombreuses incompatibilits empchent"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"de reprendre un ancien document .PAGE !"	.B	ODBCR,ODBCR2	.B	ODBTEXT	.ASCIZ	"Voulez-vous quand mme essayer ?"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBNORM	.ASCIZ	"  OUI  "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F4,TDBMEV	.ASCIZ	"  NON  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Oui"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Non"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVENTKEY_IOREV:	.W	F1,F2,F3,0		DOKF1-TKEY_IOREV	.W	F4,F5,F6,CR,0		DOKF4-TKEY_IOREV	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_IOREV	.W	0;-----------\\; DBOXZPRINT >;===========/; Avertissement ...; in	-; out	D3.L	dernire touche (F1/F4);	D7.W	erreur; mod	D3.L, D7.WDBOXZPRINT:	PUSHM.L	D1,D2,D4,D5,A1..A4	LIB	?BUZZ	LOAD.L	A2,#R16"TDBOX_ZPRINT	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4	CALL	DBOXOPEN	; ouvre la DBOX	JUMP',NE EXIT$LOOP$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_ZPRINT	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP',EQ QUIT$	COMP.W	D3,#F4	JUMP',EQ QUIT$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$QUIT$:	CALL	DBOXCLOSE	; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_ZPRINT:	.W	10$-TDBOX_ZPRINT	.W	20$-TDBOX_ZPRINT	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"<AFINV> ATTENTION : <AFDIR>"	.B	ODBCR,ODBCR2	.B	ODBTEXT	.ASCIZ	"Le zoom graphique de la prsentation"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"d'impression n'est pas rgl sur un !"	.B	ODBCR,ODBCR2	.B	ODBTEXT	.ASCIZ	"Voulez-vous quand mme imprimer ?"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBNORM	.ASCIZ	"  OUI  "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F4,TDBMEV	.ASCIZ	"  NON  "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Oui"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Non"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""	.EVENTKEY_ZPRINT:	.W	F1,F2,F3,0		DOKF1-TKEY_ZPRINT	.W	F4,F5,F6,CR,0		DOKF4-TKEY_ZPRINT	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_ZPRINT	.W	0;----------\\; DBOXERROR >;==========/; Affiche une erreur.; in	D7.W	erreur; out	D7.W	erreur; mod	D7.WDBOXERROR:	PUSHM.L	D2..D4,A3	LOAD.W	D4,D7	JUMP',EQ 20$	COMP.W	D7,#ERKNO	JUMP',EQ 20$	COMP.W	D7,#ERKSTO	JUMP',NE 30$20$:	CLR.W	D7		; D7 <-- ok	JUMP'	90$30$:	CALL	DBOXOPEN1	; remet la flche	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	CALL	DBERTEXT	; A3 <-- ^message interne  PAGE	JUMP',EQ 50$	LOAD.W	D7,D4		; D7 <-- code de l'erreur	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur "externe" ...	JUMP'	80$50$:	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	TERROR		; affiche l'erreur "interne" ...80$:	CALL	DBOXCLOSE1	; remet les soft-keys90$:	POPM.L	D2..D4,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBERTEXT >;---------/; Donne le texte d'une erreur interne  PAGE.; in	D4.W	erreur; out	A3.L	^message d'erreur;	D7.W	erreur; mod	D7.W, A3.LDBERTEXT:	PUSH.L	D3	LOAD.W	D7,#ERPBIP	; D7 <-- pas trouv	LOAD.W	D3,D4	SR.W	D3,#8	COMP.B	D3,#ERPAGE/H'100 ; erreur interne  PAGE ?	JUMP',NE 90$		; non => 90$				; oui =>	LOAD.L	A3,#R16"TABLE$20$:	TEST.W	(A3+)		; fin de la table ?	JUMP',EQ 80$		; oui => 80$	COMP.W	D4,(A3)-2	; erreur trouve ?	JUMP',EQ 80$		; oui => 80$30$:	TEST.B	(A3+)		; A3 <-- saute un .ASCIZ	JUMP,NE	30$	LOAD.L	D3,A3	INC.L	D3	TCLR.L	D3:#0		; A3 <-- saute comme .EVEN	LOAD.L	A3,D3	JUMP	20$80$:	CLR.W	D7		; D7 <-- trouv90$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RETTABLE$:	.W	ERPAILOP	.ASCIZ	"Opration impossible !"	.EVEN	.W	ERPAHANDDNE	.ASCIZ	"Poigne n'existe pas !"	.EVEN	.W	ERPAHANDEND	.ASCIZ	"Dernire poigne !"	.EVEN	.W	ERPOVER	.ASCIZ	"Dpassement de capacit !"	.EVEN	.W	ERPMDNE	.ASCIZ	"Mthode n'existe pas !"	.EVEN	.W	ERPOBPC	.ASCII	"Il existe un ou plusieurs objets<CR>"	.ASCIZ	"qui ne sont pas chargs !"	.EVEN	.W	ERPIOFORM	.ASCIZ	"Fichier .PAGE incompatible !"	.EVEN	.W	ERPNOTF	.ASCII	"Pas trouv dans la<CR>"	.ASCIZ	"direction choisie !"	.EVEN	.W	ERPPSCA	.ASCII	"Le changement d'chelle produit<CR>"	.ASCIZ	"un document trop grand !"	.EVEN	.W	0	.ASCIZ	"Erreur avec le logiciel PAGE !"	.EVEN	.END