	.SBTTL	PAGECLIC.ASI;************;;    CLIC    ;;************;CLIC:	COMP.W	D3,#KEYMMP	JUMP,EQ CLICM	LOAD.W	D1,D3		; D1 <-- bouton press	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP; Traite le cas o la souris est dans un ascenseur.	LOAD.L	A1,#0	CALL	_DOMASCENSEUR	; agit dans ascenseurs selon souris	JUMP,EQ LOOP; Traite le cas o la souris est dans une icne.	CALL	_MOVICONE	; souris dans une icne ?	JUMP,EQ CLICICONE	; oui => CLICICONE				; non =>	CALL	_DPLICONE	; dplace toutes les icnes ?	JUMP,EQ LOOP		; oui => LOOP; Traite le cas o la souris est dans les informations.	CALL	_ICAMOVE	; souris dans le cadre ?	JUMP,EQ CLICCADRE	; oui => CLICCADRE	LOAD.W	D3,D1		; D3 <-- bouton press	COMP.W	D3,#KEYMGP	JUMP,EQ CLICG	COMP.W	D3,#KEYMDP	JUMP,EQ CLICD	JUMP	BIP;*****************;;    CLICICONE    ;;*****************;CLICICONE:	COMP.W	D3,#ICOOCRAYON	JUMP,EQ OUTIL$	COMP.W	D3,#ICOOZONE	JUMP,EQ OUTIL$	COMP.W	D3,#ICOOPOIGNEE	JUMP,EQ OUTIL$	COMP.W	D3,#ICOOEDIT	JUMP,EQ OUTIL$	COMP.W	D3,#ICOOLOUPE	JUMP,EQ OUTIL$	COMP.W	D3,#ICOOMAIN	JUMP,EQ OUTIL$	COMP.W	D3,#ICOOBJET	JUMP',LO 20$	COMP.W	D3,#ICOOBJET+NBIOBJET	JUMP,LO OBJET$20$:	COMP.W	D3,#ICOSTATE	JUMP',LO 30$	COMP.W	D3,#ICOSTATE+NBISTATE	JUMP,LO STATE$30$:	COMP.W	D3,#ICOCALQUE	JUMP,EQ CALQUE$	COMP.W	D3,#ICOGRID	JUMP,EQ GRID$	COMP.W	D3,#ICOHORVERT	JUMP,EQ HORVERT$	COMP.W	D3,#ICOMVUE	JUMP,EQ VUE$	COMP.W	D3,#ICOCOLONNES	JUMP,EQ COLONNES$	JUMP	BIPOUTIL$:	TEST.B	(A6)+ODEF+1:#BDEFOGD-0	JUMP',BC OUTIL1$;;?	COMP.W	D1,#KEYMDP;;?	JUMP',EQ OUTILR$	COMP.W	D3,#ICOOZONE	JUMP',EQ OUTILR$	COMP.W	D3,#ICOOPOIGNEE	JUMP',EQ OUTILR$OUTILL$:	COMP.W	D3,(A6)+OOUTILL	JUMP,EQ BIP	LOAD.W	(A6)+OOUTILL,D3	CALL	_UPDICONE	; met  jour les icnes	JUMP	LOOPOUTILR$:	COMP.W	D3,(A6)+OOUTILR	JUMP,EQ BIP	LOAD.W	(A6)+OOUTILR,D3	CALL	_UPDICONE	; met  jour les icnes	JUMP	LOOPOUTIL1$:	COMP.W	D3,(A6)+OOUTILL	JUMP',NE OUTIL11$	COMP.W	D3,(A6)+OOUTILR	JUMP,EQ BIPOUTIL11$:	LOAD.W	(A6)+OOUTILL,D3	LOAD.W	(A6)+OOUTILR,D3	CALL	_UPDICONE	; met  jour les icnes	JUMP	LOOPOBJET$:	COMP.W	D3,(A6)+OOBJET	JUMP',EQ OBJCR$	LOAD.W	(A6)+OOBJET,D3	LOAD.W	D3,#ICOSTATE	LOAD.W	D4,#NBISTATE-1OBJST$:	CALL	_KSTICONE	; supprime l'tat de l'icne	INC.W	D3	DECJ.W,NMO D4,OBJST$	CALL	_UPDICONE	; met  jour les icnesOBJCR$:	LOAD.W	D3,#ICOOCRAYON	COMP.W	D3,(A6)+OOUTILL	; outil = crayon ?	JUMP,EQ LOOP		; oui => LOOP	COMP.W	D3,(A6)+OOUTILR	; outil = crayon ?	JUMP,EQ LOOP		; oui => LOOP	JUMP	OUTIL$STATE$:	LOAD.W	D2,D3	SUB.W	D3,#ICOSTATE	; D3 <-- 0..n	LOAD.W	D0,(A6)+OOBJET	SUB.W	D0,#ICOOBJET	CALL	_OBJGETID	; D0 <-- identificateur de l'objet	JUMP,NE BIP	LOAD.W	D1,#opIDENTSTATE ; D1 <-- mthode	CALL	_OBJCALL	; A4 <-- ^identificateurs des tats	JUMP,NE BIPSTATE2$:	DEC.W	D3	JUMP',NS STATE3$	COMP.W	(A4+),#-1	JUMP,NE STATE2$	JUMP	BIPSTATE3$:	LOAD.W	D3,(A4)		; D3 <-- identificateur	COMP.W	D3,#ICOVIDE	JUMP,EQ BIP	LOAD.W	D1,#opMODSTATE	CALL	_OBJCALL	; modifie l'tat ...	JUMP,NE ERROR	LOAD.W	D3,D2		; D3 <-- icne	CALL	_DESICONEONE	; redessine une icne	TEST.W	D4	JUMP,NE DOREFAITBBOX	JUMP	LOOPCALQUE$:	CALL	_DBOXCALQUE	; choix des calques ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	CALL	_DESINFCALQUE	; affiche le calque actif	CALL	_DESINFNBOBJ	; affiche le nombre d'objets	JUMP	DOREFAITGRID$:	CALL	_DBOXGRID	; choix de la grille ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	CALL	_DESINFPAS	; affiche le pas	JUMP	DOREFAITHORVERT$:	CALL	_DBOXHORVERT	; choix contrainte ...	JUMP,NE ERROR	JUMP	LOOPVUE$:	CALL	_DBOXVUE	; choix de la vue ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	JUMP	DOREFAITCOLONNES$:	CALL	_DBOXCOLONNES	; nombre de colonnes ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	SET.B	(A6)+OMAJ	; mise  jour sur disque ncessaire	JUMP	DOREFAIT;*****************;;    CLICCADRE    ;;*****************;CLICCADRE:	TEST.W	D2	JUMP',EQ SCALE$	COMP.W	D2,#1	JUMP',EQ CALQUE$	JUMP	BIPSCALE$:	CALL	_GETMMENUSCALE	; A3/D3 <-- ^mmenu chelle/case grise	LOAD.L	A4,#(A6)+OMPASC	; A4 <-- ^paramtres	CLR.L	D4	TSET.L	D4:D3	LOAD.L	(A4)+(LMM*0)+OMMINA,D4	CALL	_MMENUS		; choix selon mmenus ...	LOAD.W	D4,(A4)+(LMM*0)+OMMSEL	JUMP,EQ LOOP	SL.W	D4,#1	LOAD.L	A4,#R16"TASCALE	LOAD.W	D4,(A4)+(D4.W)-2 ; D4 <-- nouvelle chelle	LOAD.W	D5,(A6)+ODESY2	SUB.W	D5,(A6)+ODESY1	SR.W	D5,#1	ADD.W	D5,(A6)+ODESY1	SWAP.W	D5	LOAD.W	D5,(A6)+ODESX2	SUB.W	D5,(A6)+ODESX1	SR.W	D5,#1	ADD.W	D5,(A6)+ODESX1		; D5 <-- au milieu de l'cran	JUMP	LOUPEQCALQUE$:	LOAD.L	A3,#R16"TMENUCALQUE	LOAD.L	A4,#(A6)+OMPACA	; A4 <-- ^paramtres	CLR.L	D4	LOAD.W	D4,(A6)+OCALQUE+2	NOT.W	D4		; D4 <-- grise les calques invisibles	OR.W	D4,(A6)+OCALQUE+0 ; D4 <-- grise le calque actif	CLR.L	D3	LOAD.W	D2,#8-1CALQ2$:	RRX.B	D4,#1	RLX.B	D3,#1		; D3 <-- D4 avec les bits inverss !	DECJ.W,NMO D2,CALQ2$	SL.L	D3,#1		; D3 <-- place pour case blanche	LOAD.L	(A4)+(LMM*0)+OMMINA,D3	CALL	_MMENUS		; choix selon mmenus ...	LOAD.W	D4,(A4)+(LMM*0)+OMMSEL	JUMP,EQ LOOP	SUB.W	D4,#MAXCALQUE	NEG.W	D4		; D4 <-- 0..7	LOAD.W	(A6)+OCALACT,D4	CLR.W	D3	TSET.L	D3:D4	LOAD.W	(A6)+OCALQUE+0,D3	CALL	_DESINFCALQUE	; affiche le calque actif	CALL	_DESINFNBOBJ	; affiche le nombre d'objets	JUMP	DOREFAITTMENUCALQUE:	.ASCIZ	" "	.B	-1	.ASCIZ	"  A  "	.ASCIZ	"  B"	.ASCIZ	"  C"	.ASCIZ	"  D"	.ASCIZ	"  E"	.ASCIZ	"  F"	.ASCIZ	"  G"	.ASCIZ	"  H"	.B	0;*************;;    CLICM    ;;*************;CLICM:	LOAD.L	A3,#R16"MMENU$	; A3 <-- ^mmenu	LOAD.L	A4,#(A6)+OMPAMI	; A4 <-- ^paramtres	CLR.L	(A4)+(LMM*0)+OMMINA	CLR.L	(A4)+(LMM*1)+OMMINA	CLR.L	(A4)+(LMM*2)+OMMINA	CLR.L	(A4)+(LMM*3)+OMMINA	CLR.L	(A4)+(LMM*4)+OMMINA	TSET.B	(A4)+(LMM*0)+OMMINA+3:#3 ; grise la case "vue"	TSET.B	(A4)+(LMM*2)+OMMINA+3:#0 ; grise la case "annule"	TSET.B	(A4)+(LMM*2)+OMMINA+3:#2 ; grise la case "aide"	CALL	_MMENUS		; choix selon mmenus ...	LOAD.W	D4,(A4)+(LMM*0)+OMMSEL	JUMP,EQ LOOP	COMP.W	D4,#1	JUMP,EQ FILE$	COMP.W	D4,#2	JUMP,EQ EDIT$;	COMP.W	D4,#3;	JUMP,EQ SHOW$	COMP.W	D4,#4	JUMP,EQ DEF$	JUMP	BIPFILE$:	LOAD.W	D4,(A4)+(LMM*1)+OMMSEL	JUMP,EQ _DOPREND	COMP.W	D4,#1	JUMP,EQ _DOAJOUTE	COMP.W	D4,#2	JUMP,EQ _DOSAUVE	COMP.W	D4,#3	JUMP,EQ _DOIMPRIME	COMP.W	D4,#4	JUMP,EQ DOFINI	JUMP	BIPEDIT$:	LOAD.W	D4,(A4)+(LMM*2)+OMMSEL;	JUMP,EQ DOANNULE	COMP.W	D4,#1	JUMP,EQ _DOEFFACE;	COMP.W	D4,#2;	JUMP,EQ DOAIDE	JUMP	BIPDEF$:	LOAD.W	D4,(A4)+(LMM*3)+OMMSEL	JUMP,EQ DODEFPAGE	COMP.W	D4,#1	JUMP,EQ DODEFUNIT	COMP.W	D4,#2	JUMP,EQ DODEFMOUS	COMP.W	D4,#3	JUMP,EQ DODEFOBJ	JUMP	BIPMMENU$:	.ASCIZ	" "	.B	-1	.BW	-2,MFILE$-MMENU$	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOFILE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  fichier"	.BW	-2,MEDIT$-MMENU$	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOEDIT	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  dition";	.BW	-2,MSHOW$-MMENU$	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSHOW	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  vue"	.B	-1	.BW	-2,MDEF$-MMENU$	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODEF	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  dfinitions"	.B	0MFILE$:	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOPREND	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  prend.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOAJOUTE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  ajoute.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSAUVE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  sauve.."	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOPRINT	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  imprime.."	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOQUITTE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  quitte.."	.B	0MEDIT$:	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUNDO	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  annule"	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOEFFACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  efface.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOHELP	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  aide.."	.B	0MDEF$:	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODEFPAGE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  page.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODEFUNIT	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  unit.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODEFMOUS	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  souris.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODEFOBJ	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  objets.."	.B	0	.EVEN;*************;;    CLICG    ;;*************;;*************;;    CLICD    ;;*************;CLICG:	LOAD.W	D3,(A6)+OOUTILL	JUMP'	CLICXCLICD:	LOAD.W	D3,(A6)+OOUTILR;	JUMP'	CLICXCLICX:	COMP.W	D3,#ICOOCRAYON	JUMP,EQ CRAYON	COMP.W	D3,#ICOOZONE	JUMP,EQ ZONE	COMP.W	D3,#ICOOPOIGNEE	JUMP,EQ POIGNEE	COMP.W	D3,#ICOOEDIT	JUMP,EQ EDIT	COMP.W	D3,#ICOOLOUPE	JUMP,EQ LOUPE	COMP.W	D3,#ICOOMAIN	JUMP,EQ MAIN	JUMP	BIP;**************;;    CRAYON    ;;**************;CRAYON:	CLR.L	(A6)+OAPOS	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP	CALL	_CONVSCROBP	; D4 <-- position [obj]	JUMP,NE BIP	LOAD.L	D3,D4	LOAD.W	D0,(A6)+OOBJET	SUB.W	D0,#ICOOBJET	CALL	_OBJGETID	; D0 <-- identificateur de l'objet	JUMP,NE BIP	LOAD.W	D1,#opCRGETLG	CALL	_OBJCALL	; D4 <-- longueur ncessaire	JUMP,NE BIP	LOAD.L	A3,#0	LOAD.L	A4,#0	CALL	GETACH		; D6 <-- canal de l'arbre des objets	CALL	_LSTA_INSERT	; A4 <-- ^objet  la tte	JUMP,NE ERROR	LOAD.W	(A4)+OobjIDENT,D0	SET.B	(A6)+OMAJ	; mise  jour sur disque ncessaire	LOAD.W	D1,#opCRINIT	CALL	_OBJCALLD	; initialise l'objet	JUMP,NE DEL$	PUSH.L	D3	CALL	WDOOPEN		; dessine dans la swdo	LOAD.W	D3,#CRMOVEOPEN	; D3 <-- dbut	LOAD.W	D1,#opCRMOVE	CALL	_OBJCALLD	; indique le dbut de la cration	CALL	WDOCLOSE	; fin du dessin dans la swdo	POP.L	D3	LOAD.W	D1,#opCRICOLIST	CALL	_OBJCALLD	; A3 <-- ^liste des icnes, A2 <-- ^table des softkeys	JUMP',NE BEGIN$	LOAD.L	(A6)+OICOPH,A3	; OICOPH <-- ^liste des icnes	LOAD.L	(A6)+OICOPS,A2	; OICOPS <-- ^table des soft-keys	LOAD.W	(A6)+OICONIV,#NICOCREATE ; dbut de l'opration	LOAD.W	(A6)+OICOID,D0	; OICOID <-- identificateur	CALL	_DESICONE	; dessine les icnes de gauche	CALL	_MAJICONE	; mj. les icnes variables	CALL	_AFMENU		; refait les soft-keysBEGIN$:	LOAD.L	D4,D3		; D4 <-- position de la souris	LOAD.W	D3,#ICOOCRAYON	CALL	_SELMO		; utilise le bon lutin	CALL	HVOPEN		; contrainte: fixe le point initial	JUMP	CREATE0$LOOP$:	CALL	_UPDICONE	; met  jour l'tat des icnes	CALL	_SCMO		; remet la sourisLOOP2$:	LOAD.W	D1,#opCRICOOUTIL	CALL	_OBJCALLD	; D3 <-- icne pour la souris	JUMP',EQ LOOP3$	LOAD.W	D3,#ICOOCRAYONLOOP3$:	CALL	_SELMO		; utilise le bon lutin	CALL	_DESINFXY	; affiche X= et Y= dans les informations	CALL	_WAITMOVE	; attend dplacement souris ...	COMP.W	D3,#KEYMPO	JUMP,EQ LOOP2$	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMMP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMDP	JUMP',EQ CLIC$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#CR	JUMP,EQ END$	COMP.W	D3,#UNDO	JUMP,EQ CANCEL$	COMP.W	D3,#DEL	JUMP,EQ CANCEL$	COMP.W	D3,#BS	JUMP,EQ CANCEL$	COMP.W	D3,#DELETE	JUMP,EQ CANCEL$	COMP.W	D3,#DEFINE	JUMP,EQ HAND$	TEST.L	D3:#BKRELEAS	JUMP',BS BIP$	TEST.L	D3:#BKPSEUDO	; changement de touches super-shift ?	JUMP',BS SHIFT$		; oui => SHIFT$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOP$SHIFT$:	LOAD.L	D4,(A6)+OHVFIX	CALL	HVCONV		; met/enlve les repres	JUMP	LOOP$CLIC$:	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP$	LOAD.L	A1,#R16"ASCINV$	CALL	_DOMASCENSEUR	; agit dans ascenseurs selon souris	JUMP,EQ LOOP$	LOAD.W	D1,#opBUTTON	CALL	_OBJCALLD	; indique le bouton utilis	CALL	_MOVICONE	; souris dans une icne ?	JUMP',EQ ICONE$		; oui => ICONE$	JUMP	CREATE$ICONE$:	COMP.W	D3,#ICODACCORD	JUMP,EQ END$	COMP.W	D3,#ICOANNULE	JUMP,EQ CANCEL$	COMP.W	D3,#ICOOPOIGNEE	JUMP,EQ HAND$	CLR.L	D4	LOAD.W	D1,#opCRICOGET	CALL	_OBJCALLD	; D4 <-- tat	TEST.L	D4:#BSTICOCHGDRAW ; faut-il changer le dessin ?	JUMP',BC ICONE23$	; non => ICONE23$	LOAD.L	D2,#2^BVUECLR!2^BVUEPROV!2^BVUEPROVE	CALL	DESOBJET	; efface l'objetICONE23$:	LOAD.W	D1,#opCRICOMOD	CALL	_OBJCALLD	; agit dans l'objet selon l'ine clique ...	PUSH.W	D7	TEST.L	D4:#BSTICOCHGDRAW ; faut-il changer le dessin ?	JUMP',BC ICONE43$	; non => ICONE43$	LOAD.L	D2,#2^BVUESET!2^BVUEPROV!2^BVUEPROVE	CALL	DESOBJET	; redessine l'objetICONE43$:	POP.W	D7	JUMP,NE BIP$	JUMP	LOOP$CREATE$:	CALL	_CONVSCROBP	; D4 <-- point o est la souris	JUMP,NE BIP$CREATE0$:	CALL	HVCONV		; D4 <-- point selon contrainte	CALL	WDOOPEN		; dessine dans la swdo	LOAD.W	D3,#CRMOVEBEGIN	; D3 <-- dbut	LOAD.W	D1,#opCRMOVE	CALL	_OBJCALLD	; indique le dbut du dplacement	PUSH.W	D7	CALL	WDOCLOSE	; fin du dessin dans la swdo	POP.W	D7	JUMP,NE END$CREATE2$:	CALL	_SCMO		; remet la souris	CALL	_WAITMOVE	; attend dplacement souris ...	JUMP',NE CREATE8$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE CREATE2$	CALL	_CONVSCROBP	; D4 <-- point o est la souris	JUMP,NE CREATE2$	CALL	HVCONV		; D4 <-- point selon contrainte	CALL	WDOOPEN		; dessine dans la swdo	LOAD.W	D3,#CRMOVEDRAG	; D3 <-- dplacement	LOAD.W	D1,#opCRMOVE	CALL	_OBJCALLD	; dplace la poigne	CALL	WDOCLOSE	; fin du dessin dans la swdo	LOAD.W	D1,#opCRINFO	CALL	_DESINFOBJ	; affiche les informations	JUMP	CREATE2$CREATE8$:	CALL	HVCLOSE		; contrainte: termine	CALL	WDOOPEN		; dessine dans la swdo	LOAD.W	D3,#CRMOVEEND	; D3 <-- fin	LOAD.W	D1,#opCRMOVE	CALL	_OBJCALLD	; indique la fin du dplacement	PUSH.W	D7	CALL	WDOCLOSE	; fin du dessin dans la swdo	POP.W	D7	JUMP',NE CANCEL1$	CALL	_DESINFALL	; remet les informations normales	TEST.W	(A6)+OICONIV	; icnes de gauche changes ?	JUMP',EQ END2$		; non => END2$	CALL	HVOPEN		; contrainte: fixe le point initial	JUMP	LOOP$HAND$:	CALL	HVCLOSE		; contrainte: termine	CALL	WDOOPEN		; dessine dans la swdo	LOAD.W	D3,#CRMOVECLOSE	; D3 <-- fin	LOAD.W	D1,#opCRMOVE	CALL	_OBJCALLD	; indique la fin de la cration	PUSH.W	D7	CALL	WDOCLOSE	; fin du dessin dans la swdo	POP.W	D7	JUMP',NE CANCEL2$	CALL	_LSTO_CCOMPACT	; A4 <-- ^objet compact;;?	CALL	_GROUPSRCP	; A3 <-- ^pre possible;;?	JUMP,NE POIGNEE3;;?	CALL	_GROUPADOPT	; le pre adopte le fils	JUMP	POIGNEE3CANCEL$:	CALL	HVCLOSE		; contrainte: termineCANCEL1$:	CALL	WDOOPEN		; dessine dans la swdo	LOAD.W	D3,#CRMOVECLOSE	; D3 <-- fin	LOAD.W	D1,#opCRMOVE	CALL	_OBJCALLD	; indique la fin de la cration	CALL	WDOCLOSE	; fin du dessin dans la swdoCANCEL2$:	CALL	_LSTA_REMOVE	; enlve l'objet	JUMP'	MENU$END$:	CALL	HVCLOSE		; contrainte: termineEND2$:	CALL	WDOOPEN		; dessine dans la swdo	LOAD.W	D3,#CRMOVECLOSE	; D3 <-- fin	LOAD.W	D1,#opCRMOVE	CALL	_OBJCALLD	; indique la fin de la cration	PUSH.W	D7	CALL	WDOCLOSE	; fin du dessin dans la swdo	POP.W	D7	JUMP,NE CANCEL2$	CALL	_LSTO_CCOMPACT	; A4 <-- ^objet compact;;?	CALL	_GROUPSRCP	; A3 <-- ^pre possible;;?	JUMP',NE END5$;;?	CALL	_GROUPADOPT	; le pre adopte le fils;;?END5$:	LOAD.W	D1,#opHANDIFCR	CALL	_OBJCALLD	; D7 <-- slectionne tout de suite	JUMP',EQ SELECT$	CALL	DESSET		; dessine l'objet dfinitif	LOAD.W	D1,#opEDITICOLIST	CALL	_OBJCALLD	; A3 <-- ^liste des icnes, A2 <-- ^table des softkeys	JUMP',EQ EDIT$		; si elle existe => EDIT$ (dite l'objet cr)MENU$:	CALL	_DESINFNBOBJ	; affiche le nombre d'objets	TEST.W	(A6)+OICONIV	; icnes de gauche changes ?	JUMP,EQ LOOP		; non => LOOP	CLR.W	(A6)+OICONIV	; fin de la cration	CALL	_REMICONE	; remet les icnes  gauche	CALL	_AFMENU		; refait les soft-keys	JUMP	LOOPEDIT$:	CALL	_DESINFNBOBJ	; affiche le nombre d'objets	JUMP	EDIT2SELECT$:	CALL	_DESINFNBOBJ	; affiche le nombre d'objets	JUMP	POIGNEE3DEL$:	PUSH.W	D7	CALL	_LSTA_REMOVE	; enlve l'objet	CALL	_DESINFNBOBJ	; affiche le nombre d'objets	POP.W	D7	JUMP	ERRORASCINV$:	PUSH.L	D2	INC.W	(A6)+OASNBI	TEST.B	(A6)+OASNBI+1:#0	JUMP',BC ASCSET$ASCCLR$:	CALL	HVCLR		; efface les repres	LOAD.L	D2,#2^BVUECLR!2^BVUEPROV!2^BVUEPROVE	CALL	DESOBJET	; efface l'objet	JUMP'	ASCEND$ASCSET$:	LOAD.L	D2,#2^BVUESET!2^BVUEPROV!2^BVUEPROVE	CALL	DESOBJET	; allume l'objet	CALL	HVSET		; allume les repres;	JUMP'	ASCEND$ASCEND$:	POP.L	D2	RET;************;;    ZONE    ;;************;ZONE:	LOAD.W	D4,#ICOOZONE	LIB	?GETSHIFT	; D3 <-- touches super-shift	TEST.L	D3:#BCOPY	JUMP,BS MULTI	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP	CALL	_CONVSCROBJ	; D4 <-- position [obj]	JUMP,NE BIP	LOAD.L	(A6)+OZONY1,D4	LOAD.L	(A6)+OZONY2,D4	SET.B	(A6)+OCCMO	; n'enlve pas le rticule !	LOAD.W	D2,#1		; D2 <-- open	CALL	DESISHIFTZ	; dessine le premier rectangleRECT$:	LOAD.W	D3,#ICOOZONE	CALL	_SELMO		; utilise le bon lutin	CALL	_DESINFXY	; affiche X= et Y= dans les informations	LOAD.W	D2,#2		; D2 <-- shift	CALL	DESISHIFTZ	; fait tourner le traitill	CALL	_WAITMOVES	; attend dplacement ...	JUMP',NE MENU$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE RECT$	CALL	_CONVSCROBJ	; D4 <-- point o est la souris	JUMP,NE RECT$	COMP.L	D4,(A6)+OZONY2	; position change ?	JUMP,EQ RECT$		; non => RECT$				; oui =>	LOAD.W	D2,#3		; D2 <-- close	CALL	DESISHIFTZ	; efface l'ancien rectangle	LOAD.L	(A6)+OZONY2,D4	LOAD.W	D2,#1		; D2 <-- open	CALL	DESISHIFTZ	; dessine le nouveau rectangle	JUMP	RECT$MENU$:	LOAD.W	D2,#3		; D2 <-- close	CALL	DESISHIFTZ	; efface le dernier rectangle	CLR.B	(A6)+OCCMO	; enlve le rticule !	LOAD.L	A4,#0		; A4 <-- encore aucun objet slectionn	CALL	ZONESELECT	; slectionne tous les objets inclus	JUMP,NE ERROR	LOAD.W	D4,(A6)+OZONNS	; D4 <-- nb d'objets slectionns	JUMP,EQ BIP	CALL	_DESINFOBJS	; affiche le nb d'objets slectionns	CALL	ZONEPSET	; allume tous les objetsZONE2:	LOAD.L	(A6)+OSELPS,A4	; OSELPS <-- ^premier objet slectionn	CALL	HANDLIMIT	; OLIMP1/P2 <-- P1/P2 limites	LOAD.W	D2,#1		; D2 <-- open	CALL	DESISHIFTZ	; dessine le nouveau rectangle	LOAD.L	D4,#2000	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire pour construire mmenu	JUMP,NE ERROR$	LOAD.L	D5,A4	LOAD.L	A3,D5		; A3 <-- ^buffer pour construire m-menu	LOAD.L	A2,D5	LOAD.L	A4,#R16"TMENUZONE	CALL	MENUBUF		; buffer <-- menu principal	CALL	MENUAJUST	; buffer <-- tous les sous-(sous-)menus	LOAD.L	A3,D5		; A3 <-- ^buffer avec m-menu	LOAD.L	A4,#(A5)+OMPAZO	; A4 <-- ^paramtres	CLR.L	(A4)+(LMM*0)+OMMINA	CLR.L	(A4)+(LMM*1)+OMMINA	CLR.L	(A4)+(LMM*2)+OMMINA	CLR.L	(A4)+(LMM*3)+OMMINA	LOAD.W	D3,(A6)+OCALACT	SUB.W	D3,#MAXCALQUE-1	NEG.W	D3	TSET.B	(A4)+(LMM*3)+OMMINA+3:D3 ; grise le calque actuel	CALL	_MMENUS		; choix selon mmenus ...	PUSHM.L	D7,A4	LOAD.L	A4,D5	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre mmoire pour construire mmenu	POPM.L	D7,A4	TEST.W	D7	JUMP,NE BIP$	LOAD.W	D4,(A4)+(LMM*0)+OMMSEL	DEC.W	D4	JUMP,EQ DETRUIT$	DEC.W	D4	JUMP,EQ DEPLACE$	DEC.W	D4	JUMP,EQ DUPLIQUE$	DEC.W	D4	JUMP,EQ OPER$	DEC.W	D4	JUMP,EQ MODIF$	DEC.W	D4	JUMP,EQ GROUPE$	DEC.W	D4	JUMP,EQ CALQUE$	DEC.W	D4	JUMP,EQ FRAGMENT$	DEC.W	D4	JUMP,EQ SAUVE$	JUMP	END$DETRUIT$:	CALL	ZONEDETRUIT	; dtruit toute la zone	CALL	_DESINFNBOBJ	; affiche le nombre d'objets	LOAD.W	D2,#3		; D2 <-- close	CALL	DESISHIFTZ	; efface le dernier rectangle	JUMP	LOOPDEPLACE$:	LOAD.B	D3,#AFCCMO	LIB	?AFCAR		; enlve la souris	CALL	ZONEDEPLACE	; dplace la zone ...	JUMP	END$DUPLIQUE$:	LOAD.B	D3,#AFCCMO	LIB	?AFCAR		; enlve la souris	CALL	ZONEDUPLIQUE	; duplique tous les objets	CALL	ZONEDEPLACE	; dplace la zone ...	CALL	_DESINFNBOBJ	; affiche le nombre d'objets	JUMP	END$MODIF$:	LOAD.W	D4,(A4)+(LMM*1)+OMMSEL	SL.W	D4,#1	LOAD.L	A4,#(A6)+OMBUMO	LOAD.W	D0,(A4)+(D4.W)	; D0 <-- identificateur  modifier	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D1,#opDGET	CALL	_OBJCALL	; D3 <-- tat slectionn	JUMP,NE ERROR$	LOAD.W	D2,D3	LOAD.W	D1,#opDSELECT	CALL	_OBJCALL	; choix d'un tat ...	JUMP',NE MEND$	COMP.W	D3,#F1	JUMP',NE MEND$	LOAD.W	D3,D0	CALL	ZONEMODIF	; modifie toute la zone	CLR.W	D7MEND$:	PUSH.W	D7	LOAD.W	D3,D2	LOAD.W	D1,#opDPUT	CALL	_OBJCALL	; slectionne l'tat initial	POP.W	D7	JUMP	REFAIT$OPER$:	JUMP	ZONEOPERFRAGMENT$:	LOAD.L	D4,(A6)+OFRAFA	CALL	_DBOXFRAGMENT	; fragmente ...	JUMP,NE	ERROR$	COMP.W	D3,#F1	JUMP,NE END$	LOAD.L	(A6)+OFRAFA,D4	CALL	FRAGSELECT	; fragmente tous les objets slectionns	JUMP',EQ FRAG8$	CALL	_DBOXERROR	; affiche l'erreur ...FRAG8$:	CALL	_DESINFNBOBJ	; affiche le nombre d'objets	JUMP	DOREFAITGROUPE$:	LOAD.W	D2,#3		; D2 <-- close	CALL	DESISHIFTZ	; efface le dernier rectangle	LOAD.W	D4,(A4)+(LMM*2)+OMMSEL	DEC.W	D4	JUMP',EQ GRKILL$	DEC.W	D4	JUMP',EQ GRCHG$GRMAKE$:	CALL	ZONEGRMAKE	; assemble un groupe	JUMP,NE ERROR	JUMP	LOOPGRKILL$:	CALL	ZONEGRKILL	; spare un groupe	JUMP,NE ERROR	JUMP	LOOPGRCHG$:	CALL	ZONEGRCHG	; change de groupe	JUMP,NE BIP	JUMP	LOOPCALQUE$:	LOAD.W	D2,#3		; D2 <-- close	CALL	DESISHIFTZ	; efface le dernier rectangle	LOAD.W	D4,(A4)+(LMM*3)+OMMSEL	SUB.W	D4,#MAXCALQUE-1	NEG.W	D4		; D4 <-- numro du calque destination	CALL	ZONECALQUE	; change les objets de calque	CALL	_DESINFNBOBJ	; affiche le nombre d'objets	JUMP	DOREFAITSAUVE$:	CALL	_SAUVESELECT	; sauve les objets slectionns ...	JUMP',NE ERROR$;	JUMP'	END$END$:	CLR.W	D7		; D7 <-- ok	JUMP'	ERROR$BIP$:	LOAD.W	D7,#ERPBIP	; D7 <-- bip;	JUMP'	ERROR$ERROR$:	CLR.W	D4		; D4 <-- rien  refaireREFAIT$:	PUSH.W	D7	LOAD.W	D2,#3		; D2 <-- close	CALL	DESISHIFTZ	; efface le dernier rectangle	CALL	ZONEDESELECT	; dslectionne tous les objets inclus	POP.W	D7	JUMP,NE ERROR	TEST.W	D4	JUMP,NE DOREFAITBBOX	JUMP	LOOPZONEOPER:	LOAD.W	D2,#3		; D2 <-- close	CALL	DESISHIFTZ	; efface le dernier rectangle	CALL	ZONESELFILS	; slectionne aussi tous les fils	JUMP,NE ERROR	CALL	ZONEABS		; rend tous les objets absolus !	CLR.B	(A6)+OZONDE	LOAD.W	D4,#ZONEMOVEDEFORME	CALL	ZONEMOVEH	; D4 <-- zro si dformation possible	TEST.W	D4	JUMP',EQ IFDBZ$	SET.B	(A6)+OZONDE	COMP.W	(A6)+OZONIV,#NICODEFORME	JUMP',NE IFDBZ$	LOAD.W	(A6)+OZONIV,#NICOZOOMIFDBZ$:	CLR.B	(A6)+OZONDB	LOAD.W	D4,#ZONEMOVEDEFBEZ	CALL	ZONEMOVEH	; D4 <-- zro si dformation possible	TEST.W	D4	JUMP',EQ CHANGE$	SET.B	(A6)+OZONDB	COMP.W	(A6)+OZONIV,#NICODEFBEZ	JUMP',NE CHANGE$	LOAD.W	(A6)+OZONIV,#NICOZOOMCHANGE$:	LOAD.W	(A6)+OICONIV,(A6)+OZONIV	CALL	_DESICONE	; dessine les icnes de gauche	CALL	_MAJICONE	; mj. les icnes variables	CALL	_AFMENU		; refait les soft-keys	CALL	ZONEQREDUCE	; calcule une zone la plus petite possible	CALL	ZONEQHOPEN	; ouverture du dplacement	CALL	ZONEQINV	; allume la zone quelconque	CALL	ZONEQHSET	; allume les poignesLOOP$:	CALL	_UPDICONE	; met  jour l'tat des icnes	CALL	_SCMO		; remet la sourisLOOP2$:	CALL	_DESINFXY	; affiche X= et Y= dans les informations	CALL	_WAITMOVE	; attend dplacement souris ...	COMP.W	D3,#KEYMPO	JUMP,EQ LOOP2$	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMMP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMDP	JUMP',EQ CLIC$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#CR	JUMP,EQ END$	TEST.L	D3:#BKRELEAS	JUMP',BS BIP$	TEST.L	D3:#BKPSEUDO	; changement de touches super-shift ?	JUMP,BS LOOP2$		; oui => LOOP2$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOP$CLIC$:	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP$	LOAD.L	A1,#R16"ASCINV$	CALL	_DOMASCENSEUR	; agit dans ascenseurs selon souris	JUMP,EQ LOOP$	LOAD.W	D1,#opBUTTON	CALL	_OBJCALLD	; indique le bouton utilis	CALL	_MOVICONE	; souris dans une icne ?	JUMP',EQ ICONE$		; oui => ICONE$	JUMP	HAND$ICONE$:	TEST.W	D3		; clic dans une icne grise ?	JUMP,EQ BIP$		; oui => BIP$	COMP.W	D3,#ICOMVUE	JUMP,EQ VUE$	COMP.W	D3,#ICOGRID	JUMP,EQ GRID$	COMP.W	D3,#ICOHORVERT	JUMP,EQ HORVERT$	COMP.W	D3,#ICOZZOOM	JUMP,EQ	OPER$	COMP.W	D3,#ICOZTOURNE	JUMP,EQ	OPER$	COMP.W	D3,#ICOZMIROIR	JUMP,EQ	OPER$	COMP.W	D3,#ICOZDEFORME	JUMP,EQ	OPER$	COMP.W	D3,#ICOZDEFBEZ	JUMP,EQ	OPER$	COMP.W	D3,#ICOZHOMOT	JUMP,EQ ZHOMOT$	COMP.W	D3,#ICODQQ	JUMP,EQ	DEFORME$	COMP.W	D3,#ICODTRAH	JUMP,EQ	DEFORME$	COMP.W	D3,#ICODTRAV	JUMP,EQ	DEFORME$	COMP.W	D3,#ICODPARH	JUMP,EQ	DEFORME$	COMP.W	D3,#ICODPARV	JUMP,EQ	DEFORME$	COMP.W	D3,#ICOBQQ	JUMP,EQ	DEFBEZ$	COMP.W	D3,#ICOBHORIZ	JUMP,EQ	DEFBEZ$	COMP.W	D3,#ICOBVERTI	JUMP,EQ	DEFBEZ$	COMP.W	D3,#ICODACCORD	JUMP,EQ END$	CALL	ZONEQOPER	; opration selon icne	JUMP	LOOP$ZHOMOT$:	TEST.B	(A6)+OZONHB	; homothtie bloque ?	JUMP,NE BIP$		; oui => BIP$	NOT.B	(A6)+OZONHO	JUMP	LOOP$VUE$:	CALL	_DBOXVUE	; choix de la vue ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	JUMP	REFAIT$GRID$:	CALL	_DBOXGRID	; choix de la grille ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	JUMP	REFAIT$HORVERT$:	CALL	_DBOXHORVERT	; choix contrainte ...	JUMP,NE BIP$	JUMP	LOOP$OPER$:	LOAD.W	D4,#NICOZOOM	COMP.W	D3,#ICOZZOOM	JUMP',EQ OPER2$	LOAD.W	D4,#NICOTOURNE	COMP.W	D3,#ICOZTOURNE	JUMP',EQ OPER2$	LOAD.W	D4,#NICOMIROIR	COMP.W	D3,#ICOZMIROIR	JUMP',EQ OPER2$	LOAD.W	D4,#NICODEFORME	COMP.W	D3,#ICOZDEFORME	JUMP',EQ OPER2$	LOAD.W	D4,#NICODEFBEZOPER2$:	COMP.W	D4,(A6)+OZONIV	JUMP,EQ	BIP$	CALL	ZONEQHCLR	; teint les poignes	CALL	ZONEQHCLOSE	; fermeture du dplacement	CALL	ZONEQINV	; teint la zone	LOAD.W	(A6)+OZONIV,D4	JUMP	CHANGE$DEFORME$:	COMP.W	D3,(A6)+OZONDF	JUMP,EQ	BIP$	LOAD.W	(A6)+OZONDF,D3	JUMP	LOOP$DEFBEZ$:	COMP.W	D3,(A6)+OZONDFB	JUMP,EQ	BIP$	CALL	WDOOPEN		; dessine dans la swdo	CALL	ZONEQHCLR	; teint les poignes	CALL	ZONEQINV	; teint la zone	LOAD.W	(A6)+OZONDFB,D3	COMP.W	(A6)+OZONDFB,#ICOBVERTI	JUMP',NE DEFBEZH$	CALL	ZONEQDBHOR	; ajuste les poignes secondaires horizontalesDEFBEZH$:	COMP.W	(A6)+OZONDFB,#ICOBHORIZ	JUMP',NE DEFBEZV$	CALL	ZONEQDBVER	; ajuste les poignes secondaires verticalesDEFBEZV$:	LOAD.L	A2,#R16"ZONERDEFBEZ ; A2 <-- ^routine de transformation	CALL	ZONEMOVED	; dforme tous les objets	CALL	ZONEQINV	; allume la zone	CALL	ZONEQHSET	; allume les poignes	CALL	WDOCLOSE	; fin du dessin dans la swdo	JUMP	LOOP$REFAIT$:	CALL	WDOOPEN		; dessine dans la swdo	CALL	ZONEQHCLR	; teint les poignes	CALL	ZONEQINV	; teint la zone	CALL	ZONEPCLEAR	; teint tous les objets	CALL	DESOBJETS	; redessine tous les objets	CALL	ZONEPSET	; allume tous les objets	CALL	ZONEQINV	; allume la zone	CALL	ZONEQHSET	; allume les poignes	CALL	WDOCLOSE	; fin du dessin dans la swdo	JUMP	LOOP$HAND$:	CALL	ZONEQHDETECT	; D2 <-- rang de la poigne	JUMP,NE BIP$	CALL	_CONVSCROBP	CALL	ZONEQHCLR	; teint les poignes	CALL	ZONEQHMARKSET	; allume les marques	CALL	ZONEQHBEGIN	; dbut du dplacement	CALL	HVOPEN		; contrainte: fixe le point initialMOVE1$:	CLR.W	D0		; D0 <-- tout est dplacMOVE2$:	CALL	_SCMO		; remet la souris	CALL	_WAITMOVE	; attend dplacement souris ...	JUMP',NE MOVE8$MOVE4$:	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE MOVE2$	CALL	_CONVSCROBP	; D4 <-- point o est la souris	JUMP,NE MOVE2$	CALL	HVCONV		; D4 <-- point selon contrainte	LOAD.L	A1,#R16"ZONEMOVEDM	CALL	ZONEQHDRAG	; dplace la zone	JUMP,NE MOVE1$	INC.W	D0		; D0 <-- tout n'est pas dplac	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,EQ MOVE4$MOVE8$:	TEST.W	D0		; est-ce que tout est dplac ?	JUMP',EQ MOVE9$		; oui => MOVE9$	LOAD.L	A1,#R16"ZONEMOVED	CALL	ZONEQHDRAG	; dplace la zoneMOVE9$:	CALL	HVCLOSE		; contrainte: termine	CALL	ZONEQHEND	; fin du dplacement	CALL	ZONEQHMARKCLR	; teint les marques	CALL	ZONEQHSET	; allume les poignes	JUMP	LOOP$END$:	SET.B	(A6)+OMAJ	; mise  jour sur disque ncessaire	CALL	ZONEQHCLR	; teint les poignes	CALL	ZONEQHCLOSE	; fermeture du dplacement	CALL	ZONEQINV	; teint la zone	CALL	ZONEREL		; rend tous les objets relatifs	CALL	ZONEDESELECT	; dslectionne tous les objets inclus	CLR.W	(A6)+OICONIV	; fin de l'opration	CALL	_REMICONE	; remet les icnes  gauche	CALL	_AFMENU		; refait les soft-keys	JUMP	LOOPASCINV$:	CALL	WDOOPEN		; dessine dans la swdo	INC.W	(A6)+OASNBI	TEST.B	(A6)+OASNBI+1:#0	JUMP',BC ASCSET$ASCCLR$:	CALL	ZONEQHCLR	; teint les poignes	CALL	ZONEQINV	; teint la zone	CALL	ZONEPCLEAR	; teint tous les objets	JUMP'	ASCEND$ASCSET$:	CALL	ZONEPSET	; allume tous les objets	CALL	ZONEQINV	; allume la zone	CALL	ZONEQHSET	; allume les poignes;	JUMP'	ASCEND$ASCEND$:	CALL	WDOCLOSE	; fin du dessin dans la swdo	RETTMENUZONE:	.ASCIZ	" "	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOZDETRUIT	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  dtruit"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOZDEPLACE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	"  dplace  "	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOPRESS	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOZDUPLIQUE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	"  duplique "	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOPRESS	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOZOPER	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  opration.."	.BW	-2,-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOZMODIF	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  modifie"	.BW	-2,TMENUGROUP$-TMENUZONE	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOGROUPE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  groupe"	.BW	-2,TMENUCALC$-TMENUZONE	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOZCALQUE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  calque"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOZFRAGMENT	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  fragmente.."	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOSAUVE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  sauve.."	.B	0TMENUGROUP$:	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOGROUPMAKE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  assemble "	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOGROUPKILL	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  spare"	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOGROUPCHG	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCII	"  change "	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOPRESS	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.B	0TMENUCALC$:	.ASCIZ	"  A  "	.ASCIZ	"  B"	.ASCIZ	"  C"	.ASCIZ	"  D"	.ASCIZ	"  E"	.ASCIZ	"  F"	.ASCIZ	"  G"	.ASCIZ	"  H"	.B	0	.EVEN;----------\\; MENUAJUST >;----------/; Ajuste les pointeurs relatifs du menu pre qui vient d'tre; mis dans le buffer.; in	A2.L	^dbut du menu pre;	A3.L	^buffer;	A4.L	^mmenu; out	A3.L	^plus loin;	A4.L	^plus loin; mod	D7.W, A3.L, A4.LMENUAJUST:	PUSHM.L	D3,D4,A1,A2	LOAD.L	A1,A220$:	TEST.B	(A2)		; fin du mmenu ?	JUMP,EQ EXIT$		; oui => EXIT$30$:	LOAD.B	D3,(A2+)	JUMP,EQ 20$	COMP.B	D3,#-2	JUMP,NE 30$				; ^sous-menu =>	LOAD.B	D3,(A2+)	SL.W	D3,#8	LOAD.B	D3,(A2+)	; D3 <-- ^relatif	LOAD.L	D4,A3	SUB.L	D4,A1	LOAD.B	(A2)-1,D4	RR.W	D4,#8	LOAD.B	(A2)-2,D4	; buffer <-- ^relatif au sous-menu	RR.W	D4,#8	PUSH.L	A2	PUSH.L	A3	TEST.W	D3		; .BW -2,-n  ?	JUMP',NS 50$		; oui => 50$				; non =>	CALL	MENUBUF		; buffer <-- sous-menu	JUMP'	52$50$:	CALL	MENUSPEC	; buffer <-- sous-menu52$:	POP.L	A2	CALL	MENUAJUST	; paf, rcursif !!!	POP.L	A2	JUMP	30$EXIT$:	POPM.L	D3,D4,A1,A2	RET;--------\\; MENUBUF >;--------/; Met un mmenu dans un buffer.; in	A3.L	^buffer;	A4.L	^mmenu; out	A3.L	^plus loin;	A4.L	^plus loin; mod	D7.W, A3.L, A4.LMENUBUF:	PUSH.W	D310$:	TEST.B	(A4)		; fin du mmenu ?	JUMP',EQ 80$20$:	LOAD.B	D3,(A4+)	LOAD.B	(A3+),D3	; buffer <-- .ASCIZ	JUMP,EQ 10$	COMP.B	D3,#-2	JUMP,NE	20$	LOAD.B	(A3+),(A4+)	; buffer <-- <^rel-high>	LOAD.B	(A3+),(A4+)	; buffer <-- <^rel-low>	JUMP	20$80$:	INC.L	A4	CLR.B	(A3+)		; buffer <-- terminateur	POP.W	D3	RET;---------\\; MENUSPEC >;---------/; Met un mmenu spcial dans un buffer.; in	D3.W	type du menu spcial (-);	D4.W	^relatif;	A2.L	^pour mj. ^relatif;	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LMENUSPEC:	PUSHM.L	D0..D3,A1,A2,A4,A5	COMP.W	D3,#-1	JUMP',EQ MODIF$	JUMP	EXIT$; Construit le sous-menu des modifications.MODIF$:	LOAD.L	A1,#(A6)+OMBUMO	LOAD.L	A5,#(A6)+OTAMO	CLR.W	D0	LOAD.W	D2,#ICOUSERMLOOP$:	TEST.L	(A5)+OMOCOD	; objet en fonction ?	JUMP',EQ MNEXT$		; non => MNEXT$	COMP.W	(A5)+OMOTYP,#TYPOBDEF	JUMP',NE MNEXT$	PUSH.L	A3	LOAD.W	D1,#opDMMGETTX	CALL	_OBJCALL	; A3 <-- ^texte pour mmenu	LOAD.L	A2,A3	POP.L	A3	TEST.W	D7	JUMP',NE MNEXT$	LOAD.W	D3,#ICOIOBJET	LOAD.W	D1,#opGETICONE	CALL	_OBJCALL	; A4 <-- ^dx,dy,icne	JUMP',NE MNEXT$	LOAD.W	D3,D2	CALL	DRPUTICO	; IPP21 <-- une icne	LOAD.B	(A3+),#SPACE	LOAD.B	(A3+),#USEGC	LOAD.B	(A3+),#GCICF	LOAD.B	(A3+),#GCICS	LOAD.B	(A3+),#GCICT	LOAD.B	(A3+),D2	; buffer <-- ICOUSER+n	LOAD.B	(A3+),#USEGC	LOAD.B	(A3+),#GCTXF	LOAD.B	(A3+),#GCTXS	LOAD.B	(A3+),#GCTXT	LOAD.B	(A3+),#SPACE	LOAD.B	(A3+),#SPACEMTEXT$:	LOAD.B	(A3+),(A2+)	; buffer <-- texte	JUMP,NE MTEXT$	LOAD.B	(A3)-1,#'.	LOAD.B	(A3+),#'.	CLR.B	(A3+)	LOAD.W	(A1+),D0	; OMBUMO <-- identificateur	INC.W	D2		; D2 <-- ICOUSER suivanteMNEXT$:	ADD.L	A5,#LMO		; A5 <-- ^suivant dans OTAMO	INC.W	D0		; D0 <-- identificateur suivant	COMP.W	D0,#MAXMO	JUMP,LO MLOOP$	CLR.B	(A3+);	JUMP	EXIT$EXIT$:	POPM.L	D0..D3,A1,A2,A4,A5	RET;***************;;    MULTI      ;;***************;MULTI:	LOAD.W	(A6)+OOUTILM,D4	CLR.W	(A6)+OZONNS	; OZONNS <-- nb d'objets slectionns	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP	LOAD.W	(A6)+OICONIV,#NICOMULTI ; dbut de l'opration	CALL	_DESICONE	; dessine les icnes de gauche	CALL	_MAJICONE	; mj. les icnes variables	CALL	_AFMENU		; refait les soft-keys	LOAD.L	A2,#0		; A2 <-- ^premier objet slectionn	JUMP	SEL$INFO$:	LOAD.W	D4,(A6)+OZONNS	; D4 <-- nb d'objets slectionns	CALL	_DESINFOBJS	; affiche le nb d'objets slectionnsLOOP$:	CALL	_SCMO		; remet la sourisLOOP2$:	LOAD.W	D3,(A6)+OOUTILM	CALL	_SELMO		; utilise le bon lutin	CALL	_WAITMOVE	; attend dplacement souris ...	COMP.W	D3,#KEYMPO	JUMP,EQ LOOP2$	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMMP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMDP	JUMP',EQ CLIC$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#CR	JUMP,EQ END$	COMP.W	D3,#SPACE	JUMP,EQ END$	COMP.W	D3,#UNDO	JUMP,EQ CANCEL$	COMP.W	D3,#END	JUMP,EQ CANCEL$	TEST.L	D3:#BKPSEUDO	; changement de touches super-shift ?	JUMP,BS LOOP2$		; oui => LOOP2$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOP$CLIC$:	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP$	LOAD.L	A1,#R16"ASCINV$	CALL	_DOMASCENSEUR	; agit dans ascenseurs selon souris	JUMP,EQ LOOP$	CALL	_MOVICONE	; souris dans une icne ?	JUMP',EQ ICONE$		; oui => ICONE$	JUMP	SEL$ICONE$:	TEST.W	D3		; clic dans une icne grise ?	JUMP,EQ BIP$		; oui => BIP$	COMP.W	D3,#ICOOPOIGNEE	JUMP',EQ OUTIL$	COMP.W	D3,#ICOOZONE	JUMP',EQ OUTIL$	COMP.W	D3,#ICODACCORD	JUMP,EQ END$	COMP.W	D3,#ICOANNULE	JUMP,EQ CANCEL$	JUMP	BIP$OUTIL$:	COMP.W	D3,(A6)+OOUTILM	JUMP,EQ BIP$	LOAD.W	(A6)+OOUTILM,D3	CALL	_UPDICONE	; mj. les icnes variables	JUMP	LOOP$SEL$:	COMP.W	(A6)+OOUTILM,#ICOOZONE	JUMP,EQ ZONE$	LOAD.L	A1,#R16"HANDIFSEL2	LOAD.L	(A6)+OSELPS,A2	COMP.L	A2,#0		; y a-t-il dj des objets slectionns ?	JUMP',NE SELONE$	; oui => SELONE$	LOAD.L	A1,#R16"HANDIFSEL1	CALL	GETACH		; D6 <-- canal de l'arbre des objets	LOAD.L	(A6)+OSELPS,D6SELONE$:	CALL	HANDSELECT	; slectionne un objet ...	JUMP,NE BIP$	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BS DESEL$	CALL	ZONEPCLEAR	; teint tous les objets slectionns	CALL	DESCLEAR	; efface l'objet captur	CALL	_LSTO_HEXTEND	; A4 <-- ^objet tendu	JUMP',NE SELERR$	CALL	ZONEPSET	; allume tous les objets slectionns	INC.W	(A6)+OZONNS	; OZONNS <-- nb d'objets slectionns	COMP.L	A2,#0	JUMP,NE INFO$	LOAD.L	A2,A4		; A2 <-- ^premier objet slectionn	JUMP	INFO$SELERR$:	CALL	DESSET		; dessine l'objet captur	CALL	ZONEPSET	; allume tous les objets slectionns	JUMP	BIP$DESEL$:	CALL	ZONEPCLEAR	; teint tous les objets slectionns	CALL	_LSTO_HCOMPACT	; compactifie l'objet captur	CALL	DESSET		; dessine l'objet	CALL	ZONEPSET	; allume tous les objets slectionns	DEC.W	(A6)+OZONNS	; OZONNS <-- nb d'objets slectionns	JUMP,NE INFO$	LOAD.L	A2,#0		; A2 <-- plus de premier objet slectionn	JUMP	INFO$ZONE$:	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP$	CALL	_CONVSCROBJ	; D4 <-- position [obj]	JUMP,NE BIP$	LOAD.L	(A6)+OZONY1,D4	LOAD.L	(A6)+OZONY2,D4	SET.B	(A6)+OCCMO	; n'enlve pas le rticule !	LOAD.W	D2,#1		; D2 <-- open	CALL	DESISHIFTZ	; dessine le premier rectangleZLOOP$:	LOAD.W	D3,#ICOOZONE	CALL	_SELMO		; utilise le bon lutin	CALL	_DESINFXY	; affiche X= et Y= dans les informations	LOAD.W	D2,#2		; D2 <-- shift	CALL	DESISHIFTZ	; fait tourner le traitill	CALL	_WAITMOVES	; attend dplacement ...	JUMP',NE ZEND$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE ZLOOP$	CALL	_CONVSCROBJ	; D4 <-- point o est la souris	JUMP,NE ZLOOP$	COMP.L	D4,(A6)+OZONY2	; position change ?	JUMP,EQ ZLOOP$		; non => ZLOOP$				; oui =>	LOAD.W	D2,#3		; D2 <-- close	CALL	DESISHIFTZ	; efface l'ancien rectangle	LOAD.L	(A6)+OZONY2,D4	LOAD.W	D2,#1		; D2 <-- open	CALL	DESISHIFTZ	; dessine le nouveau rectangle	JUMP	ZLOOP$ZEND$:	LOAD.W	D2,#3		; D2 <-- close	CALL	DESISHIFTZ	; efface le dernier rectangle	CLR.B	(A6)+OCCMO	; enlve le rticule !	LOAD.W	D4,(A6)+OZONNS	; D4 <-- nb d'objets slectionns	CALL	ZONEPCLEAR	; teint tous les objets slectionns	LOAD.L	A4,A2		; A4 <-- ^premier objet slectionn	CALL	ZONESELECT	; slectionne tous les objets inclus	LOAD.L	A2,A4		; A2 <-- ^premier objet slectionn	CALL	ZONEPSET	; allume tous les objets slectionns	ADD.W	(A6)+OZONNS,D4	; OZONNS <-- nb d'objets slectionns	JUMP	INFO$CANCEL$:	CALL	ZONEDESELECT	; dslectionne tous les objets inclus	CLR.W	(A6)+OICONIV	; fin des poignes	CALL	_REMICONE	; remet les icnes  gauche	CALL	_AFMENU		; refait les soft-keys	CALL	_DESINFALL	; remet les informations normales	JUMP	LOOPEND$:	TEST.W	(A6)+OZONNS	; au moins un objet slectionn ?	JUMP,EQ CANCEL$		; non => CANCEL$	CLR.W	(A6)+OICONIV	; fin des poignes	CALL	_REMICONE	; remet les icnes  gauche	CALL	_AFMENU		; refait les soft-keys	CALL	_DESINFALL	; remet les informations normales	CALL	ZONEQREDUCE	; calcule une zone la plus petite possible	LOAD.L	A4,A2		; A4 <-- ^premier objet slectionn	CLR.W	D3	CALL	_SELMO		; outil = flche	LOAD.L	D4,(A6)+OZONY2	CALL	_CONVOBJSCR	; D4 <- position [scr]	JUMP,NE ZONE2	CALL	_PMOUSE		; met la souris dans le coin inf/droite	LOAD.W	D4,#2	NTREL	?DELMS		; attend le positionnement	JUMP	ZONE2ASCINV$:	CALL	WDOOPEN		; dessine dans la swdo	INC.W	(A6)+OASNBI	TEST.B	(A6)+OASNBI+1:#0	JUMP',BC ASCSET$ASCCLR$:	CALL	ZONEPCLEAR	; teint tous les objets	JUMP'	ASCEND$ASCSET$:	CALL	ZONEPSET	; allume tous les objets;	JUMP'	ASCEND$ASCEND$:	CALL	WDOCLOSE	; fin du dessin dans la swdo	RET;***************;;    POIGNEE    ;;***************;POIGNEE:	LOAD.W	D4,#ICOOPOIGNEE	LIB	?GETSHIFT	; D3 <-- touches super-shift	TEST.L	D3:#BCOPY	JUMP,BS MULTI	CLR.W	(A6)+OPOINBM	; OPOINBM <-- aucune modification	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP	CALL	GETACH		; D6 <-- canal de l'arbre des objets	LOAD.L	(A6)+OSELPS,D6	LOAD.L	A1,#R16"HANDIFSEL1	CALL	HANDSELECT	; slectionne un objet ...	JUMP,NE BIP	CALL	DESCLEAR	; efface l'objetPOIGNEE3:	LOAD.W	D0,(A4)+OobjIDENT	CALL	HANDUNDOCOPY	; copie pour UNDO	CALL	_LSTO_HEXTEND	; A4 <-- ^objet tendu	JUMP',EQ EXTOK$	PUSH.W	D7	CALL	DESSET		; redessine l'objet	POP.W	D7	JUMP	ERROREXTOK$:	CALL	_LSTA_POS	; met  jour la position absolue	LOAD.L	(A6)+OPOIPOB,A4	; OPOIPOB <-- ^objet slection	SET.B	(A6)+OMAJ	; mise  jour sur disque ncessaire	CALL	HANDOPEN	; ouvre le dplacement	CALL	HANDSET		; allume toutes les poignes	LOAD.W	D1,#opHANDICOLIST	CALL	_OBJCALLD	; A3 <-- ^liste des icnes, A2 <-- ^table des softkeys	LOAD.L	(A6)+OICOPH,A3	; OICOPH <-- ^liste des icnes	LOAD.L	(A6)+OICOPS,A2	; OICOPS <-- ^table des soft-keys	LOAD.W	(A6)+OICONIV,#NICOHAND ; dbut de l'opration	LOAD.W	(A6)+OICOID,D0	; OICOID <-- identificateur	CALL	_DESICONE	; dessine les icnes de gauche	CALL	_MAJICONE	; mj. les icnes variables	CALL	_AFMENU		; refait les soft-keysINFO$:	LOAD.W	D1,#opHANDINFO	CALL	_DESINFOBJ	; affiche les informationsLOOP$:	CALL	_UPDICONE	; met  jour l'tat des icnes	CALL	_SCMO		; remet la sourisLOOP2$:	LOAD.W	D1,#opHANDICOOUTIL	CALL	_OBJCALLD	; D3 <-- icne pour la souris	JUMP',EQ LOOP3$	LOAD.W	D3,#ICOOZONELOOP3$:	CALL	_SELMO		; utilise le bon lutin;;?	CALL	_DESINFXY	; affiche X= et Y= dans les informations	CALL	_WAITMOVE	; attend dplacement souris ...	COMP.W	D3,#KEYMPO	JUMP,EQ LOOP2$	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMMP	JUMP',EQ CLIC$	COMP.W	D3,#KEYMDP	JUMP',EQ CLIC$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#CR	JUMP,EQ END$	COMP.W	D3,#UNDO	JUMP,EQ UNDO$	COMP.W	D3,#DEL	JUMP,EQ DETRUIT$	COMP.W	D3,#BS	JUMP,EQ DETRUIT$	COMP.W	D3,#DELETE	JUMP,EQ DETRUIT$	TEST.L	D3:#BKRELEAS	JUMP',BS EVENT$	TEST.L	D3:#BKPSEUDO	; changement de touches super-shift ?	JUMP,BS LOOP3$		; oui => LOOP3$EVENT$:	LOAD.W	D1,#opHANDEVENT	CALL	_OBJCALLD	; donne l'vnement  l'objet	JUMP,EQ INFO$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOP$CLIC$:	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP$	LOAD.L	A1,#R16"ASCINV$	CALL	_DOMASCENSEUR	; agit dans ascenseurs selon souris	JUMP,EQ LOOP$	LOAD.W	D1,#opBUTTON	CALL	_OBJCALLD	; indique le bouton utilis	CALL	_MOVICONE	; souris dans une icne ?	JUMP',EQ ICONE$		; oui => ICONE$	JUMP	HAND$ICONE$:	COMP.W	D3,#ICOMVUE	JUMP,EQ VUE$	COMP.W	D3,#ICOGRID	JUMP,EQ GRID$	COMP.W	D3,#ICOHORVERT	JUMP,EQ HORVERT$	COMP.W	D3,#ICOOEDIT	JUMP,EQ EDIT$	COMP.W	D3,#ICODEVANT	JUMP,EQ LAST$	COMP.W	D3,#ICODERRIERE	JUMP,EQ FIRST$	COMP.W	D3,#ICOPOUBELLE	JUMP,EQ DETRUIT$	COMP.W	D3,#ICOSEPARE	JUMP,EQ SEPARE$	COMP.W	D3,#ICODACCORD	JUMP,EQ END$	COMP.W	D3,#ICOANNULE	JUMP,EQ UNDO$	CLR.L	D4	LOAD.W	D1,#opHANDICOGET	CALL	_OBJCALLD	; D4 <-- tat	LOAD.L	D5,D4	TEST.L	D5:#BSTICOCHGHAND ; faut-il changer les poignes ?	JUMP',BC ICONE22$	; non => ICONE22$	CALL	HANDCLR		; teint toutes les poignesICONE22$:	TEST.L	D5:#BSTICOCHGDRAW ; faut-il changer le dessin ?	JUMP',BC ICONE23$	; non => ICONE23$	LOAD.L	D2,#2^BVUECLR!2^BVUEPROV!2^BVUEPROVE!2^BVUEPROVI	CALL	DESOBJET	; efface l'objetICONE23$:	LOAD.W	D1,#opHANDICOMOD	CALL	_OBJCALLD	; agit dans l'objet selon l'ine clique ...	JUMP',NE ICONE3$	ADD.W	(A6)+OPOINBM,D4	; OPOINBM <-- nb de modificationsICONE3$:	PUSH.W	D7	TEST.L	D5:#BSTICOCHGDRAW ; faut-il changer le dessin ?	JUMP',BC ICONE42$	; non => ICONE42$	LOAD.L	D2,#2^BVUESET!2^BVUEPROV!2^BVUEPROVE!2^BVUEPROVI	CALL	DESOBJET	; redessine l'objetICONE42$:	TEST.L	D5:#BSTICOCHGHAND ; faut-il changer les poignes ?	JUMP',BC ICONE43$	; non => ICONE43$	CALL	HANDSET		; allume toutes les poignesICONE43$:	TEST.L	D5:#BSTICOCHGUPIC ; faut-il changer l'icne ?	JUMP',BC ICONE44$	; non => ICONE44$	CALL	_DESICONEONE	; redessine l'icneICONE44$:	POP.W	D7	JUMP,NE BIP$	JUMP	INFO$HAND$:	LOAD.W	D1,#opHANDICOOUTIL	CALL	_OBJCALLD	; D3 <-- icne pour la souris	CALL	HANDDETECT	; D2 <-- rang de la poigne	JUMP',EQ MOVE11$	COMP.W	D3,#ICOHADD	; outil = ajoute poigne ?	JUMP',EQ MOVE10$	COMP.W	D3,#ICOOCRAYON	; outil = nouvelle courbe ?	JUMP',EQ MOVE10$	COMP.W	D3,#ICOHLINE	; outil = transforme ligne ?	JUMP',EQ MOVE10$	COMP.W	D3,#ICOHCURVE	; outil = transforme courbe ?	JUMP,NE RESEL$		; non => RESEL$MOVE10$:	LOAD.W	D2,#-1		; D2 <-- rang spcial	CALL	_CONVSCROBJ	; D4 <-- position de la souris [obj]	JUMP,NE BIP$	LOAD.L	D3,#-1		; D3 <-- point fixe initial	JUMP'	MOVE12$MOVE11$:	COMP.W	D3,#ICOHADD	; outil = ajoute poigne ?	JUMP,EQ BIP$		; oui => BIP$	COMP.W	D3,#ICOOCRAYON	; outil = nouvelle courbe ?	JUMP,EQ BIP$		; oui => BIP$	COMP.W	D3,#ICOHLINE	; outil = transforme ligne ?	JUMP,EQ BIP$		; oui => BIP$	COMP.W	D3,#ICOHCURVE	; outil = transforme courbe ?	JUMP,EQ BIP$		; oui => BIP$	LOAD.W	D1,#opHANDGET	CALL	_OBJCALLD	; D3/D4 <-- icne/position	JUMP,NE BIP$	ADD.W	D4,(A6)+OAPOS+2	SWAP.W	D4	ADD.W	D4,(A6)+OAPOS+0	SWAP.W	D4	LOAD.L	D3,D4		; D3 <-- point fixe initialMOVE12$:	CALL	HANDCLR		; teint toutes les poignes	CALL	HANDMARKSET	; allume les marques	EX.L	D4,D3	CALL	HVOPEN		; contrainte: fixe le point initial	EX.L	D3,D4	CALL	HANDBEGIN	; indique le dbut du dplacementMOVE2$:	CALL	_SCMO		; remet la souris	CALL	_WAITMOVE	; attend dplacement souris ...	JUMP',NE MOVE8$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE MOVE2$	CALL	_CONVSCROBP	; D4 <-- point o est la souris	JUMP,NE MOVE2$	CALL	HVCONV		; D4 <-- point selon contrainte	SUB.W	D4,(A6)+OAPOS+2	SWAP.W	D4	SUB.W	D4,(A6)+OAPOS+0	SWAP.W	D4	CALL	HANDDRAG	; dplace la poigne	LOAD.W	D1,#opHANDINFO	CALL	_DESINFOBJ	; affiche les informations	JUMP	MOVE2$MOVE8$:	CALL	HANDEND		; indique la fin du dplacement	PUSH.W	D7	CALL	HVCLOSE		; contrainte: termine	CALL	HANDMARKCLR	; teint les marques	CALL	HANDSET		; rallume toutes les poignes	POP.W	D7	JUMP,NE BIP$	JUMP	INFO$RESEL$:	LOAD.L	D2,D4	LOAD.W	D3,#ICOOEDIT	CALL	_GSTICONE	; D4 <-- tat de l'icne	COMP.W	D4,#STICONORM	; icne normale ?	JUMP,NE BIP$		; non => BIP$	LOAD.L	D4,D2	LOAD.L	A3,A4	LOAD.L	(A6)+OSELPS,A4	LOAD.L	A1,#R16"HANDIFSEL1	CALL	HANDSELECT	; slectionne un objet ...	EX.L	A3,A4		; A3 <-- ^nouveau, A4 <-- ^actuel;;?	JUMP,NE BIP$	JUMP,NE END$	CALL	HANDCLR		; enlve toutes les poignes	CALL	HANDCLOSE	; ferme le dplacement	CALL	_LSTO_HCOMPACT	; A4 <-- ^objet compact	CALL	DESSET		; redessine l'objet	LOAD.L	A4,A3		; A4 <-- ^nouvel objet slectionn	LOAD.W	D0,(A4)+OobjIDENT	CALL	DESCLEAR	; efface l'objet	CALL	HANDUNDOCOPY	; copie pour UNDO	CALL	_LSTO_HEXTEND	; A4 <-- ^objet tendu	JUMP,EQ EXTOK$	CALL	DESSET		; redessine l'objet	JUMP	MENU$EDIT$:	CALL	HANDCLR		; enlve toutes les poignes	CALL	HANDCLOSE	; ferme le dplacement	CALL	_LSTO_HCOMPACT	; A4 <-- ^objet compact	JUMP	EDIT3VUE$:	CALL	_DBOXVUE	; choix de la vue ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	JUMP'	REFAIT$GRID$:	CALL	_DBOXGRID	; choix de la grille ...	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	JUMP'	REFAIT$HORVERT$:	CALL	_DBOXHORVERT	; choix contrainte ...	JUMP,NE BIP$	JUMP	LOOP$REFAIT$:	CALL	WDOOPEN		; dessine dans la swdo	CALL	HANDCLR		; enlve toutes les poignes	CALL	DESOBJETS	; redessine tous les objets	LOAD.W	D3,#HANDMOVEINVBEG ; D3 <-- inverse le dbut	LOAD.W	D1,#opHANDMOVE	CALL	_OBJCALLD	; allume le dbut	LOAD.L	D2,#2^BVUESET!2^BVUEPROV!2^BVUEPROVE!2^BVUEPROVI	CALL	DESOBJET	; allume l'objet	CALL	HANDSETFILS	; allume tous les fils	CALL	HANDSET		; remet toutes les poignes	CALL	WDOCLOSE	; fin du dessin dans la swdo	JUMP	LOOP$LAST$:	CALL	GETACH		; D6 <-- canal de l'arbre des objets	CALL	_LSTA_TAIL	; met  la fin de la liste	JUMP	LOOP$FIRST$:	CALL	GETACH		; D6 <-- canal de l'arbre des objets	CALL	_LSTA_HEAD	; met au dbut de la liste	JUMP	LOOP$SEPARE$:	CALL	HANDCLR		; enlve toutes les poignes	CALL	HANDCLOSE	; ferme le dplacement	CALL	_LSTA_BBOX	; D3/D4 <-- bbox	CALL	_GROUPDEAD	; mort du pre	CALL	DESALLWDO	; redessine par-l	CALL	_DESINFNBOBJ	; affiche le nombre d'objets	JUMP	MENU$DETRUIT$:	CALL	HANDCLR		; enlve toutes les poignes	CALL	HANDCLOSE	; ferme le dplacement	CALL	GETACH		; D6 <-- canal de l'arbre des objets	CALL	_LSTA_REMOVE	CALL	_DESINFNBOBJ	; affiche le nombre d'objets	JUMP	MENU$UNDO$:	CALL	HANDCLR		; enlve toutes les poignes	CALL	HANDCLOSE	; ferme le dplacement	CALL	HANDUNDOBACK	; A4 <-- ^objet original	LOAD.L	D4,(A6)+OPOISDD	; D4 <-- somme de tous les dplacements	NEG.W	D4	SWAP.W	D4	NEG.W	D4	SWAP.W	D4	CALL	_GROUPDFILS	; dplace tous les fils (pour qu'ils restent immoblies)	CALL	DESSET		; redessine l'objet	JUMP	MENU$END$:	CALL	HANDCLR		; enlve toutes les poignes	CALL	HANDCLOSE	; ferme le dplacement	CALL	_LSTO_HCOMPACT	; A4 <-- ^objet compact	CALL	DESSET		; redessine l'objetMENU$:	CALL	HANDUNDOFLUSH	; annule le UNDO	CLR.W	(A6)+OICONIV	; fin des poignes	CALL	_REMICONE	; remet les icnes  gauche	CALL	_AFMENU		; refait les soft-keys	CALL	_DESINFALL	; remet les informations normales	TEST.W	(A6)+OPOINBM	; y a-t-il eu des modifications ?	JUMP,NE DOREFAITBBOX	; oui => DOREFAITBBOX	JUMP	LOOPASCINV$:	PUSHM.L	D1..D3	CALL	WDOOPEN		; dessine dans la swdo	INC.W	(A6)+OASNBI	TEST.B	(A6)+OASNBI+1:#0	JUMP',BC ASCSET$ASCCLR$:	CALL	HANDCLR		; enlve toutes les poignes	LOAD.L	D2,#2^BVUECLR!2^BVUEPROV!2^BVUEPROVE!2^BVUEPROVI	CALL	DESOBJET	; efface l'objet	CALL	HANDCLRFILS	; efface tous les fils	LOAD.W	D3,#HANDMOVEINVBEG ; D3 <-- inverse le dbut	LOAD.W	D1,#opHANDMOVE	CALL	_OBJCALLD	; efface le dbut	JUMP'	ASCEND$ASCSET$:	LOAD.W	D3,#HANDMOVEINVBEG ; D3 <-- inverse le dbut	LOAD.W	D1,#opHANDMOVE	CALL	_OBJCALLD	; allume le dbut	LOAD.L	D2,#2^BVUESET!2^BVUEPROV!2^BVUEPROVE!2^BVUEPROVI	CALL	DESOBJET	; allume l'objet	CALL	HANDSETFILS	; allume tous les fils	CALL	HANDSET		; remet toutes les poignes;	JUMP'	ASCEND$ASCEND$:	CALL	WDOCLOSE	; fin du dessin dans la swdo	POPM.L	D1..D3	RET;************;;    EDIT    ;;************;EDIT:	CLR.W	(A6)+OPOINBM	; OPOINBM <-- aucune modification	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP	LOAD.L	A3,#0	CALL	EDITSELECT	; slectionne un objet ...	JUMP,NE BIPEDIT2:	CALL	DESCLEAR	; efface l'objetEDIT3:	CALL	_LSTA_POS	; met  jour la position absolue	LOAD.L	(A6)+OPOIPOB,A4	; OPOIPOB <-- ^objet slection	LOAD.W	D0,(A4)+OobjIDENT	CALL	HANDUNDOCOPY	; copie pour UNDO	SET.B	(A6)+OMAJ	; mise  jour sur disque ncessaire	LOAD.W	D3,#1		; D3 <-- affiche tout	LOAD.W	D1,#opEDITDRAW	CALL	_OBJCALLD	; affiche l'objet	PUSH.L	D4	LOAD.W	D4,#1	CALL	_SCALEN	TEST.W	D4	JUMP',NE NONULL$	INC.W	D4NONULL$:	LOAD.W	D2,D4	CALL	_LSTA_BBOXQ	; D3/D4 <-- bbox	SUB.W	D3,D2	SWAP.W	D3	SUB.W	D3,D2	SWAP.W	D3	ADD.W	D4,D2	SWAP.W	D4	ADD.W	D4,D2	SWAP.W	D4	LOAD.L	(A6)+OZONY1,D3	LOAD.L	(A6)+OZONY2,D4	LOAD.W	D2,#1		; D2 <-- open	CALL	DESISHIFTZ	; dessine le rectangle englobant	POP.L	D4	LOAD.W	D1,#opEDITICOLIST	CALL	_OBJCALLD	; A3 <-- ^liste des icnes, A2 <-- ^table des softkeys	LOAD.L	(A6)+OICOPH,A3	; OICOPH <-- ^liste des icnes	LOAD.L	(A6)+OICOPS,A2	; OICOPS <-- ^table des soft-keys	LOAD.W	(A6)+OICONIV,#NICOEDIT ; dbut de l'opration	LOAD.W	(A6)+OICOID,D0	; OICOID <-- identificateur	CALL	_DESICONE	; dessine les icnes de gauche	CALL	_MAJICONE	; mj. les icnes variables	CALL	_AFMENU		; refait les soft-keys	LOAD.W	D1,#opEDITINFO	CALL	_DESINFOBJ	; affiche les informations	SUB.W	D4,(A6)+OAPOS+2	SWAP.W	D4	SUB.W	D4,(A6)+OAPOS+0	SWAP.W	D4	LOAD.W	D3,#KEYMGP	; D3 <-- vnement "clic de la souris"	LOAD.W	D1,#opEDITEVENT	CALL	_OBJCALLD	; donne l'vnement  l'objet	JUMP',NE LOOP$	CLR.W	D3		; D3 <-- affichage minimal	LOAD.W	D1,#opEDITDRAW	CALL	_OBJCALLD	; affiche l'objetLOOP$:	CALL	_UPDICONE	; met  jour l'tat des icnes	CALL	_SCMO		; remet la sourisLOOPS$:	CALL	WDOOPEN		; dessine dans la swdo	LOAD.W	D1,#opEDITFLASH	CALL	_OBJCALLD	; allume le curseur	LOAD.W	D2,#2		; D2 <-- shift	CALL	DESISHIFTZ	; fait tourner le rectangle englobant	CALL	WDOCLOSE	; fin du dessin dans la swdo	CALL	_SCMO		; remet la souris	JUMP'	LOOPS4$LOOPS2$:	LOAD.W	D1,#opEDITICOOUTIL	CALL	_OBJCALLD	; D3 <-- icne pour la souris	JUMP',EQ LOOPS3$	LOAD.W	D3,#ICOOEDITLOOPS3$:	CALL	_SELMO		; utilise le bon lutin;;?	CALL	_DESINFXY	; affiche X= et Y= dans les informationsLOOPS4$:	LOAD.W	D3,#15	CALL	_WAITMOVET	; attend vnement ...	JUMP',NE LOOPC$	COMP.W	D3,#KEYMPO	JUMP,EQ LOOPS2$	JUMP'	LOOPX1$LOOPC$:	CALL	WDOOPEN		; dessine dans la swdo	LOAD.W	D1,#opEDITFLASH	CALL	_OBJCALLD	; teint le curseur	LOAD.W	D2,#2		; D2 <-- shift	CALL	DESISHIFTZ	; fait tourner le rectangle englobant	CALL	WDOCLOSE	; fin du dessin dans la swdo	CALL	_SCMO		; remet la souris	JUMP'	LOOPC4$LOOPC2$:	LOAD.W	D1,#opEDITICOOUTIL	CALL	_OBJCALLD	; D3 <-- icne pour la souris	JUMP',EQ LOOPC3$	LOAD.W	D3,#ICOOEDITLOOPC3$:	CALL	_SELMO		; utilise le bon lutin;;?	CALL	_DESINFXY	; affiche X= et Y= dans les informationsLOOPC4$:	LOAD.W	D3,#15	CALL	_WAITMOVET	; attend vnement ...	JUMP,NE LOOPS$	COMP.W	D3,#KEYMPO	JUMP,EQ LOOPC2$	JUMP'	LOOPX2$LOOPX1$:	CALL	WDOOPEN		; dessine dans la swdo	LOAD.W	D1,#opEDITFLASH	CALL	_OBJCALLD	; teint le curseur	CALL	WDOCLOSE	; fin du dessin dans la swdo	CALL	_SCMO		; remet la sourisLOOPX2$:	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#KEYMMP	JUMP,EQ CLICM$	COMP.W	D3,#KEYMDP	JUMP,EQ CLIC$	COMP.W	D3,#F0	JUMP,EQ END$EVENT$:	LOAD.W	D1,#opEDITEVENT	CALL	_OBJCALLD	; donne l'vnement  l'objet	JUMP',NE ERROR$EVLOOP$:	LOAD.W	D3,#1	CALL	_WAITMOVET	; autre vnement tout de suite ?	JUMP',NE EVDRAW$	; non => EVDRAW$				; oui =>	COMP.W	D3,#KEYMPO	JUMP,EQ EVLOOP$	COMP.W	D3,#KEYMGR	JUMP,EQ EVLOOP$	COMP.W	D3,#KEYMMR	JUMP,EQ EVLOOP$	COMP.W	D3,#KEYMDR	JUMP,EQ EVLOOP$	COMP.W	D3,#KEYMGP	JUMP',EQ EVKEY$	COMP.W	D3,#KEYMMP	JUMP',EQ EVKEY$	COMP.W	D3,#KEYMDP	JUMP',EQ EVKEY$	COMP.W	D3,#F0	JUMP,NE EVENT$EVKEY$:	CLR.W	D3		; D3 <-- affichage minimal	LOAD.W	D1,#opEDITDRAW	CALL	_OBJCALLD	; affiche l'objet	LOAD.W	D1,#opEDITINFO	CALL	_DESINFOBJ	; affiche les informations	JUMP	LOOPX2$EVDRAW$:	CLR.W	D3		; D3 <-- affichage minimal	LOAD.W	D1,#opEDITDRAW	CALL	_OBJCALLD	; affiche l'objet	LOAD.W	D1,#opEDITINFO	CALL	_DESINFOBJ	; affiche les informations	JUMP	LOOP$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP	JUMP	LOOP$ERROR$:	COMP.W	D7,#ERPBIP	JUMP,EQ BIP$	CALL	_DBOXERROR	; affiche l'erreur ...	JUMP	LOOP$CLICM$:	LOAD.W	D1,#opEDITMMENU	CALL	_OBJCALLD	; mmenu du bouton du milieu	JUMP,NE BIP$	JUMP	LOOP$CLIC$:	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP$	LOAD.L	A1,#R16"ASCINV$	CALL	_DOMASCENSEUR	; agit dans ascenseurs selon souris	JUMP,EQ LOOP$	LOAD.W	D1,#opBUTTON	CALL	_OBJCALLD	; indique le bouton utilis	CALL	_MOVICONE	; souris dans une icne ?	JUMP',EQ ICONE$		; oui => ICONE$	JUMP	MOVE$ICONE$:	COMP.W	D3,#ICOHMOVE	JUMP,EQ HAND$	COMP.W	D3,#ICODEVANT	JUMP,EQ LAST$	COMP.W	D3,#ICODERRIERE	JUMP,EQ FIRST$	COMP.W	D3,#ICOPOUBELLE	JUMP,EQ DETRUIT$	COMP.W	D3,#ICODACCORD	JUMP,EQ END$	COMP.W	D3,#ICOANNULE	JUMP,EQ UNDO$	CLR.L	D4	LOAD.W	D1,#opEDITICOGET	CALL	_OBJCALLD	; D4 <-- tat	LOAD.L	D5,D4	TEST.L	D5:#BSTICOCHGDRAW ; faut-il changer le dessin ?	JUMP',BC ICONE23$	; non => ICONE23$	LOAD.L	D2,#2^BVUECLR!2^BVUEPROV!2^BVUEPROVI	CALL	DESOBJET	; efface l'objetICONE23$:	LOAD.W	D1,#opEDITICOMOD	CALL	_OBJCALLD	; agit dans l'objet selon l'ine clique ...	JUMP',NE ICONE3$	ADD.W	(A6)+OPOINBM,D4	; OPOINBM <-- nb de modificationsICONE3$:	PUSH.W	D7	TEST.L	D5:#BSTICOCHGDRAW ; faut-il changer le dessin ?	JUMP',BC ICONE43$	; non => ICONE43$	LOAD.L	D2,#2^BVUESET!2^BVUEPROV!2^BVUEPROVI	CALL	DESOBJET	; redessine l'objetICONE43$:	TEST.L	D5:#BSTICOCHGUPIC ; faut-il changer l'icne ?	JUMP',BC ICONE44$	; non => ICONE44$	CALL	_DESICONEONE	; redessine l'icneICONE44$:	POP.W	D7	JUMP,NE BIP$	JUMP	LOOP$MOVE$:	LOAD.L	D3,D4	CALL	_CONVSCROBJ	; D4 <-- position [obj]	JUMP,NE BIP$	LOAD.L	A3,A4	CALL	DEEOBJET	; A4 <-- ^objet montr	EX.L	A3,A4	JUMP',NE MOVE1$	COMP.L	A3,A4		; objet montr = objet actuel ?	JUMP,NE RESEL$		; non => RESEL$MOVE1$:	SUB.W	D4,(A6)+OAPOS+2	SWAP.W	D4	SUB.W	D4,(A6)+OAPOS+0	SWAP.W	D4	CALL	WDOOPEN		; dessine dans la swdo	LOAD.W	D3,#EDITMOVEBEGIN ; D3 <-- dbut	LOAD.W	D1,#opEDITMOVE	CALL	_OBJCALLD	; indique le dbut du dplacement	PUSH.W	D7	CALL	WDOCLOSE	; fin du dessin dans la swdo	POP.W	D7	JUMP,NE BIP$MOVE2$:	CALL	_SCMO		; remet la souris	CALL	_WAITMOVE	; attend dplacement souris ...	JUMP',NE MOVE8$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE MOVE2$	CALL	_CONVSCROBJ	; D4 <-- point o est la souris	JUMP,NE MOVE2$	SUB.W	D4,(A6)+OAPOS+2	SWAP.W	D4	SUB.W	D4,(A6)+OAPOS+0	SWAP.W	D4	CALL	WDOOPEN		; dessine dans la swdo	LOAD.W	D3,#EDITMOVEDRAG ; D3 <-- dplacement	LOAD.W	D1,#opEDITMOVE	CALL	_OBJCALLD	; dplace la poigne	CALL	WDOCLOSE	; fin du dessin dans la swdo	JUMP	MOVE2$MOVE8$:	CALL	WDOOPEN		; dessine dans la swdo	LOAD.W	D3,#EDITMOVEEND	; D3 <-- fin	LOAD.W	D1,#opEDITMOVE	CALL	_OBJCALLD	; indique la fin du dplacement	PUSH.W	D7	CALL	WDOCLOSE	; fin du dessin dans la swdo	POP.W	D7	JUMP,NE ERROR$	JUMP	LOOP$RESEL$:	LOAD.W	D2,#3		; D2 <-- close	CALL	DESISHIFTZ	; efface le rectangle englobant	LOAD.L	D4,D3		; D4 <-- position de la souris [scr]	LOAD.L	A3,A4		; A3 <-- ^objet actuel	CALL	EDITSELECT	; slectionne un objet ...	EX.L	A3,A4		; A3 <-- ^nouveau, A4 <-- ^actuel	JUMP',NE RESEL8$	PUSH.L	D4	LOAD.W	D1,#opGETBBOX	CALL	_OBJCALLD	; D3/D4 <-- bounding box	LOAD.L	(A4)+OobjBBOX1,D3	LOAD.L	(A4)+OobjBBOX2,D4	POP.L	D4	CALL	DESSETALL	; redessine l'objet	LOAD.L	A4,A3		; A4 <-- ^nouvel objet	JUMP	EDIT2HAND$:	LOAD.W	D2,#3		; D2 <-- close	CALL	DESISHIFTZ	; efface le rectangle englobant	LOAD.W	D1,#opGETBBOX	CALL	_OBJCALLD	; D3/D4 <-- bounding box	LOAD.L	(A4)+OobjBBOX1,D3	LOAD.L	(A4)+OobjBBOX2,D4	TSET.B	(A4)+OobjFLAGS:#BobjEXTEND	CALL	DESSETALL	; redessine tout, sans l'objet !	TCLR.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP	POIGNEE3RESEL8$:	LOAD.W	D2,#1		; D2 <-- open	CALL	DESISHIFTZ	; dessine le rectangle englobant	JUMP	BIP$LAST$:	CALL	GETACH		; D6 <-- canal de l'arbre des objets	CALL	_LSTA_TAIL	; met  la fin de la liste	JUMP	LOOP$FIRST$:	CALL	GETACH		; D6 <-- canal de l'arbre des objets	CALL	_LSTA_HEAD	; met au dbut de la liste	JUMP	LOOP$DETRUIT$:	LOAD.W	D2,#3		; D2 <-- close	CALL	DESISHIFTZ	; efface le rectangle englobant	TSET.B	(A4)+OobjFLAGS:#BobjEXTEND	CALL	DESSETALL	; redessine tout, sans l'objet !	TCLR.B	(A4)+OobjFLAGS:#BobjEXTEND	CALL	GETACH		; D6 <-- canal de l'arbre des objets	CALL	_LSTA_REMOVE	CALL	_DESINFNBOBJ	; affiche le nombre d'objets	JUMP	MENU$UNDO$:	CALL	HANDUNDOBACK	; A4 <-- ^objet original	LOAD.W	D2,#3		; D2 <-- close	CALL	DESISHIFTZ	; efface le rectangle englobant	CALL	DESSETALL	; redessine l'objet	JUMP	MENU$END$:	LOAD.W	D1,#opGETBBOX	CALL	_OBJCALLD	; D3/D4 <-- bounding box	LOAD.L	(A4)+OobjBBOX1,D3	LOAD.L	(A4)+OobjBBOX2,D4	LOAD.W	D2,#3		; D2 <-- close	CALL	DESISHIFTZ	; efface le rectangle englobant	CALL	DESSETALL	; redessine l'objetMENU$:	CALL	HANDUNDOFLUSH	; annule le UNDO	CLR.W	(A6)+OICONIV	; fin des poignes	CALL	_REMICONE	; remet les icnes  gauche	CALL	_AFMENU		; refait les soft-keys	CALL	_DESINFALL	; remet les informations normales	TEST.W	(A6)+OPOINBM	; y a-t-il eu des modifications ?	JUMP,NE DOREFAITBBOX	; oui => DOREFAITBBOX	JUMP	LOOPASCINV$:	PUSHM.L	D1..D3	INC.W	(A6)+OASNBI	TEST.B	(A6)+OASNBI+1:#0	JUMP',BC ASCSET$ASCCLR$:	LOAD.W	D2,#3		; D2 <-- close	CALL	DESISHIFTZ	; efface le rectangle englobant	CALL	DESSETALL	; redessine l'objet normalement	JUMP'	ASCEND$ASCSET$:	LOAD.W	D3,#1		; D3 <-- affiche tout	LOAD.W	D1,#opEDITDRAW	CALL	_OBJCALLD	; affiche l'objet	LOAD.W	D2,#1		; D2 <-- open	CALL	DESISHIFTZ	; dessine le rectangle englobant;	JUMP'	ASCEND$ASCEND$:	POPM.L	D1..D3	RET;*************;;    LOUPE    ;;*************;LOUPE:	LOAD.W	D4,#+1		; D4 <-- suivante	LIB	?GETSHIFT	; D3 <-- touches super-shift	TEST.L	D3:#BCHANGE	JUMP',BC GO$	LOAD.W	D4,#-1		; D4 <-- prcdenteGO$:	LOAD.W	D3,D4	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP	CALL	_CONVSCROBJ	; D4 <-- position [obj]	JUMP,NE BIPLOUPES:	LOAD.L	D5,D4		; D5 <-- position [obj]	LOAD.W	D4,(A6)+OSCA100	; D4 <-- chelle pour 100%	TEST.W	D3	JUMP',EQ LOUPEQ	CALL	_NEXTSCALE	; D4 <-- nouvelle chelle	JUMP,NE BIPLOUPEQ:	LOAD.W	(A6)+OSCALE,D4	LOAD.L	D4,(A6)+OWDOY2	SUB.W	D4,(A6)+OWDOX1	SR.W	D4,#1	SWAP.W	D4	SUB.W	D4,(A6)+OWDOY1	SR.W	D4,#1	SWAP.W	D4	CALL	_SCALEN	SUB.W	D5,D4	SWAP.W	D4	SWAP.W	D5	SUB.W	D5,D4;	SWAP.W	D4	SWAP.W	D5	LOAD.L	D4,D5	CALL	_CLIPPOS	; D4 <-- position clippe et arrondie	LOAD.L	(A6)+ODESY1,D4	CALL	_DESINFSCALE	; affiche l'chelle	CALL	_MAJCADRE	; mj cadre (ascenseurs et rgles)	CALL	DESOBJETS	; redessine tous les objets	JUMP	LOOP;************;;    MAIN    ;;************;MAIN:	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE BIP	LOAD.L	D5,D4	LOAD.L	D6,(A6)+ODESY1	LOAD.W	D3,#ICOOMAIN	CALL	_SELMO		; utilise le bon lutinLOOP$:	CALL	_SCMO		; remet la souris	CALL	_WAITMOVE	; attend dplacement souris ...	JUMP',NE END$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE LOOP$	SUB.W	D4,D5	NEG.W	D4	SWAP.W	D4	SWAP.W	D5	SUB.W	D4,D5	NEG.W	D4	SWAP.W	D4	SWAP.W	D5	CALL	_SCALEN	ADD.W	D4,D6	SWAP.W	D4	SWAP.W	D6	ADD.W	D4,D6	SWAP.W	D4	SWAP.W	D6	CALL	_CLIPPOS	; D4 <-- position clippe et arrondie	LOAD.L	D3,(A6)+ODESY1	LOAD.L	(A6)+ODESY1,D4	CALL	_CHGCADRE	; met  jour OWDOY2/OWDOX2	LOAD.L	D4,D3		; D4 <-- ancienne position	CALL	DEMOBJETS	; dessine les objets	CALL	_MOVCADRE	; dplace ascenseurs et rgles	JUMP	LOOP$END$:	JUMP	LOOP	.END