	.SBTTL	PAGEHAND.ASI;-----------\\; HANDSELECT >;===========/; Slectionne un objet avec la poigne.; in	D4.L	position de la souris (y;x);	A1.L	^routine pour objets  exclure (*); out	A4.L	^objet slectionn;	D7.W	erreur; mod	D7.W, A4.L; Routine (*) :; in	A4.L	^objet; out	D7.W	erreur si objet  exclure; mod	D7.WHANDSELECT:	PUSHM.L	D2..D4,D6,A2	PUSH.L	(A6)+OAPOS	CALL	_CONVSCROBJ	; D4 <-- position [obj]	JUMP,NE EXIT$	CALL	DETOBJET	; A4 <-- ^objet montr	LOAD.L	A2,A4	LOAD.W	D2,#1		; D2 <-- open	CALL	DESISHIFT	; dessine le premier objet	LOAD.W	D3,#ICOOPOIGNEE	CALL	_SELMO		; utilise le bon lutinLOOP$:	CALL	_SCMO		; remet la souris	LOAD.W	D2,#2		; D2 <-- shift	CALL	DESISHIFT	; fait tourner le traitill	CALL	_WAITMOVES	; attend dplacement ...	JUMP',NE END$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE LOOP$	CALL	_CONVSCROBJ	; D4 <-- position [obj]	JUMP,NE LOOP$	CALL	DETOBJET	; A4 <-- ^objet montr	COMP.L	A4,A2		; toujours le mme objet ?	JUMP,EQ LOOP$		; oui => LOOP$				; non =>	EX.L	A2,A4	LOAD.W	D2,#3		; D2 <-- close	CALL	DESISHIFT	; efface l'ancien objet	LOAD.L	A4,A2	LOAD.W	D2,#1		; D2 <-- open	CALL	DESISHIFT	; dessine le nouvel objet	JUMP	LOOP$END$:	LOAD.L	A4,A2	LOAD.W	D2,#3		; D2 <-- close	CALL	DESISHIFT	; efface le dernier objet	CLR.W	D7		; D7 <-- ok	COMP.L	A4,#0	JUMP',NE EXIT$	LOAD.W	D7,#ERPAHANDENDEXIT$:	POP.L	(A6)+OAPOS	POPM.L	D2..D4,D6,A2	TEST.W	D7		; retour EQ/NE	RET;-----------\\; HANDIFSEL1 >;-----------/; Regarde s'il est possible de slectionner un objet.; Accepte si l'objet est pre, frre ou fils du premier objet slectionn.; in	A4.L	^objet slectionn; out	D7.W	erreur; mod	D7.WHANDIFSEL1:	PUSHM.L	A2..A4	PUSH.L	(A6)+OAPOS	LOAD.L	A2,A4		; A2 <-- ^objet  slectionner	LOAD.L	A3,(A6)+OSELPS	; A3 <-- ^premier objet slectionn	COMP.L	A2,A3		; est-ce le premier objet slectionn ?	JUMP',EQ NOSEL$		; oui => NOSEL$	TEST.B	(A6)+OSELSS:#BKILL ; touche (KILL) enfonce ?	JUMP',BS SEL$		; oui => SEL$;	LOAD.L	A4,A2	CALL	_LSTA_FRERE	; est-ce deux frres ?	JUMP',EQ SEL$		; oui => SEL$;	LOAD.L	A4,A2	CALL	_LSTA_PREVP	; A4 <-- ^pre	COMP.L	A4,A3		; est-ce que le premier slectionn est le pre ?	JUMP',EQ SEL$	LOAD.L	A4,A3	CALL	_LSTA_PREVP	; A4 <-- ^pre	COMP.L	A4,A2		; est-ce que l'objet  slectionner est le pre ?	JUMP',NE NOSEL$		; non => NOSEL$SEL$:	CLR.W	D7		; D7 <-- slection possible	JUMP'	EXIT$NOSEL$:	LOAD.W	D7,#1		; D7 <-- slection refuseEXIT$:	POP.L	(A6)+OAPOS	POPM.L	A2..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; HANDIFSEL2 >;-----------/; Regarde s'il est possible de slectionner un objet.; Accepte seulement si l'objet est frre du premier objet slectionn (cousins interdits).; in	A4.L	^objet slectionn; out	D7.W	erreur; mod	D7.WHANDIFSEL2:	PUSH.L	A3	CLR.W	D7		; D7 <-- slection possible	TEST.L	(A6)+OSELPS	JUMP',EQ EXIT$	LOAD.L	A3,(A6)+OSELPS	; A3 <-- ^premier objet slectionn	CALL	_LSTA_FRERE	; est-ce deux frres ?EXIT$:	POP.L	A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; HANDLIMIT >;==========/; Cherche les limites en fonction du pre d'un objet slectionn.; in	A4.L		^objet slectionn; out	(A6)+OLIMP1.L	P1 (y;x);	(A6)+OLIMP2.L	P2 (y;x); mod	D7.WHANDLIMIT:	PUSHM.L	D3,D4,A4	PUSH.L	(A6)+OAPOS	CALL	_LSTA_PREVP	; A4 <-- ^pre	JUMP',NE ALL$	CALL	_LSTA_BBOX	; D3/D4 <-- bbox du pre	LOAD.L	(A6)+OLIMP1,D3	LOAD.L	(A6)+OLIMP2,D4	JUMP',NE EXIT$ALL$:	CLR.L	(A6)+OLIMP1	LOAD.L	(A6)+OLIMP2,(A6)+ODESYDEXIT$:	POP.L	(A6)+OAPOS	POPM.L	D3,D4,A4	RET;-----------\\; EDITSELECT >;===========/; Slectionne un objet pour l'diter.; in	D4.L	position de la souris [scr];	A3.L	^objet actuel; out	A4.L	^objet slectionn;	D4.L	position slection [obj];	D7.W	erreur; mod	D4.L, D7.W, A4.LEDITSELECT:	PUSHM.L	D2..D3,A2	CALL	_CONVSCROBJ	; D4 <-- position [obj]	JUMP,NE EXIT$	CALL	DEEOBJET	; A4 <-- ^objet montr	JUMP',NE DET1$	COMP.L	A4,A3		; est-ce l'objet actuel ?	JUMP',NE DET1$		; non => DET1$	LOAD.L	A4,#0DET1$:	LOAD.L	A2,A4	LOAD.W	D2,#1		; D2 <-- open	CALL	DESISHIFT	; dessine le premier objet	LOAD.W	D3,#ICOOEDIT	CALL	_SELMO		; utilise le bon lutinLOOP$:	CALL	_SCMO		; remet la souris	LOAD.W	D2,#2		; D2 <-- shift	CALL	DESISHIFT	; fait tourner le traitill	CALL	_WAITMOVES	; attend dplacement ...	JUMP',NE END$	CALL	_IFMOUSE	; D4 <-- position de la souris	JUMP,NE LOOP$	CALL	_CONVSCROBJ	; D4 <-- position [obj]	JUMP,NE LOOP$	CALL	DEEOBJET	; A4 <-- ^objet montr	JUMP',NE DET2$	COMP.L	A4,A3		; est-ce l'objet actuel ?	JUMP',NE DET2$		; non => DET2$	LOAD.L	A4,#0DET2$:	COMP.L	A4,A2		; toujours le mme objet ?	JUMP,EQ LOOP$		; oui => LOOP$				; non =>	EX.L	A2,A4	LOAD.W	D2,#3		; D2 <-- close	CALL	DESISHIFT	; efface l'ancien objet	LOAD.L	A4,A2	LOAD.W	D2,#1		; D2 <-- open	CALL	DESISHIFT	; dessine le nouvel objet	JUMP	LOOP$END$:	LOAD.L	A4,A2	LOAD.W	D2,#3		; D2 <-- close	CALL	DESISHIFT	; efface le dernier objet	CLR.W	D7		; D7 <-- ok	COMP.L	A4,#0	JUMP',NE EXIT$	LOAD.W	D7,#ERPAHANDENDEXIT$:	POPM.L	D2..D3,A2	TEST.W	D7		; retour EQ/NE	RET;-------------\\; HANDUNDOCOPY >;=============/; Copie un objet, afin de pouvoir revenir  l'tat initial (undo).; in	A4.L	^objet; out	D7.W	erreur; mod	D7.WHANDUNDOCOPY:	PUSHM.L	D0,D1,D4,D6,A3,A4	CALL	HANDUNDOFLUSH	; annule l'objet copi	LOAD.L	A3,(A4)+OobjPDATA ; A3 <-- ^data de l'objet source	LOAD.W	D0,(A4)+OobjIDENT	LOAD.W	D1,#opCRCOPYLG	CALL	_OBJCALL	; D4 <-- lg ncessaire	JUMP',NE EXIT$	LOAD.L	D6,(A6)+ODALCH	; D6 <-- canal de la liste des datas	LOAD.L	A4,#0	CALL	_LST_INSERT	; A4 <-- ^data pour copie objet	JUMP',NE EXIT$	LOAD.L	(A6)+OPOIPCU,A4	LOAD.W	(A6)+OPOIPCI,D0	LOAD.W	D1,#opCRCOPYXFER	CALL	_OBJCALL	; (A4)++ <-- (A3)++EXIT$:	POPM.L	D0,D1,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-------------\\; HANDUNDOBACK >;=============/; Remplace un objet par sa copie effectue lors du HANDUNDOCOPY.; in	A4.L	^objet; out	-; mod	D7.WHANDUNDOBACK:	PUSHM.L	D0,D1,D3,D4,D6,A3,A4	LOAD.W	D0,(A4)+OobjIDENT	LOAD.L	D6,(A6)+ODALCH	; D6 <-- canal de la liste des datas	LOAD.L	A3,A4		; A3 <-- ^racine de l'objet	LOAD.L	A4,(A3)+OobjPDATA ; A4 <-- ^data de l'objet original	LOAD.W	D1,#opCRCLOSE	CALL	_OBJCALL	; ferme l'objet	CALL	_LST_REMOVE	; enlve de la liste des datas	LOAD.L	(A3)+OobjPDATA,(A6)+OPOIPCU	CLR.L	(A6)+OPOIPCU	LOAD.L	A4,A3	LOAD.W	D1,#opGETBBOX	CALL	_OBJCALLD	; D3/D4 <-- bounding box	LOAD.L	(A4)+OobjBBOX1,D3	LOAD.L	(A4)+OobjBBOX2,D4	TCLR.B	(A4)+OobjFLAGS:#BobjEXTEND	POPM.L	D0,D1,D3,D4,D6,A3,A4	RET;--------------\\; HANDUNDOFLUSH >;==============/; Annule l'objet copi lors du HANDUNDOCOPY.; in	-; out	-; mod	D7.WHANDUNDOFLUSH:	PUSHM.L	D0,D1,D6,A4	LOAD.L	D6,(A6)+ODALCH	; D6 <-- canal de la liste des datas	TEST.L	(A6)+OPOIPCU	JUMP',EQ EXIT$	LOAD.L	A4,(A6)+OPOIPCU	LOAD.W	D0,(A6)+OPOIPCI	LOAD.W	D1,#opCRCLOSE	CALL	_OBJCALL	; ferme l'objet	CALL	_LST_REMOVE	; enlve de la liste des datas	CLR.L	(A6)+OPOIPCUEXIT$:	POPM.L	D0,D1,D6,A4	RET;------------\\; HANDMARKSET >;============/; Allume les marques.; in	A4.L	^objet;	D2.W	poigne dplace; out	-; mod	D7.WHANDMARKSET:	PUSHM.L	D1..D5	CLR.L	(A6)+OPOIMCC	LOAD.W	D1,#opHANDICOOUTIL	CALL	_OBJCALLD	; D3 <-- icne pour la souris	JUMP',NE EXIT$	COMP.W	D3,#ICOHROTATE	JUMP',NE EXIT$	LOAD.W	D1,#opHANDGET	CALL	_OBJCALLD	; D3/D4 <-- icne/position poigne dplace	JUMP',NE EXIT$	COMP.W	D3,#ICOHANDEXT	; icne extrmit ?	JUMP',NE EXIT$	ADD.W	D4,(A6)+OAPOS+2	SWAP.W	D4	ADD.W	D4,(A6)+OAPOS+0	SWAP.W	D4	LOAD.L	D5,D4	CLR.W	D2	LOAD.W	D1,#opHANDGET	CALL	_OBJCALLD	; D3/D4 <-- icne/position poigne centrale	JUMP',NE EXIT$	ADD.W	D4,(A6)+OAPOS+2	SWAP.W	D4	ADD.W	D4,(A6)+OAPOS+0	SWAP.W	D4	LOAD.L	D2,D4	LOAD.L	D3,D5	SUB.W	D3,D2	SWAP.W	D2	SWAP.W	D3	SUB.W	D3,D2	SWAP.W	D2	SWAP.W	D3	LIB	?CALCHYPO	; D4 <-- rayon	LOAD.L	D3,D2	LOAD.L	(A6)+OPOIMCC,D3	LOAD.W	(A6)+OPOIMRC,D4	CALL	HANDMARKINV	; allume le cercleEXIT$:	POPM.L	D1..D5	RET;------------\\; HANDMARKCLR >;============/; Eteint les marques.; in	A4.L	^objet; out	-; mod	D7.WHANDMARKCLR:	TEST.L	(A6)+OPOIMCC	; D3 <-- centre	JUMP',EQ EXIT$	CALL	HANDMARKINV	; teint le cercleEXIT$:	RET;------------\\; HANDMARKINV >;============/; Inverse les marques.; in	A4.L	^objet; out	-; mod	D7.WHANDMARKINV:	PUSHM.L	D2..D4	PUSH.L	(A6)+OAPOS	CLR.L	(A6)+OAPOS	LIB	?AFTIM	.B	MAPTT	.B	B'10001000	; map	.B	1		; chelle	.B	0	.EVEN	LOAD.L	D3,(A6)+OPOIMCC	; D3 <-- centre	LOAD.W	D4,(A6)+OPOIMRC	; D4 <-- rayon	CALL	WDOOPEN		; dessine dans la swdo	LOAD.W	D2,#INVDOT!TTTDOT	CALL	DRCIRCLE	; teint le cercle	CALL	WDOCLOSE	; fin du dessin dans la swdo	POP.L	(A6)+OAPOS	POPM.L	D2..D4	RET;-----------\\; HANDDETECT >;===========/; Dtecte dans quelle poigne est la souris.; in	A4.L	^objet quelconque;	D4.L	position de la souris (y;x); out	D2.W	rang de la poigne (0..n);	D7.W	erreur; mod	D2.L, D7.WHANDDETECT:	PUSHM.L	D1,D3..D6	LOAD.W	D5,D4		; D5 <-- position en X	LOAD.L	D6,D4	SWAP.W	D6		; D6 <-- position en Y	CLR.W	D2		; D2 <-- rang de la poigneLOOP$:	LOAD.W	D1,#opHANDGET	CALL	_OBJCALLD	; D3/D4 <-- icne/position	JUMP',EQ EXIST$	COMP.W	D7,#ERPAHANDDNE	JUMP',EQ NEXT$	JUMP'	EXIT$EXIST$:	ADD.W	D4,(A6)+OAPOS+2	SWAP.W	D4	ADD.W	D4,(A6)+OAPOS+0	SWAP.W	D4	CALL	_CONVOBJSCR	; D4 <-- position [scr]	JUMP',NE NEXT$	SUB.W	D4,#DPOIGNEE	COMP.W	D5,D4		; trop  gauche ?	JUMP',LT NEXT$	ADD.W	D4,#DPOIGNEE*2	COMP.W	D5,D4		; trop  droite ?	JUMP',GE NEXT$	SWAP.W	D4	SUB.W	D4,#DPOIGNEE	COMP.W	D6,D4		; trop haut ?	JUMP',LT NEXT$	ADD.W	D4,#DPOIGNEE*2	COMP.W	D6,D4		; trop bas ?	JUMP',LT EXIT$NEXT$:	INC.W	D2		; D2 <-- poigne suivante	JUMP	LOOP$EXIT$:	POPM.L	D1,D3..D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; HANDSET >;========/; Allume toutes les poignes d'un objet.; in	A4.L	^objet quelconque; out	-; mod	D7.WHANDSET:	PUSHM.L	D1..D4	CALL	WDOOPEN		; dessine dans la swdo; Allume les poignes dans l'ordre croissant.	LOAD.W	D2,#-1LOOP$:	INC.W	D2		; D2 <-- poigne suivante	LOAD.W	D1,#opHANDGET	CALL	_OBJCALLD	; D3/D4 <-- icne/position	JUMP',EQ SET$	COMP.W	D7,#ERPAHANDDNE	JUMP,EQ LOOP$	JUMP'	END$SET$:	ADD.W	D4,(A6)+OAPOS+2	SWAP.W	D4	ADD.W	D4,(A6)+OAPOS+0	SWAP.W	D4	CALL	HANDSETONE	; allume une poigne	JUMP	LOOP$END$:	CALL	WDOCLOSE	; fin du dessin dans la swdo	POPM.L	D1..D4	RET;--------\\; HANDCLR >;========/; Eteint toutes les poignes d'un objet.; in	A4.L	^objet quelconque; out	-; mod	D7.WHANDCLR:	PUSHM.L	D1..D4	CALL	WDOOPEN		; dessine dans la swdo; Eteint les poignes dans l'ordre dcroissant, afin de rsoudre; correctement le cas des poignes superposes !	LOAD.W	D2,#MAXPOIGNEE+1LOOP$:	DEC.W	D2		; D5 <-- poigne prcdente	JUMP',NS END$	LOAD.W	D1,#opHANDGET	CALL	_OBJCALLD	; D3/D4 <-- icne/position	JUMP,NE LOOP$	ADD.W	D4,(A6)+OAPOS+2	SWAP.W	D4	ADD.W	D4,(A6)+OAPOS+0	SWAP.W	D4	CALL	HANDCLRONE	; teint une poigne	JUMP	LOOP$END$:	CALL	WDOCLOSE	; fin du dessin dans la swdo	POPM.L	D1..D4	RET;-----------\\; HANDSETONE >;-----------/; Allume une poigne.; Lorsque la poigne est allume, on sauve au pralable ce qui est dessous.; in	D2.W	rang de la poigne (0..n);	D3.W	icne (ICOHANDxxx);	D4.L	coordonne de la poigne (y;x); out	-; mod	D7.WHANDSETONE:	PUSHM.L	D0..D5,A2..A4	LOAD.W	D0,D3		; D0 <-- icne	SUB.W	D4,(A6)+ODESX1	SWAP.W	D4	SUB.W	D4,(A6)+ODESY1	SWAP.W	D4	CALL	_SCALEP	ADD.W	D4,#-7+15	JUMP,NS EXIT$	ADD.W	D4,#-15	COMP.W	D4,(A0)+ODFFDX	JUMP,GE EXIT$	SWAP.W	D4	ADD.W	D4,#-7+15	JUMP,NS EXIT$	ADD.W	D4,#-15	COMP.W	D4,(A0)+ODFFDY	JUMP,GE EXIT$	LOAD.L	D5,D4		; D5 <-- coordonne (x;y) (!)	LOAD.L	A2,#(A6)+OPOIPFE	SL.W	D2,#2	ADD.W	A2,D2		; A2 <-- ^^buffer/nil	TEST.L	(A2)	JUMP',NE MEMOK$	LOAD.L	D4,#32	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour sauver sous une poigne	JUMP,NE EXIT$	LOAD.L	(A2),A4MEMOK$:	LOAD.L	A4,(A2)		; A4 <-- ^buffer pour sauver sous une poigne	CALL	_CCMO		; enlve la souris	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWRASTER	LOAD.L	(A3)+1,D5	; source: xx yy	CLR.L	(A3)+5		; source: pppp (dans l'cran);	CLR.W	(A3)+9		; source: ii	CLR.L	(A3)+11		; destination: xx yy	LOAD.L	(A3)+15,A4	; destination: pppp	LOAD.W	(A3)+19,#2	; destination: ii	LOAD.L	(A3)+21,#H'10000*15+15	LOAD.B	(A3)+25,#LOADDOT	LOAD.W	D3,#26	LIB	?STRING		; sauve le fond;	LOAD.L	A3,#(A6)+OBUDIS+1;	LOAD.B	(A3)+0,#DRAWRASTER	LOAD.W	(A3)+1,#16	; source: xx (pour fond)	CLR.W	(A3)+3		; source: yy	LOAD.L	A4,(A6)+OPGICO	; A4 <-- ^gencar des icnes	LOAD.W	D3,D0		; D3 <-- icne	MUL.WU	D3,(A4)+OGCMSB	ADD.L	D3,#OGCMAT	ADD.L	A4,D3		; A4 <-- ^bonne matrice	LOAD.L	(A3)+5,A4	; source: pppp (dans IIP21)	LOAD.W	(A3)+9,#GCICX/8	; source: ii	LOAD.L	(A3)+11,D5	; destination: xx yy	CLR.L	(A3)+15		; destination: pppp (dans l'cran)	CLR.W	(A3)+19		; destination: ii;	LOAD.L	(A3)+21,#H'10000*15+15	LOAD.B	(A3)+25,#CLRDOT	LOAD.W	D3,#26	LIB	?STRING		; efface selon l'icne du fond	CLR.W	(A3)+1		; source: xx (pour chair)	LOAD.B	(A3)+25,#SETDOT	LOAD.W	D3,#26	LIB	?STRING		; dessine selon l'icne de la chairEXIT$:	POPM.L	D0..D5,A2..A4	RET;-----------\\; HANDCLRONE >;-----------/; Eteint une poigne.; Lorsque la poigne est teinte, on remet simplement ce qui tait dessous.; in	D2.W	rang de la poigne (0..n);	D3.W	icne (ICOHANDxxx);	D4.L	coordonne de la poigne (y;x); out	-; mod	D7.WHANDCLRONE:	PUSHM.L	D0..D5,A2..A4	LOAD.W	D0,D3		; D0 <-- icne	SUB.W	D4,(A6)+ODESX1	SWAP.W	D4	SUB.W	D4,(A6)+ODESY1	SWAP.W	D4	CALL	_SCALEP	SUB.W	D4,#7	SWAP.W	D4	SUB.W	D4,#7	LOAD.L	D5,D4		; D5 <-- coordonne (x;y) (!)	LOAD.L	A2,#(A6)+OPOIPFE	SL.W	D2,#2	ADD.W	A2,D2		; A2 <-- ^^buffer/nil	TEST.L	(A2)	JUMP',EQ EXIT$	LOAD.L	A4,(A2)		; A4 <-- ^contenu de dessous la poigne	CALL	_CCMO		; enlve la souris	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWRASTER	CLR.L	(A3)+1		; source: xx yy	LOAD.L	(A3)+5,A4	; source: pppp	LOAD.W	(A3)+9,#2	; source: ii	LOAD.L	(A3)+11,D5	; destination: xx yy	CLR.L	(A3)+15		; destination: pppp (dans l'cran);	CLR.W	(A3)+19		; destination: ii	LOAD.L	(A3)+21,#H'10000*15+15	LOAD.B	(A3)+25,#LOADDOT	LOAD.W	D3,#26	LIB	?STRING		; remet le fond	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	CLR.L	(A2)EXIT$:	POPM.L	D0..D5,A2..A4	RET;---------\\; HANDOPEN >;=========/; Ouverture d'un dplacement avec les poignes.; in	A4.L	^objet; out	-; mod	D7.WHANDOPEN:	PUSHM.L	D1,D3,D4	CALL	WDOOPEN		; dessine dans la swdo	LOAD.W	D3,#HANDMOVEOPEN	LOAD.W	D1,#opHANDMOVE	CALL	_OBJCALLD	; ouvre le dplacement	CALL	HANDLIMIT	; OLIMP1/P2 <-- P1/P2 limites	CALL	_GROUPBBFILS	; D3/D4 <-- bbox des fils	LOAD.L	(A6)+OLIMB1,D3	LOAD.L	(A6)+OLIMB2,D4	CLR.L	(A6)+OPOISDD	; somme des dplacements nulle	CALL	HANDSETFILS	; allume tous les fils	CALL	WDOCLOSE	; fin du dessin dans la swdo	POPM.L	D1,D3,D4	RET;----------\\; HANDBEGIN >;==========/; Dbut du dplacement d'une poigne.; in	A4.L	^objet;	D2.W	rang de la poigne; out	-; mod	D7.WHANDBEGIN:	PUSHM.L	D1,D3	CALL	WDOOPEN		; dessine dans la swdo	LOAD.W	D3,#HANDMOVEBEGIN	LOAD.W	D1,#opHANDMOVE	CALL	_OBJCALLD	; dbut	LOAD.L	(A6)+OPOILB1,(A4)+OobjBBOX1	TEST.W	D2		; centre de gravit dplac ?	JUMP',NE CLOSE$		; non => CLOSE$	CALL	HANDCLRFILS	; teint tous les filsCLOSE$:	CALL	WDOCLOSE	; fin du dessin dans la swdo	POPM.L	D1,D3	RET;---------\\; HANDDRAG >;=========/; Dplacement d'une poigne.; in	A4.L	^objet;	D2.W	rang de la poigne;	D4.L	nouvelle position (y;x); out	-; mod	D7.WHANDDRAG:	PUSHM.L	D1,D3	CALL	WDOOPEN		; dessine dans la swdo	LOAD.W	D3,#HANDMOVEDRAG	LOAD.W	D1,#opHANDMOVE	CALL	_OBJCALLD	; dplace	CALL	WDOCLOSE	; fin du dessin dans la swdo	POPM.L	D1,D3	RET;--------\\; HANDEND >;========/; Fin du dplacement d'une poigne.; in	A4.L	^objet;	D2.W	rang de la poigne; out	D7.W	erreur; mod	D7.WHANDEND:	PUSHM.L	D1..D4	CALL	WDOOPEN		; dessine dans la swdo	LOAD.W	D3,#HANDMOVEEND	LOAD.W	D1,#opHANDMOVE	CALL	_OBJCALLD	; fin	PUSH.W	D7	TEST.W	(A4)+OobjNB	; y a-t-il des fils ?	JUMP',EQ CLOSE$		; non => CLOSE$	LOAD.W	D1,#opGETBBOX	CALL	_OBJCALLD	; D3/D4 <-- bounding box	LOAD.L	(A4)+OobjBBOX1,D3	LOAD.L	(A4)+OobjBBOX2,D4	TEST.W	D2		; centre de gravit dplac ?	JUMP',EQ FILS$		; oui => FILS$	LOAD.L	D4,(A6)+OPOILB1	; D4 <-- ancien P1 bbox	SUB.W	D4,D3	ADD.W	(A6)+OPOISDD+2,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	ADD.W	(A6)+OPOISDD+0,D4;	SWAP.W	D3	SWAP.W	D4		; D4 <-- contre-dplacement	CALL	_GROUPDFILS	; dplace tous les fils (pour qu'ils restent immoblies)	JUMP'	CLOSE$FILS$:	CALL	_GROUPBBFILS	; D3/D4 <-- bbox des fils	LOAD.L	(A6)+OLIMB1,D3	LOAD.L	(A6)+OLIMB2,D4	CALL	HANDSETFILS	; allume tous les filsCLOSE$:	CALL	WDOCLOSE	; fin du dessin dans la swdo	POP.W	D7	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; HANDCLOSE >;==========/; Fermeture d'un dplacement avec les poignes.; in	A4.L	^objet; out	-; mod	D7.WHANDCLOSE:	PUSHM.L	D1,D3	CALL	WDOOPEN		; dessine dans la swdo	LOAD.W	D3,#HANDMOVECLOSE	LOAD.W	D1,#opHANDMOVE	CALL	_OBJCALLD	; ferme le dplacement	CALL	HANDCLRFILS	; teint tous les fils	CALL	WDOCLOSE	; fin du dessin dans la swdo	POPM.L	D1,D3	RET;------------\\; HANDSETFILS >;------------/; Allume tous les fils d'un pre.; in	A4.L	^objet pre; out	-; mod	D7.WHANDSETFILS:	PUSHM.L	D4,A4	PUSH.L	(A6)+OAPOS	LOAD.W	D4,(A4)+OobjNB	; D4 <-- nb de fils	JUMP',EQ EXIT$LOOP$:	CALL	_LSTA_NEXT	; A4 <-- ^fils suivant	JUMP',NE EXIT$	LOAD.L	D2,#2^BVUESET!2^BVUEPROV!2^BVUEPROVE!2^BVUEPROVI	CALL	DESOBJET	; allume l'objet	DEC.W	D4	JUMP,NE LOOP$EXIT$:	POP.L	(A6)+OAPOS	POPM.L	D4,A4	RET;------------\\; HANDCLRFILS >;------------/; Eteint tous les fils d'un pre.; in	A4.L	^objet pre; out	-; mod	D7.WHANDCLRFILS:	PUSHM.L	D2,D4,A4	PUSH.L	(A6)+OAPOS	LOAD.W	D4,(A4)+OobjNB	; D4 <-- nb de fils	JUMP',EQ EXIT$LOOP$:	CALL	_LSTA_NEXT	; A4 <-- ^fils suivant	JUMP',NE EXIT$	LOAD.L	D2,#2^BVUECLR!2^BVUEPROV!2^BVUEPROVE!2^BVUEPROVI	CALL	DESOBJET	; teint l'objet	DEC.W	D4	JUMP,NE LOOP$EXIT$:	POP.L	(A6)+OAPOS	POPM.L	D2,D4,A4	RET;----------\\; HANDPOSOK >;==========/; Vrifie si la position d'un objet est correcte, c'est--dire :;   -	s'il ne dpasse pas les limites de son pre;   -	s'il n'est pas plus petit que ses fils;;	+---------------------+;	|  +--------------+   |;	|  |    +-------+ |<---------  objet vrifi;	|  |    |       | |   |;	|  |    |       |<-----------  fils;	|  |    |       | |   |;	|  |    +-------+ |   |<-----  pre;	|  |              |   |;	|  +--------------+   |;	+---------------------+; in	A4.L	^objet; out	D7.W	erreur; mod	D7.WHANDPOSOK:	PUSHM.L	D1..D4	LOAD.W	D1,#opGETBBOX	CALL	_OBJCALLD	; D3/D4 <-- bounding box	LOAD.L	(A4)+OobjBBOX1,D3	LOAD.L	(A4)+OobjBBOX2,D4	CALL	_LSTA_BBOX	; D3/D4 <-- bbox de l'objet	LOAD.L	D1,D3	LOAD.L	D2,D4	LOAD.L	D3,(A6)+OLIMP1	LOAD.L	D4,(A6)+OLIMP2	CALL	_RECTTEST	; D1/D2 inclu dans D3/D4 ?	COMP.W	D7,#2		; les deux coins inclus ?	JUMP',NE ERROR$		; non => ERROR$	LOAD.L	D3,D1	LOAD.L	D4,D2	LOAD.L	D1,(A6)+OLIMB1	LOAD.L	D2,(A6)+OLIMB2	JUMP',EQ OK$	CALL	_RECTTEST	; D1/D2 inclu dans D3/D4 ?	COMP.W	D7,#2		; les deux coins inclus ?	JUMP',NE ERROR$		; non => ERROR$OK$:	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$ERROR$:	LOAD.W	D7,#1		; D7 <-- position impossibleEXIT$:	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RET	.END