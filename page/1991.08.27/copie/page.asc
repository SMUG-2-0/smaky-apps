Y2:	.BLKB	2		; zone: coin inf/droite en YOZONX2:	.BLKB	2		; zone: coin inf/droite en XOZONY3:	.BLKB	2		; zone: coin sup/droite en YOZONX3:	.BLKB	2		; zone: coin sup/droite en XOZONY4:	.BLKB	2		; zone: coin inf/gauche en YOZONX4:	.BLKB	2		; zone: coin inf/gauche en XOZONYC:	.BLKB	2		; zone: centre en YOZONXC:	.BLKB	2		; zone: centre en XOZONY13:.BLKB	2		; zone: S13 en YOZONX13:.BLKB	2		; zone: S13 en XOZONY31:.BLKB	2		; zone: S31 en YOZONX31:.BLKB	2		; zone: S31 en XOZONY32:.BLKB	2		; zone: S32 en YOZONX32:.BLKB	2		; zone: S32 en XOZONY23:.BLKB	2		; zone: S23 en YOZONX23:.BLKB	2		; zone: S23 en XOZONY24:.BLKB	2		; zone: S24 en YOZONX24:.BLKB	2		; zone: S24 en XOZONY42:.BLKB	2		; zone: S42 en YOZONX42:.BLKB	2		; zone: S42 en XOZONY41:.BLKB	2		; zone: S41 en YOZONX41:.BLKB	2		; zone: S41 en XOZONY14:.BLKB	2		; zone: S14 en YOZONX14:.BLKB	2		; zone: S14 en XOZONCS:	.BLKB	4*4		; zone: sauvetage pour clippingOZOOY1:	.BLKB	2		; zone: init sup/gauche en YOZOOX1:	.BLKB	2		; zone: init sup/gauche en XOZOOY2:	.BLKB	2		; zone: init inf/droite en YOZOOX2:	.BLKB	2		; zone: init inf/droite en XOZOOY3:	.BLKB	2		; zone: init sup/droite en YOZOOX3:	.BLKB	2		; zone: init sup/droite en XOZOOY4:	.BLKB	2		; zone: init inf/gauche en YOZOOX4:	.BLKB	2		; zone: init inf/gauche en XOZOOYC:	.BLKB	2		; zone: init centre en YOZOOXC:	.BLKB	2		; zone: init centre en XOZONB1:	.BLKB	4		; zone: P1 bboxOZONB2:	.BLKB	4		; zone: P2 bboxOZONP1:	.BLKB	4		; zone: paramtre 1OZONAN:	.BLKB	2		; zone: angle de rotationOZONNS:	.BLKB	2		; zone: nb d'objets slectionnsOZONDF:	.BLKB	2		; zone: type de dformationOZONDFB:.BLKB	2		; zone: type de dformation selon BzierOZONDR:	.BLKB	1		; zone: 1 => dessineOZONHO:	.BLKB	1		; zone: 1 => homothtieOZONHB:	.BLKB	1		; zone: 1 => homothtie bloqueOZONDE:	.BLKB	1		; zone: 1 => dformation quadrilatre impossibleOZONDB:	.BLKB	1		; zone: 1 => dformation Bzier impossible	.EVENOWUSE:	.BLKB	2		; nb d'utilisation swdo de dessinOWNPD:	.BLKB	2		; SP dans OWTPDOWTPD:	.BLKB	10*(4+4)	; stack des positions/dimensionsOWCOPY:	.BLKB	4*5		; copie de la dfinition d'une fentreOSCALE:	.BLKB	2		; chelle (+/- 1..n)OSCA100:.BLKB	2		; chelle pour 100%OSCAP1Y:.BLKB	2		; chelle 1 pour imprimerOSCAP1X:.BLKB	2		; chelle 1 pour imprimerOSCAP2Y:.BLKB	2		; chelle 2 pour imprimerOSCAP2X:.BLKB	2		; chelle 2 pour imprimerOUNIT:	.BLKB	2		; unit par dfautODEF:	.BLKB	2		; dfinitions gnralesOCALQUE:.BLKB	4		; calques visiblesOCALACT:.BLKB	2		; calque actif (0..7)OPAS:	.BLKB	2		; pas (0..n)OGRID:	.BLKB	4		; mode de la grilleOVUE:	.BLKB	4		; mode de la vueOPRINT:	.BLKB	4		; mode d'impressionOFDICO:	.BLKB	4		; fanions du dicoOPRSC1:	.BLKB	2		; impression: chelle 1OPRSC2:	.BLKB	2		; impression: chelle 2OIFPRI:	.BLKB	1		; 1 => impression en coursOIFPPS:	.BLKB	1		; 1 => impression PostScriptOIFFRAG:.BLKB	1		; 1 => fragmentation en cours	.EVENOFRAFA:	.BLKB	4		; fragment: fanionsOFRACH:	.BLKB	4		; fragment: canal de la listeOFRAPD:	.BLKB	ldgbm		; fragment: ^descripteur gencar bitmapOASVER:	.BLKB	LSCVAR		; variables de l'ascenseur verticalOASHOR:	.BLKB	LSCVAR		; variables de l'ascenseur horizontalOASNBI:	.BLKB	2		; nb d'inversionsOBMBB1:	.BLKB	4		; bitmap: p1 bboxOBMBB2:	.BLKB	4		; bitmap: p2 bboxOBMABS:	.BLKB	4		; bitmap: sauvetage de ODFABSOBMY:	.BLKB	4		; bitmap: sauvetage de ODFY,XOBMDY:	.BLKB	4		; bitmap: sauvetage de ODFDY,XOBMFY:	.BLKB	4		; bitmap: sauvetage de ODFFY,XOBMFDY:	.BLKB	4		; bitmap: sauvetage de ODFFDY,XOBMIIY:	.BLKB	2		; bitmap: sauvetage de ODFIIYOMAPTP:	.BLKB	4		; traitill tournant: temps processeurOMAPTT:	.BLKB	1		; traitill tournant: mapOMAPNB:	.BLKB	1		; traitill tournant: nb de shift	.EVENOBZMOD:	.BLKB	2		; Bzier: mode de dessinOBZDPM:	.BLKB	4		; Bzier dtecte: position de la sourisOBZDMA:	.BLKB	2		; Bzier dtecte: margeOBZDNB:	.BLKB	2		; Bzier dtecte: nb d'intersectionsOBZBB1:	.BLKB	4		; Bzier bbox: p1OBZBB2:	.BLKB	4		; Bzier bbox: p2OSTP:	.BLKB	LSTP		; variables pour stretch selon quadrilatreOSBP:	.BLKB	LSBP		; variables pour stretch selon BzierOPOIPFE:.BLKB	MAXPOIGNEE*4	; poignes: ^buffers pour les fondsOPOIPCU:.BLKB	4		; poignes: ^objet copie pour UNDOOPOIPCI:.BLKB	2		; poignes: identificateur pour UNDOOPOIPOB:.BLKB	4		; poignes: ^objet slectionnOPOINBM:.BLKB	2		; poignes: nb de modificationsOPOIMCC:.BLKB	4		; poignes: marque (centre du cercle)OPOIMRC:.BLKB	2		; poignes: marque (rayon du cercle)OPOILB1:.BLKB	4		; poignes: ancien P1 bboxOPOISDD:.BLKB	4		; poignes: somme des dplacementsOSELPS:	.BLKB	4		; slection: ^dernier objetOSELSS:	.BLKB	1		; slection: touches super-shift	.EVENOMPAMI:	.BLKB	LMM*6		; mmenu: paramtre milieuOMPAZO:	.BLKB	LMM*5		; mmenu: paramtre zoneOMPASC:	.BLKB	LMM*1		; mmenu: paramtre chelleOMPACA:	.BLKB	LMM*1		; mmenu: paramtre calqueOMBUMO:	.BLKB	10*2		; mmenu: buffer pour modificationsOBUNAME:.BLKB	LBUFILE		; nom du dessin en mmoireOBUFIN:	.BLKB	LBUFILE		; nom du fichier en entre (prend)OBUFOUT:.BLKB	LBUFILE		; nom du fichier en sortie (sauve)OBUFADD:.BLKB	LBUFILE		; nom du fichier en entre (ajoute)OBXFILE:.BLKB	LBUFILE		; nom du fichier avec extensionOBUPRES:.BLKB	16		; nom de la prsentationOFAEXT:	.BLKB	4		; fanions pour extractionOFADIM:	.BLKB	4		; fanions pour dimensions imageODBIMY:	.BLKB	2		; dbox image: hauteurODBIMX:	.BLKB	2		; dbox image: largeurOMAJ:	.BLKB	1		; 1 => mise  jour ncessaire	.EVENODBLIN:	.BLKB	50		; dbox: ligne en ditionODBPTE:	.BLKB	4		; dbox: ^table des objets ditablesODBPTA:	.BLKB	4		; dbox: ^routine d'affichageODBSLV:	.BLKB	LSLVAR		; dbox: variables scroll-listeODBDPC:	.BLKB	4		; dbox: df-page: coin sup/gaucheODBDPF:	.BLKB	2		; dbox: df-page: facteurODBPA1:	.BLKB	2		; dbox: paramtre 1ODBPA2:	.BLKB	2		; dbox: paramtre 2ODBPA3:	.BLKB	2		; dbox: paramtre 3ODBPA4:	.BLKB	2		; dbox: paramtre 4OTADG:	.BLKB	LTADG*MAXTADG	; table des descripteurs de gencars bitmapsOUSDG:	.BLKB	4		; compteur des utilisationsOIOCH:	.BLKB	2		; canal pour entre/sortieOIOBH:	.BLKB	LHEAD		; buffer pour en-tteOIOTM:	.BLKB	LTMIO		; buffer tamponOIOPT:	.BLKB	2		; ^relatif dans OTMIOOIONB:	.BLKB	2		; reste dans OTMIOOVPSTA:	.BLKB	LGPRI1		; print: status de l'imprimanteLGVAR:; Programme; ---------	.PC	PCCODE	.LOC	0	JUMP	START; Noms des modules; ----------------NMDBOX:		.ASCIZ	"DBOX"NMLIST:		.ASCIZ	"LIST"NMSCROLL:	.ASCIZ	"SCROLL"NMSTRETCH:	.ASCIZ	"STRETCH"NMGMI:		.ASCIZ	"GRAMISC"NMGRA:		.ASCIZ	"GRA2"NMPRINTA:	.ASCIZ	"PRINTA"NMDICO:		.ASCIZ	"DICO"NMPAGE:		.ASCIZ	"(,#):page.page" ; fichier par dfaut; Erreurs fatales; ---------------TXERFATREV:	.ASCIZ	"Rvision du systme incompatible"TXERFATDIS:	.ASCIZ	"Driver d'cran incompatible"TXERFATTXT:	.ASCIZ	"Erreur avec NEF11"TXERFATICO:	.ASCIZ	"Erreur avec IPP21"TXERFATGRA:	.ASCIZ	"Erreur avec GRA"TXERFATGRA2:	.ASCIZ	"Erreur avec GRA2"TXERFATGMI:	.ASCIZ	"Erreur avec GRAMISC"TXERFATLIB:	.ASCIZ	"Erreur avec LIB_ADD"TXERFATLST:	.ASCIZ	"Erreur avec les listes"	.EVENSTART:	LIB	?OPELIB	LOAD.W	D3,#2	LIB	?MOUSE	CALL	_WAITMOUSE	; met le sablier	LOAD.L	D4,#LGVAR	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour variables	JUMP,NE ERFAT1	GESMEM	?CLEARMEM	LOAD.L	A6,A4		; A6 <-- ^variables	LOAD.L	(A6)+OPLCOM,A3	; mm ^ligne de commande	LOAD.L	A3,#R16"TXERFATREV	LOAD.W	D4,#H'AAAA	LIB	?GETREV		; D4 <-- rvision du systme	COMP.W	D4,#H'AAAA	; vielle librairie ?	JUMP,EQ ERFAT2		; oui => ERFAT2	COMP.W	D4,#H'100*6+7	; est-ce au moins 6.7 (systme romable de 1989) ?	JUMP,LO ERFAT2		; non => ERFAT2	LIB	?GETPDIS	LOAD.L	(A6)+OPDDIS,A4	LOAD.L	A0,A4		; A0 <-- ^descripteur de la fentre <<PREMANANT>>	LIB	?AFTIM	.B	NOCURS		; pas de curseur	.B	NOEFLI		; pas de EFLI automatique	.B	TRUNC		; tronque les lignes trop longues	.B	MODGRA,GRACLIP	; graphique avec clipping	.B	MMODULO,1	; n'impose plus les modulos	.B	0	.EVEN	LOAD.L	A3,#R16"TXERFATICO	LIB	?AFTIM	.B	LOADGC,GCICF,GCICS,GCICT	.B	0	.EVEN	JUMP,NE ERFAT2	LIB	?AFTIM	.B	USEGC,GCICF,GCICS,GCICT	.B	0	.EVEN	LOAD.L	(A6)+OPGICO,(A0)+ODFPGC	LOAD.L	A3,#R16"TXERFATTXT	LIB	?AFTIM	.B	LOADGC,GCTXF,GCTXS,GCTXT	.B	0	.EVEN	JUMP,NE ERFAT2	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.EVEN	LOAD.L	A3,#R16"NMDBOX	LOAD.W	D3,#DBOX_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHDBOX,D1	LOAD.L	A3,#R16"NMLIST	LOAD.W	D3,#LIST_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHLIST,D1	LOAD.L	A3,#R16"NMSCROLL	LOAD.W	D3,#SCROLL_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHSCROLL,D1	LOAD.L	A3,#R16"NMSTRETCH	LOAD.W	D3,#ST_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHSTRETCH,D1	LOAD.L	A3,#R16"NMGMI	LOAD.W	D3,#GMI_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHGMI,D1	LOAD.L	A3,#R16"NMGRA	LOAD.W	D3,#GRA2_FIRST	LIB_	OPEN	JUMP,NE ERFAT2	LOAD.W	(A6)+OCHGRA,D1	LOAD.L	A3,#R16"NMDICO	LOAD.W	D3,#DICO_FIRST	LIB_	OPEN	JUMP',NE NODICO$	LOAD.W	(A6)+OCHDICO,D1NODICO$:	LOAD.L	A3,#R16"NMPRINTA	LOAD.W	D3,#PRINTA_FIRST	LIB_	OPEN	JUMP',NE NOPRINT$	LOAD.W	(A6)+OCHPRINTA,D1	LOAD.L	D3,#2^BPRLOCAL	PRINTA_	OPEN	JUMP,NE ERFAT2	LOAD.L	(A6)+OCAPRINT,A2NOPRINT$:	LOAD.L	A1,#R16"TXERFATGRA	LOAD.W	D3,#GRA_RASTER	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+ORASTER,A3	LOAD.L	A1,#R16"TXERFATGRA2	LOAD.W	D3,#GRA2_LINE	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OLINE,A3	LOAD.W	D3,#GRA2_TRAME	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OTRAME,A3	LOAD.W	D3,#GRA2_CIRCLE	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OCIRC,A3	LOAD.W	D3,#XCAR_BMMATRIX	LIB_	GETAD	JUMP,NE ERFAT3	LOAD.L	(A6)+OBMMAT,A3	LOAD.L	A3,#R16"TXERFATGMI	SUB.L	SP,#2	PUSH.L	#(A6)+ORGNID	GMI_	NEWRGN	POP.W	D7	JUMP,NE ERFAT2	LOAD.L	A3,#R16"TXERFATLIB	LOAD.L	A4,#R16"BMPAGE	LIB_	ADD	JUMP,NE ERFAT2	LOAD.W	(A6)+ODESYD,#2970*FACMMPT ; hauteur A4 = 297.0mm	LOAD.W	(A6)+ODESXD,#2100*FACMMPT ; largeur A4 = 210.0mm	LOAD.W	(A6)+ODESMG,#200*FACMMPT ; marge gauche = 20.0mm	LOAD.W	(A6)+ODESMD,#200*FACMMPT ; marge droite = 20.0mm	LOAD.W	(A6)+ODESMS,#200*FACMMPT ; marge suprieure = 20.0mm	LOAD.W	(A6)+ODESMI,#200*FACMMPT ; marge infrieure = 20.0mm	LOAD.W	(A6)+OCOLNB,#1	LOAD.W	(A6)+OCOLES,#100*FACMMPT ; gouttire = 10.0mm	LOAD.L	(A6)+OCOLFA,#2^BCOLMAGN	CALL	_DBCOPX		; OCOLPX <-- position X des colonnes	LOAD.W	(A6)+OHVVAL,#45	LOAD.L	(A6)+OHVFAN,#2^BHV090!2^BHVCURSOR!2^BHVSHOW	LOAD.W	(A6)+ODETM,#10	LOAD.L	(A6)+OPRETI,#-1	LOAD.W	(A6)+OOUTILL,#ICOOCRAYON	LOAD.W	(A6)+OOUTILR,#ICOOCRAYON	LOAD.W	(A6)+OOBJET,#ICOOBJET+0	LOAD.W	(A6)+OZONIV,#NICOZOOM	LOAD.W	(A6)+OZONDF,#ICODQQ	LOAD.W	(A6)+OZONDFB,#ICOBQQ	LOAD.W	(A6)+OSCA100,#-18 ; OSCA100 <-- chelle pour petit cran (100 ou 324)	COMP.W	(A0)+ODFDX,#640	; cran large ?	JUMP',LS SCALE$		; non => SCALE$	LOAD.W	(A6)+OSCA100,#-14 ; OSCA100 <-- chelle pour grand cran (324)SCALE$:	LOAD.W	(A6)+OSCALE,(A6)+OSCA100	LOAD.W	(A6)+OUNIT,#UNITMM	LOAD.L	(A6)+OCALQUE,#H'FFFF!2^BCALCA7	LOAD.W	(A6)+OCALACT,#7	LOAD.W	(A6)+OPAS,#10*FACMMPT ; 1.0mm	LOAD.L	(A6)+OGRID,#2^BGRIDPAN!2^BGRIDMU5!2^BGRIDGRN	LOAD.L	(A6)+OVUE,#2^BVUEPEN!2^BVUETRAME!2^BVUECHAR!2^BVUEREPMARG!2^BVUEREPCOL	LOAD.L	(A6)+OPRINT,#H'FFFF!2^BPRIGX1	LOAD.L	(A6)+OFADIM,#H'FFFF!2^BPRIGX1	LOAD.W	(A6)+OPRSC1,#-1	LOAD.W	(A6)+OPRSC2,#-1	LOAD.L	(A6)+OFRAFA,#B'01	LOAD.L	A3,#R16"TXERFATLST	CLR.L	D3		; D3 <-- mode	CLR.W	D4		; D4 <-- lg par dfaut	CALL	_LST_OPEN	; D6 <-- canal liste des racines	JUMP,NE ERFAT2	LOAD.L	(A6)+ORALCH,D6	CLR.L	D3		; D3 <-- mode	CLR.W	D4		; D4 <-- lg par dfaut	CALL	_LST_OPEN	; D6 <-- canal liste des data	JUMP,NE ERFAT2	LOAD.L	(A6)+ODALCH,D6	CALL	_LSTA_OPEN	; D6 <-- canal arbre des dfinitions	JUMP,NE ERFAT2	LOAD.L	(A6)+ODFACH,D6	LOAD.L	A4,#(A6)+OOBACH	LOAD.W	D2,#MAXCALQUE-1CALQUE$:	CALL	_LSTA_OPEN	; D6 <-- canal arbre des objets	JUMP,NE ERFAT2	LOAD.L	(A4+),D6	DECJ.W,NMO D2,CALQUE$	CALL	_CCMO		; enlve la souris	CALL	_CALCADRE	; calcul pos/dim de la fentre de dessin	CALL	_DESWDO	CALL	_DESCADRE	CALL	_AFMENU		; affiche les soft-keys	LIB	?BUZZ		; signal: c'est prt !	LOAD.L	A3,(A6)+OPLCOM	; A3 <-- ^ligne de commande	LIB	?SWITCH		; D3 <-- bits switch aprs PAGE	LOAD.L	(A6)+OSWCOM,D3	LOAD.L	A2,#R16"NMPAGE	; A2 <-- ^nom "PAGE.PAGE" par dfautPLOOP$:	LIB	?SKPNAM		; A3 <-- ^nom suivant	JUMP',NE PEND$	LIB	?SWITCH		; D3 <-- bits switch aprs nom	TEST.L	D3		; y a-t-il des switchs ?	JUMP',NE PSWI$		; oui => PSWI$	LOAD.L	A2,A3		; A2 <-- ^nom .PAGE  lire	JUMP	PLOOP$PSWI$:	TEST.L	D3:#('X-'A)	; nom /X ?	JUMP,BC PLOOP$	LOAD.L	A4,A3	CALL	_GETANUM	; D4 <-- adresse	LOAD.L	(A6)+OPLMES,D4	JUMP	PLOOP$PEND$:	LOAD.L	A3,#(A6)+OBUFINPNAME$:	LOAD.B	D3,(A2+)	JUMP',EQ PGO$	COMP.B	D3,#CR	JUMP',EQ PGO$	COMP.B	D3,#SPACE	JUMP',EQ PGO$	COMP.B	D3,#TAB	JUMP',EQ PGO$	COMP.B	D3,#'/	JUMP',EQ PGO$	LOAD.B	(A3+),D3	; OBUFIN <-- nom ligne de commande	JUMP	PNAME$PGO$:	CLR.B	(A3)	LOAD.L	A3,#(A6)+OBUFIN	; A3 <-- ^nom	JUMP	_DOPRENDF	; essaye de prendre ce fichier ...LOOP:	CALL	_SCMO		; remet la souris	CALL	_NORMMOUSE	; enlve le sablierMOUSE$:	TEST.B	(A6)+ODEF+1:#BDEFRET-0	JUMP',BC MOUSE2$	LOAD.W	D3,#ICORETICULE	; D3 <-- force le rticule	JUMP'	MOUSE4$MOUSE2$:	LOAD.W	D3,(A6)+OOUTILL	COMP.W	D3,(A6)+OOUTILR	JUMP',EQ MOUSE4$	CLR.W	D3MOUSE4$:	CALL	_SELMO		; utilise le bon lutin	CALL	_DESINFXY	; affiche X= et Y= dans les informationsWAIT$:	TEST.L	(A6)+OPLMES	; y a-t-il une BAL ?	JUMP',NE MESS$		; oui => MESS$	LIB	?GETKEY		; attend clavier/souris ...	JUMP'	KEY$MESS$:	CALL	MESSWAITKEY	; attend clavier/souris ...	JUMP',EQ KEY$	CALL	MESSWAITBAL	; attend message BAL ...	JUMP,NE MESS$	CALL	MESSSNDBAL	; envoie le message aux objets	JUMP	MESS$KEY$:	TEST.L	D3:#BKPSEUDO	; touche presse normale ?	JUMP,BS WAIT$		; non => WAIT$				; oui =>	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP,EQ MOUSE$		; oui => MOUSE$EXECUTE:	COMP.B	D3,#F0+SHIFT	JUMP',LO SHIFT$	COMP.B	D3,#F15+SHIFT	JUMP',HI SHIFT$	SUB.B	D3,#SHIFT	; (SHIFT-Fn) --> (Fn)SHIFT$:	LOAD.W	D2,D3	LIB	?MINMAJ	EX.L	D2,D3	COMP.W	D3,#KEYMGR	JUMP,EQ LOOP	COMP.W	D3,#KEYMMR	JUMP,EQ LOOP	COMP.W	D3,#KEYMDR	JUMP,EQ LOOP	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC	COMP.W	D3,#KEYMMP	JUMP,EQ CLIC	COMP.W	D3,#KEYMDP	JUMP,EQ CLIC	COMP.W	D3,#F0	JUMP,EQ DOFINI	COMP.W	D3,#END	JUMP,EQ DOFINI	COMP.W	D3,#F1	JUMP,EQ _DOPREND	COMP.W	D3,#H'100*(2^BSHOW)+DEFINE	JUMP,EQ _DOPREND	COMP.W	D3,#F2	JUMP,EQ _DOAJOUTE	COMP.W	D3,#F3	JUMP,EQ _DOSAUVE	COMP.W	D3,#H'100*(2^BCOPY)+DEFINE	JUMP,EQ _DOSAUVE	COMP.W	D3,#F4	JUMP,EQ DODEFPAGE	COMP.W	D3,#F5	JUMP,EQ DODEFUNIT	COMP.W	D3,#F6	JUMP,EQ DODEFMOUS	COMP.W	D3,#F7	JUMP,EQ DOSCALEM	COMP.W	D3,#F8	JUMP,EQ DOSCALE1	COMP.W	D3,#F9	JUMP,EQ DOSCALEP	COMP.W	D3,#F13	JUMP,EQ DOTOUT	COMP.W	D3,#F14	JUMP,EQ _DOEFFACE	COMP.W	D3,#F15	JUMP,EQ _DOIMPRIME	COMP.W	D2,#H'100*(2^BPROGRA)+'R	JUMP,EQ DOREFAIT	COMP.W	D2,#H'100*(2^BPROGRA!2^BSHOW!2^BSEARCH!2^BCHANGE)+'D	JUMP,EQ DODEBUG	COMP.W	D2,#H'100*(2^BPROGRA!2^BSHOW!2^BSEARCH!2^BCHANGE)+'G	JUMP,EQ DOTADG	JUMP	BIPBIP:				; erreur =>	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOPBIGBIP:				; erreur =>	LOAD.B	D3,#BIPERR	LIB	?BEEP		; grand bruit	JUMP	LOOPERROR:	COMP.W	D7,#ERPBIP	JUMP,EQ BIP	CALL	_DBOXERROR	; affiche l'erreur ...	JUMP	LOOPDODEFPAGE:	CALL	DBOXDEFPAGE	; demande les dfinitions	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	SET.B	(A6)+OMAJ	; mise  jour sur disque ncessaire	CLR.L	(A6)+ODESY1	; revient en haut  gauche !	CALL	_MAJCADRE	; mj cadre (ascenseurs et rgles)	JUMP	DOREFAITDODEFUNIT:	CALL	DBOXDEFUNIT	; demande les dfinitions	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	SET.B	(A6)+OMAJ	; mise  jour sur disque ncessaire	CALL	_DESINFPAS	; affiche le pas	JUMP	LOOPDODEFMOUS:	CALL	DBOXDEFMOUS	; demande les dfinitions	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	SET.B	(A6)+OMAJ	; mise  jour sur disque ncessaire	TEST.B	(A6)+ODEF+1:#BDEFOGD-0	JUMP',BS UPDATE$	LOAD.W	(A6)+OOUTILR,(A6)+OOUTILLUPDATE$:	CALL	_UPDICONE	; met  jour les icnes	JUMP	LOOPDODEFOBJ:	CALL	DBOXDEFOBJ	; choix des objets ...	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP	CALL	_OBJCONNECT	; connecte les modules-objets demands	CALL	_CCMO		; enlve la souris	CALL	_LIBICONE	; libre les icnes mmorises	CALL	_DESICONE	; dessine toutes les icnes	CALL	_MEMICONE	; mmorise les icnes de gauche	CALL	_MAJICONE	; met  jour les icnes variables	JUMP	DOREFAITDOSCALE1:	CLR.W	D3		; D3 <-- 1:1	JUMP'	DOSCALEXDOSCALEP:	LOAD.W	D3,#+1		; D3 <-- suivante	JUMP'	DOSCALEXDOSCALEM:	LOAD.W	D3,#-1		; D3 <-- prcdente;	JUMP'	DOSCALEXDOSCALEX:	LOAD.W	D4,(A6)+ODESY2	SUB.W	D4,(A6)+ODESY1	SR.W	D4,#1	ADD.W	D4,(A6)+ODESY1	SWAP.W	D4	LOAD.W	D4,(A6)+ODESX2	SUB.W	D4,(A6)+ODESX1	SR.W	D4,#1	ADD.W	D4,(A6)+ODESX1	; D4 <-- au milieu de l'cran	JUMP	LOUPESDOTOUT:	CLR.L	D4	LOAD.W	D4,(A6)+ODESXD	LOAD.W	D3,(A6)+OWDIX2	SUB.W	D3,(A6)+OWDIX1	DIV.WU	D4,D3	INC.W	D4	NEG.W	D4	CALL	_PROXSCALE	; D4 <-- chelle souhaite en X	LOAD.W	D5,D4	CLR.L	D4	LOAD.W	D4,(A6)+ODESYD	LOAD.W	D3,(A6)+OWDIY2	SUB.W	D3,(A6)+OWDIY1	DIV.WU	D4,D3	INC.W	D4	NEG.W	D4	CALL	_PROXSCALE	; D4 <-- chelle souhaite en Y	COMP.W	D4,D5	JUMP',LE FOUND$	LOAD.W	D4,D5		; D4 <-- chelle la plus petiteFOUND$:	CLR.L	D5	JUMP	LOUPEQDOREFAITBBOX:	PUSH.W	(A6)+OCALACT	CLR.W	D2CALQUE$:	LOAD.W	(A6)+OCALACT,D2	CALL	UPDATEBBOX	; recalcule toutes les "bbox" du calque	INC.W	D2	COMP.W	D2,#MAXCALQUE	JUMP,LO CALQUE$	POP.W	(A6)+OCALACTDOREFAIT:	CALL	DESOBJETS	; redessine tous les objets	JUMP	LOOPDODEBUG:	LIB	?AFTIM	.B	EOP,AUTOCR	.ASCII	"iden bbox1    bbox2    fl data...<CR>"	.ASCII	"-----------------------------------------------<CR>"	.B	0	.EVEN	LOAD.W	D3,#1	LIB	?DISWKEY	CALL	GETACH		; D6 <-- canal de l'arbre des objets	CALL	_LSTA_FIRST	; A4 <-- ^premier objet	JUMP',NE END$LOOP$:	LOAD.W	D4,(A4)+OobjIDENT	LIB	?AFX4	LIB	?AFSPACE	LOAD.L	D4,(A4)+OobjBBOX1	LIB	?AFX8	LIB	?AFSPACE	LOAD.L	D4,(A4)+OobjBBOX2	LIB	?AFX8	LIB	?AFSPACE	LOAD.B	D4,(A4)+OobjFLAGS	LIB	?AFX2	LIB	?AFSPACE	LOAD.L	A3,(A4)+OobjPDATA ; A3 <-- ^data de l'objet source	LOAD.W	D0,(A4)+OobjIDENT	LOAD.W	D1,#opCRCOPYLG	CALL	_OBJCALL	; D4 <-- lg ncessaire	JUMP',NE CR$	LOAD.W	D3,D4	JUMP',EQ CR$	LOAD.W	D2,#4DATA$:	LOAD.B	D4,(A3+)	LIB	?AFX2	DEC.W	D2	JUMP',NE SP$	LIB	?AFSPACE	LOAD.W	D2,#4SP$:	DEC.W	D3	JUMP,NE	DATA$CR$:	LIB	?AFCRNEXT$:	CALL	_LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$END$:	CLR.W	D3	LIB	?DISWKEY	LIB	?GETCAR		; attend une touche ...	LOAD.B	D3,#TRUNC	LIB	?AFCAR	CALL	_CCMO		; enlve la souris	CALL	_DESWDO	CALL	_DESCADRE	JUMP	DOREFAITDOTADG:	LIB	?AFTIM	.B	SAVWDO	.B	EOP	.B	CR,CR	.B	TAB,TAB	.ASCII	"CorpRotation Zy  Zx  Sy  Sx"	.B	CR,CR	.B	0	.EVEN	LOAD.L	A2,#(A6)+OTADG	LOAD.W	D2,#MAXTADGLOOP$:	LOAD.L	A3,A2	LOAD.W	D1,#16ASCII$:	LOAD.B	D3,(A3+)	LIB	?AFCODE	DEC.W	D1	JUMP,NE ASCII$	LOAD.L	A3,#(A2)+32	LOAD.W	D1,#LDGBM-32HEXA$:	LOAD.B	D4,(A3+)	LIB	?AFX2	DEC.W	D1	JUMP,NE HEXA$	LIB	?AFSPACE	LOAD.L	D4,(A2)+OTADGPT	LIB	?AFX8	LIB	?AFSPACE	LOAD.L	D4,(A2)+OTADGUS	LIB	?AFX8	LIB	?AFCR	ADD.L	A2,#LTADG	DEC.W	D2	JUMP,NE LOOP$	LIB	?GETCAR	LIB	?AFTIM	.B	GETWDO	.B	0	.EVEN	JUMP	LOOPDOFINI:	CLR.W	D0		; D0 <-- avant de quitter	CALL	DBOXSAVE	; sauve si ncessaire la page	JUMP',EQ 20$		; ok => 20$	COMP.W	D7,#1		; (ANNULE) ?	JUMP,EQ LOOP		; oui => LOOP	JUMP	ERROR		; non => ERROR20$:	LOAD.L	D6,(A6)+OCIDICO	JUMP',EQ 40$	DICO_	IFMAJ		; mises  jour ncessaires ?	JUMP',EQ 40$		; non => 40$	CALL	_DBOXOPEN1	DICO_	MAJ		; effectue les mises  jour ...	CALL	_DBOXCLOSE1	TEST.W	D7	JUMP,NE ERROR	COMP.W	D3,#F1	JUMP,NE LOOP40$:	CALL	DBOXQUITTE	; demande s'il faut quitter ...	COMP.W	D3,#F1	JUMP,NE LOOPERFAT:	CALL	CHFLUSH		; libre tous les gencars en attente	CALL	_OBJDECONNECT	; dconnecte tous les modules-objets chargs	SUB.L	SP,#2	PUSH.L	(A6)+ORGNID	GMI_	DISPOSERGN	POP.W	D7	LOAD.W	D1,(A6)+OCHDBOX	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHLIST	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSCROLL	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHSTRETCH	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHGMI	LIB_	CLOSE	LOAD.W	D1,(A6)+OCHGRA	LIB_	CLOSE	TEST.W	(A6)+OCHDICO	JUMP',EQ NODICO1$	LOAD.L	D6,(A6)+OCIDICO	JUMP',EQ NODICO1$	DICO_	CLOSENODICO1$:	LOAD.W	D1,(A6)+OCHDICO	JUMP',EQ NODICO2$	LIB_	CLOSENODICO2$:	TEST.L	(A6)+OCAPRINT	JUMP',EQ NOPRINT$	LOAD.L	A2,(A6)+OCAPRINT	PRINTA_	CLOSE	LOAD.W	D1,(A6)+OCHPRINTA	LIB_	CLOSENOPRINT$:	LOAD.L	A4,#R16"BMPAGE	LIB_	SUBERFAT1:	LIB	?CLOLIB	FOS	?STOPERFAT3:	LOAD.L	A3,A1		; A3 <-- ^messageERFAT2:	PUSH.W	D7	LIB	?AFTIM	.B	NOCURS,CR,CR	.ASCIZ	"ERREUR FATALE: "	.EVEN	LIB	?AFTEXT		; affiche le message	LIB	?AFCR	POP.W	D7	JUMP',EQ 50$	LIB	?AFERROR	; affiche l'erreur	LIB	?AFCR50$:	LIB	?GETCAR		; attend une touche ...	JUMP	ERFAT	.INS	PAGEMESS.ASI	.INS	PAGECLIC.ASI	.INS	PAGEZONE.ASI	.INS	PAGEFRAG.ASI	.INS	PAGEHAND.ASI	.INS	PAGEIND1.ASI	.INS	PAGEEXT.ASI	.INS	PAGEDRAW.ASI	.INS	PAGEBEZIER.ASI	.INS	PAGECHAR.ASI	.INS	PAGEDBOX.ASI	.INS	PAGEDBOXT.ASI	.INS	PAGEPRINT.ASI	.INS	PAGEIO.ASI	.INS	PAGEIND2.ASI	.INS	PAGECADRE.ASI	.INS	PAGEICONE.ASI	.INS	PAGEOBJET.ASI	.INS	PAGEGROUP.ASI	.INS	PAGELST.ASI	.INS	PAGEUNIT.ASI	.INS	PAGEMATH.ASI	.INS	PAGEMISC.ASI	.INS	PAGETABLE.ASI	.END	START