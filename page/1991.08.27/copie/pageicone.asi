	.SBTTL	PAGEICONE.ASI;---------\\; MAJICONE >;=========/;---------\\; UPDICONE >;=========/; Met  jour les icnes variables.; in	A4.L	^objet (si NIVOHAND/CREATE); out	-; mod	D7.WMAJICONE:	LOAD.W	(A6)+OICOST,#-1	; vide la table des tats des icnesUPDICONE:	PUSHM.L	D0..D4,D6,A3,A4	PUSH.L	(A6)+OAPOS	LOAD.W	D3,(A6)+OICONIV	COMP.W	D3,#NICOHAND	JUMP,EQ HAND$	COMP.W	D3,#NICOEDIT	JUMP,EQ EDIT$	COMP.W	D3,#NICOCREATE	JUMP,EQ CREATE$	COMP.W	D3,#NICOMULTI	JUMP,EQ MULTI$	COMP.W	D3,#NICOZOOM	JUMP,EQ ZOOM$	COMP.W	D3,#NICOTOURNE	JUMP,EQ TOURNE$	COMP.W	D3,#NICOMIROIR	JUMP,EQ MIROIR$	COMP.W	D3,#NICODEFORME	JUMP,EQ DEFORME$	COMP.W	D3,#NICODEFBEZ	JUMP,EQ DEFBEZ$; Allume l'icne de l'outil slectionn.	LOAD.W	D3,(A6)+OOUTILL	CALL	GSTICONE	; bon outil allum ?	COMP.W	D4,#STICOINVL	JUMP',NE BASE22$	LOAD.W	D3,(A6)+OOUTILR	CALL	GSTICONE	; bon outil allum ?	COMP.W	D4,#STICOINVR	JUMP',EQ BASE41$BASE22$:	LOAD.W	D3,(A6)+OOUTILL	COMP.W	D3,(A6)+OOUTILR	JUMP',NE BASE23$	COMP.W	D4,#STICOINVLR	JUMP',EQ BASE41$BASE23$:	LOAD.W	D4,#STICONORM	LOAD.W	D3,#ICOOCRAYON	CALL	MSTICONE	; teint l'icne	LOAD.W	D3,#ICOOZONE	CALL	MSTICONE	; teint l'icne	LOAD.W	D3,#ICOOPOIGNEE	CALL	MSTICONE	; teint l'icne	LOAD.W	D3,#ICOOEDIT	CALL	MSTICONE	; teint l'icne	LOAD.W	D3,#ICOOLOUPE	CALL	MSTICONE	; teint l'icne	LOAD.W	D3,#ICOOMAIN	CALL	MSTICONE	; teint l'icne	LOAD.W	D3,(A6)+OOUTILL	COMP.W	D3,(A6)+OOUTILR	JUMP',EQ BASE25$	LOAD.W	D4,#STICOINVL	CALL	MSTICONE	; allume l'icne gauche	LOAD.W	D3,(A6)+OOUTILR	LOAD.W	D4,#STICOINVR	CALL	MSTICONE	; allume l'icne droite	JUMP'	BASE41$BASE25$:	LOAD.W	D4,#STICOINVLR	CALL	MSTICONE	; allume l'icne gauche+droite;	JUMP'	BASE41$; Grise tous les objets inutiliss.BASE41$:	LOAD.W	D3,#ICOOBJET	LOAD.W	D2,#NBIOBJET-1BASE42$:	LOAD.W	D4,#STICOGREY	LOAD.W	D0,D3		; D0 <-- icne	SUB.W	D0,#ICOOBJET	; D0 <-- rang	CALL	OBJGETID	; D0 <-- identificateur	JUMP',NE BASE44$	LOAD.W	D4,#STICONORM	COMP.W	D3,(A6)+OOBJET	JUMP',NE BASE44$	LOAD.W	D4,#STICOINVBASE44$:	CALL	MSTICONE	; grise/dgrise/inverse un objet	INC.W	D3	DECJ.W,NMO D2,BASE42$; Grise tous les tats inutiliss.	LOAD.W	D0,(A6)+OOBJET	; D0 <-- icne	SUB.W	D0,#ICOOBJET	; D0 <-- rang	CALL	OBJGETID	; D0 <-- identificateur	JUMP',NE BASE58$	LOAD.L	A4,#R16"NOST$	; A4 <-- ^aucun tat	LOAD.W	D1,#opIDENTSTATE ; D1 <-- mthode	CALL	OBJCALL		; A4 <-- ^identificateurs des tats	LOAD.W	D3,#ICOSTATE	LOAD.W	D2,#NBISTATE-1BASE52$:	CALL	GSTICONE	; identificateur d'tat dj dessine ?	JUMP',EQ BASE53$	; oui => BASE53$	CALL	DESICONEONE	; dessine une icne d'tatBASE53$:	LOAD.W	D4,#STICOGREY	COMP.W	(A4),#-1	JUMP',EQ BASE54$	TEST.W	(A4+)	JUMP',EQ BASE54$	LOAD.W	D4,#STICONORMBASE54$:	CALL	MSTICONE	; grise/dgrise un tat	INC.W	D3	DECJ.W,NMO D2,BASE52$BASE58$:	JUMP	EXIT$; Met  jour toutes les icnes, selon la mthode "opHANDICOGET" de; l'objet captur avec les poignes.HAND$:	CALL	PTGICONE	; A3 <-- ^icnes de gaucheHAND2$:	LOAD.W	D3,(A3+)	COMP.W	D3,#OPIF	; fin de la table ?	JUMP',EQ HAND3$		; oui => HAND3$	COMP.W	D3,#OPIL	JUMP,EQ HAND2$	COMP.W	D3,#OPIC	JUMP,EQ HAND2$	LOAD.W	D3,(A3+)	; D3 <-- icne	ADD.L	A3,#2	LOAD.W	D1,#opHANDICOGET	CALL	OBJCALLD	; D4 <-- tat de l'icne	JUMP,NE HAND2$	CALL	MSTICONE	; modifie l'tat de l'icne	JUMP	HAND2$HAND3$:	LOAD.W	D4,#STICONORM	CALL	__HANDPOSOK	; position correcte ?	JUMP',EQ HAND4$		; oui => HAND4$;	LOAD.W	D4,#STICONORM	LOAD.W	D3,#ICOANNULE	CALL	MSTICONE	; dgrise l'icne annule	LOAD.W	D4,#STICOGREYHAND4$:	LOAD.W	D3,#ICOOEDIT	CALL	MSTICONE	; modifie l'icne dite	LOAD.W	D3,#ICOSEPARE	CALL	MSTICONE	; modifie l'icne spare	LOAD.W	D3,#ICODACCORD	CALL	MSTICONE	; modifie l'icne d'accordHAND5$:	LOAD.L	A3,A4		; A3 <-- ^objet	CALL	LSTA_YOUNG	; A4 <-- ^objet frre benjamin	LOAD.W	D4,#STICONORM	COMP.L	A3,A4	JUMP',NE HAND52$	LOAD.W	D4,#STICOINVHAND52$:	LOAD.W	D3,#ICODERRIERE	CALL	MSTICONE	; allume l'icne "derrire"	LOAD.L	A4,A3		; A4 <-- ^objet	CALL	LSTA_OLD	; A4 <-- ^objet frre an	LOAD.W	D4,#STICONORM	COMP.L	A3,A4	JUMP',NE HAND53$	LOAD.W	D4,#STICOINVHAND53$:	LOAD.W	D3,#ICODEVANT	CALL	MSTICONE	; allume l'icne "devant"	JUMP	EXIT$; Met  jour toutes les icnes, selon la mthode "opEDITICOGET" de; l'objet captur pour l'diter.EDIT$:	CALL	PTGICONE	; A3 <-- ^icnes de gaucheEDIT2$:	LOAD.W	D3,(A3+)	COMP.W	D3,#OPIF	; fin de la table ?	JUMP,EQ HAND5$		; oui => HAND5$	COMP.W	D3,#OPIL	JUMP,EQ EDIT2$	COMP.W	D3,#OPIC	JUMP,EQ EDIT2$	LOAD.W	D3,(A3+)	; D3 <-- icne	ADD.L	A3,#2	LOAD.W	D1,#opEDITICOGET	CALL	OBJCALLD	; D4 <-- tat de l'icne	JUMP,NE EDIT2$	CALL	MSTICONE	; modifie l'tat de l'icne	JUMP	EDIT2$; Met  jour toutes les icnes, selon la mthode "opCRICOGET" de; l'objet en cours de cration.CREATE$:	CALL	PTGICONE	; A3 <-- ^icnes de gaucheCREATE2$:	LOAD.W	D3,(A3+)	COMP.W	D3,#OPIF	; fin de la table ?	JUMP,EQ EXIT$		; oui => EXIT$	COMP.W	D3,#OPIL	JUMP,EQ CREATE2$	COMP.W	D3,#OPIC	JUMP,EQ CREATE2$	LOAD.W	D3,(A3+)	; D3 <-- icne	ADD.L	A3,#2	LOAD.W	D1,#opCRICOGET	CALL	OBJCALLD	; D4 <-- tat de l'icne	JUMP,NE CREATE2$	CALL	MSTICONE	; modifie l'tat de l'icne	JUMP	CREATE2$; Met  jour les icnes pendant une slection multiple.MULTI$:	LOAD.W	D3,#ICOOZONE	LOAD.W	D4,#STICONORM	CALL	MSTICONE	; teint l'icne	LOAD.W	D3,#ICOOPOIGNEE;	LOAD.W	D4,#STICONORM	CALL	MSTICONE	; teint l'icne	LOAD.W	D3,(A6)+OOUTILM	LOAD.W	D4,#STICOINVLR	CALL	MSTICONE	; allume l'icne de l'outil	JUMP	EXIT$; Met  jour les icnes pendant un zoom.ZOOM$:	LOAD.W	D4,#STICONORM	TEST.B	(A6)+OZONHO	JUMP',EQ ZOOM2$	LOAD.W	D4,#STICOINVZOOM2$:	LOAD.W	D3,#ICOZHOMOT	CALL	MSTICONE	; allume/teint l'icne	JUMP	OPER$; Met  jour les icnes pendant une rotation.TOURNE$:	LOAD.W	D4,#STICOGREY	LOAD.W	D3,#ICOANNULE	CALL	MSTICONE	; grise l'icne annule	JUMP	OPER$; Met  jour les icnes pendant un miroir.MIROIR$:	JUMP	OPER$; Met  jour les icnes pendant une dformation.DEFORME$:	LOAD.W	D2,(A6)+OZONDF	; D2 <-- type de dformation	LOAD.W	D4,#STICONORM	LOAD.W	D3,#ICODQQ	COMP.W	D3,D2	JUMP',NE DEFQQ$	LOAD.W	D4,#STICOINVDEFQQ$:	CALL	MSTICONE	LOAD.W	D4,#STICONORM	LOAD.W	D3,#ICODTRAH	COMP.W	D3,D2	JUMP',NE DEFTRAH$	LOAD.W	D4,#STICOINVDEFTRAH$:	CALL	MSTICONE	LOAD.W	D4,#STICONORM	LOAD.W	D3,#ICODTRAV	COMP.W	D3,D2	JUMP',NE DEFTRAV$	LOAD.W	D4,#STICOINVDEFTRAV$:	CALL	MSTICONE	LOAD.W	D4,#STICONORM	LOAD.W	D3,#ICODPARH	COMP.W	D3,D2	JUMP',NE DEFPARH$	LOAD.W	D4,#STICOINVDEFPARH$:	CALL	MSTICONE	LOAD.W	D4,#STICONORM	LOAD.W	D3,#ICODPARV	COMP.W	D3,D2	JUMP',NE DEFPARV$	LOAD.W	D4,#STICOINVDEFPARV$:	CALL	MSTICONE	JUMP	OPER$; Met  jour les icnes pendant une dformation.DEFBEZ$:	LOAD.W	D2,(A6)+OZONDFB	; D2 <-- type de dformation	LOAD.W	D4,#STICONORM	LOAD.W	D3,#ICOBQQ	COMP.W	D3,D2	JUMP',NE DBZQQ$	LOAD.W	D4,#STICOINVDBZQQ$:	CALL	MSTICONE	LOAD.W	D4,#STICONORM	LOAD.W	D3,#ICOBHORIZ	COMP.W	D3,D2	JUMP',NE DBZHOR$	LOAD.W	D4,#STICOINVDBZHOR$:	CALL	MSTICONE	LOAD.W	D4,#STICONORM	LOAD.W	D3,#ICOBVERTI	COMP.W	D3,D2	JUMP',NE DBZVER$	LOAD.W	D4,#STICOINVDBZVER$:	CALL	MSTICONE;	JUMP'	OPER$; Met  jour les icnes pendant une opration zoom, tourne, miroir ou dformation.OPER$:	LOAD.W	D4,#STICONORM	COMP.W	(A6)+OZONIV,#NICOZOOM	JUMP',NE OPER2$	LOAD.W	D4,#STICOINVOPER2$:	LOAD.W	D3,#ICOZZOOM	CALL	MSTICONE	; allume l'icne zoom	LOAD.W	D4,#STICONORM	COMP.W	(A6)+OZONIV,#NICOTOURNE	JUMP',NE OPER3$	LOAD.W	D4,#STICOINVOPER3$:	LOAD.W	D3,#ICOZTOURNE	CALL	MSTICONE	; allume l'icne tourne	LOAD.W	D4,#STICONORM	COMP.W	(A6)+OZONIV,#NICOMIROIR	JUMP',NE OPER4$	LOAD.W	D4,#STICOINVOPER4$:	LOAD.W	D3,#ICOZMIROIR	CALL	MSTICONE	; allume l'icne miroir	LOAD.W	D4,#STICONORM	COMP.W	(A6)+OZONIV,#NICODEFORME	JUMP',NE OPER5$	LOAD.W	D4,#STICOINVOPER5$:	LOAD.W	D3,#ICOZDEFORME	CALL	MSTICONE	; allume l'icne dforme	LOAD.W	D4,#STICONORM	COMP.W	(A6)+OZONIV,#NICODEFBEZ	JUMP',NE OPER6$	LOAD.W	D4,#STICOINVOPER6$:	LOAD.W	D3,#ICOZDEFBEZ	CALL	MSTICONE	; allume l'icne dforme selon Bzier	TEST.B	(A6)+OZONDE	; dformation possible ?	JUMP',EQ OPER7$		; oui => OPER7$	LOAD.W	D4,#STICOGREY	LOAD.W	D3,#ICOZDEFORME	CALL	MSTICONE	; grise l'icne dforme selon quadrilatreOPER7$:	TEST.B	(A6)+OZONDB	; dformation possible ?	JUMP',EQ OPER8$		; oui => OPER8$	LOAD.W	D4,#STICOGREY	LOAD.W	D3,#ICOZDEFBEZ	CALL	MSTICONE	; grise l'icne dforme selon BzierOPER8$:;	JUMP'	EXIT$EXIT$:	POP.L	(A6)+OAPOS	POPM.L	D0..D4,D6,A3,A4	RETNOST$:	.W	-1;---------\\; MSTICONE >;=========/; Modifie l'tat d'une icne.; in	D3.W	icne;	D4.W	nouvel tat (STICOxxxx); out	-; mod	D7.WMSTICONE:	PUSHM.L	D2,A4	LOAD.L	A4,#(A6)+OICOST-4 ; A4 <-- ^table des tats	CLR.W	D2LOOP$:	ADD.L	A4,#4		; A4 <-- ^icne suivante	INC.W	D2	COMP.W	(A4),#-1	; fin de la table ?	JUMP,EQ NEW$		; oui => NEW$	COMP.W	D3,(A4)		; icne trouve ?	JUMP,NE LOOP$		; non => LOOP$	COMP.W	D4,(A4)+2	; tat chang ?	JUMP,EQ EXIT$		; non => EXIT$	COMP.W	(A4)+2,#STICOGREY	JUMP',NE OFULL$	CALL	FULLICONE	; dgrise l'icneOFULL$:	COMP.W	(A4)+2,#STICOINV	JUMP',NE ONORM$	CALL	INVICONE	; teint l'icneONORM$:	COMP.W	(A4)+2,#STICOINVL	JUMP',NE ONORML$	CALL	INVLICONE	; teint l'icne  gaucheONORML$:	COMP.W	(A4)+2,#STICOINVR	JUMP',NE ONORMR$	CALL	INVRICONE	; teint l'icne  droiteONORMR$:	COMP.W	(A4)+2,#STICOINVLR	JUMP',NE ONORMLR$	CALL	INVLRICONE	; teint l'icne  gauche+droiteONORMLR$:	LOAD.W	(A4)+2,D4	; OICOST <-- nouvel tatMAJ$:	COMP.W	D4,#STICOGREY	JUMP',NE NFULL$	CALL	GREYICONE	; grise l'icneNFULL$:	COMP.W	D4,#STICOINV	JUMP',NE NNORM$	CALL	INVICONE	; allume l'icneNNORM$:	COMP.W	D4,#STICOINVL	JUMP',NE NNORML$	CALL	INVLICONE	; allume l'icne  gaucheNNORML$:	COMP.W	D4,#STICOINVR	JUMP',NE NNORMR$	CALL	INVRICONE	; allume l'icne  droiteNNORMR$:	COMP.W	D4,#STICOINVLR	JUMP',NE NNORMLR$	CALL	INVLRICONE	; allume l'icne  gauche+droiteNNORMLR$:	JUMP'	EXIT$NEW$:	COMP.W	D2,#MAXICONE	; table pleine ?	JUMP',HS EXIT$		; oui => EXIT$	LOAD.W	(A4+),D3	; OICOST <-- nouvelle icne	LOAD.W	(A4+),D4	; OICOST <-- nouvel tat	LOAD.W	(A4),#-1	; OICOST <-- nouveau terminateur	JUMP	MAJ$EXIT$:	POPM.L	D2,A4	RET;---------\\; KSTICONE >;=========/; Supprime l'tat d'une icne.; in	D3.W	code de l'icne; out	-; mod	D7.WKSTICONE:	PUSH.L	A4	LOAD.L	A4,#(A6)+OICOST-4 ; A4 <-- ^table des tatsLOOP$:	ADD.L	A4,#4		; A4 <-- ^icne suivante	COMP.W	(A4),#-1	; fin de la table ?	JUMP',EQ EXIT$		; oui => EXIT$	COMP.W	D3,(A4)		; icne trouve ?	JUMP,NE LOOP$		; non => LOOP$FILL$:	COMP.W	(A4),#-1	JUMP',EQ EXIT$	LOAD.W	(A4+),(A4)+4	JUMP	FILL$EXIT$:	POP.L	A4	RET;---------\\; GSTICONE >;=========/; Donne l'tat d'une icne.; in	D3.W	code de l'icne; out	D4.W	tat de l'icne (STICOxxxx);	D7.W	erreur; mod	D4.L, D7.WGSTICONE:	PUSH.L	A4	LOAD.L	A4,#(A6)+OICOST-4 ; A4 <-- ^table des tats	LOAD.W	D4,#STICONORM	; D4 <-- tat normal par dfaut	LOAD.W	D7,#1		; D7 <-- pas dans la tableLOOP$:	ADD.L	A4,#4		; A4 <-- ^icne suivante	COMP.W	(A4),#-1	; fin de la table ?	JUMP',EQ EXIT$		; oui => EXIT$	COMP.W	D3,(A4)		; icne trouve ?	JUMP,NE LOOP$		; non => LOOP$	LOAD.W	D4,(A4)+2	; D4 <-- tat	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DPLICONE >;=========/; Dplace ventuellement toutes les icnes de gauche.; in	D4.L	position de la souris (y;x); out	D7.W	ok/erreur; mod	D7.WDPLICONE:	PUSHM.L	D2..D4	LOAD.W	D7,#1	COMP.W	D4,#MARGX+ICOLX	; trop  droite ?	JUMP,HS 90$	SWAP.W	D4	COMP.W	D4,(A0)+ODFCY	; trop haut ?	JUMP,LO 90$	SWAP.W	D4	CLR.W	D2		; D2 <-- nb de dplacements10$:	SWAP.W	D4	SUB.W	D4,#ICOLY/2	; D4 <-- la souris montre le milieu	LOAD.W	D3,#340-ICOLY	; D3 <-- minimum (340 = hauteur wdo SM100)	COMP.W	D4,D3		; trop haut ?	JUMP',GE 20$	LOAD.W	D4,D320$:	LOAD.W	D3,(A0)+ODFDY	SUB.W	D3,#ICOLY	; D3 <-- maximum	COMP.W	D4,D3		; trop bas ?	JUMP',LE 22$	LOAD.W	D4,D322$:	AND.B	D4,#B'11111110	; D4 <-- doit tre pair	COMP.W	D4,(A6)+OICOPOS+0 ; nouvelle position ?	JUMP',EQ 40$		; non => 40$				; oui =>	JUMP',HI 30$	PUSH.W	D4	LOAD.W	D3,D4	ADD.W	D3,#ICOLY	SUB.W	D4,(A6)+OICOPOS+0	NEG.W	D4	CALL	CLRICONE	; efface la partie dcouverte en bas	POP.W	D4	JUMP'	35$30$:	PUSH.W	D4	LOAD.W	D3,(A6)+OICOPOS+0	SUB.W	D4,(A6)+OICOPOS+0	CALL	CLRICONE	; efface la partie dcouverte en haut	POP.W	D435$:	LOAD.W	(A6)+OICOPOS+0,D4	CALL	REQICONE	; remet rapidement les icnes	INC.W	D2		; D2 <-- un dplacement de plus40$:	CALL	WAITMOVE	; attend dplacement souris ...	JUMP',NE 50$		; fin du dplacement => 50$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE 40$	JUMP	10$50$:	TEST.W	D2		; y a-t-il eu des dplacements	JUMP',EQ 80$		; non => 80$	CALL	MAJICONE	; mj. les icnes variables80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; LIBICONE >;=========/; Libre les icnes mmorises.; in	-; out	-; mod	D7.WLIBICONE:	PUSHM.L	D1,A4	TEST.L	(A6)+OICOPM	; icnes dj mmorises ?	JUMP',EQ EXIT$	LOAD.L	A4,(A6)+OICOPM	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre mmoire pour icnes	CLR.L	(A6)+OICOPMEXIT$:	POPM.L	D1,A4	RET;---------\\; MEMICONE >;=========/; Mmorise toutes les icnes dessines  gauche.; in	-; out	D7.W	erreur; mod	D7.WMEMICONE:	PUSHM.L	D1..D6,A1..A4	CLR.W	D7	TEST.L	(A6)+OICOPM	; icnes dj mmorises ?	JUMP,NE 90$		; oui => 90$	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP,NE 90$		; oui => 90$ (ne mmorise jamais)	LOAD.L	D4,#ICOLY*(ICOLX/8)	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour icnes	JUMP,NE 90$	LOAD.L	(A6)+OICOPM,A4	LOAD.L	A3,#0		; A3 <-- ^source (dans l'cran)	LOAD.L	D3,(A6)+OICOPOS	SUB.W	D3,#GCIMX+6	SWAP.W	D3	SUB.W	D3,#GCIMY+5	SWAP.W	D3;	LOAD.L	A4,A4		; A4 <-- ^destination	CLR.L	D4	LOAD.W	D6,#ICOLX/8	LOAD.L	D2,#H'10000*ICOLY+ICOLX	LOAD.W	D1,#LOADDOT	LOAD.L	A2,A0		; A2 <-- ^descripteur WDO	LOAD.L	A1,(A6)+ORASTER	CALL	(A1)		; appel GRA_RASTER	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D6,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; REMICONE >;=========/; Remet toutes les icnes dessines  gauche.; in	-; out	-; mod	D7.WREMICONE:	CALL	REQICONE	; remet toutes les icnes	CALL	MAJICONE	; mj. les icnes variables	RET;---------\\; REQICONE >;=========/; Remet toutes les icnes dessines  gauche, rapidement,; c'est--dire sans mettre  jour les icnes.; in	-; out	-; mod	D7.WREQICONE:	PUSHM.L	D1..D6,A1..A4	TEST.L	(A6)+OICOPM	; icnes mmorises ?	JUMP',EQ NOMEM$		; non => NOMEM$	CALL	CCMO		; enlve la souris	LOAD.L	A3,(A6)+OICOPM	; A3 <-- ^source	CLR.L	D3	LOAD.W	D5,#ICOLX/8	LOAD.L	A4,#0		; A4 <-- ^destination (dans cran)	LOAD.L	D4,(A6)+OICOPOS	SUB.W	D4,#GCIMX+6	SWAP.W	D4	SUB.W	D4,#GCIMY+5	SWAP.W	D4	LOAD.L	D2,#H'10000*ICOLY+ICOLX	LOAD.W	D1,#LOADDOT	LOAD.L	A2,A0		; A2 <-- ^descripteur WDO	LOAD.L	A1,(A6)+ORASTER	CALL	(A1)		; appel GRA_RASTER	CALL	SCMO		; remet la souris	JUMP'	EXIT$NOMEM$:	CALL	DESICONE	; dessine normalement;	JUMP'	EXIT$EXIT$:	POPM.L	D1..D6,A1..A4	RET;---------\\; DESICONE >;=========/; Dessine une liste d'icnes en colonne.; in	-; out	-; mod	D7.WDESICONE:	PUSHM.L	D0..D4,A3	LOAD.W	D3,(A6)+OICOPOS+0	LOAD.W	D4,#ICOLY	CALL	CLRICONE	; efface toutes les icnes	LOAD.W	D0,#OPICODES	; D0 <-- dessine	LIB	?BUCAR	CALL	PTGICONE	; A3 <-- ^icnes de gauche	CALL	XXXICONE	LIB	?NOBUCAR90$:	POPM.L	D0..D4,A3	RET;------------\\; DESICONEONE >;============/; Dessine une icne en colonne.; in	D3.W	icne  dessiner; out	-; mod	D7.WDESICONEONE:	PUSHM.L	D0,D5,A3	LOAD.W	D0,#OPICODESONE	; D0 <-- dessine	LOAD.W	D5,D3		; D5 <-- code de l'icne	JUMP',EQ 90$		; nil => ne fait rien	CALL	PTGICONE	; A3 <-- ^icnes de gauche	CALL	XXXICONE90$:	POPM.L	D0,D5,A3	RET;---------\\; CLRICONE >;---------/; Efface toutes les icnes de gauche.; in	D3.W	origine (y);	D4.W	hauteur (dy); out	-; mod	D7.WCLRICONE:	PUSHM.L	D2..D4	LOAD.W	D2,D4	LOAD.L	D4,#H'88228822	; D4 <-- trame pour joli cran	CALL	DRMDEF	LOAD.W	D4,D2	SUB.W	D3,#GCIMY+5	SWAP.W	D3	LOAD.W	D3,(A6)+OICOPOS+2	SUB.W	D3,#GCIMX+6	SWAP.W	D4	LOAD.W	D4,#ICOLX	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; grise toutes les icnes	POPM.L	D2..D4	RET;---------\\; MOVICONE >;=========/; Dplace une icne tant que le bouton est press.; in	D4.L	position de la souris (y;x); out	D3.W	icne o est la souris;	D7.W	ok/erreur; mod	D3.L, D7.WMOVICONE:	PUSHM.L	D4,D5	CALL	DETICONE	; souris dans une icne ?	JUMP,NE 90$		; non => 90$	LOAD.W	D5,D3	JUMP'	30$20$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP',NE 50$		; non => 50$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE 20$	CALL	DETICONE	; D3 <-- icne o est la souris	JUMP,NE 20$	COMP.W	D3,D5	JUMP,EQ 20$	EX.L	D3,D5	CALL	INVALLICONE	; teint l'ancienne icne30$:	LOAD.W	D3,D5	CALL	INVALLICONE	; allume la nouvelle icne	JUMP	20$50$:	LOAD.W	D3,D5	CALL	INVALLICONE	; teint l'ancienne icne	CALL	GSTICONE	; D4 <-- tat de l'icne	COMP.W	D4,#STICOGREY	; icne grise ?	JUMP',NE 80$		; non => 80$	CLR.W	D380$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D4,D5	TEST.W	D7		; retour EQ/NE	RET;---------\\; DETICONE >;=========/; Dtecte dans quelle icne est la souris.; in	D4.L	position de la souris (y;x); out	D3.W	icne o est la souris;	D7.W	ok/erreur; mod	D3.L, D7.WDETICONE:	PUSHM.L	D0,D5,A3	LOAD.W	D0,#OPICODET	; D0 <-- dtecte	LOAD.L	D5,D4		; D5 <-- position de la souris (y;x)	CALL	PTGICONE	; A3 <-- ^icnes de gauche	CALL	XXXICONE	JUMP',NE 90$	LOAD.W	D3,D5		; D3 <-- code de l'icne90$:	POPM.L	D0,D5,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; INVICONE >;=========/; Inverse une icne.; in	D3.W	icne  inverser; out	-; mod	D7.WINVICONE:	PUSHM.L	D0,D5,A3	LOAD.W	D0,#OPICOINV	; D0 <-- inverse	LOAD.W	D5,D3		; D5 <-- code de l'icne	JUMP',EQ 90$		; nil => ne fait rien	CALL	PTGICONE	; A3 <-- ^icnes de gauche	CALL	XXXICONE90$:	POPM.L	D0,D5,A3	RET;----------\\; INVLICONE >;==========/; Inverse une icne  gauche.; in	D3.W	icne  inverser; out	-; mod	D7.WINVLICONE:	PUSHM.L	D0,D5,A3	LOAD.W	D0,#OPICOINVL	; D0 <-- inverse	LOAD.W	D5,D3		; D5 <-- code de l'icne	JUMP',EQ 90$		; nil => ne fait rien	CALL	PTGICONE	; A3 <-- ^icnes de gauche	CALL	XXXICONE90$:	POPM.L	D0,D5,A3	RET;----------\\; INVRICONE >;==========/; Inverse une icne  droite.; in	D3.W	icne  inverser; out	-; mod	D7.WINVRICONE:	PUSHM.L	D0,D5,A3	LOAD.W	D0,#OPICOINVR	; D0 <-- inverse	LOAD.W	D5,D3		; D5 <-- code de l'icne	JUMP',EQ 90$		; nil => ne fait rien	CALL	PTGICONE	; A3 <-- ^icnes de gauche	CALL	XXXICONE90$:	POPM.L	D0,D5,A3	RET;-----------\\; INVLRICONE >;===========/; Inverse une icne  gauche+droite.; in	D3.W	icne  inverser; out	-; mod	D7.WINVLRICONE:	PUSHM.L	D0,D5,A3	LOAD.W	D0,#OPICOINVLR	; D0 <-- inverse	LOAD.W	D5,D3		; D5 <-- code de l'icne	JUMP',EQ 90$		; nil => ne fait rien	CALL	PTGICONE	; A3 <-- ^icnes de gauche	CALL	XXXICONE90$:	POPM.L	D0,D5,A3	RET;------------\\; INVALLICONE >;============/; Inverse toute une icne.; in	D3.W	icne  inverser; out	-; mod	D7.WINVALLICONE:	PUSHM.L	D0,D5,A3	LOAD.W	D0,#OPICOINVALL	; D0 <-- inverse	LOAD.W	D5,D3		; D5 <-- code de l'icne	JUMP',EQ 90$		; nil => ne fait rien	CALL	PTGICONE	; A3 <-- ^icnes de gauche	CALL	XXXICONE90$:	POPM.L	D0,D5,A3	RET;---------\\; POSICONE >;=========/; Donne la position d'une icne.; in	D3.W	icne; out	D4.L	position coin sup/gauche (y;x);	D7.W	erreur; mod	D7.WPOSICONE:	PUSHM.L	D0,D5,A3	LOAD.W	D0,#OPICOPOS	; D0 <-- position	LOAD.W	D5,D3		; D5 <-- code de l'icne	CALL	PTGICONE	; A3 <-- ^icnes de gauche	CALL	XXXICONE	JUMP',NE 90$50$:	LOAD.L	D4,D5		; D4 <-- position90$:	POPM.L	D0,D5,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; GREYICONE >;==========/; Grise une icne.; in	D3.W	icne  griser; out	-; mod	D7.WGREYICONE:	PUSHM.L	D0,D5,A3	LOAD.W	D5,D3		; D5 <-- code de l'icne	JUMP',EQ 90$		; nil => ne fait rien	LOAD.W	D0,#OPICOGREY	; D0 <-- grise	CALL	PTGICONE	; A3 <-- ^icnes de gauche	CALL	XXXICONE90$:	POPM.L	D0,D5,A3	RET;----------\\; FULLICONE >;==========/; Dgrise une icne.; in	D3.W	icne  dgriser; out	-; mod	D7.WFULLICONE:	PUSHM.L	D0,D5,A3	LOAD.W	D5,D3		; D5 <-- code de l'icne	JUMP',EQ 90$		; nil => ne fait rien	LOAD.W	D0,#OPICOFULL	; D0 <-- dgrise	CALL	PTGICONE	; A3 <-- ^icnes de gauche	CALL	XXXICONE90$:	POPM.L	D0,D5,A3	RET;---------\\; PTGICONE >;---------/; Donne le pointeur aux icnes de gauche.; in	-; out	A3.L	^icnes de gauche; mod	A3.LPTGICONE:	PUSH.W	D3	LOAD.W	D3,(A6)+OICONIV	LOAD.L	A3,(A6)+OICOPH	COMP.W	D3,#NICOHAND	JUMP',EQ EXIT$	COMP.W	D3,#NICOEDIT	JUMP',EQ EXIT$	COMP.W	D3,#NICOCREATE	JUMP',EQ EXIT$	LOAD.L	A3,#R16"TICOMULTI	COMP.W	D3,#NICOMULTI	JUMP',EQ EXIT$	LOAD.L	A3,#R16"TICOZOOM	COMP.W	D3,#NICOZOOM	JUMP',EQ EXIT$	LOAD.L	A3,#R16"TICOTOURNE	COMP.W	D3,#NICOTOURNE	JUMP',EQ EXIT$	LOAD.L	A3,#R16"TICOMIROIR	COMP.W	D3,#NICOMIROIR	JUMP',EQ EXIT$	LOAD.L	A3,#R16"TICODEFORME	COMP.W	D3,#NICODEFORME	JUMP',EQ EXIT$	LOAD.L	A3,#R16"TICODEFBEZ	COMP.W	D3,#NICODEFBEZ	JUMP',EQ EXIT$	LOAD.L	A3,#R16"TICOGAUCHEEXIT$:	POP.W	D3	RET;---------\\; XXXICONE >;---------/; Dessine une liste d'icnes en colonne.; in	A3.L	^liste;	D0.W	opration (OPICOxxx);	D5.L	position de la souris (si dtecte);	D5.W	code de l'icne (si inverse/position); out	D5.W	icne o est la souris (si dtecte);	D5.L	coordonne (si position);	D7.W	ok/erreur (si dtecte ou inverse); mod	D5.L, D7.WXXXICONE:	PUSHM.L	D1..D4,A3	LOAD.L	D4,(A6)+OICOPOS	LOAD.L	D3,D4	CLR.W	D2		; D2 <-- gencar du texte10$:	COMP.W	(A3),#OPIF	; fin de la table ?	JUMP,EQ 80$	COMP.W	(A3),#OPIL	; va  la ligne suivante ?	JUMP,EQ 40$	COMP.W	(A3),#OPIC	; va  la ligne suivante ?	JUMP,EQ 45$	COMP.W	D0,#OPICODESONE	JUMP',EQ 18$	COMP.W	D0,#OPICODET	JUMP,EQ 30$	COMP.W	D0,#OPICOINV	JUMP,EQ 35$	COMP.W	D0,#OPICOINVL	JUMP,EQ 35$	COMP.W	D0,#OPICOINVR	JUMP,EQ 35$	COMP.W	D0,#OPICOINVLR	JUMP,EQ 35$	COMP.W	D0,#OPICOINVALL	JUMP,EQ 35$	COMP.W	D0,#OPICOPOS	JUMP,EQ 35$	COMP.W	D0,#OPICOGREY	JUMP,EQ 35$	JUMP'	20$18$:	COMP.W	D5,(A3)+2	JUMP',NE 24$20$:				; dessine/dgrise =>	LOAD.B	D1,#GCICT	COMP.W	(A3)+2,#ICOOBJET	JUMP',HS 22$	COMP.W	(A3)+2,#128	JUMP',LO 22$	INC.B	D122$:	COMP.B	D2,D1		; utilise toujours le mme gencar ?	JUMP',EQ 24$		; oui => 24$	LOAD.B	D2,D1	COMP.B	D2,#GCICT+1	JUMP',EQ 23$	LIB	?AFTIM	.B	USEGC,GCICF,GCICS,GCICT	.B	0	.EVEN	JUMP'	24$23$:	LIB	?AFTIM	.B	USEGC,GCICF,GCICS,GCICT+1	.B	0	.EVEN24$:	CALL	XXXONEICONE	; dessine une icne	COMP.W	D0,#OPICODESONE	JUMP',NE 25$	TEST.W	D7	JUMP,EQ 80$25$:	ADD.L	A3,#6	JUMP	10$30$:				; dtecte =>	CALL	XXXONEICONE	; dtecte si dans cette icne ?	JUMP,NE 25$		; non => 25$	LOAD.W	D5,(A3)+2	; D5 <-- code de l'icne	JUMP'	80$35$:				; inverse/position =>	CALL	XXXONEICONE	; inverse cette icne ?	JUMP,NE 25$		; non => 25$	JUMP'	80$40$:				; grand interligne =>	SWAP.W	D3	ADD.W	D3,#GCICY+GCIMY*2	SWAP.W	D3	LOAD.L	D4,D3	ADD.L	A3,#2	JUMP	10$45$:				; petit interligne =>	SWAP.W	D3	ADD.W	D3,#5		; aligne en bas sur Smaky 100 !	SWAP.W	D3	LOAD.L	D4,D3	ADD.L	A3,#2	JUMP	10$80$:	COMP.W	D0,#OPICODES	; dessine ?	JUMP',EQ 85$		; oui => 85$	COMP.W	D0,#OPICODESONE	; dessine un ?	JUMP',EQ 85$		; oui => 85$	COMP.W	D0,#OPICOFULL	; dgrise ?	JUMP',NE 90$		; non => 90$85$:	LIB	?AFTIM	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.EVEN90$:	POPM.L	D1..D4,A3	TEST.W	D7		; retour EQ/NE	RET;------------\\; XXXONEICONE >;------------/; Dessine/dtecte/inverse une icne.; in	A3.L	^lment dans table;	D4.L	coordonne coin sup/gauche;	D0.W	opration (OPICOxxx);	D5.L	position de la souris (si dtecte);	D5.W	code de l'icne (si inverse/position/grise/dgrise); out	D4.L	coordonne suivante;	D5.L	coordonne coin (si position);	D7.W	ok/erreur (si dtecte ou inverse); mod	D4.L, D5.L, D7.WXXXONEICONE:	PUSHM.L	D1..D3	LOAD.L	D1,D4		; D1 <-- coin	LOAD.L	D3,D4	SUB.W	D3,#GCIMX	SWAP.W	D3	SUB.W	D3,#GCIMY	SWAP.W	D3	LOAD.W	D4,#GCICY+GCIMY*2	SWAP.W	D4	LOAD.W	D4,#GCICX/2+GCIMX*2	COMP.W	(A3)+0,#OPIS	JUMP',EQ CASE$	ADD.W	D4,#GCICX/2+GCIMX*2	COMP.W	(A3)+0,#OPID	JUMP',EQ CASE$	ADD.W	D4,#GCICX/2+GCIMX*2	COMP.W	(A3)+0,#OPITD	JUMP',NE CASE$	SWAP.W	D4	LOAD.W	D4,#GCICY/2	SWAP.W	D4CASE$:	COMP.W	D0,#OPICODESONE	JUMP,EQ DRAW1$	COMP.W	D0,#OPICODET	JUMP,EQ DET$	COMP.W	D0,#OPICOINV	JUMP,EQ INV$	COMP.W	D0,#OPICOINVL	JUMP,EQ INV$	COMP.W	D0,#OPICOINVR	JUMP,EQ INV$	COMP.W	D0,#OPICOINVLR	JUMP,EQ INV$	COMP.W	D0,#OPICOINVALL	JUMP,EQ INV$	COMP.W	D0,#OPICOPOS	JUMP,EQ POS$	COMP.W	D0,#OPICOGREY	JUMP,EQ GREY$	COMP.W	D0,#OPICOFULL	JUMP,EQ FULL$	JUMP'	DRAW$DRAW1$:	LOAD.W	D7,#ERDIOUT	COMP.W	D5,(A3)+2	JUMP,NE OK$DRAW$:				; dessine =>	COMP.W	(A3)+2,#ICOVIDE	JUMP,EQ OK$	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	PUSH.L	D4	CLR.L	D4	CALL	DRMDEF	POP.L	D4	PUSHM.L	D3,D4	PUSHM.L	D3,D4	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	POPM.L	D3,D4	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; rectangle autour icne	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	ADD.W	D4,#2	SWAP.W	D4	ADD.W	D4,#2	SWAP.W	D4	LIB	?DRRECT		; double l'paisseur	LOAD.L	D3,D1		; D3 <-- coin	SUB.W	D3,#4	COMP.W	(A3)+0,#OPIS	JUMP',EQ DRPOS$	ADD.W	D3,#4+GCIMX	COMP.W	(A3)+0,#OPID	JUMP',EQ DRPOS$	ADD.W	D3,#14DRPOS$:	COMP.W	(A3)+0,#OPITD	JUMP',EQ DRDEMI$	COMP.W	(A3)+2,#ICOOBJET	JUMP,HS DROBJ$	SWAP.W	D3	ADD.W	D3,#GCICY-GCICB	SWAP.W	D3	LIB	?SETCURS	LOAD.W	D3,(A3)+2	; D3 <-- code	AND.B	D3,#H'7F	LIB	?AFCODE	POPM.L	D3,D4	CALL	DESACTION	; dessine ventuellement une action	CLR.W	D7		; D7 <-- ok	JUMP	OK$DRDEMI$:	SWAP.W	D3	ADD.W	D3,#GCICY-GCICB-2	SWAP.W	D3	LIB	?SETCURS	LIB	?AFTIM	.B	MODCAR,SETDOT!PENDOT,0	.EVEN	LOAD.W	D3,(A3)+2	; D3 <-- code	AND.B	D3,#H'7F	LIB	?AFCODE	LIB	?AFTIM	.B	MODCAR,SETDOT,0	.EVEN	POPM.L	D3,D4	CLR.W	D7		; D7 <-- ok	JUMP	OK$DROBJ$:	LOAD.L	D4,D3		; D4 <-- coin sup/gauche	LOAD.W	D3,(A3)+2	; D3 <-- code	CALL	DESICOOBJ	; dessine l'icone de l'objet	POPM.L	D3,D4	CALL	DESACTION	; dessine ventuellement une action	CLR.W	D7		; D7 <-- ok	JUMP	OK$DET$:				; dtecte =>	LOAD.W	D7,#ERDIOUT	LOAD.W	D2,D5	SUB.W	D2,D3		; souris trop  gauche ?	JUMP,LO OK$	COMP.W	D2,D4		; souris trop  droite ?	JUMP,HS OK$	SET.B	(A6)+OICOCG	; on est  gauche	SR.W	D4,#1	COMP.W	D2,D4	JUMP',LO DET2$	CLR.B	(A6)+OICOCG	; on est  droiteDET2$:	SWAP.W	D3	SWAP.W	D4	LOAD.L	D2,D5	SWAP.W	D2	SUB.W	D2,D3		; souris trop en haut ?	JUMP,LO OK$	COMP.W	D2,D4		; souris trop en bas ?	JUMP,HS OK$	CLR.B	(A6)+OICOCB	; on est en haut	SR.W	D4,#1	COMP.W	D2,D4	JUMP',LO DET4$	SET.B	(A6)+OICOCB	; on est en basDET4$:	CLR.W	D7		; D7 <-- dans l'icone	JUMP	OK$INV$:				; inverse =>	LOAD.W	D7,#ERDIOUT	COMP.W	D5,(A3)+2	JUMP,NE OK$	PUSHM.L	D3,D4	LOAD.W	D3,(A3)+2	; D3 <-- code de l'icne	CALL	GSTICONE	; D4 <-- tat de l'icne	COMP.W	D4,#STICOGREY	; icne grise ?	JUMP',EQ INV22$	LOAD.L	D4,#-1		; D4 <-- trame pour inverser	JUMP'	INV23$INV22$:;;?	LOAD.L	D4,#H'00550055	; D4 <-- trame pour griser	LOAD.L	D4,#H'88228822	; D4 <-- trame pour griserINV23$:	CALL	DRMDEF	POPM.L	D3,D4	LOAD.W	D2,#1	COMP.W	D0,#OPICOINVALL	JUMP',EQ INV3$	INC.W	D2INV3$:	ADD.W	D3,D2	SWAP.W	D3	ADD.W	D3,D2	SWAP.W	D3	SUB.W	D4,D2	SUB.W	D4,D2	SWAP.W	D4	SUB.W	D4,D2	SUB.W	D4,D2	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	INC.W	D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4	SUB.W	D3,#6	SWAP.W	D4	SWAP.W	D3	COMP.W	D0,#OPICOINVL	JUMP',EQ INVL$	COMP.W	D0,#OPICOINVR	JUMP',EQ INVR$	COMP.W	D0,#OPICOINVLR	JUMP',EQ INVLR$	CLR.W	D7	JUMP	OK$INVLR$:	CALL	INVPOINT	; point  gaucheINVR$:	ADD.W	D3,D4	SUB.W	D3,#7INVL$:	CALL	INVPOINT	; point  droite	CLR.W	D7	JUMP	OK$POS$:				; position =>	LOAD.W	D7,#ERDIOUT	COMP.W	D5,(A3)+2	JUMP,NE OK$	LOAD.L	D5,D3		; D5 <-- position	CLR.W	D7	JUMP	OK$GREY$:				; grise =>	LOAD.W	D7,#ERDIOUT	COMP.W	D5,(A3)+2	JUMP,NE OK$	PUSH.L	D4;;?	LOAD.L	D4,#H'55AA55AA	load.l	d4,#H'88228822	; D4 <-- trame pour joli cran	CALL	DRMDEF	POP.L	D4	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	SUB.W	D4,#2	SWAP.W	D4	SUB.W	D4,#2	SWAP.W	D4;;?	LOAD.W	D2,#CLRDOT	load.w	d2,#setdot	LIB	?DRTRAME	; grise toute l'icne	CLR.W	D7	JUMP	OK$FULL$:				; dgrise =>	LOAD.W	D7,#ERDIOUT	COMP.W	D5,(A3)+2	JUMP,EQ DRAW$;	JUMP	OK$OK$:	LOAD.L	D4,D1	ADD.W	D4,#GCICX/2+GCIMX*2	COMP.W	(A3)+0,#OPIS	JUMP',EQ EXIT$	ADD.W	D4,#GCICX/2+GCIMX*2	COMP.W	(A3)+0,#OPID	JUMP',EQ EXIT$	ADD.W	D4,#GCICX/2+GCIMX*2EXIT$:	POPM.L	D1..D3	TEST.W	D7		; retour EQ/NE	RET;---------\\; INVPOINT >;---------/; Inverse un point rond (5x5) dans une icne.;	. o o o .;	o o o o o;	o o o o o;	o o o o o;	. o o o .; in	D3.L	coin sup/gauche du point; out	-; mod	D7.WINVPOINT:	PUSHM.L	D2..D4	LOAD.W	D2,#INVDOT	INC.W	D3	LOAD.L	D4,#H'10000*1+3	LIB	?DRTRAME	ADD.L	D3,#H'10000*1	DEC.W	D3	LOAD.L	D4,#H'10000*3+5	LIB	?DRTRAME	ADD.L	D3,#H'10000*3	INC.W	D3	LOAD.L	D4,#H'10000*1+3	LIB	?DRTRAME	POPM.L	D2..D4	RET;----------\\; DESACTION >;----------/; Dessine ventuellement une action.; in	A3.L	^OPID/OPIS et code;	D3.L	origine rectangle;	D4.L	dimensions rectangle; out	-; mod	D7.WDESACTION:	PUSHM.L	D2..D4,A3,A4	LOAD.W	D2,(A3)+4	AND.B	D2,#H'F0	; D2 <-- type de l'icne	JUMP,EQ 90$	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	SUB.W	D4,#8		; D4 <-- action  droite	LOAD.L	A4,#R16"DIAL$	COMP.B	D2,#TICODIAL	JUMP',EQ 20$	LOAD.L	A4,#R16"DOWN$	COMP.B	D2,#TICODOWN	JUMP',EQ 20$	LOAD.L	A4,#R16"EFFET$	COMP.B	D2,#TICOEFFET	JUMP',EQ 20$	LOAD.L	A4,#R16"CHANGE$	COMP.B	D2,#TICOCHANGE	JUMP',NE 90$	CLR.W	D4		; D4 <-- action  gauche20$:	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWMATRIX	ADD.W	D3,D4	SWAP.W	D3	LOAD.L	(A3)+1,D3	; <xx> et <yy>	LOAD.L	(A3)+5,A4	; <pppp>	LOAD.B	(A3)+9,#INVDOT	; <m>	LOAD.W	D3,#10	LIB	?STRING		; dessine le motif90$:	POPM.L	D2..D4,A3,A4	RETDIAL$:	.B	8,24	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00110110	.B	B'00110110	.B	B'00000000DOWN$:	.B	8,24	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00001000	.B	B'00001000	.B	B'00001000	.B	B'00111110	.B	B'00011100	.B	B'00001000	.B	B'00000000EFFET$:	.B	8,24	.B	B'00111111	.B	B'00011111	.B	B'00011111	.B	B'00001111	.B	B'00001111	.B	B'00000111	.B	B'00000111	.B	B'00000011	.B	B'00000011	.B	B'00000001	.B	B'00000001	.B	B'00000000	.B	B'00000000	.B	B'00000001	.B	B'00000001	.B	B'00000011	.B	B'00000011	.B	B'00000111	.B	B'00000111	.B	B'00001111	.B	B'00001111	.B	B'00011111	.B	B'00011111	.B	B'00111111CHANGE$:	.B	8,24	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00000000	.B	B'00010000	.B	B'00110000	.B	B'01111110	.B	B'00110000	.B	B'00010000	.B	B'00000000	.EVEN;----------\\; DESICOOBJ >;==========/; Dessine l'icone d'un objet.; in	D3.W	icne;	D4.L	coin sup/gauche (y;x); out	-; mod	D7.WDESICOOBJ:	PUSHM.L	D0..D4,A3,A4	LOAD.W	D2,D3		; D2 <-- icne	TEST.L	D3:#BICOINTERNAL	JUMP,BS INTERNAL$	COMP.W	D3,#ICOSTATE	JUMP',HS STATE$OBJET$:	LOAD.W	D0,D3		; D0 <-- icne	SUB.W	D0,#ICOOBJET	; D0 <-- rang	CALL	OBJGETID	; D0 <-- identificateur	JUMP,NE EXIT$	LOAD.W	D3,#ICOIOBJET	; D3 <-- numro de l'icone	JUMP	DRAW$STATE$:	SUB.W	D3,#ICOSTATE	LOAD.W	D0,(A6)+OOBJET	; D0 <-- icne	SUB.W	D0,#ICOOBJET	; D0 <-- rang	CALL	OBJGETID	; D0 <-- identificateur	JUMP,NE EXIT$	LOAD.W	D1,#opIDENTSTATE ; D1 <-- mthode	CALL	OBJCALL		; A4 <-- ^identificateurs des tats	JUMP,NE EXIT$STATE2$:	DEC.W	D3	JUMP',NS STATE3$	COMP.W	(A4+),#-1	JUMP,NE STATE2$	JUMP	EXIT$STATE3$:	LOAD.W	D0,(A4)		; D0 <-- identificateur	JUMP,EQ EXIT$	COMP.W	D0,#-1	JUMP,EQ EXIT$	LOAD.W	D3,#ICOIOBJET	; D3 <-- numro de l'icone	JUMP'	DRAW$INTERNAL$:	LOAD.W	D0,(A6)+OICOID	; D0 <-- identificateur;	JUMP'	DRAW$DRAW$:	TEST.L	D3:#BICOINTERNAL	JUMP',BS MATRIX$	EX.L	D3,D4	SWAP.W	D3	ADD.W	D3,#GCICY-GCICB	SWAP.W	D3	LIB	?SETCURS	EX.L	D3,D4	AND.B	D3,#H'7F	LIB	?AFCODE	JUMP'	EXIT$MATRIX$:	LOAD.L	A4,(A6)+OPOIPOB	; A4 <-- ^objet (si poignes)	LOAD.L	A4,(A4)+OobjPDATA ; A4 <-- ^data de l'objet	LOAD.W	D1,#opGETICONE	; D1 <-- mthode	CALL	OBJCALL		; A4 <-- ^dx,dy,icne	JUMP',NE EXIT$	CLR.W	D3	LOAD.B	D3,(A4)+0	; D3 <-- largeur de l'icne	SUB.W	D3,#24	ASR.W	D3,#1	SUB.W	D4,D3	CLR.W	D3	LOAD.B	D3,(A4)+1	; D3 <-- hauteur de l'icne	SUB.W	D3,#20	ASR.W	D3,#1	SWAP.W	D4	SUB.W	D4,D3;	SWAP.W	D4	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWMATRIX;	SWAP.W	D4	LOAD.L	(A3)+1,D4	; <xx> et <yy>	LOAD.L	(A3)+5,A4	; <pppp>	LOAD.B	(A3)+9,#LOADDOT	; <m>	LOAD.W	D3,#10	LIB	?STRING		; dessine l'icne;	JUMP'	EXIT$EXIT$:	POPM.L	D0..D4,A3,A4	RET	.END