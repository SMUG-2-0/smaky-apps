	.SBTTL	PAGECADRE.ASI;--------\\; ICAMOVE >;========/; Dplace une icne dans le cadre.; in	D4.L	position de la souris (y;x); out	D2.W	icne (0..n);	D7.W	erreur; mod	D2.L, D7.WICAMOVE:	PUSHM.L	D1,D3,D4	CALL	ICADET		; souris dans une icne ?	JUMP',NE EXIT$		; non => EXIT$	LOAD.W	D1,D2	JUMP'	NEW$LOOP$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP',NE END$		; non => END$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE LOOP$	CALL	ICADET		; D2 <-- icne o est la souris	COMP.W	D2,D1		; est-on toujours dans la mme icne ?	JUMP,EQ LOOP$		; oui => LOOP$	EX.L	D2,D1	CALL	ICAINV		; teint l'ancienne icneNEW$:	LOAD.W	D2,D1	CALL	ICAINV		; allume la nouvelle icne	JUMP	LOOP$END$:	LOAD.W	D2,D1	CALL	ICAINV		; teint l'ancienne icne	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1,D3,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; ICADET  >;--------/; Dtecte dans quelle icne est la souris.; in	D4.L	position de la souris (y;x); out	D2.W	icne (0..n);	D7.W	erreur; mod	D2.L, D7.WICADET:	PUSHM.L	D3..D6	LOAD.W	D5,D4		; D5 <-- position en X	LOAD.L	D6,D4	SWAP.W	D6		; D6 <-- position en Y	CLR.W	D2LOOP$:	CALL	ICAPOS		; D3/D4 <--position/dimensions	JUMP',NE ERROR$	COMP.W	D5,D3	JUMP',LO NEXT$	ADD.W	D3,D4	COMP.W	D5,D3	JUMP',HS NEXT$	SWAP.W	D3	SWAP.W	D4	COMP.W	D6,D3	JUMP',LO NEXT$	ADD.W	D3,D4	COMP.W	D6,D3	JUMP',LO EXIT$NEXT$:	INC.W	D2	JUMP	LOOP$ERROR$:	LOAD.W	D2,#-1EXIT$:	POPM.L	D3..D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; ICAINV  >;--------/; Inverse une icne.; in	D2.W	numro (0..n); out	-; mod	D7.WICAINV:	PUSHM.L	D2..D4	COMP.W	D2,#-1	JUMP',EQ EXIT$	LOAD.L	D4,#-1	CALL	DRMDEF	CALL	ICAPOS		; D3/D4 <--position/dimensions	JUMP',NE EXIT$	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	SUB.W	D4,#2	SWAP.W	D4	SUB.W	D4,#2	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	; inverse l'icneEXIT$:	POPM.L	D2..D4	RET;--------\\; ICAPOS  >;--------/; Donne la position et les dimensions d'une icne dans le cadre.; in	D2.W	numro (0..n); out	D3.L	position (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D7.WICAPOS:	LOAD.W	D3,#POSSCALE	LOAD.W	D4,#5	TEST.W	D2	JUMP',EQ OK$	LOAD.W	D3,#POSCALQUE	LOAD.W	D4,#3	COMP.W	D2,#1	JUMP',EQ OK$	LOAD.W	D7,#1	JUMP'	EXIT$OK$:	MUL.WU	D3,(A0)+ODFCX	MUL.WU	D4,(A0)+ODFCX	SWAP.W	D4	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	SWAP.W	D4	CLR.W	D7		; D7 <-- okEXIT$:	TEST.W	D7		; retour EQ/NE	RET;--------------\\; GETMMENUSCALE >;==============/; Construit le mmenu pour l'chelle.; in	-; out	A3.L	^mmenu chelle;	D3.W	case  griser; mod	D3.L, D7.W, A3.LGETMMENUSCALE:	PUSHM.L	D0..D2,D4,A2,A4	LOAD.L	A3,#(A6)+OBUDIS	LOAD.L	A4,A3	LOAD.B	(A4+),#SPACE	CLR.B	(A4+)	LOAD.B	(A4+),#-1	LOAD.L	A2,#R16"TASCALE	CLR.W	D1		; D1 <-- rang de la caseLOOP$:	INC.W	D1		; D1 <-- case suivante	LOAD.W	D4,(A6)+OSCA100	NEG.W	D4	MUL.WU	D4,#100		; D4 <-- OSCA100*100	LOAD.W	D3,(A2+)	; D3 <-- +/- chelle	COMP.W	D3,#-1	JUMP',EQ END$	COMP.W	D3,(A6)+OSCALE	JUMP',NE FULL$	LOAD.W	D0,D1		; D0 <-- case  griserFULL$:	TEST.W	D3	JUMP',EQ AFF$	JUMP',NS NEG$POS$:	MUL.WU	D4,D3		; D4 <-- OSCA100*100*OSCALE	JUMP'	AFF$NEG$:	NEG.W	D3	DIV.WU	D4,D3		; D4 <-- (OSCA100*100)/OSCALE;	JUMP'	AFF$AFF$:	COMP.W	D4,#100	JUMP',NE NO100$	LOAD.B	(A4+),#-1NO100$:	AND.L	D4,#H'FFFF	LOAD.W	D3,#5		; D3 <-- 5 digits au maximum	CLR.W	D2	LIB	?PUTDEC	LOAD.B	(A4+),#'%	LOAD.B	(A4+),#SPACE	CLR.B	(A4+)	COMP.W	D4,#100	JUMP,NE LOOP$	LOAD.B	(A4+),#-1	JUMP	LOOP$END$:	CLR.B	(A4+)	LOAD.W	D3,D0		; D3 <-- case  griser	POPM.L	D0..D2,D4,A2,A4	RET;--------\\; DESWDO  >;========/; Grise toute la fentre et place les icnes.; in	-; out	-; mod	D7.WDESWDO:	PUSHM.L	D2..D4	LOAD.B	D3,#EOP	LIB	?AFCAR		; efface toute la fentre	LOAD.L	D4,#H'88228822	; D4 <-- trame pour joli cran	CALL	DRMDEF	CLR.L	D3	LOAD.L	D4,(A0)+ODFFDY	LOAD.W	D2,#SETDOT	LIB	?DRTRAME	; grise toute la fentre	PUSH.L	D4	LOAD.L	D4,#-1	CALL	DRMDEF	POP.L	D4	SWAP.W	D4	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	SWAP.W	D4	LIB	?DRTRAME	; dessine une bande blanche en haut	CALL	DESINFALL	; affiche les informations	CLR.L	D4	CALL	DRMDEF	LOAD.W	D4,(A0)+ODFDY	SUB.W	D4,#ICOLY	SWAP.W	D4	LOAD.W	D4,#MARGX+GCIMX	LOAD.L	(A6)+OICOPOS,D4	; OICOPOS <-- position pour icnes  gauche	CALL	DESICONE	; dessine toutes les icnes	CALL	MEMICONE	; mmorise les icnes de gauche	CALL	MAJICONE	POPM.L	D2..D4	RET;----------\\; DESINFALL >;==========/; Affiche toutes les informations.; in	-; out	-; mod	D7.WDESINFALL:	PUSHM.L	D2,D3,A4	LOAD.L	A4,#(A6)+OINAFF	LOAD.W	D2,#(100/2)-1	LOAD.W	D3,#H'100*SPACE+SPACE20$:	LOAD.W	(A4+),D3	; OINAFF <-- rempli d'espaces	DECJ.W,NMO D2,20$	CALL	DESINFO		; affiche les informations	CALL	DESINFSCALE	; affiche l'chelle	CALL	DESINFCALQUE	; affiche le calque actif	CALL	DESINFPAS	; affiche le pas	CALL	DESINFNBOBJ	; affiche le nombre d'objets	CALL	DESINFFILE	; affiche le nom du dessin	POPM.L	D2,D3,A4	RET;--------\\; DESINFO >;========/; Dessine les informations tout en haut.; in	-; out	-; mod	D7.WDESINFO:	PUSHM.L	A3,A4	LOAD.L	A4,#(A6)+OINAFF	LOAD.L	A3,#R16"TEXT$40$:	LOAD.B	(A4+),(A3+)	JUMP,NE 40$	LOAD.B	(A4)-1,#SPACE	CALL	DESINFMAJ	; met  jour l'cran	POPM.L	A3,A4	RETTEXT$:	.ASCII	" PAGE "	.B	PAGEREV+'0,'.	.IF	PAGEVERS<10	.B	PAGEVERS+'0	.ELSE	.B	(PAGEVERS/10)+'0,(PAGEVERS-((PAGEVERS/10)*10))+'0	.ENDIF	.B	PAGEPROV	.B	0	.EVEN;---------\\; DESINFXY >;=========/; Affiche la position x,y de la souris dans les informations.; in	-; out	-; mod	D7.WDESINFXY:	PUSHM.L	D2..D4,A4	LOAD.L	A4,#(A6)+OINAFF+POSXY	LOAD.W	D2,#22-1	LOAD.B	D3,#SPACE20$:	LOAD.B	(A4+),D3	; OINAFF <-- rempli d'espaces	DECJ.W,NMO D2,20$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP',NE 50$	CALL	CONVSCROBP	; D4 <-- point o est la souris	JUMP',NE 50$	LOAD.L	A4,#(A6)+OINAFF+POSXY+0	LOAD.B	(A4+),#'X	LOAD.B	(A4+),#'=	CALL	PUTUNUM		; OINAFF <-- coordonne X	LOAD.L	A4,#(A6)+OINAFF+POSXY+11	LOAD.B	(A4+),#'Y	LOAD.B	(A4+),#'=	SWAP.W	D4	CALL	PUTUNUM		; OINAFF <-- coordonne Y50$:	CALL	DESINFMAJ	; met  jour l'cran	POPM.L	D2..D4,A4	RET;-----------\\; DESINFOBJS >;===========/; Affiche le nombre d'objets slectionns dans les informations.; in	D4.W	nb d'objets slectionns; out	-; mod	D7.WDESINFOBJS:	PUSHM.L	D2..D4,A3,A4	LOAD.L	A4,#(A6)+OINAFF+POSXY	LOAD.W	D2,#22-1	LOAD.B	D3,#SPACE20$:	LOAD.B	(A4+),D3	; OINAFF <-- rempli d'espaces	DECJ.W,NMO D2,20$	LOAD.L	A4,#(A6)+OINAFF+POSXY	CONV.LA.WA D4	CALL	PUTANUM	LOAD.L	A3,#R16"TEXT$40$:	LOAD.B	(A4+),(A3+)	JUMP,NE 40$	LOAD.B	(A4)-1,#SPACE	COMP.W	D4,#1	JUMP',LS 50$	LOAD.B	(A4)-1,#'s50$:	CALL	DESINFMAJ	; met  jour l'cran	POPM.L	D2..D4,A3,A4	RETTEXT$:	.ASCIZ	" objet"	.EVEN;------------\\; DESINFSCALE >;============/; Affiche l'chelle dans les informations.; in	(A6)+OSCALE.W;	(A6)+OSCA100.W; out	-; mod	D7.WDESINFSCALE:	PUSHM.L	D2..D4,A4	LOAD.L	A4,#(A6)+OINAFF+POSSCALE	LOAD.W	D2,#6-1	LOAD.B	D3,#SPACE20$:	LOAD.B	(A4+),D3	; OINAFF <-- rempli d'espaces	DECJ.W,NMO D2,20$	LOAD.W	D4,(A6)+OSCA100	NEG.W	D4	MUL.WU	D4,#100		; D4 <-- OSCA100*100	LOAD.W	D3,(A6)+OSCALE	; D3 <-- +/- chelle	JUMP',EQ AFF$	JUMP',NS NEG$POS$:	MUL.WU	D4,D3		; D4 <-- OSCA100*100*OSCALE	JUMP'	AFF$NEG$:	NEG.W	D3	DIV.WU	D4,D3		; D4 <-- (OSCA100*100)/OSCALE;	JUMP'	AFF$AFF$:	LOAD.L	A4,#(A6)+OINAFF+POSSCALE	CONV.LA.WA D4	CALL	PUTANUM	LOAD.B	(A4+),#'%	CALL	DESINFMAJ	; met  jour l'cran	POPM.L	D2..D4,A4	RET;-------------\\; DESINFCALQUE >;=============/; Affiche le calque actif dans les informations.; in	(A6)+OCALACT.W; out	-; mod	D7.WDESINFCALQUE:	PUSHM.L	D4,A4	LOAD.L	A4,#(A6)+OINAFF+POSCALQUE	LOAD.B	(A4+),#'[	LOAD.W	D4,(A6)+OCALACT	; D4 <-- 7..0	SUB.W	D4,#MAXCALQUE-1	NEG.W	D4		; D4 <-- 0..7	ADD.B	D4,#'A		; D4 <-- A..H	LOAD.B	(A4+),D4	LOAD.B	(A4+),#']	CALL	DESINFMAJ	; met  jour l'cran	POPM.L	D4,A4	RET;----------\\; DESINFPAS >;==========/; Affiche le pas dans les informations.; in	(A6)+OPAS.W; out	-; mod	D7.WDESINFPAS:	PUSHM.L	D2..D4,A4	LOAD.L	A4,#(A6)+OINAFF+POSPAS	LOAD.W	D2,#11-1	LOAD.B	D3,#SPACE20$:	LOAD.B	(A4+),D3	; OINAFF <-- rempli d'espaces	DECJ.W,NMO D2,20$	TEST.B	(A6)+OGRID+3:#BGRIDPAX-0	JUMP',BC 50$	LOAD.L	A4,#(A6)+OINAFF+POSPAS	LOAD.B	(A4+),#'p	LOAD.B	(A4+),#'=	LOAD.W	D4,(A6)+OPAS	CALL	PUTUNUM		; OBUDIS <-- pas50$:	CALL	DESINFMAJ	; met  jour l'cran	POPM.L	D2..D4,A4	RET;------------\\; DESINFNBOBJ >;============/; Affiche le nombre d'objets dans les informations.; in	-; out	-; mod	D7.WDESINFNBOBJ:	PUSHM.L	D2..D4,D6,A4	LOAD.L	A4,#(A6)+OINAFF+POSNBOBJ	LOAD.W	D2,#12-1	LOAD.B	D3,#SPACE20$:	LOAD.B	(A4+),D3	; OINAFF <-- rempli d'espaces	DECJ.W,NMO D2,20$	LOAD.L	A4,#(A6)+OINAFF+POSNBOBJ	CALL	GETACH		; D6 <-- canal de l'arbre des objets	CALL	LSTA_NB		; D4 <-- nb d'lments	CONV.LA.WA D4	CALL	PUTANUM	LOAD.B	(A4+),#'/	PUSH.W	(A6)+OCALACT	CLR.W	D2	CLR.W	D340$:	LOAD.W	(A6)+OCALACT,D2	CALL	GETACH		; D6 <-- canal de l'arbre des objets	CALL	LSTA_NB		; D4 <-- nb d'lments	ADD.W	D3,D4		; D3 <-- total	INC.W	D2	COMP.W	D2,#MAXCALQUE	JUMP,LO 40$	POP.W	(A6)+OCALACT	CLR.L	D4	LOAD.W	D4,D3	CALL	PUTANUM	CALL	DESINFMAJ	; met  jour l'cran	POPM.L	D2..D4,D6,A4	RET;----------\\; DESINFOBJ >;==========/; Affiche selon l'objet dans les informations.; in	D1.W	mthode (opCRINFO/opHANDINFO/opEDITINFO);	A4.L	^objet; out	-; mod	D7.WDESINFOBJ:	PUSHM.L	D2..D4,A3	LOAD.L	A3,#(A6)+OINAFF+POSXY	LOAD.W	D2,#(POSEND-POSXY)-1	LOAD.B	D3,#SPACE20$:	LOAD.B	(A3+),D3	; OINAFF <-- rempli d'espaces	DECJ.W,NMO D2,20$	LOAD.L	A3,#(A6)+OINAFF+POSXY	LOAD.W	D3,#POSEND-POSXY	CALL	OBJCALLD	; buffer <-- texte	CALL	DESINFMAJ	; met  jour l'cran	POPM.L	D2..D4,A3	RET;-----------\\; DESINFFILE >;===========/; Affiche le nom du fichier dans les informations.; in	-; out	-; mod	D7.WDESINFFILE:	PUSHM.L	D2..D4,A3,A4	LOAD.L	A4,#(A6)+OINAFF+POSFILE	LOAD.W	D2,#20-1	LOAD.B	D3,#SPACE20$:	LOAD.B	(A4+),D3	; OINAFF <-- rempli d'espaces	DECJ.W,NMO D2,20$	LOAD.L	A4,#(A6)+OINAFF+POSFILE	LOAD.L	A3,#(A6)+OBUNAME	TEST.B	(A3)	JUMP',EQ 50$	COMP.B	(A3),#CR	JUMP',EQ 50$	LOAD.B	(A4+),#'"	LOAD.W	D3,#20-2	LOAD.W	D2,#2^BAFXMI!2^BAFXNE!2^BAFXND	LIB	?PUTXFILE	LOAD.B	(A4+),#'"50$:	CALL	DESINFMAJ	; met  jour l'cran	POPM.L	D2..D4,A3,A4	RET;----------\\; DESINFMAJ >;----------/; Met  jour la ligne des informations.; in	-; out	-; mod	D7.WDESINFMAJ:	PUSHM.L	D1..D3,A1..A3	LOAD.B	D3,#AFINV	LIB	?AFCAR		; vido inverse	LOAD.L	A1,#(A6)+OINAFF	; A1 <-- ^ligne  afficher	LOAD.L	A2,#(A6)+OINCOP	; A2 <-- ^ligne affiche actuellement	LOAD.W	D1,#100-1LOOP$:	COMP.B	(A1+),(A2+)	; une diffrence ?	JUMP',NE DIFF$		; oui => DIFF$	DECJ.W,NMO D1,LOOP$	JUMP'	EXIT$DIFF$:	DEC.L	A1	DEC.L	A2	LOAD.L	A3,#(A6)+OINAFF	LOAD.L	D3,A1	SUB.L	D3,A3	MUL.WU	D3,(A0)+ODFCX	CONV.LA.WA D3	LIB	?SETCURS	; positionne le curseur	LOAD.L	A3,A1		; A3 <-- ^dbut diffrence(s)	CLR.W	D3		; D3 <-- lg diffrence(s)COMP$:	LOAD.B	D2,(A1)	COMP.B	D2,(A2)	JUMP',EQ AFF$	LOAD.B	(A2+),(A1+)	; OINCOP <-- copie	INC.W	D3		; D3 <-- un caractre diffrent de plus	DECJ.W,NMO D1,COMP$AFF$:	LIB	?STRING		; affiche la partie change	TEST.W	D1		; reste encore qq chose ?	JUMP,NC LOOP$		; oui => LOOP$EXIT$:	LOAD.B	D3,#AFDIR	LIB	?AFCAR		; vido normale	POPM.L	D1..D3,A1..A3	RET;---------\\; DESCADRE >;=========/; Dessine le cadre de la grande matrice, avec les ascenseurs; et la grille.; in	-; out	-; mod	D7.WDESCADRE:	PUSHM.L	D2..D5,A5	CLR.L	D4	CALL	DRMDEF	LOAD.L	D3,(A6)+OWDIY1	LOAD.L	D4,(A6)+OWDIY2	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,#LGSCROLL-1	ADD.W	D4,#LGSCROLL-1	SWAP.W	D4	ADD.W	D4,#LGSCROLL-1	SWAP.W	D4	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4	PUSHM.L	D3,D4	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface toute la grande matrice	POPM.L	D3,D4	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; rectangle autour grande matrice	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	ADD.W	D4,#2	SWAP.W	D4	ADD.W	D4,#2	SWAP.W	D4	LIB	?DRRECT		; double l'paisseur	LOAD.L	A5,#(A6)+OASVER	LOAD.W	D4,(A6)+OWDIY1	DEC.W	D4	LOAD.W	(A5)+OSCDEBO,D4	LOAD.W	D4,(A6)+OWDIX1	SUB.W	D4,#LGSCROLL	LOAD.W	(A5)+OSCDEBL,D4	LOAD.W	D4,(A6)+OWDIY2	SUB.W	D4,(A6)+OWDIY1	ADD.W	D4,#2	LOAD.W	(A5)+OSCHTR,D4	CLR.B	(A5)+OSCHOR	SET.B	(A5)+OSCPAGE	LOAD.L	A5,#(A6)+OASHOR	LOAD.W	D4,(A6)+OWDIX1	DEC.W	D4	LOAD.W	(A5)+OSCDEBO,D4	LOAD.W	D4,(A6)+OWDIY2	LOAD.W	(A5)+OSCDEBL,D4	LOAD.W	D4,(A6)+OWDIX2	SUB.W	D4,(A6)+OWDIX1	ADD.W	D4,#2	LOAD.W	(A5)+OSCHTR,D4	SET.B	(A5)+OSCHOR	SET.B	(A5)+OSCPAGE	CALL	MAJCADRE	POPM.L	D2..D5,A5	RET;---------\\; MOVCADRE >;=========/; Met  jour le cadre (ascenseurs et rgles) aprs un dplacement.; in	-; out	-; mod	D7.WMOVCADRE:	PUSH.L	A5	CALL	CHGCADRE	; met  jour OWDOY2/OWDOX2	LOAD.L	A5,#(A6)+OASVER	TEST.W	(A5)+OSCHTV	JUMP',EQ 40$	LOAD.W	(A5)+OSCPOSV,(A6)+ODESY1	SCROLL_	UPDATE		; dessine la cabine verticale40$:	LOAD.L	A5,#(A6)+OASHOR	TEST.W	(A5)+OSCHTV	JUMP',EQ 60$	LOAD.W	(A5)+OSCPOSV,(A6)+ODESX1	SCROLL_	UPDATE		; dessine la cabine horizontale60$:	POP.L	A5	RET;---------\\; MAJCADRE >;=========/; Met  jour le cadre (ascenseurs et rgles) aprs un changement d'chelle.; in	-; out	-; mod	D7.WMAJCADRE:	PUSHM.L	D4,A5	CALL	CHGCADRE	; met  jour OWDOY2/OWDOX2	LOAD.L	A5,#(A6)+OASVER	SCROLL_	DRAW		; dessine la cage verticale	CLR.W	(A5)+OSCHTV	CLR.W	(A5)+OSCPOSV	LOAD.W	D4,(A6)+OWDIY2	SUB.W	D4,(A6)+OWDIY1	CALL	SCALEN	SUB.W	D4,(A6)+ODESYD	JUMP',HS 40$	NEG.W	D4	LOAD.W	(A5)+OSCHTV,D4	LOAD.W	(A5)+OSCPOSV,(A6)+ODESY1	SCROLL_	UPDATE		; dessine la cabine verticale40$:	LOAD.L	A5,#(A6)+OASHOR	SCROLL_	DRAW		; dessine la cage horizontale	CLR.W	(A5)+OSCHTV	CLR.W	(A5)+OSCPOSV	LOAD.W	D4,(A6)+OWDIX2	SUB.W	D4,(A6)+OWDIX1	CALL	SCALEN	SUB.W	D4,(A6)+ODESXD	JUMP',HS 60$	NEG.W	D4	LOAD.W	(A5)+OSCHTV,D4	LOAD.W	(A5)+OSCPOSV,(A6)+ODESX1	SCROLL_	UPDATE		; dessine la cabine horizontale60$:	POPM.L	D4,A5	RET;-----------\\; MAJOUTPAGE >;===========/; Dessine la partie grise inutilise  droite et en bas.; On ne peut pas utiliser OWDO2 car le dessin s'effectue peut-tre; dans une partie de la zone visible (sous-fentre) !; in	-; out	-; mod	D7.WMAJOUTPAGE:	PUSHM.L	D2..D6	TEST.B	(A6)+OIFPRI	; impression en cours ?	JUMP,T	EXIT$		; oui => EXIT$	CALL	LGVCADRE	; D4 <-- dimensions visibles [scr]	ADD.W	D4,(A6)+OWDIX1	SWAP.W	D4	ADD.W	D4,(A6)+OWDIY1	SWAP.W	D4	COMP.L	D4,(A6)+OWDIY2	; qq chose  griser ?	JUMP,EQ EXIT$		; non => EXIT$	LOAD.W	D5,D4		; D5 <-- OWDOX2	LOAD.L	D6,D4	SWAP.W	D6		; D6 <-- OWDOY2	CALL	WDOCLOSE2	; utilise tout l'cran	LOAD.L	D4,#H'88228822	; D4 <-- trame pour joli cran	CALL	DRMDEF	LOAD.W	D2,#LOADDOT	; D2 <-- mode	LOAD.W	D3,(A6)+OWDIY1	LOAD.W	D4,D6	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,D5	LOAD.W	D4,(A6)+OWDIX2	SUB.W	D4,D3	JUMP',EQ HORIZ$	LIB	?DRTRAME	; grise une bande  droiteHORIZ$:	LOAD.W	D3,D6	LOAD.W	D4,(A6)+OWDIY2	SUB.W	D4,D3	JUMP',EQ VERTI$	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,(A6)+OWDIX1	LOAD.W	D4,(A6)+OWDIX2	SUB.W	D4,D3	LIB	?DRTRAME	; grise une bande en basVERTI$:	CALL	WDOOPEN2	; rutilise la swdo initialeEXIT$:	POPM.L	D2..D6	RET;-------------\\; DOMASCENSEUR >;=============/; Agit dans les ascenseurs en fonction de la souris.; in	D4.L	position de la souris (y;x);	A1.L	^routine d'inversion/nil; out	D7.W	erreur; mod	D7.WDOMASCENSEUR:	PUSHM.L	D1,D3,D4,A5	LOAD.L	D1,D4		; D1 <-- position de la souris	LOAD.L	A5,#(A6)+OASVER	TEST.W	(A5)+OSCHTV	JUMP',EQ 20$	LOAD.W	(A5)+OSCPOSV,(A6)+ODESY1	SCROLL_	MOVE		; dans ascenseur vertical ?	JUMP',NE 20$	TCLR.L	D4:#16		; D4 <-- avec rptition	CALL	ASCMOVEV	; dplace l'ascenseur vertical ...	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$20$:	LOAD.L	D4,D1		; D4 <-- position de la souris	LOAD.L	A5,#(A6)+OASHOR	TEST.W	(A5)+OSCHTV	JUMP',EQ 80$	LOAD.W	(A5)+OSCPOSV,(A6)+ODESX1	SCROLL_	MOVE		; dans ascenseur horizontal ?	JUMP',NE 80$	TCLR.L	D4:#16		; D4 <-- avec rptition	CALL	ASCMOVEH	; dplace l'ascenseur horizontal ...	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$80$:	LOAD.W	D7,#1EXIT$:	POPM.L	D1,D3,D4,A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; ASCMOVEH >;=========/; Dplace l'ascenseur horizontal.; in	A5.L	^description ascenseur;	D4.L	SCROLL(F/P)(UP/DOWN);	A1.L	^routine d'inversion/nil; out	-; mod	D7.WASCMOVEH:	PUSHM.L	D2..D4	SCROLL_	PRESS		; allume le "bouton"	COMP.L	A1,#0	JUMP',EQ 06$	CALL	(A1)		; teint qq chose !06$:	LOAD.L	D2,D4		; D2 <-- "bouton" de l'ascenseur10$:	LOAD.W	D3,#+10		; D3 <-- +10 point	COMP.W	D2,#SCROLLFDOWN	JUMP',EQ 50$	NEG.W	D3		; D3 <-- -10 point	COMP.W	D2,#SCROLLFUP	JUMP',EQ 50$	LOAD.W	D3,(A6)+OWDOX2	SUB.W	D3,(A6)+OWDOX1	DEC.W	D3		; D3 <-- +1 cran	COMP.W	D2,#SCROLLPDOWN	JUMP',EQ 50$	NEG.W	D3		; D3 <-- -1 cran	COMP.W	D2,#SCROLLPUP	JUMP',EQ 50$; Dplacement absolu selon l'ascenseur.	LOAD.L	D4,(A6)+ODESY1	LOAD.W	D4,(A5)+OSCPOSV	CALL	ASCMOVE		; dplace la partie visible	JUMP'	80$; Dplacement selon la quantit dans D3.50$:	LOAD.W	D4,D3	CALL	SCALEN		; D3 <-- dplacement selon chelle	LOAD.W	D3,D4	JUMP',NE 52$	INC.W	D352$:	LOAD.L	D4,(A6)+ODESY1	ADD.W	D4,D3	CALL	ASCMOVE		; dplace la partie visible	TEST.L	D2:#16		; juste une fois ?	JUMP',BS 80$		; oui => 80$				; non =>	LIB	?IFCAR		; bouton relach ?	JUMP,NE 10$		; non => 10$80$:	LOAD.W	D4,D2	SCROLL_	PRESS		; teint le "bouton"	COMP.L	A1,#0	JUMP',EQ 86$	CALL	(A1)		; allume qq chose !86$:	POPM.L	D2..D4	RET;---------\\; ASCMOVEV >;=========/; Dplace l'ascenseur vertical.; in	A5.L	^description ascenseur;	D4.L	SCROLL(F/P)(UP/DOWN);	A1.L	^routine d'inversion/nil; out	-; mod	D7.WASCMOVEV:	PUSHM.L	D2..D4	SCROLL_	PRESS		; allume le "bouton"	COMP.L	A1,#0	JUMP',EQ 06$	CALL	(A1)		; teint qq chose !06$:	LOAD.L	D2,D4		; D2 <-- "bouton" de l'ascenseur10$:	LOAD.W	D3,#+10		; D3 <-- +10 point	COMP.W	D2,#SCROLLFDOWN	JUMP',EQ 50$	NEG.W	D3		; D3 <-- -10 point	COMP.W	D2,#SCROLLFUP	JUMP',EQ 50$	LOAD.W	D3,(A6)+OWDOY2	SUB.W	D3,(A6)+OWDOY1	DEC.W	D3		; D3 <-- +1 cran	COMP.W	D2,#SCROLLPDOWN	JUMP',EQ 50$	NEG.W	D3		; D3 <-- -1 cran	COMP.W	D2,#SCROLLPUP	JUMP',EQ 50$; Dplacement absolu selon l'ascenseur.	LOAD.L	D4,(A6)+ODESY1	SWAP.W	D4	LOAD.W	D4,(A5)+OSCPOSV	SWAP.W	D4	CALL	ASCMOVE		; dplace la partie visible	JUMP'	80$; Dplacement selon la quantit dans D3.50$:	LOAD.W	D4,D3	CALL	SCALEN		; D3 <-- dplacement selon chelle	LOAD.W	D3,D4	JUMP',NE 52$	INC.W	D352$:	LOAD.L	D4,(A6)+ODESY1	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D4	CALL	ASCMOVE		; dplace la partie visible	TEST.L	D2:#16		; juste une fois ?	JUMP',BS 80$		; oui => 80$				; non =>	LIB	?IFCAR		; bouton relach ?	JUMP,NE 10$		; non => 10$80$:	LOAD.W	D4,D2	SCROLL_	PRESS		; teint le "bouton"	COMP.L	A1,#0	JUMP',EQ 86$	CALL	(A1)		; allume qq chose !86$:	POPM.L	D2..D4	RET;--------\\; ASCMOVE >;--------/; Dplace la partie visible horizontalement ou verticalement.; in	A5.L	^description ascenseur;	D4.L	nouvelle position (y;x); out	-; mod	D7.WASCMOVE:	PUSHM.L	D3,D4	TEST.W	D4	JUMP',NC 20$	CLR.W	D420$:	COMP.W	D4,(A6)+OASHOR+OSCHTV	JUMP',LO 22$	LOAD.W	D4,(A6)+OASHOR+OSCHTV	JUMP',EQ 22$	DEC.W	D422$:	SWAP.W	D4	TEST.W	D4	JUMP',NC 30$	CLR.W	D430$:	COMP.W	D4,(A6)+OASVER+OSCHTV	JUMP',LO 32$	LOAD.W	D4,(A6)+OASVER+OSCHTV	JUMP',EQ 32$	DEC.W	D432$:	SWAP.W	D4	CALL	RNDDPOSSCALE	; D4 <-- position arrondie (contre en bas)	LOAD.L	D3,(A6)+ODESY1	LOAD.L	(A6)+ODESY1,D4	CALL	CHGCADRE	; met  jour OWDOY2/OWDOX2	LOAD.W	(A6)+OASHOR+OSCPOSV,D4	SWAP.W	D4	LOAD.W	(A6)+OASVER+OSCPOSV,D4	SCROLL_	UPDATE		; dplace l'ascenseur	LOAD.L	D4,D3		; D4 <-- ancienne position	CALL	DEMOBJETS	; dessine les objets	POPM.L	D3,D4	RET;--------\\; CLIPPOS >;========/; Diminue ventuellement la position pour ODESY1 afin de ne pas dpasser; les dimensions de la page.; in	D4.L	nouvelle position pour ODESY1; out	D4.L	nouvelle position pour ODESY1; mod	D4.L, D7.WCLIPPOS:	PUSH.L	D3	LOAD.L	D3,D4		; D3 <-- nouvelle position	TEST.W	D3	JUMP',NC 10$	CLR.W	D310$:	SWAP.W	D3	TEST.W	D3	JUMP',NC 12$	CLR.W	D312$:	SWAP.W	D3	CALL	LGVCADRE	; D4 <-- dimensions visibles [scr]	CALL	SCALEN		; D4 <-- dimensions visibles [obj]	SUB.W	D4,(A6)+ODESXD	NEG.W	D4	JUMP',NC 20$	CLR.W	D420$:	COMP.W	D3,D4	JUMP',LE 22$	LOAD.W	D3,D422$:	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,(A6)+ODESYD	NEG.W	D4	JUMP',NC 30$	CLR.W	D430$:	COMP.W	D3,D4	JUMP',LE 32$	LOAD.W	D3,D432$:	SWAP.W	D3;	SWAP.W	D4	LOAD.L	D4,D3	CALL	RNDDPOSSCALE	; D4 <-- position arrondie (contre en bas)	POP.L	D3	RET;-------------\\; RNDDPOSSCALE >;-------------/; Arrondi contre en bas une position selon l'chelle lors d'une vue d'ensemble.; in	D4.L	position quelconque (y;x); out	D4.L	position arrondie (y;x); mod	D4.L, D7.WRNDDPOSSCALE:	PUSHM.L	D2,D3	LOAD.W	D2,(A6)+OSCALE	; vue d'ensemble ?	JUMP',NC EXIT$		; non => EXIT$	NEG.W	D2	CLR.L	D3	LOAD.W	D3,D4	DIV.WA	D3,D2	MUL.WA	D3,D2	LOAD.W	D4,D3		; D4 <-- position en X arrondi	SWAP.W	D4	CLR.L	D3	LOAD.W	D3,D4	DIV.WA	D3,D2	MUL.WA	D3,D2	LOAD.W	D4,D3		; D4 <-- position en Y arrondie	SWAP.W	D4EXIT$:	POPM.L	D2,D3	RET;-------------\\; RNDUPOSSCALE >;-------------/; Arrondi contre en haut une position selon l'chelle lors d'une vue d'ensemble.; in	D4.L	position quelconque (y;x); out	D4.L	position arrondie (y;x); mod	D4.L, D7.WRNDUPOSSCALE:	PUSHM.L	D2,D3	LOAD.W	D2,(A6)+OSCALE	; vue d'ensemble ?	JUMP',NC EXIT$		; non => EXIT$	NEG.W	D2	CLR.L	D3	LOAD.W	D3,D4	ADD.W	D3,D2	DEC.W	D3	DIV.WA	D3,D2	MUL.WA	D3,D2	LOAD.W	D4,D3		; D4 <-- position en X arrondi	SWAP.W	D4	CLR.L	D3	LOAD.W	D3,D4	ADD.W	D3,D2	DEC.W	D3	DIV.WA	D3,D2	MUL.WA	D3,D2	LOAD.W	D4,D3		; D4 <-- position en Y arrondie	SWAP.W	D4EXIT$:	POPM.L	D2,D3	RET;---------\\; CHGCADRE >;=========/; Met  jour le cadre aprs un dplacement ou un changement d'chelle.; in	-; out	-; mod	D7.WCHGCADRE:	PUSH.L	D4; Si la partie visible sur l'cran peut contenir plus que la page,; dplace OWDO2 vers l'intrieur.;	WDI1=WDO1;	o---------------|-----|;	|               |     |;	|               |     |;	|               |   <---------- partie grise;	|               |     |;	|---------------o WDO2|;	|                     |;	|---------------------o  WDI2	CALL	LGVCADRE	; D4 <-- dimensions visibles [scr]	ADD.W	D4,(A6)+OWDOX1	SWAP.W	D4	ADD.W	D4,(A6)+OWDOY1	SWAP.W	D4	LOAD.L	(A6)+OWDOY2,D4; Calcule ODES2 en fonction de OWDO2.	LOAD.L	D4,(A6)+OWDOY2	SUB.W	D4,(A6)+OWDOX1	SWAP.W	D4	SUB.W	D4,(A6)+OWDOY1	SWAP.W	D4	CALL	SCALEN	ADD.W	D4,(A6)+ODESX1	SWAP.W	D4	ADD.W	D4,(A6)+ODESY1	SWAP.W	D4	TEST.W	(A6)+OSCALE	; agrandissement ?	JUMP',LE 60$		; non => 60$	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D460$:	LOAD.L	(A6)+ODESY2,D4	POP.L	D4	RET;---------\\; LGVCADRE >;=========/; Calcule les dimensions visibles  l'cran.; in	-; out	D4.L	dimensions visibles [scr]; mod	D4.L, D7.WLGVCADRE:	PUSH.L	D3	LOAD.L	D3,(A6)+OWDIY2	SUB.W	D3,(A6)+OWDIX1	SWAP.W	D3	SUB.W	D3,(A6)+OWDIY1	; D3 <-- dimensions de toute la fentre	SWAP.W	D3	TEST.W	(A6)+OSCALE	; rduction ?	JUMP',GE 30$		; non => 30$	LOAD.L	D4,(A6)+ODESYD	CALL	SCALEP		; D4 <-- dimensions de la page [scr]	COMP.W	D3,D4	JUMP',LS 20$	LOAD.W	D3,D420$:	SWAP.W	D3	SWAP.W	D4	COMP.W	D3,D4	JUMP',LS 22$	LOAD.W	D3,D422$:	SWAP.W	D3;	SWAP.W	D430$:	LOAD.L	D4,D3		; D4 <-- dimensions visibles [scr]	POP.L	D3	RET;---------\\; CALCADRE >;=========/; Calcul la position et les dimensions de la fentre principale.; in	-; out	(A6)+OWDI?1.W	fentre initiale: coin sup/gauche;	(A6)+OWDI?2.W	fentre initiale: coin inf/droite;	(A6)+OWDO?1.W	fentre: coin sup/gauche;	(A6)+OWDO?2.W	fentre: coin inf/droite; mod	D7.WCALCADRE:	PUSH.L	D3	LOAD.W	D3,#8	LOAD.W	D3,#MARGX+(GCIMX+GCICX/2+GCIMX)*3+MARGX+LGSCROLL	AND.B	D3,#B'11111000	; D3 <-- modulo 8 en X	LOAD.W	(A6)+OWDIX1,D3	LOAD.W	D3,#MARGY	ADD.W	D3,(A0)+ODFC1Y	ADD.W	D3,(A0)+ODFC2Y	AND.B	D3,#B'11111110	; D3 <-- modulo 2 en Y	LOAD.W	(A6)+OWDIY1,D3	LOAD.W	D3,(A0)+ODFFDX	SUB.W	D3,#MARGX+(GCIMX+GCICX/2+GCIMX)*3+MARGX+LGSCROLL+8	AND.B	D3,#B'11111000	; D3 <-- modulo 8 en X	ADD.W	D3,(A6)+OWDIX1	LOAD.W	(A6)+OWDIX2,D3	LOAD.W	D3,(A0)+ODFFDY	SUB.W	D3,#MARGY+MARGY+LGSCROLL	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,(A0)+ODFC2Y	AND.B	D3,#B'11111110	; D3 <-- modulo 2 en Y	ADD.W	D3,(A6)+OWDIY1	LOAD.W	(A6)+OWDIY2,D3	LOAD.L	(A6)+OWDOY1,(A6)+OWDIY1	LOAD.L	(A6)+OWDOY2,(A6)+OWDIY2	POP.L	D3	RET;----------\\; NEXTSCALE >;==========/; Cherche l'chelle suivante ou prcdente.; in	D3.W	+1 si suivante, -1 si prcdente; out	D4.W	nouvelle chelle;	D7.W	erreur; mod	D4.L, D7.WNEXTSCALE:	PUSHM.L	D3,A4	LOAD.L	A4,#R16"TASCALE-2	LOAD.W	D4,(A6)+OSCALE	LOAD.W	D7,#1		; D7 <-- impossibleLOOP$:	ADD.L	A4,#2		; A4 <-- ^suivant	COMP.W	(A4),#-1	JUMP',EQ EXIT$	COMP.W	D4,(A4)	JUMP,NE LOOP$	ASL.W	D3,#1	LOAD.W	D4,(A4)+(D3.W)	COMP.W	D4,#-1	JUMP',EQ EXIT$	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; PROXSCALE >;==========/; Cherche l'chelle la plus proche.; in	D4.W	chelle; out	D4.W	chelle la plus proche; mod	D4.L, D7.WPROXSCALE:	PUSH.L	A4	LOAD.L	A4,#R16"TASCALE-2+2LOOP$:	ADD.L	A4,#2		; A4 <-- ^suivant	COMP.W	(A4),#-1	JUMP',EQ FOUND$	COMP.W	D4,(A4)	JUMP',EQ EXIT$	JUMP,GT	LOOP$FOUND$:	LOAD.W	D4,(A4)-2	; D4 <-- chelle la plus procheEXIT$:	POP.L	A4	RET	.END