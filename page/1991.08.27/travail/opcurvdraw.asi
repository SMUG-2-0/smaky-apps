	.SBTTL	OPCURVDRAW.ASI;---------\\; CURVEADD >;=========/; Ajoute un nouveau point  une courbe.; in	A4.L	^objet;	D2.W	point  ajouter; out	D7.W	erreur; mod	D7.WCURVEADD:	PUSHM.L	D0..D6,A1..A3	LOAD.W	D7,#ERPAILOP	; D7 <-- impossible	COMP.W	(A4)+OOBNBP,#MAXNBP	JUMP,HS EXIT$	DEC.W	D2	AND.L	D2,#H'FFFF	DIV.WU	D2,#3		; D2 <-- 0..n	LOAD.L	A3,#(A4)+OOBPS	LOAD.W	D3,(A4)+OOBNBP	MUL.WU	D3,#3*4	ADD.L	A3,D3	LOAD.W	D3,(A4)+OOBNBP	SUB.W	D3,D2	DEC.W	D3	JUMP',EQ OK$	LOAD.L	A2,#(A3)+(3*4)XFER$:	LOAD.L	(-A2),(-A3)	LOAD.L	(-A2),(-A3)	LOAD.L	(-A2),(-A3)	DEC.W	D3	JUMP,NE XFER$OK$:	INC.W	(A4)+OOBNBP	LOAD.L	A1,#(A3)-(3*4)	; A1 <-- ^point prcdent	LOAD.L	A2,A3	CALL	NEXTPOINT	; A2 <-- ^point suivant	EX.L	A2,A3	LOAD.L	D3,(A1)+8	LOAD.L	D4,(A2)+0	CALL	CALCPMILIEU	LOAD.L	D0,D4	LOAD.L	D3,(A1)+4	LOAD.L	D4,(A1)+8	CALL	CALCPMILIEU	LOAD.L	D1,D4	LOAD.L	D3,(A2)+4	LOAD.L	D4,(A2)+0	CALL	CALCPMILIEU	LOAD.L	D2,D4	LOAD.L	D3,D0	LOAD.L	D4,D1	CALL	CALCPMILIEU	LOAD.L	D5,D4	LOAD.L	D3,D0	LOAD.L	D4,D2	CALL	CALCPMILIEU	LOAD.L	D6,D4	LOAD.L	D3,D5	LOAD.L	D4,D6	CALL	CALCPMILIEU	LOAD.L	(A1)+8,D1	LOAD.L	(A3)+0,D5	LOAD.L	(A3)+4,D4	LOAD.L	(A3)+8,D6	LOAD.L	(A2)+0,D2	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D6,A1..A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; CURVESUB >;=========/; Supprime un point  une courbe.; in	A4.L	^objet;	D2.W	point  supprimer; out	D7.W	erreur; mod	D7.WCURVESUB:	PUSHM.L	D2,D3,A2,A3	LOAD.W	D7,#ERPAILOP	; D7 <-- impossible	COMP.W	(A4)+OOBNBP,#2	JUMP,LS EXIT$	SUB.W	D2,#2	AND.L	D2,#H'FFFF	DIV.WU	D2,#3		; D2 <-- 0..n	LOAD.W	D3,(A4)+OOBNBP	SUB.W	D3,D2	DEC.W	D3	JUMP',EQ OK$	LOAD.L	A3,#(A4)+OOBPS	MUL.WU	D2,#3*4	ADD.L	A3,D2	LOAD.L	A2,#(A3)+(3*4)XFER$:	LOAD.L	(A3+),(A2+)	LOAD.L	(A3+),(A2+)	LOAD.L	(A3+),(A2+)	DEC.W	D3	JUMP,NE XFER$OK$:	DEC.W	(A4)+OOBNBP	CLR.W	D7		; D7 <-- okEXIT$:	CALL	CURVECOMPRESS	; compresse la courbe	POPM.L	D2,D3,A2,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; CURVELINE >;==========/; Transforme un point d'une courbe en une droite.; in	A4.L	^objet;	D2.W	point  transformer; out	D7.W	erreur; mod	D7.WCURVELINE:	PUSHM.L	D2,A2,A3	DEC.W	D2	AND.L	D2,#H'FFFF	DIV.WU	D2,#3		; D2 <-- 0..n	LOAD.L	A3,#(A4)+OOBPS	MUL.WU	D2,#3*4	ADD.L	A3,D2		; A3 <-- ^Ps,Pp,Ps dpart	LOAD.L	A2,A3	CALL	NEXTPOINT	; A2 <-- ^Ps,Pp,Ps arrive	EX.L	A2,A3	LOAD.L	(A3)+4*2,(A3)+4*1	LOAD.L	(A2)+4*0,(A2)+4*1	POPM.L	D2,A2,A3	CLR.W	D7		; retour EQ	RET;-----------\\; CURVECURVE >;===========/; Transforme un point d'une courbe en une courbe.; in	A4.L	^objet;	D2.W	point  transformer; out	D7.W	erreur; mod	D7.WCURVECURVE:	PUSHM.L	D2..D4,A2,A3	DEC.W	D2	AND.L	D2,#H'FFFF	DIV.WU	D2,#3		; D2 <-- 0..n	LOAD.L	A3,#(A4)+OOBPS	MUL.WU	D2,#3*4	ADD.L	A3,D2		; A3 <-- ^Ps,Pp,Ps dpart	LOAD.L	A2,A3	CALL	NEXTPOINT	; A2 <-- ^Ps,Pp,Ps arrive	EX.L	A2,A3	LOAD.L	D3,(A3)+4*1	LOAD.L	D4,(A2)+4*1	CALL	CALCPMILIEU	; D4 <-- point milieu	LOAD.L	D2,D4;	LOAD.L	D3,(A3)+4*1;	LOAD.L	D4,D2	CALL	CALCPMILIEU	; D4 <-- point milieu	LOAD.L	(A3)+4*2,D4	LOAD.L	D3,D2	LOAD.L	D4,(A2)+4*1	CALL	CALCPMILIEU	; D4 <-- point milieu	LOAD.L	(A2)+4*0,D4	POPM.L	D2..D4,A2,A3	CLR.W	D7		; retour EQ	RET;--------------\\; CURVECOMPRESS >;==============/; Compresse un objet courbe.; in	A4.L	^objet; out	D7.W	erreur; mod	D7.WCURVECOMPRESS:	PUSHM.L	D2,D3,A2,A3	LOAD.L	A3,#(A4)+OOBPS	; A3 <-- ^source	LOAD.L	A2,A3		; A2 <-- ^destination	LOAD.W	D2,(A4)+OOBNBP	; D2 <-- nb de points	JUMP,EQ	EXIT$LOOP$:	COMP.L	(A3),#ENDLOC	JUMP',NE XFER$	COMP.W	D2,#3		; reste-il moins de 3 points ?	JUMP',LO END$		; oui => END$	COMP.L	(A3)+12+12,#ENDLOC ; <ENDLOC> <p> <ENDLOC> ?	JUMP',NE XFER$		; non => XFER$	LOAD.L	A3,#(A3)+12+12	DEC.W	D2	JUMP'	NEXT$XFER$:	LOAD.L	(A2+),(A3+)	LOAD.L	(A2+),(A3+)	LOAD.L	(A2+),(A3+)NEXT$:	DEC.W	D2	JUMP,NE	LOOP$END$:	LOAD.L	A3,#(A4)+OOBPS	; A3 <-- ^source	LOAD.L	D3,A2	SUB.L	D3,A3	DIV.WU	D3,#4*3	LOAD.W	(A4)+OOBNBP,D3EXIT$:	POPM.L	D2,D3,A2,A3	RET;-----------\\; CURVESLINE >;===========/; Trace toutes les courbes de l'objet.; in	A3.L	^objet courbe;	D2.W	mode de dessin; out	-; mod	D7.WCURVESLINE:	PUSHM.L	D1..D6,A2,A4	CALL	IFDRSEC		; dessine les points secondaires ?	JUMP',NE NOINV$		; non => NOINV$	LIB	?AFTIM	.B	MAPTT	.B	B'10101010	.B	1	.B	0	.EVENNOINV$:	LOAD.W	D1,(A3)+OOBNBP	; D1 <-- nb de points	JUMP,EQ EXIT$	LOAD.L	A4,#(A3)+OOBPS+4 ; A4 <-- ^points	LOAD.L	A2,A4		; A2 <-- ^premier pointLOOP$:	COMP.L	(A4),#ENDLOC	JUMP,EQ NEXTLOC$	COMP.W	D1,#1		; est-ce le tout dernier point ?	JUMP',EQ ENDLOC$	; oui => ENDLOC$	COMP.L	(A4)+12,#ENDLOC	JUMP',EQ ENDLOC$	LOAD.L	D3,(A4)		; D3 <-- Pp1	LOAD.L	D4,(A4)+4	; D4 <-- Pca1	LOAD.L	D5,(A4)+8	; D5 <-- Pcb1	LOAD.L	D6,(A4)+12	; D6 <-- Pp2	JUMP'	DRAW$ENDLOC$:	TEST.B	(A3)+OOBFLG:#BFLGCLOSE	JUMP',BS CLOSE$	CALL	IFDRSEC		; dessine les points secondaires ?	JUMP,NE NEXT$		; non => NEXT$	PUSH.W	D2	LOAD.L	D3,(A4)		; D3 <-- Pp1	LOAD.L	D4,(A4)+4	; D4 <-- Pca1	TSET.L	D2:#BTTTDOT	LOAD.W	D7,#DR_LINE	PAGE_	DRAW		; dessine juste la ligne de contrle	LOAD.L	D4,(A2)-4	; D4 <-- Pca1	LOAD.L	D3,(A2)		; D3 <-- Pp1;	TSET.L	D2:#BTTTDOT	LOAD.W	D7,#DR_LINE	PAGE_	DRAW		; dessine juste la ligne de contrle	POP.W	D2	JUMP'	NEXT$CLOSE$:	LOAD.L	D3,(A4)		; D3 <-- Pp1	LOAD.L	D4,(A4)+4	; D4 <-- Pca1	LOAD.L	D5,(A2)-4	; D5 <-- Pcb1	LOAD.L	D6,(A2)		; D6 <-- Pp2DRAW$:	LOAD.W	D7,#DR_BEZIER	PAGE_	DRAW		; ferme la courbe	CALL	IFDRSEC		; dessine les points secondaires ?	JUMP',NE DEND$		; non => DEND$	PUSH.W	D2	LOAD.W	D2,#INVDOT!TTTDOT	LOAD.W	D7,#DR_LINE	PAGE_	DRAW		; dessine juste la ligne de contrle	LOAD.L	D3,D6	LOAD.L	D4,D5;	LOAD.W	D2,#INVDOT!TTTDOT	LOAD.W	D7,#DR_LINE	PAGE_	DRAW		; dessine juste la ligne de contrle	POP.W	D2DEND$:	COMP.W	D2,#INVDOT!TTTDOT ; traitill invers ?	JUMP',NE NEXT$		; non => NEXT$	TSET.L	D2:#BNCTDOT	; D2 <-- plus de rz du traitill	JUMP'	NEXT$NEXTLOC$:	LOAD.L	A2,#(A4)+12	; A2 <-- ^premier point suivantNEXT$:	LOAD.L	A4,#(A4)+12	; A4 <-- ^point suivant	DEC.W	D1	JUMP,NE LOOP$EXIT$:	POPM.L	D1..D6,A2,A4	RET;-----------\\; CURVESFILL >;===========/; Rempli toutes les courbes de l'objet.; in	A3.L	^objet courbe; out	-; mod	D7.WCURVESFILL:	PUSHM.L	D1..D6,A2,A4	LOAD.W	D1,(A3)+OOBNBP	; D1 <-- nb de points	JUMP,EQ EXIT$	LOAD.L	A4,#(A3)+OOBPS+4 ; A4 <-- ^points	LOAD.L	A2,A4		; A2 <-- ^premier pointLOOP$:	COMP.L	(A4),#ENDLOC	JUMP,EQ NEXTLOC$	COMP.W	D1,#1		; est-ce le tout dernier point ?	JUMP',EQ ENDLOC$	; oui => ENDLOC$	COMP.L	(A4)+12,#ENDLOC	JUMP',EQ ENDLOC$	LOAD.L	D3,(A4)		; D3 <-- Pp1	LOAD.L	D4,(A4)+4	; D4 <-- Pca1	LOAD.L	D5,(A4)+8	; D5 <-- Pcb1	LOAD.L	D6,(A4)+12	; D6 <-- Pp2	LOAD.W	D7,#DR_POLYBEZIER	PAGE_	DRAW		; dessine un fragment de courbe	JUMP'	NEXT$ENDLOC$:	TEST.B	(A3)+OOBFLG:#BFLGCLOSE	JUMP',BS CLOSE$	LOAD.L	D3,(A4)		; D3 <-- Pp1	LOAD.L	D4,(A2)	COMP.L	D3,D4	JUMP',EQ NEXT$	LOAD.W	D7,#DR_POLYLINE	PAGE_	DRAW		; ferme le remplissage	JUMP'	NEXT$CLOSE$:	LOAD.L	D3,(A4)		; D3 <-- Pp1	LOAD.L	D4,(A4)+4	; D4 <-- Pca1	LOAD.L	D5,(A2)-4	; D5 <-- Pcb1	LOAD.L	D6,(A2)		; D6 <-- Pp2	LOAD.W	D7,#DR_POLYBEZIER	PAGE_	DRAW		; ferme la courbe	JUMP'	NEXT$NEXTLOC$:	LOAD.L	A2,#(A4)+12	; A2 <-- ^premier point suivantNEXT$:	LOAD.L	A4,#(A4)+12	; A4 <-- ^point suivant	DEC.W	D1	JUMP,NE LOOP$EXIT$:	POPM.L	D1..D6,A2,A4	RET;----------\\; CURVESDET >;==========/; Trace toutes les courbes de l'objet.; in	A3.L	^objet courbe;	D2.W	marge;	D4.L	position souris; out	D7.W	erreur; mod	D7.WCURVESDET:	PUSHM.L	D0..D6,A2,A4	LOAD.L	D1,D4		; D1 <-- position de la souris	CLR.W	(A5)+ODETNB	; ODETNB <-- nb d'intersections	LOAD.W	(A5)+ODETPT,#1	LOAD.W	(A5)+ODETPS,#-1	LOAD.W	D0,(A3)+OOBNBP	; D0 <-- nb de points	JUMP,EQ EXIT$	LOAD.L	A4,#(A3)+OOBPS+4 ; A4 <-- ^points	LOAD.L	A2,A4		; A2 <-- ^premier pointLOOP$:	COMP.L	(A4),#ENDLOC	JUMP,EQ NEXTLOC$	COMP.W	D0,#1		; est-ce le tout dernier point ?	JUMP',EQ ENDLOC$	; oui => ENDLOC$	COMP.L	(A4)+12,#ENDLOC	JUMP',EQ ENDLOC$	LOAD.L	D3,(A4)		; D3 <-- Pp1	LOAD.L	D4,(A4)+4	; D4 <-- Pca1	LOAD.L	D5,(A4)+8	; D5 <-- Pcb1	LOAD.L	D6,(A4)+12	; D6 <-- Pp2	JUMP'	DET$ENDLOC$:	TEST.B	(A3)+OOBFLG:#BFLGCLOSE	JUMP',BS CLOSE$	JUMP'	NEXT$CLOSE$:	LOAD.L	D3,(A4)		; D3 <-- Pp1	LOAD.L	D4,(A4)+4	; D4 <-- Pca1	LOAD.L	D5,(A2)-4	; D5 <-- Pcb1	LOAD.L	D6,(A2)		; D6 <-- Pp2DET$:	LOAD.W	D7,#MA_DETBEZIER	PAGE_	MATH		; dtecte un fragment de courbe	JUMP',NE NEXT$	INC.W	(A5)+ODETNB	; ODETNB <-- une intersection de plus	LOAD.W	(A5)+ODETPS,(A5)+ODETPT	JUMP'	NEXT$NEXTLOC$:	LOAD.L	A2,#(A4)+12	; A2 <-- ^premier point suivantNEXT$:	LOAD.L	A4,#(A4)+12	; A4 <-- ^point suivant	ADD.W	(A5)+ODETPT,#3	DEC.W	D0	JUMP,NE LOOP$EXIT$:	CLR.W	D7		; D7 <-- ok	TEST.W	(A5)+ODETNB	; au moins une intersection ?	JUMP',NE QUIT$		; oui => QUIT$	LOAD.W	D7,#ERDIOUT	; D7 <-- en dehors de la droiteQUIT$:	POPM.L	D0..D6,A2,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; CURVESBBOX >;===========/; Trace toutes les courbes de l'objet.; in	A3.L	^objet courbe; out	-; mod	D7.WCURVESBBOX:	PUSHM.L	D0..D6,A1,A2,A4	LOAD.L	(A5)+OBBOX1,#H'7FFF7FFF	LOAD.L	(A5)+OBBOX2,#H'80008000	LOAD.W	D0,(A3)+OOBNBP	; D0 <-- nb de points	JUMP,EQ EXIT$	LOAD.L	A4,#(A3)+OOBPS+4 ; A4 <-- ^points	LOAD.L	A2,A4		; A2 <-- ^premier pointLOOP$:	COMP.L	(A4),#ENDLOC	JUMP,EQ NEXTLOC$	COMP.W	D0,#1		; est-ce le tout dernier point ?	JUMP',EQ ENDLOC$	; oui => ENDLOC$	COMP.L	(A4)+12,#ENDLOC	JUMP',EQ ENDLOC$	LOAD.L	D3,(A4)		; D3 <-- Pp1	LOAD.L	D4,(A4)+4	; D4 <-- Pca1	LOAD.L	D5,(A4)+8	; D5 <-- Pcb1	LOAD.L	D6,(A4)+12	; D6 <-- Pp2	JUMP'	CALC$ENDLOC$:	TEST.B	(A3)+OOBFLG:#BFLGCLOSE	JUMP',BS CLOSE$	JUMP'	NEXT$CLOSE$:	LOAD.L	D3,(A4)		; D3 <-- Pp1	LOAD.L	D4,(A4)+4	; D4 <-- Pca1	LOAD.L	D5,(A2)-4	; D5 <-- Pcb1	LOAD.L	D6,(A2)		; D6 <-- Pp2CALC$:	LOAD.W	D7,#MA_BBOXBEZIER	PAGE_	MATH		; calcule un fragment de courbe	LOAD.L	D1,(A5)+OBBOX1	LOAD.L	D2,(A5)+OBBOX2	LOAD.W	D7,#MA_RECTOR	LOAD.L	A1,(A5)+OADMATH	CALL	(A1)		; PAGE_MATH, D3/D4 <-- rectangle englobant	LOAD.L	(A5)+OBBOX1,D3	LOAD.L	(A5)+OBBOX2,D4	JUMP'	NEXT$NEXTLOC$:	LOAD.L	A2,#(A4)+12	; A2 <-- ^premier point suivantNEXT$:	LOAD.L	A4,#(A4)+12	; A4 <-- ^point suivant	DEC.W	D0	JUMP,NE LOOP$EXIT$:	POPM.L	D0..D6,A1,A2,A4	RET;--------\\; CURVE2  >;========/; Inverse deux courbes, celle avant et celle aprs le point dplac.; in	A4.L	^objet courbe;	D2.W	point dplac (0..n); out	-; mod	D7.WCURVE2:	PUSHM.L	D2..D6,A1..A3	LOAD.W	D3,D2	MUL.WU	D3,#3*4	LOAD.L	A2,#(A4)+(D3.L)+OOBPS ; A2 <-- ^point milieu	LOAD.L	A3,A2	CALL	PREVPOINT	LOAD.L	A1,A3		; A1 <-- ^point dbut	COMP.L	A1,A2	JUMP',EQ BEG2$	JUMP',LO BEG4$	TEST.B	(A4)+OOBFLG:#BFLGCLOSE ; courbe ferme ?	JUMP',BS BEG4$		; oui => BEG4$BEG2$:	LOAD.L	A1,#0		; A1 <-- pas de point dbutBEG4$:	LOAD.L	A3,A2	CALL	NEXTPOINT	; A3 <-- ^point fin	COMP.L	A3,A2	JUMP',EQ END2$	JUMP',HI END4$	TEST.B	(A4)+OOBFLG:#BFLGCLOSE ; courbe ferme ?	JUMP',BS END4$		; oui => END4$END2$:	LOAD.L	A3,#0		; A1 <-- pas de point finEND4$:	SET.B	(A5)+ONOSEC	; ne dessine pas les points secondaires !	LOAD.L	D3,A1		; point dbut existe ?	JUMP',EQ NOT1$	LOAD.L	D3,(A1)+4	LOAD.L	D4,(A1)+8	LOAD.L	D5,(A2)+0	LOAD.L	D6,(A2)+4	LOAD.W	D2,#INVDOT	LOAD.W	D7,#DR_BEZIER	PAGE_	DRAW		; dessine un fragment de courbeNOT1$:	LOAD.L	D3,A3		; point fin existe ?	JUMP',EQ NOT2$	LOAD.L	D3,(A2)+4	LOAD.L	D4,(A2)+8	LOAD.L	D5,(A3)+0	LOAD.L	D6,(A3)+4	LOAD.W	D2,#INVDOT	LOAD.W	D7,#DR_BEZIER	PAGE_	DRAW		; dessine un fragment de courbeNOT2$:	CLR.B	(A5)+ONOSEC	LIB	?AFTIM	.B	MAPTT	.B	B'10101010	.B	1	.B	0	.EVEN	LOAD.L	D3,(A2)+4	LOAD.L	D4,(A2)+0	LOAD.W	D2,#INVDOT!TTTDOT	LOAD.W	D7,#DR_LINE	PAGE_	DRAW		; dessine juste la ligne de contrle;	LOAD.L	D3,(A2)+4	LOAD.L	D4,(A2)+8;	LOAD.W	D2,#INVDOT!TTTDOT	LOAD.W	D7,#DR_LINE	PAGE_	DRAW		; dessine juste la ligne de contrle	POPM.L	D2..D6,A1..A3	RET;--------\\; IFDRSEC >;--------/; Regarde s'il faut dessiner les points secondaires.; in	D2.W	mode de dessin; out	D7.W	EQ si dessin; mod	D7.WIFDRSEC:	LOAD.W	D7,#1		; D7 <-- ne dessine pas	TEST.B	(A5)+ONOSEC	JUMP',NE EXIT$	COMP.W	D2,#INVDOT	JUMP',NE EXIT$	TEST.B	(A5)+OCREAT	; cration ?	JUMP',T DRAW$	TEST.B	(A5)+OHAND	JUMP',F EXIT$	COMP.W	(A5)+OOUTIL,#ICOHMOVE	JUMP',EQ DRAW$	COMP.W	(A5)+OOUTIL,#ICOHNEW	JUMP',EQ DRAW$	COMP.W	(A5)+OOUTIL,#ICOHLINE	JUMP',EQ DRAW$	COMP.W	(A5)+OOUTIL,#ICOHCURVE	JUMP',NE EXIT$DRAW$:	CLR.W	D7		; D7 <-- dessineEXIT$:	TEST.W	D7		; retour EQ/NE	RET;------------\\; CALCPMILIEU >;============/; Calcule le point milieu d'un segment.; in	D3.L	P1 (y;x);	D4.L	P2 (y;x); out	D4.L	M (y;x); mod	D4.L, D7.WCALCPMILIEU:	SUB.W	D4,D3	ASR.W	D4,#1	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	ASR.W	D4,#1	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	RET;---------\\; CALCPSYM >;=========/; Calcule une symtrie centrale pour un point.; in	D3.L	centre (y;x);	D4.L	point (y;x); out	D4.L	symtrique (y;x); mod	D4.L, D7.WCALCPSYM:	SUB.W	D4,D3	NEG.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	NEG.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	RET;-----------\\; CALCSYTOUR >;===========/; Calcule le point P2' en fonction de P1, P2 et C.; Les distances P2-C et P2'-C doivent rester identiques.;	         P2' o;	            /;	           /;	        C /      P2;	         o-------o;	        /;	       /;	      /;	     /;	 P1 o; in	D3.L	C   (y;x);	D4.L	P1  (y;x);	D5.L	P2  (y;x);	D6.W	lg  (-1 si inconnue); out	D5.L	P2' (y;x);	D6.W	lg; mod	D5.L, D6.L, D7.WCALCSYTOUR:	PUSHM.L	D1..D4	SUB.W	D4,D3	SUB.W	D5,D3	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	SUB.W	D4,D3	SUB.W	D5,D3	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	COMP.W	D6,#-1		; longueur initiale connue ?	JUMP',NE 20$		; oui => 20$	PUSHM.L	D3,D4	LOAD.L	D3,D5	LIB	?CALCHYPO	LOAD.W	D6,D4		; D6 <-- longueur initiale	POPM.L	D3,D420$:	LOAD.W	D1,D4	NEG.W	D1		; D1 <-- symtrique de P1 selon C en X	LOAD.L	D2,D4	SWAP.W	D2	NEG.W	D2		; D2 <-- symtrique de P1 selon C en Y	PUSH.L	D3	LOAD.L	D3,D4	LIB	?CALCHYPO	; D4 <-- nouvelle longueur	POP.L	D3	TEST.W	D4	JUMP',EQ 50$	MUL.WA	D1,D6	DIV.WA	D1,D4	MUL.WA	D2,D6	DIV.WA	D2,D450$:	LOAD.W	D5,D2	SWAP.W	D5	LOAD.W	D5,D1	ADD.W	D5,D3	SWAP.W	D3	SWAP.W	D5	ADD.W	D5,D3;	SWAP.W	D3	SWAP.W	D590$:	POPM.L	D1..D4	RET;----------\\; NEXTPOINT >;==========/; Cherche le point suivant.; in	A4.L	^objet;	A3.L	^point; out	A3.L	^point suivant; mod	A3.LNEXTPOINT:	PUSHM.L	D3,A2	LOAD.L	A2,#(A4)+OOBPS	LOAD.L	D3,A3	SUB.L	D3,A2	DIV.WU	D3,#12		; D3 <-- rang du point	INC.W	D3	COMP.W	D3,(A4)+OOBNBP	; est-ce le tout dernier point ?	JUMP',HS FIRST$		; oui => FIRST$	COMP.L	(A3)+12,#ENDLOC	; est-ce une fin locale ?	JUMP',EQ FIRST$		; oui => FIRST$	LOAD.L	A3,#(A3)+12	; A3 <-- ^point suivant	JUMP'	EXIT$FIRST$:	COMP.L	A3,A2	JUMP',EQ EXIT$	COMP.L	(A3)-12,#ENDLOC	JUMP',EQ EXIT$	LOAD.L	A3,#(A3)-12	; A3 <-- ^point prcdent	JUMP	FIRST$EXIT$:	POPM.L	D3,A2	RET;----------\\; PREVPOINT >;==========/; Cherche le point prcdent.; in	A4.L	^objet;	A3.L	^point; out	A3.L	^point prcdent; mod	A3.LPREVPOINT:	PUSHM.L	D3,A2	LOAD.L	A2,#(A4)+OOBPS	LOAD.L	D3,A3	SUB.L	D3,A2	DIV.WU	D3,#12		; D3 <-- rang du point	TEST.W	D3		; est-ce le tout premier point ?	JUMP',EQ LAST$		; oui => LAST$	COMP.L	(A3)-12,#ENDLOC	; est-ce une fin locale ?	JUMP',EQ LAST$		; oui => LAST$	LOAD.L	A3,#(A3)-12	; A3 <-- ^point prcdent	JUMP'	EXIT$LAST$:	INC.W	D3	COMP.W	D3,(A4)+OOBNBP	JUMP',EQ EXIT$	COMP.L	(A3)+12,#ENDLOC	JUMP',EQ EXIT$	LOAD.L	A3,#(A3)+12	; A3 <-- ^point suivant	JUMP	LAST$EXIT$:	POPM.L	D3,A2	RET	.END