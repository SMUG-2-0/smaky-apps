	.SBTTL	PAGEIO.ASIDOPREND:	CLR.B	(A6)+OBUFINDOPRENDL:	LOAD.L	A3,#(A6)+OBUFIN	CALL	DBOXEDITI	JUMP,NE _ERROR	COMP.W	D3,#F0	JUMP,EQ _LOOP	LOAD.W	D0,#1		; D0 <-- avant de reprendre	CALL	DBOXSAVE	; sauve si ncessaire le dessin actuel	JUMP',EQ DOPRENDF	; ok => DOPRENDF	COMP.W	D7,#1		; (ANNULE) ?	JUMP,EQ _LOOP		; oui => _LOOP	JUMP	_ERROR		; non => _ERRORDOPRENDF:	CALL	PRENDTOUT	; lit un fichier .PAGE	JUMP',EQ 50$	COMP.W	D7,#ERKSTO	JUMP',EQ 80$	CALL	DBOXERROR	; affiche l'erreur ...	JUMP	DOPRENDL50$:	LOAD.L	A3,#(A6)+OBUFIN	CALL	SAVFILE		; OBUNAME <-- nom	CLR.B	(A6)+OMAJ	; le dessin est  jour80$:	CALL	DESINFSCALE	; affiche l'chelle	CALL	DESINFPAS	; affiche le pas	CALL	DESINFNBOBJ	; affiche le nombre d'objets	CALL	DESINFFILE	; affiche le nom du dessin	CALL	MAJCADRE	; mj cadre (ascenseurs et rgles)	.IF	PROTECT	LIB	?RDCLOCK	; D4 <-- "-jma"	JUMP',NE PASS$	RR.W	D4,#8	SWAP.W	D4	SL.W	D4,#8	SR.L	D4,#8		; D4 <-- "-amj"	COMP.L	D4,#PROTDATE	; migros data dpass ?	JUMP',LO PASS$		; non => PASS$				; oui =>	LOAD.L	A3,#R16"PNAME$	FOS	?DELETE		; dtruit PAGE.CODE !	JUMP	_ERFATPASS$:	.ENDIF	CLR.W	(A6)+OPAGE	JUMP	_DOPAGE	.IF	PROTECTPNAME$:	.ASCIZ	"#:PAGE.CODE"	.EVEN	.ENDIFDOSAUVE:	CLR.W	D2		; D2 <-- mode manuel	CALL	SAUVETOUT	; sauve toutes les pages	JUMP,NE _ERROR	JUMP	_LOOPDOAJOUTE:	LOAD.L	A3,#(A6)+OBUFADD	CALL	DBOXEDITA	; demande le nom ...	JUMP,NE _ERROR	COMP.W	D3,#F1	JUMP,NE _LOOP	CALL	PRENDSELECT	; lit un fichier .LPAGE	JUMP',EQ 50$	PUSH.W	D7	CALL	_ZONEDESELECT	; dslectionne les objets lus	POP.W	D7	COMP.W	D7,#ERKSTO	JUMP,EQ _LOOP	CALL	DBOXERROR	; affiche l'erreur ...	JUMP	DOAJOUTE50$:	CALL	DESINFNBOBJ	; affiche le nombre d'objets	JUMP	_SELIO;----------\\; PRENDTOUT >;==========/; Lit un fichier .PAGE.; in	A3.L	^nom; out	D7.W	erreur; mod	D7.WPRENDTOUT:	PUSHM.L	D3,D4,D6,A3,A4	CALL	WAITMOUSE	; met le sablier	LOAD.L	A4,#R16"TEXPA	; A4 <-- ^extension	CALL	ADDEXT		; A3 <-- ^nom du fichier .PAGE	CALL	RDOPEN		; ouvre le fichier en entre	JUMP,NE EXIT$	CALL	RDHEAD		; lit l'en-tte (D3=rvision)	JUMP,NE CLOSE$	COMP.W	D3,#H'100*2+0	; < que PAGE 2.0 ?	JUMP',LO OLD$		; oui => OLD$NEW$:	LOAD.L	A4,(A6)+OOBACH	CALL	LSTA_FLUSH	; efface tout le document	LOAD.L	(A6)+OARLIM,(A6)+ODFACH	CALL	RDARBREDF	; lit toutes les dfinitions	JUMP,NE CLOSE$	LOAD.L	(A6)+OARLIM,(A6)+OOBACH	CALL	RDARBRE		; lit tout le document	JUMP	CLOSE$OLD$:	LOAD.L	(A6)+OARLIM,(A6)+ODFACH	COMP.W	D3,#H'100*0+3	; <= que PAGE 0.3 ?	JUMP',LS OLDDF$		; oui => OLDDF$	CALL	RDARBREDF	; lit toutes les dfinitions	JUMP',NE CLOSE$	JUMP'	OBJ$OLDDF$:	CALL	RDARBREOLDDF	; saute toutes les anciennes dfinitions	JUMP',NE CLOSE$;	JUMP'	OBJ$OBJ$:	LOAD.L	A4,(A6)+OOBACH	CALL	LSTA_FLUSH	; efface tout le document	CLR.W	D4	CALL	GROUPNEWPAGE	; cre une page unique	JUMP',NE CLOSE$	CLR.W	(A6)+OPAGE;	CLR.W	D4	JUMP'	CALQUE2$CALQUE$:	CALL	GROUPNEWCALQUE	; cre un calque	JUMP',NE CLOSE$CALQUE2$:	LOAD.W	D3,(A6)+OPAGE	; D3 <-- page visible	LOAD.L	D6,(A6)+OOBACH	; D6 <-- canal de l'arbre des objets	CALL	LSTA_BEGIN	; A4 <-- ^calque pre (init OARLIM !)	JUMP',NE CLOSE$	CALL	RDARBRE		; lit tout le calque	JUMP',NE CLOSE$	INC.W	D4	COMP.W	D4,#8		; les anciens fichiers avaient 8 calques !	JUMP,LO CALQUE$CLOSE$:	CALL	RDCLOSE		; ferme le fichier en entreEXIT$:	POPM.L	D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; SAUVETOUT >;==========/; Sauve un fichier .PAGE.; in	D2.W	mode; out	D7.W	erreur; mod	D7.WSAUVETOUT:	PUSHM.L	D0..D6,A3,A4	LOAD.L	A3,#(A6)+OBUFOUT	CALL	GETFILE		; OBUFOUT <-- OBUNAME	CLR.L	D5	TEST.B	(A6)+OMAJ	; mise  jour ncessaire ?	JUMP',T EDIT$		; oui => EDIT$	TSET.L	D2:#BDBNMAJ	; D2 <-- touche (MET A JOUR) griseEDIT$:	LOAD.L	A3,#(A6)+OBUFOUT	TEST.B	(A3)		; nom existe ?	JUMP',EQ EDIT2$		; non => EDIT2$	TEST.L	D2:#BDBAUTO	; sauvetage automatique ?	JUMP',BS CREATE$	; oui => CREATE$EDIT2$:	LOAD.L	D4,D5		; D4 <-- fanions	CALL	DBOXEDITO	JUMP,NE QUIT$	COMP.W	D3,#F0	JUMP,EQ QUIT$	LOAD.W	D1,D3		; D1 <-- F1/F4	LOAD.L	D5,D4		; D5 <-- fanions	CALL	WAITMOUSE	; met le sablier	LOAD.L	A4,#R16"TEXPA	; A4 <-- ^extension	CALL	ADDEXT		; A3 <-- ^nom du fichier avec extensionCREATE$:	LOAD.L	D3,#DEFATT	; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	LOAD.L	D0,#FOS?CREATE	CALL	ERCALL		; cre le fichier	JUMP,EQ WRITE$		; ok => WRITE$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE	EXIT$		; non => EXIT$				; oui =>	TEST.L	D2:#BDBAUTO	; sauvetage automatique ?	JUMP',BS DELETE$	; oui => DELETE$	COMP.W	D1,#F4		; touche (MET A JOUR) ?	JUMP',EQ DELETE$	; oui => DELETE$	CALL	NORMMOUSE	; remet la flche	PUSH.L	D2	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	POP.L	D2	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	POP.W	D7	JUMP,NE EXIT$	COMP.W	D3,#'O	JUMP,NE EDIT$DELETE$:	LOAD.L	D0,#FOS?DELETE	CALL	ERCALL		; dtruit le fichier	JUMP,NE EXIT$	JUMP	CREATE$WRITE$:	CALL	WAITMOUSE	; met le sablier	CALL	WROPEN		; ouvre le fichier en sortie	JUMP',NE EXIT$	CALL	WRHEAD		; crit l'en-tte	JUMP',NE CLOSE$	LOAD.L	D6,(A6)+ODFACH	CALL	WRARBREDF	; crit toutes les dfinitions	JUMP',NE CLOSE$	LOAD.L	D6,(A6)+OOBACH	CALL	WRARBRE		; crit toutes les pagesCLOSE$:	CALL	WRCLOSE		; ferme le fichier en sortie	JUMP',NE CLOSE$	CALL	WRASSALL	; crit les fichiers associs (fichier "!")EXIT$:	TEST.W	D7		; ok =	JUMP',NE QUIT$		; non => QUIT$	LOAD.L	A3,#(A6)+OBUFOUT	CALL	SAVFILE		; OBUNAME <-- nom	CALL	DESINFFILE	; affiche le nom dans les infos	CLR.B	(A6)+OMAJ	; le dessin est  jour	CLR.W	D7		; D7 <-- okQUIT$:	POPM.L	D0..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; EFFACETOUT >;===========/; Efface tous les objets de tous les calques dans la page courante.; in	-; out	-; mod	D7.WEFFACETOUT:	PUSHM.L	D3,D4,D6,A4	CLR.W	D4LOOP$:	LOAD.W	D3,(A6)+OPAGE	; D3 <-- page visible	LOAD.L	D6,(A6)+OOBACH	; D6 <-- canal de l'arbre des objets	CALL	LSTA_BEGIN	; A4 <-- ^calque pre	JUMP',NE EXIT$	CALL	LSTA_FLUSH	; efface le calque	INC.W	D4		; D4 <-- calque suivant	JUMP	LOOP$EXIT$:	POPM.L	D3,D4,D6,A4	RET;------------\\; PRENDSELECT >;============/; Ajoute un fichier .LPAGE.; in	A3.L	^nom; out	D7.W	erreur; mod	D7.WPRENDSELECT:	PUSHM.L	D4,A3,A4	CALL	WAITMOUSE	; met le sablier	LOAD.L	A4,#R16"TEXLPA	; A4 <-- ^extension	CALL	ADDEXT		; A3 <-- ^nom du fichier .LPAGE	CALL	RDOPEN		; ouvre le fichier en entre	JUMP',NE EXIT$	CALL	RDHEADSEL	; lit l'en-tte	JUMP',NE CLOSE$	CALL	RDARBRESEL	; lit dans le calqueCLOSE$:	CALL	RDCLOSE		; ferme le fichier en entreEXIT$:	POPM.L	D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; SAUVESELECT >;============/; Sauve les objets slectionns dans un fichier .LPAGE.; in	-; out	D7.W	erreur; mod	D7.WSAUVESELECT:	PUSHM.L	D0..D6,A0,A2..A4	LOAD.L	D3,(A6)+OZONY1	LOAD.L	D4,D3	LOAD.L	D1,(A6)+OZONY2	LOAD.L	D2,D1	CALL	RECTOR	LOAD.L	D1,(A6)+OZONY3	LOAD.L	D2,D1	CALL	RECTOR	LOAD.L	D1,(A6)+OZONY4	LOAD.L	D2,D1	CALL	RECTOR	LOAD.L	(A6)+OIOY1,D3	; OIOY1 <-- coin sup/gauche	LOAD.L	(A6)+OIOY2,D4	; OIOY2 <-- coin inf/droite	CLR.B	(A6)+OBUFOUTEDIT$:	LOAD.L	A3,#(A6)+OBUFOUT	LOAD.L	D4,(A6)+OFAEXT	; D4 <-- fanions	CALL	DBOXEDITE	; demande le nom ...	JUMP,NE EXIT$	COMP.W	D3,#F1	JUMP,NE EXIT$	LOAD.L	(A6)+OFAEXT,D4	TEST.L	D4:#14	JUMP,BS IMAGE$; Sauve dans un fichier .LPAGE :	CALL	WAITMOUSE	; met le sablier	LOAD.L	A4,#R16"TEXLPA	; A4 <-- ^extension	CALL	ADDEXT		; A3 <-- ^nom du fichier avec extensionPCREATE$:	LOAD.L	D3,#DEFATT	; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	LOAD.L	D0,#FOS?CREATE	CALL	ERCALL		; cre le fichier	JUMP',EQ PWRITE$	; ok => PWRITE$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE	EXIT$		; non => EXIT$				; oui =>	CALL	NORMMOUSE	; remet la flche	PUSH.L	D2	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	POP.L	D2	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	POP.W	D7	JUMP,NE EXIT$	COMP.W	D3,#'O	JUMP,NE EDIT$	LOAD.L	D0,#FOS?DELETE	CALL	ERCALL		; dtruit le fichier	JUMP,NE EXIT$	JUMP	PCREATE$PWRITE$:	CALL	WAITMOUSE	; met le sablier	CALL	WROPEN		; ouvre le fichier en sortie	JUMP,NE EXIT$	CALL	_ZONEMOVEBC	; dbut du dplacement	LOAD.L	A2,#R16"DEPL1$	; A2 <-- ^routine de transformation	CALL	_ZONEMOVEDC	; dplace tous les objets	PUSH.L	(A6)+ODESYD	LOAD.L	D4,(A6)+OIOY2	SUB.W	D4,(A6)+OIOY1+2	SWAP.W	D4	SUB.W	D4,(A6)+OIOY1+0	SWAP.W	D4	LOAD.L	(A6)+ODESYD,D4	; ODESYD <-- dimensions de la zone	CALL	WRHEAD		; crit l'en-tte	POP.L	(A6)+ODESYD	TEST.W	D7	JUMP',NE PCLOSE$	LOAD.L	D6,(A6)+OOBACH	; D6 <-- canal de l'arbre des objets	CALL	WRARBRESEL	; crit tous les objets slectionnsPCLOSE$:	PUSH.W	D7	LOAD.L	A2,#R16"DEPL2$	; A2 <-- ^routine de transformation	CALL	_ZONEMOVEDC	; dplace tous les objets	CALL	_ZONEMOVEEC	; fin du dplacement	POP.W	D7	CALL	WRCLOSE		; ferme le fichier en sortie	JUMP	EXIT$; Sauve dans un fichier .IMAGE :IMAGE$:	LOAD.W	D4,(A6)+OIOY2+2	SUB.W	D4,(A6)+OIOY1+2	CALL	SCALEP	LOAD.W	(A6)+ODBIMX,D4	LOAD.W	D0,D4		; D0 <-- largeur	LOAD.W	D4,(A6)+OIOY2+0	SUB.W	D4,(A6)+OIOY1+0	CALL	SCALEP	LOAD.W	(A6)+ODBIMY,D4	LOAD.W	D1,D4		; D1 <-- hauteur	CALL	DBOXDIMIMAGE	; demande les dimensions ...	JUMP,NE EXIT$	COMP.W	D3,#F1	JUMP,NE EXIT$	LOAD.W	D4,(A6)+ODBIMX	ADD.W	D4,#16-1	AND.B	D4,#B'11110000	LOAD.W	(A6)+ODBIMX,D4;	LOAD.W	D4,(A6)+ODBIMX	MUL.WU	D4,D1	DIV.WU	D4,D0	LOAD.W	(A6)+ODBIMY,D4	CALL	WAITMOUSE	; met le sablier	LOAD.L	A4,#R16"TEXIM	; A4 <-- ^extension	CALL	ADDEXT		; A3 <-- ^nom du fichier avec extensionICREATE$:	LOAD.L	D3,#DEFATT	; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	LOAD.L	D0,#FOS?CREATE	CALL	ERCALL		; cre le fichier	JUMP',EQ IWRITE$	; ok => IWRITE$	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP,NE	EXIT$		; non => EXIT$				; oui =>	CALL	NORMMOUSE	; remet la flche	PUSH.L	D2	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	POP.L	D2	PUSH.W	D7	CALL	AFMENU		; refait les soft-keys	POP.W	D7	JUMP,NE EXIT$	COMP.W	D3,#'O	JUMP,NE EDIT$	LOAD.L	D0,#FOS?DELETE	CALL	ERCALL		; dtruit le fichier	JUMP,NE EXIT$	JUMP	ICREATE$IWRITE$:	CALL	WAITMOUSE	; met le sablier	LOAD.W	D4,(A6)+ODBIMX	SR.W	D4,#3	MUL.WU	D4,(A6)+ODBIMY	ADD.L	D4,#LGHIMA+IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour image	JUMP,NE IDELETE$	GESMEM	?CLEARMEM	LOAD.L	A2,A4	LOAD.B	(A2)+OIMTYP,#H'81	LOAD.B	(A2)+OIMCOD,#H'00	LOAD.B	(A2)+OIMBIP,#H'01	LOAD.B	(A2)+OIMDIR,#H'02	LOAD.W	(A2)+OIMDLX,(A6)+ODBIMX	LOAD.W	(A2)+OIMDLY,(A6)+ODBIMY	SUB.L	D4,#LGHIMA+IMLBUF	LOAD.L	(A2)+OIMNBB,D4	PUSH.L	(A6)+OPRINT	PUSH.L	(A6)+OVUE	PUSH.L	(A6)+OGRID	PUSH.L	(A6)+OWDIY1	PUSH.L	(A6)+OWDIY2	PUSH.L	(A6)+OWDOY1	PUSH.L	(A6)+OWDOY2	PUSH.L	(A6)+ODESY1	PUSH.L	(A6)+ODESY2	SET.B	(A6)+OIFPRI	; impression en cours	LOAD.L	(A6)+OPRINT,(A6)+OFADIM	LOAD.L	(A6)+OVUE,#-1	LOAD.L	(A6)+OGRID,#2^BGRIDPAN!2^BGRIDMU4!2^BGRIDGRN	LOAD.W	D3,(A6)+OIOY1+2	LOAD.W	D4,(A6)+OIOY2+2	LOAD.W	(A6)+ODESX1,D3	LOAD.W	(A6)+ODESX2,D4	SUB.W	D4,D3	LOAD.W	(A6)+OSCAP2X,D4	LOAD.W	(A6)+OSCAP1X,(A6)+ODBIMX	LOAD.W	D3,(A6)+OIOY1+0	LOAD.W	D4,(A6)+OIOY2+0	LOAD.W	(A6)+ODESY1,D3	LOAD.W	(A6)+ODESY2,D4	SUB.W	D4,D3	LOAD.W	(A6)+OSCAP2Y,D4	LOAD.W	(A6)+OSCAP1Y,(A6)+ODBIMY	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre	PUSH.L	(A0)+ODFABS	PUSH.L	(A0)+ODFY	PUSH.L	(A0)+ODFDY	PUSH.L	(A0)+ODFFY	PUSH.L	(A0)+ODFFDY	PUSH.L	(A0)+ODFWBY	PUSH.L	(A0)+ODFWEY	PUSH.W	(A0)+ODFIIX	PUSH.W	(A0)+ODFIIY	LOAD.L	A4,#(A2)+LGHIMA+IMLBUF	LOAD.L	(A0)+ODFABS,A4	LOAD.L	D4,(A6)+ODBIMY	CLR.L	(A6)+OWDIY1	LOAD.L	(A6)+OWDIY2,D4	CLR.L	(A6)+OWDOY1	LOAD.L	(A6)+OWDOY2,D4	CLR.L	(A0)+ODFY	LOAD.L	(A0)+ODFDY,D4	CLR.L	(A0)+ODFFY	LOAD.L	(A0)+ODFFDY,D4	CLR.L	(A0)+ODFWBY	LOAD.L	(A0)+ODFWEY,D4	LOAD.W	(A0)+ODFIIX,#1	SR.W	D4,#3	LOAD.W	(A0)+ODFIIY,D4	CALL	DESOBJETS	; dessine tous les objets	POP.W	(A0)+ODFIIY	POP.W	(A0)+ODFIIX	POP.L	(A0)+ODFWEY	POP.L	(A0)+ODFWBY	POP.L	(A0)+ODFFDY	POP.L	(A0)+ODFFY	POP.L	(A0)+ODFDY	POP.L	(A0)+ODFY	POP.L	(A0)+ODFABS	CLR.B	(A6)+OIFPRI	; fin de l'impression	POP.L	(A6)+ODESY2	POP.L	(A6)+ODESY1	POP.L	(A6)+OWDOY2	POP.L	(A6)+OWDOY1	POP.L	(A6)+OWDIY2	POP.L	(A6)+OWDIY1	POP.L	(A6)+OGRID	POP.L	(A6)+OVUE	POP.L	(A6)+OPRINT	LOAD.L	A3,#(A2)+LGHIMA+IMLBUF	LOAD.L	A4,#(A2)+LGHIMA	GRA_	CODEIMA		; code l'image	LOAD.L	A3,#(A6)+OBUFOUT	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier	JUMP',NE IGIVMEM$	LOAD.L	A4,A2	LOAD.L	D4,(A2)+OIMNBB	ADD.L	D4,#LGHIMA	FOS	?WRBYTE	PUSH.W	D7	FOS	?CLOSE	LOAD.L	A4,A2	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	POP.W	D7	JUMP'	EXIT$IGIVMEM$:	PUSH.W	D7	LOAD.L	A4,A2	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	POP.W	D7IDELETE$:	PUSH.W	D7	LOAD.L	A3,#(A6)+OBUFOUT	LOAD.L	D0,#FOS?DELETE	CALL	ERCALL		; dtruit le fichier	POP.W	D7EXIT$:	POPM.L	D0..D6,A0,A2..A4	TEST.W	D7		; retour EQ/NE	RETDEPL1$:	SUB.W	D4,(A6)+OIOY1+2	SWAP.W	D4	SUB.W	D4,(A6)+OIOY1+0	SWAP.W	D4	RETDEPL2$:	RET;--------\\; RDHEAD  >;========/; Lit l'en-tte.; in	-; out	D3.W	rvision;	D7.W	erreur; mod	D3.L, D7.WRDHEAD:	PUSHM.L	D2,D4,A3,A4	LOAD.L	A4,#(A6)+OIOBH	LOAD.W	D4,#LHEAD	CALL	RDMANY		; lit l'en-tte	JUMP,NE EXIT$	LOAD.W	D7,#ERPIOFORM	COMP.L	(A4)+OHPAGE,#H'D0C1C7C5	JUMP,NE EXIT$	LOAD.W	D2,(A4)+OHREV	; D2 <-- rvision	LOAD.W	(A6)+OIORV,D2	; OIORV <-- rvision du fichier lu	COMP.W	D2,#H'100*PAGEREV+PAGEVERS	JUMP,HI EXIT$	COMP.W	D2,#H'100*0+3	; <= que PAGE 0.3 ?	JUMP',HI NEW$		; non => NEW$	CALL	DBOXIOREV	; avertissement ...	JUMP,NE EXIT$	LOAD.W	D7,#ERKSTO	COMP.W	D3,#F1	JUMP,NE EXIT$NEW$:	LOAD.L	(A6)+ODESYD,(A4)+OHDIM	LOAD.L	(A6)+ODESY1,(A4)+OHPOS	LOAD.W	(A6)+OSCALE,(A4)+OHSCALE	LOAD.W	(A6)+OUNIT,(A4)+OHUNIT	LOAD.L	(A6)+OCALCA,(A4)+OHCALCA	LOAD.W	(A6)+OPAS,(A4)+OHPAS	LOAD.L	(A6)+OGRID,(A4)+OHGRID	LOAD.L	(A6)+OVUE,(A4)+OHVUE	LOAD.L	(A6)+OPRINT,(A4)+OHPRINT	COMP.W	D2,#H'100*0+2	; <= que PAGE 0.2 ?	JUMP',HI PAGE03$	; non => PAGE03$	TSET.B	(A6)+OVUE+0:#BVUEREPCOL-24	TSET.B	(A6)+OVUE+0:#BVUEREPMARG-24PAGE03$:	COMP.W	D2,#H'100*1+1	; < que PAGE 1.1 ?	JUMP',LO PAGE11$	; oui => PAGE11$	LOAD.W	(A6)+OPRSC1,(A4)+OHPRSC1	LOAD.W	(A6)+OPRSC2,(A4)+OHPRSC2PAGE11$:	COMP.W	D2,#H'100*2+0	; < que PAGE 2.0 ?	JUMP',LO PAGE20$	; oui => PAGE20$	LOAD.W	(A6)+OPRFROM,(A4)+OHPRFROM	LOAD.W	(A6)+OPRTO,(A4)+OHPRTO	LOAD.L	(A6)+OSELDV,(A4)+OHSELDVPAGE20$:	COMP.W	D2,#H'100*0+0	; <= que PAGE 0.0 ?	JUMP',LS PAGE02$	; oui => PAGE02$	LOAD.L	(A6)+OFDICO,(A4)+OHFDICO	COMP.W	D2,#H'100*0+2	; <= que PAGE 0.2 ?	JUMP',LS PAGE02$	; oui => PAGE02$	LOAD.W	(A6)+ODESMG,(A4)+OHDESMG	LOAD.W	(A6)+ODESMD,(A4)+OHDESMD	LOAD.W	(A6)+ODESMS,(A4)+OHDESMS	LOAD.W	(A6)+ODESMI,(A4)+OHDESMI	LOAD.W	(A6)+OCOLNB,(A4)+OHCOLNB	LOAD.W	(A6)+OCOLES,(A4)+OHCOLES	LOAD.L	(A6)+OCOLFA,(A4)+OHCOLFA	LOAD.W	(A6)+ODEF,(A4)+OHDEF	LOAD.W	(A6)+OHVVAL,(A4)+OHHVVAL	LOAD.L	(A6)+OHVFAN,(A4)+OHHVFAN	CALL	DBCOPX		; OCOLPX <-- position X des colonnesPAGE02$:	LOAD.L	A3,#R16"DEFOBJ$	COMP.W	D2,#H'100*1+8	; <= que PAGE 1.8 ?	JUMP',LS OBJ$		; oui => OBJ$	LOAD.L	A4,#(A6)+OIOBH	LOAD.W	D4,#256	CALL	RDMANY		; lit les noms des objets	JUMP',NE EXIT$	LOAD.L	A3,A4		; A3 <-- ^noms des objetsOBJ$:	CALL	OBJCONNECT	; connecte les objets demands	CALL	CCMO		; enlve la souris	CALL	DESICONE	; dessine toutes les icnes	CALL	MAJICONE	; met  jour les icnes variables	CLR.W	D7		; D7 <-- okEXIT$:	LOAD.W	D3,D2		; D3 <-- rvision	POPM.L	D2,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RETDEFOBJ$:	.ASCIZ	"LINE"	.ASCIZ	"ARROW"	.ASCIZ	"RECT"	.ASCIZ	"CADRE"	.ASCIZ	"ARCS"	.ASCIZ	"POLYR"	.ASCIZ	"POLY"	.ASCIZ	"CURVE"	.ASCIZ	"TEXT"	.ASCIZ	"LIST"	.ASCIZ	"FORM"	.ASCIZ	"IMAGE"	.B	0	.EVEN;----------\\; RDHEADSEL >;==========/; Lit l'en-tte d'un fichier .LPAGE.; in	-; out	D7.W	erreur; mod	D7.WRDHEADSEL:	PUSHM.L	D3,D4,A3,A4	LOAD.L	A4,#(A6)+OIOBH	LOAD.W	D4,#LHEAD	CALL	RDMANY		; lit l'en-tte	JUMP,NE EXIT$	LOAD.W	(A6)+OIORV,(A4)+OHREV ; OIORV <-- rvision du fichier lu	LOAD.W	D7,#ERPIOFORM	COMP.L	(A4)+OHPAGE,#H'D0C1C7C5	JUMP,NE EXIT$	COMP.W	(A4)+OHREV,#H'100*PAGEREV+PAGEVERS	JUMP,HI EXIT$	CLR.L	(A6)+OZONY1	LOAD.L	(A6)+OZONY2,(A4)+OHDIM	COMP.W	(A4)+OHREV,#H'100*1+8 ; <= que PAGE 1.8 ?	JUMP',LS OK$		; oui => OK$	LOAD.L	A4,#(A6)+OIOBH	LOAD.W	D4,#256	CALL	RDMANY		; lit les noms des objets	JUMP',NE EXIT$	LOAD.L	A3,A4		; A3 <-- ^liste des nomsLOOP$:	TEST.B	(A3)		; y a-t-il encore un nom ?	JUMP',EQ OK$		; non => OK$	LOAD.W	D3,#TYPOBEDIT	CALL	OBJIFCON	; objet dj connect ?	JUMP',NE EXIT$		; non => EXIT$NEXT$:	TEST.B	(A3+)		; A3 <-- ^nom suivant	JUMP,NE NEXT$	JUMP	LOOP$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; RDARBREDF >;==========/; Lit toute un arbre d'objets de dfinitions.; La lecture de l'arbre des objets de dfinition est un peu spciale :;  1)	il n'est pas vid avant la lecture;  2)	lorsqu'un objet est lu, s'il en existe un autre ayant le mme;	identificateur (un ancien), l'ancien est supprim.; On conserve ainsi les objets de dfinition qui ne sont pas contenus; dans le fichier lu !; in	-; out	D7.W	erreur; mod	D7.WRDARBREDF:	PUSHM.L	D0,D1,D4,A3,A4	LOAD.L	A4,#(A6)+OBUDIS	LOAD.W	D4,#8	CALL	RDMANY		; lit le nombre d'objets	JUMP',NE EXIT$	LOAD.W	D4,(A4)		; D4 <-- nb d'objets  lire	JUMP',EQ EXIT$LOOP$:	CALL	RDOBJET		; lit un objet de dfinition	JUMP',NE EXIT$	LOAD.W	D0,(A4)+OobjIDENT	LOAD.W	D1,#opDPUTDEF	CALL	OBJCALLD	; donne l'objet par dfaut	LOAD.L	A3,A4		; A3 <-- ^objet lu	LOAD.L	A4,(A6)+OARLIM	CALL	LSTA_NEXT	; A4 <-- ^premier objet	JUMP',NE NEXT$SRC2$:	COMP.L	A4,A3		; est-ce l'objet lu ?	JUMP',EQ SRC5$		; oui => SRC5$	COMP.W	D0,(A4)+OobjIDENT ; a-t-il le mme identificateur ?	JUMP',NE SRC5$		; non => SRC5$				; oui =>	LOAD.W	D1,#opCRCLOSE	CALL	OBJCALLD	; ferme l'objet	CALL	LSTA_REMOVE	; supprime l'objet de l'arbre	JUMP'	NEXT$SRC5$:	CALL	LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ SRC2$NEXT$:	DEC.W	D4	JUMP,NE LOOP$EXIT$:	POPM.L	D0,D1,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-------------\\; RDARBREOLDDF >;=============/; Lit toute un arbre d'anciens objets de dfinitions (< rev 0.3).; in	-; out	D7.W	erreur; mod	D7.WRDARBREOLDDF:	PUSHM.L	D0,D1,D4,A3,A4	LOAD.L	A4,#(A6)+OBUDIS	LOAD.W	D4,#8	CALL	RDMANY		; lit le nombre d'objets	JUMP',NE EXIT$	LOAD.W	D4,(A4)		; D4 <-- nb d'objets  lire	JUMP',EQ EXIT$LOOP$:	CALL	RDOBJET		; lit un objet de dfinition	JUMP',NE EXIT$	LOAD.W	D0,(A4)+OobjIDENT ; D0 <-- identificateur de l'objet lu	COMP.W	D0,#IDENTCHAR	JUMP',NE KILL$	LOAD.W	D1,#opDPUTDEF	CALL	OBJCALLD	; donne l'objet par dfaut	LOAD.L	A3,A4		; A3 <-- ^objet lu	LOAD.L	A4,(A6)+OARLIM	CALL	LSTA_NEXT	; A4 <-- ^premier objet	JUMP',NE NEXT$SRC2$:	COMP.L	A4,A3		; est-ce l'objet lu ?	JUMP',EQ SRC5$		; oui => SRC5$	COMP.W	D0,(A4)+OobjIDENT ; a-t-il le mme identificateur ?	JUMP',NE SRC5$		; non => SRC5$KILL$:				; oui =>	LOAD.W	D1,#opCRCLOSE	CALL	OBJCALLD	; ferme l'objet	CALL	LSTA_REMOVE	; supprime l'objet de l'arbre	JUMP'	NEXT$SRC5$:	CALL	LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ SRC2$NEXT$:	DEC.W	D4	JUMP,NE LOOP$EXIT$:	POPM.L	D0,D1,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDARBRE >;========/; Lit toute un arbre d'objets.; in	D6.L	canal de l'arbre; out	D7.W	erreur; mod	D7.WRDARBRE:	PUSHM.L	D4,A4	LOAD.L	A4,#(A6)+OBUDIS	LOAD.W	D4,#8	CALL	RDMANY		; lit le nombre d'objets	JUMP',NE EXIT$	LOAD.W	D4,(A4)		; D4 <-- nb d'objets  lire	JUMP',EQ EXIT$LOOP$:	CALL	RDOBJET		; lit un objet	JUMP',NE EXIT$	DEC.W	D4	JUMP,NE LOOP$EXIT$:	PUSH.W	D7	CALL	WRCLONUMCH	; remet les pointeurs dans les chanes	CALL	WRCLONUMCC	; fusionne les chanes	POP.W	D7	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; RDARBRESEL >;===========/; Lit toute un arbre d'objets.; in	-; out	D7.W	erreur; mod	D7.WRDARBRESEL:	PUSHM.L	D1,D3,D4,D6,A3,A4	LOAD.W	D3,(A6)+OPAGE	; D3 <-- page visible	LOAD.W	D4,(A6)+OCALQ	; D4 <-- calque visible	LOAD.L	D6,(A6)+OOBACH	; D6 <-- canal de l'arbre des objets	CALL	LSTA_BEGIN	; A4 <-- ^objet de base	CALL	LSTA_NB		; D4 <-- nb total d'objets	LOAD.W	(A6)+OIOOF,D4	; OIOOF <-- offset pour ajouter  la fin de l'arbre	LOAD.L	A4,#(A6)+OBUDIS	LOAD.W	D4,#8	CALL	RDMANY		; lit le nombre d'objets	JUMP',NE EXIT$	LOAD.W	D4,(A4)		; D4 <-- nb d'objets  lire	JUMP',EQ EXIT$LOOP$:	CALL	RDOBJET		; lit un objet	JUMP',NE EXIT$	LOAD.L	A3,#0	LOAD.W	D3,#EDITNPMNEXT	LOAD.W	D1,#opEDITNEXTPREV	CALL	OBJCALLD	; pas de chane;	LOAD.L	A3,#0	LOAD.W	D3,#EDITNPMPREV;	LOAD.W	D1,#opEDITNEXTPREV	CALL	OBJCALLD	; pas de chane	LOAD.L	A3,A4	CALL	LSTA_PREVP	; A4 <-- ^pre	COMP.L	A4,(A6)+OARLIM	; est-ce un fils du document ?	JUMP',NE NEXT$		; non => NEXT$	LOAD.L	A4,A3	CALL	LSTO_HEXTEND	; tend l'objet	JUMP',NE EXIT$NEXT$:	DEC.W	D4	JUMP,NE LOOP$EXIT$:	CLR.W	(A6)+OIOOF	POPM.L	D1,D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDOBJET >;========/; Lit un objet dans le fichier en entre.; in	-; out	A4.L	^nouvel objet;	D7.W	erreur; mod	D7.W, A4.LRDOBJET:	PUSHM.L	D0..D5,A2,A3	LOAD.L	A4,#(A6)+OBUDIS	LOAD.W	D4,#4	CLR.W	(A4)+4	COMP.W	(A6)+OIORV,#H'100*1+10 ; <= que PAGE 1.10 ?	JUMP',LS RDLIN$	LOAD.W	D4,#6RDLIN$:	CALL	RDMANY		; buffer <-- longueur + identificateur + numro	JUMP,NE EXIT$	LOAD.W	D2,(A4+)	; D2 <-- longueur  lire	LOAD.W	D0,(A4+)	; D0 <-- identificateur	LOAD.W	D3,(A4)		; D3 <-- numro du pre	LOAD.W	D1,#opCRGETLG	CALL	OBJCALL		; D4 <-- longueur pour crer	JUMP',EQ INSERT$	CLR.W	D4		; D4 <-- objet sans dataINSERT$:	CALL	RDOBJETCP	; A3/A4 <-- pre	CALL	LSTA_INSERT	; A4 <-- ^racine nouvel objet	JUMP,NE EXIT$	LOAD.W	(A4)+OobjIDENT,D0	LOAD.L	A3,A4		; A3 <-- ^racine nouvel objet	COMP.W	D4,D2		; lg objet = lg sur disque ?	JUMP',NE ADAPT$		; non => ADAPT$	LOAD.L	A4,(A3)+OobjPDATA ; A4 <-- ^data nouvel objet	LOAD.W	D4,D2		; D4 <-- lg data	CALL	RDMANY		; lit le contenu de l'objet	JUMP,NE EXIT$RDSUPPL$:	LOAD.W	D1,#opCRREAD	CALL	OBJCALL		; lit le contenu de l'objet	JUMP',EQ RDOK$	COMP.W	D7,#ERPMDNE	JUMP,NE EXIT$	JUMP'	RDOK$ADAPT$:	LOAD.W	D5,D4		; D5 <-- lg objet	LOAD.L	A4,#(A6)+OBUDIS	LOAD.W	D4,D2		; D4 <-- lg data	CALL	RDMANY		; lit le contenu de l'objet  adapter	JUMP',NE EXIT$	PUSH.L	A3	LOAD.L	A4,(A3)+OobjPDATA ; A4 <-- ^data nouvel objet	LOAD.L	A3,#(A6)+OBUDIS	; A3 <-- ^objet  adapter	LOAD.W	D3,D2		; D3 <-- lg objet  adapter	LOAD.W	D1,#opCRADAPT	CALL	OBJCALL		; D4 <-- type de l'objet	POPM.L	A3	JUMP',EQ RDOK$	COMP.W	D7,#ERPMDNE	; mthode n'existe pas ?	JUMP',NE EXIT$		; non => EXIT$	COMP.W	D5,D2	JUMP',LS ADMIN$	LOAD.W	D5,D2		; D5 <-- MIN (lg_objet,lg_data)ADMIN$:	DEC.W	D5		; D5 <-- -1  cause NMO	JUMP',NS RDOK$;	LOAD.L	A4,(A3)+OobjPDATA ; A4 <-- ^data nouvel objet	LOAD.L	A2,#(A6)+OBUDIS	; A2 <-- ^objet  adapterADXFER$:	LOAD.B	(A4+),(A2+)	DECJ.W,NMO D5,ADXFER$	LOAD.L	A4,(A3)+OobjPDATA ; A4 <-- ^data nouvel objet	JUMP	RDSUPPL$RDOK$:	LOAD.W	D1,#opGETTYPE	CALL	OBJCALL		; D4 <-- type de l'objet	JUMP',NE END$	COMP.W	D4,#TYPOBEDIT	; objet ditable (GRA*) ?	JUMP',NE END$		; non => END$;	CLR.L	(A3)+OobjBBOX1;	CLR.L	(A3)+OobjBBOX2	LOAD.W	D1,#opGETBBOX	CALL	OBJCALL		; D3/D4 <-- bounding box	JUMP',NE END$	LOAD.L	(A3)+OobjBBOX1,D3	LOAD.L	(A3)+OobjBBOX2,D4END$:	LOAD.L	A4,A3		; A4 <-- ^racine nouvel objet	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D5,A2,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; RDOBJETCP >;----------/; Cherche le pre d'aprs son numro, pour faire un LSTA_INSERT.; in	D3.W	numro du pre; out	A3.L	^lment pre (si zro => selon A4.L);	A4.L	^lment frre cadet (si zro =>  la tte); mod	D7.W, A3.L, A4.LRDOBJETCP:	PUSH.L	D3	TEST.W	D3	JUMP',EQ NOPERE$	ADD.W	D3,(A6)+OIOOF	; D3 <-- ajoute offset ventuel	LOAD.L	A4,(A6)+OARLIM	; A4 <-- ^calque de base	CALL	LSTA_NEXT	; A4 <-- ^premier objet	JUMP',NE NOPERE$LOOP$:	DEC.W	D3	JUMP',EQ PERE$	CALL	LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$NOPERE$:	LOAD.L	A3,(A6)+OARLIM	; A3 <-- ^pre	LOAD.L	A4,#0		; A4 <-- insre  la tte	JUMP'	EXIT$PERE$:	LOAD.L	A3,A4		; A3 <-- ^pre	LOAD.L	A4,#0	TEST.L	(A3)+OobjPDFILS	; est-ce que le pre a dj un fils ?	JUMP',EQ EXIT$		; non => EXIT$	LOAD.L	A4,(A3)+OobjPDFILS ; A4 <-- ^fils an du pre	LOAD.L	A3,#0		; A3 <-- pas de preEXIT$:	POP.L	D3	RET;--------\\; WRHEAD  >;========/; Ecrit l'en-tte.; in	-; out	D7.W	erreur; mod	D7.WWRHEAD:	PUSHM.L	D0..D4,A2..A4	LOAD.L	A4,#(A6)+OIOBH	LOAD.L	D4,#LHEAD	GESMEM	?CLEARMEM	LOAD.L	(A4)+OHPAGE,#H'D0C1C7C5	LOAD.W	(A4)+OHREV,#H'100*PAGEREV+PAGEVERS	LOAD.L	(A4)+OHDIM,(A6)+ODESYD	LOAD.L	(A4)+OHPOS,(A6)+ODESY1	LOAD.W	(A4)+OHDESMG,(A6)+ODESMG	LOAD.W	(A4)+OHDESMD,(A6)+ODESMD	LOAD.W	(A4)+OHDESMS,(A6)+ODESMS	LOAD.W	(A4)+OHDESMI,(A6)+ODESMI	LOAD.W	(A4)+OHCOLNB,(A6)+OCOLNB	LOAD.W	(A4)+OHCOLES,(A6)+OCOLES	LOAD.L	(A4)+OHCOLFA,(A6)+OCOLFA	LOAD.W	(A4)+OHSCALE,(A6)+OSCALE	LOAD.W	(A4)+OHUNIT,(A6)+OUNIT	LOAD.L	(A4)+OHCALCA,(A6)+OCALCA	LOAD.W	(A4)+OHPAS,(A6)+OPAS	LOAD.L	(A4)+OHGRID,(A6)+OGRID	LOAD.L	(A4)+OHVUE,(A6)+OVUE	LOAD.L	(A4)+OHPRINT,(A6)+OPRINT	LOAD.L	(A4)+OHFDICO,(A6)+OFDICO	LOAD.W	(A4)+OHDEF,(A6)+ODEF	LOAD.W	(A4)+OHHVVAL,(A6)+OHVVAL	LOAD.L	(A4)+OHHVFAN,(A6)+OHVFAN	LOAD.W	(A4)+OHPRSC1,(A6)+OPRSC1	LOAD.W	(A4)+OHPRSC2,(A6)+OPRSC2	LOAD.W	(A4)+OHPRFROM,(A6)+OPRFROM	LOAD.W	(A4)+OHPRTO,(A6)+OPRTO	LOAD.L	(A4)+OHSELDV,(A6)+OSELDV;	LOAD.W	D4,#LHEAD	CALL	WRMANY		; crit l'en-tte	JUMP',NE EXIT$;	LOAD.L	A4,#(A6)+OIOBH	LOAD.L	D4,#256	GESMEM	?CLEARMEM	LOAD.L	A2,#(A6)+OTAMO	CLR.W	D0LOOP$:	TEST.L	(A2)+OMOCOD	; objet en fonction ?	JUMP',EQ NEXT$		; non => NEXT$	COMP.W	(A2)+OMOTYP,#TYPOBEDIT ; objet ditable ?	JUMP',NE NEXT$		; non => NEXT$	LOAD.W	D1,#opGETNAME	CALL	OBJCALL		; A3 <-- ^nom du fichier	ADD.L	A3,#4		; A3 <-- saute "GRA_"XFER2$:	LOAD.B	D3,(A3+)	COMP.B	D3,#'.	JUMP',EQ XFER4$	LOAD.B	(A4+),D3	JUMP	XFER2$XFER4$:	CLR.B	(A4+)NEXT$:	ADD.L	A2,#LMO		; A2 <-- ^suivant dans OTAMO	INC.W	D0		; D0 <-- identificateur suivant	COMP.W	D0,#MAXMO	JUMP,LO LOOP$	LOAD.L	A4,#(A6)+OIOBH	LOAD.W	D4,#256	CALL	WRMANY		; crit les noms des objetsEXIT$:	POPM.L	D0..D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; WRARBRESEL >;===========/; Ecrit toute un arbre d'objets slectionns.; in	D6.L	canal de l'arbre; out	D7.W	erreur; mod	D7.WWRARBRESEL:	PUSHM.L	D3,D4,A4	CALL	WROPENUMSEL	; numrote tous les objets slectionns	LOAD.L	A4,#(A6)+OBUDIS	LOAD.W	(A4),D4	CLR.W	(A4)+2	CLR.L	(A4)+4	LOAD.W	D4,#8	CALL	WRMANY		; crit le nombre d'objets	JUMP',NE EXIT$	LOAD.W	D3,(A6)+OPAGE	; D3 <-- page visible	LOAD.W	D4,(A6)+OCALQ	; D4 <-- calque visible	CALL	LSTA_FIRST	; A4 <-- ^premier objet	JUMP',NE OK$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	CALL	LSTA_NB		; D4 <-- nombre de fils		INC.W	D4		; D4 <-- compte aussi le preFILS$:	CALL	WROBJET		; crit un objet	JUMP',NE EXIT$	CALL	LSTA_NEXT	; A4 <-- ^objet suivant	JUMP',NE OK$	DEC.W	D4	JUMP,NE FILS$	JUMP	LOOP$NEXT$:	CALL	LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	PUSH.W	D7	CALL	WRCLONUM	; fin de la numrotation	POP.W	D7	POPM.L	D3,D4,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; WRARBREDF >;==========/; Ecrit toute un arbre d'objets de dfinition.; in	D6.L	canal de l'arbre; out	D7.W	erreur; mod	D7.WWRARBREDF:	PUSHM.L	D3,D4,A4	CALL	WROPENUM	; numrote tous les objets	LOAD.L	A4,D6		; A4 <-- ^objet document	CALL	LSTA_NB		; D4 <-- nb d'lments dans l'arbre	LOAD.L	A4,#(A6)+OBUDIS	LOAD.W	(A4),D4	CLR.W	(A4)+2	CLR.L	(A4)+4	LOAD.W	D4,#8	CALL	WRMANY		; crit le nombre d'objets	JUMP',NE EXIT$	LOAD.W	D3,#-1		; D3 <-- toutes les pages	CALL	LSTA_FIRST	; A4 <-- ^premier objet	JUMP',NE OK$LOOP$:	CALL	WROBJET		; crit un objet	JUMP',NE EXIT$	CALL	LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRARBRE >;========/; Ecrit toute un arbre d'objets.; in	D6.L	canal de l'arbre; out	D7.W	erreur; mod	D7.WWRARBRE:	PUSHM.L	D3,D4,A4	CALL	WROPENUM	; numrote tous les objets	CALL	WROPENUMCH	; numrote toutes les chanes	LOAD.L	A4,D6		; A4 <-- ^objet document	CALL	LSTA_NB		; D4 <-- nb d'lments dans l'arbre	LOAD.L	A4,#(A6)+OBUDIS	LOAD.W	(A4),D4	CLR.W	(A4)+2	CLR.L	(A4)+4	LOAD.W	D4,#8	CALL	WRMANY		; crit le nombre d'objets	JUMP',NE EXIT$	LOAD.W	D3,#-1		; D3 <-- toutes les pages	CALL	LSTA_FIRST	; A4 <-- ^premier objet	JUMP',NE OK$LOOP$:	CALL	WROBJET		; crit un objet	JUMP',NE EXIT$	CALL	LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	PUSH.W	D7	CALL	WRCLONUMCH	; remet les pointeurs dans les chanes	CALL	WRCLONUM	; fin de la numrotation	POP.W	D7	POPM.L	D3,D4,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; WROPENUMSEL >;------------/; Numrote tous les objets slectionns d'un arbre.; Il ne faudra pas oublier de recalculer les bbox, avec WRCLONUM !; in	D6.L	canal de l'arbre; out	D4.W	nombre d'objets slectionns; mod	D4.L, D7.WWROPENUMSEL:	PUSHM.L	D2,D3,A4	LOAD.L	A4,D6		; A4 <-- ^objet document	CLR.L	(A4)+OobjBBOX1	CLR.L	(A4)+OobjBBOX2	; signal bbox bouzille	CLR.L	D2	LOAD.W	D3,#-1		; D3 <-- toutes les pages	CALL	LSTA_FIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	CALL	LSTA_NB		; D4 <-- nombre de fils		INC.W	D4		; D4 <-- compte aussi le preFILS$:	INC.L	D2	LOAD.L	(A4)+OobjBBOX1,D2	CLR.L	(A4)+OobjBBOX2	; signal bbox bouzille	CALL	LSTA_NEXT	; A4 <-- ^objet suivant	JUMP',NE EXIT$	DEC.W	D4	JUMP,NE FILS$	JUMP	LOOP$NEXT$:	CLR.L	(A4)+OobjBBOX1	CLR.L	(A4)+OobjBBOX2	; signal bbox bouzille	CALL	LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	LOAD.W	D4,D2		; D4 <-- nb d'objets slectionns	POPM.L	D2,D3,A4	RET;---------\\; WROPENUM >;---------/; Numrote tous les objets d'un arbre.; Il ne faudra pas oublier de recalculer les bbox, avec WRCLONUM !; in	D6.L	canal de l'arbre; out	-; mod	D7.WWROPENUM:	PUSHM.L	D3,D4,A4	LOAD.L	A4,D6		; A4 <-- ^objet document	CLR.L	(A4)+OobjBBOX1	CLR.L	(A4)+OobjBBOX2	; signal bbox bouzille	LOAD.W	D3,#-1		; D3 <-- toutes les pages	CALL	LSTA_FIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$	CLR.L	D4LOOP$:	INC.L	D4	LOAD.L	(A4)+OobjBBOX1,D4	CLR.L	(A4)+OobjBBOX2	; signal bbox bouzille	CALL	LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	POPM.L	D3,D4,A4	RET;-----------\\; WROPENUMCH >;-----------/; Numrote toutes les chanes de l'arbre.; in	D6.L	canal de l'arbre; out	-; mod	D7.WWROPENUMCH:	PUSHM.L	D1,D3,A3,A4	LOAD.W	D3,#-1		; D3 <-- toutes les pages	CALL	LSTA_FIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$	LOAD.W	D1,#opEDITNEXTPREV ; D1 <-- mthodeLOOP$:	LOAD.W	D3,#EDITNPGNEXT	CALL	OBJCALLD	; A3 <-- ^objet suivant	JUMP',NE NEXT$	COMP.L	A3,#0	JUMP',EQ PREV$	LOAD.L	A3,(A3)+OobjBBOX1 ; A3 <-- numro de l'objet suivant	LOAD.W	D3,#EDITNPMNEXT	CALL	OBJCALLD	; mmorise le numro de l'objet suivantPREV$:	LOAD.W	D3,#EDITNPGPREV	CALL	OBJCALLD	; A3 <-- ^objet prcdent	COMP.L	A3,#0	JUMP',EQ NEXT$	LOAD.L	A3,(A3)+OobjBBOX1 ; A3 <-- numro de l'objet prcdent	LOAD.W	D3,#EDITNPMPREV	CALL	OBJCALLD	; mmorise le numro de l'objet prcdentNEXT$:	CALL	LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	POPM.L	D1,D3,A3,A4	RET;---------\\; WRCLONUM >;---------/; Remplace les numros par les bbox normales.; in	D6.L	canal de l'arbre; out	-; mod	D7.WWRCLONUM:	PUSHM.L	D1,D3,D4,A4	LOAD.W	D3,#-1		; D3 <-- toutes les pages	CALL	LSTA_FIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$LOOP$:	TEST.L	(A4)+OobjBBOX2	; bbox bouzille ?	JUMP',NE NEXT$		; non => NEXT$	CLR.L	(A4)+OobjBBOX1;	CLR.L	(A4)+OobjBBOX2	LOAD.W	D1,#opGETBBOX	CALL	OBJCALLD	; D3/D4 <-- bounding box	JUMP',NE NEXT$	LOAD.L	(A4)+OobjBBOX1,D3	LOAD.L	(A4)+OobjBBOX2,D4NEXT$:	CALL	LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	POPM.L	D1,D3,D4,A4	RET;-----------\\; WRCLONUMCH >;-----------/; Remplace les numros de toutes les chanes de l'arbre par des pointeurs.; in	D6.L	canal de l'arbre; out	-; mod	D7.WWRCLONUMCH:	PUSHM.L	D1,D3,A3,A4	LOAD.W	D3,#-1		; D3 <-- toutes les pages	CALL	LSTA_FIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$	LOAD.W	D1,#opEDITNEXTPREV ; D1 <-- mthodeLOOP$:	LOAD.W	D3,#EDITNPGNEXT	CALL	OBJCALLD	; A3 <-- numro de l'objet suivant	JUMP',NE NEXT$	COMP.L	A3,#0	JUMP',EQ PREV$	CALL'	WRCLONUMCN	; A3 <-- ^objet suivant	LOAD.W	D3,#EDITNPMNEXT	CALL	OBJCALLD	; mmorise ^objet suivantPREV$:	LOAD.W	D3,#EDITNPGPREV	CALL	OBJCALLD	; A3 <-- numro de l'objet prcdent	COMP.L	A3,#0	JUMP',EQ NEXT$	CALL'	WRCLONUMCN	; A3 <-- ^objet prcdent	LOAD.W	D3,#EDITNPMPREV	CALL	OBJCALLD	; mmorise ^objet prcdentNEXT$:	CALL	LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	POPM.L	D1,D3,A3,A4	RET;-----------\\; WRCLONUMCN >;-----------/; Cherche un lment d'aprs son numro.; in	D6.L	canal de l'arbre;	A3.L	numro de l'lment; out	A3.L	^lment; mod	D7.W, A3.LWRCLONUMCN:	PUSHM.L	D3,D4,A4	LOAD.L	D4,A3		; D4 <-- numro de l'lment	JUMP',EQ ERROR$	LOAD.W	D3,#-1		; D3 <-- toutes les pages	CALL	LSTA_FIRST	; A4 <-- ^premier objet	JUMP',NE ERROR$LOOP$:	DEC.W	D4	JUMP',EQ END$	CALL	LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$ERROR$:	LOAD.L	A4,#0		; A4 <-- nil (en cas d'erreur)END$:	LOAD.L	A3,A4		; A3 <-- ^lment	POPM.L	D3,D4,A4	RET;-----------\\; WRCLONUMCC >;-----------/; Unifie tous les canaux des chanes (d'aprs le canal du premier).; in	D6.L	canal de l'arbre; out	-; mod	D7.WWRCLONUMCC:	PUSHM.L	D1,D3,A2..A4	LOAD.W	D3,#-1		; D3 <-- toutes les pages	CALL	LSTA_FIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$	LOAD.L	A2,A4LOOP$:	EX.L	A4,A2	CALL	__SUITEEXIST	; chane existe ?	EX.L	A4,A2	JUMP',NE NEXT$		; non => NEXT$	LOAD.L	A4,A2	CALL	__SUITEPREV	; est-ce le premier objet de la chane ?	JUMP',EQ NEXT$		; non => NEXT$	LOAD.L	A3,A4		; A3 <-- ^objet premier de chaneLINK$:	CALL	__SUITENEXT	; A4 <-- ^objet suivant	JUMP',NE NEXT$	LOAD.W	D3,#EDITNPLINK	LOAD.W	D1,#opEDITNEXTPREV	CALL	OBJCALLD	; fusionne les textes	JUMP	LINK$NEXT$:	EX.L	A4,A2	CALL	LSTA_NEXT	; A4 <-- ^objet suivant	EX.L	A4,A2	JUMP,EQ LOOP$EXIT$:	POPM.L	D1,D3,A2..A4	RET;--------\\; WROBJET >;========/; Ecrit l'objet dans le fichier en sortie.; in	A4.L	^objet  crire; out	D7.W	erreur; mod	D7.WWROBJET:	PUSHM.L	D0,D1,D4,A3,A4	LOAD.L	A3,(A4)+OobjPDATA ; A3 <-- ^data de l'objet	LOAD.W	D0,(A4)+OobjIDENT	LOAD.W	D1,#opCRCOPYLG	CALL	OBJCALL		; D4 <-- longueur de l'objet	JUMP',EQ WRITE$	COMP.W	D7,#ERPMDNE	JUMP',NE EXIT$	CLR.W	D4		; D4 <-- objet sans dataWRITE$:	LOAD.W	D1,D4		; D1 <-- longueur de l'objet	LOAD.L	A3,A4		; A3 <-- ^racine de l'objet	CLR.L	D4	CALL	LSTA_PREVP	; A4 <-- ^pre	JUMP',NE WRLIN$	LOAD.L	D4,(A4)+OobjBBOX1 ; D4 <-- numro du preWRLIN$:	LOAD.L	A4,#(A6)+OBUDIS	LOAD.W	(A4)+0,D1	LOAD.W	(A4)+2,D0	LOAD.W	(A4)+4,D4	LOAD.W	D4,#6	CALL	WRMANY		; fichier <-- longueur + identificateur + numro	JUMP',NE EXIT$	TEST.L	(A3)+OobjPDATA	JUMP',EQ OK$	LOAD.L	A4,(A3)+OobjPDATA ; A4 <-- ^data de l'objet	LOAD.W	D4,D1		; D4 <-- longueur	CALL	WRMANY		; fichier <-- objet	JUMP',NE EXIT$	LOAD.W	D1,#opCRWRITE	CALL	OBJCALL		; fichier <-- objet	JUMP',EQ EXIT$	COMP.W	D7,#ERPMDNE	JUMP',NE EXIT$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0,D1,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; WRASSALL >;=========/; Ecrit le fichier associ "!".; in	A3.L	^nom du fichier .PAGE; out	D7.W	erreur; mod	D7.WWRASSALL:	PUSHM.L	D3,D4,D6,A2..A4	LOAD.L	A2,A3		; A2 <-- ^nom du fichier .PAGE	CLR.B	(A6)+OIOTM	; vide le buffer	LOAD.L	A3,#R16"DEB1$	CALL	WRASSFILE	; buffer <-- dbut 1	LOAD.L	A3,#R16"DEB2$	CALL	WRASSFILE	; buffer <-- dbut 2	LOAD.L	A3,#R16"DEB3$	CALL	WRASSFILE	; buffer <-- dbut 3	LOAD.L	D6,(A6)+ODFACH	CALL	WRASSARBRE	; buffer <-- nom(s) des dfinitions	JUMP',NE EXIT$	LOAD.L	D6,(A6)+OOBACH	CALL	WRASSARBRE	; buffer <-- nom(s) des objets	JUMP',NE EXIT$	LOAD.L	A3,A2	LOAD.L	A4,A2NAME2$:	TEST.B	(A4+)	JUMP,NE NAME2$NAME3$:	COMP.B	(-A4),#'.	JUMP,NE NAME3$	LOAD.B	(A4),#'!	; remplace le "." par "!"	FOS	?DELETE		; dtruit le fichier "!"	LOAD.L	D3,#DEFATT-2^BATTL ; D3 <-- attributs par dfaut	LOAD.W	D4,#TYPRAND	; D4 <-- type "random"	FOS	?CREATE		; cre le fichier "!"	JUMP',NE EXIT$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN		; ouvre le fichier "!"	JUMP',NE EXIT$	LOAD.L	A4,#(A6)+OIOTM	LOAD.L	A3,A4	LOAD.L	D4,#-1LG$:	INC.L	D4		; D4 <-- longueur	TEST.B	(A3+)	JUMP,NE LG$	FOS	?WRBYTE		; crit le fichier "!"	PUSH.W	D7	FOS	?CLOSE		; ferme le fichier "!"	POP.W	D7EXIT$:	POPM.L	D3,D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RETDEB1$:	.ASCIZ	+"gnrateurs de caractres"/1/E+DEB2$:	.ASCIZ	"%*!PAGE/D -CL"DEB3$:	.ASCIZ	"%*.PAGE/D -C+L"	.EVEN;-----------\\; WRASSARBRE >;-----------/; Met dans le buffer tous les noms selon les objets d'un arbre.; in	D6.L	canal d'un arbre; out	D7.W	erreur; mod	D7.WWRASSARBRE:	PUSHM.L	D1,D3,A4	LOAD.W	D3,#-1		; D3 <-- toutes les pages	CALL	LSTA_FIRST	; A4 <-- ^premier objet	JUMP',NE END$LOOP$:	LOAD.W	D1,#opCRASSFILE	CALL	OBJCALLD	; buffer <-- nom(s) selon l'objet	JUMP',EQ NEXT$	COMP.W	D7,#ERPMDNE	JUMP',NE EXIT$NEXT$:	CALL	LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$END$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1,D3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; WRASSFILE >;==========/; Ajoute un nom de fichier dans le fichier "!".; Si ce nom y est dj, il n'est pas ajout.; in	A3.L	^nom  ajouter dans "!"; out	D7.W	erreur; mod	D7.WWRASSFILE:	PUSHM.L	D3,D4,A2..A4	LOAD.L	A4,#(A6)+OIOTM	; A4 <-- ^buffer	CLR.W	D4SRC2$:	TEST.B	(A4)		; fin du buffer ?	JUMP',EQ ADD2$		; oui => ADD2$	LOAD.L	A2,#R16"TERM$	LIB	?CPSTRING	; fichier dj dans le buffer ?	JUMP',EQ OK$		; oui => OK$SRC5$:	INC.W	D4	COMP.B	(A4+),#CR	; A4 <-- ^fichier suivant	JUMP,NE SRC5$	JUMP	SRC2$ADD2$:	LOAD.W	D7,#ERPIOASSF	; D7 <-- fichier "!" trop grand	COMP.W	D4,#LTMIO-30	; encore assez de place ?	JUMP',HS EXIT$		; non => EXIT$ADD3$:	LOAD.B	D3,(A3+)	JUMP',EQ ADD5$	COMP.B	D3,#CR	JUMP',EQ ADD5$	LOAD.B	(A4+),D3	; buffer <-- nouveau fichier	JUMP	ADD3$ADD5$:	LOAD.B	(A4+),#CR	CLR.B	(A4)OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4,A2..A4	TEST.W	D7		; retour EQ/NE	RETTERM$:	.B	0,CR,SPACE,TAB,'/,-1	.EVEN; Routines de bas niveau pour bufferiser les entres/sorties; ----------------------------------------------------------;--------\\; RDOPEN  >;========/; Ouvre le fichier en entre.; in	A3.L	^nom du fichier; out	D7.W	erreur; mod	D7.WRDOPEN:	PUSHM.L	D0,D3,D6	LOAD.W	D3,#2^BOPRD	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier	JUMP',NE EXIT$	LOAD.W	(A6)+OIOCH,D6	; mm. canal	LOAD.W	(A6)+OIOPT,#LTMIOEXIT$:	POPM.L	D0,D3,D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDMANY  >;========/; Lit plusieurs bytes dans le fichier en entre.; in	A4.L	^buffer;	D4.W	nombre de bytes  lire; out	(A4)++	bytes lus;	D4.W	nombre de bytes lus;	D7.W	erreur; mod	D4.L, D7.WRDMANY:	PUSHM.L	D2,D3,A4	CLR.W	D7		; D7 <-- ok	LOAD.W	D2,D4		; D2 <-- nb de bytes  lire	JUMP',EQ EXIT$	CLR.W	D4		; D4 <-- nb de bytes lusLOOP$:	CALL	RDONE		; D3 <-- lit un byte	JUMP',NE EXIT$	LOAD.B	(A4+),D3	INC.W	D4	DEC.W	D2	JUMP,NE LOOP$EXIT$:	POPM.L	D2,D3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDONE   >;========/; Lit un byte dans le fichier d'entre.; in	-; out	D3.B	byte lu;	D7.W	erreur; mod	D3.L, D7.WRDONE:	PUSHM.L	D4,D6,A4	CLR.W	D7		; D7 <-- ok	LOAD.L	A4,#(A6)+OIOTM	; A4 <-- ^buffer tampon	COMP.W	(A6)+OIOPT,#LTMIO ; reste qq chose ?	JUMP',LO 50$		; oui => 50$				; non =>	LOAD.L	D4,#LTMIO	LOAD.W	D6,(A6)+OIOCH	; D6 <-- canal	FOS	?RDBYTE		; lit tout le buffer	LOAD.W	(A6)+OIONB,#-1	CLR.W	(A6)+OIOPT	; buffer vide	TEST.W	D7		; lecture ok ?	JUMP',EQ 50$		; oui => 50$	COMP.W	D7,#EROUTF	; fin du fichier ?	JUMP',NE EXIT$		; non => EXIT$	CLR.W	D7		; D7 <-- ok pour l'instant	LOAD.W	(A6)+OIONB,D4	; mm. lg dernire tranche50$:	TEST.W	(A6)+OIONB	; reste qq chose ?	JUMP',NE 60$		; oui => 60$	LOAD.W	D7,#EROUTF	; D7 <-- fin du fichier	JUMP'	EXIT$60$:	LOAD.W	D4,(A6)+OIOPT	LOAD.B	D3,(A4)+(D4.W)	; D3 <-- un byte du buffer	INC.W	(A6)+OIOPT	; avance "pointeur"	DEC.W	(A6)+OIONB	; diminue resteEXIT$:	POPM.L	D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDCLOSE >;========/; Ferme le fichier en entre.; in	D7.W	ok/erreur; out	D7.W	erreur; mod	D7.WRDCLOSEX:	LOAD.W	D7,D5RDCLOSE:	PUSHM.L	D5,D6	LOAD.W	D5,D7		; D5 <-- ok/erreur	LOAD.W	D6,(A6)+OIOCH	; D6 <-- canal	FOS	?CLOSE		; ferme le fichier	COMP.W	D7,D5	JUMP',HS EXIT$	LOAD.W	D7,D5		; D7 <-- erreur la plus grve !EXIT$:	POPM.L	D5,D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; WROPEN  >;========/; Ouvre le fichier en sortie.; in	A3.L	^nom du fichier; out	D7.W	erreur; mod	D7.WWROPEN:	PUSHM.L	D0,D3,D6	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier	JUMP',NE EXIT$	LOAD.W	(A6)+OIOCH,D6	; mm. canal	CLR.W	(A6)+OIOPT	; buffer videEXIT$:	POPM.L	D0,D3,D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRTEXT  >;========/; Ecrit un texte (.ASCIZ) dans le fichier de sortie.; in	A3.L	^texte termin par <0>; out	D7.W	erreur; mod	D7.WWRTEXT:	PUSHM.L	D4,A3,A4	LOAD.L	A4,A3	LOAD.W	D4,#-110$:	INC.W	D4	TEST.B	(A3+)	JUMP,NE 10$	CALL	WRMANY		; crit tout le .ASCIZ	POPM.L	D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRMANY  >;========/; Ecrit plusieurs bytes dans le fichier de sortie.; in	A4.L	^bytes  crire;	D4.W	nombre de bytes  crire; out	D7.W	erreur; mod	D7.WWRMANY:	PUSHM.L	D3,D4,D6,A2..A4	CLR.W	D7		; D7 <-- ok	LOAD.L	A3,A4		; A3 <-- ^bytes  crire	LOAD.W	D3,D4		; D3 <-- nombre	JUMP',EQ EXIT$LOOP$:	LOAD.L	A4,#(A6)+OIOTM	; A4 <-- ^dbut buffer	LOAD.W	D4,(A6)+OIOPT	; D4 <-- nb bytes dans buffer	ADD.W	A4,D4		; A4 <-- ^o insrerXFER$:	COMP.W	D4,#LTMIO	; buffer plein ?	JUMP',EQ WRITE$	LOAD.B	(A4+),(A3+)	; buffer <-- un byte	INC.W	D4		; D4 <-- un byte de plus	DEC.W	D3	JUMP,NE	XFER$	LOAD.W	(A6)+OIOPT,D4	; mj offset dans buffer	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$WRITE$:	LOAD.L	A4,#(A6)+OIOTM	; A4 <-- ^dbut buffer	LOAD.L	D4,#LTMIO	; D4 <-- longueur buffer	LOAD.W	D6,(A6)+OIOCH	; D6 <-- canal	FOS	?WRBYTE		; crit tout le buffer	JUMP',NE EXIT$		; erreur => EXIT$	CLR.W	(A6)+OIOPT	; signal buffer vide	JUMP	LOOP$EXIT$:	POPM.L	D3,D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRONE   >;========/; Ecrit un byte dans le fichier de sortie.; in	D3.B	byte  crire; out	D7.W	erreur; mod	D7.WWRONE:	PUSHM.L	D4,D6,A2,A4LOOP$:	LOAD.L	A4,#(A6)+OIOTM	; A4 <-- ^dbut buffer	LOAD.W	D4,(A6)+OIOPT	; D4 <-- nb bytes dans buffer	ADD.W	A4,D4		; A4 <-- ^o insrer	COMP.W	D4,#LTMIO	; buffer plein ?	JUMP',EQ WRITE$	LOAD.B	(A4),D3		; buffer <-- le byte	INC.W	D4		; D4 <-- un byte de plus	LOAD.W	(A6)+OIOPT,D4	; mj offset dans buffer	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$WRITE$:	LOAD.L	A4,#(A6)+OIOTM	; A4 <-- ^dbut buffer	LOAD.L	D4,#LTMIO	; D4 <-- longueur buffer	LOAD.W	D6,(A6)+OIOCH	; D6 <-- canal	FOS	?WRBYTE		; crit tout le buffer	JUMP',NE EXIT$		; erreur => EXIT$	CLR.W	(A6)+OIOPT	; signal buffer vide	JUMP	LOOP$EXIT$:	POPM.L	D4,D6,A2,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRCLOSE >;========/; Ecrit le reste du fichier de sortie, puis ferme.; in	D7.W	ok/erreur; out	D7.W	erreur; mod	D7.WWRCLOSEX:	LOAD.W	D7,D5WRCLOSE:	PUSHM.L	D4..D6,A4	LOAD.W	D6,(A6)+OIOCH	; D6 <-- canal	LOAD.W	D5,D7		; D5 <-- ok/erreur	JUMP',NE 50$		; erreur => 50$				; ok =>	LOAD.L	A4,#(A6)+OIOTM	; A4 <-- ^buffer tampon	CLR.L	D4	LOAD.W	D4,(A6)+OIOPT	; D4 <-- nb bytes dans buffer	JUMP',EQ 50$		; si vide => 50$				; si reste qq chose =>	FOS	?WRBYTE		; crit tout le buffer	LOAD.W	D5,D750$:	FOS	?CLOSE		; ferme le fichier	COMP.W	D7,D5	JUMP',HS EXIT$	LOAD.W	D7,D5		; D7 <-- erreur la plus grve !EXIT$:	POPM.L	D4..D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; SAVFILE >;========/; Sauve un nom de fichier dans OBUNAME.; in	A3.L	^nom; out	-; mod	D7.WSAVFILE:	PUSHM.L	A1..A4	LOAD.L	A1,A3	CALL	SKIPREP		; A3 <-- ^aprs rep(s):	LOAD.L	A4,A3	LOAD.L	A3,#R16"NAME$	LOAD.L	A2,#R16"TERM$	LIB	?CPSTRING	; est-ce le fichier "PAGE.PAGE" ?	JUMP',NC EXIT$		; oui => EXIT$	LOAD.L	A4,#(A6)+OBUNAMELOOP$:	LOAD.B	(A4+),(A1+)	; OBUNAME <-- nom	JUMP',EQ EXIT$	COMP.B	(A4)-1,#CR	JUMP,NE LOOP$	CLR.B	(A4)-1EXIT$:	POPM.L	A1..A4	RETNAME$:	.ASCIZ	"PAGE.PAGE"TERM$:	.B	0,CR,-1	.EVEN;--------\\; GETFILE >;========/; Prend le nom de fichier dans OBUNAME.; in	A3.L	^buffer; out	-; mod	D7.WGETFILE:	PUSHM.L	A3,A4	LOAD.L	A4,#(A6)+OBUNAMELOOP$:	LOAD.B	(A3+),(A4+)	; buffer <-- OBUNAME	JUMP',EQ EXIT$	COMP.B	(A3)-1,#CR	JUMP,NE LOOP$	CLR.B	(A3)-1EXIT$:	POPM.L	A3,A4	RET;--------\\; ADDEXT  >;========/; Transfert le nom de fichier dans OBXFILE et force une extension.; in	A3.L	^nom sans extension;	A4.L	^extension  ajouter; out	A3.L	^nom avec extension (dans OBXFILE); mod	D7.W, A3.LADDEXT:	PUSHM.L	D3,A2	LOAD.L	A2,#(A6)+OBXFILE50$:	LOAD.B	(A2+),(A3+)	; OBXFILE <-- nom tel quel	JUMP,NE 50$80$:	LOAD.L	A3,#(A6)+OBXFILE	LOAD.W	D3,#1		; D3 <-- force l'extension	LIB	?ADDEXT		; ajoute l'extension	POPM.L	D3,A2	RET;--------\\; SKIPREP >;========/; Saute tous les noms d'units et de rpertoires devant; un nom de fichier.; in	A3.L	^unit:rp:rp:nom.ext; out	A3.L	^nom.ext; mod	A3.LSKIPREP:	PUSH.W	D3	CLR.W	D310$:	INC.W	D3	TEST.B	(A3+)	JUMP,NE 10$20$:	DEC.W	D3	JUMP',NS EXIT$	COMP.B	(-A3),#':	JUMP,NE 20$	INC.L	A3EXIT$:	POP.W	D3	RET;---------\\; DICOLOAD >;=========/; Donne le canal du dictionnaire, en le chargeant au pralable; si ncessaire.; in	-; out	D6.L	canal DICO;	D7.W	erreur; mod	D6.L, D7.WDICOLOAD:	PUSHM.L	D3,D4	LOAD.L	D6,(A6)+OCIDICO	JUMP',NE 80$	CALL	DBOXOPEN1	DICO_	OPEN		; ouvre le dictionnaire	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7	JUMP',NE 90$	LOAD.L	(A6)+OCIDICO,D6	LOAD.L	D4,(A6)+OFDICO	; D4 <-- dfinitions	JUMP',EQ 80$	LOAD.W	D3,#2		; D3 <-- put	DICO_	DEF		; donne les fanions au module DICO80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DICOSTATUS >;===========/; Donne l'tat de chargement du dictionnaire.; in	-; out	D4.W	0 => dictionnaire pas charg;	D7.W	erreur si module DICO absent; mod	D4.L, D7.WDICOSTATUS:	LOAD.W	D7,#1	TEST.W	(A6)+OCHDICO	; module DICO charg ?	JUMP',EQ EXIT$		; non => EXIT$	CLR.W	D4		; D4 <-- dico pas chang	TEST.L	(A6)+OCIDICO	JUMP',EQ OK$	INC.W	D4		; D4 <-- dico chargOK$:	CLR.W	D7		; D7 <-- okEXIT$:	TEST.W	D7		; retour EQ/NE	RET	.END