	.SBTTL	OPPENDBOX.ASI;--------\\; XopDGET >;========/; Donne le numro du pinceau slectionn.; in	A0.L	canal;	A4.L	^table des pinceaux/nil si par dfaut; out	D3.W	pinceau slectionn;	D7.W	erreur; mod	D3.L, D7.WXopDGET:	PUSH.L	A4	COMP.L	A4,#0		; objet par dfaut ?	JUMP',NE NODEF$		; non => NODEF$	LOAD.L	A4,(A0)+OPDEF	; A4 <-- ^objet pinceau par dfautNODEF$:	LOAD.W	D3,(A4)+OTAPSEL	; D3 <-- pinceau slectionn	POP.L	A4	CLR.W	D7		; retour EQ	RET;--------\\; XopDPUT >;========/; Spcifie le numro du pinceau.; in	A0.L	canal;	A4.L	^table des pinceaux/nil si par dfaut;	D3.W	pinceau  slectionner; out	D7.W	erreur; mod	D7.WXopDPUT:	PUSH.L	A4	COMP.L	A4,#0		; objet par dfaut ?	JUMP',NE NODEF$		; non => NODEF$	LOAD.L	A4,(A0)+OPDEF	; A4 <-- ^objet pinceau par dfautNODEF$:	LOAD.W	(A4)+OTAPSEL,D3	; slectionne un pinceau	POP.L	A4	CLR.W	D7		; retour EQ	RET;------------\\; XopDTSELECT >;============/; Choisi et/ou modifie un pinceau temporaire  utiliser.; in	A0.L	canal;	A4.L	^table des pinceaux/nil si par dfaut;	D2.W	pinceau  slectionner; out	D2.W	pinceau slectionn;	D3.L	dernire touche (F1/F0);	D4.W	nb de pinceaux modifis;	D7.W	erreur; mod	D2.L, D3.L, D4.L, D7.WXopDTSELECT:	PUSH.L	A4	COMP.L	A4,#0		; objet par dfaut ?	JUMP',NE NODEF$		; non => NODEF$	LOAD.L	A4,(A0)+OPDEF	; A4 <-- ^objet pinceau par dfautNODEF$:	PUSH.W	(A4)+OTAPSEL	; stack <-- pinceau slectionn	LOAD.W	(A4)+OTAPSEL,D2	; OTAPSEL <-- pinceau slectionn temporairement	CALL	XopDSELECT	; choisi/modifie un pinceau ...	LOAD.W	D2,(A4)+OTAPSEL	; D2 <-- pinceau slectionn temporairement	POP.W	(A4)+OTAPSEL	; OTAPSEL <-- pinceau slectionn initialement	POP.L	A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; XopDSELECT >;===========/; Choisi et/ou modifie un pinceau  utiliser.; in	A0.L	canal;	A4.L	^table des pinceaux/nil si par dfaut; out	D3.L	dernire touche (F1/F0);	D4.W	nb de pinceaux modifis;	D7.W	erreur; mod	D3.L, D4.L, D7.WXopDSELECT:	PUSHM.L	D0..D2,D5,D6,A0..A5	LOAD.L	A5,A0		; A5 <-- ^variables globales	LOAD.L	A0,(A5)+OPDDIS	; A0 <-- ^descripteur fentre	COMP.L	A4,#0		; objet par dfaut ?	JUMP',NE NODEF$		; non => NODEF$	LOAD.L	A4,(A5)+OPDEF	; A4 <-- ^objet pinceau par dfautNODEF$:	LOAD.L	(A5)+OPTAB,A4	; OPTAB <-- ^table des pinceaux	LOAD.W	D6,(A4)+OTAPSEL	; D6 <-- pinceau slectionn	LOAD.L	A2,#R16"TDBOX_PEN	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	LOAD.W	D7,#DB_OPEN	PAGE_	DBOX		; ouvre la DBOX	JUMP,NE EXIT$	LOAD.W	D3,#IDENTPEN	LOAD.L	A4,#(A5)+OUSBUF	LOAD.W	D4,#NBRX*NBRY	LOAD.W	D7,#DF_GETULIST	PAGE_	DEF		; OUSBUF <-- pinceaux utiliss	CALL	DBPALGET	; cran <-- image mmorise	JUMP',EQ PALOK$	CALL	DBRDESCADRE	; dessine les cadres des rectangles	CLR.W	D0	LOAD.W	D1,#NBRX*NBRY	CALL	DBRDESPENS	; dessine tous les pinceaux	CALL	DBPALSAV	; buffer <-- image cranPALOK$:	CLR.W	D0	LOAD.W	D1,#NBRX*NBRY	CALL	DBRUSEPENS	; marque les utiliss	LOAD.W	D0,D6	CALL	DBRINV		; inverse le rectangle slectionn	CLR.W	D0		; D0 <-- nb de pinceaux modifisLOOP$:	LOAD.W	D7,#MI_SCMO	PAGE_	MISC		; remet la souris	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_PEN	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ USE$	COMP.W	D3,#F4	JUMP,EQ MODIF$	COMP.W	D3,#F7	JUMP,EQ PREND$	COMP.W	D3,#F9	JUMP,EQ SAUVE$	COMP.W	D3,#F0	JUMP,EQ END$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$CLIC$:	CALL	DBRSEL		; slectionne un nouveau rectangle	JUMP,NE BIP$	COMP.W	D3,#KEYMGP	JUMP,EQ USE$	COMP.W	D3,#KEYMMP	JUMP,EQ USE$	COMP.W	D3,#KEYMDP	JUMP,EQ USE$	JUMP	LOOP$MODIF$:	CALL	DBOXMODPEN	; modifie un pinceau ...	PUSH.W	D7	LOAD.L	A2,#R16"TDBOX_PEN	LOAD.W	D7,#DB_RSK	PAGE_	DBOX		; refait les soft-keys	POP.W	D7	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	PUSH.W	D0	LOAD.W	D0,D6	LOAD.W	D1,#1	CALL	DBRINV		; teint le rectangle slectionn	CALL	DBRDESPENS	; dessine le pinceau modifi	CALL	DBRUSEPENS	; marque l'utilis	CALL	DBPALSAV	; buffer <-- image cran	CALL	DBRINV		; allume le rectangle slectionn	POP.W	D0	INC.W	D0		; D0 <-- un pinceau de plus modifi	JUMP	LOOP$PREND$:	CALL	PENPREND	; prend les pinceaux ...	PUSH.W	D7	LOAD.L	A2,#R16"TDBOX_PEN	LOAD.W	D7,#DB_RSK	PAGE_	DBOX		; refait les soft-keys	POP.W	D7	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	LOAD.W	D0,D6	CALL	DBRINV		; teint le rectangle slectionn	CLR.W	D0	LOAD.W	D1,#NBRX*NBRY	CALL	DBRDESPENS	; dessine tous les pinceaux	CALL	DBRUSEPENS	; marque les utiliss	CALL	DBPALSAV	; buffer <-- image cran	LOAD.W	D0,D6	CALL	DBRINV		; allume le rectangle slectionn	LOAD.W	D0,#NBRX*NBRY	; D0 <-- tous les pinceaux modifis	JUMP	LOOP$SAUVE$:	CALL	PENSAUVE	; sauve les pinceaux ...	PUSH.W	D7	LOAD.L	A2,#R16"TDBOX_PEN	LOAD.W	D7,#DB_RSK	PAGE_	DBOX		; refait les soft-keys	POP.W	D7	JUMP,NE BIP$	JUMP	LOOP$USE$:	LOAD.L	A4,(A5)+OPTAB	; A4 <-- ^table des pinceaux	LOAD.W	(A4)+OTAPSEL,D6	; mj. le pinceau slectionnEND$:	LOAD.W	D4,D0		; D4 <-- nb de pinceaux modifis	JUMP',EQ NOREG$	INC.L	(A5)+OREGEN	; change le numro de rgnrationNOREG$:	LOAD.W	D7,#DB_CLOSE	PAGE_	DBOX		; ferme la DBOXEXIT$:	POPM.L	D0..D2,D5,D6,A0..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX_PEN:	.W	10$-TDBOX_PEN	.W	20$-TDBOX_PEN	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Choix du trait :"	.B	ODBCR,ODBCR2	.B	ODBLABEL,100	.B	ODBTEXT,0	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBTABX,60	.B	ODBLABEL,101	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" UTILISE "	.B	ODBBOX,0,F4,TDBMEV	.ASCIZ	" MODIFIE "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F7,TDBNORM	.ASCIZ	" PREND "	.B	ODBBOX,0,F9,TDBNORM	.ASCIZ	" SAUVE "	.B	ODBTABX,60-10	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Utilise"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Modifie"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Prend       Sauve"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_PEN:	.W	F1,F2,F3,0		DOKF1-TKEY_PEN	.W	F4,F5,F6,0		DOKF4-TKEY_PEN	.W	F7,0			DOKF7-TKEY_PEN	.W	F9,0			DOKF9-TKEY_PEN	.W	F0,F13,F14,F15,0	DOKF0-TKEY_PEN	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_PEN	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_PEN	.W	0;-----------\\; DBOXMODPEN >;===========/; Modifie un pinceau.; in	D6.W	pinceau  modifier; out	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXMODPEN:	PUSHM.L	D0..D2,D4..D6,A1..A4	MUL.WU	D6,#LDPEN	LOAD.L	A4,(A5)+OPTAB	; A4 <-- ^table des pinceaux	ADD.L	A4,D6	LOAD.W	(A5)+ODBPLX,(A4)+OPENLX	LOAD.W	(A5)+ODBPLY,(A4)+OPENLY	LOAD.L	(A5)+ODBPT1,(A4)+OPENT1	LOAD.L	(A5)+ODBPT3,(A4)+OPENT3	LOAD.L	(A5)+ODBPT5,(A4)+OPENT5	LOAD.L	(A5)+ODBPCO,(A4)+OPENCO	LOAD.L	D4,(A4)+OPENFA	; D4 <-- fanions	JUMP',NE DEF$	LOAD.L	D4,#2^BPENCE!2^BPENCODEF$:	LOAD.L	A2,#R16"TDBOX$	LOAD.W	D7,#DB_MEMPT	PAGE_	DBOX		; mj ^table dbox	LOAD.L	A2,#R16"DBMPTESTC	LOAD.W	D7,#DB_MEMAFC	PAGE_	DBOX		; mj ^routine d'affichage	LOAD.L	A2,#R16"TDBOX_MODPEN	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.W	D7,#DB_OPEN	PAGE_	DBOX		; ouvre la DBOX	JUMP,NE EXIT$	LOAD.W	D2,#2^BDBGCLABEL!200	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	LOAD.W	D2,#2^BDBGCLABEL!201	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	CLR.W	D2AFF$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_AFF	PAGE_	DBOX		; affiche le paramtre	INC.W	D2	COMP.W	D2,#8	JUMP,LO AFF$	CALL	DBMPFORM	; mj dbox selon forme	CALL	DBMPTT		; mj dbox selon type de trait	CLR.W	D2NLINE$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_MEDIT	PAGE_	DBOXTEST$:	CALL	DBMPTEST	; affiche le trait obtenuLOOP$:	LOAD.W	D7,#MI_SCMO	PAGE_	MISC		; remet la souris	DBOX_	EDIT		; attend une action ...	LOAD.W	D7,#DB_ZEROCR	PAGE_	DBOX		; remplace <CR> par <0>	LOAD.L	A1,#R16"TKEY_MODPEN	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#F7	JUMP,EQ COLOR$	COMP.W	D3,#UNDO	JUMP,EQ UNDO$	COMP.W	D3,#CLEAR	JUMP,EQ UNDO$	COMP.W	D3,#CR	JUMP,EQ RETURN$	COMP.W	D3,#ENTER	JUMP,EQ ENTER$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,#1	JUMP',NE RETURN2$	TEST.L	D4:#BPENEL	JUMP',BS RETURN2$	TEST.L	D4:#BPENRE	JUMP',BS RETURN2$	INC.W	D2		; D2 <-- saute le paramtre "hauteur"RETURN2$:	LOAD.W	D1,#2	TEST.L	D4:#BPENTT	JUMP',BC RETURN4$	LOAD.W	D1,#2+6RETURN4$:	COMP.W	D2,D1	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$CLIC$:	LOAD.L	(A5)+ODBPFA,D4	LOAD.W	D7,#DB_CLIC	PAGE_	DBOX	JUMP,EQ LOOP$	JUMP	TEST$ENTER$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	JUMP	TEST$KEYDBOX$:			; KEYDBOX =>	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	COMP.B	D3,#100	JUMP,HS CLINE$	LOAD.L	D1,#H'FFFFFF00	COMP.B	D3,#8	JUMP',LO SET$	RL.L	D1,#8	COMP.B	D3,#16	JUMP',LO SET$	RL.L	D1,#8	COMP.B	D3,#24	JUMP',LO SET$	RL.L	D1,#8SET$:	AND.L	D4,D1	TSET.L	D4:D3	COMP.B	D3,#BPENCE	JUMP',EQ FORME$	COMP.B	D3,#BPENCA	JUMP',EQ FORME$	COMP.B	D3,#BPENEL	JUMP',EQ FORME$	COMP.B	D3,#BPENRE	JUMP',EQ FORME$	COMP.B	D3,#BPENCO	JUMP',EQ TT$	COMP.B	D3,#BPENTT	JUMP',EQ TT$	CLR.W	D2	JUMP	NLINE$FORME$:	CALL	DBMPFORM	; mj dbox selon forme	CALL	DBMPSQUA	; mj dbox "hauteur" selon "largeur"	CLR.W	D2	JUMP	NLINE$TT$:	CALL	DBMPTT		; mj dbox selon type de trait	LOAD.W	D2,#2	TEST.L	D4:#BPENTT	JUMP,BS NLINE$	CLR.W	D2	JUMP	NLINE$CLINE$:	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$COLOR$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	LOAD.L	A3,#R16"TMCOLOR$	LOAD.W	D3,(A5)+ODBPCO	LIB	?MMENU		; choix de la couleur ...	JUMP,NE NLINE$	LOAD.W	(A5)+ODBPCO,D3	JUMP	NLINE$OK$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	LOAD.L	A4,(A5)+OPTAB	; A4 <-- ^table des pinceaux	ADD.L	A4,D6	CALL	DBMPPUT		; OPENxx <-- ODBPxxEND$:	LOAD.W	D7,#DB_CLOSE	PAGE_	DBOX		; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4..D6,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	ODBPLX,DBTYPU,0,100*FACMMPT,01*FACMMPT,2^BDBGCLABEL!100,0,7+2	.W	ODBPLY,DBTYPU,0,100*FACMMPT,01*FACMMPT,2^BDBGCLABEL!101,1,7+2	.W	ODBPT1,DBTYPUF,0,500*FACMMPT,10*FACMMPT,2^BDBGCLABEL!102,2,7+2	.W	ODBPT2,DBTYPUF,0,500*FACMMPT,10*FACMMPT,2^BDBGCLABEL!103,3,7+2	.W	ODBPT3,DBTYPUF,0,500*FACMMPT,10*FACMMPT,2^BDBGCLABEL!104,4,7+2	.W	ODBPT4,DBTYPUF,0,500*FACMMPT,10*FACMMPT,2^BDBGCLABEL!105,5,7+2	.W	ODBPT5,DBTYPUF,0,500*FACMMPT,10*FACMMPT,2^BDBGCLABEL!106,6,7+2	.W	ODBPT6,DBTYPUF,0,500*FACMMPT,10*FACMMPT,2^BDBGCLABEL!107,7,7+2	.W	-1TMCOLOR$:	.ASCIZ	" noir "	.B	-1	.ASCIZ	" rouge "	.ASCIZ	" vert "	.ASCIZ	" bleu "	.ASCIZ	" violet "	.ASCIZ	" jaune "	.ASCIZ	" brun "	.ASCIZ	" gris "	.B	-1	.ASCIZ	" blanc "	.B	0	.EVEN;---------\\; DBMPFORM >;---------/; Met  jour la dbox selon la forme du pinceau.; in	D4.L	fanions; out	-; mod	D7.WDBMPFORM:	PUSHM.L	D1..D4,A3	LOAD.L	D1,D4		; D1 <-- fanions	LOAD.L	A3,#R16"TXCE$	TEST.L	D1:#BPENCE	JUMP',BS 20$	LOAD.L	A3,#R16"TXCA$	TEST.L	D1:#BPENCA	JUMP',BS 20$	LOAD.L	A3,#R16"TXXY$20$:	LOAD.W	D2,#2^BDBGCLABEL!20	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTEXT		; affiche "Diamtre", "Ct" ou "Largeur"	INC.W	D2	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTEXT		; affiche "   " ou "Hauteur"	LOAD.W	D2,#2^BDBGCLABEL!2^BDBGCGREY!101	TEST.L	D1:#BPENCE	JUMP',BS 40$	TEST.L	D1:#BPENCA	JUMP',BS 40$	LOAD.W	D2,#2^BDBGCLABEL!2^BDBGCFULL!10140$:	DBOX_	GETCO	POPM.L	D1..D4,A3	RETTXCE$:	.ASCIZ	"Diamtre:"	.ASCIZ	"         "TXCA$:	.ASCIZ	"Ct:    "	.ASCIZ	"         "TXXY$:	.ASCIZ	"Largeur: "	.ASCIZ	"Hauteur: "	.EVEN;---------\\; DBMPSQUA >;---------/; Met  jour la dbox selon la forme du pinceau.; in	D4.L	fanions; out	-; mod	D7.WDBMPSQUA:	PUSHM.L	D2,A3,A4	TEST.L	D4:#BPENCE	JUMP',BS 90$	TEST.L	D4:#BPENCA	JUMP',BS 90$	LOAD.W	(A5)+ODBPLY,(A5)+ODBPLX	LOAD.W	D2,#1	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_AFF	PAGE_	DBOX		; affiche le paramtre "hauteur" selon "largeur"90$:	POPM.L	D2,A3,A4	RET;-------\\; DBMPTT >;-------/; Met  jour la dbox selon le type de trait.; in	D4.L	fanions; out	-; mod	D7.WDBMPTT:	PUSHM.L	D1..D4,A3,A4	LOAD.L	D1,D4		; D1 <-- fanions	LOAD.W	D2,#2^BDBGCLABEL!2^BDBGCGREY!102	TEST.L	D1:#BPENTT	JUMP',BC 20$	LOAD.W	D2,#2^BDBGCLABEL!2^BDBGCFULL!10220$:	DBOX_	GETCO		; grise/dgrise les trait/trou	INC.B	D2	COMP.B	D2,#102+6+3	JUMP,LO 20$	TEST.L	D1:#BPENTT	JUMP',BC 90$	LOAD.W	D2,#260$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_AFF	PAGE_	DBOX		; affiche le paramtre	INC.W	D2	COMP.W	D2,#8	JUMP,LO 60$90$:	POPM.L	D1..D4,A3,A4	RET;----------\\; DBMPTESTC >;----------/; Affiche un petit trait de test pendant le DB_CLIC.; in	D2.W	mode (CLRDOT/SETDOT); out	-; mod	D7.WDBMPTESTC:	PUSH.L	D4	COMP.W	D2,#SETDOT	JUMP',NE EXIT$	LOAD.L	D4,(A5)+ODBPFA	CALL	DBMPTESTEXIT$:	POP.L	D4	RET;---------\\; DBMPTEST >;---------/; Affiche un petit trait de test.; in	D4.L	fanions; out	-; mod	D7.WDBMPTEST:	PUSHM.L	D1..D5,A0,A3,A4	LOAD.L	A4,#(A5)+OTPEN	; A4 <-- ^pinceau bidon	CALL	DBMPPUT		; OPENxx <-- ODBPxx	LOAD.W	D4,#1	LOAD.W	D7,#DR_CHGSCALE	PAGE_	DRAW		; met l'chelle 100%	PUSH.W	D4	LOAD.L	D2,D5	LIB	?GETWDO		; D3/D4 <-- pos/dim sous-fentre actuelle	PUSH.L	D3	PUSH.L	D4	LOAD.L	D5,D2	CLR.L	D4	CALL	DRMDEF		; trame pour effacer	LOAD.W	D2,#2^BDBGCLABEL!31	DBOX_	GETCO	SWAP.W	D3	ADD.W	D3,#4	SWAP.W	D3	PUSH.L	D3	LOAD.W	D2,#2^BDBGCLABEL!30	DBOX_	GETCO	POP.L	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; dessine le pourtour	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface l'intrieur	ADD.W	D3,(A0)+ODFFX	SWAP.W	D3	ADD.W	D3,(A0)+ODFFY;	SWAP.W	D3	SWAP.W	D4	LOAD.L	A3,#(A5)+OBUDIS+1	LOAD.B	(A3)+0,#DIMWDO	LOAD.L	(A3)+1,D3	LOAD.L	(A3)+5,D4	LOAD.W	D3,#9	LIB	?STRING		; dessine dans une sous-fentre !	CLR.L	D3		; D3 <-- origine dans sous-fentre	SWAP.W	D4		; D4 <-- dimensions	LIB	?AFTIM	.B	COLOROP,COLOROPPUSH,0	.EVEN	PUSHM.L	D3,A0	LOAD.W	D2,#SETDOT	; D2 <-- mode	CLR.W	D3		; D3 <-- numro du pinceau bidon;	LOAD.L	A4,#(A5)+OTPEN	; A4 <-- ^pinceau bidon	LOAD.L	A0,A5		; A0 <-- canal	CALL	XopDUSE		; utilise le pinceau bidon	POPM.L	D3,A0	COMP.W	D2,#-1		; pinceau nul ?	JUMP',EQ END$		; oui => END$	SWAP.W	D3	SWAP.W	D4	LOAD.W	D1,D4	SR.W	D1,#1	LOAD.W	D3,D1	CLR.W	D4	SWAP.W	D4	SWAP.W	D3	ADD.W	D3,D1	SUB.W	D4,D1	SUB.W	D4,D1	LIB	?DRSEG		; dessine le traitEND$:	POP.L	D4	POP.L	D3	LOAD.L	A3,#(A5)+OBUDIS+1	LOAD.B	(A3)+0,#DIMWDO	SWAP.W	D3	LOAD.L	(A3)+1,D3	SWAP.W	D4	LOAD.L	(A3)+5,D4	LOAD.W	D3,#9	LIB	?STRING		; remet la sous-fentre initiale	LIB	?AFTIM	.B	COLOROP,COLOROPPOP,0	.EVEN	POP.W	D4	LOAD.W	D7,#DR_PUTSCALE	PAGE_	DRAW		; remet l'chelle courante	POPM.L	D1..D5,A0,A3,A4	RET;--------\\; DBMPPUT >;--------/; Met  jour les paramtres d'un pinceau.; in	A4.L	^pinceau;	D4.L	fanions; out	-; mod	D7.WDBMPPUT:	PUSH.L	D3	LOAD.W	(A4)+OPENLX,(A5)+ODBPLX	LOAD.W	(A4)+OPENLY,(A5)+ODBPLY	LOAD.L	(A4)+OPENT1,(A5)+ODBPT1	LOAD.L	(A4)+OPENT3,(A5)+ODBPT3	LOAD.L	(A4)+OPENT5,(A5)+ODBPT5	LOAD.L	(A4)+OPENCO,(A5)+ODBPCO	LOAD.L	(A4)+OPENFA,D4	TEST.L	D4:#BPENEL	JUMP',BS 50$	TEST.L	D4:#BPENRE	JUMP',BS 50$	LOAD.W	(A4)+OPENLY,(A4)+OPENLX50$:	POP.L	D3	RETTDBOX_MODPEN:	.W	10$-TDBOX_MODPEN	.W	20$-TDBOX_MODPEN	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"    Pinceau:"	.B	ODBTABX,37+1	.B	ODBLABEL,20	.B	ODBTEXT,0	.B	ODBTABX,37+13+1	.B	ODBLABEL,21	.B	ODBTEXT,0	.B	ODBCR	.B	ODBLCIRCLE,BPENCE!2^6!2^7,KEYDBOX/H'100,BPENCE	.ASCIZ	" circulaire"	.B	ODBTABX,15	.B	ODBLCIRCLE,BPENEL!2^6!2^7,KEYDBOX/H'100,BPENEL	.ASCIZ	" elliptique"	.B	ODBCR2	.B	ODBTABX,37	.B	ODBLABEL,100	.B	ODBCLINE,(7+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTABX,37+13	.B	ODBLABEL,101	.B	ODBCLINE,(7+2)!2^7,KEYDBOX/H'100,101,TDBNORM	.B	ODBCR2	.B	ODBLCIRCLE,BPENCA!2^6!2^7,KEYDBOX/H'100,BPENCA	.ASCIZ	" carr"	.B	ODBTABX,15	.B	ODBLCIRCLE,BPENRE!2^6!2^7,KEYDBOX/H'100,BPENRE	.ASCIZ	" rectangulaire"	.B	ODBCR	.B	ODBLABEL,200	.B	ODBTEXT,0	.B	ODBCR	.B	ODBLCIRCLE,BPENCO!2^6!2^7,KEYDBOX/H'100,BPENCO	.ASCIZ	" trait continu"	.B	ODBCR2	.B	ODBTABX,21	.B	ODBLABEL,108	.B	ODBTEXT	.ASCIZ	"1er  trait/trou"	.B	ODBTABX,37	.B	ODBLABEL,102	.B	ODBCLINE,(7+2)!2^7,KEYDBOX/H'100,102,TDBNORM	.B	ODBTABX,37+13	.B	ODBLABEL,103	.B	ODBCLINE,(7+2)!2^7,KEYDBOX/H'100,103,TDBNORM	.B	ODBCR2	.B	ODBLCIRCLE,BPENTT!2^6!2^7,KEYDBOX/H'100,BPENTT	.ASCIZ	" trait pointill"	.B	ODBCR,ODBCR2	.B	ODBTABX,21	.B	ODBLABEL,109	.B	ODBTEXT	.ASCIZ	"2me trait/trou"	.B	ODBTABX,37	.B	ODBLABEL,104	.B	ODBCLINE,(7+2)!2^7,KEYDBOX/H'100,104,TDBNORM	.B	ODBTABX,37+13	.B	ODBLABEL,105	.B	ODBCLINE,(7+2)!2^7,KEYDBOX/H'100,105,TDBNORM	.B	ODBCR,ODBCR	.B	ODBTABX,21	.B	ODBLABEL,110	.B	ODBTEXT	.ASCIZ	"3me trait/trou"	.B	ODBTABX,37	.B	ODBLABEL,106	.B	ODBCLINE,(7+2)!2^7,KEYDBOX/H'100,106,TDBNORM	.B	ODBTABX,37+13	.B	ODBLABEL,107	.B	ODBCLINE,(7+2)!2^7,KEYDBOX/H'100,107,TDBNORM	.B	ODBCR	.B	ODBLABEL,201	.B	ODBTEXT,0	.B	ODBCR	.B	ODBTABX,30	.B	ODBLABEL,30	.B	ODBTEXT,0	.B	ODBCR	.B	ODBTABX,15	.B	ODBBOX,0,F7,TDBOMBRE	.ASCIZ	" COULEUR "	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE  "	.B	ODBTABX,30+32	.B	ODBLABEL,31	.B	ODBTEXT	.ASCIZ	" "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_MODPEN:	.W	F1,F2,F3,0		DOKF1-TKEY_MODPEN	.W	F0,F13,F14,F15,0	DOKF0-TKEY_MODPEN	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_MODPEN	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_MODPEN	.W	0;---------\\; DBPALSAV >;---------/; Sauve l'image cran de la palette.; in	-; out	D7.W	erreur; mod	D7.WDBPALSAV:	PUSHM.L	D1..D6,A3,A4	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP,NE OK$		; oui => OK	TEST.L	(A5)+ODBRPB	JUMP',NE BUFOK$	LOAD.W	D4,(A5)+ODBRLX	MUL.WU	D4,#NBRX	INC.W	D4	LOAD.W	(A5)+ODBRPD+2,D4	LOAD.W	D4,(A5)+ODBRLY	MUL.WU	D4,#NBRY	INC.W	D4	LOAD.W	(A5)+ODBRPD+0,D4	LOAD.W	D4,(A5)+ODBRPD+2	ADD.W	D4,#16-1	SR.W	D4,#4	SL.W	D4,#1	MUL.WU	D4,(A5)+ODBRPD+0	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour image cran	JUMP',NE EXIT$	LOAD.L	(A5)+ODBRPB,A4BUFOK$:	LOAD.W	D7,#MI_CCMO	PAGE_	MISC		; enlve la souris	LOAD.L	D3,(A5)+ODBRPY	LOAD.L	A3,#0	CLR.L	D4	LOAD.L	A4,(A5)+ODBRPB	LOAD.W	D6,(A5)+ODBRPD+2	ADD.W	D6,#16-1	SR.W	D6,#4	SL.W	D6,#1	LOAD.L	D2,(A5)+ODBRPD	LOAD.W	D1,#LOADDOT	LOAD.L	A2,A0	GRA_	RASTER		; buffer <-- image cranOK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBPALGET >;---------/; Restitue l'image cran de la palette.; in	-; out	D7.W	erreur; mod	D7.WDBPALGET:	PUSHM.L	D1..D6,A3,A4	LOAD.W	D7,#1	TEST.L	(A5)+ODBRPB	JUMP',EQ EXIT$	LOAD.W	D7,#MI_CCMO	PAGE_	MISC		; enlve la souris	CLR.L	D3	LOAD.L	A3,(A5)+ODBRPB	LOAD.W	D5,(A5)+ODBRPD+2	ADD.W	D5,#16-1	SR.W	D5,#4	SL.W	D5,#1	LOAD.L	D4,(A5)+ODBRPY	LOAD.L	A4,#0	LOAD.L	D2,(A5)+ODBRPD+0	LOAD.W	D1,#LOADDOT	LOAD.L	A2,A0	GRA_	RASTER		; cran <-- image mmorise	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-------\\; DBRSEL >;-------/; Slectionne un nouveau rectangle.; in	D6.W	rectangle slectionn (0..n); out	D6.W	nouveau rectangle (0..n);	D3.L	touche presse;	D7.W	erreur; mod	D3.L, D6.L, D7.WDBRSEL:	PUSHM.L	D0,D4	CALL	DBRDET		; est-on dans un rectangle ?	JUMP',NE 90$		; non => 90$	EX.L	D0,D6	CALL	DBRINV		; efface l'ancien	LOAD.W	D0,D6	CALL	DBRINV		; allume le nouveau20$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris bouge ?	JUMP',NE 80$		; non => 80$	CALL	DBRDET		; D0 <-- rectangle o est la souris	JUMP,NE 20$	COMP.W	D0,D6		; toujours dans le mme ?	JUMP,EQ 20$		; oui => 20$				; non =>	EX.L	D0,D6	CALL	DBRINV		; efface l'ancien	LOAD.W	D0,D6	CALL	DBRINV		; allume le nouveau	JUMP	20$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,D4	TEST.W	D7		; retour EQ/NE	RET;-------\\; DBRDET >;-------/; Dtecte dans quel rectangle est la souris.; in	-; out	D0.W	rectangle (0..n);	D7.W	erreur; mod	D0.L, D7.WDBRDET:	PUSHM.L	D1..D4	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP',NE 90$	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la matrice	SUB.W	D4,(A0)+ODFFX	; D4 <-- pos relative dans swdo	JUMP',LO 90$	SUB.W	D4,(A5)+ODBRPX	; D4 <-- pos relative dans rectangle	JUMP',LO 90$	CLR.L	D0	LOAD.W	D0,D4	DIV.WU	D0,(A5)+ODBRLX	; D0 <-- coordonne X	COMP.W	D0,#NBRX	JUMP',HS 90$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	; D4 <-- pos relative dans swdo	JUMP',LO 90$	SUB.W	D4,(A5)+ODBRPY	; D4 <-- pos relative dans rectangle	JUMP',LO 90$	CLR.L	D1	LOAD.W	D1,D4	DIV.WU	D1,(A5)+ODBRLY	; D1 <-- coordonne Y	COMP.W	D1,#NBRY	JUMP',HS 90$	MUL.WU	D1,#NBRX	ADD.W	D0,D1		; D0 <-- no du rectangle	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RET;-------\\; DBRINV >;-------/; Inverse un rectangle.; in	D0.W	no du rectangle (0..n); out	-; mod	D7.WDBRINV:	PUSHM.L	D2..D4	LOAD.L	D4,#-1	CALL	DRMDEF	LOAD.W	D2,#INVDOT	CALL	DBRPOS	JUMP',NE 90$	PUSHM.L	D3,D4	ADD.W	D3,#2	SWAP.W	D3	ADD.W	D3,#2	SWAP.W	D3	SUB.W	D4,#3	SWAP.W	D4	SUB.W	D4,#3	SWAP.W	D4;;?	DEC.W	D3;;?	SWAP.W	D3;;?	DEC.W	D3;;?	SWAP.W	D3;;?	ADD.W	D4,#3;;?	SWAP.W	D4;;?	ADD.W	D4,#3;;?	SWAP.W	D4	LIB	?DRTRAME	; inverse un rectangle	POPM.L	D3,D490$:	POPM.L	D2..D4	RET;-----------\\; DBRUSEPENS >;-----------/; Dessine une ou plusieurs utilisations.; in	D0.W	premier pinceau;	D1.W	nombre de pinceaux; out	-; mod	D7.WDBRUSEPENS:	PUSHM.L	D0..D4,A3,A4	LOAD.L	A3,#(A5)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWMATRIXLOOP$:	CALL	DBRPOS		; D3/D4 <-- pos/dim	JUMP',NE EXIT$	INC.W	D3	SWAP.W	D3	INC.W	D3	LOAD.L	(A3)+1,D3	LOAD.L	A4,#R16"MACLR$	LOAD.L	(A3)+5,A4	LOAD.B	(A3)+9,#CLRDOT!PENDOT	LOAD.W	D3,#10	LIB	?STRING	LOAD.L	A4,#(A5)+OUSBUF	TEST.B	(A4)+(D0.W)	; pinceau utilis ?	JUMP',EQ NEXT$		; non => NEXT$	LOAD.L	A4,#R16"MASET$	LOAD.L	(A3)+5,A4	LOAD.B	(A3)+9,#SETDOT!PENDOT	LOAD.W	D3,#10	LIB	?STRINGNEXT$:	INC.W	D0	DEC.W	D1	JUMP,NE LOOP$EXIT$:	POPM.L	D0..D4,A3,A4	RETMACLR$:	.B	8,8	.B	B'11111111	.B	B'11111111	.B	B'11111110	.B	B'11111100	.B	B'11111000	.B	B'11110000	.B	B'11100000	.B	B'11000000MASET$:	.B	8,8	.B	B'00000000	.B	B'01111110	.B	B'01111100	.B	B'01111000	.B	B'01110000	.B	B'01100000	.B	B'01000000	.B	B'00000000	.EVEN;-----------\\; DBRDESPENS >;-----------/; Dessine un ou plusieurs pinceaux.; in	D0.W	premier pinceau;	D1.W	nombre de pinceaux; out	-; mod	D7.WDBRDESPENS:	PUSHM.L	D0..D6,A3	LOAD.W	D7,#DR_GETSCALE	PAGE_	DRAW		; D4 <-- chelle courante	LOAD.W	D6,D4	LOAD.W	D4,#1	LOAD.W	D7,#DR_PUTSCALE	PAGE_	DRAW		; met l'chelle 100%	LIB	?GETWDO		; D3/D4 <-- pos/dim sous-fentre actuelle20$:	CALL	DBRDESPEN	; dessine un pinceau	INC.W	D0	DEC.W	D1	JUMP,NE 20$	LOAD.L	A3,#(A5)+OBUDIS+1	LOAD.B	(A3)+0,#DIMWDO	SWAP.W	D3	LOAD.L	(A3)+1,D3	SWAP.W	D4	LOAD.L	(A3)+5,D4	LOAD.W	D3,#9	LIB	?STRING		; remet la sous-fentre initiale	LOAD.W	D4,D6	LOAD.W	D7,#DR_PUTSCALE	PAGE_	DRAW		; remet l'chelle courante	POPM.L	D0..D6,A3	RET;----------\\; DBRDESPEN >;----------/; Dessine un pinceau dans un rectangle.; in	D0.W	numro du rectangle;	D3.L	position sous-fentre; out	-; mod	D7.WDBRDESPEN:	PUSHM.L	D2..D5,A0,A3,A4	LOAD.L	D5,D3	CLR.L	D4	CALL	DRMDEF	CALL	DBRPOS	JUMP,NE 90$	ADD.W	D3,#3	ADD.W	D3,D5	SWAP.W	D5	SWAP.W	D3	ADD.W	D3,#3	ADD.W	D3,D5;	SWAP.W	D3	SUB.W	D4,#5	SWAP.W	D4	SUB.W	D4,#5;	SWAP.W	D4	LOAD.L	A3,#(A5)+OBUDIS+1	LOAD.B	(A3)+0,#DIMWDO	LOAD.L	(A3)+1,D3	LOAD.L	(A3)+5,D4	LOAD.W	D3,#9	LIB	?STRING		; dessine dans une sous-fentre !	CLR.L	D3		; D3 <-- origine dans sous-fentre	SWAP.W	D4		; D4 <-- dimensions	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface l'emplacement	LIB	?AFTIM	.B	COLOROP,COLOROPPUSH,0	.EVEN	PUSHM.L	D3,A0	LOAD.W	D2,#SETDOT	; D2 <-- mode	LOAD.W	D3,D0		; D3 <-- numro du pinceau	LOAD.L	A4,(A5)+OPTAB	; A4 <-- ^table des pinceaux	LOAD.L	A0,A5		; A0 <-- canal	CALL	XopDUSE		; utilise le bon pinceau	POPM.L	D3,A0	COMP.W	D2,#-1		; pinceau nul ?	JUMP',EQ 80$		; oui => 80$	ADD.W	D3,#(8/2)+1	SUB.W	D4,#8+1	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,#(8/2)+0	SUB.W	D4,#8+1	ADD.W	D3,D4		; droite dans le sens "/"	NEG.W	D4	SWAP.W	D3	SWAP.W	D4	LIB	?DRSEG		; dessine le trait80$:	LIB	?AFTIM	.B	COLOROP,COLOROPPOP,0	.EVEN90$:	POPM.L	D2..D5,A0,A3,A4	RET;-------\\; DBRPOS >;-------/; Donne la position et les dimensions d'un rectangle.; in	D0.W	no du rectangle (0..n); out	D3.L	coin sup/gauche (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D7.WDBRPOS:	PUSHM.L	D0,D1	LOAD.W	D7,#1		; D7 <-- erreur	COMP.W	D0,#NBRX*NBRY	JUMP',HS 90$	AND.L	D0,#H'FFFF	DIV.WU	D0,#NBRX	LOAD.W	D1,D0		; D1 <-- Y	SWAP.W	D0		; D0 <-- X	MUL.WU	D1,(A5)+ODBRLY	ADD.W	D1,(A5)+ODBRPY	MUL.WU	D0,(A5)+ODBRLX	ADD.W	D0,(A5)+ODBRPX	LOAD.W	D3,D1	SWAP.W	D3	LOAD.W	D3,D0	LOAD.L	D4,(A5)+ODBRLY	; D4 <-- dimensions	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,D1	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBRDESCADRE >;------------/; Dessine les rectangles pour entourer la palette; de trames ou de pinceaux.; in	-; out	-; mod	D7.WDBRDESCADRE:	PUSHM.L	D0..D4	LOAD.W	D2,#2^BDBGCLABEL!100	DBOX_	GETCO	SWAP.W	D3	SUB.W	D3,#16	SWAP.W	D3	LOAD.L	(A5)+ODBRPY,D3	LOAD.W	D2,#2^BDBGCLABEL!101	DBOX_	GETCO	CLR.L	D4	LOAD.W	D4,D3	SUB.W	D4,(A5)+ODBRPX	DIV.WU	D4,#NBRX	LOAD.W	(A5)+ODBRLX,D4	MUL.WU	D4,#NBRX	SUB.W	D4,(A0)+ODFFDX	NEG.W	D4	SR.W	D4,#1	LOAD.W	(A5)+ODBRPX,D4	CLR.W	D3	SWAP.W	D3	SUB.W	D3,(A5)+ODBRPY	DIV.WU	D3,#NBRY	LOAD.W	(A5)+ODBRLY,D3	LOAD.L	D3,(A5)+ODBRPY	LOAD.L	D4,(A5)+ODBRLY	LOAD.W	D2,#SETDOT	; D2 <-- mode de dessin	LOAD.W	D1,#NBRY-1	; D1 <-- compteur vertical30$:	PUSHM.L	D3,D4	LOAD.W	D0,#NBRX-1	; D0 <-- compteur horizontal40$:	LIB	?DRRECT		; dessine rectangle	ADD.W	D3,D4		; D3 <-- X suivant	DECJ.W,NMO D0,40$	POPM.L	D3,D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4		; D3 <-- Y suivant	SWAP.W	D4	SWAP.W	D3	DECJ.W,NMO D1,30$	POPM.L	D0..D4	RET;--------\\; DRMDEF  >;========/; Dfini la demi-trame super-rapidement.; ATTENTION:	Le fait d'crire directement dans le descripteur;		de la fentre fait que la trame est inverse;		entre le Smaky 8 et 100 (gauche <--> droite) !;		Il ne faut donc utiliser que des trames simples;		(pas de hachures par exemple).; in	D4.L	demi-trame; out	-; mod	D7.WDRMDEF:	LOAD.L (A0)+ODFTRA+0,D4	LOAD.L (A0)+ODFTRA+4,D4	RET;--------\\; DOK...  >;========/DOKMGP:	LOAD.W	D3,#KEYMGP	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RETDOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RETDOKF2:	LOAD.W	D3,#F2	RETDOKF3:	LOAD.W	D3,#F3	RETDOKF4:	LOAD.W	D3,#F4	RETDOKF5:	LOAD.W	D3,#F5	RETDOKF6:	LOAD.W	D3,#F6	RETDOKF7:	LOAD.W	D3,#F7	RETDOKF8:	LOAD.W	D3,#F8	RETDOKF9:	LOAD.W	D3,#F9	RETDOKF10:	LOAD.W	D3,#F10	RETDOKF11:	LOAD.W	D3,#F11	RETDOKF12:	LOAD.W	D3,#F12	RETDOKF13:	LOAD.W	D3,#F13	RETDOKF14:	LOAD.W	D3,#F14	RETDOKF15:	LOAD.W	D3,#F15	RET	.END