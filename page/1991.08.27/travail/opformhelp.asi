	.CHAP	FORHELP.ASI;-----------\\;   AFHELP   >;===========/; Affiche l'aide pour l'utilisateur; in	-; out	-; mod	D7.16AFHELP:	PUSHM.32 D3|D5|A0|A3	MOVE.32	{A5}+OPDDIS,A0		; A0 <-- descripteur de l'cran	MOVE.16	#0,D5	LIB	?USEWDO	LIB	?AFTIM	.8	SAVWDO	.8	0	.EVEN	JUMP,NE	ERR$			; mmoire pleine -> abandonne	MOVE.32	#MI_CCMO,D7	PAGE_	MISC	LIB	?PUSHMENU	MOVE.32	#R16^TKEYHELP,A3	LIB	?AFMENU			; affiche les soft-keysN1$:	MOVE.32	#R16^IMAHELP1,A3		CALL	AFIMAGEX1$:	LIB	?GETCAR			; attend pression sur "suivant..."	COMP.8	#F1,D3	JUMP,EQ	N2$	COMP.8	#F2,D3	JUMP,EQ	N2$	COMP.8	#F3,D3	JUMP,EQ	N2$	COMP.8	#END,D3	JUMP,EQ	END$	COMP.8	#F0,D3	JUMP,EQ	END$	JUMP	X1$N2$:	JUMP	N1$			; recommenceEND$:	MOVE.32	#MI_SCMO,D7	PAGE_	MISC	LIB	?POPMENU	LIB	?AFTIM	.8	GETWDO	.8	0	.EVENERR$:	POPM.32	D0|D5|A0|A3	TEST.16	D7			; test pour EQ/NE	RETTKEYHELP:	.ASCIZ	"Ter-"	.ASCIZ	"mine"		;     ;     ;     ;	.ASCIZ	"   Suite des     "	.ASCIZ	" explications ..."		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""IMAHELP1:	.ASCIZ	"#:PAGE_FORH.IMAGE"	.EVEN;------------\\;   AFIMAGE   >;============/; Affiche une image dans l'cran; in	A3.32	^nom de l'image; out	D7.16	ok/erreur; mod	D7.16AFIMAGE:	PUSHM.32 D0..D6|A1..A4	LIB	?AFTIM	.8	NOCURS	.8	0	.EVEN	MOVE.32	#16'22882288,D3	MOVE.32	D3,D4	LIB	?DRMDEF	CLR.32	D3	MOVE.32	{A0}+ODFFDY,D4		; [dy;dx] de la fentre	MOVE.16	#LOADDOT,D2		; recouvre	LIB	?DRTRAME	CALL	LOADIMAGE		; charge l'image demande	JUMP,NE	ERR$			; erreur -> termine	TEST.8	{A0}+ODFMOD:#BFBLANC	; fond blanc  l'cran ?	JUMP,BS	RIEN$			; oui -> n'inverse pas	MOVE.32	A4,A3			; dbut de l'image	MOVE.16	D0,D2	MUL.16	D1,D2	SR.32	#3,D2			; taille en bytes	DEC.16	D2INV$:	NOT.8	{A3+}	DJ.16,NMO D2,INV$		; inverse la suite de l'imageRIEN$:	COMP.16	{A0}+ODFFDX,D0		; largeur ok ?	JUMP,HI	END$			; image trop large	COMP.16	{A0}+ODFFDY,D1		; hauteur ok ?	JUMP,HI	END$			; image trop haute	MOVE.16	D1,D2			; [--;dy]	SWAP.32	D2	MOVE.16	D0,D2			; [dy;dx]	MOVE.32	A0,A2			; description d'cran	CLR.32	D3	MOVE.32	A4,A3			; ^mmoire source	MOVE.16	D0,D5	SR.16	#3,D5			; [ly] de l'image source	MOVE.16	{A0}+ODFFDY,D4	SUB.16	D1,D4	SR.16	#1,D4			; [-;y]	SWAP.32	D4	MOVE.16	{A0}+ODFFDX,D4	SUB.16	D0,D4	SR.16	#1,D4			; [y;x] destination	MOVE.32	#0,A4			; dans l'cran	MOVE.8	#LOADDOT,D1	GRA_	RASTER			; dessine l'image	MOVE.32	A3,A4			; restaure base de l'imageEND$:	CALL	UNLOADIMA		; rend la mmoire imageERR$:	POPM.32 D0..D6|A1..A4	TEST.16	D7			; test pour EQ/NE	RET;--------------\\;   LOADIMAGE   >;==============/; Charge une image en mmoire (effectue le bon GESMEM ?GETMEM); in	A3.32	^nom de l'image; out	A4.32	^dbut de l'image;	D0.16	dimension X;	D1.16	dimension Y; mod	A3.32 D0.16 D1.16;	D7.16LOADIMAGE:	PUSHM.32 A1|A2|A3|D3|D4|D6	MOVE.16	#MTYPCP,D1	MOVE.32	#16'20,D4	GESMEM	?GETMEM			; demande 32 octets pour en-tte	JUMP,NE	MEM$	MOVE.32	A4,A2NEXT$:	MOVE.16	#2**BOPRD,D3		; ouverture en lecture	FOS	?OPEN	JUMP,NE	MEM$	MOVE.32	A2,A4			; ^tampon pour l'image	FOS	?RDBYTE	JUMP,NE	FOS1$	COMP.8	#16'82,{A2}+0		; teste si c'est une en-tte binaire	JUMP,NE	LOAD$			; non -> passe  la suite	CLR.8	D3	MOVE.32	#16'100,D4		; saute l'en-tte de 256 octets	FOS	?SPOS	JUMP,NE	FOS1$	MOVE.32	#16'20,D4		; relit l'image	FOS	?RDBYTELOAD$:	MOVE.16	{A2}+4,D0		; largeur X	MOVE.16	{A2}+6,D1		; hauteur Y	MOVE.16	D0,D4	SR.16	#3,D4	MUL.16	D1,D4	ADD.32	#16'4A,D4		; mmoire totale ncessaire  l'image dcode	PUSHM.32 D1	MOVE.16	#MTYPCP,D1	GESMEM	?GETMEM			; demande l'espace ncessaire	POPM.32 D1	JUMP,NE	FOS1$	MOVE.32	#{A4}+16'40,A1		; ^dbut de l'image dans le buffer	MOVE.32	{A2}+OIMNBB,D4		; longueur de l'image code	TEST.8	{A2}+OIMCOD		; ncessaire de dcoder ?	JUMP,NE	DECO$			; oui -> dcode	MOVE.32	A1,A4			; buffer	FOS	?RDBYTE			; lit l'image non code	JUMP,NE	FOS2$	JUMP	FIN$DECO$:	FOS	?RDBYTE	JUMP,NE	FOS2$	MOVE.32	A1,A3			; buffer image dcode	GRA_	DECOIMA			; dcode l'imageFIN$:	FOS	?CLOSE			; ferme le fichier	MOVE.32	A2,A4	PUSH.16	D1	MOVE.16	#MTYPCP,D1		; rend les 32 octets	GESMEM	?GIVMEM	MOVE.32	A1,A4	POP.16	D1	POPM.32	A1|A2|A3|D3|D4|D6	TEST.16	D7			; test pour EQ/NE	RETFOS2$:	PUSH.16	D7	MOVE.32	#{A1}-16'40,A4	MOVE.16	#MTYPCP,D1	GESMEM	?GIVMEM	POP.16	D7FOS1$:	PUSH.16	D7	FOS	?CLOSE	MOVE.32	A2,A4	MOVE.16	#MTYPCP,D1		; rend la mmoire d'en-tte	GESMEM	?GIVMEM	POP.16	D7MEM$:	POPM.32	A1|A2|A3|D3|D4|D6	TEST.16	D7	RET;--------------\\;   UNLOADIMA   >;==============/; Libre la mmoire occupe; in	A4.32	^buffer image relle; out	-; mod	-UNLOADIMA:	PUSHM.32 D1|A4	MOVE.32	#{A4}-16'40,A4	MOVE.16	#MTYPCP,D1	GESMEM	?GIVMEM	POPM.32	D1|A4	RET