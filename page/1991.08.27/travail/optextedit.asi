	.SBTTL	OPTEXTEDIT.ASITXPREL:				; base pour ^relatifs;----------\\; EDITMMENU >;==========/; Agit dans le texte selon le mmenu traditionnel (ddd).; in	A4.L	^objet texte; out	D7.W	erreur; mod	D7.WEDITMMENU:	PUSHM.L	D1..D5,A1..A4	LOAD.L	D4,(A5)+OTXZO1	LOAD.L	D5,(A5)+OTXZO2	COMP.L	D4,D5	JUMP',NE SELOK$	CALL	ESELMOT		; D4/D5 <-- dbut/fin d'un mot	CALL	BASZONEINV	; inverse la nouvelle partie de la zone	LOAD.L	(A5)+OTXZO1,D4	LOAD.L	(A5)+OTXZO2,D5SELOK$:	LOAD.L	A1,A4		; A1 <-- ^objet texte	LOAD.L	A3,#R16"ITABLE$ILOOP$:	LOAD.W	D3,(A3+)	; D3 <-- code de l'icne interne	JUMP',EQ IEND$	CALL	XopGETICONE	; A4 <-- ^matrice	LOAD.W	D3,(A3+)	; D3 <-- code de l'icne PAGE	LOAD.W	D7,#DR_PUTICO	PAGE_	DRAW		; IPP21 <-- matrice de l'icne	JUMP	ILOOP$IEND$:	LOAD.L	D4,#2000	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire pour construire mmenu	JUMP,NE CLEAR$	LOAD.L	D5,A4	LOAD.L	A3,D5		; A3 <-- ^buffer pour construire m-menu	LOAD.L	A2,D5	LOAD.L	A4,#R16"MMENU$	CALL	MENUBUF		; buffer <-- menu principal	CALL	MENUAJUST	; buffer <-- tous les sous-(sous-)menus	LOAD.L	A3,D5		; A3 <-- ^buffer avec m-menu	LOAD.L	A4,#(A5)+OMPATX	; A4 <-- ^paramtres	CLR.L	(A4)+(LMM*0)+OMMINA	LOAD.L	(A4)+(LMM*1)+OMMINA,(A5)+OMCHG	CLR.L	(A4)+(LMM*2)+OMMINA	CLR.L	(A4)+(LMM*3)+OMMINA	CLR.L	(A4)+(LMM*4)+OMMINA	CLR.L	(A4)+(LMM*5)+OMMINA	CLR.L	(A4)+(LMM*6)+OMMINA	TSET.B	(A4)+(LMM*0)+OMMINA+3:#2 ; grise la case "dplace"	TSET.B	(A4)+(LMM*0)+OMMINA+3:#3 ; grise la case "duplique"	TSET.B	(A4)+(LMM*0)+OMMINA+3:#5 ; grise la case "soulign"	LOAD.W	D7,#IO_DICOSTATUS	PAGE_	IO		; D4 <-- zro si dico pas charg	JUMP',EQ DICO5$	TSET.B	(A4)+(LMM*0)+OMMINA+2:#8-8 ; grise la case "dictionnaire"DICO5$:	LOAD.W	D7,#MI_MMENUS	PAGE_	MISC		; attend choix selon mmenus ...	PUSHM.L	D7,A4	LOAD.L	A4,D5	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre mmoire pour construire mmenu	POPM.L	D7,A4	TEST.W	D7	JUMP,NE CLEAR$	LOAD.W	D2,(A4)+(LMM*0)+OMMSEL	COMP.W	D2,#1	JUMP',EQ OPER$	COMP.W	D2,#2	JUMP',EQ OPER$	COMP.W	D2,#3	JUMP',EQ OPER$	LOAD.W	D3,(A4)+(LMM*1)+OMMSEL	COMP.W	D2,#4	JUMP',EQ OPER$	LOAD.W	D3,(A4)+(LMM*2)+OMMSEL	COMP.W	D2,#5	JUMP',EQ OPER$	LOAD.W	D3,(A4)+(LMM*3)+OMMSEL	COMP.W	D2,#6	JUMP',EQ OPER$	LOAD.W	D3,(A4)+(LMM*4)+OMMSEL	COMP.W	D2,#7	JUMP',EQ OPER$	LOAD.W	D3,(A4)+(LMM*5)+OMMSEL	COMP.W	D2,#8	JUMP',EQ OPER$	LOAD.W	D3,(A4)+(LMM*6)+OMMSEL	COMP.W	D2,#9	JUMP',EQ OPER$	JUMP'	CLEAR$OPER$:	LOAD.L	A4,A1		; A4 <-- ^objet texte	LOAD.L	D4,(A5)+OTXZO1	LOAD.L	D5,(A5)+OTXZO2	CALL	BASZONEINV	; efface toute la zone	CALL	EDITOPMOUSE	; effectue une action dans le texte	JUMP'	EXIT$CLEAR$:	PUSH.W	D7	LOAD.L	A4,A1		; A4 <-- ^objet texte	LOAD.L	D4,(A5)+OTXZO1	LOAD.L	D5,(A5)+OTXZO2	CALL	BASZONEINV	; efface toute la zone	POP.W	D7EXIT$:	POPM.L	D1..D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETITABLE$:	.W	ICOGENCAR,ICOUSER+0	.W	ICOSOUL,ICOUSER+1	.W	ICOUPDOWN,ICOUSER+2	.W	ICOMINMAJ,ICOUSER+3	.W	ICOSNORM,ICOUSER+4	.W	ICOSDOWN,ICOUSER+5	.W	ICOSMID,ICOUSER+6	.W	ICOSUP,ICOUSER+7	.W	ICOUDNORM,ICOUSER+8	.W	ICOUDUP,ICOUSER+9	.W	ICOUDDOWN,ICOUSER+10	.W	ICOMMMIN,ICOUSER+11	.W	ICOMMMAJ,ICOUSER+12	.W	ICOMINMAJACC,ICOUSER+13	.W	ICONBFIX,ICOUSER+14	.W	ICONBPROP,ICOUSER+15	.W	ICOCHERCHE,ICOUSER+16	.W	ICOCHERCHEAR,ICOUSER+17	.W	ICOCHERCHEAV,ICOUSER+18	.W	ICOCHANGE,ICOUSER+19	.W	ICOZDETRUIT,ICOUSER+20	.W	ICOZDEPLACE,ICOUSER+21	.W	ICOZDUPLIQUE,ICOUSER+22	.W	0MMENU$:	.ASCIZ	" "	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+20	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  dtruit"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+21	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  dplace"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+22	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  duplique"	.B	-1	.BW	-2,-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+0	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  caractre"	.BW	-2,SOUL$-MMENU$	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+1	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  soulign"	.BW	-2,EXP$-MMENU$	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+2	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  exposant"	.B	-1	.BW	-2,MINMAJ$-MMENU$	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+3	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  transforme"	.BW	-2,DICO$-MMENU$	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODICO	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  dictionnaire"	.BW	-2,SEARCH$-MMENU$	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+16	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  cherche"	.B	0SOUL$:	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+4	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  normal "	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+5	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  soulign "	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+6	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  biff "	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  surlign "	.B	0EXP$:	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+8	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  normal "	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+9	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  exposant "	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+10	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  indice "	.B	0MINMAJ$:	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+11	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  minuscules "	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+12	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  majuscules "	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+13	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  idem + accents "	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+14	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  fixes "	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+15	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  proportionnels "	.B	0DICO$:	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODICOVE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  vrifie.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODICOMA	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  marque"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODICOAD	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  conserve.."	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODICOAC	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  accorde.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODICOCO	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  conjugue.."	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODICOSY	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  synonymes.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODICOFA	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  famille.."	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODICONB	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  nombre.."	.B	0SEARCH$:	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+17	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  cherche"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+18	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  cherche"	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+19	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  change.."	.B	0	.EVEN;----------\\; MENUAJUST >;----------/; Ajuste les pointeurs relatifs du menu pre qui vient d'tre; mis dans le buffer.; in	A2.L	^dbut du menu pre;	A3.L	^buffer;	A4.L	^mmenu; out	A3.L	^plus loin;	A4.L	^plus loin; mod	D7.W, A3.L, A4.LMENUAJUST:	PUSHM.L	D3,D4,A1,A2	LOAD.L	A1,A220$:	TEST.B	(A2)		; fin du mmenu ?	JUMP,EQ EXIT$		; oui => EXIT$30$:	LOAD.B	D3,(A2+)	JUMP,EQ 20$	COMP.B	D3,#-2	JUMP,NE 30$				; ^sous-menu =>	LOAD.B	D3,(A2+)	SL.W	D3,#8	LOAD.B	D3,(A2+)	; D3 <-- ^relatif	LOAD.L	D4,A3	SUB.L	D4,A1	LOAD.B	(A2)-1,D4	RR.W	D4,#8	LOAD.B	(A2)-2,D4	; buffer <-- ^relatif au sous-menu	RR.W	D4,#8	PUSH.L	A2	PUSH.L	A3	TEST.W	D3		; .BW -2,-n  ?	JUMP',NS 50$		; oui => 50$				; non =>	CALL	MENUBUF		; buffer <-- sous-menu	JUMP'	52$50$:	CALL	MENUSPEC	; buffer <-- sous-menu52$:	POP.L	A2	CALL	MENUAJUST	; paf, rcursif !!!	POP.L	A2	JUMP	30$EXIT$:	POPM.L	D3,D4,A1,A2	RET;--------\\; MENUBUF >;--------/; Met un mmenu dans un buffer.; in	A3.L	^buffer;	A4.L	^mmenu; out	A3.L	^plus loin;	A4.L	^plus loin; mod	D7.W, A3.L, A4.LMENUBUF:	PUSH.W	D3LOOP1$:	TEST.B	(A4)		; fin du mmenu ?	JUMP',EQ END$LOOP2$:	LOAD.B	D3,(A4+)	LOAD.B	(A3+),D3	; buffer <-- .ASCIZ	JUMP,EQ LOOP1$	COMP.B	D3,#-2	JUMP,NE	LOOP2$	LOAD.B	(A3+),(A4+)	; buffer <-- <^rel-high>	LOAD.B	(A3+),(A4+)	; buffer <-- <^rel-low>	JUMP	LOOP2$END$:	INC.L	A4	CLR.B	(A3+)		; buffer <-- terminateur	POP.W	D3	RET;---------\\; MENUSPEC >;---------/; Met un mmenu spcial dans un buffer.; in	D3.W	type du menu spcial (-);	D4.W	^relatif;	A2.L	^pour mj. ^relatif;	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LMENUSPEC:	PUSHM.L	D0,D1,D3,A4	COMP.W	D3,#-1	JUMP',EQ CHAR$	JUMP'	EXIT$; Construit le sous-menu des caractres.CHAR$:	LOAD.L	A4,#R16"CDEF$CHAR2$:	LOAD.B	(A3+),(A4+)	; buffer <-- "ordinaire"	JUMP,NE CHAR2$	LOAD.B	(A3+),#-1	; buffer <-- trait de sparation	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D0,#IDENTCHAR	LOAD.W	D1,#opDGETMENU	PAGE_	OBJCALL		; buffer <-- construit le mmenu	RL.L	D3,#1		; D3 <-- dcale  cause de "ordinaire"	LOAD.L	(A5)+OMCHG,D3	; OMCHG <-- cases grises;	JUMP	EXIT$EXIT$:	POPM.L	D0,D1,D3,A4	RETCDEF$:	.ASCIZ	" Ordinaire "	.EVEN;------------\\; EDITOPMOUSE >;============/; Effectue une opration selon le mmenu texte.; in	A4.L	^objet texte;	D2.W	opration (dtruit, dplace, etc.);	D3.W	sous-opration (selon sous-menu);	D4.L	dbut zone;	D5.L	fin zone; out	D7.W	erreur; mod	D7.WEDITOPMOUSE:	PUSHM.L	D0..D6,A3	LOAD.L	D6,(A4)+OOBCHT	; D6 <-- canal pour le buffer de texte	COMP.L	D4,D5	JUMP,EQ OK$	JUMP',LO NOEX$	EX.L	D4,D5		; D4 toujours avant D5 !NOEX$:	AND.L	D3,#H'FFFF	COMP.W	D2,#1	JUMP,EQ DETR$	COMP.W	D2,#2	JUMP,EQ DEPL$	COMP.W	D2,#3	JUMP,EQ DUPL$	COMP.W	D2,#4	JUMP,EQ CAR$	COMP.W	D2,#5	JUMP,EQ SOUL$	COMP.W	D2,#6	JUMP,EQ EXP$	COMP.W	D2,#7	JUMP,EQ MIMA$	COMP.W	D2,#8	JUMP,EQ DICO$	COMP.W	D2,#9	JUMP,EQ SEARCH$	JUMP	EXIT$DETR$:	EX.L	D4,D5	CALL	_BUTX_SETPOS	; va  la fin	SUB.L	D4,D5		; D4 <-- nombre de caractres	LOAD.L	D2,D4DETR2$:	CALL	PDELETE		; dtruit toute la zone	DEC.L	D2	JUMP,NE DETR2$	CALL	EDSPYCURS	; renseigne les espions	JUMP	OK$DEPL$:	LOAD.W	D7,#1	JUMP	EXIT$DUPL$:	LOAD.W	D7,#1	JUMP	EXIT$CAR$:	DEC.W	D3	JUMP',NC CAR2$	LOAD.B	D3,#-1		; D3 <-- caractre "ordinaire"CAR2$:;	SL.L	D3,#CCGCSHI	LOAD.L	D2,#CCGCMSK	; D2 <-- masque	JUMP'	OPER$SOUL$:	SL.L	D3,#CCSOSHI	LOAD.L	D2,#CCSOMSK	; D2 <-- masque	JUMP'	OPER$EXP$:;	SL.L	D3,#CCEXSHI	SWAP.W	D3	LOAD.L	D2,#CCEXMSK	; D2 <-- masque;	JUMP'	OPER$OPER$:	CALL	_BUTX_SETPOS	; va sur le premier caractre  modifier	CALL	EDSPYCURS	; renseigne les espions	SUB.L	D5,D4		; D5 <-- nombre de caractres	LOAD.L	D1,D5;	LOAD.L	D2,D2		; D2 <-- masque 1	LOAD.L	D4,D3		; D4 <-- info 1	CLR.L	D3		; D3 <-- masque 2	CLR.L	D5		; D5 <-- info 2	CALL	_BUTX_INFOMASK	; donne les info et les masques	LOAD.L	D4,D1		; D4 <-- nombre de caractres	CALL	_BUTX_MODINFO	; modifie le mode	JUMP	EXIT$MIMA$:	SUB.L	D5,D4		; D5 <-- nombre de caractres	LOAD.L	D2,D5	CALL	_BUTX_SETPOS	; va au dbut de la zone	LOAD.B	D4,#'a	TEST.W	D3	JUMP',EQ MIMA2$	LOAD.B	D4,#'A	COMP.W	D3,#1	JUMP',EQ MIMA2$	LOAD.B	D4,#H'80	COMP.W	D3,#2	JUMP',EQ MIMA2$	LOAD.B	D4,#H'81	COMP.W	D3,#3	JUMP',EQ MIMA2$	LOAD.B	D4,#H'82MIMA2$:	LOAD.B	D3,D4	CALL	EMINMAJ	JUMP,NE EXIT$	CALL	_BUTX_AVANCE	JUMP,NE OK$	DEC.L	D2	JUMP,NE MIMA2$	JUMP	OK$DICO$:	SUB.L	D5,D4		; D5 <-- nombre de caractres	COMP.W	D3,#0	JUMP',EQ DICOVE$	COMP.W	D3,#1	JUMP',EQ DICOMA$	COMP.W	D3,#2	JUMP',EQ DICOAD$	COMP.W	D3,#3	JUMP',EQ DICOAC$	COMP.W	D3,#4	JUMP',EQ DICOCO$	COMP.W	D3,#5	JUMP',EQ DICOSY$	COMP.W	D3,#6	JUMP',EQ DICOFA$	COMP.W	D3,#7	JUMP',EQ DICONB$	JUMP	EXIT$DICOVE$:	CALL	DICOVERIF	JUMP'	DICOEXIT$DICOMA$:	CALL	DICOMARK	JUMP'	DICOEXIT$DICOAD$:	CALL	DICOADD	JUMP'	DICOEXIT$DICOAC$:	CALL	DICOACCORD	JUMP'	DICOEXIT$DICOCO$:	CALL	DICOCONJ	JUMP'	DICOEXIT$DICOSY$:	CALL	DICOSYNO	JUMP'	DICOEXIT$DICOFA$:	CALL	DICOFAMILLE	JUMP'	DICOEXIT$DICONB$:	CALL	DICONOMB;	JUMP'	DICOEXIT$DICOEXIT$:	JUMP	EXIT$SEARCH$:	LOAD.W	D2,D3		; D2 <-- sous-opration	SUB.L	D5,D4		; D5 <-- nombre de caractres	LOAD.L	D1,D5	CALL	_BUTX_SETPOS	JUMP,NE EXIT$	LOAD.L	A3,#(A5)+OCH1	; A3 <-- ^chane de recherche	COMP.W	D1,#MAXCH-2	JUMP',LO SEARCH2$	LOAD.W	D1,#MAXCH-2SEARCH2$:	CALL	_BUTX_AVANCE	; D3/D4/D5 <-- caractre suivant	JUMP',NE SEARCH3$	CALL	_BUTX_NOSUPPL	; D3 <-- caractre < 128	LOAD.B	(A3+),D3	; chane de recherche <-- caractres	DEC.L	D1	JUMP,NE SEARCH2$SEARCH3$:	CLR.B	(A3)	CLR.B	(A5)+OCH2	; chane de substitution <-- vide	COMP.W	D2,#0	JUMP',EQ SEARCHAR$	COMP.W	D2,#1	JUMP',EQ SEARCHAV$	COMP.W	D2,#2	JUMP',EQ CHANGE$	JUMP	EXIT$SEARCHAR$:	CALL	_BUTX_RECULE	; revient au dbut de la chane	DEC.L	D1	JUMP,NE SEARCHAR$	LOAD.L	D3,#H'100*(2^BSEARCH)+'D	CALL	EDITEVENT	; cherche en arrire	JUMP'	EXIT$SEARCHAV$:	LOAD.L	D3,#H'100*(2^BSEARCH)+'F	CALL	EDITEVENT	; cherche en avant	JUMP'	EXIT$CHANGE$:	CALL	_BUTX_RECULE	; revient au dbut de la chane	DEC.L	D1	JUMP,NE CHANGE$	CALL	_BUTX_RECULE	LOAD.L	D3,#H'100*(2^BCHANGE)+DEFINE+SHIFT	CALL	EDITEVENT	JUMP'	EXIT$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D6,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; EDITEVENT >;==========/; Edite un pav de texte selon une touche presse.; in	A4.L	^objet texte;	D3.L	touche presse;	D4.L	position de la souris (si D3=KEYM?P); out	D7.W	erreur; mod	D7.WEDITEVENT:	PUSHM.L	D1..D6	LOAD.L	D6,(A4)+OOBCHT	; D6 <-- canal pour le buffer de texte; Dbranchements principaux selon les touches super-shift.	COMP.W	D3,#H'80	JUMP',HS NOACCENT$	COMP.B	D3,#DEL	JUMP',EQ NOACCENT$	COMP.B	D3,#BS	JUMP',NE ACCENT$NOACCENT$:	CALL	NOACCENT	; plus de frappe d'accent flottantACCENT$:	CALL	EXFONC	.WW	CURSOR,KCURS$-TXPREL	.WW	CURSOR!KILL,KCUKI$-TXPREL	.WW	PROGRA,KPROG$-TXPREL	.WW	PROGRA!CHANGE,KPRCH$-TXPREL	.WW	SEARCH,KSEAR$-TXPREL	.WW	CHANGE,KCHAN$-TXPREL	.WW	SEARCH!CHANGE,KSECH$-TXPREL	.WW	KEYMGP/H'100,KMOUSE$-TXPREL	.WW	0,KEY$-TXPRELKEY$:	CALL	EXKEY	.WW	DELETE,KDEL$-TXPREL	.WW	DEL,KDEL$-TXPREL	.WW	BS,KBS$-TXPREL	.WW	CCIRCON,KCIRCON$-TXPREL	.WW	CTREMA,KTREMA$-TXPREL	.WW	TRIZERO,KTRIZERO$-TXPREL	.WW	POINT,KPOINT$-TXPREL	.WW	FNCT,KFLIP$-TXPREL	.WW	F1,KPREND$-TXPREL	.WW	F2,KAJOUTE$-TXPREL	.WW	F3,KSAUVE$-TXPREL	.WW	DEFINE,KCHANGE$-TXPREL	.WW	0,INSERT$-TXPREL; Actions spciales, sans touches super-shift.KMOUSE$:	CALL	EXKEY	.WW	KEYMGP&H'FF,CLIC$-TXPREL	.WW	KEYMGR&H'FF,OK$-TXPREL	.WW	KEYMMR&H'FF,OK$-TXPREL	.WW	KEYMDR&H'FF,OK$-TXPREL	.WW	0,BIP$-TXPRELCLIC$:	LOAD.W	D1,(A4)+OOBAE+0	CALL	INVANGLE	CALL	GETPX		; D4 <-- position tourne	CALL	BASGETPOS	; positionne le curseur	JUMP,NE EXIT$	JUMP	OK$KPREND$:	CALL	IORALL		; lit un texte	JUMP	OK$KAJOUTE$:	CALL	IORADD		; ajoute un texte	JUMP	OK$KSAUVE$:	CALL	IOWALL		; crit un texte	JUMP	OK$KCHANGE$:	CALL	DBOXCHANGE	; demande recherche/substitution ...	COMP.W	D3,#F1	JUMP,EQ ISEAR$	COMP.W	D3,#F4	JUMP,EQ ICNT$	COMP.W	D3,#F7	JUMP,EQ ICHAN$	JUMP	OK$; Insertion des caractres, avec gestion du pav numrique.INSERT$:	COMP.W	D3,#H'80	JUMP,HS BIP$	CALL	ACCENT		; va sous un accent flottant ?	JUMP,EQ OK$		; oui => OK$	CALL	EINSERE	JUMP,NE EXIT$	JUMP	OK$KTRIZERO$:			; insre 3x zro =>	LOAD.B	D3,#'0	CALL	EINSERE	JUMP,NE EXIT$	CALL	EINSERE	JUMP,NE EXIT$	CALL	EINSERE	JUMP,NE EXIT$	JUMP	OK$KPOINT$:			; insre un "." =>	LOAD.B	D3,#'.	CALL	EINSERE	JUMP,NE EXIT$	JUMP	OK$KCIRCON$:	LOAD.B	D4,#CIRCON	; met un circonflxe	JUMP'	KACCENT$KTREMA$:	LOAD.B	D4,#TREMA	; met qq chose comme un trma;	JUMP'	KACCENT$KACCENT$:	TEST.B	(A4)+OOBACC	JUMP',T KACCENT6$	PUSH.W	D4	CALL	_BUTX_AVANCE	; D3 <-- car "sous" le curseur	POPM.W	D4	JUMP',NE KACCENT5$	; rien => KACCENT5$	PUSH.W	D4	CALL	_BUTX_RECULE	POP.W	D4	CALL	GETACCENT	; calcul lettre accentue	JUMP',NE KACCENT5$	; n'existe pas => KACCENT5$				; existe =>	TEST.B	D3	JUMP',EQ KACCENT5$	PUSH.W	D3	CALL	_BUTX_AVANCE	CALL	_BUTX_DELETE	; dtruit lettre non accentue	POP.W	D3	CALL	EDSPYCURS	; renseigne les espions	CALL	PINSERT		; remplace par lettre accentue	JUMP	OK$KACCENT5$:	LOAD.B	D3,D4		; D3 <-- accent	CALL	EINSERE		; insert un accent tout seul	CALL	_BUTX_RECULE	; puis recule "dessus"	SET.B	(A4)+OOBACC	JUMP	OK$KACCENT6$:	CALL	NOACCENT	; plus de frappe d'accent flottant	JUMP	OK$KFLIP$:				; permute deux caractres =>	CALL	PDELETE	JUMP,NE BIP$	CALL	EDSPYCURS	; renseigne les espions	PUSHM.L	D3..D5	CALL	_BUTX_AVANCE	POPM.L	D3..D5	CALL	PINSERT	CALL	_BUTX_RECULE	JUMP	OK$KDEL$:	LOAD.B	D3,#'D	JUMP	ECUKI$KBS$:	LOAD.B	D3,#'F	JUMP	ECUKI$; Table pour les diffrentes combinaisons de touches super-shift.KCURS$:	CALL	EXKEY	.WW	'E,ECURS$-TXPREL	.WW	'R,ECURS$-TXPREL	.WW	'T,ECURS$-TXPREL	.WW	'S,ECURS$-TXPREL	.WW	'D,ECURS$-TXPREL	.WW	'F,ECURS$-TXPREL	.WW	'G,ECURS$-TXPREL	.WW	'X,ECURS$-TXPREL	.WW	'C,ECURS$-TXPREL	.WW	'V,ECURS$-TXPREL	.WW	0,BIP$-TXPRELKCUKI$:	CALL	EXKEY	.WW	'E,ECUKI$-TXPREL	.WW	'R,ECUKI$-TXPREL	.WW	'T,ECUKIQ$-TXPREL	.WW	'S,ECUKI$-TXPREL	.WW	'D,ECUKI$-TXPREL	.WW	'F,ECUKI$-TXPREL	.WW	'G,ECUKI$-TXPREL	.WW	'X,ECUKI$-TXPREL	.WW	'C,ECUKI$-TXPREL	.WW	'V,ECUKIQ$-TXPREL	.WW	0,BIP$-TXPRELKPROG$:	CALL	EXKEY	.WW	'R,EPROGR$-TXPREL	.WW	0,BIP$-TXPRELKPRCH$:	CALL	EXKEY	.WW	'E,EPRCH$-TXPREL	.WW	'R,EPRCH$-TXPREL	.WW	'T,EPRCHQ$-TXPREL	.WW	'S,EPRCH$-TXPREL	.WW	'D,EPRCH$-TXPREL	.WW	'F,EPRCH$-TXPREL	.WW	'G,EPRCH$-TXPREL	.WW	'X,EPRCH$-TXPREL	.WW	'C,EPRCH$-TXPREL	.WW	'V,EPRCHQ$-TXPREL	.WW	0,BIP$-TXPRELKSEAR$:	CALL	EXKEY	.WW	'R,ECNTAR$-TXPREL	.WW	'D,ESEARAR$-TXPREL	.WW	'F,ESEARAV$-TXPREL	.WW	'C,ECNTAV$-TXPREL	.WW	',,EDICOAR$-TXPREL	.WW	'.,EDICOAV$-TXPREL	.WW	0,BIP$-TXPRELKCHAN$:	CALL	EXKEY	.WW	'D,ECHANGAR$-TXPREL	.WW	'F,ECHANGAV$-TXPREL	.WW	'R,ECHANGTR$-TXPREL	.WW	'C,ECHANGTV$-TXPREL	.WW	',,EDICOAR$-TXPREL	.WW	'.,EDICOAV$-TXPREL	.WW	DEFINE,KCHANGE$-TXPREL	.WW	DEFINE+SHIFT,KCHANGE$-TXPREL	.WW	0,BIP$-TXPRELKSECH$:	CALL	EXKEY	.WW	',,EDICOAR$-TXPREL	.WW	'.,EDICOAV$-TXPREL	.WW	0,BIP$-TXPREL; (CURSOR) = Dplacement du curseur.ECURS$:	CALL	EFLECHE		; D2 <-- +/- dplacement	TEST.L	D2	JUMP,EQ BIP$	JUMP',NS ECURS4$ECURS2$:	CALL	_BUTX_AVANCE	DEC.L	D2	JUMP,NE ECURS2$	JUMP	OK$ECURS4$:	CALL	_BUTX_RECULE	INC.L	D2	JUMP,NE ECURS4$	JUMP	OK$; (CURSOR-KILL) = destructions autour du curseur.ECUKIQ$:	CALL	EFLECHE		; D2 <-- +/- dplacement	TEST.L	D2	JUMP,EQ BIP$	CALL	DBOXSURE	; demande ...	JUMP,NE BIP$	JUMP'	ECUKI1$ECUKI$:	CALL	EFLECHE		; D2 <-- +/- dplacementECUKI1$:	TEST.L	D2	JUMP,EQ BIP$	JUMP',NS ECUKI4$	CALL	EDSPYCURS	; renseigne les espionsECUKI2$:	CALL	_BUTX_AVANCE	JUMP,NE EXIT$	CALL	PDELETE	JUMP,NE EXIT$	DEC.L	D2	JUMP,NE ECUKI2$	JUMP	OK$ECUKI4$:	CALL	PDELETE	JUMP,NE EXIT$	INC.L	D2	JUMP,NE ECUKI4$	CALL	EDSPYCURS	; renseigne les espions	JUMP	OK$; (PROGRA) = divers.EPROGR$:	CALL	CARMODPALL	; signal qu'il faudra tout redessiner	JUMP	OK$; (PROGRA-CHANGE) = transformations minuscules <--> majuscules.EPRCHQ$:	LOAD.B	D1,D3	CALL	EFLECHE		; D2 <-- +/- dplacement	TEST.L	D2	JUMP,EQ BIP$	CALL	DBOXSURE	; demande ...	JUMP,NE BIP$	JUMP'	EPRCH1$EPRCH$:	LOAD.B	D1,D3	CALL	EFLECHE		; D2 <-- +/- dplacementEPRCH1$:	TEST.L	D2	JUMP,EQ BIP$	JUMP',NS EPRCH4$EPRCH2$:	LOAD.B	D3,D1	CALL	EMINMAJ	JUMP,NE BIP$	CALL	_BUTX_AVANCE	JUMP,NE EXIT$	DEC.L	D2	JUMP,NE EPRCH2$	JUMP	OK$EPRCH4$:	CALL	_BUTX_RECULE	JUMP,NE EXIT$	LOAD.B	D3,D1	CALL	EMINMAJ	JUMP,NE BIP$	INC.L	D2	JUMP,NE EPRCH4$	JUMP	OK$; (SEARCH) = recherche et comptages.ESEARAR$:	CALL	ECHERCHEAR	; cherche en arrire	JUMP,NE EXIT$	JUMP	OK$ESEARAV$:	CALL	ECHERCHEAV	; cherche en avant	JUMP,NE EXIT$	JUMP	OK$ECNTAV$:	CALL	_BUTX_POSSAVE	LOAD.W	D1,D4	CLR.L	D2		; D2 <-- nombre d'occurencesECNTAV2$:	CALL	ECHERCHEAV	; cherche en avant	JUMP',NE ECNTAV3$	INC.L	D2		; D2 <-- une occurence de plus	JUMP	ECNTAV2$ECNTAV3$:	LOAD.W	D4,D1	CALL	_BUTX_POSEND	; remet le curseur o il tait	LOAD.L	D4,D2		; D4 <-- nombre d'occurences	CALL	DBOXOCCURENCE	; affiche le nombre d'occurences ...	JUMP,NE EXIT$	JUMP	OK$ECNTAR$:	CALL	_BUTX_POSSAVE	LOAD.W	D1,D4	CLR.L	D2		; D2 <-- nombre d'occurencesECNTAR2$:	CALL	ECHERCHEAR	; cherche en arrire	JUMP',NE ECNTAR3$	INC.L	D2		; D2 <-- une occurence de plus	JUMP	ECNTAR2$ECNTAR3$:	LOAD.W	D4,D1	CALL	_BUTX_POSEND	; remet le curseur o il tait	LOAD.L	D4,D2		; D4 <-- nombre d'occurences	CALL	DBOXOCCURENCE	; affiche le nombre d'occurences ...	JUMP,NE EXIT$	JUMP	OK$; (CHANGE) = recherches puis substitutions.ECHANGAR$:	CALL	ECHERCHEAR	; cherche en arrire	JUMP,NE EXIT$	CALL	ESUBSTITUEAR	; effectue la substitution	JUMP,NE EXIT$	JUMP	OK$ECHANGAV$:	CALL	_BUTX_RECULE	CALL	ECHERCHEAV	; cherche en avant	JUMP,NE EXIT$	CALL	ESUBSTITUEAV	; effectue la substitution	JUMP,NE EXIT$	JUMP	OK$ECHANGTR$:	CALL	ECHERCHEAR	; cherche en arrire	JUMP,NE OK$	CALL	ESUBSTITUEAR	; effectue la substitution	JUMP,NE EXIT$	JUMP	ECHANGTR$ECHANGTV$:	CALL	_BUTX_RECULE	CALL	ECHERCHEAV	; cherche en avant	JUMP,NE OK$	CALL	ESUBSTITUEAV	; effectue la substitution	JUMP,NE EXIT$	JUMP	ECHANGTV$; Diverses recherches pour les marques du dictionnaire.EDICOAV$:	PUSH.L	(A5)+OCH1	PUSH.L	(A5)+OCHM1	PUSH.L	(A5)+OCHC1	LOAD.L	(A5)+OCH1,#H'1000000*MARKFM	CLR.L	(A5)+OCHM1	CLR.L	(A5)+OCHC1	CALL	ECHERCHEAV	; cherche fin faute en avant	POP.L	(A5)+OCHC1	POP.L	(A5)+OCHM1	POP.L	(A5)+OCH1	TEST.W	D7	JUMP,NE EXIT$	JUMP'	EDICOVR$EDICOAR$:	PUSH.L	(A5)+OCH1	PUSH.L	(A5)+OCHM1	PUSH.L	(A5)+OCHC1	LOAD.L	(A5)+OCH1,#H'1000000*MARKFM	CLR.L	(A5)+OCHM1	CLR.L	(A5)+OCHC1	CALL	ECHERCHEAR	; cherche fin faute en arrire	POP.L	(A5)+OCHC1	POP.L	(A5)+OCHM1	POP.L	(A5)+OCH1	TEST.W	D7	JUMP,NE EXIT$;	JUMP'	EDICOVR$EDICOVR$:	LOAD.W	D2,D3	SR.W	D2,#8		; D2 <-- touches super-shift	COMP.B	D2,#SEARCH	JUMP,EQ OK$	CALL	_BUTX_GETPOS	; D4 <-- position actuelle	LOAD.L	D0,D4EDICOVR2$:	CALL	_BUTX_RECULE	JUMP',NE EDICOVR8$	COMP.B	D3,#MARKDM	JUMP,NE EDICOVR2$	CALL	EDSPYCURS	; renseigne les espions	CALL	_BUTX_AVANCE	CALL	_BUTX_DELETE	; dtruit le MARKDM	CALL	_BUTX_GETPOS	; D4 <-- position actuelle	LOAD.L	D0,D4	LOAD.L	D1,#-1EDICOVR4$:	INC.L	D1	CALL	_BUTX_AVANCE	JUMP',NE EDICOVR8$	COMP.B	D3,#MARKFM	JUMP,NE EDICOVR4$	CALL	_BUTX_DELETE	; dtruit le MARKFM	JUMP'	EDICODB$EDICOVR8$:	LOAD.L	D4,D0	CALL	_BUTX_SETPOS	JUMP	BIP$EDICODB$:	COMP.B	D2,#SEARCH!CHANGE	JUMP,NE OK$	LOAD.L	D4,D0		; D4 <-- position	LOAD.L	D5,D1		; D5 <-- nb de caractres	CALL	DICOVERIF	; vrifie juste le mot	JUMP,NE EXIT$	JUMP	OK$; Recherches interractives avec dbox.ISEAR$:	TEST.B	(A5)+OCHFAN+2:#BCHAR-8	JUMP,BS ISEARAR$ISEARAV$:	CALL	ECHERCHEAV	; cherche en avant	JUMP,NE BIP$	CALL	EDAFMAJALLv	; affiche le pav de texte	CALL	ESETZONE	; met en vidence les caractres trouvs	CALL	DBOXCHERCHE	; SUIVANT/STOP ...	PUSH.W	D7	CALL	ECLRZONE	; enlve la mise en vidence	POP.W	D7	JUMP,NE BIP$	COMP.W	D3,#F1		; suivant ?	JUMP,EQ ISEARAV$	; oui => ISEARAV$	JUMP	OK$ISEARAR$:	CALL	ECHERCHEAR	; cherche en arrire	JUMP,NE BIP$	CALL	EDAFMAJALLv	; affiche le pav de texte	CALL	ESETZONE	; met en vidence les caractres trouvs	CALL	DBOXCHERCHE	; SUIVANT/STOP ...	PUSH.W	D7	CALL	ECLRZONE	; enlve la mise en vidence	POP.W	D7	JUMP,NE BIP$	COMP.W	D3,#F1		; suivant ?	JUMP,EQ ISEARAR$	; oui => ISEARAR$	JUMP	OK$; Comptages interractifs avec dbox.ICNT$:	TEST.B	(A5)+OCHFAN+2:#BCHAR-8	JUMP,BS ECNTAR$	JUMP	ECNTAV$; Substitutions interractives avec dbox.ICHAN$:	TEST.B	(A5)+OCHFAN+2:#BCHAR-8	JUMP,BS ICHANAR$ICHANAV$:	CALL	ECHERCHEAV	; cherche en avant	JUMP,NE BIP$	CALL	EDAFMAJALLv	; affiche le pav de texte	CALL	ESETZONE	; met en vidence les caractres trouvs	CALL	DBOXSUBSTITUE	; CHANGE/SUIVANT/PARTOUT/UN/STOP ...	PUSH.W	D7	CALL	ECLRZONE	; enlve la mise en vidence	POP.W	D7	JUMP,NE BIP$	COMP.W	D3,#F1		; CHANGE ?	JUMP',EQ ICHANSAV$	; oui => ICHANSAV$	COMP.W	D3,#F4		; SUIVANT ?	JUMP,EQ ICHANAV$	; oui => ICHANAV$	COMP.W	D3,#F7		; PARTOUT ?	JUMP',EQ ICHANAAV$	; oui => ICHANAAV$	COMP.W	D3,#F10		; UN ?	JUMP',EQ ICHANSAV$	; oui => ICHANSAV$	JUMP	OK$ICHANSAV$:	CALL	ESUBSTITUEAV	; effectue la substitution	JUMP,NE BIP$	CALL	EDAFMAJALLv	; affiche le pav de texte	COMP.W	D3,#F1		; CHANGE ?	JUMP,EQ ICHANAV$	; oui => ICHANAV$	JUMP	OK$ICHANAAV$:	CALL	ESUBSTITUEAV	; effectue la substitution	JUMP,NE BIP$	CALL	ECHERCHEAV	; cherche en avant	JUMP,EQ ICHANAAV$	CALL	EDAFMAJALLv	; affiche le pav de texte	JUMP	OK$ICHANAR$:	CALL	ECHERCHEAR	; cherche en arrire	JUMP,NE BIP$	CALL	EDAFMAJALLv	; affiche le pav de texte	CALL	ESETZONE	; met en vidence les caractres trouvs	CALL	DBOXSUBSTITUE	; CHANGE/SUIVANT/PARTOUT/UN/STOP ...	PUSH.W	D7	CALL	ECLRZONE	; enlve la mise en vidence	POP.W	D7	JUMP,NE BIP$	COMP.W	D3,#F1		; CHANGE ?	JUMP',EQ ICHANSAR$	; oui => ICHANSAR$	COMP.W	D3,#F4		; SUIVANT ?	JUMP,EQ ICHANAR$	; oui => ICHANAR$	COMP.W	D3,#F7		; PARTOUT ?	JUMP',EQ ICHANAAR$	; oui => ICHANAAR$	COMP.W	D3,#F10		; UN ?	JUMP',EQ ICHANSAR$	; oui => ICHANSAR$	JUMP'	OK$ICHANSAR$:	CALL	ESUBSTITUEAR	; effectue la substitution	JUMP',NE BIP$	CALL	EDAFMAJALLv	; affiche le pav de texte	COMP.W	D3,#F1		; CHANGE ?	JUMP,EQ ICHANAR$	; oui => ICHANAR$	JUMP'	OK$ICHANAAR$:	CALL	ESUBSTITUEAR	; effectue la substitution	JUMP',NE BIP$	CALL	ECHERCHEAR	; cherche en arrire	JUMP,EQ ICHANAAR$	CALL	EDAFMAJALLv	; affiche le pav de texte;	JUMP'	OK$OK$:	CLR.W	D7		; D7 <-- action effectue correctement	JUMP'	EXIT$BIP$:	LOAD.W	D7,#ERPBIP	; D7 <-- rien  faire avec cette toucheEXIT$:	POPM.L	D1..D6	TEST.W	D7		; retour EQ/NE	RET;---------\\; ESETZONE >;---------/; Allume les caractres trouvs.; in	A4.L	^objet;	D4.L	nb de caractres; out	D4.L	premier caractre;	D5.L	dernier caractre; mod	D4.L, D5.L, D7.WESETZONE:	LOAD.W	D7,#DR_WDOOPEN	PAGE_	DRAW		; dessine dans la swdo	LOAD.L	D5,D4	CALL	_BUTX_GETPOS	; D4 <-- position actuelle	ADD.L	D5,D4	CALL	BASZONEINV	; met en vidence les caractres trouvs	LOAD.W	D7,#DR_WDOCLOSE	PAGE_	DRAW		; fin du dessin dans la swdo	RET;---------\\; ECLRZONE >;---------/; Allume les caractres trouvs.; in	A4.L	^objet;	D4.L	premier caractre;	D5.L	dernier caractre; out	D4.L	nb de caractres; mod	D4.L, D7.WECLRZONE:	LOAD.W	D7,#DR_WDOOPEN	PAGE_	DRAW		; dessine dans la swdo	CALL	BASZONEINV	; efface la mise en vidence	SUB.L	D4,D5	NEG.L	D4	LOAD.W	D7,#DR_WDOCLOSE	PAGE_	DRAW		; fin du dessin dans la swdo	RET;--------\\; EINSERE >;========/; Insre un caractre en mode "environnant".; in	D3.B	caractre  insrer; out	D7.W	erreur; mod	D7.WEINSERE:	PUSHM.L	D0..D5	LOAD.B	D0,D3		; D0 <-- caractre; Si le buffer est vide, cherche le caractre choisi.	CALL	_BUTX_GETINFO	; D3/D4/D5 <-- ?/nb car/?	TEST.L	D4		; y a-t-il des caractres ?	JUMP',NE SEARCH$	; oui => SEARCH$;;?	LOAD.W	D4,(A4)+OOBCHAR	; D4 <-- caractre slectionn;;?	AND.L	D4,#CCGCMSK;;?;	SL.L	D4,#CCGCSHI	CLR.L	D4	LOAD.B	D4,#-1		; D4 <-- caractre ordinaire	CLR.L	D5	JUMP'	INS$; Cherche le mode du caractre avant le curseur.SEARCH$:	CALL	_BUTX_POSSAVE	; D4 <-- position du curseur	LOAD.W	D1,D4	CALL	_BUTX_RECULE	; D3/D4/D5 <-- mode du caractre prcdent	JUMP',EQ PREV$	CLR.L	D4		; D4 <-- mode par dfautPREV$:	LOAD.L	D2,D4	LOAD.W	D4,D1	CALL	_BUTX_POSEND	; remet le curseur o il tait; Cherche le mode du caractre aprs le curseur.	CALL	_BUTX_POSSAVE	; D4 <-- position du curseur	LOAD.W	D1,D4	CALL	_BUTX_AVANCE	; D3/D4/D5 <-- mode du caractre suivant	JUMP',EQ NEXT$	CLR.L	D4		; D4 <-- mode par dfautNEXT$:	LOAD.L	D5,D4	LOAD.W	D4,D1	CALL	_BUTX_POSEND	; remet le curseur o il tait; Insre le caractre avec le mode le plus grand.	LOAD.L	D4,D2	COMP.L	D4,D5	JUMP',HS INS$	LOAD.L	D4,D5INS$:	LOAD.L	D3,(A5)+OFRMSK	NOT.L	D3	AND.L	D4,D3		; D4 <-- masque selon frappe	OR.L	D4,(A5)+OFRCAR	; D4 <-- mode selon frappe	CALL	EDSPYCURS	; renseigne les espions	LOAD.B	D3,D0		; D3 <-- mode et caractre	CALL	PINSERT		; insre normalement	POPM.L	D0..D5	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ECHERCHEAV >;===========/; Cherche en avant selon le dialogue "change".; Si elle est trouve, le curseur est plac sur le premier caractre.; Si elle n'est pas trouve, le curseur reste immobile !; in	-; out	D4.L	longueur de la chane trouve;	D7.W	erreur; mod	D4.L, D7.WECHERCHEAV:	PUSHM.L	D0..D3,D5,A3	LOAD.L	A3,#(A5)+OCH1	; A3 <-- ^chane de recherche	CALL	_BUTX_POSSAVE	PUSH.W	D4		; stack <-- position actuelle	CALL	_BUTX_GETPOS	; D4 <-- position actuelle	LOAD.L	D0,D4	LOAD.L	D2,(A5)+OCHM1	CLR.L	D3	LOAD.L	D4,(A5)+OCHC1	CLR.L	D5	CALL	_BUTX_INFOMASK	; donne les informations et les masquesLOOP$:	CALL	_BUTX_AVANCE	; D3/D4/D5 <-- caractre suivant	JUMP',NE END$; Cherche rapidement le premier caractre de la chane.	LOAD.B	D3,(A3)		; D3 <-- premier caractre	LOAD.W	D4,#2^1		; D4 <-- mode (selon INFOMASK)	TEST.B	(A5)+OCHFAN+3:#BCHMIMA-0	JUMP',BC MAJ$	TSET.L	D4:#0MAJ$:	CALL	_BUTX_NSEARCH	; cherche le premier caractre	JUMP',NE END$; Cherche normalement si le reste de la chane correspond.	CALL	ECHERCHECP	; chane complte trouve ?	JUMP,NE LOOP$; Fin de la recherche. En cas d'erreur, remet le curseur o il tait.END$:	LOAD.W	D3,D7	JUMP',NE ERROR$	CALL	_BUTX_GETPOS	; D4 <-- position actuelle	SUB.L	D4,D0	POP.W	D4	CALL	_BUTX_POSCANCEL	; annule le BUTX_POSSAVE	JUMP'	QUIT$ERROR$:	POP.W	D4	CALL	_BUTX_POSEND	; remet le curseur o il tait	LOAD.W	D3,#ERPNOTF	; D7 <-- pas trouvQUIT$:	LOAD.W	D7,D3		; D7 <-- ok/erreur	LOAD.L	D4,D1		; D4 <-- nombre de caractres trouvs	POPM.L	D0..D3,D5,A3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ECHERCHEAR >;===========/; Cherche en arrire selon le dialogue "change".; Si elle est trouve, le curseur est plac sur le premier caractre.; Si elle n'est pas trouve, le curseur reste immobile !; in	-; out	D4.L	longueur de la chane trouve;	D7.W	erreur; mod	D4.L, D7.WECHERCHEAR:	PUSHM.L	D0..D3,D5,A3	LOAD.L	A3,#(A5)+OCH1	; A3 <-- ^chane de recherche	CALL	_BUTX_POSSAVE	PUSH.W	D4		; stack <-- position actuelle	CALL	_BUTX_GETPOS	; D4 <-- position actuelle	LOAD.L	D0,D4	LOAD.L	D2,(A5)+OCHM1	CLR.L	D3	LOAD.L	D4,(A5)+OCHC1	CLR.L	D5	CALL	_BUTX_INFOMASK	; donne les informations et les masques; Cherche rapidement le premier caractre de la chane.LOOP$:	LOAD.B	D3,(A3)		; D3 <-- premier caractre	LOAD.W	D4,#2^1		; D4 <-- mode (selon INFOMASK)	TEST.B	(A5)+OCHFAN+3:#BCHMIMA-0	JUMP',BC MAJ$	TSET.L	D4:#0MAJ$:	CALL	_BUTX_RSEARCH	; cherche le premier caractre	JUMP',NE END$	CALL	_BUTX_RECULE	; D3/D4/D5 <-- recule d'un caractre	JUMP',NE END$; Cherche normalement si le reste de la chane correspond.	CALL	ECHERCHECP	; chane complte trouve ?	JUMP,NE LOOP$; Fin de la recherche. En cas d'erreur, remet le curseur o il tait.END$:	LOAD.W	D3,D7	JUMP',NE ERROR$	CALL	_BUTX_GETPOS	; D4 <-- position actuelle	SUB.L	D0,D4	POP.W	D4	CALL	_BUTX_POSCANCEL	; annule le BUTX_POSSAVE	JUMP'	QUIT$ERROR$:	POP.W	D4	CALL	_BUTX_POSEND	; remet le curseur o il tait	LOAD.W	D3,#ERPNOTF	; D7 <-- pas trouvQUIT$:	LOAD.W	D7,D3		; D7 <-- ok/erreur	LOAD.L	D4,D1		; D4 <-- nombre de caractres trouvs	POPM.L	D0..D3,D5,A3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ECHERCHECP >;-----------/; Regarde si le curseur est au dbut de la chane de recherche complte.; in	A3.L	^chane de recherche; out	D1.L	nombre de caractres trouvs;	D7.W	erreur; mod	D1.L, D7.WECHERCHECP:	PUSHM.L	D2..D5,A3	CALL	_BUTX_POSSAVE	PUSH.W	D4		; stack <-- position dbut chane	TEST.B	(A5)+OCHFAN+3:#BCHMOT-0	JUMP',BC BEGIN$	CALL	_BUTX_RECULE	JUMP',NE BEGIN$	CALL	ECHERCHEMO	; lettre ou chiffre ?	JUMP,EQ ERROR$		; oui => ERROR$	CALL	_BUTX_AVANCEBEGIN$:	CLR.L	D1		; D1 <-- nombre de caractres trouvsLOOP$:	LOAD.B	D2,(A3+)	; D2 <-- caractre de la chane	JUMP,EQ TERM$	COMP.B	D2,#'*	JUMP',NE NOSTAR$	TEST.B	(A5)+OCHFAN+3:#BCHJOKER-0	JUMP,BS STAR$NOSTAR$:	CALL	_BUTX_AVANCE	; D3/D4/D5 <-- caractre du texte	JUMP,NE ERROR$	INC.L	D1		; D1 <-- un caractre de plus	COMP.B	D2,#'?	JUMP',NE NOEXCL$	TEST.B	(A5)+OCHFAN+3:#BCHJOKER-0	JUMP,BS LOOP$NOEXCL$:	TEST.B	(A5)+OCHFAN+3:#BCHMIMA-0	JUMP',BC NOMAJ$	CALL	_BUTX_MINMAJ	; D3 <-- majuscule	EX.L	D2,D3	CALL	_BUTX_MINMAJ	; D2 <-- majuscule	EX.L	D3,D2NOMAJ$:	COMP.B	D3,D2		; compare deux caractres	JUMP,NE ERROR$	AND.L	D4,(A5)+OCHM1	COMP.L	D4,(A5)+OCHC1	; compare deux info1 ?	JUMP,NE ERROR$	JUMP	LOOP$STAR$:				; toile rencontre =>	LOAD.B	D2,(A3+)	; D2 <-- caractre aprs l'toile	JUMP,EQ TERM$	TEST.B	(A5)+OCHFAN+3:#BCHMIMA-0	JUMP',BC SLOOP$	EX.L	D2,D3	CALL	_BUTX_MINMAJ	; D2 <-- majuscule	EX.L	D3,D2SLOOP$:	CALL	_BUTX_AVANCE	; D3/D4/D5 <-- caractre du texte	JUMP,NE ERROR$	INC.L	D1		; D1 <-- un caractre de plus	TEST.B	(A5)+OCHFAN+3:#BCHMOT-0	JUMP',BC SLC$	CALL	ECHERCHEMO	; lettre ou chiffre ?	JUMP,NE ERROR$		; non => ERROR$SLC$:	TEST.B	(A5)+OCHFAN+3:#BCHMIMA-0	JUMP',BC SNOMAJ$	CALL	_BUTX_MINMAJ	; D3 <-- majusculeSNOMAJ$:	COMP.B	D3,D2		; compare deux caractres	JUMP,NE SLOOP$	AND.L	D4,(A5)+OCHM1	COMP.L	D4,(A5)+OCHC1	; compare deux info1 ?	JUMP,NE SLOOP$	JUMP	LOOP$TERM$:				; fin chane de recherche =>	TEST.B	(A5)+OCHFAN+3:#BCHMOT-0	JUMP',BC FOUND$	CALL	_BUTX_AVANCE	JUMP',NE FOUND$	CALL	ECHERCHEMO	; lettre ou chiffre ?	JUMP',EQ ERROR$		; oui => ERROR$FOUND$:	CLR.W	D7		; D7 <-- trouv	JUMP'	END$ERROR$:	LOAD.W	D7,#ERPNOTF	; D7 <-- pas trouvEND$:	LOAD.W	D3,D7	POP.W	D4	CALL	_BUTX_POSEND	; revient au dbut de la chane	LOAD.W	D7,D3	POPM.L	D2..D5,A3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ECHERCHEMO >;-----------/; Regarde si un caractre est une lettre ou un chiffre.; in	D3.B	caractre; out	D7.W	EQ => c'est une lettre/chiffre;		NE => autre caractre; mod	D3.B, D7.WECHERCHEMO:	CALL	_BUTX_MINMAJ	LOAD.W	D7,#1		; D7 <-- autre chose	COMP.B	D3,#'0	JUMP',LO EXIT$	COMP.B	D3,#'9	JUMP',LS OK$	COMP.B	D3,#'A	JUMP',LO EXIT$	COMP.B	D3,#'Z	JUMP',HI EXIT$OK$:	CLR.W	D7		; D7 <-- lettre ou chiffreEXIT$:	TEST.W	D7		; retour EQ/NE	RET;-------------\\; ESUBSTITUEAR >;=============/; Remplace la chane de recherche par la chane de substitution.; Le curseur est plac au dbut de la chane substitue.; in	D4.L	longueur de la chane trouve; out	D4.L	longueur de la chane substitue;	D7.W	erreur; mod	D4.L, D7.WESUBSTITUEAR:	CALL	ESUBSTITUEAV	JUMP',EQ SUBS$	RETSUBS$:	PUSHM.L	D2..D5	LOAD.L	D2,D4LOOP$:	CALL	_BUTX_RECULE	; recule au dbut	JUMP',NE END$	DEC.L	D2	JUMP,NE LOOP$END$:	POPM.L	D2..D5	CLR.W	D7		; D7 <-- ok	RET;-------------\\; ESUBSTITUEAV >;=============/; Remplace la chane de recherche par la chane de substitution.; Le curseur est plac  la fin de la chane substitue.; in	D4.L	longueur de la chane trouve; out	D4.L	longueur de la chane substitue;	D7.W	erreur; mod	D4.L, D7.WESUBSTITUEAV:	PUSHM.L	D0..D3,D5,A3	CALL	EDSPYCURS	; renseigne les espions; Supprime d'abord la chane de recherche.	LOAD.L	D1,D4	LOAD.L	D2,#-1KLOOP$:	CALL	_BUTX_AVANCE	JUMP',NE INS$	COMP.L	D2,#-1	JUMP',NE KNEXT$	LOAD.L	D2,D4		; D2 <-- info1 premier caractre dtruitKNEXT$:	CALL	PDELETE		; dtruit un caractre en avant	DEC.L	D1		; encore un caractre ?	JUMP,NE KLOOP$		; oui => KLOOP$; Insre la chane de substitution.INS$:	LOAD.L	D1,(A5)+OCHM2	NOT.L	D1	AND.L	D2,D1	OR.L	D2,(A5)+OCHC2	LOAD.L	A3,#(A5)+OCH2	; A3 <-- ^chane de substitution	CLR.L	D1ILOOP$:	LOAD.B	D3,(A3+)	; D3 <-- caractre	JUMP',EQ OK$	LOAD.L	D4,D2	CLR.L	D5	CALL	PINSERT	JUMP',NE EXIT$	INC.L	D1		; D1 <-- longueur de la chane de substitution	JUMP	ILOOP$OK$:	LOAD.L	D4,D1	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D3,D5,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; EMINMAJ >;========/; Transforme un caractre, en majuscule ou en minuscule.; in	D3.B	touche majuscule/minuscule;		H'80 = majuscules accentues;		H'81 = chiffres fixes;		H'82 = chiffres proportionnels; out	D7.W	erreur; mod	D7.WEMINMAJ:	PUSHM.L	D1..D5	LOAD.B	D2,D3	CALL	_BUTX_AVANCE	; D3/D4/D5 <-- caractre sous le curseur	JUMP,NE EXIT$	CALL	_BUTX_RECULE	LOAD.B	D1,D3		; D1 <-- caractre actuel	COMP.B	D2,#H'80	JUMP',EQ MAJACC$	COMP.B	D2,#H'81	JUMP',EQ FIX$	COMP.B	D2,#H'82	JUMP',EQ PROP$	COMP.B	D2,#'a	JUMP',LO MINUS$	COMP.B	D2,#'z	JUMP',HI MINUS$MAJUS$:				; en minuscule =>	CALL	_BUTX_MAJMIN	; D3 <-- lattre majuscule	JUMP'	CHANGE$MINUS$:				; en majuscule =>	CALL	_BUTX_MINMAJ	; D3 <-- lettre majuscule	JUMP'	CHANGE$MAJACC$:			; en majuscule accentue =>	CALL	_BUTX_MINMAC	; D3 <-- lettre majuscule accentue	JUMP'	CHANGE$FIX$:	COMP.B	D3,#H'E6	JUMP',LO CHANGE$	COMP.B	D3,#H'EF	JUMP',HI CHANGE$	SUB.B	D3,#H'E6-'0	JUMP'	CHANGE$PROP$:	COMP.B	D3,#'0	JUMP',LO CHANGE$	COMP.B	D3,#'9	JUMP',HI CHANGE$	ADD.B	D3,#H'E6-'0;	JUMP'	CHANGE$CHANGE$:	COMP.B	D3,D1		; caractre chang ?	JUMP',EQ EXIT$		; non => EXIT$	CALL	EDSPYCURS	; renseigne les espions	CALL	_BUTX_AVANCE	CALL	PDELETE		; dtruit le caractre actuel	CALL	PINSERT		; met le nouveau  la place	CALL	_BUTX_RECULEEXIT$:	POPM.L	D1..D5	TEST.W	D7		; retour EQ/NE	RET;--------\\; ESELMOT >;========/; Slectionne tout un mot.; in	D4.L	position n'importe o; out	D4.L	position dbut mot;	D5.L	position fin mot; mod	D4.L, D5.L, D7.WESELMOT:	PUSHM.L	D0..D3	LOAD.L	D0,D4	CALL	_BUTX_POSSAVE	; D4 <-- numro position actuelle	EX.L	D0,D4	CALL	_BUTX_SETPOS	; positionne	LOAD.B	D3,#'S	CALL	EFLECHE		; D2 <-- dplacement pour reculer au dbut du mot	LOAD.L	D1,D2	LOAD.B	D3,#'G	CALL	EFLECHE		; D2 <-- dplacement pour avancer  la fin du mot	LOAD.L	D5,D4	ADD.L	D5,D2		; D5 <-- position fin mot	ADD.L	D4,D1		; D4 <-- position dbut mot	EX.L	D0,D4	CALL	_BUTX_POSEND	; remet le curseur o il tait	LOAD.L	D4,D0	POPM.L	D0..D3	RET;---------\\; EFLECHE  >;---------/; Calcul l'amplitude d'un dplacement/destruction en fonction; d'une touche flche.; in	D3.B	touche flche; out	D2.L	dplacement (+/-n); mod	D2.L, D7.WEFLECHE:	PUSHM.L	D1,D3..D5,A3,A4	CALL	_BUTX_POSSAVE	; D4 <-- numro position actuelle	PUSH.W	D4	CLR.L	D2		; D2 <-- dplacement	COMP.B	D3,#'A-H'40	JUMP',LO NOCTRL$	COMP.B	D3,#'Z-H'40	JUMP',HI NOCTRL$	ADD.B	D3,#H'40NOCTRL$:	CALL	_BUTX_MINMAJ	COMP.B	D3,#'F	JUMP,EQ AONE$	COMP.B	D3,#'D	JUMP,EQ RONE$	LOAD.W	D1,#1		; D1 <-- une fois	LOAD.L	A3,#R16"TWORD	; A3 <-- ^terminateurs de mots	COMP.B	D3,#'G	JUMP,EQ ALIST$	COMP.B	D3,#'S	JUMP,EQ RLIST$	COMP.B	D3,#'C	JUMP,EQ ALINE$	COMP.B	D3,#'R	JUMP,EQ RLINE$	LOAD.L	A3,#R16"TLINE	; A3 <-- ^terminateurs de lignes	COMP.B	D3,#'X	JUMP,EQ ALIST$	COMP.B	D3,#'E	JUMP,EQ RLIST$	COMP.B	D3,#'V	JUMP,EQ AEND$	COMP.B	D3,#'T	JUMP,EQ REND$	JUMP	EXIT$AONE$:				; +1 caractre =>	CALL	_BUTX_AVANCE	JUMP,NE EXIT$	COMP.B	D3,#PEOT	JUMP,EQ EXIT$	INC.L	D2	JUMP	EXIT$RONE$:				; -1 caractre =>	CALL	_BUTX_RECULE	JUMP,NE EXIT$	DEC.L	D2	JUMP	EXIT$ALIST$:				; +1 mot/ligne =>	CALL	_BUTX_AVANCE	JUMP,NE EXIT$	COMP.B	D3,#PEOT	JUMP,EQ EXIT$	INC.L	D2	CALL	ETESTCAR	JUMP',NE ALIST2$	COMP.B	(A3),#CR	JUMP,NE ALIST$ALIST2$:	CALL	_BUTX_AVANCE	JUMP,NE EXIT$	COMP.B	D3,#PEOT	JUMP,EQ EXIT$	INC.L	D2	CALL	ETESTCAR	JUMP,NE ALIST2$	CALL	_BUTX_RECULE	DEC.L	D2	DEC.W	D1	JUMP,NE ALIST$	JUMP	EXIT$RLIST$:				; -1 mot/ligne =>	CALL	_BUTX_RECULE	JUMP,NE EXIT$	DEC.L	D2	CALL	ETESTCAR	JUMP',NE RLIST2$	COMP.B	(A3),#CR	JUMP,NE RLIST$RLIST2$:	CALL	_BUTX_RECULE	JUMP,NE EXIT$	DEC.L	D2	CALL	ETESTCAR	JUMP,NE RLIST2$	CALL	_BUTX_AVANCE	INC.L	D2	DEC.W	D1	JUMP,NE RLIST$	JUMP	EXIT$ALINE$:	CALL	_BUTX_GETPOS	; D4 <-- position du curseur	LOAD.L	D3,D4	CALL	CARPJSEARCH	; A3/A4 <-- ^dans OPJxxx	JUMP',NE EXIT$	CALL	CARPOSDIM	; cherche position/dimensions du pav	CALL	BASPOSCLINE	; D2 <-- position (y;x)	LOAD.L	D4,D2	CLR.L	D2	CALL	CARPJNEXT	; A3/A4 <-- ^ligne suivante	JUMP',NE EXIT$	CALL	BASGPCAR	; D4 <-- position o aller dans BUTX	LOAD.L	D2,D4	SUB.L	D2,D3		; D2 <-- dplacement (+)	JUMP'	EXIT$RLINE$:	CALL	_BUTX_GETPOS	; D4 <-- position du curseur	LOAD.L	D3,D4	CALL	CARPJSEARCH	; A3/A4 <-- ^dans OPJxxx	JUMP',NE EXIT$	CALL	CARPOSDIM	; cherche position/dimensions du pav	CALL	BASPOSCLINE	; D2 <-- position (y;x)	LOAD.L	D4,D2	CLR.L	D2	CALL	CARPJPREV	; A3/A4 <-- ^ligne prcdente	JUMP',NE EXIT$	CALL	BASGPCAR	; D4 <-- position o aller dans BUTX	LOAD.L	D2,D4	SUB.L	D2,D3		; D2 <-- dplacement (-)	JUMP'	EXIT$AEND$:				; fin =>	CALL	_BUTX_GETINFO	; D3/D4/D5 <-- ?/nb car/?	LOAD.L	D2,D4	CALL	_BUTX_GETPOS	; D4 <-- position actuelle	SUB.L	D2,D4	JUMP'	EXIT$REND$:				; dbut =>	CALL	_BUTX_GETPOS	; D4 <-- position actuelle	LOAD.L	D2,D4	NEG.L	D2;	JUMP'	EXIT$EXIT$:	POP.W	D4	CALL	_BUTX_POSEND	; remet le curseur o il tait	POPM.L	D1,D3..D5,A3,A4	RETTWORD:	.B	SPACE		; terminateurs de mots	.B	TAB	.B	'+	.B	'-	.B	'*	.B	'/	.B	'^	.B	'(	.B	')	.B	'.	.B	':	.B	',	.B	';	.B	'!	.B	'?TLINE:	.B	CR		; terminateurs de lignes	.B	LF	.B	0	.EVEN;---------\\; ETESTCAR >;---------/; Test si le caractre dans D3.B est un terminateur.; in	D3.B	caractre;	A3.L	^liste de terminateurs; out	EQ	terminateur;	NE	autre chose; mod	FETESTCAR:	PUSH.L	A3LOOP$:	TEST.B	(A3)	NOTZ	JUMP',NE EXIT$	COMP.B	D3,(A3+)	JUMP,NE LOOP$EXIT$:	POP.L	A3	RET;--------\\; ACCENT  >;========/; Caractre aprs un accent flottant frapp.; in	D3.B	caractre aprs accent; out	D7.W	erreur; mod	D7.WACCENT:	PUSHM.L	D2..D5	LOAD.W	D7,#ERPBIP	TEST.B	(A4)+OOBACC	JUMP',F EXIT$	CLR.B	(A4)+OOBACC	LOAD.B	D2,D3	CALL	_BUTX_AVANCE	; D3 <-- cherche car prcdent tap	JUMP',NE SKIP$		; rien => SKIP$	CALL	_BUTX_RECULE	LOAD.B	D4,D3		; D4 <-- accent	LOAD.B	D3,D2		; D3 <-- car qui ira "sous"	CALL	GETACCENT	; accent existe ?	JUMP',NE SKIP$		; non => SKIP$				; oui =>	TEST.B	D3		; laisse l'accent seul ?	JUMP',EQ SKIP$		; oui => SKIP$				; non =>	PUSH.L	D3	CALL	_BUTX_AVANCE	CALL	_BUTX_DELETE	; dtruit l'accent seul	POP.L	D3	CALL	EINSERE		; remplace par lettre accentue	JUMP'	EXIT$SKIP$:	PUSH.W	D7	CALL	_BUTX_AVANCE	; saute '^' ou '"'	POP.W	D7EXIT$:	POPM.L	D2..D5	TEST.W	D7		; retour EQ/NE	RET;----------\\; GETACCENT >;----------/; Calcul le code correspondant  une lettre (a,e,i,o,u) et ; un accent (^,").; in	D4.B	accent (^,");	D3.B	caractre; out	D7.W	zro => ok (lettre accentue existe);	 D3.B	 lettre accentue;	D7.W	EREOUTB => lettre accentue n'existe pas;	 D3.B	 caractre qui devait aller sous l'accent; mod	D3.B, D7.WGETACCENT:	PUSH.L	A3	LOAD.L	A3,#R16"ACCENT$-3LOOP$:	ADD.L	A3,#3		; A3 <-- ^suivant dans table	TEST.B	(A3)		; fin de la table ?	JUMP',EQ ERROR$		; oui => ERROR$	COMP.B	D3,(A3)		; lettre trouve dans table ?	JUMP,NE LOOP$		; non => LOOP$				; oui =>	COMP.B	D4,#CIRCON	JUMP',EQ CIRCON$	COMP.B	D4,#TREMA	JUMP',NE ERROR$TREMA$:	LOAD.B	D3,(A3)+2	; D3 <-- lettre accentue (")	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$CIRCON$:	LOAD.B	D3,(A3)+1	; D3 <-- lettre accentue (^)	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$ERROR$:	LOAD.W	D7,#ERPBIP	; D7 <-- erreurEXIT$:	POP.L	A3	TEST.W	D7		; retour EQ/NE	RETACCENT$:	.B	'a	' '	.B	'e	' '	.B	'i	' '	.B	'o	' '	.B	'u	' '	.B	SPACE	 0  0	.B	0	.EVEN;---------\\; NOACCENT >;=========/; Annule l'effet d'un ventuel accent flottant tap, alors; que la lettre devant aller "dessous" n'a pas encore t; tape.NOACCENT:	TEST.B	(A4)+OOBACC	JUMP',F EXIT$	CLR.B	(A4)+OOBACC	PUSHM.L	D3..D5	CALL	_BUTX_AVANCE	; saute l'accent flottant	POPM.L	D3..D5EXIT$:	RET;----------\\; EDSPYCURS >;----------/; Informe les espions de la nouvelle position du curseur.; in	-; out	-; mod	D7.WEDSPYCURS:	PUSH.L	D4	CALL	_BUTX_GETPOS	; D4 <-- position actuelle	COMP.L	D4,(A5)+OSPYLII	JUMP',HS EXIT$	LOAD.L	(A5)+OSPYLII,D4	; OSPYLII <-- limite infrieureEXIT$:	POP.L	D4	RET;--------\\; PINSERT >;========/; Insre un caractrre, en grant les paragraphes.; in	D6.L	canal;	D3.B	caractre (0..255);	D4.L	info 1;	D5.L	info 2; out	D7.W	erreur; mod	D7.WPINSERT:	PUSHM.L	D2,D4	CALL	CARSRCNJUST	; D2 <-- justification	RR.L	D2,#32-CCJUSHI	AND.L	D2,#CCJUMSK	AND.L	D4,#-1-CCJUMSK	OR.L	D4,D2		; D4 <-- info1 avec justification du paragraphe	CALL	_BUTX_INSERT	POPM.L	D2,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; PDELETE >;========/; Dtruit un caractrre, en grant les paragraphes.; in	D6.L	canal; out	D3.B	caractre (0..255);	D4.L	info 1;	D5.L	info 2;	D7.W	erreur; mod	D3.L, D4.L, D5.L, D7.WPDELETE:	PUSH.L	D2	CALL	_BUTX_DELETE	; D3/D4/D5 <-- caractre dtruit	JUMP',NE EXIT$	COMP.B	D3,#CR	JUMP',NE EXIT$	LOAD.L	D2,D4	AND.L	D2,#CCJUMSK	RL.L	D2,#32-CCJUSHI	CALL	CARJUSTPUT	; modifie la justification	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	D2	TEST.W	D7		; retour EQ/NE	RET;--------\\; EXKEY   >;========/; in	D3.B	touche presse; out	-; mod	A1.LEXKEY:	POP.L	A1		; A1 <-- ^table des .WW	PUSH.L	D3	COMP.B	D3,#'a		; minuscule ?	JUMP',LO MAJ$		; non => MAJ$	COMP.B	D3,#'z	JUMP',HI MAJ$	SUB.B	D3,#'a-'A	; oui => transformeMAJ$:	COMP.B	D3,#F0+SHIFT	JUMP',LO SHIFT$	COMP.B	D3,#F15+SHIFT	JUMP',HI SHIFT$	SUB.B	D3,#SHIFT	; (SHIFT-Fn) --> (Fn)SHIFT$:	SUB.L	A1,#4		; A1 <-- recule .WWLOOP$:	ADD.L	A1,#4		; A1 <-- saute .WW	TEST.W	(A1)		; table termine ?	JUMP',EQ END$		; oui => END$				; non =>	COMP.B	D3,(A1)+1	; code touche trouve ?	JUMP,NE	LOOP$		; non => LOOP$END$:	LOAD.W	D3,(A1)+2	; D3 <-- adresse relative	LOAD.L	A1,#R16"TXPREL	ADD.W	A1,D3		; A1 <-- adresse absolue	POP.L	D3	JUMP	(A1)		; excute ...;--------\\; EXFONC  >;========/; in	D3.W	touche fonction (dans high); out	-; mod	A1.LEXFONC:	POP.L	A1		; A1 <-- ^table des .WW	PUSH.L	D3	SR.W	D3,#8		; D3 <-- touche fonction	SUB.L	A1,#4		; A1 <-- recule .WWLOOP$:	ADD.L	A1,#4		; A1 <-- saute .WW	TEST.W	(A1)		; table termine ?	JUMP',EQ END$		; oui => END$				; non =>	COMP.B	D3,(A1)+1	; code touche fonction trouv ?	JUMP,NE	LOOP$		; non => LOOP$END$:	LOAD.W	D3,(A1)+2	; D3 <-- adresse relative	LOAD.L	A1,#R16"TXPREL	ADD.W	A1,D3		; A1 <-- adresse absolue	POP.L	D3	JUMP	(A1)		; excute ...	.END