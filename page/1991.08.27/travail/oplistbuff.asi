	.SBTTL	OPLISTBUFF.ASI;--------\\; TXINFO  >;========/; Donne quelques informations sur un objet texte.; in	-; out	D4.W	position actuelle du curseur;	D5.W	nombre de caractres; mod	D4.L, D5.L, D7.WTXINFO:	PUSH.L	A1	CLR.L	D4	CLR.L	D5	LOAD.L	A1,(A5)+OTEPCE	; A1 <-- ^cellule en dition (OCE*)	TEST.L	(A1)+OCEPTX	JUMP',EQ EXIT$	LOAD.L	A1,(A1)+OCEPTX	; A1 <-- ^texte en dition (OTX*)	LOAD.W	D4,(A5)+OTECUR	; D4 <-- position du curseur	LOAD.W	D5,(A1)+OTXNBC	; D5 <-- nombre de caractresEXIT$:	POP.L	A1	CLR.W	D7		; retour EQ	RET;-------------\\; TXPOSITIONNE >;=============/; Positionne le curseur n'importe o dans un objet texte.; in	D4.W	nouvelle position; out	D7.W	erreur; mod	D7.WTXPOSITIONNE:	PUSHM.L	D3,A1	CLR.W	D3	LOAD.L	A1,(A5)+OTEPCE	; A1 <-- ^cellule en dition (OCE*)	TEST.L	(A1)+OCEPTX	JUMP',EQ RIEN$	LOAD.L	A1,(A1)+OCEPTX	; A1 <-- ^texte en dition (OTX*)	LOAD.W	D3,(A1)+OTXNBCRIEN$:	LOAD.W	D7,#1	COMP.W	D4,D3	JUMP',HI EXIT$	LOAD.W	(A5)+OTECUR,D4	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,A1	TEST.W	D7		; retour EQ/NE	RET;---------\\; TXDONNE  >;=========/; Donne le caractre sous le curseur.; in	-; out	D3.W	caractre;	D7.W	erreur; mod	D3.L, D7.WTXDONNE:	PUSHM.L	D4,A1,A4	LOAD.W	D7,#1	LOAD.L	A1,(A5)+OTEPCE	; A1 <-- ^cellule en dition (OCE*)	TEST.L	(A1)+OCEPTX	JUMP',EQ EXIT$	LOAD.L	A1,(A1)+OCEPTX	; A1 <-- ^texte en dition (OTX*)	LOAD.W	D4,(A5)+OTECUR	COMP.W	D4,(A1)+OTXNBC	; est-on tout  la fin ?	JUMP',HS EXIT$		; oui => EXIT$	LOAD.L	A4,#(A1)+OTXDEB	; A4 <-- ^buffer	CLR.W	D3	LOAD.B	D3,(A4)+(D4.W)	; D3 <-- caractre	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D4,A1,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; TXAVANCE >;=========/; Avance d'un caractre dans un objet texte.; in	-; out	D3.W	caractre avanc;	D7.W	erreur; mod	D3.L, D7.WTXAVANCE:	PUSHM.L	D4,A1,A4	LOAD.W	D7,#1	LOAD.L	A1,(A5)+OTEPCE	; A1 <-- ^cellule en dition (OCE*)	TEST.L	(A1)+OCEPTX	JUMP',EQ EXIT$	LOAD.L	A1,(A1)+OCEPTX	; A1 <-- ^texte en dition (OTX*)	LOAD.W	D4,(A5)+OTECUR	COMP.W	D4,(A1)+OTXNBC	; est-on tout  la fin ?	JUMP',HS EXIT$		; oui => EXIT$	LOAD.L	A4,#(A1)+OTXDEB	; A4 <-- ^buffer	CLR.W	D3	LOAD.B	D3,(A4)+(D4.W)	; D3 <-- caractre	INC.W	D4	LOAD.W	(A5)+OTECUR,D4	; avance le curseur	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D4,A1,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; TXRECULE >;=========/; Recule d'un caractre dans un objet texte.; in	-; out	D3.W	caractre recul;	D7.W	erreur; mod	D3.L, D7.WTXRECULE:	PUSHM.L	D4,A1,A4	LOAD.W	D7,#1	LOAD.L	A1,(A5)+OTEPCE	; A1 <-- ^cellule en dition (OCE*)	TEST.L	(A1)+OCEPTX	JUMP',EQ EXIT$	LOAD.L	A1,(A1)+OCEPTX	; A1 <-- ^texte en dition (OTX*)	LOAD.W	D4,(A5)+OTECUR	; est-on tout au dbut ?	JUMP',EQ EXIT$		; oui => EXIT$	LOAD.L	A4,#(A1)+OTXDEB	; A4 <-- ^buffer	DEC.W	D4	CLR.W	D3	LOAD.B	D3,(A4)+(D4.W)	; D3 <-- caractre	LOAD.W	(A5)+OTECUR,D4	; recule le curseur	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D4,A1,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; TXINSERE >;=========/; Insre un caractre dans un objet texte.; in	D3.W	caractre  insrer; out	D7.W	erreur; mod	D7.WTXINSERE:	PUSHM.L	D1,D4,A1..A4	LOAD.L	A1,(A5)+OTEPCE	; A1 <-- ^cellule en dition (OCE*)	TEST.L	(A1)+OCEPTX	JUMP',EQ RIEN$	LOAD.L	A2,(A1)+OCEPTX	; A2 <-- ^texte en dition (OTX*)	LOAD.W	D7,#1	CLR.L	D4	LOAD.W	D4,(A2)+OTXNBC	COMP.W	D4,(A2)+OTXLGM	; buffer tout plein ?	JUMP',LO INS$	ADD.W	D4,#OTXDEB+TXRES	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour texte plus long	JUMP,NE EXIT$	PUSHM.L	D4,A2,A4	LOAD.W	D4,(A2)+OTXNBC	ADD.W	D4,#OTXDEB-1XFER$:	LOAD.B	(A4+),(A2+)	; nouveau texte <-- ancien texte	DECJ.W,NMO D4,XFER$	POPM.L	D4,A2,A4	SUB.W	D4,#OTXDEB	LOAD.W	(A4)+OTXLGM,D4	LOAD.L	(A1)+OCEPTX,A4	EX.L	A4,A2;	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre l'ancien texte	JUMP'	INS$RIEN$:	LOAD.L	D4,#OTXDEB+TXRES	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour texte	JUMP',NE EXIT$	SUB.W	D4,#OTXDEB	LOAD.W	(A4)+OTXLGM,D4	CLR.W	(A4)+OTXNBC	LOAD.L	(A1)+OCEPTX,A4	LOAD.L	A2,A4INS$:	LOAD.L	A4,#(A2)+OTXDEB	; A4 <-- ^buffer	LOAD.W	D4,(A2)+OTXNBC	ADD.W	A4,D4	SUB.W	D4,(A5)+OTECUR	JUMP',EQ PUT$	LOAD.L	A3,#(A4)+1	DEC.W	D4SHIFT$:	LOAD.B	(-A3),(-A4)	; pousse la fin du buffer	DECJ.W,NMO D4,SHIFT$PUT$:	LOAD.B	(A4),D3		; buffer <-- caractre	INC.W	(A2)+OTXNBC	; utilise un caractre de plus	INC.W	(A5)+OTECUR	; avance le curseur	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1,D4,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; TXDETRUIT >;==========/; Dtruit le caractre plac juste avant le curseur dans un objet texte.; in	-; out	D3.W	caractre dtruit;	D7.W	erreur; mod	D3.L, D7.WTXDETRUIT:	PUSHM.L	D1,D4,A1..A4	LOAD.W	D7,#1	LOAD.L	A1,(A5)+OTEPCE	; A1 <-- ^cellule en dition (OCE*)	TEST.L	(A1)+OCEPTX	JUMP,EQ EXIT$	LOAD.L	A2,(A1)+OCEPTX	; A2 <-- ^texte en dition (OTX*)	LOAD.W	D4,(A5)+OTECUR	; est-on tout au dbut ?	JUMP',EQ EXIT$		; oui => EXIT$	LOAD.L	A4,#(A2)+OTXDEB	; A4 <-- ^buffer	ADD.W	A4,D4	CLR.W	D3	LOAD.B	D3,(A4)-1	; D3 <-- caractre dtruit	SUB.W	D4,(A2)+OTXNBC	JUMP',EQ KILL$	NEG.W	D4	LOAD.L	A3,#(A4)-1	DEC.W	D4SHIFT$:	LOAD.B	(A3+),(A4+)	; remne la fin du buffer	DECJ.W,NMO D4,SHIFT$KILL$:	DEC.W	(A5)+OTECUR	; recule le curseur	DEC.W	(A2)+OTXNBC	; utilise un caractre de moins	JUMP',NE END$	LOAD.L	A4,A2	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le texte	CLR.L	(A1)+OCEPTXEND$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1,D4,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; TXGETPCE >;=========/; Cherche le descripteur d'une cellule.; in	A1.L	^objet liste;	D1.L	coordonne de la cellule (y;x); out	A2.L	^cellule (OCE*);	D7.W	erreur; mod	D7.W, A2.LTXGETPCE:	PUSHM.L	D1,D2	LOAD.W	D7,#1	COMP.W	D1,(A1)+OOBNBX	JUMP',HS EXIT$	LOAD.L	D2,D1	SWAP.W	D2	COMP.W	D2,(A1)+OOBNBY	JUMP',HS EXIT$	MUL.WU	D2,(A1)+OOBNBX	ADD.W	D1,D2	MUL.WU	D1,#LCE	LOAD.L	A2,(A1)+OOBPCE	; A2 <-- ^table des cellules	ADD.L	A2,D1	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1,D2	TEST.W	D7		; retour EQ/NE	RET	.END