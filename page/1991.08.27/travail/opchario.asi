	.SBTTL	OPCHARIO.ASI;----------\\; CHARPREND >;==========/; Prend un fichier de pinceaux.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WCHARPREND:	PUSHM.L	D1,D2,D4,A2..A4	LOAD.L	A2,(A5)+OPTAB20$:	LOAD.W	D1,#DBOX_PREND	LOAD.W	D2,#2^BDBEXTEND!2^BDBSAV	LOAD.L	D3,#LBUNAME!2^BDBIOEXT1	LOAD.L	A3,#R16"TIOCHAR	LOAD.L	A4,#R16"TEXCHAR	PUSH.L	A5	LOAD.L	A5,#(A2)+OTACNAM ; A5 <-- ^nom	DBOX_	EXTEND		; demande le nom ...	POPM.L	A5	JUMP',NE 90$	COMP.W	D3,#F1	JUMP',NE 90$	LOAD.L	A3,#(A2)+OTACNAM ; A3 <-- ^nom	CALL	CHARFPREND	; lit un fichier .CPAGE	JUMP',EQ 90$	PUSH.W	D7	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	JUMP	20$90$:	POPM.L	D1,D2,D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; CHARSAUVE >;==========/; Sauve un fichier de pinceaux.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WCHARSAUVE:	PUSHM.L	D1,D2,D4,A2..A4	LOAD.L	A2,(A5)+OPTAB20$:	LOAD.W	D1,#DBOX_EXTRAIT	LOAD.W	D2,#2^BDBEXTEND!2^BDBSAV	LOAD.L	D3,#LBUNAME!2^BDBIOEXT1	LOAD.L	A3,#R16"TIOCHAR	LOAD.L	A4,#R16"TEXCHAR	PUSH.L	A5	LOAD.L	A5,#(A2)+OTACNAM ; A5 <-- ^nom	DBOX_	EXTEND		; demande le nom ...	POPM.L	A5	JUMP,NE 90$	COMP.W	D3,#F1	JUMP,NE 90$30$:	LOAD.L	A3,#(A2)+OTACNAM ; A3 <-- ^nom	CALL	CHARFSAUVE	; crit un fichier .CPAGE	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP',NE 50$		; non => 50$				; oui =>	LOAD.W	D1,#DBOX_DETRUIT	LOAD.W	D2,#2^BDBEXTEND!2^BDBSAV	LOAD.L	D3,#LBUNAME	LOAD.L	A3,#R16"TIOCHAR	DBOX_	EXTEND		; dtruit le nom ...	JUMP,NE 90$	COMP.W	D3,#F1	JUMP,NE 90$	LOAD.L	A3,#(A2)+OTACNAM ; A3 <-- ^nom	FOS	?DELETE	JUMP,EQ 30$50$:	LOAD.W	D3,#F1	TEST.W	D7	JUMP',EQ 90$	PUSH.W	D7	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	JUMP	20$90$:	POPM.L	D1,D2,D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; CHARFPREND >;===========/; Prend un fichier ".CPAGE".; in	A3.L	^nom du fichier; out	D7.W	erreur; mod	D7.WCHARFPREND:	PUSHM.L	D3,D4,D6,A4	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP',NE 90$	LOAD.L	A4,(A5)+OPTAB	; A4 <-- ^table des pinceaux	LOAD.L	D4,#LTACIO	FOS	?RDBYTE		; lit tous les pinceaux	PUSH.W	D7	FOS	?CLOSE	POP.W	D790$:	POPM.L	D3,D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; CHARFSAUVE >;===========/; Ecrit un fichier ".CPAGE".; in	A3.L	^nom du fichier; out	D7.W	erreur; mod	D7.WCHARFSAUVE:	PUSHM.L	D3,D4,D6,A4	LOAD.L	D3,#DEFATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE	JUMP',NE 90$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP',NE 90$	LOAD.L	A4,(A5)+OPTAB	; A4 <-- ^table des pinceaux	LOAD.L	D4,#LTACIO	FOS	?WRBYTE		; crit tous les pinceaux	JUMP',NE 80$	FOS	?CLOSE	JUMP'	90$80$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D790$:	POPM.L	D3,D4,D6,A4	TEST.W	D7		; retour EQ/NE	RETTEXCHAR:.ASCIZ	".CPAGE"TIOCHAR:	.ASCIZ	"PAGE"			; nom du logiciel	.ASCIZ	"Fliste de caractres"	; [M,F] nom des lments manipuls	.ASCIZ	""			; [M,F] nom du contenant	.B	0	.EVEN	.END