	.CHAP	OPFORMEDIT.ASI;	----------------------------------------;		(C) 1990 - Pierre Arnaud;	----------------------------------------;	Source de la partie "dition";	Date      Rv	Commentaire;	-------------------------------------------------------------------------------;	09/04/90  0.0	Dbut des travaux;	-------------------------------------------------------------------------------;------------\\;  EDITEVENT  >;============/; Edition de l'vnement.; in	A4.32	^instance;	A5.32	^var.;	D4.32	position de la souris;	D3.32	touche presse; out	D7.16; mod	D7.16EDITEVENT:	PUSHM.32 D2|D3|A3	CLR.16	D7	SWAP.16	D3	TEST.8	D3	JUMP,NE	SUPERSH$	SR.16	#8,D3	COMP.8	#CR,D3	JUMP,EQ	RETURN$	COMP.8	#EOP,D3	JUMP,EQ	SRETURN$	COMP.8	#DELETE,D3	JUMP,EQ	DEL$	COMP.8	#DEL,D3	JUMP,EQ	DEL$	COMP.8	#BS,D3	JUMP,EQ	BS$	COMP.8	#15,D3	JUMP,LO	BIP$	COMP.8	#HELP,D3	JUMP,EQ	HELP$	COMP.8	#F4,D3	JUMP,EQ	R8^DEF$	COMP.8	#F7,D3	JUMP,EQ	R8^DBOX$	COMP.8	#F8,D3	JUMP,EQ	R8^DBOX$	COMP.8	#F9,D3	JUMP,EQ	R8^DBOX$	TEST.32	D3:#7	JUMP,BC	R8^CAR$	JUMP	BIP$HELP$:	CALL	AFHELP	JUMP	ERR$DEF$:	CALL	DBOXDEFABORT$:	CLR.16	D7	JUMP	ERR$DBOX$:	CALL	CHOIX	JUMP,NE	BIP$	JUMP	ERR$CAR$:	SWAP.16	D3;;	MOVE.8	{A4}+OOBFONT+1,D3	MOVE.8	#16,D3	SWAP.16	D3	CALL	TXTINSCAR	CLR.16	D7	JUMP	ERR$SUPERSH$:	COMP.8	#2'01111111,D3			; envoi de la souris ?	JUMP,EQ	MOUSE$	COMP.8	#2**BKILL,D3	JUMP,EQ	R8^KILL$	COMP.8	#2**BKILL+2**BCURSOR,D3	JUMP,EQ	R8^KILL$	COMP.8	#2**BCURSOR,D3	JUMP,EQ	R8^CURSOR$BIP$:	MOVE.16	#ERPBIP,D7	JUMP	ERR$KILL$:	SR.16	#8,D3				; touche (KILL) + ...	LIB	?MINMAJ	COMP.8	#"F",D3	JUMP,EQ	R8^BS$	COMP.8	#"D",D3	JUMP,EQ	R8^DEL$	JUMP	R8^BIP$CURSOR$:	SR.16	#8,D3	LIB	?MINMAJ	COMP.8	#"D",D3	JUMP,EQ	R8^BACK1$	COMP.8	#"F",D3	JUMP,EQ	R8^FORW1$	COMP.8	#"C",D3	JUMP,EQ	RETURN$	COMP.8	#"R",D3	JUMP,EQ	SRETURN$	JUMP	R8^BIP$BACK1$:	CALL	TXTBACKONE	JUMP	ERR$FORW1$:	CALL	TXTFORWONE	JUMP	ERR$DEL$:	CALL	TXTBACKONE			; recule d'un puis efface	JUMP,NE	BIP$	MOVE.32	{A4}+OOBPTXT,A3	ADD.32	{A4}+OOBPOC,A3	COMP.16	#CR,{A3}	JUMP,EQ	R8^DEL$				; un <CR>, alors on le saute en arrireBS$:	MOVE.32	{A4}+OOBPTXT,A3	ADD.32	{A4}+OOBPOC,A3	COMP.16	#CR,{A3}	JUMP,NE	R8^BS1$	CALL	TXTFORWONE			; saute le <CR>	JUMP,NE	BIP$	JUMP	R8^BS$BS1$:	CALL	TXTDELONE			; efface un caractre	JUMP	ERR$RETURN$:	MOVE.32	{A4}+OOBPTXT,A3	ADD.32	{A4}+OOBPOC,A3	COMP.16	#CR,{A3}	JUMP,EQ	R8^FORW1$	RETDO$:	MOVE.32	{A4}+OOBPTXT,A3	ADD.32	{A4}+OOBPOC,A3	TEST.16	{A3}	JUMP,EQ	BIP$				; fin de formule => bip	COMP.16	#CR,{A3}			; sur fin de pav ?	JUMP,EQ	R8^ERR$				; oui => termin	COMP.8	#tfSYMBBEGIN,{A3}		; sur dbut de formule => saute df.	JUMP,EQ	FORW1$	CALL	TXTFORWONE	JUMP	R8^RETDO$SRETURN$:	MOVE.32	{A4}+OOBPTXT,A3	ADD.32	{A4}+OOBPOC,A3	TEST.32	{A4}+OOBPOC	JUMP,EQ	R8^SRETDO$	COMP.16	#CR,{A3}-2			; sur un return ?	JUMP,EQ	BACK1$				; oui => recule que de 1SRETDO$:	MOVE.32	{A4}+OOBPTXT,A3	ADD.32	{A4}+OOBPOC,A3	TEST.32	{A4}+OOBPOC	JUMP,EQ	BIP$				; dbut de formule => bip	COMP.16	#CR,{A3}-2			; sur fin de pav ?	JUMP,EQ	R8^ERR$				; oui => ok !	COMP.8	#tfSYMBEND,{A3}-2		; sur fin de df de formule ?	JUMP,EQ	BACK1$				; oui => recule	CALL	TXTBACKONE	JUMP	R8^SRETDO$MOUSE$:	CALL	GETMOUSECURSERR$:	POPM.32	D2|D3|A3	TEST.16	D7	RET;	Effectue un choixCHOIX:	PUSHM.32 D2|D3|A3	MOVE.32	#R16^CHOIX$,A3	CALL	DBOXCHOIX	JUMP,NE	ERR$	COMP.16	#F1,D3	JUMP,NE	ERR$	CALL	SYMBCHOIXERR$:	POPM.32	D2|D3|A3	TEST.16	D7	RETCHOIX$:	.ASCIZE	"Choix du symbole mathmatique  insrer :";------------\\;  EDITMMENU  >;============/; Agit dans le texte selon le mmenu traditionnel; in	A1.32	^objet formule;	A5.32	^variables; out	D7.16	erreur; mod	D7.16EDITMMENU:	PUSHM.32 D0..D5|A0..A4	MOVE.32	{A5}+OTXZO1,D4	MOVE.32	{A5}+OTXZO2,D5	COMP.32	D5,D4	JUMP,EQ	BIP$	MOVE.32	{A5}+OCANRES,A2	MOVE.32	#RtypMISC,D0	MOVE.32	#RMIICOTABLE,D1	MOVE.32	#2**BRSGETPOINTER+2**BRSGETnoHAND,D2	RES_	GET	JUMP,NE	BIP$	MOVE.32	A4,A3				; A3 <-- ^table de conversion	MOVE.32	A5,A0ILOOP$:	MOVE.16	{A3+},D3			; D3 <-- code de l'icne interne	JUMP,EQ	R8^IEND$	CALL	XopGETICONE			; A4 <-- ^matrice	MOVE.16	{A3+},D3			; D3 <-- code de l'icne PAGE	MOVE.32	#DR_PUTICO,D7	PAGE_	DRAW				; IPP21 <-- matrice de l'icne	JUMP	ILOOP$IEND$:	MOVE.32	A5,A4				; A4 <-- ^variables du programme	MOVE.32	#2**BRSDEFPROGVAR,D2	RES_	DEF				; dfinit les variables du programme	MOVE.32	#{A5}+OCHARMMENU,A3		; A3 <-- ^buffer pour y mettre la liste des fontes	MOVE.32	#R16^MATH$,A4COPYS$:	MOVE.8	{A4+},{A3+}			; c'est bon, le menu de car. est prt..	JUMP,NE	R8^COPYS$	MOVE.8	#-1,{A3+}	MOVE.32	#0,A4				; A4 <-- caractre par dfaut	MOVE.16	#IDENTCHAR,D0	MOVE.16	#opDGETMENU,D1	PAGE_	OBJCALL				; A3 <-- ^aprs menu fourni	MOVE.32	D3,{A5}+OMMMEV+1*LMM+OMMINA	; D3 <-- case grises	CLR.8	{A3}	MOVE.32	#RtypMMENUS,D0	MOVE.32	#RMENUMEV,D1	MOVE.32	#2**BRSGETCOPY+2**BRSGETnoHAND,D2	RES_	GET				; A4 <-- ^menu complet construit	JUMP,NE	BIP$	MOVE.32	A4,A3				; A3 <-- ^buffer avec m-menu	MOVE.32	#{A5}+OMMMEV,A4			; A4 <-- ^paramtres	CLR.32	{A4}+(LMM*0)+OMMINA	TSET.8	{A4}+(LMM*0)+OMMINA+3:#2	; grise la case "dplace"	TSET.8	{A4}+(LMM*0)+OMMINA+3:#3	; grise la case "duplique"	MOVE.32	#MI_MMENUS,D7	PAGE_	MISC				; attend choix selon mmenus ...	PUSHM.32 D7|A4	MOVE.32	A3,A4	MOVE.32	#MTYPCP,D1	GESMEM	?GIVMEM				; libre mmoire pour construire mmenu	POPM.32	D7|A4	TEST.16	D7	JUMP,NE	BIP$	MOVE.16	{A4}+(LMM*0)+OMMSEL,D2	JUMP,EQ	EXIT$	COMP.16	#1,D2	JUMP,EQ	R8^DETRUIT$	COMP.16	#4,D2	JUMP,EQ	R8^FONTE$	JUMP	EXIT$;	DtruitDETRUIT$:	MOVE.32	A1,A4	MOVE.32	{A5}+OTXZO1,{A4}+OOBPOC		; nouvelle position du curseur	MOVE.32	{A5}+OTXZO2,D4	SUB.32	{A5}+OTXZO1,D4	CLR.16	{A4}+OOBINIPG			; refaire les calculs des poignes	CALL	TXTDEL				; supprime cette partie	JUMP	EXIT$;	Modifie la fonteFONTE$:	MOVE.16	{A4}+(LMM*1)+OMMSEL,D2		; fonte  utiliser	JUMP,EQ	R8^FONTSYMB$	DEC.16	D2	JUMP	R8^OKFONTE$FONTSYMB$:	MOVE.16	#16,D2OKFONTE$:	MOVE.32	A1,A4	MOVE.32	{A4}+OOBPTXT,A3	ADD.32	{A5}+OTXZO1,A3			; A3 <-- ^dbut de la zone	MOVE.32	{A5}+OTXZO2,D1	SUB.32	{A5}+OTXZO1,D1	JUMP,EQ	EXIT$	CLR.16	{A4}+OOBINIPG			; il faudra refaire les calculs des poignesDOFONTE$:	COMP.8	#tfSYMBBEGIN,{A3}	JUMP,EQ	R8^FONTSY$	COMP.16	#CR,{A3}	JUMP,EQ	R8^NEXT$	TEST.8	{A3}+1:#7			; symbole mathmatique ?	JUMP,BS	R8^NEXT$			; oui => ne fait rien	MOVE.8	D2,{A3}				; change la fonte utiliseNEXT$:	ADD.A16	#2,A3	SUB.16	#2,D1	JUMP,GT	R8^DOFONTE$	MOVE.16	#SPACE,D3	CALL	TXTINSCAR	CALL	TXTBACKONE	CALL	TXTDELONE	JUMP	EXIT$FONTSY$:	ADD.A16	#LTSY,A3	SUB.16	#LTSY,D1	JUMP,GT	R8^DOFONTE$	JUMP	EXIT$BIP$:	MOVE.32	#BIPLIT,D3	LIB	?BEEPEXIT$:	POPM.32	D0..D5|A0..A4	TEST.16	D7				; retour EQ/NE	RETMATH$:	.ASCIZE	" Symboles ";------------\\;  DBOXCHOIX  >;============/; Dialogue du choix.; in	A3.32	^texte  afficher en haut  gauche; out	D2.16	caractre choisi;	D3.16	dernire touche;	D7.16	erreur; mod	D2.16, D3.16, D7.16DBOXCHOIX:	PUSHM.32 D0|D1|D4|D5|A0..A4	MOVE.32	{A5}+OPDDIS,A0			; A0 <-- ^descripteur fentre	MOVE.32	#R16^TDBOX_INSCAR,A2	MOVE.16	#2**BDBSAV,D2	CLR.32	D4	MOVE.16	#DB_OPEN,D7	PAGE_	DBOX				; ouvre la DBOX	JUMP,NE	EXIT$	MOVE.32	#0,D2	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTEXT				; affiche le texte en haut  gauche..	MOVE.32	{A5}+OIPPT,A4	MOVE.32	{A5}+OIPDIM,D4	MOVE.32	#16'10000*IPWDOY+IPWDOX,D3	MOVE.16	#DB_IMASHOW,D7	PAGE_	DBOX				; affiche l'image de la palette	MOVE.16	#-1,D0	MOVE.16	D0,D2	CALL	IPINV				; allume le caractre actuelLOOP$:	DBOX_	EDIT				; attend action ...	MOVE.32	#R16^TKEY_INSCAR,A1	MOVE.16	#2**BDBCCMM.OR.2**BDBCCFF,D1	DBOX_	CALLC	COMP.16	#KEYMGR,D3			; bouton souris relach ?	JUMP,EQ	LOOP$				; oui => LOOP$	COMP.16	#KEYMGP,D3	JUMP,EQ	R8^CLIC$	COMP.16	#F1,D3	JUMP,EQ	R8^OK$	COMP.16	#F0,D3	JUMP,EQ	R8^CANCEL$BIP$:	MOVE.8	#BIPLIT,D3	LIB	?BEEP				; p'tit bruit	JUMP	LOOP$CLIC$:	CALL	IPMOVE				; slectionne un caractre ...	JUMP,NE	LOOP$	MOVE.16	#F1,D3OK$:	COMP.16	#-1,D0	JUMP,EQ	BIP$	MOVE.16	D0,D2CANCEL$:					; ANNULE =>	MOVE.16	#DB_CLOSE,D7	PAGE_	DBOX				; ferme la DBOXEXIT$:	POPM.32	D0|D1|D4|D5|A0..A4	TEST.16	D7				; retour EQ/NE	RET;----------\\;  DBOXDEF  >;==========/; Dialogue pour une dfinition.; in	A4.32	^instance; out	D7.16	erreur; mod	D7.16DBOXDEF:	PUSHM.32 D0|D1|D2|D3|D4|D5|A0..A4	MOVE.32	A4,A1				; A1 <-- ^instance	MOVE.32	{A5}+OPDDIS,A0			; A0 <-- ^descripteur fentre	MOVE.32	#R16^TDBOX$,A2	MOVE.32	#DB_MEMPT,D7	PAGE_	DBOX				; mmorise le ^table propre  PAGE	MOVE.16	{A1}+OOBSIZE,{A5}+ODBP1		; premier paramtre	MOVE.16	{A1}+OOBRED,{A5}+ODBP2	CLR.32	D4	MOVE.16	{A1}+OOBMSYMB,D2	TSET.32	D4:D2				; bouton 0/1	MOVE.32	#R16^TDBOX_DEF,A2	MOVE.16	#2**BDBSAV,D2	MOVE.32	#DB_OPEN,D7	PAGE_	DBOX				; ouvre la DBOX	JUMP,NE	EXIT$	CLR.16	D2AFF$:	MOVE.32	#DB_GET,D7	PAGE_	DBOX				; A3/A4 <-- ^dbut/fin paramtre	MOVE.32	#DB_AFF,D7	PAGE_	DBOX				; affiche le paramtre	INC.16	D2	COMP.16	#2,D2	JUMP,LO	R8^AFF$	CLR.16	D2NLINE$:	MOVE.16	#DB_GET,D7	PAGE_	DBOX				; A3/A4 <-- ^dbut/fin paramtre	MOVE.16	#DB_MEDIT,D7	PAGE_	DBOXLOOP$:	MOVE.32	#MI_SCMO,D7	PAGE_	MISC	DBOX_	EDIT				; attend action ...	MOVE.32	#DB_ZEROCR,D7	PAGE_	DBOX				; remplace <CR> par <0>	PUSH.32	A1	MOVE.32	#R16^TKEY_INSCAR,A1	MOVE.16	#2**BDBCCMM.OR.2**BDBCCFF,D1	DBOX_	CALLC	POP.32	A1	COMP.16	#KEYMGR,D3			; bouton souris relach ?	JUMP,EQ	R8^LOOP$			; oui => LOOP$	COMP.16	#KEYMGP,D3	JUMP,EQ	R8^CLIC$	COMP.16	#F1,D3	JUMP,EQ	OK$	COMP.16	#F0,D3	JUMP,EQ	CANCEL$	COMP.16	#CR,D3	JUMP,EQ	R8^RETURN$	COMP.16	#UNDO,D3	JUMP,EQ	R8^UNDO$	MOVE.16	D3,D1	AND.16	#16'FF00,D1	COMP.16	#KEYDBOX,D1	JUMP,EQ	R8^KEYDB$BIP$:	MOVE.32	#BIPLIT,D3	LIB	?BEEP				; p'tit bruit	JUMP	LOOP$UNDO$:	MOVE.32	A3,A4	CLR.8	{A4}	JUMP	LOOP$RETURN$:						; RETURN =>	MOVE.16	#DB_PUT,D7	PAGE_	DBOX	JUMP,NE	BIP$	INC.16	D2					; D2 <-- paramtre suivant	COMP.16	#2,D2	JUMP,LO	NLINE$	CLR.16	D2	JUMP	NLINE$CLIC$:	MOVE.32	#DB_CLIC,D7	PAGE_	DBOX	JUMP,NE	R8^BIP$	JUMP	NLINE$KEYDB$:	MOVE.32	#DB_PUT,D7	PAGE_	DBOX	JUMP,NE	BIP$	COMP.8	#100,D3	JUMP,HS	R8^CLINE$	JUMP	LOOP$CLINE$:	CLR.16	D2	MOVE.8	D3,D2	SUB.16	#100,D2	JUMP	NLINE$OK$:	MOVE.32	#DB_PUT,D7	PAGE_	DBOX	MOVE.16	{A5}+ODBP1,{A1}+OOBSIZE	MOVE.16	{A5}+ODBP2,{A1}+OOBRED	MOVE.16	#0,{A1}+OOBMSYMB	TEST.32	D4:#0	JUMP,BS	R8^REGC$	MOVE.16	#1,{A1}+OOBMSYMB	REGC$:	MOVE.32	A1,A4	CALL	INITGENCCANCEL$:					; ANNULE =>	MOVE.16	#DB_CLOSE,D7	PAGE_	DBOX				; ferme la DBOXEXIT$:	POPM.32	D0|D1|D2|D3|D4|D5|A0..A4	TEST.16	D7				; retour EQ/NE	RETTDBOX$:	.16	ODBP1,DBTYPU,0,2000*FACMMPT,05*FACMMPT,2**BDBGCLABEL+100,0,8+2	.16	ODBP2,DBTYPN,0,100,5,2**BDBGCLABEL+101,1,4+2	.16	-1;--------\\; IPMOVE  >;--------/; Change de caractre slectionn.; in	D0.16	caractre slectionn; out	D0.16	nouveau caractre;	D7.16	0 => double clic; mod	D0.32, D7.16IPMOVE:	PUSHM.32 D1..D4	MOVE.16	D0,D1	JUMP	R8^CPOS$CLOOP$:	LIB	?GETKEY				; attend souris ...	COMP.16	#KEYMPO,D3	JUMP,NE	R8^CEND$CPOS$:	LIB	?IFMOUSE			; D4 <-- position de la souris	JUMP,NE	CLOOP$	SUB.16	{A0}+ODFFX,D4	JUMP,LO	CLOOP$	SWAP.32	D4	SUB.16	{A0}+ODFFY,D4	JUMP,LO	CLOOP$	SWAP.32	D4	CALL	IPDET				; D2 <-- caractre o est la souris	COMP.16	D0,D2				; toujours dans le mme ?	JUMP,EQ	CLOOP$				; oui => CLOOP$						; non =>	EX.32	D2,D0	CALL	IPINV				; efface l'ancien	MOVE.16	D0,D2	CALL	IPINV				; allume le nouveau	JUMP	CLOOP$CEND$:	MOVE.16	#1,D7				; D7 <-- simple clic	COMP.16	D1,D0	JUMP,NE	R8^EXIT$	COMP.16	#-1,D0	JUMP,EQ	R8^EXIT$	CLR.16	D7				; D7 <-- double clicEXIT$:	POPM.32	D1..D4	TEST.16	D7				; retour EQ/NE	RET;--------\\; IPDET   >;--------/; Dtecte dans quel caractre est la souris.; in	D4.32	position de la souris (y;x); out	D2.16	caractre (0..127,-1);	D7.16	erreur; mod	D2.32, D7.16IPDET:	PUSHM.32 D0|D1|D3|D4	MOVE.16	D4,D0	MOVE.32	D4,D1	SWAP.32	D1	CLR.16	D7	CLR.16	D2L20$:	CALL	IPPOS					; D3/D4 <-- position/dimensions	ADD.16	#IPWDOX,D3	SWAP.32	D3	ADD.16	#IPWDOY,D3	SWAP.32	D3	COMP.16	D3,D0	JUMP,LO	R8^L40$	ADD.16	D4,D3	COMP.16	D3,D0	JUMP,HS	R8^L40$	SWAP.32	D3	SWAP.32	D4	COMP.16	D3,D1	JUMP,LO	R8^L40$	ADD.16	D4,D3	COMP.16	D3,D1	JUMP,LO	R8^L90$L40$:	INC.16	D2	COMP.16	#128,D2	JUMP,LO	L20$	MOVE.16	#-1,D2	MOVE.16	#1,D7L90$:	POPM.32	D0|D1|D3|D4	TEST.16	D7					; retour EQ/NE	RET;--------\\; IPINV   >;--------/; Inverse un caractre.; in	D2.16	caractre (0..127,-1); out	-; mod	D7.16IPINV:	PUSHM.32 D2..D4	COMP.16	#-1,D2	JUMP,EQ	R8^L90$	MOVE.32	#-1,D3	MOVE.32	D3,D4	LIB	?DRMDEF	CALL	IPPOS					; D3/D4 <-- position/dimensions	ADD.16	#IPWDOX+1,D3	SWAP.32	D3	ADD.16	#IPWDOY+1,D3	SWAP.32	D3	DEC.16	D4	SWAP.32	D4	DEC.16	D4	SWAP.32	D4	MOVE.16	#INVDOT,D2	LIB	?DRTRAMEL90$:	POPM.32	D2..D4	RET;--------\\; IPPOS   >;--------/; Donne la position et les dimensions d'un caractre.; in	D2.16	caractre (0..127); out	D3.32	position (y;x);	D4.32	dimensions (dy;dx); mod	D3.32, D4.32, D7.16IPPOS:	PUSHM.32 D1|D2	MOVE.32	#16'10000*IPPOSY+(IPPOSX+((IPDIMX*(16+1)/2))),D3	SUB.16	#64,D2	JUMP,NC	R8^L20$	ADD.16	#64,D2	MOVE.32	#16'10000*IPPOSY+IPPOSX,D3L20$:	MOVE.16	D2,D1	AND.16	#2'111,D1	MUL.16	#IPDIMX,D1	ADD.16	D1,D3	MOVE.16	D2,D1	SR.16	#3,D1	MUL.16	#IPDIMY,D1	SWAP.32	D3	ADD.16	D1,D3	SWAP.32	D3	MOVE.32	#16'10000*IPDIMY+IPDIMX,D4	POPM.32	D1|D2	TEST.16	D7					; retour EQ/NE	RETTDBOX_DEF:	.16	L10$-TDBOX_DEF	.16	MENUOK-TDBOX_DEF	.16	0,0L10$:	.IF FALSE	.8	ODBTEXT	.ASCIZ	"Nom complet du gnrateur :  MathSymbols"	.8	ODBCR	.8	ODBTEXT	.ASCIZ	"Nom court du gnrateur :    IMP00"	.8	ODBCR,ODBCR	.8	ODBTEXT	.ASCIZ	"Auteur du gnrateur :       Daniel ROUX"	.8	ODBCR,ODBCR	.8	ODBTEXT	.ASCIZ	"Taille de rfrence :       "	.8	ODBLABEL,100	.8	ODBCLINE,(8+2).OR.2**7,KEYDBOX/16'100,100,TDBNORM	.8	ODBCR,ODBCR	.8	ODBTEXT	.ASCIZ	"Facteur de rduction :      "	.8	ODBLABEL,101	.8	ODBCLINE,(8+2).OR.2**7,KEYDBOX/16'100,101,TDBNORM	.8	ODBTEXT	.ASCIZ	"  %"	.8	ODBCR,ODBCR,ODBCR2	.ELSE	.8	ODBTEXT	.ASCIZ	"Taille des symboles "	.8	ODBLABEL,100	.8	ODBCLINE,(8+2).OR.2**7,KEYDBOX/16'100,100,TDBNORM	.8	ODBCR,ODBCR	.8	ODBTABX,30	.8	ODBLCIRCLE,0	.ASCIZ	" SwissSymbols"	.8	ODBCR2	.8	ODBTEXT	.ASCIZ	"Choix du style des symboles "	.8	ODBCR2	.8	ODBTABX,30	.8	ODBLCIRCLE,1	.ASCIZ	" TimesSymbols"	.8	ODBCR	.8	ODBCR,ODBCR2	.8	ODBTEXT	.ASCIZ	"Rduction  "	.8	ODBLABEL,101	.8	ODBCLINE,(4+2).OR.2**7,KEYDBOX/16'100,101,TDBNORM	.8	ODBTEXT	.ASCIZ	"  % pour les indices."	.8	ODBCR,ODBCR,ODBCR2	.ENDIF	.8	ODBTEXT	.ASCII	"FORMULE "	.8	PAGEREV+"0",".",PAGEVERS+"0",PAGEPROV	.ASCIZ	" -- (C) 1990, P.ARNAUD et EPSITEC-system SA  "	.8	ODBCR,ODBCR,ODBCR	.8	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.8	ODBTEXT	.ASCIZ	"   "	.8	ODBBOX,0,END,TDBNORM	.ASCIZ	"  ANNULE  "	.8	0	.EVENTDBOX_INSCAR:	.16	L10$-TDBOX_INSCAR	.16	MENUOK-TDBOX_INSCAR	.16	0,0L10$:	.8	ODBTEXT	.ASCIZ	" "	.8	ODBTABX,69	.8	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.8	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.8	ODBCR,ODBCR,ODBCR,ODBCR	.8	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.8	ODBTEXT	.ASCIZ	"   "	.8	ODBBOX,0,END,TDBNORM	.ASCIZ	"  ANNULE  "	.8	0MENUOK:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_INSCAR:	.16	F1,F2,F3,0,DOKF1-TKEY_INSCAR	.16	F0,F13,F14,F15,END,0,DOKF0-TKEY_INSCAR	.16	KEYMGP,KEYMMP,KEYMDP,0,DOKMGP-TKEY_INSCAR	.16	KEYMGR,KEYMMR,KEYMDR,0,DOKMGR-TKEY_INSCAR	.16	CR,ENTER,0,DOKCR-TKEY_INSCAR	.16	UNDO,CLEAR,0,DOKUND-TKEY_INSCAR	.16	0DOKF1:	MOVE.16	#F1,D3	RETDOKF0:	MOVE.16	#F0,D3	RETDOKMGP:	MOVE.16	#KEYMGP,D3	RETDOKMGR:	MOVE.16	#KEYMGR,D3	RETDOKCR:	MOVE.16	#CR,D3	RETDOKUND:	MOVE.16	#UNDO,D3	RET;------------\\;  TXTINSCAR  >;============/; Insre un caractre  la position du curseur.; in	A4.32	^instance;	D3.16	caractre  insrer; out	D7.16	ok/erreur; mod	D7.16TXTINSCAR:	PUSHM.32 D4|A0|A3	MOVE.32	A5,A0	MOVE.32	#2,D4	CALL	TXTINSFREE			; insre un peu de place	MOVE.32	{A4}+OOBPTXT,A3			; ^buffer	ADD.32	{A4}+OOBPOC,A3			; + position curseur	MOVE.16	D3,{A3}	ADD.32	#2,{A4}+OOBPOC			; incrmente la position du curseur	CLR.16	{A4}+OOBINIPGERR$:	POPM.32	D4|A0|A3	TEST.16	D7	RET;-------------\\;  TXTFORWONE  >;=============/; Avance d'un caractre (si possible); in	A4.32	^instance; out	D7.16	erreur; mod	D7.16TXTFORWONE:	PUSHM.32 D3|A3	MOVE.16	#ERPBIP,D7	MOVE.32	{A4}+OOBTXTUSE,D3	SUB.32	{A4}+OOBPOC,D3	COMP.32	#2,D3	JUMP,LE	R8^ERR$	MOVE.32	{A4}+OOBPTXT,A3	ADD.32	{A4}+OOBPOC,A3			; ^lment  sauter	COMP.8	#tfSYMBBEGIN,{A3}		; dbut de symbole ?	JUMP,NE	R8^OK$				; non => ok !	ADD.32	#LTSY-2,{A4}+OOBPOC		; saute le symboleOK$:	ADD.32	#2,{A4}+OOBPOC	CLR.16	D7ERR$:	POPM.32	D3|A3	TEST.16	D7	RET;-------------\\;  TXTBACKONE  >;=============/; Recule d'un caractre (si possible); in	A4.32	^instance; out	D7.16	erreur; mod	D7.16TXTBACKONE:	PUSHM.32 A3	MOVE.16	#ERPBIP,D7	TEST.32	{A4}+OOBPOC	JUMP,EQ	R8^ERR$	MOVE.32	{A4}+OOBPTXT,A3	ADD.32	{A4}+OOBPOC,A3			; ^lment  sauter en arrire	COMP.8	#tfSYMBEND,{A3}-2		; fin de symbole ?	JUMP,NE	R8^OK$				; non => ok !	SUB.32	#LTSY-2,{A4}+OOBPOC		; saute le symbole en marche arrireOK$:	SUB.32	#2,{A4}+OOBPOC	CLR.16	D7ERR$:	POPM.32	A3	TEST.16	D7	RET;------------\\;  TXTDELONE  >;============/; Dtruit un lment (et un seul); in	A4.32	^instance; out	-; mod	D7.16TXTDELONE:	PUSHM.32 D4|A3	CLR.16	D7	MOVE.32	{A4}+OOBPTXT,A3	ADD.32	{A4}+OOBPOC,A3	COMP.16	#CR,{A3}			; <CR> ?	JUMP,EQ	R8^ERR$				; oui => rien !	COMP.8	#tfSYMBBEGIN,{A3}		; dbut de symbole ?	JUMP,NE	R8^OK$				; non => ok !	MOVE.32	#LTSY,D4			; dtruit le symbole	JUMP	R8^DEL$OK$:	MOVE.32	#2,D4DEL$:	CALL	TXTDEL	CLR.16	{A4}+OOBINIPGERR$:	POPM.32	D4|A3	TEST.16	D7	RET;---------\\;  TXTDEL  >;=========/; Supprime une tranche aprs le curseur; in	A4.32	^instance;	D4.32	taille  supprimer; out	D7.16; mod	D7.16TXTDEL:	PUSHM.32 D3|A0|A1|A2	CLR.16	D7	MOVE.32	A5,A0	CLR.32	{A4}+OOBH1	MOVE.32	{A4}+OOBPOC,D3	ADD.32	D4,D3	COMP.32	{A4}+OOBTXTUSE,D3	JUMP,LT	R8^OK$	MOVE.32	{A4}+OOBPOC,{A4}+OOBTXTUSE	; nouvelle taille = position curseur	ADD.32	#2,{A4}+OOBTXTUSE		; + 2 (ne pas oublier le terminateur)	MOVE.32	{A4}+OOBPTXT,A1	MOVE.32	{A4}+OOBTXTUSE,D3	CLR.16	{A1}+32^{D3}	JUMP	R8^ERR$OK$:	MOVE.32	{A4}+OOBPOC,D3	MOVE.32	{A4}+OOBPTXT,A1	ADD.32	D3,A1				; A1 <- ^zone de rception	MOVE.32	#{A1}+32^{D4},A2		; A2 <- ^zone source	ADD.32	D4,D3				; on en perd une partie	NEG.32	D3	ADD.32	{A4}+OOBTXTUSE,D3		; taille  dplacer	SR.16	#1,D3	DEC.16	D3DO$:	MOVE.16	{A2+},{A1+}	DJ.16,NMO D3,DO$	SUB.32	D4,{A4}+OOBTXTUSE		; nouvelle tailleERR$:	POPM.32	D3|A0|A1|A2	TEST.16	D7	RET;-------------\\;  TXTINSFREE  >;=============/; Insre de la place libre dans le texte afin de remplir cet espace; in	A4.32	^instance;	D4.32	taille  rserver (paire et < 512); out	D7.16; mod	D7.16TXTINSFREE:	PUSHM.32 D3|A0|A1|A2	CLR.32	{A4}+OOBH1			; force le recalcul de la taille...	MOVE.32	A5,A0	MOVE.32	{A4}+OOBTXTSIZE,D0	SUB.32	{A4}+OOBTXTUSE,D0		; taille disponible	COMP.16	D0,D4				; assez de place ?	JUMP,LT	R8^OK$				; oui => c'est bon	CALL	FORTXTEXTEND			; tend !OK$:	MOVE.32	{A4}+OOBPOC,D3			; position du curseur	MOVE.32	{A4}+OOBPTXT,A1	ADD.32	{A4}+OOBTXTUSE,A1		; A1 <- ^fin du buffer	MOVE.32	#{A1}+32^{D4},A2		; A2 <- ^fin du buffer + dcalage  faire	NEG.32	D3	ADD.32	{A4}+OOBTXTUSE,D3		; D3 <- taille du dcalage	SR.16	#1,D3	JUMP,EQ	R8^END$	DEC.16	D3DO$:	MOVE.16	{-A1},{-A2}			; dcale vers la fin	DJ.16,NMO D3,DO$END$:	ADD.32	D4,{A4}+OOBTXTUSE		; nouvelle tailleERR$:	POPM.32	D3|A0|A1|A2	TEST.16	D7	RET	.END