	.SBTTL	OPARRDBOX.ASI;--------\\; XopDGET >;========/; Donne le numro du pinceau slectionn.; in	A0.L	canal;	A4.L	^table des flches/nil si par dfaut; out	D3.W	flche slectionne;	D7.W	erreur; mod	D3.L, D7.WXopDGET:	PUSH.L	A4	COMP.L	A4,#0		; objet par dfaut ?	JUMP',NE NODEF$		; non => NODEF$	LOAD.L	A4,(A0)+OPDEF	; A4 <-- ^objet flche par dfautNODEF$:	LOAD.W	D3,(A4)+OTAFSEL	; D3 <-- flche slectionne	POP.L	A4	CLR.W	D7		; retour EQ	RET;--------\\; XopDPUT >;========/; Spcifie le numro du pinceau.; in	A0.L	canal;	A4.L	^table des flches/nil si par dfaut;	D3.W	flche  slectionner; out	D7.W	erreur; mod	D7.WXopDPUT:	PUSH.L	A4	COMP.L	A4,#0		; objet par dfaut ?	JUMP',NE NODEF$		; non => NODEF$	LOAD.L	A4,(A0)+OPDEF	; A4 <-- ^objet flche par dfautNODEF$:	LOAD.W	(A4)+OTAFSEL,D3	; slectionne une flche	POP.L	A4	CLR.W	D7		; retour EQ	RET;------------\\; XopDTSELECT >;============/; Choisi et/ou modifie une flche temporaire  utiliser.; in	A0.L	canal;	A4.L	^table des flches/nil si par dfaut;	D2.W	flche  slectionner; out	D2.W	flche slectionne;	D3.L	dernire touche (F1/F0);	D4.W	nb de flches modifies;	D7.W	erreur; mod	D2.L, D3.L, D4.L, D7.WXopDTSELECT:	PUSH.L	A4	COMP.L	A4,#0		; objet par dfaut ?	JUMP',NE NODEF$		; non => NODEF$	LOAD.L	A4,(A0)+OPDEF	; A4 <-- ^objet flche par dfautNODEF$:	PUSH.W	(A4)+OTAFSEL	; stack <-- flche slectionne	LOAD.W	(A4)+OTAFSEL,D2	; OTAFSEL <-- flche slectionne temporairement	CALL	XopDSELECT	; choisi/modifie une flche ...	LOAD.W	D2,(A4)+OTAFSEL	; D2 <-- flche slectionne temporairement	POP.W	(A4)+OTAFSEL	; OTAFSEL <-- flche slectionne initialement	POP.L	A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; XopDSELECT >;===========/; Choisi et/ou modifie une flche  utiliser.; in	A0.L	canal;	A4.L	^table des flches/nil si par dfaut; out	D3.L	dernire touche (F1/F0);	D4.W	nb de flches modifies;	D7.W	erreur; mod	D3.L, D4.L, D7.WXopDSELECT:	PUSHM.L	D0..D2,D5,D6,A0..A5	LOAD.L	A5,A0		; A5 <-- ^variables globales	LOAD.L	A0,(A5)+OPDDIS	; A0 <-- ^descripteur fentre	COMP.L	A4,#0		; objet par dfaut ?	JUMP',NE NODEF$		; non => NODEF$	LOAD.L	A4,(A5)+OPDEF	; A4 <-- ^objet flche par dfautNODEF$:	LOAD.L	(A5)+OPTAB,A4	; OPTAB <-- ^table des flches	LOAD.W	D6,(A4)+OTAFSEL	; D6 <-- flche slectionne	LOAD.L	A2,#R16"TDBOX_FLE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	LOAD.W	D7,#DB_OPEN	PAGE_	DBOX		; ouvre la DBOX	JUMP,NE EXIT$	LOAD.W	D3,#IDENTARROW	LOAD.L	A4,#(A5)+OUSBUF	LOAD.W	D4,#NBRX*NBRY	LOAD.W	D7,#DF_GETULIST	PAGE_	DEF		; OUSBUF <-- flches utilises	CALL	DBPALGET	; cran <-- image mmorise	JUMP',EQ PALOK$	CALL	DBRDESCADRE	; dessine les cadres des rectangles	CLR.W	D0	LOAD.W	D1,#NBRX*NBRY	CALL	DBRDESFLES	; dessine toutes les flches	CALL	DBPALSAV	; buffer <-- image cranPALOK$:	CLR.W	D0	LOAD.W	D1,#NBRX*NBRY	CALL	DBRUSEFLES	; marque les utilises	LOAD.W	D0,D6	CALL	DBRINV		; inverse le rectangle slectionn	CLR.W	D0		; D0 <-- nb de flches modifiesLOOP$:	LOAD.W	D7,#MI_SCMO	PAGE_	MISC		; remet la souris	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_FLE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ USE$	COMP.W	D3,#F4	JUMP,EQ MODIF$	COMP.W	D3,#F7	JUMP,EQ PREND$	COMP.W	D3,#F9	JUMP,EQ SAUVE$	COMP.W	D3,#F0	JUMP,EQ END$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$CLIC$:	CALL	DBRSEL		; slectionne un nouveau rectangle	JUMP,NE BIP$	COMP.W	D3,#KEYMGP	JUMP,EQ USE$	COMP.W	D3,#KEYMMP	JUMP,EQ USE$	COMP.W	D3,#KEYMDP	JUMP,EQ USE$	JUMP	LOOP$MODIF$:	CALL	DBOXMODFLECHE	; modifie une flche ...	PUSH.W	D7	LOAD.L	A2,#R16"TDBOX_FLE	LOAD.W	D7,#DB_RSK	PAGE_	DBOX		; refait les soft-keys	POP.W	D7	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	PUSH.W	D0	LOAD.W	D0,D6	LOAD.W	D1,#1	CALL	DBRINV		; teint le rectangle slectionn	CALL	DBRDESFLES	; dessine la flche modifie	CALL	DBRUSEFLES	; marque l'utilise	CALL	DBPALUPD	; mj l'image cran si ncessaire	CALL	DBPALSAV	; buffer <-- image cran	CALL	DBRINV		; allume le rectangle slectionn	POP.W	D0	INC.W	D0		; D0 <-- une flche de plus modifie	JUMP	LOOP$PREND$:	CALL	FLEPREND	; prend les flches ...	PUSH.W	D7	LOAD.L	A2,#R16"TDBOX_FLE	LOAD.W	D7,#DB_RSK	PAGE_	DBOX		; refait les soft-keys	POP.W	D7	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	LOAD.W	D0,D6	CALL	DBRINV		; teint le rectangle slectionn	CLR.W	D0	LOAD.W	D1,#NBRX*NBRY	CALL	DBRDESFLES	; dessine toutes les flches	CALL	DBRUSEFLES	; marque les utilises	CALL	DBPALSAV	; buffer <-- image cran	LOAD.W	D0,D6	CALL	DBRINV		; allume le rectangle slectionn	LOAD.W	D0,#NBRX*NBRY	; D0 <-- toutes les flches modifies	JUMP	LOOP$SAUVE$:	CALL	FLESAUVE	; sauve les flches ...	PUSH.W	D7	LOAD.L	A2,#R16"TDBOX_FLE	LOAD.W	D7,#DB_RSK	PAGE_	DBOX		; refait les soft-keys	POP.W	D7	JUMP,NE BIP$	JUMP	LOOP$USE$:	LOAD.L	A4,(A5)+OPTAB	; A4 <-- ^table des flches	LOAD.W	(A4)+OTAFSEL,D6	; mj. la flche slectionneEND$:	LOAD.W	D4,D0		; D4 <-- nb de flches modifies	JUMP',EQ NOREG$	INC.L	(A5)+OREGEN	; change le numro de rgnrationNOREG$:	LOAD.W	D7,#DB_CLOSE	PAGE_	DBOX		; ferme la DBOXEXIT$:	POPM.L	D0..D2,D5,D6,A0..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX_FLE:	.W	10$-TDBOX_FLE	.W	20$-TDBOX_FLE	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Choix de la flche :"	.B	ODBCR,ODBCR2	.B	ODBLABEL,100	.B	ODBTEXT,0	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBTABX,60	.B	ODBLABEL,101	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" UTILISE "	.B	ODBBOX,0,F4,TDBMEV	.ASCIZ	" MODIFIE "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F7,TDBNORM	.ASCIZ	" PREND "	.B	ODBBOX,0,F9,TDBNORM	.ASCIZ	" SAUVE "	.B	ODBTABX,60-10	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Utilise"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Modifie"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Prend       Sauve"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_FLE:	.W	F1,F2,F3,0		DOKF1-TKEY_FLE	.W	F4,F5,F6,0		DOKF4-TKEY_FLE	.W	F7,0			DOKF7-TKEY_FLE	.W	F9,0			DOKF9-TKEY_FLE	.W	F0,F13,F14,F15,0	DOKF0-TKEY_FLE	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_FLE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_FLE	.W	0;--------------\\; DBOXMODFLECHE >;==============/; Modifie une flche.; in	D6.W	flche  modifier; out	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXMODFLECHE:	PUSHM.L	D0..D2,D4..D6,A1..A4	MUL.WU	D6,#LDFLE	LOAD.L	A4,(A5)+OPTAB	; A4 <-- ^table des flches	ADD.L	A4,D6	LOAD.W	(A5)+ODBPaX,(A4)+OFLEPa+2	LOAD.W	D4,(A4)+OFLEPa+0	SL.W	D4,#1	LOAD.W	(A5)+ODBPaY,D4	LOAD.W	(A5)+ODBPbX,(A4)+OFLEPb+2	LOAD.W	(A5)+ODBPbY,(A4)+OFLEPb+0	LOAD.W	(A5)+ODBPe,(A4)+OFLEPe	LOAD.L	D4,(A4)+OFLEFA	; D4 <-- fanions	JUMP',NE DEF$	LOAD.L	D4,#2^BFLEi1!2^BFLEr2DEF$:	LOAD.L	A2,#R16"TDBOX$	LOAD.W	D7,#DB_MEMPT	PAGE_	DBOX		; mj ^table dbox	LOAD.L	A2,#R16"DBMTTESTC	LOAD.W	D7,#DB_MEMAFC	PAGE_	DBOX		; mj ^routine d'affichage	LOAD.L	A2,#R16"TDBOX_MODFLE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.W	D7,#DB_OPEN	PAGE_	DBOX		; ouvre la DBOX	JUMP,NE EXIT$	PUSH.L	D4	LOAD.W	D2,#2^BDBGCLABEL!201	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	LOAD.W	D2,#2^BDBGCLABEL!200	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	LOAD.L	D4,D3	CLR.W	D4	LOAD.W	D3,(A0)+ODFCX	MUL.WU	D3,#29	LOAD.W	D2,#SETDOT	LIB	?DRSEG	LOAD.W	D3,(A0)+ODFCX	MUL.WU	D3,#54;	LOAD.W	D2,#SETDOT	LIB	?DRSEG	LOAD.L	A4,(A5)+OI1PT	LOAD.L	D4,(A5)+OI1DIM	LOAD.L	D3,#H'10000*30+246	LOAD.W	D7,#DB_IMASHOW	PAGE_	DBOX		; affiche l'image "A1"	POP.L	D4	CLR.W	D2AFF$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_AFF	PAGE_	DBOX		; affiche le paramtre	INC.W	D2	COMP.W	D2,#5	JUMP,LO AFF$	CLR.W	D2NLINE$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_MEDIT	PAGE_	DBOXTEST$:	CALL	DBMTTEST	; affiche la flche obtenueLOOP$:	LOAD.W	D7,#MI_SCMO	PAGE_	MISC		; remet la souris	DBOX_	EDIT		; attend une action ...	LOAD.W	D7,#DB_ZEROCR	PAGE_	DBOX		; remplace <CR> par <0>	LOAD.L	A1,#R16"TKEY_MODFLE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#F7	JUMP,EQ PEN$	COMP.W	D3,#F9	JUMP,EQ TRAME$	COMP.W	D3,#UNDO	JUMP,EQ UNDO$	COMP.W	D3,#CLEAR	JUMP,EQ UNDO$	COMP.W	D3,#CR	JUMP,EQ RETURN$	COMP.W	D3,#ENTER	JUMP,EQ ENTER$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,#5	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$CLIC$:	LOAD.L	(A5)+ODBAFA,D4	LOAD.L	(A5)+ODBAOF,D6	LOAD.W	D7,#DB_CLIC	PAGE_	DBOX	JUMP,EQ LOOP$	JUMP	TEST$ENTER$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	JUMP	TEST$KEYDBOX$:			; KEYDBOX =>	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	COMP.B	D3,#100	JUMP,HS CLINE$	LOAD.L	D1,#H'FFFFFF00	COMP.B	D3,#8	JUMP',LO SET$	RL.L	D1,#8	COMP.B	D3,#16	JUMP',LO SET$	RL.L	D1,#8	COMP.B	D3,#24	JUMP',LO SET$	RL.L	D1,#8SET$:	AND.L	D4,D1	TSET.L	D4:D3	JUMP	NLINE$CLINE$:	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$PEN$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	PUSHM.L	D2,D4	LOAD.L	A3,(A5)+OPTAB	; A3 <-- ^table des flches	ADD.L	A3,D6	LOAD.W	D2,(A3)+OFLEPEN	LOAD.L	A4,#0	LOAD.W	D1,#opDTSELECT	LOAD.W	D0,#IDENTPEN	PAGE_	OBJCALL		; choisi un pinceau ...	JUMP',NE EDIAL$	COMP.W	D3,#F1	JUMP',NE EDIAL$	LOAD.W	(A3)+OFLEPEN,D2	JUMP'	EDIAL$TRAME$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	PUSHM.L	D2,D4	LOAD.L	A3,(A5)+OPTAB	; A3 <-- ^table des flches	ADD.L	A3,D6	LOAD.W	D2,(A3)+OFLETRA	LOAD.L	A4,#0	LOAD.W	D1,#opDTSELECT	LOAD.W	D0,#IDENTTRAME	PAGE_	OBJCALL		; choisi une trame ...	JUMP',NE EDIAL$	COMP.W	D3,#F1	JUMP',NE EDIAL$	LOAD.W	(A3)+OFLETRA,D2EDIAL$:	LOAD.L	A2,#R16"TDBOX_MODFLE	LOAD.W	D7,#DB_RSK	PAGE_	DBOX		; refait les soft-keys	LOAD.L	A2,#R16"TDBOX$	LOAD.W	D7,#DB_MEMPT	PAGE_	DBOX		; mj ^table dbox	LOAD.L	A2,#R16"DBMTTESTC	LOAD.W	D7,#DB_MEMAFC	PAGE_	DBOX		; mj ^routine d'affichage	POPM.L	D2,D4	JUMP	NLINE$OK$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	LOAD.L	A4,(A5)+OPTAB	; A4 <-- ^table des flches	ADD.L	A4,D6	CALL	DBMTPUT		; OFLExx <-- ODBxxxEND$:	LOAD.W	D7,#DB_CLOSE	PAGE_	DBOX		; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4..D6,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	ODBPaY,DBTYPU,0,200*FACMMPT,05*FACMMPT,2^BDBGCLABEL!100,0,7+2	.W	ODBPbY,DBTYPU,0,200*FACMMPT,10*FACMMPT,2^BDBGCLABEL!101,2,7+2	.W	ODBPaX,DBTYPU,0,200*FACMMPT,10*FACMMPT,2^BDBGCLABEL!102,1,7+2	.W	ODBPbX,DBTYPU,0,200*FACMMPT,10*FACMMPT,2^BDBGCLABEL!103,3,7+2	.W	ODBPe,DBTYPU,0,200*FACMMPT,10*FACMMPT,2^BDBGCLABEL!104,4,7+2	.W	-1;----------\\; DBMTTESTC >;----------/; Affiche une petite flche de test pendant le DB_CLIC.; in	D2.W	mode (CLRDOT/SETDOT); out	-; mod	D7.WDBMTTESTC:	PUSHM.L	D4,D6	COMP.W	D2,#SETDOT	JUMP',NE EXIT$	LOAD.L	D4,(A5)+ODBAFA	LOAD.L	D6,(A5)+ODBAOF	CALL	DBMTTESTEXIT$:	POPM.L	D4,D6	RET;---------\\; DBMTTEST >;---------/; Affiche une petite flche de test.; in	D4.L	fanions;	D6.L	offset dans table des flches; out	-; mod	D7.WDBMTTEST:	PUSHM.L	D0..D6,A3,A4	LOAD.L	A4,#(A5)+OTFLE	; A4 <-- ^flche bidon	CALL	DBMTPUT		; OFLExx <-- ODBxxx	LOAD.L	A3,(A5)+OPTAB	; A3 <-- ^table des flches	ADD.L	A3,D6	LOAD.W	(A4)+OFLEPEN,(A3)+OFLEPEN	LOAD.W	(A4)+OFLETRA,(A3)+OFLETRA	LOAD.W	D4,#1	LOAD.W	D7,#DR_CHGSCALE	PAGE_	DRAW		; met l'chelle 100%	PUSH.W	D4	CLR.L	D4	CALL	DRMDEF		; trame pour effacer	LOAD.W	D2,#2^BDBGCLABEL!31	DBOX_	GETCO	SWAP.W	D3	ADD.W	D3,#4	SWAP.W	D3	PUSH.L	D3	LOAD.W	D2,#2^BDBGCLABEL!30	DBOX_	GETCO	POP.L	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; dessine le pourtour	ADD.W	D3,(A0)+ODFFX	INC.W	D3	DEC.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,(A0)+ODFFY	INC.W	D3	DEC.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D7,#DR_WDOUOPEN	PAGE_	DRAW		; ouvre swdo de dessin	CLR.L	D3	LOAD.L	D4,(A0)+ODFFDY	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface l'intrieur	SWAP.W	D4	LOAD.W	D1,D4	SR.W	D1,#1	SWAP.W	D4	LIB	?AFTIM	.B	MAPTT	.B	B'01010101	.B	1	.B	0	.EVEN	LOAD.W	D2,#SETDOT!TTTDOT	PUSHM.L	D3,D4	ADD.W	D3,D1	ADD.W	D3,D1	CLR.W	D4	LIB	?DRSEG	POPM.L	D3,D4	PUSHM.L	D3,D4	ADD.W	D3,D4	SUB.W	D3,D1	SUB.W	D3,D1	CLR.W	D4	LIB	?DRSEG	POPM.L	D3,D4	PUSHM.L	D3,D4	SWAP.W	D3	ADD.W	D3,D1	SWAP.W	D3	AND.L	D4,#H'FFFF	LIB	?DRSEG	POPM.L	D3,D4	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,D1	LOAD.W	D4,D1	SWAP.W	D4	SWAP.W	D3	ADD.W	D4,D3	ADD.W	D3,D1	ADD.W	D3,D1	SUB.W	D4,D1	SUB.W	D4,D1	LOAD.L	D5,D4		; D5 <-- arrive	LOAD.L	D4,D3		; D4 <-- dpart	LOAD.W	D7,#MA_SCALEN	PAGE_	MATH		; D4 <-- plus petit si n:1	EX.L	D5,D4	LOAD.W	D7,#MA_SCALEN	PAGE_	MATH		; D5 <-- plus petit si n:1	EX.L	D5,D4	CLR.W	D3		; D3 <-- numro de la flche bidon;	LOAD.L	A4,#(A5)+OTFLE	; A4 <-- ^flche bidon	CALL	PTDUSE		; utilise la flche bidon	LOAD.W	D6,D3		; D6 <-- nb de droites	PUSHM.L	D4,A3	LOAD.W	D3,D4		; D3 <-- numro de la trame	TSET.L	D3:#15		; D3 <-- sans offset	LOAD.L	A4,#0	LOAD.W	D2,#SETDOT	LOAD.W	D1,#opDUSE	LOAD.W	D0,#IDENTTRAME	PAGE_	OBJCALL		; utilise la bonne trame	JUMP',NE IEND$	COMP.W	D2,#-1	JUMP',EQ IEND$	LOAD.W	D7,#DR_POLYOPEN	PAGE_	DRAW	LOAD.W	D1,D6		; D1 <-- nb de droitesILOOP$:	LOAD.L	D3,(A3+)	LOAD.L	D4,(A3+)	LOAD.W	D7,#DR_POLYLINE	PAGE_	DRAW	DEC.W	D1	JUMP,NE ILOOP$	LOAD.W	D7,#DR_POLYCLOSE	PAGE_	DRAWIEND$:	POPM.L	D4,A3	SWAP.W	D4	LOAD.W	D3,D4		; D3 <-- numro du pinceau	LOAD.L	A4,#0	LOAD.W	D2,#SETDOT	LOAD.W	D1,#opDUSE	LOAD.W	D0,#IDENTPEN	PAGE_	OBJCALL		; utilise le bon pinceau	JUMP',NE EEND$	COMP.W	D2,#-1	JUMP',EQ EEND$	LOAD.W	D1,D6		; D1 <-- nb de droitesELOOP$:	LOAD.L	D3,(A3+)	LOAD.L	D4,(A3+)	LOAD.W	D7,#DR_LINE	PAGE_	DRAW	DEC.W	D1	JUMP,NE ELOOP$EEND$:	LOAD.W	D7,#DR_WDOUCLOSE	PAGE_	DRAW		; ferme swdo de dessin	POP.W	D4	LOAD.W	D7,#DR_PUTSCALE	PAGE_	DRAW		; remet l'chelle courante	CLR.L	(A0)+ODFTPM	; annule XTRAME	POPM.L	D0..D6,A3,A4	RET;--------\\; DBMTPUT >;--------/; Met  jour les paramtres d'une flche.; in	A4.L	^flche;	D4.L	fanions; out	-; mod	D7.WDBMTPUT:	PUSH.L	D3	LOAD.W	(A4)+OFLEPa+2,(A5)+ODBPaX	LOAD.W	D3,(A5)+ODBPaY	SR.W	D3,#1	LOAD.W	(A4)+OFLEPa+0,D3	LOAD.W	(A4)+OFLEPb+2,(A5)+ODBPbX	LOAD.W	(A4)+OFLEPb+0,(A5)+ODBPbY	LOAD.W	(A4)+OFLEPe,(A5)+ODBPe	LOAD.L	(A4)+OFLEFA,D4	POP.L	D3	RETTDBOX_MODFLE:	.W	10$-TDBOX_MODFLE	.W	20$-TDBOX_MODFLE	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Dpart :"	.B	ODBTABX,14	.B	ODBTEXT	.ASCIZ	"Arrive :"	.B	ODBCR	.B	ODBTABX,54	.B	ODBBOX,0,F7,TDBOMBRE	.ASCIZ	" TRAIT "	.B	ODBCR2	.B	ODBLCIRCLE,BFLEr2!2^6!2^7,KEYDBOX/H'100,BFLEr2	.ASCIZ	" rien"	.B	ODBTABX,14	.B	ODBLCIRCLE,BFLEr1!2^6!2^7,KEYDBOX/H'100,BFLEr1	.ASCIZ	" rien"	.B	ODBCR	.B	ODBLCIRCLE,BFLEi2!2^6!2^7,KEYDBOX/H'100,BFLEi2	.ASCIZ	" intrieur"	.B	ODBTABX,14	.B	ODBLCIRCLE,BFLEi1!2^6!2^7,KEYDBOX/H'100,BFLEi1	.ASCIZ	" intrieur"	.B	ODBCR2	.B	ODBTABX,54	.B	ODBBOX,0,F9,TDBOMBRE	.ASCIZ	" TRAME "	.B	ODBCR2	.B	ODBLCIRCLE,BFLEe2!2^6!2^7,KEYDBOX/H'100,BFLEe2	.ASCIZ	" extrieur"	.B	ODBTABX,14	.B	ODBLCIRCLE,BFLEe1!2^6!2^7,KEYDBOX/H'100,BFLEe1	.ASCIZ	" extrieur"	.B	ODBCR	.B	ODBLABEL,200	.B	ODBTEXT,0	.B	ODBCR,ODBCR2	.B	ODBTEXT	.ASCIZ	"Epaisseur"	.B	ODBLABEL,100	.B	ODBCLINE,(7+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTEXT	.ASCIZ	"  Renfoncement"	.B	ODBLABEL,102	.B	ODBCLINE,(7+2)!2^7,KEYDBOX/H'100,102,TDBNORM	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Ouverture"	.B	ODBLABEL,101	.B	ODBCLINE,(7+2)!2^7,KEYDBOX/H'100,101,TDBNORM	.B	ODBTEXT	.ASCIZ	"      Longueur"	.B	ODBLABEL,103	.B	ODBCLINE,(7+2)!2^7,KEYDBOX/H'100,103,TDBNORM	.B	ODBTEXT	.ASCIZ	"  Ext."	.B	ODBLABEL,104	.B	ODBCLINE,(7+2)!2^7,KEYDBOX/H'100,104,TDBNORM	.B	ODBCR	.B	ODBLABEL,201	.B	ODBTEXT,0	.B	ODBCR	.B	ODBTABX,30	.B	ODBLABEL,30	.B	ODBTEXT,0	.B	ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	ODBTABX,31+32	.B	ODBLABEL,31	.B	ODBTEXT,0	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Trait       Trame"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_MODFLE:	.W	F1,F2,F3,0		DOKF1-TKEY_MODFLE	.W	F0,F13,F14,F15,0	DOKF0-TKEY_MODFLE	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_MODFLE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_MODFLE	.W	0;---------\\; DBPALSAV >;---------/; Sauve l'image cran de la palette.; in	-; out	D7.W	erreur; mod	D7.WDBPALSAV:	PUSHM.L	D0..D6,A3,A4	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP,NE OK$		; oui => OK	TEST.L	(A5)+ODBRPB	JUMP',NE BUFOK$	LOAD.W	D4,(A5)+ODBRLX	MUL.WU	D4,#NBRX	INC.W	D4	LOAD.W	(A5)+ODBRPD+2,D4	LOAD.W	D4,(A5)+ODBRLY	MUL.WU	D4,#NBRY	INC.W	D4	LOAD.W	(A5)+ODBRPD+0,D4	LOAD.W	D4,(A5)+ODBRPD+2	ADD.W	D4,#16-1	SR.W	D4,#4	SL.W	D4,#1	MUL.WU	D4,(A5)+ODBRPD+0	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour image cran	JUMP',NE EXIT$	LOAD.L	(A5)+ODBRPB,A4BUFOK$:	LOAD.W	D7,#MI_CCMO	PAGE_	MISC		; enlve la souris	LOAD.L	D3,(A5)+ODBRPY	LOAD.L	A3,#0	CLR.L	D4	LOAD.L	A4,(A5)+ODBRPB	LOAD.W	D6,(A5)+ODBRPD+2	ADD.W	D6,#16-1	SR.W	D6,#4	SL.W	D6,#1	LOAD.L	D2,(A5)+ODBRPD	LOAD.W	D1,#LOADDOT	LOAD.L	A2,A0	GRA_	RASTER		; buffer <-- image cran	LOAD.W	D1,#opDGETREGEN	LOAD.W	D0,#IDENTPEN	PAGE_	OBJCALL		; D4 <-- numro de rgnration des pinceaux	LOAD.L	(A5)+ODBRRP,D4;	LOAD.W	D1,#opDGETREGEN	LOAD.W	D0,#IDENTTRAME	PAGE_	OBJCALL		; D4 <-- numro de rgnration des trames	LOAD.L	(A5)+ODBRRT,D4OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBPALUPD >;---------/; Met  jour l'image cran de la palette, si ncessaire.; in	-; out	-; mod	D7.WDBPALUPD:	PUSHM.L	D0,D1,D4	LOAD.W	D1,#opDGETREGEN	LOAD.W	D0,#IDENTPEN	PAGE_	OBJCALL		; D4 <-- numro de rgnration des pinceaux	COMP.L	D4,(A5)+ODBRRP	JUMP',NE UPDATE$;	LOAD.W	D1,#opDGETREGEN	LOAD.W	D0,#IDENTTRAME	PAGE_	OBJCALL		; D4 <-- numro de rgnration des trames	COMP.L	D4,(A5)+ODBRRT	JUMP',EQ EXIT$UPDATE$:	CLR.W	D0	LOAD.W	D1,#NBRX*NBRY	CALL	DBRDESFLES	; redessine toutes les flches	CALL	DBRUSEFLES	; marque les utilisesEXIT$:	POPM.L	D0,D1,D4	RET;---------\\; DBPALGET >;---------/; Restitue l'image cran de la palette.; in	-; out	D7.W	erreur; mod	D7.WDBPALGET:	PUSHM.L	D0..D6,A3,A4	TEST.L	(A5)+ODBRPB	JUMP',EQ ERROR$	LOAD.W	D1,#opDGETREGEN	LOAD.W	D0,#IDENTPEN	PAGE_	OBJCALL		; D4 <-- numro de rgnration des pinceaux	COMP.L	D4,(A5)+ODBRRP	JUMP',NE ERROR$;	LOAD.W	D1,#opDGETREGEN	LOAD.W	D0,#IDENTTRAME	PAGE_	OBJCALL		; D4 <-- numro de rgnration des trames	COMP.L	D4,(A5)+ODBRRT	JUMP',NE ERROR$	LOAD.W	D7,#MI_CCMO	PAGE_	MISC		; enlve la souris	CLR.L	D3	LOAD.L	A3,(A5)+ODBRPB	LOAD.W	D5,(A5)+ODBRPD+2	ADD.W	D5,#16-1	SR.W	D5,#4	SL.W	D5,#1	LOAD.L	D4,(A5)+ODBRPY	LOAD.L	A4,#0	LOAD.L	D2,(A5)+ODBRPD+0	LOAD.W	D1,#LOADDOT	LOAD.L	A2,A0	GRA_	RASTER		; cran <-- image mmorise	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$ERROR$:	LOAD.W	D7,#1EXIT$:	POPM.L	D0..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;-------\\; DBRSEL >;-------/; Slectionne un nouveau rectangle.; in	D6.W	rectangle slectionn (0..n); out	D6.W	nouveau rectangle (0..n);	D3.L	touche presse;	D7.W	erreur; mod	D3.L, D6.L, D7.WDBRSEL:	PUSHM.L	D0,D4	CALL	DBRDET		; est-on dans un rectangle ?	JUMP',NE 90$		; non => 90$	EX.L	D0,D6	CALL	DBRINV		; efface l'ancien	LOAD.W	D0,D6	CALL	DBRINV		; allume le nouveau20$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris bouge ?	JUMP',NE 80$		; non => 80$	CALL	DBRDET		; D0 <-- rectangle o est la souris	JUMP,NE 20$	COMP.W	D0,D6		; toujours dans le mme ?	JUMP,EQ 20$		; oui => 20$				; non =>	EX.L	D0,D6	CALL	DBRINV		; efface l'ancien	LOAD.W	D0,D6	CALL	DBRINV		; allume le nouveau	JUMP	20$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,D4	TEST.W	D7		; retour EQ/NE	RET;-------\\; DBRDET >;-------/; Dtecte dans quel rectangle est la souris.; in	-; out	D0.W	rectangle (0..n);	D7.W	erreur; mod	D0.L, D7.WDBRDET:	PUSHM.L	D1..D4	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP',NE 90$	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la matrice	SUB.W	D4,(A0)+ODFFX	; D4 <-- pos relative dans swdo	JUMP',LO 90$	SUB.W	D4,(A5)+ODBRPX	; D4 <-- pos relative dans rectangle	JUMP',LO 90$	CLR.L	D0	LOAD.W	D0,D4	DIV.WU	D0,(A5)+ODBRLX	; D0 <-- coordonne X	COMP.W	D0,#NBRX	JUMP',HS 90$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	; D4 <-- pos relative dans swdo	JUMP',LO 90$	SUB.W	D4,(A5)+ODBRPY	; D4 <-- pos relative dans rectangle	JUMP',LO 90$	CLR.L	D1	LOAD.W	D1,D4	DIV.WU	D1,(A5)+ODBRLY	; D1 <-- coordonne Y	COMP.W	D1,#NBRY	JUMP',HS 90$	MUL.WU	D1,#NBRX	ADD.W	D0,D1		; D0 <-- no du rectangle	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RET;-------\\; DBRINV >;-------/; Inverse un rectangle.; in	D0.W	no du rectangle (0..n); out	-; mod	D7.WDBRINV:	PUSHM.L	D2..D4	LOAD.L	D4,#-1	CALL	DRMDEF	LOAD.W	D2,#INVDOT	CALL	DBRPOS	JUMP',NE EXIT$	ADD.W	D3,#2	SWAP.W	D3	ADD.W	D3,#2	SWAP.W	D3	SUB.W	D4,#3	SWAP.W	D4	SUB.W	D4,#3	SWAP.W	D4;;?	DEC.W	D3;;?	SWAP.W	D3;;?	DEC.W	D3;;?	SWAP.W	D3;;?	ADD.W	D4,#3;;?	SWAP.W	D4;;?	ADD.W	D4,#3;;?	SWAP.W	D4	LIB	?DRTRAME	; inverse un rectangleEXIT$:	POPM.L	D2..D4	RET;-----------\\; DBRUSEFLES >;-----------/; Dessine une ou plusieurs utilisations.; in	D0.W	premire flche;	D1.W	nombre de flches; out	-; mod	D7.WDBRUSEFLES:	PUSHM.L	D0..D4,A3,A4	LOAD.L	A3,#(A5)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWMATRIXLOOP$:	CALL	DBRPOS		; D3/D4 <-- pos/dim	JUMP',NE EXIT$	INC.W	D3	SWAP.W	D3	INC.W	D3	LOAD.L	(A3)+1,D3	LOAD.L	A4,#R16"MACLR$	LOAD.L	(A3)+5,A4	LOAD.B	(A3)+9,#CLRDOT!PENDOT	LOAD.W	D3,#10	LIB	?STRING	LOAD.L	A4,#(A5)+OUSBUF	TEST.B	(A4)+(D0.W)	; flche utilise ?	JUMP',EQ NEXT$		; non => NEXT$	LOAD.L	A4,#R16"MASET$	LOAD.L	(A3)+5,A4	LOAD.B	(A3)+9,#SETDOT!PENDOT	LOAD.W	D3,#10	LIB	?STRINGNEXT$:	INC.W	D0	DEC.W	D1	JUMP,NE LOOP$EXIT$:	POPM.L	D0..D4,A3,A4	RETMACLR$:	.B	8,8	.B	B'11111111	.B	B'11111111	.B	B'11111110	.B	B'11111100	.B	B'11111000	.B	B'11110000	.B	B'11100000	.B	B'11000000MASET$:	.B	8,8	.B	B'00000000	.B	B'01111110	.B	B'01111100	.B	B'01111000	.B	B'01110000	.B	B'01100000	.B	B'01000000	.B	B'00000000	.EVEN;-----------\\; DBRDESFLES >;-----------/; Dessine une ou plusieurs flches.; in	D0.W	premire flche;	D1.W	nombre de flches; out	-; mod	D7.WDBRDESFLES:	PUSHM.L	D0..D4	LOAD.W	D4,#1	LOAD.W	D7,#DR_CHGSCALE	PAGE_	DRAW		; met l'chelle 100%20$:	CALL	DBRDESFLE	; dessine une flche	INC.W	D0	DEC.W	D1	JUMP,NE 20$	LOAD.W	D7,#DR_PUTSCALE	PAGE_	DRAW		; remet l'chelle courante	POPM.L	D0..D4	RET;----------\\; DBRDESFLE >;----------/; Dessine une flche dans un rectangle.; in	D0.W	numro du rectangle; out	-; mod	D7.WDBRDESFLE:	PUSHM.L	D0..D6,A1,A3,A4	LOAD.L	A1,(A5)+OADDRAW	; A1 <-- ^appel PAGE_DRAW	CLR.L	D4	CALL	DRMDEF		; dfini trame pour effacer	CALL	DBRPOS	JUMP,NE EXIT$	ADD.W	D3,(A0)+ODFFX	ADD.W	D3,#3	SUB.W	D4,#5	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,(A0)+ODFFY	ADD.W	D3,#3	SUB.W	D4,#5	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D7,#DR_WDOUOPEN	CALL	(A1)		; PAGE_DRAW, ouvre swdo de dessin	CLR.L	D3	LOAD.L	D4,(A0)+ODFFDY	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface l'emplacement	ADD.W	D3,#(4/2)+1	SUB.W	D4,#4+1	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,#(4/2)+0	SUB.W	D4,#4+1	ADD.W	D3,D4		; flche dans le sens "/"	NEG.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	D5,D4		; D5 <-- arrive	LOAD.L	D4,D3		; D4 <-- dpart	LOAD.L	A4,(A5)+OPTAB	; A4 <-- ^table des flches	LOAD.W	D3,D0		; D3 <-- numro de la flche	MUL.WU	D3,#LDFLE	LOAD.L	D3,(A4)+(D3.L)+OFLEFA	TEST.L	D3:#BFLEe1	JUMP',BC e1$	SUB.W	D5,#20	SWAP.W	D5	ADD.W	D5,#20	SWAP.W	D5e1$:	TEST.L	D3:#BFLEe2	JUMP',BC e2$	ADD.W	D4,#20	SWAP.W	D4	SUB.W	D4,#20	SWAP.W	D4e2$:	LOAD.W	D7,#MA_SCALEN	PAGE_	MATH		; D4 <-- plus petit si n:1	EX.L	D5,D4	LOAD.W	D7,#MA_SCALEN	PAGE_	MATH		; D5 <-- plus petit si n:1	EX.L	D5,D4	LOAD.W	D3,D0		; D3 <-- numro de la flche;	LOAD.L	A4,(A5)+OPTAB	; A4 <-- ^table des flches	CALL	PTDUSE		; utilise la bonne flche	LOAD.W	D6,D3		; D6 <-- nb de droites	PUSHM.L	D4,A3	LOAD.W	D3,D4		; D3 <-- numro de la trame	TSET.L	D3:#15		; D3 <-- sans offset	LOAD.W	D2,#SETDOT	LOAD.L	A4,#0	LOAD.W	D1,#opDUSE	LOAD.W	D0,#IDENTTRAME	PAGE_	OBJCALL		; utilise la bonne trame	JUMP',NE IEND$	COMP.W	D2,#-1	JUMP',EQ IEND$	LOAD.W	D7,#DR_POLYOPEN	CALL	(A1)		; PAGE_DRAW	LOAD.W	D1,D6		; D1 <-- nb de droitesILOOP$:	LOAD.L	D3,(A3+)	LOAD.L	D4,(A3+)	LOAD.W	D7,#DR_POLYLINE	CALL	(A1)		; PAGE_DRAW	DEC.W	D1	JUMP,NE ILOOP$	LOAD.W	D7,#DR_POLYCLOSE	CALL	(A1)		; PAGE_DRAWIEND$:	POPM.L	D4,A3	SWAP.W	D4	LOAD.W	D3,D4		; D3 <-- numro du pinceau	LOAD.W	D2,#SETDOT	LOAD.L	A4,#0	LOAD.W	D1,#opDUSE	LOAD.W	D0,#IDENTPEN	PAGE_	OBJCALL		; utilise le bon pinceau	JUMP',NE EEND$	COMP.W	D2,#-1	JUMP',EQ EEND$	LOAD.W	D1,D6		; D1 <-- nb de droitesELOOP$:	LOAD.L	D3,(A3+)	LOAD.L	D4,(A3+)	LOAD.W	D7,#DR_LINE	CALL	(A1)		; PAGE_DRAW	DEC.W	D1	JUMP,NE ELOOP$EEND$:	LOAD.W	D7,#DR_WDOUCLOSE	CALL	(A1)		; PAGE_DRAW, ferme swdo de dessinEXIT$:	POPM.L	D0..D6,A1,A3,A4	RET;-------\\; DBRPOS >;-------/; Donne la position et les dimensions d'un rectangle.; in	D0.W	no du rectangle (0..n); out	D3.L	coin sup/gauche (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D7.WDBRPOS:	PUSHM.L	D0,D1	LOAD.W	D7,#1		; D7 <-- erreur	COMP.W	D0,#NBRX*NBRY	JUMP',HS 90$	AND.L	D0,#H'FFFF	DIV.WU	D0,#NBRX	LOAD.W	D1,D0		; D1 <-- Y	SWAP.W	D0		; D0 <-- X	MUL.WU	D1,(A5)+ODBRLY	ADD.W	D1,(A5)+ODBRPY	MUL.WU	D0,(A5)+ODBRLX	ADD.W	D0,(A5)+ODBRPX	LOAD.W	D3,D1	SWAP.W	D3	LOAD.W	D3,D0	LOAD.L	D4,(A5)+ODBRLY	; D4 <-- dimensions	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,D1	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBRDESCADRE >;------------/; Dessine les rectangles pour entourer la palette; de flches ou de pinceaux.; in	-; out	-; mod	D7.WDBRDESCADRE:	PUSHM.L	D0..D4	LOAD.W	D2,#2^BDBGCLABEL!100	DBOX_	GETCO	SWAP.W	D3	SUB.W	D3,#16	SWAP.W	D3	LOAD.L	(A5)+ODBRPY,D3	LOAD.W	D2,#2^BDBGCLABEL!101	DBOX_	GETCO	CLR.L	D4	LOAD.W	D4,D3	SUB.W	D4,(A5)+ODBRPX	DIV.WU	D4,#NBRX	LOAD.W	(A5)+ODBRLX,D4	MUL.WU	D4,#NBRX	SUB.W	D4,(A0)+ODFFDX	NEG.W	D4	SR.W	D4,#1	LOAD.W	(A5)+ODBRPX,D4	CLR.W	D3	SWAP.W	D3	SUB.W	D3,(A5)+ODBRPY	DIV.WU	D3,#NBRY	LOAD.W	(A5)+ODBRLY,D3	LOAD.L	D3,(A5)+ODBRPY	LOAD.L	D4,(A5)+ODBRLY	LOAD.W	D2,#SETDOT	; D2 <-- mode de dessin	LOAD.W	D1,#NBRY-1	; D1 <-- compteur vertical30$:	PUSHM.L	D3,D4	LOAD.W	D0,#NBRX-1	; D0 <-- compteur horizontal40$:	LIB	?DRRECT		; dessine rectangle	ADD.W	D3,D4		; D3 <-- X suivant	DECJ.W,NMO D0,40$	POPM.L	D3,D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4		; D3 <-- Y suivant	SWAP.W	D4	SWAP.W	D3	DECJ.W,NMO D1,30$	POPM.L	D0..D4	RET;--------\\; DRMDEF  >;========/; Dfini la demi-trame super-rapidement.; ATTENTION:	Le fait d'crire directement dans le descripteur;		de la fentre fait que la trame est inverse;		entre le Smaky 8 et 100 (gauche <--> droite) !;		Il ne faut donc utiliser que des trames simples;		(pas de hachures par exemple).; in	D4.L	demi-trame; out	-; mod	D7.WDRMDEF:	LOAD.L (A0)+ODFTRA+0,D4	LOAD.L (A0)+ODFTRA+4,D4	CLR.L	(A0)+ODFTPM	; annule XTRAME	RET;--------\\; DOK...  >;========/DOKMGP:	LOAD.W	D3,#KEYMGP	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RETDOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RETDOKF2:	LOAD.W	D3,#F2	RETDOKF3:	LOAD.W	D3,#F3	RETDOKF4:	LOAD.W	D3,#F4	RETDOKF5:	LOAD.W	D3,#F5	RETDOKF6:	LOAD.W	D3,#F6	RETDOKF7:	LOAD.W	D3,#F7	RETDOKF8:	LOAD.W	D3,#F8	RETDOKF9:	LOAD.W	D3,#F9	RETDOKF10:	LOAD.W	D3,#F10	RETDOKF11:	LOAD.W	D3,#F11	RETDOKF12:	LOAD.W	D3,#F12	RETDOKF13:	LOAD.W	D3,#F13	RETDOKF14:	LOAD.W	D3,#F14	RETDOKF15:	LOAD.W	D3,#F15	RET	.END