	.SBTTL	OPLISTIO.ASI;--------\\; IOWALL  >;========/; Sauve toutes les cellules dans un fichier texte.; in	A1.L	^objet liste; out	D7.W	erreur; mod	D7.WIOWALL:	PUSHM.L	D1,D3,D4,D6,A3,A4NAME$:	LOAD.L	A3,#(A5)+OBUNAM	CALL	DBOXTXSAUVE	; demande le nom ...	JUMP,NE EXIT$	COMP.W	D3,#F1	JUMP,NE EXIT$CREATE$:	LOAD.W	D7,#MI_WAITMOUSE	PAGE_	MISC		; met le sablier	LOAD.L	D3,#DEFATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE	JUMP',EQ OPEN$	COMP.W	D7,#ERFAEX	JUMP',NE ERROR$	CALL	DBOXDELETE	; faut-il dtruire ...	COMP.W	D3,#'O	JUMP,NE NAME$	LOAD.W	D7,#MI_WAITMOUSE	PAGE_	MISC		; met le sablier	FOS	?DELETE	JUMP,EQ CREATE$ERROR$:	CALL	DBOXERROR	; affiche l'erreur ...	JUMP	NAME$OPEN$:	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP,NE ERROR$	CALL	IOGETLG		; D4 <-- longueur ncessaire	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- demande mmoire pour texte	JUMP',NE CLOSE$	CALL	IOWCELS		; crit toutes les cellules	FOS	?WRBYTE		; crit tout le fichier	PUSH.W	D7;	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre mmoire pour le texte	POP.W	D7	JUMP',NE CLOSE$	FOS	?CLOSE	JUMP'	EXIT$CLOSE$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D7EXIT$:	PUSH.W	D7	LOAD.W	D7,#MI_NORMMOUSE	PAGE_	MISC		; enlve le sablier	POP.W	D7	POPM.L	D1,D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; IOGETLG >;--------/; Calcule la longueur ncessaire pour tous les textes d'une liste.; in	A1.L	^objet liste; out	D4.L	longueur ncessaire; mod	D4.L, D7.WIOGETLG:	PUSHM.L	D2,D3,A2,A3	CLR.L	D4	LOAD.L	A2,(A1)+OOBPCE	; A2 <-- ^table des cellules (OCE*)	LOAD.W	D2,(A1)+OOBNBTLOOP$:	TEST.L	(A2)+OCEPTX	; texte existe ?	JUMP',EQ NEXT$		; non => NEXT$	LOAD.L	A3,(A2)+OCEPTX	; A3 <-- ^texte (OTX*)	CLR.L	D3	LOAD.W	D3,(A3)+OTXNBC	ADD.L	D4,D3		; D4 <-- compte le texteNEXT$:	INC.L	D4		; D4 <-- compte un <TAB> (ou <CR> si dernier)	ADD.L	A2,#LCE	DEC.W	D2	JUMP,NE LOOP$	POPM.L	D2,D3,A2,A3	RET;--------\\; IOWCELS >;--------/; Ecrit toutes les cellules dans le buffer en sortie.; in	A4.L	^buffer;	D4.L	lg buffer; out	D7.W	erreur; mod	D7.WIOWCELS:	PUSHM.L	D1..D4,A2..A4	LOAD.L	A2,(A1)+OOBPCE	; A2 <-- ^table des cellules (OCE*)	LOAD.W	D1,(A1)+OOBNBYLOOPY$:	LOAD.W	D2,(A1)+OOBNBXLOOPX$:	TEST.L	(A2)+OCEPTX	; texte existe ?	JUMP',EQ NEXT$		; non => NEXT$	LOAD.L	A3,(A2)+OCEPTX	; A3 <-- ^texte (OTX*)	LOAD.W	D3,(A3)+OTXNBC	JUMP',EQ NEXT$	LOAD.L	A3,#(A3)+OTXDEBXFER$:	LOAD.B	(A4+),(A3+)	; buffer <-- texte	DEC.W	D3	JUMP,NE XFER$NEXT$:	LOAD.B	(A4+),#TAB	; buffer <-- <TAB>	ADD.L	A2,#LCE	DEC.W	D2	JUMP,NE LOOPX$	LOAD.B	(A4)-1,#CR	; buffer <-- <CR>	DEC.W	D1	JUMP,NE LOOPY$	POPM.L	D1..D4,A2..A4	RET;--------\\; IORALL  >;========/; Lit toutes les cellules d'un fichier texte.; in	A1.L	^objet liste; out	D7.W	erreur; mod	D7.WIORALL:	PUSHM.L	D1,D3,D4,D6,A3,A4NAME$:	LOAD.L	A3,#(A5)+OBUNAM	CALL	DBOXTXPREND	; demande le nom ...	JUMP,NE EXIT$	COMP.W	D3,#F1	JUMP,NE EXIT$OPEN$:	LOAD.W	D7,#MI_WAITMOUSE	PAGE_	MISC		; met le sablier	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP',EQ READ$ERROR$:	CALL	DBOXERROR	; affiche l'erreur ...	JUMP	NAME$READ$:	LOAD.L	D4,#-1	LOAD.L	D3,D4	FOS	?SPOS		; D4 <-- longueur du fichier	PUSH.L	D4	CLR.L	D4	CLR.L	D3	FOS	?SPOS	POP.L	D4	INC.L	D4	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire pour fichier	JUMP',NE CLOSE$	LOAD.L	A3,A4	DEC.L	D4	FOS	?RDBYTE		; lit tout le fichier	JUMP',NE GIVMEM$	CLR.B	(A4)+(D4.L)	; met un <0> terminateur	CALL	IOCNTCELS	; D4 <-- (ny;nx)	JUMP',NE GIVMEM$	COMP.W	D4,(A1)+OOBNBX	JUMP',NE CHANGE$	SWAP.W	D4	COMP.W	D4,(A1)+OOBNBY	JUMP',EQ PUT$	SWAP.W	D4CHANGE$:	LOAD.L	A4,A1		; A4 <-- ^objet	CALL	DIMCHANGE	; change le nombre de cellules	JUMP',NE GIVMEM$PUT$:	CALL	IOPUTCELS	; met les textes dans l'objetGIVMEM$:	PUSH.W	D7;	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	POP.W	D7CLOSE$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D7EXIT$:	PUSH.W	D7	LOAD.W	D7,#MI_NORMMOUSE	PAGE_	MISC		; enlve le sablier	POP.W	D7	POPM.L	D1,D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; IOCNTCELS >;----------/; Compte le nombre de cellules d'un texte.; in	A3.L	^texte; out	D4.L	nombre de cellules (ny;nx);	D7.W	erreur; mod	D4.L, D7.WIOCNTCELS:	PUSHM.L	D0..D3,A3	CLR.W	D0		; D0 <-- nb de lignes	CLR.W	D1		; D1 <-- nb de colonnesLOOPY$:	LOAD.W	D2,#1LOOPX$:	LOAD.B	D3,(A3+)	JUMP',EQ END$	COMP.B	D3,#CR	JUMP',EQ CR$	COMP.B	D3,#TAB	JUMP,NE LOOPX$TAB$:	INC.W	D2		; D2 <-- une colonne de plus	JUMP	LOOPX$CR$:	INC.W	D0		; D0 <-- une ligne de plus	COMP.W	D1,D2	JUMP',HS LOOPY$	LOAD.W	D1,D2		; D1 <-- nb de colonnes le plus grand	JUMP	LOOPY$END$:	LOAD.W	D7,#ERFOS	; D7 <-- erreur avec le FOS (!)	COMP.W	D0,#MAXLIN	JUMP',HS EXIT$	COMP.W	D1,#MAXCOL	JUMP',HS EXIT$	LOAD.W	D4,D0	SWAP.W	D4	LOAD.W	D4,D1	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D3,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; IOPUTCELS >;----------/; Met tous les textes dans l'objet.; in	A1.L	^objet liste;	A3.L	^texte lu <0>; out	D7.W	erreur; mod	D7.WIOPUTCELS:	PUSHM.L	D1..D4,A2..A4	CLR.L	D2LOOPY$:	CLR.W	D2LOOPX$:	LOAD.B	D3,(A3+)	JUMP,EQ END$	COMP.B	D3,#TAB	JUMP,EQ NEXTX$	COMP.B	D3,#CR	JUMP,EQ NEXTY$	DEC.L	A3	LOAD.L	D1,D2	CALL	TXGETPCE	; A2 <-- ^cellule	JUMP,NE SKIP$	TEST.L	(A2)+OCEPTX	JUMP',EQ GIVE$	LOAD.L	A4,(A2)+OCEPTX	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le texte	CLR.L	(A2)+OCEPTXGIVE$:	LOAD.L	A4,A3	CLR.L	D4LG$:	LOAD.B	D3,(A4+)	JUMP',EQ MEM$	COMP.B	D3,#CR	JUMP',EQ MEM$	COMP.B	D3,#TAB	JUMP',EQ MEM$	INC.W	D4	JUMP	LG$MEM$:	ADD.W	D4,#OTXDEB+TXRES	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour texte	JUMP,NE EXIT$	LOAD.L	(A2)+OCEPTX,A4	SUB.W	D4,#OTXDEB	LOAD.W	(A4)+OTXLGM,D4	SUB.W	D4,#TXRES	LOAD.W	(A4)+OTXNBC,D4	LOAD.L	A4,#(A4)+OTXDEBXFER$:	LOAD.B	D3,(A3)	JUMP,EQ LOOPX$	COMP.B	D3,#TAB	JUMP,EQ LOOPX$	COMP.B	D3,#CR	JUMP,EQ LOOPX$	INC.L	A3	LOAD.B	(A4+),D3	JUMP	XFER$SKIP$:	LOAD.B	D3,(A3)	JUMP,EQ LOOPX$	COMP.B	D3,#CR	JUMP,EQ LOOPX$	COMP.B	D3,#TAB	JUMP,EQ LOOPX$	INC.L	A3	JUMP	SKIP$NEXTX$:	INC.W	D2	JUMP	LOOPX$NEXTY$:	SWAP.W	D2	INC.W	D2	SWAP.W	D2	JUMP	LOOPY$END$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET	.END