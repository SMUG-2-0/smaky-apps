	.SBTTL	OPTEXTDICO.ASI;----------\\; DICOVERIF >;==========/; Vrifie l'orthographe d'une zone quelconque.; in	A4.L	^objet texte;	D4.L	position;	D5.L	nb de caractres; out	D7.W	erreur; mod	D7.WDICOVERIF:	PUSHM.L	D0..D6,A0,A1..A4	LOAD.L	A1,A4		; A1 <-- ^objet texte	LOAD.W	D7,#MI_WAITMOUSE	PAGE_	MISC		; met le sablier	LOAD.L	D0,D4	CALL	DICOOPTEXT	; A4/D4 <-- ^texte/lg	JUMP,NE EXIT$	LOAD.L	A0,A4	LOAD.L	D1,D4		; A0/D1 <-- ^texte/lg	LOAD.L	A2,A4	LOAD.L	D2,D4		; A2/D2 <-- ^texte/lg	CLR.W	(A5)+ODINBF	CLR.B	(A5)+ODIBM	; aucun mot  changer partoutLOOP$:	LOAD.L	A4,A0	LOAD.L	D4,D1		; A4/D4 <-- ^phrase complte	LOAD.L	A3,A2	LOAD.L	D3,D2		; A3/D3 <-- ^o vrifier	LOAD.W	D7,#IO_DICOLOAD	PAGE_	IO		; D6 <-- canal	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX	LOAD.W	D7,#MI_WAITMOUSE	PAGE_	MISC		; met le sablier	DICO_	JUSTE		; est-ce juste ?	PUSH.W	D7	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX	POP.W	D7	JUMP,EQ END$	COMP.W	D7,#ERKSTO	JUMP,EQ STOP$	ADD.L	D2,A2	SUB.L	D2,A4	SUB.L	D2,D4	LOAD.L	A2,A4	ADD.L	A2,D4		; A2 <-- ^plus loin	LOAD.L	D6,A4	LOAD.L	D5,D4	INC.W	(A5)+ODINBF	; une faute de plus	LOAD.L	D3,D0	ADD.L	D3,D6	SUB.L	D3,A0	CALL	DICOMASC	; met  jour l'ascenseur	LOAD.L	A3,A4	LOAD.L	D3,D4	CALL	DICOCTEXI	; mot  changer partout ?	JUMP',EQ ONE$		; oui => ONE$	LOAD.L	A3,A0	LOAD.L	D3,D1	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX	PUSH.L	D6	LOAD.W	D7,#IO_DICOLOAD	PAGE_	IO		; D6 <-- canal	DICO_	CHANGE		; change un mot ...	POP.L	D6	PUSH.W	D7	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX	POP.W	D7	JUMP,NE EXIT$	COMP.W	D3,#F1		; remplace-un ?	JUMP',EQ ONE$	COMP.W	D3,#F3		; remplace-tout ?	JUMP',EQ ALL$	COMP.W	D3,#F10		; stoppe ?	JUMP,EQ EXIT$	JUMP	LOOP$ONE$:				; remplace-un =>	LOAD.L	D3,D0	ADD.L	D3,D6	SUB.L	D3,A0	CALL	DICOCHMOT	; change un mot	JUMP,NE EXIT$	JUMP	LOOP$ALL$:				; remplace-tout =>	LOAD.L	D3,D0	ADD.L	D3,D6	SUB.L	D3,A0	CALL	DICOCHMOT	; change un mot	JUMP',NE EXIT$	LOAD.L	A3,D6	LOAD.L	D3,D5	CALL	DICOCTMEM	; mmorise le mot	JUMP	LOOP$STOP$:				; stoppe =>	LOAD.L	D4,D0	ADD.L	D4,A4	SUB.L	D4,A0	CALL	DICOSETPOS	JUMP'	OK$END$:	LOAD.B	D3,#BIPDONE	LIB	?BEEP		; indique que c'est fini	TEST.W	(A5)+ODINBF	; y a-t-il eu des fautes ?	JUMP',NE OK$		; oui => OK$	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX	LOAD.W	D7,#IO_DICOLOAD	PAGE_	IO		; D6 <-- canal	DICO_	OK		; indique que tout est ok ...	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOXOK$:	CLR.W	D7		; D7 <-- okEXIT$:	CALL	DICOCLTEXT	; ferme le buffer de texte	POPM.L	D0..D6,A0,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DICOMARK >;=========/; Marque les fautes d'orthographe d'une zone quelconque.; in	A4.L	^objet texte;	D4.L	position;	D5.L	nb de caractres; out	D7.W	erreur; mod	D7.WDICOMARK:	PUSHM.L	D0..D6,A0,A1..A4	LOAD.L	A1,A4		; A1 <-- ^objet texte	LOAD.W	D7,#MI_WAITMOUSE	PAGE_	MISC		; met le sablier	LOAD.L	D0,D4	CALL	DICOOPTEXT	; A4/D4 <-- ^texte/lg	JUMP,NE EXIT$	LOAD.L	A0,A4	LOAD.L	D1,D4		; A0/D1 <-- ^texte/lg	LOAD.L	A2,A4	LOAD.L	D2,D4		; A2/D2 <-- ^texte/lg	CLR.W	(A5)+ODINBF	LOAD.L	D5,#-1LOOP$:	LOAD.L	A4,A0	LOAD.L	D4,D1		; A4/D4 <-- ^phrase complte	LOAD.L	A3,A2	LOAD.L	D3,D2		; A3/D3 <-- ^o vrifier	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX	LOAD.W	D7,#MI_WAITMOUSE	PAGE_	MISC		; met le sablier	DICO_	JUSTE		; est-ce juste ?	PUSH.W	D7	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX	POP.W	D7	JUMP,EQ END$	COMP.W	D7,#ERKSTO	JUMP,EQ STOP$	ADD.L	D2,A2	SUB.L	D2,A4	SUB.L	D2,D4	LOAD.L	A2,A4	ADD.L	A2,D4		; A2 <-- ^plus loin	INC.W	(A5)+ODINBF	; une faute de plus	LOAD.L	D3,D0	ADD.L	D3,A4	SUB.L	D3,A0	CALL	DICOMAMOT	; marque un mot	COMP.L	D5,#-1	JUMP',NE BIP$	LOAD.L	D5,D3		; D5 <-- position premire fauteBIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$STOP$:				; stoppe =>	LOAD.L	D4,D0	ADD.L	D4,A4	SUB.L	D4,A0	CALL	DICOSETPOS	JUMP'	OK$END$:	LOAD.B	D3,#BIPDONE	LIB	?BEEP		; indique que c'est fini	TEST.W	(A5)+ODINBF	; y a-t-il eu des fautes ?	JUMP',EQ END2$		; non => END2$				; oui =>	LOAD.L	D4,D5	INC.L	D4	CALL	DICOSETPOS	; va au dbut de la premire faute	JUMP'	OK$END2$:	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX	DICO_	OK		; indique que tout est ok ...	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOXOK$:	CLR.W	D7		; D7 <-- okEXIT$:	CALL	DICOCLTEXT	; ferme le buffer de texte	POPM.L	D0..D6,A0,A1..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DICOADD >;========/; Ajoute un mot dans le dictionnaire.; in	A4.L	^objet texte;	D4.L	position;	D5.L	nb de caractres; out	D7.W	erreur; mod	D7.WDICOADD:	PUSHM.L	D0..D6,A1..A4	LOAD.L	A1,A4		; A1 <-- ^objet texte	LOAD.W	D7,#MI_WAITMOUSE	PAGE_	MISC		; met le sablier	LOAD.L	D0,D4	CALL	DICOOPTEXT	; A4/D4 <-- ^texte/lg	JUMP',NE EXIT$	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX	DICO_	ADD		; conserve un mot ...	PUSH.W	D7	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX	POP.W	D7EXIT$:	CALL	DICOCLTEXT	; ferme le buffer de texte	POPM.L	D0..D6,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DICOCONJ >;=========/; Conjugue un verbe quelconque.; in	A4.L	^objet texte;	D4.L	position;	D5.L	nb de caractres; out	D7.W	erreur; mod	D7.WDICOCONJ:	PUSHM.L	D0..D6,A1,A4	LOAD.L	A1,A4		; A1 <-- ^objet texte	LOAD.W	D7,#MI_WAITMOUSE	PAGE_	MISC		; met le sablier	LOAD.L	D0,D4	CALL	DICOOPTEXT	; A4/D4 <-- ^texte/lg	JUMP',NE EXIT$	LOAD.L	D5,D4	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX	DICO_	CONJ		; conjugue un verbe ...	PUSH.W	D7	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX	POP.W	D7	JUMP',NE EXIT$	COMP.W	D3,#F1		; remplace ?	JUMP',NE EXIT$	LOAD.L	D3,D0	CALL	DICOCHMOT	; change un motEXIT$:	CALL	DICOCLTEXT	; ferme le buffer de texte	POPM.L	D0..D6,A1,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DICOACCORD >;===========/; Accorde un mot quelconque.; in	A4.L	^objet texte;	D4.L	position;	D5.L	nb de caractres; out	D7.W	erreur; mod	D7.WDICOACCORD:	PUSHM.L	D0..D6,A1,A4	LOAD.L	A1,A4		; A1 <-- ^objet texte	LOAD.W	D7,#MI_WAITMOUSE	PAGE_	MISC		; met le sablier	LOAD.L	D0,D4	CALL	DICOOPTEXT	; A4/D4 <-- ^texte/lg	JUMP',NE EXIT$	LOAD.L	D5,D4	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX	DICO_	ACCORD		; accorde le mot ...	PUSH.W	D7	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX	POP.W	D7	JUMP',NE EXIT$	COMP.W	D3,#F1		; remplace ?	JUMP',NE EXIT$	LOAD.L	D3,D0	CALL	DICOCHMOT	; change un motEXIT$:	CALL	DICOCLTEXT	; ferme le buffer de texte	POPM.L	D0..D6,A1,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DICOSYNO >;=========/; Trouve le synonyme d'un mot quelconque.; in	A4.L	^objet texte;	D4.L	position;	D5.L	nb de caractres; out	D7.W	erreur; mod	D7.WDICOSYNO:	PUSHM.L	D0..D6,A1,A3,A4	LOAD.L	A1,A4		; A1 <-- ^objet texte	LOAD.W	D7,#MI_WAITMOUSE	PAGE_	MISC		; met le sablier	LOAD.L	D0,D4	CALL	DICOOPMOT	; A4/D4 <-- ^texte/lg, A3/D3 <-- ^mot/lg	JUMP',NE EXIT$	LOAD.L	D5,D3	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX	DICO_	SYNO		; synonyme du mot ...	PUSH.W	D7	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX	POP.W	D7	JUMP',NE EXIT$	COMP.W	D3,#F1		; remplace ?	JUMP',NE EXIT$	LOAD.L	D3,D0	CALL	DICOCHMOT	; change un motEXIT$:	CALL	DICOCLTEXT	; ferme le buffer de texte	POPM.L	D0..D6,A1,A3,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; DICOFAMILLE >;============/; Trouve les mots de la mme famille.; in	A4.L	^objet texte;	D4.L	position;	D5.L	nb de caractres; out	D7.W	erreur; mod	D7.WDICOFAMILLE:	PUSHM.L	D0..D6,A1,A3,A4	LOAD.L	A1,A4		; A1 <-- ^objet texte	LOAD.W	D7,#MI_WAITMOUSE	PAGE_	MISC		; met le sablier	LOAD.L	D0,D4	CALL	DICOOPMOT	; A4/D4 <-- ^texte/lg, A3/D3 <-- ^mot/lg	JUMP',NE EXIT$	LOAD.L	D5,D3	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX	DICO_	FAMILLE		; mme famille ...	PUSH.W	D7	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX	POP.W	D7	JUMP',NE EXIT$	COMP.W	D3,#F1		; remplace ?	JUMP',NE EXIT$	LOAD.L	D3,D0	CALL	DICOCHMOT	; change un motEXIT$:	CALL	DICOCLTEXT	; ferme le buffer de texte	POPM.L	D0..D6,A1,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DICONOMB >;=========/; Transforme un nombre.; in	A4.L	^objet texte;	D4.L	position;	D5.L	nb de caractres; out	D7.W	erreur; mod	D7.WDICONOMB:	PUSHM.L	D0..D6,A1,A4	LOAD.L	A1,A4		; A1 <-- ^objet texte	LOAD.W	D7,#MI_WAITMOUSE	PAGE_	MISC		; met le sablier	LOAD.L	D0,D4	CALL	DICOOPTEXT	; A4/D4 <-- ^texte/lg	JUMP',NE EXIT$	LOAD.L	D5,D4	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX	DICO_	CHIFFRE		; transforme un chiffre ...	PUSH.W	D7	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX	POP.W	D7	JUMP',NE EXIT$	COMP.W	D3,#F1		; remplace ?	JUMP',NE EXIT$	LOAD.L	D3,D0	CALL	DICOCHMOT	; change un motEXIT$:	CALL	DICOCLTEXT	; ferme le buffer de texte	POPM.L	D0..D6,A1,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DICOMAJ >;========/; Met  jour les dictionnaires privs.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDICOMAJ:	PUSH.L	D6	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX	LOAD.W	D7,#IO_DICOLOAD	PAGE_	IO		; D6 <-- canal	DICO_	MAJ		; met  jour ...	PUSH.W	D7	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX	POP.W	D7	POP.L	D6	TEST.W	D7		; retour EQ/NE	RET;----------\\; DICOVTEMP >;==========/; Vide TEMP.; in	-; out	D7.W	erreur; mod	D7.WDICOVTEMP:	PUSHM.L	D3,D6	LOAD.W	D7,#IO_DICOLOAD	PAGE_	IO		; D6 <-- canal	CLR.W	D3	DICO_	VTEMP		; vide TEMP	POPM.L	D3,D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; DICODEF >;========/; Choix des dfinitions gnrales.; in	-; out	D7.W	erreur; mod	D7.WDICODEF:	PUSHM.L	D3,D4,D6	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX	LOAD.W	D7,#IO_DICOLOAD	PAGE_	IO		; D6 <-- canal	CLR.W	D3	DICO_	DEF		; choix des dfinitions ...	PUSH.W	D7	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX	POP.W	D7	POPM.L	D3,D4,D6	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DICOOPTEXT >;-----------/; Ouvre le buffer de texte.; in	D4.L	position;	D5.L	nb de caractres; out	A4/D4.L	^texte/lg;	D6.L	canal DICO;	D7.W	erreur; mod	D4.L, D6.L, D7.W, A4.LDICOOPTEXT:	PUSHM.L	D1,D3	LOAD.W	D7,#IO_DICOLOAD	PAGE_	IO		; D6 <-- canal	JUMP',NE EXIT$	CALL	DICOSETPOS	; va au dbut de la zone  vrifier	JUMP',NE EXIT$	LOAD.L	D4,D5	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire pour texte	JUMP',NE EXIT$	LOAD.L	(A5)+ODIPBT,A4	PUSHM.L	D2..D6	LOAD.L	D6,(A1)+OOBCHT	LOAD.L	D2,D4XLOOP$:	CALL	_BUTX_AVANCE	JUMP',NE XEND$	CALL	_BUTX_NOSUPPL	; D3 <-- caractre < 128	LOAD.B	(A4+),D3	; buffer <-- caractres	DEC.L	D2	JUMP,NE XLOOP$XEND$:	POPM.L	D2..D6	LOAD.L	A4,(A5)+ODIPBT	; A4 <-- ^texte	LOAD.L	D4,D5		; D4 <-- lgEXIT$:	POPM.L	D1,D3	TEST.W	D7		; retour EQ/NE	RET;----------\\; DICOOPMOT >;----------/; Ouvre le buffer de texte.; in	D4.L	position;	D5.L	nb de caractres; out	A4/D4.L	^texte/lg;	A3/D3.L	^mot/lg;	D6.L	canal DICO;	D7.W	erreur; mod	D3.L, D4.L, D6.L, D7.W, A3.L, A4.LDICOOPMOT:	PUSHM.L	D0..D2	LOAD.W	D7,#IO_DICOLOAD	PAGE_	IO		; D6 <-- canal	JUMP,NE EXIT$	LOAD.L	D0,#200		; D0 <-- lg  reculer	COMP.L	D0,D4	JUMP',LS 10$	LOAD.L	D0,D410$:	LOAD.L	D1,#200		; D1 <-- lg  avancer	PUSHM.L	D4,D5	CALL	_BUTX_GETINFO	; D3/D4/D5 <-- ?/nb car/?	LOAD.L	D3,D4		; D3 <-- nb car	POPM.L	D4,D5	SUB.L	D3,D4	SUB.L	D3,D5	COMP.L	D1,D3	JUMP',LS 12$	LOAD.L	D1,D312$:	LOAD.L	D2,D4		; D2 <-- position dbut mot	SUB.L	D4,D0	CALL	DICOSETPOS	; va au dbut de la zone  vrifier	JUMP',NE EXIT$	LOAD.L	D4,D5	ADD.L	D4,D0	ADD.L	D4,D1	PUSH.L	D1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire pour texte	POPM.L	D1	JUMP',NE EXIT$	LOAD.L	(A5)+ODIPBT,A4	PUSHM.L	D2..D6	LOAD.L	D6,(A1)+OOBCHT	LOAD.L	D2,D4XLOOP$:	CALL	_BUTX_AVANCE	JUMP',NE XEND$	CALL	_BUTX_NOSUPPL	; D3 <-- caractre < 128	LOAD.B	(A4+),D3	; buffer <-- caractres	DEC.L	D2	JUMP,NE XLOOP$XEND$:	POPM.L	D2..D6	LOAD.L	D4,D2	ADD.L	D4,D5	CALL	DICOSETPOS	; va  la fin du mot	JUMP',NE EXIT$	LOAD.L	A4,(A5)+ODIPBT	; A4 <-- ^texte	LOAD.L	D4,D5	ADD.L	D4,D0	ADD.L	D4,D1		; D4 <-- lg	LOAD.L	A3,#(A4)+(D0.L)	; A3 <-- ^mot	LOAD.L	D3,D5		; D3 <-- lgEXIT$:	POPM.L	D0..D2	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DICOCLTEXT >;-----------/; Ferme le buffer de texte.; in	-; out	-; mod	-DICOCLTEXT:	PUSHM.L	D1,D7,A4	TEST.L	(A5)+ODIPBT	JUMP',EQ EXIT$	LOAD.L	A4,(A5)+ODIPBT	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le buffer de texte	CLR.L	(A5)+ODIPBTEXIT$:	POPM.L	D1,D7,A4	RET;----------\\; DICOCTEXI >;----------/; Cherche si c'est un mot  changer partout.; in	A3/D3.L	^ancien mot/lg; out	D7.W	ok;	 A4/D4.L ^nouveau mot/lg;	D7.W	erreur;	 A4/D4.L inchang; mod	D4.L, D7.W, A4.LDICOCTEXI:	PUSHM.L	D1,D2,A0,A2	LOAD.L	A2,#(A5)+ODIBM	CLR.B	D2	LOAD.W	D7,#1		; D7 <-- pas trouv20$:	COMP.B	D2,(A2)		; fin rencontre ?	JUMP,EQ EXIT$		; oui => EXIT$	LOAD.L	A0,A3	LOAD.L	D1,D330$:	COMP.B	D2,(A2)	JUMP',EQ 34$	DEC.L	D1	JUMP',NS 36$	COMP.B	(A2+),(A0+)	JUMP,EQ 30$	JUMP'	36$34$:	TEST.L	D1	JUMP',EQ 50$36$:	COMP.B	D2,(A2+)	; A2 <-- ^saute ancien mot	JUMP,NE 36$38$:	COMP.B	D2,(A2+)	; A2 <-- ^saute nouveau mot	JUMP,NE 38$	JUMP	20$50$:	LOAD.L	A4,#(A2)+1	; A4 <-- ^nouveau mot	LOAD.L	A2,A4	LOAD.L	D4,#-152$:	INC.L	D4		; D4 <-- lg nouveau mot	COMP.B	D2,(A2+)	JUMP,NE 52$	CLR.W	D7		; D7 <-- trouvEXIT$:	POPM.L	D1,D2,A0,A2	TEST.W	D7		; retour EQ/NE	RET;----------\\; DICOCTMEM >;----------/; Mmorise un mot  changer partout.; in	A3/D3.L	^ancien mot/lg;	A4/D4.L	^nouveau mot/lg; out	-; mod	D7.WDICOCTMEM:	PUSHM.L	D2..D4,A0,A2..A4	LOAD.L	A2,#(A5)+ODIBM	LOAD.L	A0,A2	CLR.B	D220$:	COMP.B	D2,(A2)		; fin rencontre ?	JUMP',EQ 30$		; oui => 30$22$:	COMP.B	D2,(A2+)	; A2 <-- ^saute ancien mot	JUMP,NE 22$24$:	COMP.B	D2,(A2+)	; A2 <-- ^saute nouveau mot	JUMP,NE 24$	JUMP	20$30$:	ADD.L	A0,#LDIBM	SUB.L	A0,D3	SUB.L	A0,D4	SUB.L	A0,#2		; A0 <-- ^adresse  ne pas dpasser	COMP.L	A2,A0		; reste assez de place ?	JUMP,HS EXIT$		; non => EXIT$40$:	LOAD.B	(A2+),(A3+)	; ODIBM <-- ancien mot	DEC.W	D3	JUMP,NE 40$	CLR.B	(A2+)42$:	LOAD.B	(A2+),(A4+)	; ODIBM <-- nouveau mot	DEC.W	D4	JUMP,NE 42$	CLR.B	(A2+)	CLR.B	(A2+)EXIT$:	POPM.L	D2..D4,A0,A2..A4	RET;---------\\; DICOMASC >;---------/; Met  jour l'ascenseur  une position donne.; in	D3.L	position; out	-; mod	D7.WDICOMASC:	PUSHM.L	D4,D6	LOAD.L	D6,(A1)+OOBCHT	LOAD.L	D4,D3	CALL	_BUTX_SETPOS	; va au dbut du mot  changer	POPM.L	D4,D6	RET;----------\\; DICOCHMOT >;----------/; Change un mot dans le texte.; in	D0.L	position dbut phrase;	D3.L	position dbut ancien mot;	A4/D4.L	^nouveau mot/lg;	D5.L	lg de l'ancien mot; out	D0.L	position dbut phrase;	D7.W	erreur; mod	D0.L, D7.WDICOCHMOT:	PUSHM.L	D1..D6,A4	LOAD.L	D6,(A1)+OOBCHT	ADD.L	D0,D4	SUB.L	D0,D5		; D0 <-- nouvelle position	PUSH.L	D0	LOAD.W	D1,D4		; D1 <-- lg nouveau mot	LOAD.W	D0,D5		; D0 <-- lg ancien mot	LOAD.L	D4,D3	CALL	_BUTX_SETPOS	; va au dbut du mot  changer	JUMP,NE EXIT$	CALL	EDSPYCURS	; renseigne les espionsLOOP$:	TEST.W	D0	JUMP',EQ KOLD$	CALL	_BUTX_AVANCE	CALL	_BUTX_DELETE	; dtruit un caractre de l'ancien mot	DEC.W	D0	LOAD.B	D2,D3KOLD$:	LOAD.B	D3,(A4+)	COMP.B	D2,#'A	JUMP',LO INSERT$	COMP.B	D2,#'Z		; lettre majuscule ?	JUMP',LS MAJ$		; oui => MAJ$	COMP.B	D2,#H'80	JUMP',LO INSERT$	COMP.B	D2,#H'9F	; lettre majuscule ?	JUMP',LS MAJ$		; oui => MAJ$	COMP.B	D2,#H'A8	JUMP',LO INSERT$	COMP.B	D2,#H'AB	; lettre majuscule ?	JUMP',HI INSERT$	; non => INSERT$MAJ$:	CALL	_BUTX_MINMAJINSERT$:	CALL	_BUTX_INSERT	; insre un caractre du nouveau mot	JUMP',NE EXIT$	DEC.W	D1	JUMP,NE LOOP$ELOOP$:	DEC.W	D0	JUMP',NS END$	CALL	_BUTX_AVANCE	CALL	_BUTX_DELETE	; dtruit un caractre de l'ancien mot	JUMP	ELOOP$END$:	LOAD.L	A4,A1		; A4 <-- ^objet	CALL	EDAFMAJALLv	; affiche le pav de texte	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	D0		; D0 <-- nouvelle position	POPM.L	D1..D6,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DICOMAMOT >;----------/; Marque un mot dans le texte (>...<).; in	D0.L	position dbut phrase;	D3.L	position dbut mot;	D4.L	lg du mot; out	D0.L	position dbut phrase;	D7.W	erreur; mod	D0.L, D7.WDICOMAMOT:	PUSHM.L	D2..D6,A4	LOAD.L	D6,(A1)+OOBCHT	ADD.L	D0,#2		; D0 <-- nouvelle position	LOAD.W	D2,D4		; D2 <-- lg du mot	LOAD.L	D4,D3	CALL	_BUTX_SETPOS	; va au dbut du mot  marquer	JUMP',NE EXIT$	CALL	EDSPYCURS	; renseigne les espions	CALL	_BUTX_AVANCE	CALL	_BUTX_RECULE	LOAD.B	D3,#MARKDM	CALL	_BUTX_INSERTLOOP$:	DEC.W	D2	JUMP',NS END$	CALL	_BUTX_AVANCE	JUMP	LOOP$END$:	LOAD.B	D3,#MARKFM	CALL	_BUTX_INSERT	LOAD.L	A4,A1		; A4 <-- ^objet	CALL	EDAFMAJALLv	; affiche le pav de texte	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D6,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DICOSETPOS >;-----------/; Positionne le curseur.; in	D4.L	nouvelle position; out	D7.W	erreur; mod	D7.WDICOSETPOS:	PUSH.L	D6	LOAD.L	D6,(A1)+OOBCHT	CALL	_BUTX_SETPOS	POP.L	D6	TEST.W	D7		; retour EQ/NE	RET	.END