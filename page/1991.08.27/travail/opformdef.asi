	.CHAP	OPFORMDEF.ASI;	----------------------------------------;		(C) 1990 - Pierre Arnaud;	----------------------------------------;	Source de la gestion des dfinitions des formules dans l'objet;	"formule" de PAGE.;	FORDEFOPEN, ouvre les ressources;	FORDEFCLOSE, ferme les ressources;	FORDEFGET, demande le pointeur  une dfinition de formule;	FORTXTOPEN, initialise le texte d'une formule (rien);	FORTXTCLOSE, libre le texte d'une formule;	FORTXTCOMPACT, compactifie  la plus petite taille;	FORTXTEXTEND, tend pour dition;	FORTXTIOREAD, prend un nouveau texte d'une formule;	FORTXTIOWRITE, sauve un texte d'une formule;	FORCOPYMEM, copie de A3 -> A4;	Date      Rv	Commentaire;	-------------------------------------------------------------------------------;	27/03/90  0.0	Dbut des travaux;	-------------------------------------------------------------------------------;-------------\\;  FORDEFOPEN  >;=============/; Charge les dfinitions de formules en mmoire.; in	A0.32	canal; out	D7.16	ok/erreur; mod	D7.16FORDEFOPEN:	PUSHM.32 D0|D1|D2|D3|D4|A0|A2|A3|A5	MOVE.32	A0,A5	MOVE.16	#RES_FIRST,D3	MOVE.32	#R16^RES$,A3	LIB_	OPEN				; ouvre la librairie RES	JUMP,NE	R8^ERR$	MOVE.16	D1,{A5}+OCANLIB			; canal	MOVE.32	#R16^NOM$,A3	MOVE.32	#2**BRSOPCACHE,D2	MOVE.32	#RESREV*16'1000+RESVER,D4	RES_	OPEN				; ouvre le fichier de ressources	JUMP,NE	R8^ER$	MOVE.32	A2,{A5}+OCANRES	MOVE.32	#RtypFORDEF,D0	RES_	GETTYPE				; demande handle + nb ressources de ce type	JUMP,EQ	R8^OK$CLOS$:	RES_	CLOSE	MOVE.16	#ERPIOFORM,D7			; format i/o incorrectER$:	PUSH.16	D7	MOVE.16	{A5}+OCANLIB,D1	LIB_	CLOSE				; ferme RES si pas utilisable	POP.16	D7	JUMP	R8^ERR$OK$:	MOVE.16	D1,{A5}+ONBFORDEF	MOVE.32	A0,{A5}+OTYPFORDEF		; sauve handle aux df. de formules	MOVE.32	#RtypRASTER,D0	RES_	GETTYPE				; demande handle + nb ressources de ce type	JUMP,NE	R8^CLOS$	MOVE.32	A0,{A5}+OTYPRASTER		; sauve handle aux rasters	MOVE.16	#RES_GET,D3	LIB_	GETAD				; acclre l'accs aux ressources	MOVE.32	A3,{A5}+ORESGETERR$:	POPM.32	D0|D1|D2|D3|D4|A0|A2|A3|A5	TEST.16	D7	RETNOM$:	.ASCIZ	"(:,#:)GRA_FORM.RS"RES$:	.ASCIZ	"RES"	.EVEN;--------------\\;  FORDEFCLOSE  >;==============/; Libre les dfinitions de formules.; in	A0.32	canal; out	D7.16; mod	D7.16FORDEFCLOSE:	PUSHM.32 D1|D2|A2	MOVE.32	{A0}+OCANRES,A2	MOVE.32	#0,D2	RES_	CLOSE				; ferme le fichier de ressources	MOVE.16	{A0}+OCANLIB,D1	LIB_	CLOSE				; libaire la librairieERR$:	POPM.32	D1|D2|A2	TEST.16	D7	RET;------------\\;  FORDEFGET  >;============/; Demande la dfinition d'une formule; in	A0.32	canal;	D1.32	numro de la dfinition; out	A4.32	^dfinition;	D4.16	taille;	D7.16	erreur; mod	D4.32, D7.16, A4.32FORDEFGET:	PUSHM.32 D2|A0|A2	MOVE.32	{A0}+OCANRES,A2			;  canal	MOVE.32	{A0}+ORESGET,A4			; ^routine RES_GET	MOVE.32	{A0}+OTYPFORDEF,A0		;  handle du type	MOVE.32	#2**BRSGETPOINTER+2**BRSGETSIZE,D2	CALL	{A4}				; RES_GET super-rapideERR$:	POPM.32	D2|A0|A2	TEST.16	D7	RET;-------------\\;  FORTXTOPEN  >;=============/; Initialise un texte pour une instance de formule.; in	A0.32	canal;	A4.32	^instance; out	D7.16	erreur; mod	D7.16FORTXTOPEN:	PUSHM.32 D1|D4|A4|A5	MOVE.32	A4,A5				; ^instance	MOVE.32	#MTYPCP,D1	MOVE.32	{A5}+OOBPTXT,A4	COMP.32	#0,A4	JUMP,EQ	R8^OK$	GESMEM	?GIVMEM				; rend la mmoire actuelleOK$:	MOVE.32	#TXTSIZE,D4	GESMEM	?GETMEM				; demande la mmoire pour la formule	JUMP,NE	R8^ERR$	MOVE.32	A4,{A5}+OOBPTXT			; ^zone de texte	MOVE.32	D4,{A5}+OOBTXTSIZE		; taille disponible	MOVE.32	#2,{A5}+OOBTXTUSE		; taille rellement disponible	CLR.16	{A4}				; place le terminateurERR$:	POPM.32	D1|D4|A4|A5	TEST.16	D7	RET;--------------\\;  FORTXTCLOSE  >;==============/; Dtruit un texte d'une instance de formule; in	A0.32	canal;	A4.32	^instance; out	D7.16	erreur; mod	D7.16FORTXTCLOSE:	PUSHM.32 D1|A4|A5	MOVE.32	A4,A5				; ^instance	MOVE.32	#MTYPCP,D1	MOVE.32	{A5}+OOBPTXT,A4	COMP.32	#0,A4	JUMP,EQ	R8^OK$	GESMEM	?GIVMEM				; rend la mmoire actuelleOK$:	CLR.32	{A5}+OOBPTXT			; ^zone de texte	CLR.32	{A5}+OOBTXTSIZE			; taille disponible	CLR.32	{A5}+OOBTXTUSE			; taille rellement disponibleERR$:	POPM.32	D1|A4|A5	TEST.16	D7	RET;----------------\\;  FORTXTCOMPACT  >;================/; Compactifie le tampon  la taille minimale; in	A0.32	canal;	A4.32	^instance; out	D7.16	erreur; mod	D7.16FORTXTCOMPACT:	PUSHM.32 D4|A4|A5	MOVE.16	#ERPBIP,D7			; fait un bip si pas possible	MOVE.32	A4,A5				; ^instance	MOVE.32	{A5}+OOBPTXT,A4	COMP.32	#0,A4				; rien ?	JUMP,EQ	R8^ERR$				; non => fin	CLR.16	D7	MOVE.32	{A5}+OOBTXTUSE,D4	COMP.32	{A5}+OOBTXTSIZE,D4		; besoin de rduire ?	JUMP,EQ	R8^ERR$				; non => fin  	GESMEM	?TRUNCMEM	MOVE.32	D4,{A5}+OOBTXTSIZE		; nouvelle tailleERR$:	POPM.32	D4|A4|A5	TEST.16	D7	RET;---------------\\;  FORTXTEXTEND  >;===============/; Etend le tampon pour l'dition; in	A0.32	canal;	A4.32	^instance; out	D7.16	erreur; mod	D7.16FORTXTEXTEND:	PUSHM.32 D1|D4|A3|A4|A5	MOVE.32	A4,A5				; ^instance	MOVE.32	{A5}+OOBPTXT,A3	MOVE.32	#MTYPCP,D1	MOVE.32	{A5}+OOBTXTUSE,D4	ADD.32	#TXTSIZE,D4	GESMEM	?GETMEM				; demande mmoire pour zone rceptrice	JUMP,NE	R8^ERR$	MOVE.32	D4,{A5}+OOBTXTSIZE		; mmorise nouvelle taille	MOVE.32	A4,{A5}+OOBPTXT			; nouveau pointeur	MOVE.32	{A5}+OOBTXTUSE,D4	CALL	FORCOPYMEM			; copie A3 -> A4	MOVE.32	A3,A4	GESMEM	?GIVMEM				; rend l'ancienne tranche mmoireERR$:	POPM.32	D1|D4|A3|A4|A5	TEST.16	D7	RET;---------------\\;  FORTXTIOREAD  >;===============/; Charge le texte d'une formule; in	A0.32	canal;	A4.32	^instance; out	D7.16	erreur; mod	D7.16FORTXTIOREAD:	PUSHM.32 D1|D4|A4|A5	MOVE.32	A4,A5				; ^instance	MOVE.32	#MTYPCP,D1	MOVE.32	{A5}+OOBTXTUSE,D4		; taille  lire en plus	GESMEM	?GETMEM				; demande la mmoire (compact) pour la formule	JUMP,NE	R8^ERR$	MOVE.32	#IO_RDMANY,D7			; lit la suite ensuite !	PAGE_	IO		MOVE.32	A4,{A5}+OOBPTXT			; ^zone de texte	MOVE.32	D4,{A5}+OOBTXTSIZE		; taille disponibleERR$:	POPM.32	D1|D4|A4|A5	TEST.16	D7	RET;----------------\\;  FORTXTIOWRITE  >;================/; Sauve le texte d'une formule; in	A0.32	canal;	A4.32	^instance; out	D7.16	erreur; mod	D7.16FORTXTIOWRITE:	PUSHM.32 D1|D4|A4|A5	MOVE.32	A4,A5				; ^instance	MOVE.32	{A5}+OOBTXTUSE,D4		; taille  crire en plus	MOVE.32	{A5}+OOBPTXT,A4	MOVE.32	#IO_WRMANY,D7			; crit  la suite	PAGE_	IOERR$:	POPM.32	D1|D4|A4|A5	TEST.16	D7	RET;-------------\\;  FORCOPYMEM  >;=============/; Copie une tranche mmoire dans une autre.; in	D4.32	taille (paire & non nulle);	A3.32	^tranche de dpart;	A4.32	^tranche d'arrive; out	-; mod	-FORCOPYMEM:	PUSHM.32 D4|A3|A4	SR.16	#1,D4	DEC.16	D4DO$:	MOVE.16	{A3+},{A4+}			; copie rapidement	DJ.16,NMO D4,DO$ERR$:	POPM.32	D4|A3|A4	TEST.16	D7	RET	.END