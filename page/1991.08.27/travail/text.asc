	.TITLE	TEXT.ASC	.PROC	M680002	.REF	SMAKY	.REF	BUTXPCVAR	=	0PCCODE	=	1; Constantes; ----------LBUMOT	=	50		; lg max d'un motLBUCOUP	=	50		; nb max de coupures dans un mot	.PC	PCVAR	.LOC	0OCHBUTX:.BLKB	2		; canal module BUTXOBUMOT:	.BLKB	LBUMOT		; mot  couperOBULMO:	.BLKB	LBUMOT*2	; positions des caractres du mot  couperOBUCOUP:.BLKB	LBUCOUP+2	; coupures de motsLGVAR:	.PC	PCCODE	.LOC	0START:	LOAD.L	A5,#R16"VAR	LOAD.L	A3,#R16"NMBUTX	LOAD.W	D3,#BUTX_FIRST	LIB_	OPEN	JUMP,NE ERFAT	LOAD.W	(A5)+OCHBUTX,D1	LOAD.W	D1,(A5)+OCHBUTX	LIB_	CLOSEERFAT:	EXIT;-------------\\; CARCOUPELINE >;=============/; Dtermine o il faut couper dans une longue ligne.; Cette routine est la base de tous les modes de justification.; N'avance pas le curseur dans la ligne !; in	A1.L	^objet texte;	D4.W	largeur maximale; out	D2.L	nb de caractre  avancer (0..n);	D3.B	info eol, voir (*);	D4.W	largeur de la ligne;	D5.W	nb d'espaces (0..n); mod	D2.L, D3.L, D4.L, D5.L, D7.W; (*)	zro	n'affiche rien et justifie;	tiret	affiche "-" et justifie;	CR	n'affiche rien et ne justifie pas	.PC	PCVAR	.LOC	0OCCLPOS:.BLKB	4		; position dbut de la ligneOCCLPDL:.BLKB	2		; no position dbut de la ligneOCCLPFL:.BLKB	2		; no position fin de la ligneOCCLLGM:.BLKB	2		; largeur maximaleOCCLNBC:.BLKB	2		; nombre de caractres dans le motOCCLNBS:.BLKB	2		; nombre d'espaces totalLCCL:	.PC	PCCODECARCOUPELINE:	PUSHM.L	D0,D1	SUB.L	SP,#LCCL	; SP <-- ^variables locales	LOAD.W	(SP)+OCCLLGM,D4	; OCCLLGM <-- lg max	BUTX_	POSSAVE		; D4 <-- no de la position	LOAD.W	(SP)+OCCLPDL,D4	BUTX_	GETPOS		; D4 <-- position	LOAD.L	(SP)+OCCLPOS,D4	CLR.W	(SP)+OCCLNBC	CLR.W	(SP)+OCCLNBS	CLR.W	D1		; D1 <-- position dans la ligneSLOOP$:	COMP.W	D1,(SP)+OCCLLGM	; largeur maximale atteinte ?	JUMP,HI OUTL$		; oui => OUTL$	BUTX_	AVANCE		; D3/D4/D5 <-- caractre suivant	JUMP,NE EOT$	COMP.B	D3,#CR	JUMP,EQ EOL$	COMP.B	D3,#EOP	JUMP,EQ EOL$	INC.W	(SP)+OCCLNBC	; OCCLNBC <-- +1 caractre	CALL	CARCHASSE	; D5 <-- chasse	ADD.W	D1,D5		; D1 <-- avance dans la ligne	COMP.B	D3,#SPACE	JUMP,EQ SLOOP$CLOOP$:	COMP.W	D1,(SP)+OCCLLGM	; largeur maximale atteinte ?	JUMP,HI OUTL$		; oui => OUTL$	BUTX_	AVANCE		; D3/D4/D5 <-- caractre suivant	JUMP,NE EOT$	COMP.B	D3,#CR	JUMP,EQ EOL$	COMP.B	D3,#EOP	JUMP,EQ EOL$	INC.W	(SP)+OCCLNBC	; OCCLNBC <-- +1 caractre	CALL	CARCHASSE	; D5 <-- chasse	ADD.W	D1,D5		; D1 <-- avance dans la ligne	COMP.B	D3,#SPACE	JUMP,NE CLOOP$	CLR.W	(SP)+OCCLNBC	; OCCLNBC <-- rz avance dans mot	INC.W	(SP)+OCCLNBS	; OCCLNBS <-- +1 espace	JUMP	SLOOP$OUTL$:	TEST.W	(SP)+OCCLNBS	; un seul mot ?	JUMP',NE CMGO$		; non => CMGO$C1GO$:				; oui =>	BUTX_	RECULE		; D3/D4/D5 <-- caractre prcdent	CALL	CARCHASSE	; D5 <-- chasse du caractre	SUB.W	D1,D5		; D1 <-- recule dans la ligne	BUTX_	POSSAVE		; D4 <-- no de la position	LOAD.W	(SP)+OCCLPFL,D4	LOAD.W	D4,(SP)+OCCLPDL	; D4 <-- no position dbut ligne	BUTX_	POSBEGIN	; revient au dbut de la ligne	LOAD.W	D2,(SP)+OCCLLGM	; D2 <-- lg max coupable	LOAD.W	D3,D2		; D3 <-- largeur totale	CALL	CARCOUPEMOT	; essaye de couper dans le mot suivant	JUMP',NE C1NOT$	LOAD.W	D4,(SP)+OSSLPFL	; D4 <-- no position fin ligne	BUTX_	POSCANCEL	LOAD.W	D1,D2		; D1 <-- largeur de la ligne	JUMP'	COUPE$C1NOT$:	LOAD.W	D4,(SP)+OSSLPFL	; D4 <-- no position fin ligne	BUTX_	POSEND		; va  la fin de la ligne	JUMP	EOL0$CMGO$:	DEC.W	(SP)+OCCLNBS	; OCCLNBS <-- ne compte pas le dernier espace	LOAD.W	D2,(SP)+OCCLNBC	; D2 <-- nb de caractres dans le dernier mot	JUMP',EQ CMREND$CMRLOOP$:	BUTX_	RECULE		; D3/D4/D5 <-- caractre prcdent	CALL	CARCHASSE	; D5 <-- chasse du caractre	SUB.W	D1,D5		; D1 <-- recule dans la ligne	DEC.W	D2	JUMP,NE CMRLOOP$CMREND$:	LOAD.W	D2,(SP)+OCCLLGM	SUB.W	D2,D1		; D2 <-- lg max coupable	BUTX_	RECULE		; D3/D4/D5 <-- caractre prcdent (espace)	CALL	CARCHASSE	; D5 <-- chasse du dernier espace	SUB.W	D1,D5		; D1 <-- n'affiche pas le dernier espace	BUTX_	AVANCE		; annule le RECULE !	LOAD.W	D3,(SP)+OCCLLGM	; D3 <-- largeur totale	CALL	CARCOUPEMOT	; essaye de couper dans le mot suivant	JUMP',NE EOL0$	INC.W	(SP)+OCCLNBS	; OCCLNBS <-- un mot de plus	ADD.W	D1,D5		; D1 <-- ajoute le dernier espace	ADD.W	D1,D2		; D1 <-- resteCOUPE$:	LOAD.B	D3,#'-		; D3 <-- info eol (faudra ajouter tiret)	TEST.L	D2:#16		; tiret dj dans le mot ?	JUMP',BC END$		; non => END$EOL0$:EOT$:	CLR.B	D3		; D3 <-- info eolEOL$:END$:	BUTX_	GETPOS		; D4 <-- position	SUB.L	D4,(SP)+OCCLPOS	; D4 <-- avance (nb car)	LOAD.L	D2,D4		; D2 <-- nb de caractres  avancer	LOAD.W	D4,D1		; D4 <-- largeur de la ligne	LOAD.W	D5,(SP)+OCCLNBS	; D5 <-- nb d'espaces	ADD.L	SP,#LCCL	; POP variables	POPM.L	D0,D1	RET;------------\\; CARCOUPEMOT >;------------/; Essaye de couper dans un mot.;;	   D2;	|<---->|;	 construction;	 ^;	 A3; in	A1.L	^objet texte;	D2.W	lg max coupable;	D3.W	lg totale de la ligne; out	D2.W	lg rcupre grce  la coupure;		si 2^16 = 1 --> tiret dj dans le mot;	D7.W	ok/erreur; mod	D2.L, D7.W	.PC	PCVAR	.LOC	0OCCMPOS:.BLKB	4		; position dbut motOCCMPDM:.BLKB	2		; no position dbut du motOCCMLGC:.BLKB	2		; largeur max coupableLCCM:	.PC	PCCODECARCOUPEMOT:	PUSHM.L	D0,D1,D3..D5,A2..A4	SUB.L	SP,#LCCM	; SP <-- ^variables locales	BUTX_	POSSAVE	LOAD.W	(SP)+OCCMPDM,D4	; OCCMPDM <-- no position dbut mot	BUTX_	GETPOS	LOAD.L	(SP)+OCCMPOS,D4	; OCCMPOS <-- position dbut mot	LOAD.W	(SP)+OCCMLGC,D2	; OCCMLGC <-- lg max coupable	JUMP,LE ERROR$	TEST.B	(A1)+OOBJUF:#BTXJUM ; autorise les divisions dans les mots ?	JUMP,BC ERROR$		; non => ERROR$	LOAD.W	D1,D2	MUL.WU	D1,#100	DIV.WU	D1,D3		; D1 <-- lg max coupable en %	CLR.W	D4	LOAD.B	D4,(A1)+OOBJUD	; D4 <-- limite choisie par l'utilisateur	COMP.W	D1,D4	JUMP,LO ERROR$	LOAD.L	A3,#(A5)+OBUMOT	; A3 <-- ^buffer pour mot	LOAD.L	A2,#(A5)+OBULMO	; A2 <-- ^buffer pour lg caractres	LOAD.W	D1,#LBUMOT-1	; D1 <-- nb car. max pour le mot	CLR.W	D0		; D0 <-- position dans le mot	CLR.W	D2		; D2 <-- compte nb car. avancsPLOOP$:	BUTX_	AVANCE		; D3/D4/D5 <-- caractre suivant	JUMP',NE PEND$	COMP.B	D3,#SPACE	; fin du mot ?	JUMP',EQ PEND$		; oui => PEND$	COMP.B	D3,#TAB	JUMP',EQ PEND$	COMP.B	D3,#CR	JUMP',EQ PEND$	COMP.B	D3,#EOP	JUMP',EQ PEND$	INC.W	D2		; D2 <-- +1 caractre avanc	LOAD.B	(A3+),D3	; OBUMOT <-- un caractre	LOAD.W	(A2+),D0	; OBULMO <-- position	CALL	CARCHASSE	; D5 <-- chasse du caractre	ADD.W	D0,D5		; D0 <-- position dans le mot	DEC.W	D1	JUMP,NE	PLOOP$	JUMP	ERROR$PEND$:	TEST.W	D2	JUMP,EQ ERROR$	LOAD.L	A3,#(A5)+OBUMOT	; A3 <-- ^mot	LOAD.W	D3,D2		; D3 <-- lg mot	LOAD.L	A4,#(A5)+OBUCOUP ; A4 <-- ^buffer	LOAD.W	D4,#LBUCOUP	; D4 <-- lg buffer	COUPE_	HASH		; cherche la liste des coupures	JUMP,NE ERROR$; Cherche la coupure optimale dans la liste rendue.	CLR.W	D0SLAST$:	INC.W	D0	TEST.B	(A4+)	JUMP,NE	SLAST$	DEC.L	A4		; A4 <-- ^dernire coupure	LOAD.L	A2,#(A5)+OBULMO	; A2 <-- ^buffer pour lg caractresSLOOP$:	DEC.W	D0		; encore une coupure possible ?	JUMP,EQ ERROR$		; non => ERROR$	CLR.L	D2	LOAD.B	D2,(-A4)	; D2 <-- position coupure (nb car)	JUMP,EQ ERROR$	JUMP',NS TIRET$				; coupe en ajoutant un tiret =>	SL.W	D2,#1	LOAD.W	D1,(A2)+(D2.W)	; D1 <-- lg du mot jusque l	SR.W	D2,#1	LOAD.L	D4,(SP)+OCCMPOS	; D4 <-- position dbut mot	ADD.L	D4,D2		; D4 <-- position du futur tiret	BUTX_	SETPOS		; va o ira le tiret	BUTX_	RECULE		; D3/D4/D5 <-- caractre avant le tiret	LOAD.B	D3,#'-	CALL	CARCHASSE	; D5 <-- chasse du tiret	ADD.W	D1,D5		; D1 <-- lg du mot avec le tiret	COMP.W	D1,(SP)+OCCMLGC	; reste assez de place en bout de ligne ?	JUMP,HI SLOOP$		; non => SLOOP$	TCLR.L	D2:#16		; D2 <-- faudra ajouter un tiret	JUMP'	COUPE$TIRET$:				; coupe sans ajouter de tiret =>	TCLR.L	D2:#7	SL.W	D2,#1	LOAD.W	D1,(A2)+(D2.W)	; D1 <-- lg du mot jusque l	SR.W	D2,#1	COMP.W	D1,(SP)+OCCMLGC	; reste assez de place en bout de ligne ?	JUMP,HI SLOOP$		; non => SLOOP$	TSET.L	D2:#16		; D2 <-- tiret dj dans le motCOUPE$:	LOAD.W	D4,(SP)+OCCMPDM	; D4 <-- no position dbut mot	BUTX_	POSEND		; revient au dbut du mot	LOAD.W	D0,D2CPOS$:	BUTX_	AVANCE		; avance jusqu' la coupure	DEC.W	D0	JUMP,NE CPOS$	LOAD.W	D2,D1		; D2 <-- lg rcupre	CLR.W	D7		; D7 <-- coupure effectue	JUMP'	EXIT$ERROR$:	LOAD.W	D4,(SP)+OCCMPDM	; D4 <-- no position dbut mot	BUTX_	POSEND		; revient o l'on tait	LOAD.W	D7,#1		; D7 <-- coupure pas faite !EXIT$:	ADD.L	SP,#LCCM	; POP variables	POPM.L	D0,D1,D3..D5,A2..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; CARMAXH1H2 >;===========/; Cherche les valeurs maximales pour h1 et h2.; in	D2.W		nb de caractre  avancer (0..n); out	(A5)+OTXMH1.W	h1 max;	(A5)+OTXMH2.W	h2 max;	(A5)+OTXMBL.W	ligne de base;	(A5)+OTXMIL.W	interligne; mod	D7.W	.PC	PCVAR	.LOC	0OCMAPDL:.BLKB	2		; no position dbut ligneOCMANBC:.BLKB	2		; nb de caractresOCMAH1C:.BLKB	2		; h1 caractreOCMAH2C:.BLKB	2		; h2 caractreOCMAH1R:.BLKB	2		; h1 rfrence "E"OCMAH2R:.BLKB	2		; h2 rfrence "p"OCMAHIE:.BLKB	2		; +/- hauteur si indice/exposantOCMAIF1:.BLKB	4		; info 1OCMAIF2:.BLKB	4		; info 2LCMA:	.PC	PCCODECARMAXH1H2:	PUSHM.L	D0..D5	SUB.L	SP,#LCMA	; SP <-- ^variables locales	BUTX_	POSSAVE		; D4 <-- no de la position	LOAD.W	(SP)+OCMAPDL,D4	; OCMAPDL <-- no position dbut ligne	CLR.W	(SP)+OCMAH1C	; OCMAH1C <-- h1 max	CLR.W	(SP)+OCMAH2C	; OCMAH2C <-- h2 max	CLR.W	(SP)+OCMAH1R	; OCMAH1R <-- h1 max	CLR.W	(SP)+OCMAH2R	; OCMAH2R <-- h2 max	TEST.W	D2		; D2 <-- nb de caractres	JUMP,EQ END$	LOAD.W	(SP)+OCMANBC,D2	LOAD.L	(SP)+OCMAIF1,#-1	CLR.L	(SP)+OCMAIF2LOOP$:	BUTX_	AVANCE		; D3/D4/D5 <-- caractre suivant	JUMP,NE END$	COMP.B	D3,#CR	JUMP',NE NOVIDE$	COMP.W	(SP)+OCMANBC,#1	JUMP,EQ VIDE$NOVIDE$:	COMP.L	D4,(SP)+OCMAIF1	JUMP',NE CHANGE$	COMP.L	D5,(SP)+OCMAIF2	; toujours le mme gencar ?	JUMP,EQ SAME$		; oui => SAME$CHANGE$:	LOAD.L	(SP)+OCMAIF1,D4	LOAD.L	(SP)+OCMAIF2,D5	LOAD.B	D1,D3		; D1 <-- caractre;	LOAD.L	D4,(SP)+OCMAIF1;	LOAD.L	D5,(SP)+OCMAIF2	LOAD.B	D3,#'E	CALL	CARDIM		; D3/D4/D5 <-- min/max/chasse	SWAP.W	D3	LOAD.W	D0,D3		; D0 <-- h1 de "E"	LOAD.L	D4,(SP)+OCMAIF1	LOAD.L	D5,(SP)+OCMAIF2	LOAD.B	D3,#'p	CALL	CARDIM		; D3/D4/D5 <-- min/max/chasse	SWAP.W	D4		; D4 <-- h2 de "p"	LOAD.W	D3,D0		; D3 <-- h1 de "E"	LOAD.L	D0,(SP)+OCMAIF1	AND.W	D0,#H'FF	; D0 <-- rang de l'exposant (0..2);;????	CLR.W	D5		; D5 <-- normal	TEST.W	D0	JUMP',EQ EXP$	LOAD.W	D5,D3	ASR.W	D5,#1		; D5 <-- 1/2 h1 de "E"	COMP.W	D0,#2	JUMP',EQ EXP$	NEG.W	D5		; D5 <-- -1/2 h1 de "E"EXP$:	LOAD.W	(SP)+OCMAHIE,D5	ADD.W	D3,D5		; D3 <-- h1 selon exposant/indice	JUMP',NC H1REX$	CLR.W	D3H1REX$:	ADD.W	D4,D5		; D4 <-- h2 selon exposant/indice	JUMP',NC H2REX$	CLR.W	D4H2REX$:	COMP.W	D3,(SP)+OCMAH1R	JUMP',LS H1R$	LOAD.W	(SP)+OCMAH1R,D3	; OCMAH1R <-- h1 maxH1R$:	COMP.W	D4,(SP)+OCMAH2R	JUMP',LS H2R$	LOAD.W	(SP)+OCMAH2R,D4	; OCMAH2R <-- h2 maxH2R$:	LOAD.L	D4,(SP)+OCMAIF1	LOAD.L	D5,(SP)+OCMAIF2	LOAD.B	D3,D1SAME$:	CALL	CARDIM		; D3/D4/D5 <-- min/max/chasse	SWAP.W	D3		; D3 <-- h1 du caractre	SWAP.W	D4		; D4 <-- h2 du caractre	LOAD.W	D5,(SP)+OCMAHIE	ADD.W	D3,D5		; D3 <-- h1 selon exposant/indice	JUMP',NC H1CEX$	CLR.W	D3H1CEX$:	ADD.W	D4,D5		; D4 <-- h2 selon exposant/indice	JUMP',NC H2CEX$	CLR.W	D4H2CEX$:	COMP.W	D3,(SP)+OCMAH1C	JUMP',LS H1C$	LOAD.W	(SP)+OCMAH1C,D3	; OCMAH1C <-- h1 maxH1C$:	COMP.W	D4,(SP)+OCMAH2C	JUMP',LS H2C$	LOAD.W	(SP)+OCMAH2C,D4	; OCMAH2C <-- h2 maxH2C$:	DEC.W	D2		; encore un caractre ?	JUMP,NE LOOP$		; oui => LOOP$END$:	LOAD.W	D2,(SP)+OCMAH1R	OR.W	D2,(SP)+OCMAH2R	; h1 et h2 nuls ?	JUMP',NE NONULL$	; non => NONULL$;;?	LOAD.W	(SP)+OCMAH1R,#20*FACMMPT;;?	LOAD.W	(SP)+OCMAH2R,#20*FACMMPT	CLR.L	D4	CLR.L	D5	LOAD.B	D3,#'E	CALL	CARDIM		; D3/D4/D5 <-- min/max/chasse	SWAP.W	D3		; D3 <-- h1 de "E"	LOAD.W	(SP)+OCMAH1R,D3	LOAD.W	(SP)+OCMAH1C,D3	CLR.L	D4	CLR.L	D5	LOAD.B	D3,#'p	CALL	CARDIM		; D3/D4/D5 <-- min/max/chasse	SWAP.W	D4		; D4 <-- h2 de "p"	LOAD.W	(SP)+OCMAH2R,D4	LOAD.W	(SP)+OCMAH2C,D4NONULL$:	LOAD.W	(A5)+OTXMH1,(SP)+OCMAH1C	LOAD.W	(A5)+OTXMH2,(SP)+OCMAH2C	LOAD.W	D4,(A1)+OOBILM	LOAD.W	D2,(SP)+OCMAH1R	ADD.W	D2,(SP)+OCMAH2R	COMP.W	D4,D2	JUMP',HS ILMIN$	LOAD.W	D4,D2ILMIN$:	ADD.W	D4,(A1)+OOBILA	JUMP',NC ILOK$	CLR.W	D4ILOK$:	LOAD.W	(A5)+OTXMIL,D4	SUB.W	D4,(SP)+OCMAH1R	SUB.W	D4,(SP)+OCMAH2R	ASR.W	D4,#1	ADD.W	D4,(SP)+OCMAH1R	LOAD.W	(A5)+OTXMBL,D4	JUMP	EXIT$VIDE$:	TEST.W	(A1)+OOBILV	JUMP,LE NOVIDE$	LOAD.W	D0,(A1)+OOBILV	; D0 <-- h1 de ILV	CLR.W	D1		; D1 <-- h2 nul	CALL	CARDIM		; D3/D4/D5 <-- min/max/chasse	SWAP.W	D3		; D3 <-- h1 de <CR>	SWAP.W	D4		; D4 <-- h2 de <CR>	LOAD.W	D5,D3	ADD.W	D5,D4		; D5 <-- h1+h2	COMP.W	D5,D0	JUMP',HI VIDE4$	SUB.W	D0,D4	LOAD.W	D1,D4VIDE4$:	LOAD.W	(A5)+OTXMBL,D0	LOAD.W	(A5)+OTXMH1,D0	LOAD.W	(A5)+OTXMH2,D1	ADD.W	D0,D1	LOAD.W	(A5)+OTXMIL,D0;	JUMP'	EXIT$EXIT$:	LOAD.W	D4,(SP)+OCMAPDL	; D4 <-- no position dbut ligne	BUTX_	POSEND		; revient au dbut de la ligne	ADD.L	SP,#LCMA	; POP variables	POPM.L	D0..D5	RET;----------\\; CARCHASSE >;==========/; Donne la chasse d'un caractre.; in	D3.B	caractre;	D4.L	info 1;	D5.L	info 2; out	D5.W	chasse (dx);	D7.W	erreur; mod	D5.L, D7.WCARCHASSE:	PUSHM.L	EXIT$:	POPM.L		TEST.W	D7		; retour EQ/NE	RET;-------\\; CARDIM >;=======/; Donne les dimensions de la bote d'un caractre.; in	D3.B	caractre;	D4.L	info 1;	D5.L	info 2; out	D3.L	min (dy;dx);	D4.L	max (dy;dx);	D5.W	chasse (dx);	D7.W	erreur; mod	D3.L, D4.L, D5.L, D7.WCARDIM:	PUSHM.L	EXIT$:	POPM.L		TEST.W	D7		; retour EQ/NE	RETNMBUTX:	.ASCIZ	"BUTX"VAR:	.FILLB	LGVAR,0	.END	START