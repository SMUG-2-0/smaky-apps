	.SBTTL	OPCHARDBOX.ASI;--------\\; XopDGET >;========/; Donne le caractre slectionn.; in	A0.L	canal;	A4.L	^table du caractre/nil si par dfaut; out	D3.W	caractre slectionn;	D7.W	erreur; mod	D3.L, D7.WXopDGET:	PUSH.L	A4	COMP.L	A4,#0		; objet par dfaut ?	JUMP',NE NODEF$		; non => NODEF$	LOAD.L	A4,(A0)+OPDEF	; A4 <-- ^objet caractre par dfautNODEF$:	LOAD.W	D3,(A4)+OTACSEL	; D3 <-- caractre slectionn	POP.L	A4	CLR.W	D7		; retour EQ	RET;--------\\; XopDPUT >;========/; Spcifie le caractre.; in	A0.L	canal;	A4.L	^table du caractre/nil si par dfaut;	D3.W	caractre  slectionner; out	D7.W	erreur; mod	D7.WXopDPUT:	PUSH.L	A4	COMP.L	A4,#0		; objet par dfaut ?	JUMP',NE NODEF$		; non => NODEF$	LOAD.L	A4,(A0)+OPDEF	; A4 <-- ^objet caractre par dfautNODEF$:	LOAD.W	(A4)+OTACSEL,D3	; slectionne un caractre	POP.L	A4	CLR.W	D7		; retour EQ	RET;------------\\; XopDTSELECT >;============/; Choisi et/ou modifie un caractre temporaire  utiliser.; in	A0.L	canal;	A4.L	^table des caractres/nil si par dfaut;	D2.W	caractre  slectionner; out	D2.W	caractre slectionn;	D3.L	dernire touche (F1/F0);	D4.W	nb de caractres modifis;	D7.W	erreur; mod	D2.L, D3.L, D4.L, D7.WXopDTSELECT:	PUSH.L	A4	COMP.L	A4,#0		; objet par dfaut ?	JUMP',NE NODEF$		; non => NODEF$	LOAD.L	A4,(A0)+OPDEF	; A4 <-- ^objet caractre par dfautNODEF$:	PUSH.W	(A4)+OTACSEL	; stack <-- caractre slectionn	LOAD.W	(A4)+OTACSEL,D2	; OTACSEL <-- caractre slectionn temporairement	CALL	XopDSELECT	; choisi/modifie un caractre ...	LOAD.W	D2,(A4)+OTACSEL	; D2 <-- caractre slectionn temporairement	POP.W	(A4)+OTACSEL	; OTACSEL <-- caractre slectionn initialement	POP.L	A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; XopDSELECT >;===========/; Choisi un caractre  utiliser.; in	A0.L	canal;	A4.L	^table du caractre/nil si par dfaut; out	D3.L	dernire touche (F1/F0);	D4.W	nb de modifications;	D7.W	erreur; mod	D3.L, D4.L, D7.WXopDSELECT:	PUSHM.L	D0..D2,D5,A0..A5	LOAD.L	A5,A0		; A5 <-- ^variables globales	LOAD.L	A0,(A5)+OPDDIS	; A0 <-- ^descripteur fentre	COMP.L	A4,#0		; objet par dfaut ?	JUMP',NE NODEF$		; non => NODEF$	LOAD.L	A4,(A5)+OPDEF	; A4 <-- ^objet caractre par dfautNODEF$:	LOAD.L	(A5)+OPTAB,A4	; OPTAB <-- ^table du caractre	CLR.W	D0		; D0 <-- nb de modifsREFAIT$:	LOAD.L	A4,(A5)+OPTAB	; A4 <-- ^table du caractre	LOAD.W	D3,(A4)+OTACSEL	; D3 <-- caractre slectionn	CLR.L	D4	TSET.L	D4:D3		; D4 <-- fanions	LOAD.L	A2,#R16"TDBOX_CHAR	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.W	D7,#DB_OPEN	PAGE_	DBOX		; ouvre la DBOX	JUMP,NE EXIT$AFF$:	PUSH.L	D4	LOAD.L	D4,#2^0	LOAD.W	D3,#NBCAR-1AFF2$:	CALL	DBSELAFF	; affiche un nom	RL.L	D4,#1	DECJ.W,NMO D3,AFF2$	POP.L	D4MAJ$:	CALL	DBSELGREY	; met  jour (CREE/MODIFIE) et (SUPPRIME)LOOP$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_CHAR	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#F1	JUMP,EQ USE$	COMP.W	D3,#F4	JUMP',EQ MODIF$	COMP.W	D3,#F7	JUMP,EQ PREND$	COMP.W	D3,#F9	JUMP,EQ SAUVE$	COMP.W	D3,#F0	JUMP,EQ END$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ MAJ$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$MODIF$:	CALL	DBSELPGC	; A4 <-- ^caractre selon les fanions	CALL	DBSELRANG	; D4 <-- rang (0..n)	LOAD.L	A3,(A5)+OPTAB	; A4 <-- ^table du caractre	LOAD.W	(A3)+OTACSEL,D4	; mj. le caractre slectionn	LOAD.W	D7,#DB_CLOSE	PAGE_	DBOX		; ferme la DBOX	LOAD.L	D4,(A3)+OTACFAN	; D4 <-- fanions	CALL	DBOXCHOIX	; choix d'un caractre ...	COMP.W	D3,#F1	JUMP',EQ MODIF4$	COMP.W	D3,#F4	JUMP,NE REFAIT$MODIF4$:	LOAD.L	(A3)+OTACFAN,D4	INC.W	D0		; D0 <-- une modif de plus	JUMP	REFAIT$PREND$:	CALL	CHARPREND	; prend les caractres ...	PUSH.W	D7	LOAD.L	A2,#R16"TDBOX_CHAR	LOAD.W	D7,#DB_RSK	PAGE_	DBOX		; refait les soft-keys	POP.W	D7	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	LOAD.W	D0,#NBCAR	; D0 <-- tous les caractres modifis	JUMP	AFF$SAUVE$:	CALL	CHARSAUVE	; sauve les caractres ...	PUSH.W	D7	LOAD.L	A2,#R16"TDBOX_CHAR	LOAD.W	D7,#DB_RSK	PAGE_	DBOX		; refait les soft-keys	POP.W	D7	JUMP,NE BIP$	JUMP	LOOP$USE$:	CALL	DBSELRANG	; D4 <-- rang (0..n)	LOAD.L	A4,(A5)+OPTAB	; A4 <-- ^table du caractre	LOAD.W	(A4)+OTACSEL,D4	; mj. le caractre slectionnEND$:	LOAD.W	D7,#DB_CLOSE	PAGE_	DBOX		; ferme la DBOX	LOAD.W	D4,D0		; D4 <-- nb de modif(s)	JUMP',EQ EXIT$	INC.L	(A5)+OREGEN	; change le numro de rgnrationEXIT$:	POPM.L	D0..D2,D5,A0..A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBSELAFF >;---------/; Affiche un nom de fonction.; in	D4.L	fanions; out	-; mod	D7.WDBSELAFF:	PUSHM.L	D2..D4,A3,A4	CALL	DBSELPGC	; A4 <-- ^caractre selon les fanions	CALL	DBSELRANG	; D4 <-- rang (0..n)	LOAD.W	D2,D4	OR.W	D2,#2^BDBGCLABEL	DBOX_	GETCO	ADD.W	D3,(A0)+ODFCX	ADD.W	D3,(A0)+ODFCX	ADD.W	D3,(A0)+ODFCX	LIB	?SETCURS	LOAD.L	A3,#(A4)+OCARNM	LOAD.L	A4,A3	LOAD.W	D4,#16+2CNT$:	DEC.W	D4	TEST.B	(A4+)	JUMP,NE CNT$	LIB	?AFTEXT		; affiche le nom	LOAD.B	D3,#MSPACE	LIB	?AFCAR	LOAD.B	D3,D4	LIB	?AFCAR		; efface la fin	POPM.L	D2..D4,A3,A4	RET;----------\\; DBSELGREY >;----------/; Met  jour (UTILISE) et (CREE/MODIFIE).; in	D4.L	fanions; out	-; mod	D7.WDBSELGREY:	PUSHM.L	D2..D4,A3,A4	CALL	DBSELPGC	; A4 <-- ^caractre selon les fanions	LOAD.W	D2,#100!2^BDBGCLABEL!2^BDBGCGREY	TEST.B	(A4)	JUMP',EQ AFF1$	LOAD.W	D2,#100!2^BDBGCLABEL!2^BDBGCFULLAFF1$:	DBOX_	GETCO		; grise/dgrise (UTILISE)	LOAD.W	D2,#101!2^BDBGCLABEL	DBOX_	GETCO	LIB 	?SETCURS	LOAD.L	A3,#R16"CREE$	TEST.B	(A4)	JUMP',EQ AFF2$	LOAD.L	A3,#R16"MODIF$AFF2$:	LIB 	?AFTEXT	POPM.L	D2..D4,A3,A4	RETCREE$:	.ASCIZ	"  CREE   "MODIF$:	.ASCIZ	" MODIFIE "	.EVEN;---------\\; DBSELPGC >;---------/; Donne le pointeur au caractre slection selon les fanions.; in	D4.L	fanions; out	A4.L	^caractre dans l'objet; mod	A4.LDBSELPGC:	PUSH.L	D4	CALL	DBSELRANG	; D4 <-- rang (0..n)	LOAD.L	A4,(A5)+OPTAB	; A4 <-- ^table du caractre	MUL.WU	D4,#LDCAR	ADD.L	A4,D4		; A4 <-- ^dans l'objet	POP.L	D4	RET;----------\\; DBSELRANG >;----------/; Donne le rang en fonction du fanion.; in	D4.L	fanions; out	D4.W	rang (0..n); mod	D4.LDBSELRANG:	PUSH.W	D3	LOAD.W	D3,#-1LOOP$:	INC.W	D3	RR.L	D4,#1	JUMP,CC LOOP$	LOAD.W	D4,D3		; D4 <-- rang	POP.W	D3	RETTDBOX_CHAR:	.W	10$-TDBOX_CHAR	.W	20$-TDBOX_CHAR	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Choix des caractres :"	.B	ODBCR,ODBCR	.B	ODBLABEL,0	.B	ODBLCIRCLE,0!2^7,KEYDBOX/H'100,0	.ASCIZ	"          "	.B	ODBTABX,30	.B	ODBLABEL,8	.B	ODBLCIRCLE,8!2^7,KEYDBOX/H'100,8	.ASCIZ	"          "	.B	ODBTABX,30+30	.B	ODBCR	.B	ODBLABEL,1	.B	ODBLCIRCLE,1!2^7,KEYDBOX/H'100,1	.ASCIZ	"          "	.B	ODBTABX,30	.B	ODBLABEL,9	.B	ODBLCIRCLE,9!2^7,KEYDBOX/H'100,9	.ASCIZ	"          "	.B	ODBCR	.B	ODBLABEL,2	.B	ODBLCIRCLE,2!2^7,KEYDBOX/H'100,2	.ASCIZ	"          "	.B	ODBTABX,30	.B	ODBLABEL,10	.B	ODBLCIRCLE,10!2^7,KEYDBOX/H'100,10	.ASCIZ	"          "	.B	ODBCR	.B	ODBLABEL,3	.B	ODBLCIRCLE,3!2^7,KEYDBOX/H'100,3	.ASCIZ	"          "	.B	ODBTABX,30	.B	ODBLABEL,11	.B	ODBLCIRCLE,11!2^7,KEYDBOX/H'100,11	.ASCIZ	"          "	.B	ODBCR	.B	ODBLABEL,4	.B	ODBLCIRCLE,4!2^7,KEYDBOX/H'100,4	.ASCIZ	"          "	.B	ODBTABX,30	.B	ODBLABEL,12	.B	ODBLCIRCLE,12!2^7,KEYDBOX/H'100,12	.ASCIZ	"          "	.B	ODBCR	.B	ODBLABEL,5	.B	ODBLCIRCLE,5!2^7,KEYDBOX/H'100,5	.ASCIZ	"          "	.B	ODBTABX,30	.B	ODBLABEL,13	.B	ODBLCIRCLE,13!2^7,KEYDBOX/H'100,13	.ASCIZ	"          "	.B	ODBCR	.B	ODBLABEL,6	.B	ODBLCIRCLE,6!2^7,KEYDBOX/H'100,6	.ASCIZ	"          "	.B	ODBTABX,30	.B	ODBLABEL,14	.B	ODBLCIRCLE,14!2^7,KEYDBOX/H'100,14	.ASCIZ	"          "	.B	ODBCR	.B	ODBLABEL,7	.B	ODBLCIRCLE,7!2^7,KEYDBOX/H'100,7	.ASCIZ	"          "	.B	ODBTABX,30	.B	ODBLABEL,15	.B	ODBLCIRCLE,15!2^7,KEYDBOX/H'100,15	.ASCIZ	"          "	.B	ODBCR,ODBCR,ODBCR	.B	ODBLABEL,100	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" UTILISE "	.B	ODBLABEL,101	.B	ODBBOX,0,F4,TDBMEV	.ASCIZ	" MODIFIE "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F7,TDBNORM	.ASCIZ	" PREND "	.B	ODBBOX,0,F9,TDBNORM	.ASCIZ	" SAUVE "	.B	ODBTABX,60-10	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Utilise"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Cre/Modifie"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Prend       Sauve"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_CHAR:	.W	F1,F2,F3,0		DOKF1-TKEY_CHAR	.W	F4,F5,F6,0		DOKF4-TKEY_CHAR	.W	F7,0			DOKF7-TKEY_CHAR	.W	F9,0			DOKF9-TKEY_CHAR	.W	F0,F13,F14,F15,0	DOKF0-TKEY_CHAR	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_CHAR	.W	0;----------\\; DBOXCHOIX >;==========/; Choisi un caractre  utiliser.; in	A4.L	^caractre;	D4.L	fanions; out	D3.L	dernire touche (F1/F4/F0);	D4.L	fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXCHOIX:	PUSHM.L	D1,D2,D5,A1..A4	CALL	DBCHOIXGET	; OCCAR <-- paramtres	LOAD.L	A2,#R16"TDBOX$	LOAD.W	D7,#DB_MEMPT	PAGE_	DBOX		; mj ^table dbox	LOAD.L	A2,#R16"DBCHOIXEXINV	LOAD.W	D7,#DB_MEMAFC	PAGE_	DBOX		; mj ^routine d'affichage	LOAD.L	A2,#R16"TDBOX_CHOIX	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.W	D7,#DB_OPEN	PAGE_	DBOX		; ouvre la DBOX	JUMP,NE EXIT$	PUSH.L	D4	LOAD.W	D2,#200!2^BDBGCLABEL	DBOX_	GETCO	LOAD.L	(A5)+OABCPOS,D3	LOAD.W	D2,#201!2^BDBGCLABEL	DBOX_	GETCO	SUB.W	D3,(A5)+OABCPOS+2	SWAP.W	D3	SUB.W	D3,(A5)+OABCPOS+0	SWAP.W	D3	LOAD.L	(A5)+OABCDIM,D3	ADD.W	(A5)+OABCPOS+2,#+3	ADD.W	(A5)+OABCPOS+0,#-3	ADD.W	(A5)+OABCDIM+2,#+1;	ADD.W	(A5)+OABCDIM+0,#+0	LOAD.L	D3,(A5)+OABCPOS	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	LOAD.L	D4,(A5)+OABCDIM	INC.W	D4	SWAP.W	D4	INC.W	D4	SWAP.W	D4	LOAD.W	D2,#SETDOT	LIB	?DRRECT	LOAD.W	D2,#202!2^BDBGCLABEL	DBOX_	GETCO	LOAD.L	(A5)+OEXEPOS,D3	ADD.W	(A5)+OEXEPOS+2,#+20	ADD.W	(A5)+OEXEPOS+0,#-18+10	LOAD.W	(A5)+OEXEDIM+2,#+56-20	LOAD.W	(A5)+OEXEDIM+0,#+56-20	LIB	?AFTIM	.B	MAPTT	.B	B'10001000	.B	1	.B	0	.EVEN	LOAD.L	D3,(A5)+OEXEPOS	LOAD.L	D4,(A5)+OEXEDIM	LOAD.W	D2,#INVDOT!TTTDOT	LIB	?DRRECT	POP.L	D4REFAIT$:	CALL	DBCHOIXDRAW	; dessine la scroll-liste	CALL	AFFABC		; affiche "Abc"	CLR.W	D2AFF$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_AFF	PAGE_	DBOX		; affiche le paramtre	INC.W	D2	COMP.W	D2,#4	JUMP,LO AFF$	CLR.W	D2NLINE$:	CALL	DBCHOIXEXINV	; allume l'exempleNLINEI$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_MEDIT	PAGE_	DBOXLOOP$:	DBOX_	EDIT		; attend une action ...	LOAD.W	D7,#DB_ZEROCR	PAGE_	DBOX		; remplace <CR> par <0>	LOAD.L	A1,#R16"TKEY_CHOIX	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#UNDO	JUMP,EQ UNDO$	COMP.W	D3,#CLEAR	JUMP,EQ UNDO$	COMP.W	D3,#CR	JUMP,EQ RETURN$	COMP.W	D3,#ENTER	JUMP,EQ ENTER$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F4	JUMP,EQ LIST$	COMP.W	D3,#F10	JUMP,EQ KILL$	COMP.W	D3,#F0	JUMP,EQ CANCEL$	COMP.W	D3,#F7	JUMP,EQ COLOR$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEYDBOX$	JUMP'	BIP$BIPEXE$:	CALL	DBCHOIXEXINV	; allume l'exempleBIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	CALL	DBCHOIXEXINV	; teint l'exemple	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIPEXE$	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,#4	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$ENTER$:	CALL	DBCHOIXEXINV	; teint l'exemple	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIPEXE$	JUMP	NLINE$KEYDBOX$:			; KEYDBOX =>	CALL	DBCHOIXEXINV	; teint l'exemple	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIPEXE$	COMP.B	D3,#100	JUMP',HS CLINE$	CALL	AFFABC		; affiche "Abc"	CALL	DBCHOIXEXINV	; allume l'exemple	JUMP	LOOP$CLINE$:	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$CLIC$:	CALL	DBCHOIXMOVE	; dplace la scroll-liste ...	JUMP',NE EXE$	CALL	AFFABC		; affiche "Abc"	JUMP	LOOP$EXE$:	LOAD.W	D7,#DB_CLIC	PAGE_	DBOX	JUMP,EQ LOOP$	CALL	DBCHOIXEXMOVE	; dplace l'exemple ...	JUMP,NE BIP$	JUMP	NLINEI$LIST$:	CALL	DBCHOIXEXINV	; teint l'exemple	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIPEXE$	LOAD.W	D7,#xcLISTREFAIT	XCAR_	LIST		; refait toute la liste	JUMP	REFAIT$COLOR$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	LOAD.L	A3,#R16"TMCOLOR$	LOAD.W	D3,(A5)+OCCAR+OCARCO	LIB	?MMENU		; choix de la couleur ...	JUMP,NE NLINEI$	LOAD.W	(A5)+OCCAR+OCARCO,D3	CALL	AFFABC		; affiche "Abc"	JUMP	NLINEI$OK$:	CALL	DBCHOIXEXINV	; teint l'exemple	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIPEXE$	TEST.B	(A5)+OCCAR+OCARNM ; nom de fonction existe ?	JUMP,EQ BIPEXE$		; non => BIPEXE$	PUSH.W	D3	LOAD.W	D3,(A5)+OSLVAR+OSLCYS	LOAD.W	D7,#xcLISTGETNL	XCAR_	LIST		; A3 <-- ^nom complet	POP.W	D3	LOAD.L	A4,#(A5)+OCCAR+OCARDE+odgbmNAMEOK4$:	LOAD.B	(A4+),(A3+)	JUMP,NE OK4$	CALL	DBCHOIXPUT	; table <-- paramtres	JUMP'	CANCEL$KILL$:	CLR.B	(A5)+OCCAR+OCARNM	CALL	DBCHOIXPUT	; table <-- paramtres;	JUMP'	CANCEL$CANCEL$:	LOAD.W	D7,#DB_CLOSE	PAGE_	DBOX		; ferme la DBOXEXIT$:	POPM.L	D1,D2,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	OCCAR+OCARNM,DBTYPA,0,0,0,2^BDBGCLABEL!100,0,14+2	.W	OCCAR+OCARDE+odgbmCORPS,DBTYPU,0,2000*FACMMPT,05*FACMMPT,2^BDBGCLABEL!101,1,7+2	.W	OCCAR+OCARDE+odgbmSHIFTX,DBTYPNS,-100,+100,10,2^BDBGCLABEL!102,2,4+2	.W	OCCAR+OCARDE+odgbmZOOMX,DBTYPN,10,200,10,2^BDBGCLABEL!103,3,4+2	.W	-1TMCOLOR$:	.ASCIZ	" noir "	.B	-1	.ASCIZ	" rouge "	.ASCIZ	" vert "	.ASCIZ	" bleu "	.ASCIZ	" violet "	.ASCIZ	" jaune "	.ASCIZ	" brun "	.ASCIZ	" gris "	.B	-1	.ASCIZ	" blanc "	.B	0	.EVEN;------------\\; DBCHOIXDRAW >;------------/; Dessine la scroll-liste.; in	-; out	-; mod	D7.WDBCHOIXDRAW:	PUSHM.L	D2..D4,A4,A5,A6	LOAD.L	A6,A5		; A6 <-- ^variables globales	LOAD.L	A5,#(A6)+OSLVAR	; A5 <-- ^variables de la scroll-liste	LOAD.W	D2,#20!2^BDBGCLABEL	DBOX_	GETCO	SWAP.W	D3	SUB.W	D3,(A0)+ODFC1Y	SWAP.W	D3	LOAD.L	(A5)+OSLPOS,D3	LOAD.W	D2,#21!2^BDBGCLABEL	DBOX_	GETCO	SUB.W	D3,(A5)+OSLPOS+2	SWAP.W	D3	SUB.W	D3,(A5)+OSLPOS+0	SWAP.W	D3	LOAD.L	(A5)+OSLDIM,D3	SET.B	(A5)+OSLASV+OSCPAGE	SCROLL_	LDRAW		; dessine la scroll-liste	CALL	DBCHOIXLIST	; fait la liste	LOAD.L	A4,#R16"DBCHOIXSLTX	LOAD.L	(A5)+OSLADL,A4	SCROLL_	LUPDATE		; dessine le contenu de la scroll-liste	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D4,A4,A5,A6	RET;------------\\; DBCHOIXSLTX >;------------/; Donne le texte d'une case de la scroll-liste.; Appel directement depuis SCROLL_LUPDATE !; in	D3.W	rang de la case (0..OSLCYN-1); out	D3.W	zro/un;	A3.L	^contenu de la case termin par <0> ou <CR>;	D7.W	erreur si la case est vide; mod	D3.L, D7.W, A3.LDBCHOIXSLTX:	PUSH.W	D4	CLR.W	D4	INC.W	D3	LOAD.W	D7,#xcLISTGETNL	XCAR_	LIST		; A3 <-- ^nom complet suivant	JUMP',NE LAST$	LOAD.W	D4,(A3)		; D4 <-- 2 premiers caractres du nom suivantLAST$:	DEC.W	D3	LOAD.W	D7,#xcLISTGETNL	XCAR_	LIST		; A3 <-- ^nom complet	CLR.W	D3		; D3 <-- pas de trait	COMP.W	D4,(A3)	JUMP',EQ EXIT$	INC.W	D3		; D3 <-- traitill de sparation	RR.W	D4,#8	COMP.B	D4,(A3)	JUMP',EQ EXIT$	INC.W	D3		; D3 <-- trait plein de sparationEXIT$:	POP.W	D4	CLR.W	D7		; retour EQ	RET;------------\\; DBCHOIXLIST >;------------/; Effectue la liste trie de tous les gencars disponibles.; in	-; out	-; mod	D7.WDBCHOIXLIST:	PUSHM.L	D3,D4,A3	LOAD.W	D7,#xcLISTGETNB	XCAR_	LIST		; D3 <-- nb de noms complets	LOAD.W	(A6)+OSLVAR+OSLCYN,D3	CLR.W	(A6)+OSLVAR+OSLCYS	LOAD.L	A3,#(A6)+OCCAR+OCARDE+odgbmNAME	TEST.B	(A3)	JUMP',EQ EXIT$	LOAD.W	D7,#xcLISTSRCNC	XCAR_	LIST		; D3/D4 <-- rang/"-fst"	JUMP',NE EXIT$	LOAD.W	(A6)+OSLVAR+OSLCYS,D3EXIT$:	POPM.L	D3,D4,A3	RET;------------\\; DBCHOIXMOVE >;------------/; Dplace ventuellement la scroll-liste.; in	-; out	D7.W	erreur; mod	D7.WDBCHOIXMOVE:	PUSHM.L	D3,D4,A5,A6	LOAD.L	A6,A5		; A6 <-- ^variables globales	LOAD.L	A5,#(A6)+OSLVAR	; A5 <-- ^variables de la scroll-liste	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP',NE EXIT$	LOAD.W	D7,#ERDIOUT	SUB.W	D4,(A0)+ODFFX	JUMP',LO EXIT$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	; D4 <-- position relative dans swdo	JUMP',LO EXIT$	SWAP.W	D4	SCROLL_	LMOVE		; dplace la scroll-liste ...EXIT$:	POPM.L	D3,D4,A5,A6	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DBCHOIXGET >;-----------/; in	A4.L	^caractre; out	-; mod	D7.WDBCHOIXGET:	PUSHM.L	D4,A3,A4	LOAD.L	(A5)+OPCAR,A4	LOAD.L	A3,#(A5)+OCCAR	LOAD.W	D4,#(LDCAR/2)-1LOOP$:	LOAD.W	(A3+),(A4+)	DECJ.W,NMO D4,LOOP$	TEST.W	(A5)+OCCAR+OCARDE+odgbmZOOMX	JUMP',NE ZOOM$	LOAD.W	(A5)+OCCAR+OCARDE+odgbmZOOMX,#100ZOOM$:	TEST.B	(A5)+OCCAR+OCARNM ; nom de fonction existe ?	JUMP',NE EXIT$	LOAD.L	A3,(A5)+OPTAB	; A4 <-- ^table du caractre	LOAD.W	D4,(A3)+OTACSEL	; D4 <-- caractre slectionn	LOAD.L	A3,#R16"NDEF$	LOAD.L	A4,#(A5)+OCCAR+OCARNMSRC$:	TEST.B	(A3)	JUMP',EQ EXIT$	DEC.W	D4	JUMP',NS PUT$NEXT$:	TEST.B	(A3+)	JUMP,NE NEXT$	JUMP	SRC$PUT$:	LOAD.B	(A4+),(A3+)	; OCARNM <-- nom par dfaut	JUMP,NE PUT$EXIT$:	POPM.L	D4,A3,A4	RETNDEF$:	.ASCIZ	"Fond"	.ASCIZ	"Evidence"	.ASCIZ	"Italique"	.ASCIZ	"Titre"	.ASCIZ	"Sous-titre"	.ASCIZ	"Lgende"	.ASCIZ	"Figure"	.ASCIZ	"Grec"	.ASCIZ	"Minuscule"	.ASCIZ	"Petit"	.ASCIZ	"Moyen"	.ASCIZ	"Grand"	.ASCIZ	"Immense"	.ASCIZ	"Liste"	.ASCIZ	"Encart"	.ASCIZ	"Spcial"	.B	0	.EVEN;-----------\\; DBCHOIXPUT >;-----------/; in	-; out	-; mod	D7.WDBCHOIXPUT:	PUSHM.L	D4,A3,A4	LOAD.L	A4,(A5)+OPCAR	LOAD.L	A3,#(A5)+OCCAR	LOAD.W	D4,#(LDCAR/2)-1LOOP$:	LOAD.W	(A4+),(A3+)	DECJ.W,NMO D4,LOOP$	LOAD.L	A4,(A5)+OPCAR	CALL	INITPARAM	; initialise qq paramtres	POPM.L	D4,A3,A4	RET;--------------\\; DBCHOIXEXMOVE >;--------------/; Dplace une poigne de l'exemple.; in	-; out	D2.W	nouvelle ligne ditable;	D7.W	erreur; mod	D2.L, D7.WDBCHOIXEXMOVE:	PUSHM.L	D1,D3,D4	CALL	IFMOUSE$	; D4 <-- position de la souris	JUMP',NE EXIT$	CALL	DBCHOIXEXDET	; D1 <-- poigne o est la souris	JUMP',NE EXIT$MOVE$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP',NE EXIT$	CALL	IFMOUSE$	; D4 <-- position de la souris	JUMP,NE MOVE$	LOAD.L	D3,D4	CALL	DBCHOIXEXINV	; efface l'ancien	CALL	DBCHOIXEXDEP	CALL	DBCHOIXEXINV	; allume le nouveau	JUMP	MOVE$EXIT$:	POPM.L	D1,D3,D4	TEST.W	D7		; retour EQ/NE	RETIFMOUSE$:	PUSH.L	D3	LIB	?IFMOUSE	JUMP',NE IFEXIT$	LOAD.W	D7,#ERDIOUT	SUB.W	D4,(A0)+ODFFX	JUMP',LO IFEXIT$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	; D4 <-- position relative dans swdo	JUMP',LO IFEXIT$	SWAP.W	D4	CLR.W	D7IFEXIT$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;-------------\\; DBCHOIXEXDET >;-------------/; Dtecte dans quelle poigne est la souris.; in	D4.L	position de la souris (y;x); out	D1.W	poigne (0..n);	D7.W	erreur; mod	D1.L, D7.WDBCHOIXEXDET:	PUSHM.L	D3..D5	LOAD.L	D5,D4		; D4 <-- position en X	SWAP.W	D5		; D5 <-- position en Y	CLR.W	D1LOOP$:	CALL	DBCHOIXEXPOS	; D3 <-- position poigne	JUMP',NE EXIT$	SUB.W	D3,#5	COMP.W	D4,D3	JUMP',LT NEXT$	ADD.W	D3,#5+5	COMP.W	D4,D3	JUMP',GE NEXT$	SWAP.W	D3	SUB.W	D3,#5	COMP.W	D5,D3	JUMP',LT NEXT$	ADD.W	D3,#5+5	COMP.W	D5,D3	JUMP',LT EXIT$NEXT$:	INC.W	D1	JUMP	LOOP$EXIT$:	POPM.L	D3..D5	TEST.W	D7		; retour EQ/NE	RET;-------------\\; DBCHOIXEXINV >;-------------/; Inverse l'exemple.; in	-; out	-; mod	D7.WDBCHOIXEXINV:	PUSHM.L	D0..D4	LOAD.L	D3,#-1	LOAD.L	D4,D3	LIB	?DRMDEF	CLR.W	D1	CALL	DBCHOIXEXPOS	; D3 <-- position poigne ZOOM	LOAD.L	D0,D3	INC.W	D1	CALL	DBCHOIXEXPOS	; D3 <-- position poigne SHIFT	LOAD.L	D1,D3	LOAD.W	D2,#INVDOT	LOAD.L	D3,(A5)+OEXEPOS	SWAP.W	D3	ADD.W	D3,(A5)+OEXEDIM+0	SWAP.W	D3	LOAD.L	D4,D0	CALL	LINE$	LOAD.L	D3,D4	LOAD.L	D4,D1	CALL	LINE$	LOAD.L	D3,D4	LOAD.L	D4,(A5)+OEXEPOS	ADD.W	D4,D1	SUB.W	D4,D0	CALL	LINE$	LOAD.L	D3,D4	LOAD.L	D4,(A5)+OEXEPOS	SWAP.W	D4	ADD.W	D4,(A5)+OEXEDIM+0	SWAP.W	D4	CALL	LINE$	LOAD.L	D4,#H'10000*7+7	LOAD.L	D3,D0	SUB.W	D3,#3	SWAP.W	D3	SUB.W	D3,#3	SWAP.W	D3	LIB	?DRTRAME	LOAD.L	D3,D1	SUB.W	D3,#3	SWAP.W	D3	SUB.W	D3,#3	SWAP.W	D3	LIB	?DRTRAME	POPM.L	D0..D4	RETLINE$:	PUSHM.L	D3,D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LIB	?DRSEG	POPM.L	D3,D4	RET;-------------\\; DBCHOIXEXDEP >;-------------/; Dplace une poigne.; in	D1.W	poigne (0..n);	D3.L	nouvelle position (y;x); out	D2.W	rang ligne ditable; mod	D2.L, D7.WDBCHOIXEXDEP:	PUSHM.L	D1,D3,D4	TEST.W	D1	JUMP',EQ ZOOM$	COMP.W	D1,#1	JUMP',EQ SHIFT$	JUMP	EXIT$ZOOM$:	SUB.W	D3,(A5)+OEXEPOS+2	MUL.WA	D3,#100	DIV.WA	D3,(A5)+OEXEDIM+2	COMP.W	D3,#50	JUMP',GE ZOOM2$	LOAD.W	D3,#50ZOOM2$:	COMP.W	D3,#200	JUMP',LE ZOOM3$	LOAD.W	D3,#200ZOOM3$:	LOAD.W	(A5)+OCCAR+OCARDE+odgbmZOOMX,D3	LOAD.W	D2,#3	JUMP'	AFF$SHIFT$:	LOAD.W	D4,D3	SUB.W	D4,(A5)+OEXEPOS+2	CLR.W	D1	CALL	DBCHOIXEXPOS	; D3 <-- position poigne ZOOM	SUB.W	D3,(A5)+OEXEPOS+2	SUB.W	D4,D3	MUL.WA	D4,#100	DIV.WA	D4,(A5)+OEXEDIM+0	COMP.W	D4,#-100	JUMP',GE SHIFT2$	LOAD.W	D4,#-100SHIFT2$:	COMP.W	D4,#+100	JUMP',LE SHIFT3$	LOAD.W	D4,#+100SHIFT3$:	LOAD.W	(A5)+OCCAR+OCARDE+odgbmSHIFTX,D4	LOAD.W	D2,#2;	JUMP'	AFF$AFF$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_AFF	PAGE_	DBOX		; affiche le paramtreEXIT$:	POPM.L	D1,D3,D4	RET;-------------\\; DBCHOIXEXPOS >;-------------/; Donne la position d'une poigne.; in	D1.W	poigne (0..n); out	D3.L	position (y;x);	D7.W	erreur; mod	D3.L, D7.WDBCHOIXEXPOS:	PUSHM.L	D2,D4	LOAD.L	D3,(A5)+OEXEPOS	LOAD.L	D4,(A5)+OEXEDIM	TEST.W	D1	JUMP',EQ ZOOM$	COMP.W	D1,#1	JUMP',EQ SHIFT$	LOAD.W	D7,#1	JUMP'	EXIT$ZOOM$:	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	MUL.WA	D4,(A5)+OCCAR+OCARDE+odgbmZOOMX	DIV.WA	D4,#100	ADD.W	D3,D4	JUMP'	OK$SHIFT$:	MUL.WA	D4,(A5)+OCCAR+OCARDE+odgbmZOOMX	DIV.WA	D4,#100	ADD.W	D3,D4	LOAD.W	D2,(A5)+OEXEDIM+0	MUL.WA	D2,(A5)+OCCAR+OCARDE+odgbmSHIFTX	DIV.WA	D2,#100	ADD.W	D3,D2;	JUMP'	OK$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2,D4	TEST.W	D7		; retour EQ/NE	RETTDBOX_CHOIX:	.W	10$-TDBOX_CHOIX	.W	20$-TDBOX_CHOIX	.W	0,010$:	.B	ODBLABEL,20	.B	ODBTEXT,0	.B	ODBCR2	.B	ODBTABX,LGCNAME+8	.B	ODBTEXT	.ASCIZ	"Nom      "	.B	ODBLABEL,100	.B	ODBCLINE,(14+2+6)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBCR,ODBCR	.B	ODBTABX,LGCNAME+8	.B	ODBTEXT	.ASCIZ	"Taille   "	.B	ODBLABEL,101	.B	ODBCLINE,(7+2)!2^7,KEYDBOX/H'100,101,TDBNORM	.B	ODBTABX,61-11	.B	ODBBOX,0,F7,TDBNORM	.ASCIZ	" COULEUR "	.B	ODBCR,ODBCR	.B	ODBTABX,LGCNAME+8	.B	ODBTEXT	.ASCIZ	"Italique "	.B	ODBLABEL,102	.B	ODBCLINE,(4+2)!2^7,KEYDBOX/H'100,102,TDBNORM	.B	ODBTEXT	.ASCIZ	"  % "	.B	ODBLABEL,202	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBTABX,LGCNAME+8	.B	ODBTEXT	.ASCIZ	"Largeur  "	.B	ODBLABEL,103	.B	ODBCLINE,(4+2)!2^7,KEYDBOX/H'100,103,TDBNORM	.B	ODBTEXT	.ASCIZ	"  %"	.B	ODBCR	.B	ODBTABX,LGCNAME+8	.B	ODBLABEL,200	.B	ODBTEXT,0	.B	ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBTABX,LGCNAME+5	.B	ODBLABEL,21	.B	ODBTEXT,0	.B	ODBTABX,61-1	.B	ODBLABEL,201	.B	ODBTEXT,0	.B	ODBCR	.B	ODBTABX,LGCNAME+8	.B	ODBSQUARE,BFANAFF!2^7,KEYDBOX/H'100,BFANAFF	.ASCIZ	" affiche"	.B	ODBCR,ODBCR2	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	"   CREE   "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F4,TDBOMBRE	.ASCIZ	" REFAIT "	.B	ODBTABX,LGCNAME+8	.B	ODBBOX,0,F10,TDBNORM	.ASCIZ	" SUPPRIME "	.B	ODBTABX,61-10	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Cre"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Refait"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Suprime"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_CHOIX:	.W	F1,F2,F3,0		DOKF1-TKEY_CHOIX	.W	F4,F5,F6,0		DOKF4-TKEY_CHOIX	.W	F10,F11,F12,0		DOKF10-TKEY_CHOIX	.W	F0,F13,F14,F15,0	DOKF0-TKEY_CHOIX	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_CHOIX	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_CHOIX	.W	0;--------\\; DOK...  >;========/DOKMGR:	LOAD.W	D3,#KEYMGR	RETDOKMGP:	LOAD.W	D3,#KEYMGP	RETDOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RETDOKF4:	LOAD.W	D3,#F4	RETDOKF7:	LOAD.W	D3,#F7	RETDOKF9:	LOAD.W	D3,#F9	RETDOKF10:	LOAD.W	D3,#F10	RET	.END