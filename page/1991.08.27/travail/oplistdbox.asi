	.SBTTL	OPLISTDBOX.ASI;---------\\; DBOXNBXY >;=========/; Choix du nombre de lignes/colonnes.; in	A4.L	^objet;	D4.W	0=d'accord, 1=dite/prend; out	D4.L	nouvelles dimensions (ny;nx);	D3.L	dernire touche (F1/F4/F0);	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXNBXY:	PUSHM.L	D0..D2,D5,A0..A4	LOAD.L	A0,(A5)+OPDDIS	; A0 <-- ^descripteur fentre	LOAD.L	A1,A4		; A1 <-- ^objet	LOAD.L	A2,#R16"TDBOX$	LOAD.W	D7,#DB_MEMPT	PAGE_	DBOX		; mj ^table dbox	LOAD.W	(A5)+ODBP1,(A1)+OOBNBX	LOAD.W	(A5)+ODBP2,(A1)+OOBNBY	LOAD.L	A2,#R16"TDBOX_NBXY1	TEST.W	D4	JUMP',EQ OPEN$	LOAD.L	A2,#R16"TDBOX_NBXY2OPEN$:	CLR.L	D4		; D4 <-- fanions	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.W	D7,#DB_OPEN	PAGE_	DBOX		; ouvre la DBOX	JUMP,NE EXIT$	CLR.W	D2AFF$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_AFF	PAGE_	DBOX		; affiche le paramtre	INC.W	D2	COMP.W	D2,#2	JUMP,LO AFF$	CLR.W	D2NLINE$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_MEDIT	PAGE_	DBOXLOOP$:	LOAD.W	D7,#MI_SCMO	PAGE_	MISC		; remet la souris	DBOX_	EDIT		; attend une action ...	LOAD.W	D7,#DB_ZEROCR	PAGE_	DBOX		; remplace <CR> par <0>	PUSH.L	A1	LOAD.L	A1,#R16"TKEY_NBXY	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	POP.L	A1	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F4	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#CLEAR	JUMP',EQ UNDO$	COMP.W	D3,#CR	JUMP',EQ RETURN$	COMP.W	D3,#ENTER	JUMP',EQ ENTER$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,#2	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$ENTER$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	JUMP	LOOP$KEYDBOX$:			; KEYDBOX =>	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	COMP.B	D3,#100	JUMP',HS CLINE$	JUMP	LOOP$CLINE$:	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$CLIC$:	LOAD.W	D7,#DB_CLIC	PAGE_	DBOX	JUMP,EQ LOOP$	JUMP	BIP$OK$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	LOAD.W	D4,(A5)+ODBP2	SWAP.W	D4	LOAD.W	D4,(A5)+ODBP1	; D4 <-- nouvelles dimensionsEND$:	LOAD.W	D7,#DB_CLOSE	PAGE_	DBOX		; ferme la DBOXEXIT$:	POPM.L	D0..D2,D5,A0..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	ODBP1,DBTYPN,1,MAXCOL,1,2^BDBGCLABEL!100,0,3+2	.W	ODBP2,DBTYPN,1,MAXLIN,1,2^BDBGCLABEL!101,1,3+2	.W	-1TDBOX_NBXY1:	.W	10$-TDBOX_NBXY1	.W	20$-TDBOX_NBXY1	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Nombre de colonnes  "	.B	ODBLABEL,100	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Nombre de lignes    "	.B	ODBLABEL,101	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,101,TDBNORM	.B	ODBCR,ODBCR,ODBCR,ODBCR2	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"   "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTDBOX_NBXY2:	.W	10$-TDBOX_NBXY2	.W	20$-TDBOX_NBXY2	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Nombre de colonnes  "	.B	ODBLABEL,100	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Nombre de lignes    "	.B	ODBLABEL,101	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,101,TDBNORM	.B	ODBCR,ODBCR,ODBCR,ODBCR2	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" EDITE "	.B	ODBBOX,0,F4,TDBMEV	.ASCIZ	" PREND "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Edite"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Prend"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_NBXY:	.W	F1,F2,F3,0		DOKF1-TKEY_NBXY	.W	F4,F5,F6,0		DOKF4-TKEY_NBXY	.W	F0,F13,F14,F15,0	DOKF0-TKEY_NBXY	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_NBXY	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_NBXY	.W	0;---------\\; DBOXJUST >;=========/; Choix du mode de justification.; in	A4.L	^objet; out	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXJUST:	PUSHM.L	D0..D2,D4,D5,A0..A4	LOAD.L	A0,(A5)+OPDDIS	; A0 <-- ^descripteur fentre	LOAD.L	A1,A4		; A1 <-- ^objet	LOAD.L	A2,#R16"TDBOX$	LOAD.W	D7,#DB_MEMPT	PAGE_	DBOX		; mj ^table dbox	LOAD.L	A2,#R16"DBJUSTSHOWC	LOAD.W	D7,#DB_MEMAFC	PAGE_	DBOX		; mj ^routine d'affichage	CALL	DBJUSTGET	; D1/D2/D4 <-- mode de justification	LOAD.W	(A5)+ODBP1,D1	LOAD.W	(A5)+ODBP2,D2	LOAD.L	A2,#R16"TDBOX_JUST	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.W	D7,#DB_OPEN	PAGE_	DBOX		; ouvre la DBOX	JUMP,NE EXIT$	CLR.W	D2AFF$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_AFF	PAGE_	DBOX		; affiche le paramtre	INC.W	D2	COMP.W	D2,#2	JUMP,LO AFF$	CLR.W	D2NLINE$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_MEDIT	PAGE_	DBOXSHOW$:	CALL	DBJUSTSHOW	; monte les centragesLOOP$:	LOAD.W	D7,#MI_SCMO	PAGE_	MISC		; remet la souris	DBOX_	EDIT		; attend une action ...	LOAD.W	D7,#DB_ZEROCR	PAGE_	DBOX		; remplace <CR> par <0>	PUSH.L	A1	LOAD.L	A1,#R16"TKEY_JUST	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	POP.L	A1	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#CLEAR	JUMP',EQ UNDO$	COMP.W	D3,#CR	JUMP',EQ RETURN$	COMP.W	D3,#ENTER	JUMP',EQ ENTER$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP',EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	SHOW$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,#2	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$ENTER$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	JUMP	LOOP$KEYDBOX$:			; KEYDBOX =>	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	COMP.B	D3,#100	JUMP',HS CLINE$	LOAD.W	(A5)+ODBP1,#10	COMP.B	D3,#0	JUMP',EQ JUSTH$	LOAD.W	(A5)+ODBP1,#90	COMP.B	D3,#1	JUMP',EQ JUSTH$	LOAD.W	(A5)+ODBP1,#50JUSTH$:	CLR.W	D2	JUMP	NLINE$CLINE$:	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$CLIC$:	LOAD.W	D7,#DB_CLIC	PAGE_	DBOX	JUMP,EQ LOOP$	JUMP	BIP$OK$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	LOAD.W	D1,(A5)+ODBP1	LOAD.W	D2,(A5)+ODBP2	CALL	DBJUSTPUT	; modifie la zoneEND$:	LOAD.W	D7,#DB_CLOSE	PAGE_	DBOX		; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A0..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	ODBP1,DBTYPNF,0,100,5,2^BDBGCLABEL!100,0,3+2	.W	ODBP2,DBTYPNF,1,100,5,2^BDBGCLABEL!101,1,3+2	.W	-1;----------\\; DBJUSTGET >;----------/; Cherche le mode de justification d'une zone.; in	A1.L	^objet; out	D4.L	fanions;	D1.W	positionnement en X;	D2.W	positionnement en Y; mod	D1.L, D2.L, D4.L, D7.WDBJUSTGET:	PUSHM.L	D0,D3,A2	LOAD.B	D4,#-1	LOAD.B	D0,D4	LOAD.B	D2,D4	LOAD.L	D1,(A5)+OAFIC1LOOPY$:	LOAD.W	D1,(A5)+OAFIC1+2LOOPX$:	CALL	TXGETPCE	; A2 <-- ^cellule (OCE*)	JUMP',NE NEXT$	COMP.B	D4,#-1	JUMP',NE JCOMP$	LOAD.B	D4,(A2)+OCEJUS	JUMP'	JEND$JCOMP$:	COMP.B	D4,(A2)+OCEJUS	JUMP',EQ JEND$	LOAD.B	D4,#-2JEND$:	COMP.B	D0,#-1	JUMP',NE HCOMP$	LOAD.B	D0,(A2)+OCEPOH	JUMP'	HEND$HCOMP$:	COMP.B	D0,(A2)+OCEPOH	JUMP',EQ HEND$	LOAD.B	D0,#-2HEND$:	COMP.B	D2,#-1	JUMP',NE VCOMP$	LOAD.B	D2,(A2)+OCEPOV	JUMP'	VEND$VCOMP$:	COMP.B	D2,(A2)+OCEPOV	JUMP',EQ VEND$	LOAD.B	D2,#-2VEND$:NEXT$:	INC.W	D1	COMP.W	D1,(A5)+OAFIC2+2	JUMP,LS LOOPX$	SWAP.W	D1	INC.W	D1	LOAD.W	D3,D1	SWAP.W	D1	COMP.W	D3,(A5)+OAFIC2+0	JUMP,LS LOOPY$	LOAD.B	D3,D4	CLR.L	D4	TEST.B	D3	JUMP',NS JOK$	LOAD.W	D4,#2^0	DEC.B	D3	JUMP',NS JOK$	LOAD.W	D4,#2^1	DEC.B	D3	JUMP',NS JOK$	LOAD.W	D4,#2^2	DEC.B	D3	JUMP',NS JOK$	LOAD.W	D4,#2^3	DEC.B	D3	JUMP',NS JOK$	LOAD.W	D4,#2^4JOK$:	LOAD.B	D3,D0	LOAD.W	D1,#-1	TEST.B	D3	JUMP',NS HOK$	CLR.W	D1	LOAD.B	D1,D3HOK$:	LOAD.B	D3,D2	LOAD.W	D2,#-1	TEST.B	D3	JUMP',NS VOK$	CLR.W	D2	LOAD.B	D2,D3VOK$:	POPM.L	D0,D3,A2	RET;----------\\; DBJUSTPUT >;----------/; Modifie le mode de justification d'une zone.; in	A1.L	^objet;	D4.L	fanions;	D1.W	positionnement en X;	D2.W	positionnement en Y; out	-; mod	D7.WDBJUSTPUT:	PUSHM.L	D0..D4,A2	LOAD.W	D3,D4	LOAD.B	D4,#-1	TEST.W	D3	JUMP',EQ JOK$	INC.B	D4	TEST.L	D3:#0	JUMP',BS JOK$	INC.B	D4	TEST.L	D3:#1	JUMP',BS JOK$	INC.B	D4	TEST.L	D3:#2	JUMP',BS JOK$	INC.B	D4	TEST.L	D3:#3	JUMP',BS JOK$	INC.B	D4JOK$:	LOAD.W	D0,D1	LOAD.L	D1,(A5)+OAFIC1LOOPY$:	LOAD.W	D1,(A5)+OAFIC1+2LOOPX$:	CALL	TXGETPCE	; A2 <-- ^cellule (OCE*)	JUMP',NE NEXT$	COMP.B	D4,#-1	JUMP',EQ JEND$	LOAD.B	(A2)+OCEJUS,D4JEND$:	COMP.B	D0,#-1	JUMP',EQ HEND$	LOAD.B	(A2)+OCEPOH,D0HEND$:	COMP.B	D2,#-1	JUMP',EQ VEND$	LOAD.B	(A2)+OCEPOV,D2VEND$:NEXT$:	INC.W	D1	COMP.W	D1,(A5)+OAFIC2+2	JUMP,LS LOOPX$	SWAP.W	D1	INC.W	D1	LOAD.W	D3,D1	SWAP.W	D1	COMP.W	D3,(A5)+OAFIC2+0	JUMP,LS LOOPY$	POPM.L	D0..D4,A2	RET;------------\\; DBJUSTSHOWC >;------------/; Montre les centrages.; in	D2.W	mode (SETDOT/CLRDOT); out	-; mod	D7.WDBJUSTSHOWC:	COMP.W	D2,#SETDOT	JUMP',EQ DBJUSTSHOW	RET;-----------\\; DBJUSTSHOW >;-----------/; Montre les centrages.; in	-; out	-; mod	D7.WDBJUSTSHOW:	PUSHM.L	D2..D4	CLR.L	D3	CLR.L	D4	LIB	?DRMDEF	LOAD.W	D2,#11!2^BDBGCLABEL	DBOX_	GETCO	PUSH.L	D3	LOAD.W	D2,#10!2^BDBGCLABEL	DBOX_	GETCO	POP.L	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	ADD.W	D4,(A0)+ODFC1Y	SWAP.W	D3	SWAP.W	D4	PUSHM.L	D3,D4	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface l'ancien	POPM.L	D3,D4	LOAD.W	D2,#SETDOT	LIB	?DRRECT	TEST.W	(A5)+ODBP1	JUMP,NS EXIT$	TEST.W	(A5)+ODBP2	JUMP,NS EXIT$	LIB	?AFTIM	.B	MAPTT	.B	B'10101010	; <map>	.B	1		; <chelle>	.B	0	.EVEN	PUSHM.L	D3,D4	LOAD.W	D2,D4	MUL.WU	D2,(A5)+ODBP1	DIV.WU	D2,#100	ADD.W	D3,D2	CLR.W	D4	LOAD.W	D2,#SETDOT!TTTDOT	LIB	?DRSEG	POPM.L	D3,D4	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,D4	MUL.WU	D2,(A5)+ODBP2	DIV.WU	D2,#100	ADD.W	D3,D2	CLR.W	D4	SWAP.W	D4	SWAP.W	D3	LOAD.W	D2,#SETDOT!TTTDOT	LIB	?DRSEGEXIT$:	POPM.L	D2..D4	RETTDBOX_JUST:	.W	10$-TDBOX_JUST	.W	20$-TDBOX_JUST	.W	0,010$:	.B	ODBLCIRCLE,0!2^7,KEYDBOX/H'100,0	.ASCIZ	" drapeau  droite"	.B	ODBCR	.B	ODBLCIRCLE,1!2^7,KEYDBOX/H'100,1	.ASCIZ	" drapeau  gauche"	.B	ODBCR	.B	ODBLCIRCLE,2!2^7,KEYDBOX/H'100,2	.ASCIZ	" centr"	.B	ODBCR	.B	ODBLCIRCLE,3!2^7,KEYDBOX/H'100,3	.ASCIZ	" align sur le point   (.)"	.B	ODBCR	.B	ODBLCIRCLE,4!2^7,KEYDBOX/H'100,4	.ASCIZ	" align sur la virgule (,)"	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Centrage horizontal  partir de "	.B	ODBLABEL,100	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTEXT	.ASCIZ	"   % "	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Centrage vertical  partir de   "	.B	ODBLABEL,101	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,101,TDBNORM	.B	ODBTEXT	.ASCIZ	"   % "	.B	ODBCR,ODBCR2	.B	ODBTABX,28	.B	ODBLABEL,10	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	ODBTABX,28+14	.B	ODBLABEL,11	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_JUST:	.W	F1,F2,F3,0		DOKF1-TKEY_JUST	.W	F0,F13,F14,F15,0	DOKF0-TKEY_JUST	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_JUST	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_JUST	.W	0;----------\\; DBOXSERIE >;==========/; Choix d'une srie.; in	A4.L	^objet; out	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXSERIE:	PUSHM.L	D0..D2,D4,D5,A0..A4	LOAD.L	A0,(A5)+OPDDIS	; A0 <-- ^descripteur fentre	LOAD.L	A1,A4		; A1 <-- ^objet	LOAD.L	A2,#R16"TDBOX$	LOAD.W	D7,#DB_MEMPT	PAGE_	DBOX		; mj ^table dbox	LOAD.W	(A5)+ODBP1,(A5)+OSEINI	LOAD.W	(A5)+ODBP2,(A5)+OSEPAS	LOAD.L	D4,(A5)+OSEFAN	; D4 <-- fanions	LOAD.L	A2,#R16"TDBOX_SERIE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.W	D7,#DB_OPEN	PAGE_	DBOX		; ouvre la DBOX	JUMP,NE EXIT$	CLR.W	D2AFF$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_AFF	PAGE_	DBOX		; affiche le paramtre	INC.W	D2	COMP.W	D2,#2	JUMP,LO AFF$	CLR.W	D2GREY$:	PUSH.L	D2	LOAD.L	D1,D4	TEST.L	D4:#BSENUM	JUMP',BS GREY4$GREY2$:	LOAD.W	D2,#BSEMINUS!2^BDBGCLABEL!2^BDBGCFULL	DBOX_	GETCO	LOAD.W	D2,#BSEMAJUS!2^BDBGCLABEL!2^BDBGCFULL	DBOX_	GETCO	LOAD.W	D2,#BSENOMP!2^BDBGCLABEL!2^BDBGCFULL	DBOX_	GETCO	JUMP'	GREY8$GREY4$:	AND.W	D1,#H'00FF	LOAD.W	D2,#BSEMINUS!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#BSEMAJUS!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#BSENOMP!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCOGREY8$:	LOAD.L	D4,D1	POP.L	D2NLINE$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_MEDIT	PAGE_	DBOXLOOP$:	LOAD.W	D7,#MI_SCMO	PAGE_	MISC		; remet la souris	DBOX_	EDIT		; attend une action ...	LOAD.W	D7,#DB_ZEROCR	PAGE_	DBOX		; remplace <CR> par <0>	PUSH.L	A1	LOAD.L	A1,#R16"TKEY_SERIE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	POP.L	A1	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#CLEAR	JUMP',EQ UNDO$	COMP.W	D3,#CR	JUMP',EQ RETURN$	COMP.W	D3,#ENTER	JUMP',EQ ENTER$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,#2	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$ENTER$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	JUMP	LOOP$KEYDBOX$:			; KEYDBOX =>	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	COMP.B	D3,#100	JUMP',HS CLINE$	LOAD.L	D1,#H'FFFFFF00	COMP.B	D3,#8	JUMP',LO MASK$	LOAD.L	D1,#H'FFFF00FFMASK$:	AND.L	D4,D1	TSET.L	D4:D3	COMP.B	D3,#BSENUM	JUMP,EQ GREY$	COMP.B	D3,#BSEJDLS	JUMP',EQ UNUN$	COMP.B	D3,#BSEMOIS	JUMP,NE LOOP$UNUN$:	LOAD.W	(A5)+ODBP1,#1	LOAD.W	(A5)+ODBP2,#1	LOAD.W	D2,#1	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	CLR.W	D2	LOAD.W	D1,D4	AND.W	D1,#H'FF00	JUMP,NE GREY$	TSET.L	D4:#BSEMINUS	JUMP	GREY$CLINE$:	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$CLIC$:	LOAD.W	D7,#DB_CLIC	PAGE_	DBOX	JUMP,EQ LOOP$	JUMP	BIP$OK$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	LOAD.W	(A5)+OSEINI,(A5)+ODBP1	LOAD.W	(A5)+OSEPAS,(A5)+ODBP2	LOAD.L	(A5)+OSEFAN,D4	CALL	DBSERIEPUTEND$:	LOAD.W	D7,#DB_CLOSE	PAGE_	DBOX		; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A0..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	ODBP1,DBTYPNS,-10000,+10000,1,2^BDBGCLABEL!100,0,6+2	.W	ODBP2,DBTYPNS,-10000,+10000,1,2^BDBGCLABEL!101,1,6+2	.W	-1;-----------\\; DBSERIEPUT >;-----------/; Met une srie dans une liste.; in	A1.L	^objet; out	-; mod	D7.WDBSERIEPUT:	PUSHM.L	D0..D4,A2..A4	LOAD.W	D0,(A5)+OSEINI	; D0 <-- valeur initiale	LOAD.L	D2,(A5)+OAFIC1LOOPY$:	LOAD.W	D2,(A5)+OAFIC1+2LOOPX$:	LOAD.L	D1,D2	CALL	TXGETPCE	; A2 <-- ^cellule (OCE*)	JUMP,NE NEXT$	TEST.L	(A2)+OCEPTX	JUMP',EQ GIVMEM$	LOAD.L	A4,(A2)+OCEPTX	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	CLR.L	(A2)+OCEPTXGIVMEM$:	LOAD.L	D4,#OTXDEB+TXRES	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande de la mmoire	JUMP,NE EXIT$	LOAD.L	(A2)+OCEPTX,A4	SUB.W	D4,#OTXDEB	LOAD.W	(A4)+OTXLGM,D4	CLR.W	(A4)+OTXNBC	LOAD.L	A4,#(A4)+OTXDEB	CALL	DBSERIEONE	; texte <-- valeur	LOAD.W	(A4)-OTXDEB+OTXNBC,D4	ADD.W	D0,(A5)+OSEPAS	; D0 <-- valeur suivanteNEXT$:	INC.W	D2	COMP.W	D2,(A5)+OAFIC2+2	JUMP,LS LOOPX$	SWAP.W	D2	INC.W	D2	LOAD.W	D3,D2	SWAP.W	D2	COMP.W	D3,(A5)+OAFIC2+0	JUMP,LS LOOPY$EXIT$:	POPM.L	D0..D4,A2..A4	RET;-----------\\; DBSERIEONE >;-----------/; Met une valeur dans un buffer.; in	A4.L	^buffer;	D0.W	valeur; out	D4.W	longueur; mod	D4.L, D7.WDBSERIEONE:	PUSHM.L	D2,D3,A2..A4	CLR.L	D4	LOAD.W	D4,D0		; D4 <-- valeur	LOAD.L	A3,A4	LOAD.L	D2,(A5)+OSEFAN	; D2 <-- fanions	TEST.L	D2:#BSEJDLS	JUMP',BS JDLS$	TEST.L	D2:#BSEMOIS	JUMP',BS MOIS$NUM$:	TEST.W	D4	JUMP',NC NUMPUT$	NEG.W	D4	LOAD.B	(A4+),#'-NUMPUT$:	LOAD.W	D7,#MI_PUTANUM	PAGE_	MISC		; buffer <-- nombre	JUMP	LG$JDLS$:	LOAD.L	A2,#R16"TJDLS$	DEC.W	D4	DIV.WU	D4,#7	SWAP.W	D4		; D4 <-- 0..6	JUMP'	TEXT$MOIS$:	LOAD.L	A2,#R16"TMOIS$	DEC.W	D4	DIV.WU	D4,#12	SWAP.W	D4		; D4 <-- 0..11;	JUMP'	TEXT$TEXT$:	DEC.W	D4	JUMP',NS TPUT$TNEXT$:	TEST.B	(A2+)	JUMP,NE TNEXT$	JUMP	TEXT$TPUT$:	LOAD.B	D3,(A2+)	JUMP',EQ LG$	TEST.L	D2:#BSEMAJUS	JUMP',BS TMAJ$	TCLR.L	D2:#BSENOMP	JUMP',BC TCAR$TMAJ$:	LIB	?MINMAJTCAR$:	LOAD.B	(A4+),D3	JUMP	TPUT$LG$:	LOAD.L	D4,A4	SUB.L	D4,A3		; D4 <-- longueur	POPM.L	D2,D3,A2..A4	RETTJDLS$:	.ASCIZ	"lundi"	.ASCIZ	"mardi"	.ASCIZ	"mercredi"	.ASCIZ	"jeudi"	.ASCIZ	"vendredi"	.ASCIZ	"samedi"	.ASCIZ	"dimanche"	.B	0TMOIS$:	.ASCIZ	"janvier"	.ASCIZ	"fvrier"	.ASCIZ	"mars"	.ASCIZ	"avril"	.ASCIZ	"mai"	.ASCIZ	"juin"	.ASCIZ	"juillet"	.ASCIZ	"aot"	.ASCIZ	"septembre"	.ASCIZ	"octobre"	.ASCIZ	"novembre"	.ASCIZ	"dcembre"	.B	0	.EVENTDBOX_SERIE:	.W	10$-TDBOX_SERIE	.W	20$-TDBOX_SERIE	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Valeur initiale  "	.B	ODBLABEL,100	.B	ODBCLINE,(6+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Valeur du pas    "	.B	ODBLABEL,101	.B	ODBCLINE,(6+2)!2^7,KEYDBOX/H'100,101,TDBNORM	.B	ODBCR,ODBCR	.B	ODBLCIRCLE,BSENUM!2^7!2^6,KEYDBOX/H'100,BSENUM	.ASCIZ	" nombres"	.B	ODBTABX,25	.B	ODBLABEL,BSEMINUS	.B	ODBLCIRCLE,BSEMINUS!2^7!2^6,KEYDBOX/H'100,BSEMINUS	.ASCIZ	" minuscules"	.B	ODBCR	.B	ODBLCIRCLE,BSEJDLS!2^7!2^6,KEYDBOX/H'100,BSEJDLS	.ASCIZ	" jours de la semaine"	.B	ODBTABX,25	.B	ODBLABEL,BSEMAJUS	.B	ODBLCIRCLE,BSEMAJUS!2^7!2^6,KEYDBOX/H'100,BSEMAJUS	.ASCIZ	" majuscules"	.B	ODBCR	.B	ODBLCIRCLE,BSEMOIS!2^7!2^6,KEYDBOX/H'100,BSEMOIS	.ASCIZ	" mois"	.B	ODBTABX,25	.B	ODBLABEL,BSENOMP	.B	ODBLCIRCLE,BSENOMP!2^7!2^6,KEYDBOX/H'100,BSENOMP	.ASCIZ	" noms propres"	.B	ODBCR,ODBCR,ODBCR2	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_SERIE:	.W	F1,F2,F3,0		DOKF1-TKEY_SERIE	.W	F0,F13,F14,F15,0	DOKF0-TKEY_SERIE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_SERIE	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_SERIE	.W	0;------------\\; DBOXTXPREND >;============/; Edite un nom de fichier texte en entre (prend).; in	A3.L	^nom du fichier; out	D3.W	dernire touche (F1/F0);	D4.L	tats des fanions;	D7.W	erreur; mod	D3.L, D4.L, D7.WDBOXTXPREND:	PUSHM.L	D1,D2,D5,A2..A5	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX		; prpare l'ouverture de la DBOX	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IOTX	LOAD.L	A4,#R16"TEXTX	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_PREND	; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUNAM!2^BDBIOEXT1!2^BDBIOFULL	LOAD.W	D7,#DB_POS5	PAGE_	DBOX		; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	PUSH.W	D7	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX		; prpare la fermeture de la DBOX	POP.W	D7EXIT$:	POPM.L	D1,D2,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBOXTXSAUVE >;============/; Edite un nom de fichier texte en sortie.; in	A3.L	^nom du fichier;	D4.L	fanions par dfaut; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXTXSAUVE:	PUSHM.L	D1,D2,D4,D5,A2..A5	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX		; prpare l'ouverture de la DBOX	CLR.L	D4		; D4 <-- fanions	LOAD.L	A5,A3		; A5 <-- ^nom du fichier	LOAD.L	A3,#R16"TDBOX_IOTX	LOAD.L	A4,#R16"TEXTX	; A4 <-- ^critre de recherche (extension)	LOAD.W	D1,#DBOX_EXTRAIT; D1 <-- code du sous-appel	LOAD.W	D2,#2^BDBSAV!2^BDBEXTEND	LOAD.L	D3,#LBUNAM!2^BDBIOEXT1!2^BDBIOFULL	LOAD.W	D7,#DB_POS5	PAGE_	DBOX		; D5 <-- centre de la dbox	DBOX_	EXTEND		; dbox: attend la rponse ...	LOAD.W	D2,D4		; D2 <-- nouveau mode (fanions)	PUSH.W	D7	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX		; prpare la fermeture de la DBOX	POP.W	D7EXIT$:	POPM.L	D1,D2,D4,D5,A2..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX_IOTX:	.ASCIZ	"PAGE"		; nom du logiciel	.ASCIZ	"Fliste"	; [M,F] nom des lments manipuls	.ASCIZ	""		; [M,F] nom du contenant	.B	0TEXTX:	.ASCIZ	".TEXT"	.EVEN;-----------\\; DBOXDELETE >;===========/; Demande s'il faut dtruire un fichier.; in	A3.L	^nom du fichier; out	D3.W	'O/'N; mod	D7.WDBOXDELETE:	PUSH.L	D2	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX		; prpare l'ouverture de la DBOX	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LIST_	DELETE		; dtruit le fichier ?	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX		; prpare la fermeture de la DBOX	POP.L	D2	RET;----------\\; DBOXERROR >;==========/; Affiche une erreur.; in	D7.W	erreur; out	-; mod	D7.WDBOXERROR:	PUSHM.L	D2,D3	PUSH.W	D7	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX		; prpare l'ouverture de la DBOX	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX		; prpare la fermeture de la DBOX	POPM.L	D2,D3	RET;--------\\; DOK...  >;========/DOKMGR:	LOAD.W	D3,#KEYMGR	RETDOKMGP:	LOAD.W	D3,#KEYMGP	RETDOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RETDOKF4:	LOAD.W	D3,#F4	RETDOKF7:	LOAD.W	D3,#F7	RETDOKF10:	LOAD.W	D3,#F10	RETDOKF13:	LOAD.W	D3,#F13	RET	.END