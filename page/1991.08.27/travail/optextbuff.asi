	.SBTTL	OPTEXTBUFF.ASI;--------\\; TXINFO  >;========/; Donne quelques informations sur un objet texte.; in	A1.L	^objet texte; out	D4.L	position actuelle du curseur;	D5.L	nombre de caractres; mod	D4.L, D5.L, D7.WTXINFO:	LOAD.L	D4,(A1)+OOBPOC	; D4 <-- position du curseur	LOAD.L	D5,(A1)+OOBNBC	; D5 <-- nombre de caractres	CLR.W	D7		; retour EQ	RET;--------------\\; TXQPOSITIONNE >;==============/; Positionne rapidement le curseur n'importe o dans un objet texte.; La position de la ligne n'est pas mise  jour (OOBPLI) !; in	A1.L	^objet texte;	D4.L	nouvelle position; out	D7.W	erreur; mod	D7.WTXQPOSITIONNE:	PUSHM.L	D2..D4,A4	LOAD.L	D3,(A1)+OOBPOC	SUB.L	D3,D4	JUMP,EQ 80$	JUMP',NC 10$	NEG.L	D3		; D3 <-- |cart|10$:	COMP.L	D3,#20		; cart suffisement petit ?	JUMP,LO 50$		; oui => 50$; Positionne le curseur en parcourant tous les blocs.	LOAD.W	D7,#1		; D7 <-- hors de la zone	LOAD.L	A4,(A1)+OOBFBT	CLR.L	D320$:	ADD.L	D3,(A4)+OBTNBC	COMP.L	D4,D3		; va dans ce bloc ?	JUMP',LS 30$		; oui => 30$				; non =>	LOAD.L	D2,(A4)+OBTNEXT	JUMP',EQ 90$	LOAD.L	A4,D2		; A4 <-- ^bloc suivant	JUMP	20$30$:	LOAD.L	(A1)+OOBPPB,A4	LOAD.L	(A1)+OOBPOC,D4	SUB.L	D3,(A4)+OBTNBC	SUB.L	D4,D3	LOAD.L	(A1)+OOBPPR,D4	JUMP'	80$; Positionne le curseur en avanant ou en reculant un peu.50$:	COMP.L	D4,(A1)+OOBPOC	JUMP',LO 70$60$:	CALL	TXAVANCE	COMP.L	D4,(A1)+OOBPOC	; position atteinte ?	JUMP,NE 60$		; non => 60$	JUMP'	80$70$:	CALL	TXRECULE	COMP.L	D4,(A1)+OOBPOC	; position atteinte ?	JUMP,NE 70$		; non => 70$;	JUMP'	80$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D4,A4	TEST.W	D7		; retour EQ/NE	RET;-------------\\; TXPOSITIONNE >;=============/; Positionne le curseur n'importe o dans un objet texte.; in	A1.L	^objet texte;	D4.L	nouvelle position; out	D7.W	erreur; mod	D7.WTXPOSITIONNE:	PUSHM.L	D0..D4,A3,A4	LOAD.L	D3,(A1)+OOBPOC	SUB.L	D3,D4	JUMP,EQ 80$	JUMP',NC 10$	NEG.L	D3		; D3 <-- |cart|10$:	COMP.L	D3,#100		; cart suffisement petit ?	JUMP,LO 50$		; oui => 50$; Positionne le curseur en parcourant tous les blocs.	LOAD.W	D7,#1		; D7 <-- hors de la zone	LOAD.L	A4,(A1)+OOBFBT	CLR.L	D3	CLR.L	D0		; D0 <-- position en ligne20$:	LOAD.L	D2,(A4)+OBTNBC	ADD.L	D3,D2	COMP.L	D4,D3		; va dans ce bloc ?	JUMP',LS 30$		; oui => 30$				; non =>	CALL	TXPOSCLIN	; D0 <-- position en ligne	LOAD.L	D2,(A4)+OBTNEXT	JUMP',EQ 90$	LOAD.L	A4,D2		; A4 <-- ^bloc suivant	JUMP	20$30$:	LOAD.L	(A1)+OOBPPB,A4	LOAD.L	(A1)+OOBPOC,D4	SUB.L	D3,D2	SUB.L	D4,D3	LOAD.L	(A1)+OOBPPR,D4	LOAD.L	D2,D4	CALL	TXPOSCLIN	; D0 <-- position en ligne	LOAD.L	(A1)+OOBPLI,D0	JUMP'	80$; Positionne le curseur en avanant ou en reculant un peu.50$:	COMP.L	D4,(A1)+OOBPOC	JUMP',LO 70$60$:	CALL	TXAVANCE	COMP.L	D4,(A1)+OOBPOC	; position atteinte ?	JUMP,NE 60$		; non => 60$	JUMP'	80$70$:	CALL	TXRECULE	COMP.L	D4,(A1)+OOBPOC	; position atteinte ?	JUMP,NE 70$		; non => 70$;	JUMP'	80$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; TXPOSCLIN >;----------/; Compte  quelle ligne est le curseur.; in	A4.L	^bloc;	D2.L	nb de caractres;	D0.L	position en ligne; out	D0.L	nouvelle position; mod	D0.L, D1.L, D2.L, A3.LTXPOSCLIN:	LOAD.L	A3,#(A4)+LBT	DEC.W	D2		; D2 <-- -1  cause NMO	JUMP',NS 90$20$:	LOAD.W	D1,(A3+)	; D1 <-- caractre brut	COMP.B	D1,#CR	JUMP',EQ 40$	COMP.B	D1,#LF	JUMP',NE 42$40$:	INC.L	D0		; D0 <-- avance d'une ligne42$:	DECJ.W,NMO D2,20$90$:	RET;---------\\; TXPSAUVE >;=========/; Sauve la position actuelle du curseur.; in	A1.L	^objet texte; out	D4.W	numro de la position;	D7.W	erreur; mod	D4.L, D7.WTXPSAUVE:	PUSH.L	A3	LOAD.L	A3,#(A1)+OOBSP	CLR.W	D410$:	TEST.L	(A3)+OSPPPB	; lment libre ?	JUMP',EQ 40$		; oui => 40$	LOAD.L	A3,#(A3)+LSP	; A3 <-- ^lment suivant	INC.W	D4	COMP.W	D4,#MAXSP	JUMP,LO 10$	LOAD.W	D7,#1	JUMP'	90$40$:	LOAD.L	(A3)+OSPPOC,(A1)+OOBPOC	LOAD.L	(A3)+OSPPLI,(A1)+OOBPLI	LOAD.L	(A3)+OSPPPB,(A1)+OOBPPB	LOAD.L	(A3)+OSPPPR,(A1)+OOBPPR	CLR.W	D7		; D7 <-- ok90$:	POP.L	A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; TXPANNULE >;==========/; Annule l'effet d'une TXPSAUVE.; A utiliser  la place de TXPPREND !; in	A1.L	^objet texte;	D4.W	numro de la position; out	D7.W	erreur; mod	D7.WTXPANNULE:	PUSHM.L	D4,A3	LOAD.L	A3,#(A1)+OOBSP	MUL.WU	D4,#LSP	ADD.L	A3,D4		; A3 <-- ^lment selon numro	CLR.L	(A3)+OSPPPB	; libre l'lment	POPM.L	D4,A3	CLR.W	D7		; retour EQ	RET;---------\\; TXPREMET >;=========/; Remet le curseur  une position sauve.; TXPSAUVE TXPREMET TXPREMET ... TXPANNULE; in	A1.L	^objet texte;	D4.W	numro de la position; out	D7.W	erreur; mod	D7.WTXPREMET:	PUSHM.L	D4,A3	LOAD.L	A3,#(A1)+OOBSP	MUL.WU	D4,#LSP	ADD.L	A3,D4		; A3 <-- ^lment selon numro	LOAD.L	(A1)+OOBPOC,(A3)+OSPPOC	LOAD.L	(A1)+OOBPLI,(A3)+OSPPLI	LOAD.L	(A1)+OOBPPB,(A3)+OSPPPB	LOAD.L	(A1)+OOBPPR,(A3)+OSPPPR	POPM.L	D4,A3	CLR.W	D7		; retour EQ	RET;---------\\; TXPPREND >;=========/; Remet le curseur  une position sauve.; ATTENTION:	Entre le "sauve" et le "prend", il ne faut pas;		faire de "insre", de "dtruit", etc.; in	A1.L	^objet texte;	D4.W	numro de la position; out	D7.W	erreur; mod	D7.WTXPPREND:	PUSHM.L	D4,A3	LOAD.L	A3,#(A1)+OOBSP	MUL.WU	D4,#LSP	ADD.L	A3,D4		; A3 <-- ^lment selon numro	LOAD.L	(A1)+OOBPOC,(A3)+OSPPOC	LOAD.L	(A1)+OOBPLI,(A3)+OSPPLI	LOAD.L	(A1)+OOBPPB,(A3)+OSPPPB	LOAD.L	(A1)+OOBPPR,(A3)+OSPPPR	CLR.L	(A3)+OSPPPB	; libre l'lment	POPM.L	D4,A3	CLR.W	D7		; retour EQ	RET;--------\\; TXDONNE >;========/; Donne le caractre  droite du curseur, dans un objet texte.; in	A1.L	^objet texte; out	D3.L	caractre  droite du curseur;	D7.W	erreur; mod	D3.L, D7.WTXDONNE:	PUSH.L	A4	LOAD.W	D7,#1		; D7 <-- hors de la zone	LOAD.L	A4,(A1)+OOBPPB	; A4 <-- ^bloc o est le curseur	LOAD.L	D3,(A1)+OOBPPR	COMP.L	D3,(A4)+OBTNBC	JUMP',LO 30$	LOAD.L	D3,(A4)+OBTNEXT	JUMP',EQ 90$	LOAD.L	A4,D3		; A4 <-- ^bloc suivant	CLR.L	D330$:	SL.L	D3,#1	LOAD.W	D3,(A4)+(D3.L)+LBT ; D3 <-- caractre cod	CALL	CARDECO		; D3 <-- caractre complet	CLR.W	D7		; D7 <-- ok90$:	POP.L	A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; TXREMPLACE >;===========/; Remplace le caractre  droite du curseur, dans un objet texte.; in	A1.L	^objet texte;	D3.L	nouveau caractre; out	D7.W	erreur; mod	D7.WTXREMPLACE:	PUSHM.L	D2..D4,A4	LOAD.W	D7,#1		; D7 <-- hors de la zone	LOAD.L	A4,(A1)+OOBPPB	; A4 <-- ^bloc o est le curseur	LOAD.L	D4,(A1)+OOBPPR	COMP.L	D4,(A4)+OBTNBC	JUMP',LO 30$	LOAD.L	D4,(A4)+OBTNEXT	JUMP',EQ 90$	LOAD.L	A4,D4		; A4 <-- ^bloc suivant	CLR.L	D430$:	CALL	CARCODE		; D3 <-- caractre cod	JUMP',NE 90$	SL.L	D4,#1	LOAD.W	D2,(A4)+(D4.L)+LBT ; D2 <-- caractre prcdent	LOAD.W	(A4)+(D4.L)+LBT,D3 ; remplace le caractre	COMP.B	D3,#CR	JUMP',EQ 40$	COMP.B	D3,#LF	JUMP',NE 42$40$:	INC.L	(A1)+OOBNBL	; une ligne de plus42$:	COMP.B	D2,#CR	JUMP',EQ 50$	COMP.B	D2,#LF	JUMP',NE 52$50$:	DEC.L	(A1)+OOBNBL	; une ligne de moins52$:	SET.B	(A1)+OOBMAJ	; mise  jour ncessaire	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D4,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; TXACHERCHE >;===========/; Cherche un caractre en avant, dans un objet texte.; Si le caractre n'est pas trouv, la position du curseur; n'est pas change !; in	A1.L	^objet texte;	D3.L	caractre cherch;	D2.L	masque ventuel;	D5.W	mode (si 2^0=1 --> min=maj); out	D4.L	position juste avant le caractre trouv;	D7.W	erreur; mod	D4.L, D7.WTXACHERCHE:	PUSHM.L	D0..D3,D5,D6,A2..A4	TEST.L	D5:#0		; minuscules = majuscules ?	JUMP',BC 10$		; non => 10$	CALL	MINMAJ		; D3 <-- caractre majuscule cherch10$:	LOAD.L	D6,D3	AND.L	D6,D2		; D6 <-- caractre cherch; Cherche le premier bloc o chercher.	LOAD.W	D7,#1		; D7 <-- hors de la zone	LOAD.L	A4,(A1)+OOBPPB	; A4 <-- ^bloc o est le curseur	LOAD.L	D3,(A1)+OOBPPR	COMP.L	D3,(A4)+OBTNBC	JUMP',LO 20$	LOAD.L	D3,(A4)+OBTNEXT	JUMP,EQ 90$	LOAD.L	A4,D3		; A4 <-- ^bloc suivant	CLR.L	D320$:	LOAD.L	D4,(A4)+OBTNBC	SUB.L	D4,D3		; D4 <-- nb de caractres restant dans ce bloc	LOAD.L	D0,D3		; D0 <-- position dans le bloc	LOAD.L	D1,(A1)+OOBPOC	; D1 <-- position absolue	SL.L	D3,#1	LOAD.L	A3,#(A4)+(D3.L)+LBT	LOAD.L	A2,(A1)+OOBPLI	; A2 <-- position en ligne	LOAD.L	D3,D2	CLR.B	D3	TEST.L	D3		; cherche aussi le mode ?	JUMP,EQ 40$		; non => 40$; Cherche un caractre complet (avec le mode).30$:	DEC.W	D432$:	LOAD.W	D3,(A3+)	CALL	CARDECO		; D3 <-- caractre complet	AND.L	D3,D2	TEST.L	D5:#0		; minuscules = majuscules ?	JUMP',BC 34$		; non => 34$	CALL	MINMAJ		; D3 <-- caractre majuscule34$:	COMP.L	D3,D6		; caractre trouv ?	JUMP,EQ 70$		; oui => 70$	INC.L	D0		; D0 <-- position dans le bloc suivante	INC.L	D1		; D1 <-- position absolue suivante	COMP.B	D3,#CR	JUMP',EQ 36$	COMP.B	D3,#LF	JUMP',NE 37$36$:	INC.L	A2		; A2 <-- position ligne suivante37$:	DECJ.W,NMO D4,32$	LOAD.L	D4,(A4)+OBTNEXT	JUMP,EQ 90$	LOAD.L	A4,D4		; A4 <-- ^bloc suivant	LOAD.L	D4,(A4)+OBTNBC	CLR.L	D0		; D0 <-- position dans le bloc	LOAD.L	A3,#(A4)+LBT	JUMP	30$; Cherche un caractre rduit (juste le code ASCII).40$:	TEST.L	D5:#0		; minuscules = majuscules ?	JUMP',BC 50$		; non => 50$41$:	DEC.W	D442$:	LOAD.W	D3,(A3+)	; D3 <-- caractre ASCII	CALL	MINMAJ		; D3 <-- caractre majuscule	COMP.B	D3,D6		; caractre trouv ?	JUMP,EQ 70$		; oui => 70$	INC.L	D0		; D0 <-- position dans le bloc suivante	INC.L	D1		; D1 <-- position absolue suivante	COMP.B	D3,#CR	JUMP',EQ 46$	COMP.B	D3,#LF	JUMP',NE 47$46$:	INC.L	A2		; A2 <-- position ligne suivante47$:	DECJ.W,NMO D4,42$	LOAD.L	D4,(A4)+OBTNEXT	JUMP,EQ 90$	LOAD.L	A4,D4		; A4 <-- ^bloc suivant	LOAD.L	D4,(A4)+OBTNBC	CLR.L	D0		; D0 <-- position dans le bloc	LOAD.L	A3,#(A4)+LBT	JUMP	41$50$:	DEC.W	D452$:	LOAD.W	D3,(A3+)	; D3 <-- caractre ASCII	COMP.B	D3,D6		; caractre trouv ?	JUMP',EQ 70$		; oui => 70$	INC.L	D0		; D0 <-- position dans le bloc suivante	INC.L	D1		; D1 <-- position absolue suivante	COMP.B	D3,#CR	JUMP',EQ 56$	COMP.B	D3,#LF	JUMP',NE 57$56$:	INC.L	A2		; A2 <-- position ligne suivante57$:	DECJ.W,NMO D4,52$	LOAD.L	D4,(A4)+OBTNEXT	JUMP',EQ 90$	LOAD.L	A4,D4		; A4 <-- ^bloc suivant	LOAD.L	D4,(A4)+OBTNBC	CLR.L	D0		; D0 <-- position dans le bloc	LOAD.L	A3,#(A4)+LBT	JUMP	50$70$:	LOAD.L	(A1)+OOBPPB,A4	LOAD.L	(A1)+OOBPPR,D0	LOAD.L	(A1)+OOBPOC,D1	LOAD.L	(A1)+OOBPLI,A2	LOAD.L	D4,D1		; D4 <-- position	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D3,D5,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; TXRCHERCHE >;===========/; Cherche un caractre en arrire, dans un objet texte.; Si le caractre n'est pas trouv, la position du curseur; n'est pas change !; in	A1.L	^objet texte;	D3.L	caractre cherch;	D2.L	masque ventuel;	D5.W	mode (si 2^0=1 --> min=maj); out	D4.L	position juste avant le caractre trouv;	D7.W	erreur; mod	D4.L, D7.WTXRCHERCHE:	PUSHM.L	D0..D3,D5,D6,A2..A4	TEST.L	D5:#0		; minuscules = majuscules ?	JUMP',BC 10$		; non => 10$	CALL	MINMAJ		; D3 <-- caractre majuscule cherch10$:	LOAD.L	D6,D3	AND.L	D6,D2		; D6 <-- caractre cherch; Cherche le premier bloc o chercher.	LOAD.W	D7,#1		; D7 <-- hors de la zone	LOAD.L	A4,(A1)+OOBPPB	; A4 <-- ^bloc o est le curseur	LOAD.L	D3,(A1)+OOBPPR	JUMP',NE 20$	LOAD.L	D3,(A4)+OBTPREV	JUMP,EQ 90$	LOAD.L	A4,D3		; A4 <-- ^bloc prcdent	LOAD.L	D3,(A4)+OBTNBC20$:	LOAD.L	D4,D3		; D4 <-- nb de caractres restant dans ce bloc	LOAD.L	D0,D3		; D0 <-- position dans le bloc	LOAD.L	D1,(A1)+OOBPOC	; D1 <-- position absolue	SL.L	D3,#1	LOAD.L	A3,#(A4)+(D3.L)+LBT	LOAD.L	A2,(A1)+OOBPLI	; A2 <-- position en ligne	LOAD.L	D3,D2	CLR.B	D3	TEST.L	D3		; cherche aussi le mode ?	JUMP,EQ 40$		; non => 40$; Cherche un caractre complet (avec le mode).30$:	DEC.W	D432$:	LOAD.W	D3,(-A3)	CALL	CARDECO		; D3 <-- caractre complet	AND.L	D3,D2	TEST.L	D5:#0		; minuscules = majuscules ?	JUMP',BC 34$		; non => 34$	CALL	MINMAJ		; D3 <-- caractre majuscule34$:	COMP.L	D3,D6		; caractre trouv ?	JUMP,EQ 70$		; oui => 70$	DEC.L	D0		; D0 <-- position dans le bloc prcdente	DEC.L	D1		; D1 <-- position absolue prcdente	COMP.B	D3,#CR	JUMP',EQ 36$	COMP.B	D3,#LF	JUMP',NE 37$36$:	DEC.L	A2		; A2 <-- position ligne prcdente37$:	DECJ.W,NMO D4,32$	LOAD.L	D4,(A4)+OBTPREV	JUMP,EQ 90$	LOAD.L	A4,D4		; A4 <-- ^bloc prcdent	LOAD.L	D4,(A4)+OBTNBC	LOAD.L	D0,D4		; D0 <-- position dans le bloc	LOAD.L	A3,#(A4)+(D4.L)+LBT	ADD.L	A3,D4	JUMP	30$; Cherche un caractre rduit (juste le code ASCII).40$:	TEST.L	D5:#0		; minuscules = majuscules ?	JUMP',BC 50$		; non => 50$41$:	DEC.W	D442$:	LOAD.W	D3,(-A3)	; D3 <-- caractre ASCII	CALL	MINMAJ		; D3 <-- caractre majuscule	COMP.B	D3,D6		; caractre trouv ?	JUMP,EQ 70$		; oui => 70$	DEC.L	D0		; D0 <-- position dans le bloc prcdente	DEC.L	D1		; D1 <-- position absolue prcdente	COMP.B	D3,#CR	JUMP',EQ 46$	COMP.B	D3,#LF	JUMP',NE 47$46$:	DEC.L	A2		; A2 <-- position ligne prcdente47$:	DECJ.W,NMO D4,42$	LOAD.L	D4,(A4)+OBTPREV	JUMP,EQ 90$	LOAD.L	A4,D4		; A4 <-- ^bloc prcdent	LOAD.L	D4,(A4)+OBTNBC	LOAD.L	D0,D4		; D0 <-- position dans le bloc	LOAD.L	A3,#(A4)+(D4.L)+LBT	ADD.L	A3,D4	JUMP	41$50$:	DEC.W	D452$:	LOAD.W	D3,(-A3)	; D3 <-- caractre ASCII	COMP.B	D3,D6		; caractre trouv ?	JUMP',EQ 70$		; oui => 70$	DEC.L	D0		; D0 <-- position dans le bloc prcdente	DEC.L	D1		; D1 <-- position absolue prcdente	COMP.B	D3,#CR	JUMP',EQ 56$	COMP.B	D3,#LF	JUMP',NE 57$56$:	DEC.L	A2		; A2 <-- position ligne prcdente57$:	DECJ.W,NMO D4,52$	LOAD.L	D4,(A4)+OBTPREV	JUMP,EQ 90$	LOAD.L	A4,D4		; A4 <-- ^bloc prcdent	LOAD.L	D4,(A4)+OBTNBC	LOAD.L	D0,D4		; D0 <-- position dans le bloc	LOAD.L	A3,#(A4)+(D4.L)+LBT	ADD.L	A3,D4	JUMP	50$70$:	LOAD.L	(A1)+OOBPPB,A4	LOAD.L	(A1)+OOBPPR,D0	LOAD.L	(A1)+OOBPOC,D1	LOAD.L	(A1)+OOBPLI,A2	LOAD.L	D4,D1		; D4 <-- position	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D3,D5,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; TXAVANCE >;=========/; Avance d'un caractre dans un objet texte.; in	A1.L	^objet texte; out	D3.L	caractre avanc;	D7.W	erreur; mod	D3.L, D7.WTXAVANCE:	PUSHM.L	D4,A4	LOAD.W	D7,#1		; D7 <-- hors de la zone	LOAD.L	A4,(A1)+OOBPPB	; A4 <-- ^bloc o est le curseur	LOAD.L	D4,(A1)+OOBPPR	COMP.L	D4,(A4)+OBTNBC	JUMP',LO 50$	LOAD.L	D4,(A4)+OBTNEXT	JUMP',EQ 90$	LOAD.L	A4,D4		; A4 <-- ^bloc suivant	LOAD.L	(A1)+OOBPPB,A4	CLR.L	D4	LOAD.L	(A1)+OOBPPR,D450$:	SL.L	D4,#1	LOAD.W	D3,(A4)+(D4.L)+LBT ; D3 <-- caractre saut;;?	CALL	CARDECO		; D3 <-- caractre complet	LOAD.B	D4,D3	CLR.B	D3		; D3 <-- codage	RR.W	D3,#6		; D3 <-- /256 puis *4	LOAD.L	A4,#(A5)+OTXCOD	LOAD.L	D3,(A4)+(D3.W)	LOAD.B	D3,D4	INC.L	(A1)+OOBPPR	; avance la position du curseur dans ce bloc	INC.L	(A1)+OOBPOC	; avance la position du curseur	COMP.B	D3,#CR	JUMP',EQ 70$	COMP.B	D3,#LF	JUMP',NE 72$70$:	INC.L	(A1)+OOBPLI	; avance d'une ligne72$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; TXRECULE >;=========/; Recule d'un caractre dans un objet texte.; in	A1.L	^objet texte; out	D3.L	caractre recul;	D7.W	erreur; mod	D3.L, D7.WTXRECULE:	PUSHM.L	D4,A4	LOAD.W	D7,#1		; D7 <-- hors de la zone	LOAD.L	A4,(A1)+OOBPPB	; A4 <-- ^bloc o est le curseur	LOAD.L	D4,(A1)+OOBPPR	JUMP',NE 50$	LOAD.L	D4,(A4)+OBTPREV	JUMP',EQ 90$	LOAD.L	A4,D4		; A4 <-- ^bloc prcdent	LOAD.L	(A1)+OOBPPB,A4	LOAD.L	D4,(A4)+OBTNBC	LOAD.L	(A1)+OOBPPR,D450$:	DEC.L	D4	SL.L	D4,#1	LOAD.W	D3,(A4)+(D4.L)+LBT ; D3 <-- caractre saut;;?	CALL	CARDECO		; D3 <-- caractre complet	LOAD.B	D4,D3	CLR.B	D3		; D3 <-- codage	RR.W	D3,#6		; D3 <-- /256 puis *4	LOAD.L	A4,#(A5)+OTXCOD	LOAD.L	D3,(A4)+(D3.W)	LOAD.B	D3,D4	DEC.L	(A1)+OOBPPR	; recule la position du curseur dans ce bloc	DEC.L	(A1)+OOBPOC	; recule la position du curseur	COMP.B	D3,#CR	JUMP',EQ 70$	COMP.B	D3,#LF	JUMP',NE 72$70$:	DEC.L	(A1)+OOBPLI	; recule d'une ligne72$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; TXMODE  >;========/; Modifie le mode d'une suite de caractres, dans un objet texte.; Ne modifie pas la position du curseur !; in	A1.L	^objet texte;	D3.L	nouveau mode;	D2.L	masque ventuel;	D4.L	position de dbut;	D5.L	nombre de caractres; out	D7.W	erreur; mod	D7.WTXMODE:	PUSHM.L	D0..D5,A3,A4	CLR.B	D2		; D2 <-- ne modifie jamais le caractre ASCII	LOAD.L	D0,D3	AND.L	D0,D2		; D0 <-- nouveau mode	NOT.L	D2		; D2 <-- masque; Cherche le premier caractre  modifier.	LOAD.W	D7,#1		; D7 <-- hors de la zone	LOAD.L	A4,(A1)+OOBFBT	CLR.L	D320$:	ADD.L	D3,(A4)+OBTNBC	COMP.L	D4,D3		; va dans ce bloc ?	JUMP',LO 24$		; oui => 24$	LOAD.L	D1,(A4)+OBTNEXT	JUMP,EQ 90$	LOAD.L	A4,D1		; A4 <-- ^bloc suivant	JUMP	20$24$:	LOAD.L	D1,D4	SUB.L	D1,D3	ADD.L	D1,(A4)+OBTNBC	SL.L	D1,#1	LOAD.L	A3,#(A4)+(D1.L)+LBT	SUB.L	D3,D4	LOAD.L	D4,D3		; D4 <-- nb de caractres restant; Modifie tous les caractres de la zone.30$:	DEC.W	D432$:	LOAD.W	D3,(A3+)	CALL	CARDECO		; D3 <-- caractre complet	LOAD.L	D1,D3	AND.L	D3,D2		; D3 <-- masque	OR.L	D3,D0		; D3 <-- nouveau mode	COMP.B	D3,#CR	JUMP',NE 34$	AND.L	D3,#-1-CCSOMSK-CCEXMSK34$:	COMP.L	D3,D1		; qq chose de chang ?	JUMP',EQ 38$		; non => 38$				; oui =>	CALL	CARCODE		; D3 <-- caractre cod	JUMP',NE 90$	LOAD.W	(A3)-2,D3	SET.B	(A1)+OOBMAJ	; mise  jour ncessaire38$:	DEC.L	D5		; encore un caractre ?	JUMP',EQ 80$		; non => 80$	DECJ.W,NMO D4,32$	LOAD.W	D7,#1		; D7 <-- hors de la zone	LOAD.L	D4,(A4)+OBTNEXT	JUMP',EQ 90$	LOAD.L	A4,D4		; A4 <-- ^bloc suivant	LOAD.L	D4,(A4)+OBTNBC	LOAD.L	A3,#(A4)+LBT	JUMP	30$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D5,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; TXINSERE >;=========/; Insre un caractre dans un objet texte.; in	A1.L	^objet texte;	D3.L	caractre  insrer; out	D7.W	erreur; mod	D7.WTXINSERE:	PUSHM.L	D1,D3,D4,A2..A4	COMP.B	D3,#CR	JUMP',NE 10$	AND.L	D3,#-1-CCSOMSK-CCEXMSK10$:	CALL	CARCODE		; D3 <-- caractre cod	JUMP,NE 90$	LOAD.L	A4,(A1)+OOBPPB	; A4 <-- ^bloc o est le curseur	COMP.L	(A4)+OBTNBC,#LBTCAR ; encore de la place dans ce bloc ?	JUMP,LO 50$		; oui => 50$; Ajoute un nouveau bloc aprs le bloc actuel (qui est plein).	LOAD.L	A3,A4		; A3 <-- ^bloc prcdent	LOAD.L	A2,(A3)+OBTNEXT	; A2 <-- ^bloc suivant	LOAD.L	D4,#LBT+(LBTCAR*2)	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour nouveau bloc	JUMP,NE 90$	LOAD.L	(A4)+OBTNEXT,A2	LOAD.L	(A4)+OBTPREV,A3	LOAD.L	(A3)+OBTNEXT,A4	LOAD.L	D1,A2	JUMP',EQ 30$	LOAD.L	(A2)+OBTPREV,A430$:	LOAD.L	D1,#LBTCAR	LOAD.L	D4,(A1)+OOBPPR	SUB.L	D1,D4	JUMP',NE 40$	CLR.L	(A4)+OBTNBC	; ne contient encore rien	LOAD.L	(A1)+OOBPPB,A4	CLR.L	(A1)+OOBPPR	JUMP'	50$40$:	LOAD.L	(A4)+OBTNBC,D1	DEC.W	D1	SL.L	D4,#1	LOAD.L	A2,#(A4)+LBT	LOAD.L	A4,#(A3)+(D4.L)+LBT42$:	LOAD.W	(A2+),(A4+)	DECJ.W,NMO D1,42$	LOAD.L	A4,A3	LOAD.L	(A4)+OBTNBC,(A1)+OOBPPR; Insre un caractre dans le bloc actuel.50$:	LOAD.L	D1,(A4)+OBTNBC	LOAD.L	A3,#(A4)+(D1.L)+LBT	ADD.L	A3,D1	SUB.L	D1,(A1)+OOBPPR	JUMP',EQ 65$	DEC.W	D1	LOAD.L	A2,#(A3)+260$:	LOAD.W	(-A2),(-A3)	; pousse dans le bloc	DECJ.W,NMO D1,60$65$:	LOAD.W	(A3),D3		; bloc <-- met le nouveau caractre	INC.L	(A4)+OBTNBC	; un caractre de plus dans ce bloc	INC.L	(A1)+OOBNBC	; un caractre de plus	INC.L	(A1)+OOBPPR	; avance la position du curseur dans ce bloc	INC.L	(A1)+OOBPOC	; avance la position du curseur	COMP.B	D3,#CR	JUMP',EQ 70$	COMP.B	D3,#LF	JUMP',NE 72$70$:	INC.L	(A1)+OOBNBL	; une ligne de plus	INC.L	(A1)+OOBPLI	; avance d'une ligne72$:	SET.B	(A1)+OOBMAJ	; mise  jour ncessaire	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1,D3,D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; TXDETRUIT >;==========/; Dtruit le caractre plac juste avant le curseur dans un objet texte.; in	A1.L	^objet texte; out	D3.L	caractre dtruit;	D7.W	erreur; mod	D3.L, D7.WTXDETRUIT:	PUSHM.L	D1,D4,A2..A4	LOAD.L	A4,(A1)+OOBPPB	; A4 <-- ^bloc o est le curseur	LOAD.L	D4,(A1)+OOBPPR	; est-on au dbut du bloc ?	JUMP',NE 20$		; non => 20$				; oui =>	LOAD.W	D7,#1	LOAD.L	D4,(A4)+OBTPREV	JUMP,EQ 90$	LOAD.L	A4,D4		; A4 <-- ^bloc prcdent	LOAD.L	(A1)+OOBPPB,A4	LOAD.L	D4,(A4)+OBTNBC	LOAD.L	(A1)+OOBPPR,D4; Supprime un caractre dans le bloc actuel.20$:	LOAD.L	A3,#(A4)+(D4.L)+LBT	ADD.L	A3,D4	LOAD.W	D3,(A3)-2	; D3 <-- caractre dtruit	CALL	CARDECO		; D3 <-- caractre complet	LOAD.L	D1,(A4)+OBTNBC	SUB.L	D1,D4	JUMP',EQ 35$	DEC.W	D1	LOAD.L	A2,#(A3)-230$:	LOAD.W	(A2+),(A3+)	; compactifie le bloc	DECJ.W,NMO D1,30$35$:	DEC.L	(A4)+OBTNBC	; un caractre de moins dans ce bloc	DEC.L	(A1)+OOBNBC	; un caractre de moins	DEC.L	(A1)+OOBPPR	; recule la position du curseur dans ce bloc	DEC.L	(A1)+OOBPOC	; recule la position du curseur	COMP.B	D3,#CR	JUMP',EQ 40$	COMP.B	D3,#LF	JUMP',NE 42$40$:	DEC.L	(A1)+OOBNBL	; une ligne de moins	DEC.L	(A1)+OOBPLI	; recule d'une ligne42$:	SET.B	(A1)+OOBMAJ	; mise  jour ncessaire; Supprime le bloc actuel, s'il est entirement vide.50$:	TEST.L	(A4)+OBTNBC	; bloc entirement vide ?	JUMP,NE 80$		; non => 80$				; oui =>	LOAD.L	A3,(A4)+OBTPREV	; A3 <-- ^bloc prcdent	LOAD.L	A2,(A4)+OBTNEXT	; A2 <-- ^bloc suivant	LOAD.L	D4,A3	JUMP',NE 60$	LOAD.L	D4,A2	JUMP,EQ 80$				; bloc prcdent n'existe pas =>	LOAD.L	A3,A2	CLR.L	(A3)+OBTPREV	LOAD.L	(A1)+OOBFBT,A3	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire du bloc	LOAD.L	(A1)+OOBPPB,A3	CLR.L	(A1)+OOBPPR	JUMP'	80$60$:	LOAD.L	D4,A2	JUMP',NE 65$				; bloc suivant n'existe pas =>	CLR.L	(A3)+OBTNEXT	JUMP'	70$65$:	LOAD.L	(A3)+OBTNEXT,A2	LOAD.L	(A2)+OBTPREV,A370$:	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire du bloc	LOAD.L	(A1)+OOBPPB,A3	LOAD.L	(A1)+OOBPPR,(A3)+OBTNBC80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1,D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; TXINIT  >;========/; Initialise un objet texte. Il sera vide et prt  tre utilis.; S'il contenait quelque chose, il est correctement vid.; in	A1.L	^objet texte; out	D7.W	erreur; mod	D7.WTXINIT:	PUSHM.L	D1,D4,A4	TEST.L	(A1)+OOBFBT	JUMP',EQ 25$; Libre tous les bloc de texte utiliss, sauf le premier.	LOAD.L	A4,(A1)+OOBFBT	LOAD.L	D4,(A4)+OBTNEXT	; D4 <-- ^deuxime bloc20$:	TEST.L	D4	JUMP',EQ 30$	LOAD.L	A4,D4		; A4 <-- ^bloc  supprimer	LOAD.L	D4,(A4)+OBTNEXT	; D4 <-- ^bloc suivant	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre un bloc	JUMP	20$; Cre un nouveau bloc libre.25$:	LOAD.L	D4,#LBT+(LBTCAR*2)	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour nouveau bloc	JUMP',NE 90$	LOAD.L	(A1)+OOBFBT,A4; Initialise le premier (et unique) bloc.30$:	LOAD.L	A4,(A1)+OOBFBT	CLR.L	(A4)+OBTPREV	CLR.L	(A4)+OBTNEXT	CLR.L	(A4)+OBTNBC	LOAD.L	(A1)+OOBPPB,A4	CLR.L	(A1)+OOBNBC	LOAD.L	(A1)+OOBNBL,#1	CLR.L	(A1)+OOBPOC	CLR.L	(A1)+OOBPLI	CLR.L	(A1)+OOBPPR	TCLR.B	(A1)+OOBMAJ:#BTXMIO ; mise  jour disque pas ncessaire	TSET.B	(A1)+OOBMAJ:#BTXMAF ; mise  jour affichage ncessaire	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1,D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; TXKILL  >;========/; Libre la mmoire d'un objet texte.; in	A1.L	^objet texte; out	-; mod	D7.WTXKILL:	PUSHM.L	D1,D4,A4	TEST.L	(A1)+OOBPTL	JUMP',EQ 20$	LOAD.L	A4,(A1)+OOBPTL	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire OTLxxx	CLR.L	(A1)+OOBPTL20$:	TEST.L	(A1)+OOBFBT	JUMP',EQ 90$; Libre tous les bloc de texte utiliss.	LOAD.L	A4,(A1)+OOBFBT	CLR.L	(A1)+OOBFBT30$:	LOAD.L	D4,(A4)+OBTNEXT	; D4 <-- ^bloc suivant	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre un bloc	TEST.L	D4	JUMP',EQ 90$	LOAD.L	A4,D4		; A4 <-- ^bloc  supprimer	JUMP	30$90$:	POPM.L	D1,D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CARDECO >;--------/; Dcode un caractre.; in	D3.W	caractre cod; out	D3.L	caractre complet; mod	D3.LCARDECO:	PUSH.B	D3		; stack <-- code du caractre	PUSH.L	A3	CLR.B	D3		; D3 <-- codage	RR.W	D3,#6		; D3 <-- /256 puis *4	LOAD.L	A3,#(A5)+OTXCOD	LOAD.L	D3,(A3)+(D3.W)	POP.L	A3	POP.B	D3		; D3 <-- caractre complet	RET;--------\\; CARCODE >;--------/; Code un caractre.; in	D3.L	caractre complet; out	D3.W	caractre cod;	D7.W	erreur; mod	D3.L, D7.WCARCODE:	PUSHM.L	D0,D2,D4,D5,A4	LOAD.B	D2,D3		; D2 <-- code du caractre	LOAD.B	D3,#1		; D3 <-- mode; Cherche si le mode demand existe dj.	LOAD.L	A4,#(A5)+OTXCOD	LOAD.W	D4,#TXMMAX-120$:	COMP.L	D3,(A4+)	; mode trouv ?	JUMP',EQ 37$		; oui => 37$	DECJ.W,NMO D4,20$; Cherche un emplacement libre.30$:	LOAD.L	A4,#(A5)+OTXCOD	LOAD.W	D4,#TXMMAX-132$:	TEST.L	(A4+)		; emplacement libre ?	JUMP',EQ 35$		; oui => 35$	DECJ.W,NMO D4,32$	JUMP'	40$35$:	LOAD.L	(A4)-4,D3	; OTXCOD <-- nouveau mode37$:	LOAD.W	D3,#TXMMAX-1	SUB.W	D3,D4		; D3 <-- codage (0..255)	RL.W	D3,#8	LOAD.B	D3,D2		; D3 <-- caractre cod	CLR.W	D7		; D7 <-- ok	JUMP'	90$; Regarde s'il existe des emplacements occups devenus inutiles,; car plus utiliss dans le texte.40$:	LOAD.W	D7,#190$:	POPM.L	D0,D2,D4,D5,A4	TEST.W	D7		; retour EQ/NE	RET	.END