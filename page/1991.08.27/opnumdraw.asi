	.SBTTL	OPNUMDRAW.ASI;--------\\; DRNUM   >;========/; Affiche le numro.; in	A4.L	^objet;	D2.L	mode de dessin;	D1.L	mode de la vue; out	-; mod	D7.WDRNUM:	PUSHM.L	D0..D5,A1..A4	LOAD.L	A1,A4		; A1 <-- ^objet	LOAD.L	D5,D2		; D5 <-- mode de dessin	LOAD.L	D0,(A5)+OFAN	; D0 <-- fanions	LOAD.L	A4,#(A5)+OBUDIS	LOAD.L	A3,#(A5)+OTEXTBLOOP$:	LOAD.B	D3,(A3)	JUMP',EQ BEND$	INC.L	A3	COMP.B	D3,#'#	JUMP',EQ BEND$	LOAD.B	(A4+),D3	; OBUDIS <-- texte avant #	JUMP	BLOOP$BEND$:	LOAD.W	D7,#DR_GETPAGE	PAGE_	DRAW		; D4 <-- page courante	TEST.W	D4	JUMP',NS MODEL$	ADD.W	D4,(A5)+ONUM	; D4 <-- ajoute la page initiale	AND.L	D4,#H'FFFF	CALL	DRPUT		; OBUDIS <-- nombre	JUMP'	ELOOP$MODEL$:	LOAD.B	(A4+),#'.	LOAD.B	(A4+),#'.	NEG.W	D4	DEC.W	D4		; D4 <-- 0..2ELOOP$:	LOAD.B	(A4+),(A3+)	; OBUDIS <-- texte aprs #	JUMP,NE ELOOP$	TCLR.L	D0:#BFANJAI	JUMP',BS JUSTAI$	TCLR.L	D0:#BFANJA	JUMP',BC JUST$JUSTA$:	TSET.L	D0:#BFANJG	TEST.L	D4:#0	JUMP',BS JUST$	TCLR.L	D0:#BFANJG	TSET.L	D0:#BFANJD	JUMP'	JUST$JUSTAI$:	TSET.L	D0:#BFANJG	TEST.L	D4:#0	JUMP',BC JUST$	TCLR.L	D0:#BFANJG	TSET.L	D0:#BFANJD;	JUMP'	JUST$JUST$:	PUSH.L	D0	LOAD.W	D3,(A5)+OCHAR	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D0,#IDENTCHAR	LOAD.W	D1,#opDGETDIM	PAGE_	OBJCALL		; A2/A3/A4/D3/D4 <-- paramtres	POPM.L	D0	JUMP,NE EXIT$	LOAD.L	A2,A4		; A2 <-- ^chasses	LOAD.L	D2,D3		; D2 <-- h1;h2	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ NOCOUL$	; non => NOCOUL$	PUSHM.L	D0,D2	LOAD.L	D3,D4	SWAP.W	D3		; D3 <-- couleur chair (selon CARGETPT)	LOAD.W	D2,#SETDOT	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D0,#IDENTCOLOR	LOAD.W	D1,#opDUSE	PAGE_	OBJCALL		; choisi la couleur pour dessiner le caractre	POPM.L	D0,D2NOCOUL$:	LOAD.L	A4,A3		; A4 <-- ^descripteur	LOAD.L	D1,(A1)+OOBA	; D1 <-- angle de rotation	LOAD.W	D7,#DR_GETPGC	; A3 <-- ^gencar bitmap	PAGE_	DRAW	JUMP,NE EXIT$	LOAD.L	A4,A3		; A4 <-- ^gencar bitmap (pour DR_CHARQ)	LOAD.L	A3,#(A5)+OBUDIS	; A3 <-- ^nombre	CLR.W	D4		; D4 <-- largeurLLOOP$:	CLR.W	D3	LOAD.B	D3,(A3+)	JUMP',EQ LEND$	SL.W	D3,#1	ADD.W	D4,(A2)+(D3.W)	; D4 <-- ajoute largeur d'un caractre	JUMP	LLOOP$LEND$:	LOAD.W	D3,(A1)+OOBP3+2	SUB.W	D3,(A1)+OOBP1+2	JUMP',NC DIMX$	NEG.W	D3		; D3 <-- largeur du rectangleDIMX$:	COMP.W	D4,D3		; rectangle assez large ?	JUMP,GE ERROR$		; non => ERROR$	LOAD.W	D3,(A1)+OOBP3+0	SUB.W	D3,(A1)+OOBP1+0	JUMP',NC DIMY$	NEG.W	D3		; D3 <-- hauteur du rectangleDIMY$:	LOAD.L	D1,D2	SWAP.W	D1	ADD.W	D1,D2		; D1 <-- h2+h1	COMP.W	D1,D3		; rectangle assez haut ?	JUMP,GE ERROR$		; non => ERROR$	TEST.L	D0:#BFANJD	JUMP',BS JUSTD$	TEST.L	D0:#BFANJG	JUMP',BS JUSTG$JUSTC$:	LOAD.W	D3,(A1)+OOBP3+2	SUB.W	D3,(A1)+OOBP1+2	ASR.W	D3,#1	ADD.W	D3,(A1)+OOBP1+2	SR.W	D4,#1	SUB.W	D3,D4		; D3 <-- position initiale en X	JUMP'	POSY$JUSTD$:	LOAD.W	D3,(A1)+OOBP1+2	COMP.W	D3,(A1)+OOBP3+2	JUMP',LE POSY$	LOAD.W	D3,(A1)+OOBP3+2	JUMP'	POSY$JUSTG$:	LOAD.W	D3,(A1)+OOBP1+2	COMP.W	D3,(A1)+OOBP3+2	JUMP',GE JUSTG2$	LOAD.W	D3,(A1)+OOBP3+2JUSTG2$:	SUB.W	D3,D4;	JUMP'	POSY$POSY$:	SWAP.W	D3	LOAD.W	D3,(A1)+OOBP3+0	SUB.W	D3,(A1)+OOBP1+0	ASR.W	D3,#1	ADD.W	D3,(A1)+OOBP1+0	LOAD.W	D4,D2	SWAP.W	D2	ADD.W	D4,D2		; D4 <-- h2+h1	SR.W	D4,#1	SUB.W	D3,D4	ADD.W	D3,D2		; D3 <-- position initiale en Y	SWAP.W	D3	LOAD.L	A3,#(A5)+OBUDIS	; A3 <-- ^nombre	LOAD.L	D2,D5		; D2 <-- mode de dessin	LOAD.L	D5,D3		; D5 <-- position initiale	LOAD.W	D1,(A1)+OOBA+0	; D1 <-- angle de rotationDLOOP$:	CLR.W	D3	LOAD.B	D3,(A3+)	JUMP,EQ EXIT$	LOAD.L	D4,D5	TEST.W	D1	JUMP',EQ DCHAR$	PUSH.L	D3	LOAD.L	D3,(A1)+OOBP1	; D3 <-- centre	LIB	?CALCPSYM	; D4 <-- tourn autour du centre	POP.L	D3DCHAR$:	LOAD.W	D7,#DR_CHARQ	PAGE_	DRAW		; dessine un caractre	SL.W	D3,#1	ADD.W	D5,(A2)+(D3.W)	; D5 <-- position suivante	JUMP	DLOOP$ERROR$:	LOAD.L	D4,#H'10000*COLORFPAGE+COLORCDRAW	LOAD.W	D7,#DR_COLORINIT	PAGE_	DRAW		; spcifie les couleurs	LOAD.L	A4,A1		; A4 <-- ^objet	LOAD.L	D2,D5		; D2 <-- mode de dessin	CALL	GETP1	LOAD.L	D3,D4		; D3 <-- P1	CALL	GETP3		; D4 <-- P3	LOAD.W	D7,#DR_LINE	PAGE_	DRAW	CALL	GETP2	LOAD.L	D3,D4		; D3 <-- P2	CALL	GETP4		; D4 <-- P4	LOAD.W	D7,#DR_LINE	PAGE_	DRAWEXIT$:	POPM.L	D0..D5,A1..A4	RET;--------\\; DRPUT   >;--------/; Met un nombre dans le buffer.; in	D0.L	fanions (BFAN*);	D4.L	nombre;	A4.L	^buffer; out	A4.L	^plus loin; mod	D7.W, A4.LDRPUT:	PUSHM.L	D2..D4,A3	TEST.W	D4		; numro ngatif ou nul ?	JUMP,LE EXIT$		; oui => EXIT$	TEST.L	D0:#BFANRMA	JUMP',BS ROMAIN$	TEST.L	D0:#BFANRMI	JUMP',BS ROMAIN$	LOAD.W	D3,#3		; D3 <-- nb max de digits	LOAD.W	D2,#2^BAFDCM	; D2 <-- mode compact	LIB	?PUTDEC		; buffer <-- nombre en ASCII	JUMP	EXIT$ROMAIN$:	LIB	?BINBCD		; D4 <-- nombre BCD	RL.W	D4,#4	LOAD.W	D3,D4	AND.W	D3,#B'1111	DEC.W	D3	JUMP',NS R100$	LOAD.L	A3,#R16"TR1000$	CALL	DRPUTTEXT	; buffer <-- milliersR100$:	RL.W	D4,#4	LOAD.W	D3,D4	AND.W	D3,#B'1111	DEC.W	D3	JUMP',NS R10$	LOAD.L	A3,#R16"TR100$	CALL	DRPUTTEXT	; buffer <-- centainesR10$:	RL.W	D4,#4	LOAD.W	D3,D4	AND.W	D3,#B'1111	DEC.W	D3	JUMP',NS R1$	LOAD.L	A3,#R16"TR10$	CALL	DRPUTTEXT	; buffer <-- dizainesR1$:	RL.W	D4,#4	LOAD.W	D3,D4	AND.W	D3,#B'1111	DEC.W	D3	JUMP',NS EXIT$	LOAD.L	A3,#R16"TR1$	CALL	DRPUTTEXT	; buffer <-- unitsEXIT$:	POPM.L	D2..D4,A3	TEST.W	D7		; retour EQ/NE	RETTR1$:	.ASCIZ	"i"		; 1	.ASCIZ	"ii"		; 2	.ASCIZ	"iii"		; 3	.ASCIZ	"iv"		; 4	.ASCIZ	"v"		; 5	.ASCIZ	"vi"		; 6	.ASCIZ	"vii"		; 7	.ASCIZ	"viii"		; 8	.ASCIZ	"ix"		; 9TR10$:	.ASCIZ	"x"		; 10	.ASCIZ	"xx"		; 20	.ASCIZ	"xxx"		; 30	.ASCIZ	"xl"		; 40	.ASCIZ	"l"		; 50	.ASCIZ	"lx"		; 60	.ASCIZ	"lxx"		; 70	.ASCIZ	"lxxx"		; 80	.ASCIZ	"xc"		; 90TR100$:	.ASCIZ	"c"		; 100	.ASCIZ	"cc"		; 200	.ASCIZ	"ccc"		; 300	.ASCIZ	"cd"		; 400	.ASCIZ	"d"		; 500	.ASCIZ	"dc"		; 600	.ASCIZ	"dcc"		; 700	.ASCIZ	"dccc"		; 800	.ASCIZ	"cm"		; 900TR1000$:	.ASCIZ	"m"		; 1000	.ASCIZ	"mm"		; 2000	.ASCIZ	"mmm"		; 3000	.ASCIZ	"mr"		; 4000	.ASCIZ	"r"		; 5000	.ASCIZ	"rm"		; 6000	.ASCIZ	"rmm"		; 7000	.ASCIZ	"rmmm"		; 8000	.ASCIZ	"mq"		; 9000	.EVEN;----------\\; DRPUTTEXT >;----------/; Met le nime texte d'une table dans le buffer.; in	D0.L	fanions;	D3.W	rang (0..n);	A3.L	^table;	A4.L	^buffer; out	A4.L	^plus loin; mod	D7.W, A4.LDRPUTTEXT:	PUSHM.L	D3,A3LOOP$:	DEC.W	D3	JUMP',NS PUT$SKIP$:	TEST.B	(A3+)	JUMP,NE SKIP$	JUMP	LOOP$PUT$:	LOAD.B	D3,(A3+)	JUMP',EQ EXIT$	TEST.L	D0:#BFANRMA	JUMP',BC BUFF$	LIB	?MINMAJBUFF$:	LOAD.B	(A4+),D3	JUMP	PUT$EXIT$:	POPM.L	D3,A3	RET	.END