	.SBTTL	PAGECOPY.ASI;-------------\\; ZONEDUPLIQUE >;=============/; Duplique tous les objets slectionns.; in	-; out	D7.W	erreur; mod	D7.WZONEDUPLIQUE:	PUSHM.L	D3,D4,A4	CALL	ZONEQREDUCE	; OZONY1/OZONY2 <-- zone englobante	CALL	WDOOPEN		; dessine dans la swdo	CALL	_1LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$LOOP$:	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	CALL	ZONEDUPLOBJ	; duplique un objet et tous ses fils	JUMP',NE EXIT$NEXT$:	CALL	_1LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	PUSH.W	D7	CALL	WDOCLOSE	; fin du dessin dans la swdo	LOAD.L	D3,(A6)+OZONY1	LOAD.L	D4,(A6)+OZONY2	CALL	DESALLWDO	; redessine toute la fentre	POP.W	D7	SET.B	(A6)+OMAJ	; mise  jour sur disque ncessaire	POPM.L	D3,D4,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; ZONEDUPLOBJ >;============/; Duplique un objet et tous ses fils.; in	A4.L	^objet  dupliquer; out	D7.W	erreur; mod	D7.WZONEDUPLOBJ:	PUSHM.L	A0..A5	LOAD.L	A0,A4		; A0 <-- ^source	LOAD.L	A1,#0		; A1 <-- pas de pre	LOAD.L	A2,A4		; A2 <-- ^frre cadet	CALL	ZONEDUPLONE	; duplique l'objet principal	JUMP',NE EXIT$	TEST.B	(A6)+OCOPDV	; duplique des objets vides ?	JUMP',T EXFC$		; oui => EXFC$	EX.L	A3,A4	CALL	_1LSTA_EXFC	; change, pour que l'objet cr soit dessus !	EX.L	A4,A3EXFC$:	TEST.L	(A4)+OobjPPFILS	; y a-t-il des fils ?	JUMP',EQ EXIT$		; non => EXIT$;	LOAD.L	A4,A4		; A4 <-- ^pre source	LOAD.L	A5,A3		; A5 <-- ^pre destination	CALL	ZONEDUPLFILS	; duplique rcursivement tous les filsEXIT$:	POPM.L	A0..A5	TEST.W	D7		; retour EQ/NE	RET;-------------\\; ZONEDUPLFILS >;-------------/; Duplique les fils d'un objet.; ATTENTION: rcursif avec le stack normal (SP) !; in	A4.L	^pre source;	A5.L	^pre destination; out	D7.W	erreur; mod	D7.WZONEDUPLFILS:	PUSHM.L	A0..A5	LOAD.L	A0,(A4)+OobjPPFILS ; A0 <-- ^fils benjamin	LOAD.L	A1,A5LOOP$:;	LOAD.L	A0,A0		; A0 <-- ^source;	LOAD.L	A1,A1		; A1 <-- ^pre	LOAD.L	A2,#0		; A2 <-- pas de frre cadet	CALL	ZONEDUPLONE	; duplique un fils	JUMP',NE EXIT$	TEST.L	(A0)+OobjPPFILS	; y a-t-il des petits-fils ?	JUMP',EQ NEXT$		; non => NEXT$	LOAD.L	A4,A0		; A4 <-- ^source	LOAD.L	A5,A3		; A5 <-- ^destination	CALL	ZONEDUPLFILS	; appel rcursif !	JUMP',NE EXIT$NEXT$:	TEST.L	(A0)+OobjPSFRERE ; encore un frre ?	JUMP',EQ EXIT$		; non => EXIT$	LOAD.L	A0,(A0)+OobjPSFRERE ; A0 <-- ^frre an	JUMP	LOOP$EXIT$:	POPM.L	A0..A5	TEST.W	D7		; retour EQ/NE	RET;------------\\; ZONEDUPLONE >;------------/; Duplique un objet, sans s'occuper de ses fils.; in	A0.L	^objet  dupliquer (source);	A1.L	^pre (si zro => selon A2.L);	A2.L	^frre cadet; out	A3.L	^objet cr;	D7.W	erreur; mod	D7.W, A3.LZONEDUPLONE:	PUSHM.L	D0..D4,A4	CLR.W	D4		; D4 <-- objet sans data	LOAD.W	D0,(A0)+OobjIDENT	JUMP',EQ INSERT$	LOAD.W	D4,#LIP	COMP.W	D0,#IDENTPAGE	JUMP',EQ INSERT$	LOAD.L	A3,(A0)+OobjPDATA ; A3 <-- ^data de l'objet source	LOAD.W	D1,#opCRCOPYLG	CALL	_1OBJCALL	; D4 <-- lg ncessaire	JUMP,NE EXIT$INSERT$:	LOAD.L	A3,A1		; A3 <-- ^pre ventuel	LOAD.L	A4,A2		; A2 <-- ^frre cadet ventuel	CALL	_1LSTA_INSERT	; A4 <-- ^racine objet destination	JUMP,NE EXIT$	LOAD.W	(A4)+OobjIDENT,(A0)+OobjIDENT	LOAD.L	(A4)+OobjBBOX1,(A0)+OobjBBOX1	LOAD.L	(A4)+OobjBBOX2,(A0)+OobjBBOX2	COMP.W	D0,#IDENTPAGE	JUMP,EQ PAGE$	TEST.B	(A6)+OCOPDV	; duplique des objets vides ?	JUMP',F XFER$		; non => XFER$				; oui =>	TEST.B	(A0)+OobjFLAGS:#BobjFLAG	JUMP',BC XFER$	PUSH.L	A4	LOAD.L	A4,(A4)+OobjPDATA	LOAD.L	A3,(A0)+OobjPDATA	LOAD.W	D1,#opCRCOPYEMPTY	CALL	_1OBJCALL	; (A4)++ <-- (A3)++	POPM.L	A4	JUMP',EQ OK$XFER$:	PUSH.L	A4	LOAD.L	A4,(A4)+OobjPDATA	LOAD.L	A3,(A0)+OobjPDATA	LOAD.W	D1,#opCRCOPYXFER	CALL	_1OBJCALL	; (A4)++ <-- (A3)++	POP.L	A4	JUMP'	OK$PAGE$:	PUSH.L	A4	LOAD.L	A4,(A4)+OobjPDATA	LOAD.L	A3,(A0)+OobjPDATA	DEC.W	D4		; D4 <-- -1  cause NMOPLOOP$:	LOAD.B	(A4+),(A3+)	; (A4)++ <-- (A3)++	DECJ.W,NMO D4,PLOOP$	POP.L	A4OK$:	LOAD.L	A3,A4		; A3 <-- ^objet cr	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D4,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; COPYMODEL >;==========/; Copie une page "modle".; in	A4.L	^page; out	D7.W	erreur; mod	D7.WCOPYMODEL:	PUSHM.L	D3,A2..A4	LOAD.L	A2,A4	CALL	COPYMSURF	; A4 <-- ^objet le plus grand	LOAD.L	(A6)+OCOPFO,A4	LOAD.L	(A6)+OCOPLO,A4	TEST.W	D7	JUMP',NE DUPL$SLOOP$:	LOAD.L	(A6)+OCOPFO,A4	TSET.B	(A4)+OobjFLAGS:#BobjFLAG	CALL	SUITEPREV	; A4 <-- ^objet prcdent de la chane	JUMP',NE DUPL$	LOAD.L	A3,A2		; A3 <-- ^page originale	CALL	_1LSTA_FILS	; dans la mme page ?	JUMP,EQ SLOOP$		; oui => SLOOP$DUPL$:	LOAD.L	A4,A2	SET.B	(A6)+OCOPDV	; duplique des objets vides	CALL	ZONEDUPLOBJ	; duplique la page et tous ses fils	CLR.B	(A6)+OCOPDV	; remet mode normal	TEST.W	D7	JUMP',NE CLR$	LOAD.L	A3,A4		; A3 <-- ^page originale	CALL	_1LSTA_NEXTF	; A4 <-- ^page copie	JUMP',NE OK$	LOAD.W	D3,#-1		; D3 <-- fait tous les chanages	CALL	COPYSUITE	; "copie" les chanagesOK$:	CLR.W	D7		; D7 <-- okCLR$:	PUSH.W	D7	CALL	COPYMCLR	; clear tous les flags	POP.W	D7	POPM.L	D3,A2..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; COPYPMODEL >;===========/; Cre une nouvelle page d'aprs une page modle "G/D/X".; in	D4.L	flags (BIP*); out	D7.W	erreur; mod	D7.WCOPYPMODEL:	PUSHM.L	D0..D6,A0..A5	LOAD.L	D6,(A6)+OOBACH	; D6 <-- canal de l'arbre des objets; Cre la nouvelle page vide, avec juste un calque "A".	LOAD.L	D2,D4		; D2 <-- flags	LOAD.W	D4,(A6)+OPAGE	; D4 <-- page frre cadet	CALL	_1GROUPNEWPAGE	; cre une nouvelle page vide	JUMP,NE EXIT$	LOAD.W	D3,D4	INC.W	D3		; D3 <-- numro de la page cre	LOAD.W	D4,#-1	CALL	_1LSTA_BEGIN	; A4 <-- ^page cre	JUMP,NE EXIT$	TEST.L	(A4)+OobjPDATA	JUMP,EQ EXIT$	LOAD.L	A3,(A4)+OobjPDATA	LOAD.L	(A3)+OIPFLG,D2	; instance objet page <-- flags	CALL	_1LSTA_NEXT	; A4 <-- ^calque "A" de la page cre	JUMP,NE EXIT$	LOAD.L	A1,A4		; A1 <-- futur pre pour les objets dupliqus; Cherche la page modle en fonction des flags.	LOAD.L	D4,D2		; D4 <-- flags	CLR.W	D3		; D3 <-- page modle "G"	TEST.L	D4:#BIPG	JUMP',BS COPY$	INC.W	D3		; D3 <-- page modle "D"	TEST.L	D4:#BIPD	JUMP',BS COPY$	INC.W	D3		; D3 <-- page modle "X"	TEST.L	D4:#BIPX	JUMP',BS COPY$	CLR.W	D3		; D3 <-- page modle "G"	TEST.B	(A6)+OPAGE+1:#0	; page pair ?	JUMP',BS COPY$		; oui => COPY$ (voir *)	INC.W	D3		; D3 <-- page modle "D"COPY$:	LOAD.W	D4,#-1		; D4 <-- pas de calques	CALL	_1LSTA_BEGIN	; A4 <-- ^page modle  dupliquer	JUMP,NE EXIT$	LOAD.L	A5,A4		; A5 <-- ^page modle; (*)	Le test est invers (BS), car la page cre est gale  OPAGE+1 !; Duplique tous les objets ditables et vides de la page modle; dans la nouvelle page cre.	CALL	_1LSTA_NB	; D4 <-- nb de fils	LOAD.W	D3,D4	JUMP',EQ SUITE$DLOOP$:	CALL	_1LSTA_NEXT	; A4 <-- ^objet suivant	JUMP',NE SUITE$	LOAD.W	D1,#opCRIFEMPTY	CALL	_1OBJCALLD	; D4 <-- zro si vide	JUMP',NE DNEXT$	TEST.L	D4		; objet vide ?	JUMP',NE DNEXT$		; non => DNEXT$	LOAD.L	A0,A4		; A0 <-- ^objet source	SET.B	(A6)+OCOPDV	; duplique un objet vide	CALL	ZONEDUPLONE	; duplique l'objet vide	CLR.B	(A6)+OCOPDV	; remet mode normal	TEST.W	D7	JUMP,NE EXIT$DNEXT$:	DEC.W	D3	JUMP,NE DLOOP$; Cherche le permier et le dernier objets ditables de la plus grande; chane dans la page modle.SUITE$:	LOAD.L	A4,A5		; A4 <-- ^page modle	CALL	COPYMSURF	; A4 <-- ^objet le plus grand	JUMP,NE OK$	LOAD.L	(A6)+OCOPFO,A4	LOAD.L	(A6)+OCOPLO,A4MLOOP$:	LOAD.L	(A6)+OCOPFO,A4	CALL	SUITEPREV	; A4 <-- ^objet prcdent de la chane	JUMP',NE MEND$	LOAD.L	A3,A5		; A3 <-- ^page modle	CALL	_1LSTA_FILS	; dans la mme page ?	JUMP,EQ MLOOP$		; oui => MLOOP$; Cherche la page cre (appele page copie) et celle juste avant.MEND$:	LOAD.W	D3,(A6)+OPAGE	; D3 <-- page avant celle cre	LOAD.W	D4,#-1	CALL	_1LSTA_BEGIN	; A4 <-- ^page prcdente	JUMP,NE OK$	LOAD.L	A2,A4		; A2 <-- ^page prcdente	CALL	_1LSTA_NEXTF	JUMP,NE OK$	LOAD.L	A1,A4		; A1 <-- ^page copie; Cre un chanage entre le plus grand pav de la page prcdente; et le premier pav de la page copie.	PUSH.L	A2	LOAD.L	A2,A5	LOAD.L	A4,(A6)+OCOPFO	CALL	COPYSRCSAME	; A3 <-- ^objet dans la page copie	POP.L	A2	LOAD.L	A4,A2	CALL	COPYMSURF	; A4 <-- ^objet le plus grand	JUMP',NE INT$	PUSHM.L	A2,A5	LOAD.L	A2,A4		; A2 <-- ^objet pre	LOAD.L	A4,A3	CALL	SUITEOUT	LOAD.L	A5,A2		; A5 <-- ^objet pre	CALL	SUITEIN		; fait un lien d'une page  l'autre	POPM.L	A2,A5; Cre les chanages dans la page copie comme dans la page modle.INT$:	LOAD.L	A3,A5		; A3 <-- ^page modle	LOAD.L	A4,A1		; A4 <-- ^page copie	LOAD.W	D3,#2^1		; D3 <-- fait les chanages dans la page	CALL	COPYSUITE	; "copie" les chanagesOK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D6,A0..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; COPYMSURF >;==========/; Cherche l'objet ditable ayant la plus grande surface dans une page.; Si plusieurs sont chans dans la mme page, tient compte de la; surface de toute la chane, et rend toujours le dernier.; in	A4.L	^page; out	A4.L	^objet ayant la plus grande surface;	D7.W	erreur; mod	D7.W, A4.LCOPYMSURF:	PUSHM.L	D1..D4,A0..A3	PUSH.L	(A6)+OARLIM	LOAD.L	(A6)+OARLIM,A4	LOAD.L	A2,A4	CLR.L	D2		; D2 <-- surface maximale	LOAD.L	A0,#0		; A0 <-- ^objet ayant la plus grande surfaceLOOP$:	LOAD.L	A4,A2	CALL	_1LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,NE END$	LOAD.L	A2,A4	LOAD.W	D3,#EDITNPGNEXT	LOAD.W	D1,#opEDITNEXTPREV	CALL	_1OBJCALLD	; A3 <-- ^objet suivant	JUMP,NE LOOP$	COMP.L	A3,#0	JUMP',EQ SURF$	LOAD.L	A4,A3	LOAD.L	A3,(A6)+OARLIM	; A3 <-- ^page originale	CALL	_1LSTA_FILS	; dans la mme page ?	JUMP,EQ LOOP$		; oui => LOOP$	LOAD.L	A4,A2SURF$:	LOAD.L	A1,A4	CLR.L	D3SLOOP$:	CALL	COPYMSURFONE	; D4 <-- surface de l'objet	ADD.L	D3,D4		; D3 <-- surface totale	CALL	SUITEPREV	; A4 <-- ^objet prcdent de la chane	JUMP',NE SEND$	LOAD.L	A3,(A6)+OARLIM	; A3 <-- ^page originale	CALL	_1LSTA_FILS	; dans la mme page ?	JUMP,EQ SLOOP$		; oui => SLOOP$SEND$:	COMP.L	D3,D2	JUMP,LO LOOP$	LOAD.L	D2,D3		; D2 <-- surface maximale	LOAD.L	A0,A1		; A0 <-- ^objet ayant la plus grande surface	JUMP	LOOP$END$:	LOAD.W	D7,#1		; D7 <-- rien trouv	LOAD.L	A4,A0	TEST.L	D2	JUMP',EQ EXIT$	CLR.W	D7		; D7 <-- trouv qq choseEXIT$:	POP.L	(A6)+OARLIM	POPM.L	D1..D4,A0..A3	TEST.W	D7		; retour EQ/NE	RET;-------------\\; COPYMSURFONE >;-------------/; Calcule la surface occupe par un objet.; in	A4.L	^objet; out	D4.L	surface occupe; mod	D4.L, D7.WCOPYMSURFONE:	PUSH.L	D3	LOAD.W	D4,(A4)+OobjBBOX2+2	SUB.W	D4,(A4)+OobjBBOX1+2 ; D4 <-- largeur	LOAD.W	D3,(A4)+OobjBBOX2+0	SUB.W	D3,(A4)+OobjBBOX1+0 ; D3 <-- hauteur	MUL.WU	D4,D3		; D4 <-- surface (largeur*hauteur)	POP.L	D3	RET;---------\\; COPYMCLR >;=========/; Clear tous les flags de la chane dans la page originale.; in	A4.L	^page; out	-; mod	D7.WCOPYMCLR:	PUSH.L	A4	LOAD.L	A4,(A6)+OCOPFO	; A4 <-- ^premier objt de la chaneLOOP$:	TCLR.B	(A4)+OobjFLAGS:#BobjFLAG	COMP.L	A4,(A6)+OCOPLO	; a-t-on atteint le dernier ?	JUMP',EQ EXIT$		; oui => EXIT$	CALL	SUITENEXT	; A4 <-- ^objet suivant de la chane	JUMP,EQ LOOP$EXIT$:	POP.L	A4	RET;----------\\; COPYSUITE >;==========/; Copie les chanages des pavs de textes.; in	A3.L		^page originale;	A4.L		^page copie;	(A6)+OCOPFO.L	^premier objet de la chane  copier;	(A6)+OCOPLO.L	^dernier objet de la chane  copier;	D3.W		 si :#0 -> chanage interpage;			 si :#1 -> chanage dans la page; out	-; mod	D7.W	.PC	PCVAR	.LOC	0OCOSPPO:.BLKB	4		; ^page originaleOCOSPPC:.BLKB	4		; ^page copieOCOSPOB:.BLKB	4		; ^objet courantLCOS:	.PC	PCCODECOPYSUITE:	PUSHM.L	A1..A5	LOAD.L	SP,#(SP)-LCOS	; SP <-- ^variables locales	LOAD.L	(SP)+OCOSPPO,A3	; OCOSPPO <-- ^page originale	LOAD.L	(SP)+OCOSPPC,A4	; OCOSPPO <-- ^page copie	TEST.L	D3:#0	JUMP',BC INTERN$	LOAD.L	A4,(A6)+OCOPFO	LOAD.L	A1,(SP)+OCOSPPC	; A1 <-- ^page copie	LOAD.L	A2,(SP)+OCOSPPO	; A2 <-- ^page originale	CALL	COPYSRCSAME	; A3 <-- ^objet dans la page copie	JUMP',NE INTERN$	LOAD.L	A4,A3	CALL	SUITEOUT	LOAD.L	A5,(A6)+OCOPLO	CALL	SUITEIN		; fait un lien d'une page  l'autreINTERN$:	TEST.L	D3:#1	JUMP',BC EXIT$	LOAD.L	(SP)+OCOSPOB,(A6)+OCOPFOLOOP$:	LOAD.L	A4,(SP)+OCOSPOB	COMP.L	A4,(A6)+OCOPLO	; a-t-on atteint le dernier de la chane ?	JUMP',EQ EXIT$		; oui => EXIT$	CALL	SUITENEXT	; A4 <-- ^objet suivant de la chane	JUMP',NE EXIT$	LOAD.L	A1,(SP)+OCOSPPC	; A1 <-- ^page copie	LOAD.L	A2,(SP)+OCOSPPO	; A2 <-- ^page originale	CALL	COPYSRCSAME	; A3 <-- ^objet dans la page copie	JUMP',NE EXIT$	LOAD.L	A5,A3	LOAD.L	A4,(SP)+OCOSPOB;	LOAD.L	A1,(SP)+OCOSPPC	; A1 <-- ^page copie;	LOAD.L	A2,(SP)+OCOSPPO	; A2 <-- ^page originale	CALL	COPYSRCSAME	; A3 <-- ^objet dans la page copie	JUMP',NE EXIT$	LOAD.L	A4,A5	CALL	SUITEOUT	LOAD.L	A5,A3	CALL	SUITEIN		; fait un lien dans la page copie	LOAD.L	A4,(SP)+OCOSPOB	CALL	SUITENEXT	; A4 <-- ^objet suivant de la chane	JUMP',NE EXIT$	LOAD.L	(SP)+OCOSPOB,A4	JUMP	LOOP$EXIT$:	LOAD.L	SP,#(SP)+LCOS	; SP <-- ajuste le stack	POPM.L	A1..A5	RET;------------\\; COPYSRCSAME >;------------/; Cherche l'objet copie (le mme) dans une autre page (appele; page copie).; in	A1.L	^page copie;	A2.L	^page originale (plus utilis !);	A4.L	^objet dans la page originale; out	A3.L	^objet dans la page copie;	D7.W	erreur; mod	D7.W, A3.LCOPYSRCSAME:	PUSHM.L	D3,D4,D6,A1,A4	LOAD.L	D6,(A6)+OOBACH	; D6 <-- canal de l'arbre des objets	EX.L	A4,A1		; A4 <-- page copie, A1 <-- ^objet cherch	CALL	_1LSTA_NB	; D4 <-- nb de fils	TEST.W	D4	JUMP',EQ ERROR$LOOP$:	CALL	_1LSTA_NEXT	; A4 <-- ^objet suivant	JUMP',NE ERROR$	LOAD.W	D3,(A1)+OobjIDENT	COMP.W	D3,(A4)+OobjIDENT	JUMP',NE NEXT$	LOAD.L	D3,(A1)+OobjBBOX1	COMP.L	D3,(A4)+OobjBBOX1	JUMP',NE NEXT$	LOAD.L	D3,(A1)+OobjBBOX2	COMP.L	D3,(A4)+OobjBBOX2	JUMP',NE NEXT$	LOAD.L	A3,A4		; A3 <-- ^objet copie	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$NEXT$:	DEC.W	D4	JUMP,NE LOOP$ERROR$:	LOAD.W	D7,#1		; D7 <-- pas trouvEXIT$:	POPM.L	D3,D4,D6,A1,A4	TEST.W	D7		; retour EQ/NE	RET.IF 0	PUSHM.L	D4,A2,A4	EX.L	A4,A2		; A4 <-- ^page originale, A2 <-- ^objet	CLR.W	D4OLOOP$:	CALL	_1LSTA_NEXT	; A4 <-- ^objet suivant	JUMP',NE EXIT$	INC.W	D4		; D4 <-- un de plus	COMP.L	A4,A2		; a-t-on atteint l'objet ?	JUMP,NE OLOOP$		; non => OLOOP$	LOAD.L	A4,A1		; A4 <-- ^page copieCLOOP$:	CALL	_1LSTA_NEXT	; A4 <-- ^objet suivant	JUMP',NE EXIT$	DEC.W	D4		; a-t-on atteint l'objet copie ?	JUMP,NE CLOOP$		; non => CLOOP$	LOAD.L	A3,A4		; A3 <-- ^objet dans page copieEXIT$:	POPM.L	D4,A2,A4	TEST.W	D7		; retour EQ/NE	RET.ENDIF	.END