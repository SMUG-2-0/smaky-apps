	.SBTTL	MPAGEREGLE;--------\\; RGMOVE  >;========/; Agit dans les rgles selon la souris.; in	A4.L	^objet texte;	D3.B	outil (ICOTXTABx); out	D7.W	erreur; mod	D7.WRGMOVE:	PUSHM.L	D1..D4,A5	LOAD.L	A5,A4		; A5 <-- ^objet	COMP.W	(A5)+OOOBJ,#ICOTX	JUMP,NE ERR$	CLR.W	D2	LOAD.B	D2,D3		; D2 <-- outil	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE ERR$	LOAD.L	D1,D4	CALL	RGDET		; D4 <-- |icne|position|	JUMP,NE ERR$	LOAD.L	D3,D4	SWAP.W	D3	TEST.W	D3		; est-on dans une icne ?	JUMP',NE MOVE$		; oui => MOVE$ADD$:	COMP.W	D2,#ICOTXTABM	JUMP,EQ ERR$	SWAP.W	D4	LOAD.W	D4,D2	SWAP.W	D4	CALL	RGADD		; ajoute un tabulateur	JUMP,NE ERR$	CALL	RGIICONE	; affiche l'icne	JUMP	OK$MOVE$:	COMP.W	D2,#ICOTXTABM	JUMP,NE ERR$	CALL	RGIICONE	; efface l'icne	CALL	RGSUB		; enlve un tabulateur	LOAD.L	D2,D4	LOAD.L	D3,D1	CALL	RGIICONEXY	; allume la premire icne	CALL	CCMO		; enlve la sourisMOVE2$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP',NE MOVE4$	CALL	IFMOUSE		; D4 <-- position de la souris	JUMP,NE MOVE2$	PUSH.L	D4	LOAD.L	D3,D1	LOAD.L	D4,D2	CALL	RGIICONEXY	; teint l'ancienne icne	POP.L	D3	CALL	RGIICONEXY	; allume la nouvelle icne	LOAD.L	D1,D3	JUMP	MOVE2$MOVE4$:	LOAD.L	D3,D1	LOAD.L	D4,D2	CALL	RGIICONEXY	; teint la dernire icne	LOAD.L	D4,D3	CALL	RGDET		; D4 <-- |icne|position|	JUMP',EQ MOVE6$	COMP.W	D7,#2	JUMP',NE OK$	LOAD.L	D3,D2	SWAP.W	D3	COMP.W	D3,#ICOTXMR	JUMP',EQ MOVE6$	COMP.W	D3,#ICOTXMG	JUMP',EQ MOVE6$	COMP.W	D3,#ICOTXMD	JUMP',EQ MOVE6$	COMP.W	D3,#ICOTXMH	JUMP',EQ MOVE6$	COMP.W	D3,#ICOTXMB	JUMP',NE OK$MOVE6$:	LOAD.W	D2,D4	LOAD.L	D4,D2	CALL	RGADD		; ajoute un tabulateur	JUMP',NE ERR$	CALL	RGIICONE	; affiche l'icne;	JUMP'	OK$OK$:	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$ERR$:	LOAD.W	D7,#1		; D7 <-- impossible;	JUMP'	EXIT$EXIT$:	POPM.L	D1..D4,A5	TEST.W	D7		; retour EQ/NE	RET;------\\; RGDET >;------/; Dtecte dans quel tabulateur est la souris.; in	A5.L	^objet texte;	D4.L	position de la souris; out	D4.L	|icne|position|;	D7.W	erreur (1=ailleur, 2=dpasse un peu); mod	D4.L, D7.WRGDET:	PUSHM.L	D1..D3,A4	SUB.W	D4,(A6)+OWPOS+2	JUMP,LO 80$	COMP.W	D4,(A6)+OWDIM+2	JUMP,HS 80$	SWAP.W	D4	SUB.W	D4,(A6)+OWPOS+0	JUMP,LO 80$	COMP.W	D4,(A6)+OWDIM+0	JUMP,HS 80$	SWAP.W	D4	LOAD.L	D2,D4		; D2 <-- position souris dans l'cran; Regarde si l'on est dans la rgle horizontale.	LOAD.L	D3,(A5)+OOTXPOS	LOAD.L	D4,(A5)+OOTXDIM	CALL	CONVP3L4	; D3/D4 <-- dans l'cran	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	D1,D2	SUB.W	D1,D3		; trop  gauche ?	JUMP,LT 50$	COMP.W	D1,D4		; trop  droite ?	JUMP,GE 40$	SWAP.W	D1	SWAP.W	D3	SUB.W	D1,D3		; trop bas ?	JUMP,GE 50$	NEG.W	D1	COMP.W	D1,#LREGLE+2	; trop haut ?	JUMP,GE 50$	SWAP.W	D1	LOAD.W	D3,D1	CALL	DETSCALEN	; D3 <-- plus petit (si n:1); Cherche dans quel tabulateur on est.	LOAD.L	A4,#(A5)+OOTXRTX ; A4 <-- ^liste des tabulateurs30$:	LOAD.L	D4,(A4+)	; D4 <-- |icne|position|	JUMP',EQ 34$	SUB.W	D4,#5	COMP.W	D3,D4	JUMP,LT 30$	ADD.W	D4,#5+5	COMP.W	D3,D4	JUMP,GE 30$32$:	SUB.W	D4,#5	CLR.W	D7		; D7 <-- trouv	JUMP	90$34$:	LOAD.L	D4,#H'10000*ICOTXMR	LOAD.W	D4,(A5)+OOTXRMR;	SUB.W	D4,#0	COMP.W	D3,D4	JUMP',LT 35$	ADD.W	D4,#0+5	COMP.W	D3,D4	JUMP,LT 32$35$:	LOAD.L	D4,#H'10000*ICOTXMG	LOAD.W	D4,(A5)+OOTXRMG	SUB.W	D4,#5	COMP.W	D3,D4	JUMP',LT 36$	ADD.W	D4,#5+5	COMP.W	D3,D4	JUMP,LT 32$36$:	LOAD.L	D4,#H'10000*ICOTXMD	LOAD.W	D4,(A5)+OOTXDIM+2	SUB.W	D4,(A5)+OOTXRMD	SUB.W	D4,#5+1	COMP.W	D3,D4	JUMP',LT 38$	ADD.W	D4,#5+5	COMP.W	D3,D4	JUMP,LT 32$38$:	CLR.L	D4		; D4 <-- pas d'icme	LOAD.W	D4,D3		; D4 <-- position	CLR.W	D7		; D7 <-- trouv	JUMP	90$40$:	CLR.L	D4		; D4 <-- pas d'icme	LOAD.W	D4,(A5)+OOTXDIM+2	DEC.W	D4		; D4 <-- position	LOAD.W	D7,#2	JUMP	90$; Regarde si l'on est dans la rgle verticale.50$:	LOAD.L	D3,(A5)+OOTXPOS	LOAD.L	D4,(A5)+OOTXDIM	CALL	CONVP3L4	; D3/D4 <-- dans l'cran	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3;	SWAP.W	D3;	SWAP.W	D4	LOAD.L	D1,D2	SWAP.W	D1;	SWAP.W	D3;	SWAP.W	D4	SUB.W	D1,D3		; trop en haut ?	JUMP,LT 72$	COMP.W	D1,D4		; trop en bas ?	JUMP,GE 70$	SWAP.W	D1	SWAP.W	D3	SUB.W	D1,D3		; trop  droite ?	JUMP,GE 80$	NEG.W	D1	COMP.W	D1,#LREGLE+2	; trop  gauche ?	JUMP,GE 80$	SWAP.W	D1	LOAD.W	D3,D1	CALL	DETSCALEN	; D3 <-- plus petit (si n:1); Cherche dans quel tabulateur on est.	LOAD.L	D4,#H'10000*ICOTXMH	LOAD.W	D4,(A5)+OOTXRMH	SUB.W	D4,#5	COMP.W	D3,D4	JUMP',LT 66$	ADD.W	D4,#5+5	COMP.W	D3,D4	JUMP,LT 32$66$:	LOAD.L	D4,#H'10000*ICOTXMB	LOAD.W	D4,(A5)+OOTXDIM+0	SUB.W	D4,(A5)+OOTXRMB	SUB.W	D4,#5+1	COMP.W	D3,D4	JUMP',LT 68$	ADD.W	D4,#5+5	COMP.W	D3,D4	JUMP,LT 32$68$:	CLR.L	D4		; D4 <-- pas d'icme	LOAD.W	D4,D3		; D4 <-- position	CLR.W	D7		; D7 <-- trouv	JUMP'	90$70$:	CLR.L	D4		; D4 <-- pas d'icme	LOAD.W	D4,(A5)+OOTXDIM+0	DEC.W	D4		; D4 <-- position	LOAD.W	D7,#2	JUMP'	90$72$:	CLR.L	D4		; D4 <-- pas d'icme	LOAD.W	D7,#2	JUMP'	90$80$:	LOAD.W	D7,#1		; D7 <-- pas trouv90$:	POPM.L	D1..D3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; RGIDRAW >;========/; Inverse les rgles horizontales et verticales.; in	A5.L	^objet texte;	D3.B	outil (ICOTXTABx); out	-; mod	D7.WRGIDRAW:	PUSHM.L	D1..D4,A5	LOAD.L	A5,A4		; A5 <-- ^objet	COMP.W	(A5)+OOOBJ,#ICOTX	JUMP,NE 90$	COMP.B	D3,#ICOTXTABM	JUMP',EQ 20$	COMP.B	D3,#ICOTXTABD	JUMP',EQ 20$	COMP.B	D3,#ICOTXTABG	JUMP',EQ 20$	COMP.B	D3,#ICOTXTABC	JUMP',EQ 20$	COMP.B	D3,#ICOTXTABN	JUMP,NE 90$20$:	CALL	OPEWDO		; dessine dans la swdo	LOAD.W	D2,#INVDOT	LOAD.L	D3,(A5)+OOTXPOS	LOAD.L	D4,(A5)+OOTXDIM	CALL	CONVP3L4	; D3/D4 <-- dans l'cran	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	PUSHM.L	D3,D4	DEC.W	D3	INC.W	D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,#LREGLE+3	LOAD.W	D4,#LREGLE+1	SWAP.W	D3	SWAP.W	D4	LIB	?DRRECT		; dessine cadre rgle horizontale	LOAD.W	D1,(A6)+OBUGC+OGCX	CALL	RGIGRADH	; dessine graduation dans rgle horizontale	POPM.L	D3,D4	SUB.W	D3,#LREGLE+3	LOAD.W	D4,#LREGLE+1	SWAP.W	D3	SWAP.W	D4	DEC.W	D3	INC.W	D4	SWAP.W	D3	SWAP.W	D4	LIB	?DRRECT		; dessine cadre rgle verticale	LOAD.W	D1,(A5)+OOTXITL+2	CALL	RGIGRADV	; dessine graduation dans rgle verticale	CALL	RGITABH		; inverse les tabluateurs horizontaux	LOAD.L	D4,#H'10000*ICOTXMR	LOAD.W	D4,(A5)+OOTXRMR	CALL	RGIICONE	; inverse le renfoncement	LOAD.L	D4,#H'10000*ICOTXMG	LOAD.W	D4,(A5)+OOTXRMG	CALL	RGIICONE	; inverse la marge gauche	LOAD.L	D4,#H'10000*ICOTXMD	LOAD.W	D4,(A5)+OOTXDIM+2	SUB.W	D4,(A5)+OOTXRMD	DEC.W	D4	CALL	RGIICONE	; inverse la marge droite	LOAD.L	D4,#H'10000*ICOTXMH	LOAD.W	D4,(A5)+OOTXRMH	CALL	RGIICONE	; inverse la marge haute	LOAD.L	D4,#H'10000*ICOTXMB	LOAD.W	D4,(A5)+OOTXDIM+0	SUB.W	D4,(A5)+OOTXRMB	DEC.W	D4	CALL	RGIICONE	; inverse la marge basse	CALL	CLOWDO		; fin du dessin dans la swdo90$:	POPM.L	D1..D4,A5	RET;---------\\; RGIGRADH >;---------/; Dessine une graduation dans une rgle horizontale.; in	D1.W	incrment;	D2.W	mode de dessin;	D3.L	position (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WRGIGRADH:	PUSHM.L	D0..D5	EX.L	D3,D1	CALL	DETSCALEP	; D1 <-- plus grand (si n:1)	EX.L	D1,D3	COMP.W	D1,#3	JUMP,LO 90$	ADD.W	D4,D3		; D4 <-- max  ne pas dpasser	INC.W	D3	SWAP.W	D3	SWAP.W	D4	DEC.W	D4	ADD.W	D3,D4		; D3 <-- origine en Y	NEG.W	D4		; D4 <-- hauteur ngative	SWAP.W	D3	SWAP.W	D4	CLR.L	D020$:	PUSHM.L	D3,D4	SWAP.W	D4	LOAD.B	D5,D0	AND.B	D5,#B'11	LOAD.W	D4,#-1	TEST.L	D5:#0	JUMP',BS 30$	LOAD.W	D4,#-2	COMP.B	D5,#B'10	JUMP',EQ 30$	LOAD.W	D4,#-430$:	SWAP.W	D4	CLR.W	D4	LIB	?DRSEG	POPM.L	D3,D4	INC.L	D0	ADD.W	D3,D1		; D3 <-- origine en X suivante	COMP.W	D3,D4		; dpasse  droite ?	JUMP,LT 20$		; non => 20$90$:	POPM.L	D0..D5	RET;---------\\; RGIGRADV >;---------/; Dessine une graduation dans une rgle verticale.; in	D1.W	incrment;	D2.W	mode de dessin;	D3.L	position (y;x);	D4.L	dimensions (dy;dx); out	-; mod	D7.WRGIGRADV:	PUSHM.L	D0..D5	EX.L	D3,D1	CALL	DETSCALEP	; D1 <-- plus grand (si n:1)	EX.L	D1,D3	COMP.W	D1,#3	JUMP,LO 90$	DEC.W	D4	ADD.W	D3,D4		; D3 <-- origine en Y	NEG.W	D4		; D4 <-- largeur ngative	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3		; D4 <-- max  ne pas dpasser	INC.W	D3	SWAP.W	D3	SWAP.W	D4	CLR.L	D020$:	PUSHM.L	D3,D4	LOAD.B	D5,D0	AND.B	D5,#B'11	LOAD.W	D4,#-1	TEST.L	D5:#0	JUMP',BS 30$	LOAD.W	D4,#-2	COMP.B	D5,#B'10	JUMP',EQ 30$	LOAD.W	D4,#-430$:	AND.L	D4,#H'FFFF	LIB	?DRSEG	POPM.L	D3,D4	INC.L	D0	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D1		; D3 <-- origine en Y suivante	COMP.W	D3,D4		; dpasse en bas ?	JUMP',GE 90$		; oui => 90$	SWAP.W	D3	SWAP.W	D4	JUMP	20$90$:	POPM.L	D0..D5	RET;--------\\; RGITABH >;--------/; Inverse les tabluateurs horizontaux.; in	A5.L	^objet texte; out	-; mod	D7.WRGITABH:	PUSHM.L	D4,A4	LOAD.L	A4,#(A5)+OOTXRTX ; A4 <-- ^liste des tabulateurs20$:	LOAD.L	D4,(A4+)	; D4 <-- |icne|position|	JUMP',EQ 90$	CALL	RGIICONE	; inverse un tabulateur	JUMP	20$90$:	POPM.L	D4,A4	RET;---------\\; RGIICONE >;---------/; Inverse une icne dans une rgle.; in	A5.L	^objet texte;	D4.L	|icne|position|; out	-; mod	D7.WRGIICONE:	PUSHM.L	D1..D5,A1..A4	LOAD.W	D3,D4	CALL	DETSCALEP	; D3 <-- plus grand (si n:1)	LOAD.W	D2,D3		; D2 <-- position	LOAD.L	A2,#R16"TABLE$-8	SWAP.W	D4		; D4 <-- icne20$:	ADD.L	A2,#8	TEST.W	(A2)	JUMP,EQ 90$	COMP.W	D4,(A2)		; icne trouve ?	JUMP,NE 20$		; non => 20$	LOAD.L	D3,(A5)+OOTXPOS	LOAD.L	D4,(A5)+OOTXDIM	CALL	CONVP3L4	; D3/D4 <-- dans l'cran	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	CALL	OPEWDO		; dessine dans la swdo	CALL	CCMO		; enlve la souris	TEST.W	(A2)+2		; dans la rgle verticale ?	JUMP',NE 40$		; oui => 40$	COMP.W	D2,D4		; dpasse  droite ?	JUMP,HI 80$		; oui => 80$	LOAD.L	D4,D3	ADD.W	D4,D2	SUB.W	D4,(A2)+4	SWAP.W	D4	SUB.W	D4,#LREGLE+2	SUB.W	D4,(A2)+6	SWAP.W	D4		; D4 <-- position dans l'cran	JUMP'	42$40$:	SWAP.W	D4	COMP.W	D2,D4		; dpasse en bas ?	JUMP,HI 80$		; oui => 80$	LOAD.L	D4,D3	SUB.W	D4,#LREGLE+2	SUB.W	D4,(A2)+4	SWAP.W	D4	ADD.W	D4,D2	SUB.W	D4,(A2)+6	SWAP.W	D4		; D4 <-- position dans l'cran42$:	LOAD.L	A4,#0		; A4 <-- destination dans l'cran	LOAD.L	A3,(A6)+OPGICO	; A3 <-- ^gencar des icnes IPP21	LOAD.W	D3,(A2)	TCLR.L	D3:#7	JUMP',BC 50$	LOAD.L	A3,(A6)+OPHICO	; A3 <-- ^gencar des icnes IPP2250$:	MUL.WU	D3,(A3)+OGCMSB	ADD.L	D3,#OGCMAT	LOAD.L	A3,#(A3)+(D3.L)	; A3 <-- ^bonne matrice	CLR.L	D3		; D3 <-- position dans source	LOAD.W	D5,#GCICX/8	; D5 <-- Iy source	LOAD.L	D2,#H'10000*GCICY+GCICX	LOAD.W	D1,#INVDOT	; D1 <-- mode	LOAD.L	A2,A0		; A2 <-- ^descripteur	LOAD.L	A1,(A6)+ORASTER	CALL	(A1)		; GRA_RASTER80$:	CALL	CLOWDO		; fin du dessin dans la swdo90$:	POPM.L	D1..D5,A1..A4	RETTABLE$:	.W	ICOTXTABD,0	15,4	.W	ICOTXTABG,0	15,4	.W	ICOTXTABC,0	11,4	.W	ICOTXTABN,0	11,4	.W	ICOTXMR,0	8,4	.W	ICOTXMG,0	8,4	.W	ICOTXMD,0	8,4	.W	ICOTXMH,1	0,8	.W	ICOTXMB,1	0,8	.W	0;-----------\\; RGIICONEXY >;-----------/; Inverse une icne n'importe o.; in	D4.L	|icne|-|;	D3.L	position (y;x); out	-; mod	D7.WRGIICONEXY:	PUSHM.L	D1..D5,A1..A4	LOAD.L	A2,#R16"TABLE$-6	SWAP.W	D4		; D4 <-- icne20$:	ADD.L	A2,#6	TEST.W	(A2)	JUMP,EQ 90$	COMP.W	D4,(A2)		; icne trouve ?	JUMP,NE 20$		; non => 20$	CALL	CCMO		; enlve la souris	LOAD.L	D4,D3	SUB.W	D4,(A2)+2	SWAP.W	D4	SUB.W	D4,(A2)+4	SWAP.W	D4		; D4 <-- position dans l'cran	LOAD.L	A4,#0		; A4 <-- destination dans l'cran	LOAD.L	A3,(A6)+OPGICO	; A3 <-- ^gencar des icnes IPP21	LOAD.W	D3,(A2)	TCLR.L	D3:#7	JUMP',BC 50$	LOAD.L	A3,(A6)+OPHICO	; A3 <-- ^gencar des icnes IPP2250$:	MUL.WU	D3,(A3)+OGCMSB	ADD.L	D3,#OGCMAT	LOAD.L	A3,#(A3)+(D3.L)	; A3 <-- ^bonne matrice	CLR.L	D3		; D3 <-- position dans source	LOAD.W	D5,#GCICX/8	; D5 <-- Iy source	LOAD.L	D2,#H'10000*GCICY+GCICX	LOAD.W	D1,#INVDOT	; D1 <-- mode	LOAD.L	A2,A0		; A2 <-- ^descripteur	LOAD.L	A1,(A6)+ORASTER	CALL	(A1)		; GRA_RASTER90$:	POPM.L	D1..D5,A1..A4	RETTABLE$:	.W	ICOTXTABD	15,10	.W	ICOTXTABG	15,10	.W	ICOTXTABC	11,10	.W	ICOTXTABN	11,10	.W	ICOTXMR		8,10	.W	ICOTXMG		8,10	.W	ICOTXMD		8,10	.W	ICOTXMH		6,8	.W	ICOTXMB		6,8	.W	0;--------\\; RGNEXT  >;========/; Cherche le tabulateur suivant.; in	A5.L	^objet texte;	D2.L	position; out	D2.L	position suivante;	D7.W	erreur; mod	D2.L, D7.WRGNEXT:	PUSHM.L	D3,D4,A4	LOAD.L	A4,#(A5)+OOTXRTX ; A4 <-- ^liste des tabulateurs;;?	TEST.L	(A4)		; au moins un tabulateur ?;;?	JUMP,EQ 80$		; non => 80$20$:	LOAD.L	D4,(A4+)	; D4 <-- |icne|position|	JUMP',EQ 80$	ADD.W	D4,(A5)+OOTXPOS+2	SUB.W	D4,(A6)+OTXPOS+2	JUMP,LE 20$	CALL	RGNEXTLG	; D3 <-- lg "ngative"	SUB.W	D4,D3	JUMP,LE 20$	COMP.W	D2,D4	JUMP,HS 20$	LOAD.W	D2,D4		; D2 <-- nouvelle position80$:	CLR.W	D7		; D7 <-- ok	JUMP'	90$85$:	LOAD.W	D7,#1		; D7 <-- pas trouv;	JUMP'	90$90$:	POPM.L	D3,D4,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; RGNEXTLG >;---------/; Cherche la longueur jusqu'au prochain tabulateur.; in	D4.L	|icne|-|; out	D3.W	longueur (0..n); mod	D3.L, D7.WRGNEXTLG:	PUSHM.L	D0..D2,D4	LOAD.L	D2,D4	SWAP.W	D2		; D2 <-- icne	CLR.W	D3		; D3 <-- longueur nulle	COMP.W	D2,#ICOTXTABD	; tabulateur droite (normal) ?	JUMP,EQ 90$	CALL	TXPSAUVE	; D4 <-- no de la position	PUSH.W	D4		; stack <-- no position initiale	CLR.W	D0		; D0 <-- longueur20$:	CALL	TXAVANCE	JUMP',NE 50$	COMP.B	D3,#CR	JUMP',EQ 50$	COMP.B	D3,#EOP	JUMP',EQ 50$	COMP.B	D3,#TAB	JUMP',EQ 50$	COMP.W	D2,#ICOTXTABN	; tabulateur numrique ?	JUMP',NE 30$	COMP.B	D3,#'.	JUMP',EQ 50$	COMP.B	D3,#',	JUMP',EQ 50$30$:	CALL	EDGETLGC	; D1 <-- largeur du caractre	ADD.W	D0,D1	JUMP	20$50$:	POP.W	D4		; D4 <-- no position initiale	CALL	TXPPREND	; remet le curseur o il tait	COMP.W	D2,#ICOTXTABC	; tabulateur centr ?	JUMP',NE 60$	SR.W	D0,#160$:	LOAD.W	D3,D0		; D3 <-- longueur90$:	POPM.L	D0..D2,D4	RET;--------\\; RGADD   >;========/; Ajoute un tabulateur.; in	A5.L	^objet texte;	D4.L	|icne|position|; out	D7.W	erreur; mod	D7.WRGADD:	PUSHM.L	D2..D4,A3,A4	LOAD.L	D3,D4	SWAP.W	D3	COMP.W	D3,#ICOTXMR	JUMP,EQ 50$	COMP.W	D3,#ICOTXMG	JUMP,EQ 51$	COMP.W	D3,#ICOTXMD	JUMP,EQ 52$	COMP.W	D3,#ICOTXMH	JUMP,EQ 54$	COMP.W	D3,#ICOTXMB	JUMP,EQ 56$	LOAD.L	A4,#(A5)+OOTXRTX ; A4 <-- ^liste des tabulateurs	CLR.W	D220$:	INC.W	D2	LOAD.L	D3,(A4+)	; D3 <-- |icne|position|	JUMP',EQ 30$	COMP.W	D4,D3	JUMP,HI 20$30$:	DEC.W	D2	SUB.L	A4,#4	CLR.W	D332$:	INC.W	D2	INC.W	D3	TEST.L	(A4+)	JUMP,NE 32$	LOAD.W	D7,#1		; D7 <-- trop de tabulateurs	COMP.W	D2,#RGMAXTAB	JUMP',HS 90$	LOAD.L	A3,#(A4)+440$:	LOAD.L	(-A3),(-A4)	; creuse le trou	DEC.W	D3	JUMP,NE 40$	LOAD.L	(A4),D4	JUMP'	80$50$:				; renfoncement =>	LOAD.W	(A5)+OOTXRMR,D4	JUMP'	80$51$:				; marge gauche =>	LOAD.W	(A5)+OOTXRMG,D4	JUMP'	80$52$:				; marge droite =>	SUB.W	D4,(A5)+OOTXDIM+2	NEG.W	D4	DEC.W	D4	LOAD.W	(A5)+OOTXRMD,D4	JUMP'	80$54$:				; marge haute =>	LOAD.W	(A5)+OOTXRMH,D4	JUMP'	80$56$:				; marge basse =>	SUB.W	D4,(A5)+OOTXDIM+0	NEG.W	D4	DEC.W	D4	LOAD.W	(A5)+OOTXRMB,D4;	JUMP'	80$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; RGSUB   >;========/; Supprime un tabulateur.; in	A5.L	^objet texte;	D4.L	|icne|position|; out	D7.W	erreur; mod	D7.WRGSUB:	PUSHM.L	D3,D4,A3,A4	LOAD.L	A4,#(A5)+OOTXRTX ; A4 <-- ^liste des tabulateurs	LOAD.W	D7,#1		; D7 <-- pas trouv20$:	LOAD.L	D3,(A4+)	; D3 <-- |icne|position|	JUMP',EQ 90$	COMP.W	D4,D3	JUMP,NE 20$	LOAD.L	A3,#(A4)-430$:	LOAD.L	(A3+),(A4+)	; bouche le trou	JUMP,NE 30$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET	.END