	.SBTTL	MPAGEIO;---------\\; _PAGE_IO >;=========/; ; in	D7.W	numro du sous-appel;	?	selon appel; out	?	selon appel; mod	?	selon appel_PAGE_IO:	COMP.W	D7,#IO_RPEN	JUMP,EQ PENFPREND	COMP.W	D7,#IO_RTRAME	JUMP,EQ TRAFPREND	COMP.W	D7,#IO_RTEXT	JUMP,EQ IORTEXT	COMP.W	D7,#IO_WTEXT	JUMP,EQ IOWTEXT	COMP.W	D7,#IO_RPAGE	JUMP,EQ IORPAGE	COMP.W	D7,#IO_WPAGE	JUMP,EQ IOWPAGE	RET;---------\\; PENPREND >;=========/; Prend un fichier de pinceaux.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WPENPREND:	PUSHM.L	D1,D2,D4,A3..A520$:	LOAD.W	D1,#DBOX_PREND	LOAD.W	D2,#2^BDBEXTEND!2^BDBSAV	LOAD.L	D3,#LBUNAME!2^BDBIOEXT1	LOAD.L	A3,#R16"TIOPEN	LOAD.L	A4,#R16"TEXPEN	LOAD.L	A5,#(A6)+ONAPEN	DBOX_	EXTEND		; demande le nom ...	JUMP',NE 90$	COMP.W	D3,#F1	JUMP',NE 90$	LOAD.L	A3,#(A6)+ONAPEN	CALL	PENFPREND	; lit un fichier .PPAGE	JUMP',EQ 90$	PUSH.W	D7	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	JUMP	20$90$:	POPM.L	D1,D2,D4,A3..A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; PENSAUVE >;=========/; Sauve un fichier de pinceaux.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WPENSAUVE:	PUSHM.L	D1,D2,D4,A3..A520$:	LOAD.W	D1,#DBOX_EXTRAIT	LOAD.W	D2,#2^BDBEXTEND!2^BDBSAV	LOAD.L	D3,#LBUNAME!2^BDBIOEXT1	LOAD.L	A3,#R16"TIOPEN	LOAD.L	A4,#R16"TEXPEN	LOAD.L	A5,#(A6)+ONAPEN	DBOX_	EXTEND		; demande le nom ...	JUMP,NE 90$	COMP.W	D3,#F1	JUMP,NE 90$30$:	LOAD.L	A3,#(A6)+ONAPEN	CALL	PENFSAUVE	; crit un fichier .PPAGE	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP',NE 50$		; non => 50$				; oui =>	LOAD.W	D1,#DBOX_DETRUIT	LOAD.W	D2,#2^BDBEXTEND!2^BDBSAV	LOAD.L	D3,#LBUNAME	LOAD.L	A3,#R16"TIOPEN	LOAD.L	A5,#(A6)+ONAPEN	DBOX_	EXTEND		; dtruit le nom ...	JUMP,NE 90$	COMP.W	D3,#F1	JUMP,NE 90$	LOAD.L	A3,#(A6)+ONAPEN	FOS	?DELETE	JUMP,EQ 30$50$:	LOAD.W	D3,#F1	TEST.W	D7	JUMP',EQ 90$	PUSH.W	D7	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	JUMP	20$90$:	POPM.L	D1,D2,D4,A3..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; PENFPREND >;==========/; Prend un fichier ".PPAGE".; in	A3.L	^nom du fichier; out	D7.W	erreur; mod	D7.WPENFPREND:	PUSHM.L	D3,D4,D6,A4	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP',NE 90$	LOAD.L	A4,#(A6)+OTAPEN	LOAD.L	D4,#LDPEN*NBRX*NBRY	FOS	?RDBYTE		; lit tous les pinceaux	PUSH.W	D7	FOS	?CLOSE	POP.W	D790$:	POPM.L	D3,D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; PENFSAUVE >;==========/; Ecrit un fichier ".PPAGE".; in	A3.L	^nom du fichier; out	D7.W	erreur; mod	D7.WPENFSAUVE:	PUSHM.L	D3,D4,D6,A4	LOAD.L	D3,#DEFATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE	JUMP',NE 90$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP',NE 90$	LOAD.L	A4,#(A6)+OTAPEN	LOAD.L	D4,#LDPEN*NBRX*NBRY	FOS	?WRBYTE		; crit tous les pinceaux	JUMP',NE 80$	FOS	?CLOSE	JUMP'	90$80$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D790$:	POPM.L	D3,D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; TRAPREND >;=========/; Prend un fichier de trames.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WTRAPREND:	PUSHM.L	D1,D2,D4,A3..A520$:	LOAD.W	D1,#DBOX_PREND	LOAD.W	D2,#2^BDBEXTEND!2^BDBSAV	LOAD.L	D3,#LBUNAME!2^BDBIOEXT1	LOAD.L	A3,#R16"TIOTRA	LOAD.L	A4,#R16"TEXTRA	LOAD.L	A5,#(A6)+ONATRA	DBOX_	EXTEND		; demande le nom ...	JUMP',NE 90$	COMP.W	D3,#F1	JUMP',NE 90$	LOAD.L	A3,#(A6)+ONATRA	CALL	TRAFPREND	; lit un fichier .TPAGE	JUMP',EQ 90$	PUSH.W	D7	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	JUMP	20$90$:	POPM.L	D1,D2,D4,A3..A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; TRASAUVE >;=========/; Sauve un fichier de trames.; in	-; out	D3.W	dernire touche;	D7.W	erreur; mod	D3.L, D7.WTRASAUVE:	PUSHM.L	D1,D2,D4,A3..A520$:	LOAD.W	D1,#DBOX_EXTRAIT	LOAD.W	D2,#2^BDBEXTEND!2^BDBSAV	LOAD.L	D3,#LBUNAME!2^BDBIOEXT1	LOAD.L	A3,#R16"TIOTRA	LOAD.L	A4,#R16"TEXTRA	LOAD.L	A5,#(A6)+ONATRA	DBOX_	EXTEND		; demande le nom ...	JUMP,NE 90$	COMP.W	D3,#F1	JUMP,NE 90$30$:	LOAD.L	A3,#(A6)+ONATRA	CALL	TRAFSAUVE	; crit un fichier .TPAGE	COMP.W	D7,#ERFAEX	; fichier existe dj ?	JUMP',NE 50$		; non => 50$				; oui =>	LOAD.W	D1,#DBOX_DETRUIT	LOAD.W	D2,#2^BDBEXTEND!2^BDBSAV	LOAD.L	D3,#LBUNAME	LOAD.L	A3,#R16"TIOTRA	LOAD.L	A5,#(A6)+ONATRA	DBOX_	EXTEND		; dtruit le nom ...	JUMP,NE 90$	COMP.W	D3,#F1	JUMP,NE 90$	LOAD.L	A3,#(A6)+ONATRA	FOS	?DELETE	JUMP,EQ 30$50$:	LOAD.W	D3,#F1	TEST.W	D7	JUMP',EQ 90$	PUSH.W	D7	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	JUMP	20$90$:	POPM.L	D1,D2,D4,A3..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; TRAFPREND >;==========/; Prend un fichier ".TPAGE".; in	A3.L	^nom du fichier; out	D7.W	erreur; mod	D7.WTRAFPREND:	PUSHM.L	D3,D4,D6,A4	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP',NE 90$	LOAD.L	A4,#(A6)+OTATRA	LOAD.L	D4,#LDTRA*NBRX*NBRY	FOS	?RDBYTE		; lit toutes les trames	PUSH.W	D7	FOS	?CLOSE	POP.W	D790$:	POPM.L	D3,D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; TRAFSAUVE >;==========/; Ecrit un fichier ".TPAGE".; in	A3.L	^nom du fichier; out	D7.W	erreur; mod	D7.WTRAFSAUVE:	PUSHM.L	D3,D4,D6,A4	LOAD.L	D3,#DEFATT	LOAD.W	D4,#TYPRAND	FOS	?CREATE	JUMP',NE 90$	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	FOS	?OPEN	JUMP',NE 90$	LOAD.L	A4,#(A6)+OTATRA	LOAD.L	D4,#LDTRA*NBRX*NBRY	FOS	?WRBYTE		; crit toutes les trames	JUMP',NE 80$	FOS	?CLOSE	JUMP'	90$80$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D790$:	POPM.L	D3,D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; IORPAGE >;========/; Prend un fichier ".PAGE" complet.; in	A3.L	^nom du fichier; out	D7.W	erreur; mod	D7.WIORPAGE:	PUSHM.L	D1..D4,A3,A4	CALL	RDOPEN		; ouvre le fichier en entre	JUMP,NE 90$	CALL	RDHEADPA	; lit l'en-tte	JUMP,NE 80$20$:	CALL	RDONE		; D3 <-- lg <high>	JUMP,NE 80$	LOAD.B	D4,D3	SL.W	D4,#8	CALL	RDONE		; D3 <-- lg <low>	JUMP,NE 80$	LOAD.B	D4,D3		; D4 <-- lg	CALL	RDONE		; D3 <-- objet <high>	JUMP,NE 80$	LOAD.B	D2,D3	SL.W	D2,#8	CALL	RDONE		; D3 <-- objet <low>	JUMP,NE 80$	LOAD.B	D2,D3		; D2 <-- objet	LOAD.W	D3,D2		; D3 <-- objet	ADD.W	D4,#OLLG	; D4 <-- lg	CLR.W	D2		; D2 <-- mode	CALL	INSERT		; A4 <-- ^nouvel objet	JUMP,NE 80$	COMP.W	D3,#ICOTX	JUMP',NE 25$	PUSH.L	A4	LOAD.L	A4,(A4)+OOTXFBT	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; annule le TXINIT !	POP.L	A425$:	LOAD.L	A3,#(A4)+OOOBJ+2	SUB.W	D4,#OOOBJ+230$:	CALL	RDONE		; D3 <-- lit un caractre	JUMP',NE 80$	LOAD.B	(A3+),D3	DEC.W	D4	JUMP,NE 30$	LOAD.W	(A4)+OOFSCA,#-1	; faudra reconstruire les matrices de fond	CLR.L	(A4)+OOFPM	; matrice de fond n'existe pas	CLR.L	(A4)+OOFPT	; matrice de trame n'existe pas	COMP.W	(A4)+OOOBJ,#ICOIM	JUMP',NE 35$	CLR.L	(A4)+OOIMPMZ	; matrice zoome n'existe pas35$:	COMP.W	(A4)+OOOBJ,#ICOTX	JUMP',NE 36$	CLR.L	(A4)+OOTXFBT	CLR.L	(A4)+OOTXPTL	EX.L	A5,A4	CALL	TXINIT		; initialise un objet texte vide	EX.L	A4,A5	CALL	RDTEXTPA	; lit le contenu du pav de texte	JUMP',NE 80$36$:	JUMP	20$80$:	CALL	RDCLOSE		; ferme le fichier en entre	COMP.W	D7,#EROUTF	; fin du fichier ?	JUMP',NE 90$		; non => 90$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; RDHEADPA >;---------/; Lit l'en-tte d'un fichier ".PAGE".; in	-; out	D7.W	erreur; mod	D7.WRDHEADPA:	PUSHM.L	D2..D6,A2..A5	LOAD.L	A4,#(A6)+OBUHEAD	LOAD.L	D4,#LHEAD	LOAD.W	D6,(A6)+OIOCH	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 90$	LOAD.L	A4,#(A6)+OTAPEN	LOAD.L	D4,#LDPEN*NBRX*NBRY	FOS	?RDBYTE		; lit tous les pinceaux	JUMP,NE 90$	LOAD.L	A4,#(A6)+OTATRA	LOAD.L	D4,#LDTRA*NBRX*NBRY	FOS	?RDBYTE		; lit toutes les trames	JUMP,NE 90$	LOAD.L	A4,#(A6)+OBUHEAD	LOAD.L	(A6)+OPPOS,(A4)+OHPPOS	LOAD.L	(A6)+OPDIM,(A4)+OHPDIM	LOAD.B	(A6)+OOUTIL,(A4)+OHOUTIL	LOAD.B	(A6)+OOBJET,(A4)+OHOBJET	LOAD.B	(A6)+OSELECT,(A4)+OHSELECT	LOAD.W	(A6)+OSLPEN,(A4)+OHSLPEN	LOAD.W	(A6)+OSLTRA,(A4)+OHSLTRA	LOAD.L	(A6)+ODEF,(A4)+OHDEF	LOAD.W	(A6)+OPAS,(A4)+OHPAS	LOAD.W	(A6)+OSCALE,(A4)+OHSCALE	LOAD.L	(A6)+OFLAGS,(A4)+OHFLAGS	LOAD.L	(A6)+OVUE,(A4)+OHVUE	LOAD.L	(A6)+OMFOND,(A4)+OHMFOND	LOAD.L	(A6)+ODRTYP,(A4)+OHDRTYP	LOAD.L	(A6)+OFLTYP,(A4)+OHFLTYP	LOAD.L	(A6)+ORDTYP,(A4)+OHRDTYP	LOAD.W	(A6)+ORDRAY,(A4)+OHRDRAY	LOAD.L	(A6)+ORATYP,(A4)+OHRATYP	LOAD.W	(A6)+ORARAY,(A4)+OHRARAY	LOAD.L	(A6)+OPOTYP,(A4)+OHPOTYP	LOAD.L	(A6)+OCETYP,(A4)+OHCETYP	LOAD.L	(A6)+OELTYP,(A4)+OHELTYP	LOAD.L	(A6)+OARTYP,(A4)+OHARTYP	LOAD.W	(A6)+OARANG,(A4)+OHARANG	LOAD.L	(A6)+OTXJUS,(A4)+OHTXJUS	LOAD.L	(A6)+OTXITL,(A4)+OHTXITL	LOAD.L	(A6)+OTXITC,(A4)+OHTXITC	LOAD.L	(A6)+OAJFAN,(A4)+OHAJFAN	LOAD.L	D4,(A6)+OPPOS	CALL	DETINITSC	; initialise selon l'chelle	LOAD.L	A4,#(A6)+OBUGC	LOAD.W	D2,#MAXGC40$:	TEST.B	(A4)+OGCFLG:#BGCUSE	JUMP',BC 44$	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A3,#(A6)+OBUGC	DGENC_	KILL44$:	LOAD.L	A4,#(A4)+LGGC	; A4 <-- suivant dans OBUGC	DEC.W	D2	JUMP,NE 40$	LOAD.L	A5,#(A6)+OBUHEAD+OHBUGC	LOAD.L	A4,#(A6)+OBUGC	LOAD.B	D3,#2^BGCPROT50$:	TEST.B	(A5)		; fin de la table ?	JUMP,EQ 80$		; oui => 80$				; non =>	LOAD.L	A3,#(A4)+OGCTIT52$:	LOAD.B	(A3+),(A5+)	; OBUGC <-- titre	JUMP,NE 52$	LOAD.B	(A4)+OGCFLG,D3	LOAD.B	(A4)+OGCF,(A5+)	; OBUGC <-- fonte	LOAD.B	(A4)+OGCS,(A5+)	; OBUGC <-- style	LOAD.B	(A4)+OGCT,(A5+)	; OBUGC <-- taille	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A3,#(A6)+OBUGC	DGENC_	NEW	LOAD.L	A4,#(A4)+LGGC	; A4 <-- suivant dans OBUGC	CLR.B	D3		; D3 <-- protection seulement pour 1er	JUMP	50$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D6,A2..A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; RDTEXTPA >;---------/; Lit le contenu d'un pav de texte.; in	A4.L	^objet texte; out	D7.W	erreur; mod	D7.WRDTEXTPA:	PUSHM.L	D3,D4,A5	LOAD.L	A5,A4		; A5 <-- ^objet texte20$:	CALL	RDONE	JUMP',NE 90$	LOAD.B	D4,D3	SL.L	D4,#8	CALL	RDONE	JUMP',NE 90$	LOAD.B	D4,D3	SL.L	D4,#8	CALL	RDONE	JUMP',NE 90$	LOAD.B	D4,D3	SL.L	D4,#8	CALL	RDONE	JUMP',NE 90$	LOAD.B	D4,D3	LOAD.L	D3,D4	JUMP',EQ 90$	CALL	TXINSERE	; met dans le buffer de texte	JUMP,EQ 20$90$:	POPM.L	D3,D4,A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; IOWPAGE >;========/; Sauve un fichier ".PAGE" sur disque.; in	A3.L	^nom du fichier; out	D7.W	erreur; mod	D7.WIOWPAGE:	PUSHM.L	D3,D4,A2..A4	CALL	WROPEN		; ouvre le fichier en sortie	JUMP,NE 90$	CALL	WRHEADPA	; crit l'en-tte	JUMP',NE 80$	LOAD.L	A2,#(A6)+OUSE	LOAD.L	A3,(A2)+OLNEXT20$:	COMP.L	A3,A2		; fin de la liste ?	JUMP',EQ 80$		; oui => 80$	SUB.W	(A3)+OLLG,#OLLG	LOAD.W	D4,(A3)+OLLG	LOAD.L	A4,#(A3)+OLLG	CALL	WRMANY		; crit un objet sur disque	ADD.W	(A3)+OLLG,#OLLG	TEST.W	D7	JUMP',NE 80$	LOAD.L	A4,A3	COMP.W	(A4)+OOOBJ,#ICOTX	JUMP',NE 50$	CALL	WRTEXTPA	; crit le contenu du pav de texte	JUMP',NE 80$50$:	LOAD.L	A3,(A3)+OLNEXT	; A3 <-- ^suivant	JUMP	20$80$:	CALL	WRCLOSE		; ferme le fichier en sortie90$:	POPM.L	D3,D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; WRHEADPA >;---------/; Ecrit l'en-tte d'un fichier ".PAGE".; in	-; out	D7.W	erreur; mod	D7.WWRHEADPA:	PUSHM.L	D3,D4,D6,A2..A4	LOAD.L	A4,#(A6)+OBUHEAD	LOAD.W	D4,#(LHEAD/2)-110$:	CLR.W	(A4+)		; OBUHEAD <-- rempli de zro	DECJ.W,NMO D4,10$	LOAD.L	A4,#(A6)+OBUHEAD	LOAD.B	(A4)+OHMAJREV,#PAGEREV	LOAD.B	(A4)+OHMINREV,#PAGEVERS	LOAD.L	D4,(A6)+OPPOS	LOAD.L	D3,(A6)+OSDIM	SR.W	D3,#1	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SR.W	D3,#1	ADD.W	D4,D3;	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A4)+OHPPOS,D4	LOAD.L	(A4)+OHPDIM,(A6)+OPDIM	LOAD.B	(A4)+OHOUTIL,(A6)+OOUTIL	LOAD.B	(A4)+OHOBJET,(A6)+OOBJET	LOAD.B	(A4)+OHSELECT,(A6)+OSELECT	LOAD.W	(A4)+OHSLPEN,(A6)+OSLPEN	LOAD.W	(A4)+OHSLTRA,(A6)+OSLTRA	LOAD.L	(A4)+OHDEF,(A6)+ODEF	LOAD.W	(A4)+OHPAS,(A6)+OPAS	LOAD.W	(A4)+OHSCALE,(A6)+OSCALE	LOAD.L	(A4)+OHFLAGS,(A6)+OFLAGS	LOAD.L	(A4)+OHVUE,(A6)+OVUE	LOAD.L	(A4)+OHMFOND,(A6)+OMFOND	LOAD.L	(A4)+OHDRTYP,(A6)+ODRTYP	LOAD.L	(A4)+OHFLTYP,(A6)+OFLTYP	LOAD.L	(A4)+OHRDTYP,(A6)+ORDTYP	LOAD.W	(A4)+OHRDRAY,(A6)+ORDRAY	LOAD.L	(A4)+OHRATYP,(A6)+ORATYP	LOAD.W	(A4)+OHRARAY,(A6)+ORARAY	LOAD.L	(A4)+OHPOTYP,(A6)+OPOTYP	LOAD.L	(A4)+OHCETYP,(A6)+OCETYP	LOAD.L	(A4)+OHELTYP,(A6)+OELTYP	LOAD.L	(A4)+OHARTYP,(A6)+OARTYP	LOAD.W	(A4)+OHARANG,(A6)+OARANG	LOAD.L	(A4)+OHTXJUS,(A6)+OTXJUS	LOAD.L	(A4)+OHTXITL,(A6)+OTXITL	LOAD.L	(A4)+OHTXITC,(A6)+OTXITC	LOAD.L	(A4)+OHAJFAN,(A6)+OAJFAN	LOAD.L	A4,#(A4)+OHBUGC	LOAD.L	A3,#(A6)+OBUGC	LOAD.W	D4,#MAXGC30$:	TEST.B	(A3)+OGCFLG:#BGCUSE	JUMP',BC 40$	LOAD.L	A2,#(A3)+OGCTIT32$:	LOAD.B	(A4+),(A2+)	; OHBUGC <-- titre	JUMP,NE 32$	LOAD.B	(A4+),(A3)+OGCCOD+1 ; OHBUGC <-- fonte	LOAD.B	(A4+),(A3)+OGCCOD+2 ; OHBUGC <-- style	LOAD.B	(A4+),(A3)+OGCCOD+3 ; OHBUGC <-- taille40$:	LOAD.L	A3,#(A3)+LGGC	; A3 <-- ^suivant dans OBUGC	DEC.W	D4	JUMP,NE 30$	LOAD.L	A4,#(A6)+OBUHEAD	LOAD.L	D4,#LHEAD	LOAD.W	D6,(A6)+OIOCH	FOS	?WRBYTE		; disque <-- entte	JUMP',NE 90$	LOAD.L	A4,#(A6)+OTAPEN	LOAD.L	D4,#LDPEN*NBRX*NBRY	FOS	?WRBYTE		; crit tous les pinceaux	JUMP',NE 90$	LOAD.L	A4,#(A6)+OTATRA	LOAD.L	D4,#LDTRA*NBRX*NBRY	FOS	?WRBYTE		; crit toutes les trames;	JUMP',NE 90$90$:	POPM.L	D3,D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; WRTEXTPA >;---------/; Ecrit le contenu d'un pav de texte.; in	A4.L	^objet texte; out	D7.W	erreur; mod	D7.WWRTEXTPA:	PUSHM.L	D3..D5,A4,A5	LOAD.L	A5,A4		; A5 <-- ^objet texte	CALL	TXPSAUVE	; D4 <-- no de la position	LOAD.W	D5,D4		; D5 <-- no position initiale	CLR.L	D4	CALL	TXQPOSITIONNE	; va au dbut du texte	LOAD.L	A4,#(A6)+OBUDIS20$:	CALL	TXAVANCE	; D3 <-- caractre suivant	JUMP',NE 50$	TEST.L	D3	JUMP,EQ 20$	LOAD.L	(A4),D3	LOAD.W	D4,#4	CALL	WRMANY		; crit un caractre (4 bytes)	JUMP',NE 80$	JUMP	20$50$:	CLR.L	(A4)	LOAD.W	D4,#4	CALL	WRMANY		; crit un terminateur (4 bytes)80$:	PUSH.W	D7	LOAD.W	D4,D5		; D4 <-- no position initiale	CALL	TXPPREND	; remet le curseur o il tait	POP.W	D7	POPM.L	D3..D5,A4,A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; IORTEXT >;========/; Prend ou ajoute un fichier complet dans une zone.; in	A4.L	^objet texte;	A3.L	^nom du fichier; out	D7.W	erreur; mod	D7.WIORTEXT:	PUSHM.L	D0..D6,A3..A5	LOAD.L	A5,A4		; A5 <-- ^objet texte	COMP.W	(A5)+OOOBJ,#ICOTX	JUMP,NE 90$	CALL	RDOPEN		; ouvre le fichier en entre	JUMP,NE 90$	CALL	TXINFO		; D4 <-- position, D5 <-- nb car	LOAD.L	D5,D4	CLR.L	D6		; D6 <-- nb de commandes boa bouffes20$:	CALL	RDONE		; D3 <-- lit un caractre	JUMP,NE 80$	COMP.B	D3,#BOA		; commande boa ?	JUMP',EQ 30$		; oui => 30$22$:	LOAD.B	D4,D3	LOAD.L	D3,(A6)+OIOLC	LOAD.B	D3,D4	CALL	TXINSERE	; buffer <-- un caractre	JUMP,NE 80$	JUMP	20$30$:	TEST.B	(A6)+OFANIO+0:#BDBLBOA-24 ; option "laisse les commandes boa" ?	JUMP,BS 22$		; oui => 22$	LOAD.L	A3,#(A6)+OBUBOA	; A3 <-- ^buffer pour commande "boa"	LOAD.W	D1,#LBUBOA-5	; D1 <-- lg max commande	LOAD.B	(A3+),D3	; buffer <-- <BOA>	CALL	RDONE		; D3 <-- premier caractre	JUMP,NE 80$	LOAD.B	(A3+),D3	; buffer <-- premier caractre	CLR.B	(A3)		; buffer <-- terminateur	CLR.W	D0		; D0 <-- nb de \; imbriqus	COMP.B	D3,#'0	JUMP',LO 42$	COMP.B	D3,#'9	JUMP',LS 35$	COMP.B	D3,#'A	JUMP',LO 42$	COMP.B	D3,#'Z	JUMP',LS 35$	COMP.B	D3,#'a	JUMP',LO 42$	COMP.B	D3,#'z	JUMP',HI 42$35$:	CALL	RDONE		; D3 <-- caractre	JUMP,NE 80$	LOAD.B	(A3+),D3	; buffer <-- caractre	CLR.B	(A3)		; buffer <-- terminateur	DEC.W	D1		; commande trop longue ?	JUMP',EQ 45$		; oui => 45$	COMP.B	D3,#CR		; fin de la commande ?	JUMP',EQ 40$		; oui => 40$	COMP.B	D3,#';	JUMP',EQ 38$	COMP.B	D3,#BOA		; dbut d'une commande \; imbrique ?	JUMP,NE 35$		; non => 35$	INC.W	D0		; D0 <-- un niveau de plus	JUMP	35$38$:	DEC.W	D0		; D0 <-- un niveau de moins	JUMP,NC 35$40$:	INC.L	D6		; D6 <-- une commande boa bouffe de plus	TEST.B	(A6)+OFANIO+0:#BDBFBOA-24 ; option "filtre les commandes boa" ?	JUMP,BS 20$		; oui => 20$	DEC.L	D6		; D6 <-- mais non42$:	LOAD.L	A3,#(A6)+OBUBOA	CALL	RDBOA		; cherche commande "boa"	JUMP,EQ	20$		; ok => 20$45$:				; commande <boa> inconnue =>	LOAD.L	A3,#(A6)+OBUBOA46$:	LOAD.L	D3,(A6)+OIOLC	LOAD.B	D3,(A3+)	JUMP,EQ	20$	CALL	TXINSERE	; buffer <-- commande boa inconnue	JUMP,NE 80$	JUMP	46$80$:	PUSH.W	D7	LOAD.L	D4,D5	CALL	TXPOSITIONNE	; revient au dbut du fichier lu	POP.W	D7	CALL	RDCLOSE		; ferme le fichier en entre	COMP.W	D7,#EROUTF	; fin du fichier ?	JUMP',NE 90$		; non => 90$	LOAD.W	D7,#ERPBBOA	TEST.L	D6		; commandes boa bouffes ?	JUMP',NE 90$		; oui => 90$	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D6,A3..A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDBOA   >;--------/; Cherche la routine  excuter en fonction d'une commande boa.; in	A3.L	^commande; out	D7.W	erreur; mod	D7.WRDBOA:	PUSHM.L	D0..D5,A0..A4	LOAD.W	D7,#1		; D7 <-- commande inconnue	LOAD.L	A4,#R16"TABOA$10$:	TEST.B	(A4)		; fin de la table ?	JUMP',EQ 90$		; oui => 90$	LOAD.L	A2,A3		; A2 <-- ^commande cherche20$:	TEST.B	(A4)	JUMP',EQ 50$	COMP.B	(A4+),(A2+)	JUMP,EQ 20$30$:	TEST.B	(A4+)		; A4 <-- saute fin du .ASCIZ	JUMP,NE	30$	EX.L	D4,A4	INC.L	D4	TCLR.L	D4:#0		; A4 <-- saute .EVEN	EX.L	A4,D4	ADD.L	A4,#2		; A4 <-- saute .W	JUMP	10$50$:	LOAD.L	A3,A2		; A3 <-- ^paramtres ventuels	INC.L	A4		; A4 <-- saute le <0>	EX.L	D4,A4	INC.L	D4	TCLR.L	D4:#0		; A4 <-- saute .EVEN	EX.L	A4,D4	LOAD.W	D2,(A4)		; D2 <-- adresse relative	LOAD.L	A2,#R16"TABOA$	; A2 <-- adresse absolue dbut du code	ADD.W	A2,D2		; A2 <-- adresse absolue	CLR.W	D7		; D7 <-- ok	CALL	(A2)		; appel routine ...90$:	POPM.L	D0..D5,A0..A4	TEST.W	D7		; retour EQ/NE	RETTABOA$:	.ASCIZ	"<BOA>g_"	.EVEN	.W	RDBOAGC-TABOA$	.ASCIZ	"<BOA>_"	.EVEN	.W	RDBOASOUL-TABOA$	.ASCIZ	"<BOA>biff;"	.EVEN	.W	RDBOABIFF-TABOA$	.ASCIZ	"<BOA>surl;"	.EVEN	.W	RDBOASURL-TABOA$	.ASCIZ	"<BOA>up;"	.EVEN	.W	RDBOAUP-TABOA$	.ASCIZ	"<BOA>down;"	.EVEN	.W	RDBOADOWN-TABOA$	.ASCIZ	"<BOA>color "	.EVEN	.W	RDBOACOLOR-TABOA$	.ASCIZ	"<BOA>define g_"	.EVEN	.W	RDBOADEF-TABOA$	.B	0	.EVEN;---------\\; RDBOADEF >;---------/; Dfinition d'un nouveau gencar.; in	A3.L	^paramtres; out	D7.W	erreur; mod	D0..D4, D7.W, A0..A4RDBOADEF:	LOAD.L	A4,#(A6)+OBUGC	; A4 <-- ^buffer des gencars	DGENC_	SEARCH		; cherche si titre existe dj ?	JUMP,EQ 20$	LOAD.L	A4,#(A6)+OBUGC	; A4 <-- ^buffer des gencars	DGENC_	FREE		; cherche gencar libre	JUMP,NE 90$20$:	LOAD.W	D7,#1	LOAD.L	A1,A3		; A1 <-- ^titre25$:	LOAD.B	D3,(A3+)	; A3 <-- saute le titre	COMP.B	D3,#':	JUMP',EQ 30$	COMP.B	D3,#';	JUMP,EQ 90$	COMP.B	D3,#CR	JUMP,EQ 90$	COMP.B	D3,#',	JUMP,EQ 90$	JUMP	25$30$:	COMP.B	(A3+),#BOA	JUMP',NE 90$	LOAD.L	A2,A3		; A2 <-- ^fsctt	DGENC_	GET		; D5 <-- "-fst"	JUMP',NE 90$		; syntaxe pas correcte => 90$	LOAD.W	D7,#1	COMP.B	(A3+),#';	JUMP',NE 90$	COMP.B	(A3+),#CR	JUMP',NE 90$	LOAD.L	(A4)+OGCCOD,D5	; OBUGC <-- "fst" compactifi	LOAD.L	A3,#(A4)+OGCTIT50$:	LOAD.B	(A3+),(A1+)	; OBUGC <-- titre	COMP.B	(A1)-1,#':	JUMP,NE	50$	CLR.B	(A3)-1	LOAD.L	A3,#(A4)+OGCNAM60$:	LOAD.B	(A3+),(A2+)	; OBUGC <-- fsctt	COMP.B	(A2)-1,#';	JUMP,NE	60$	CLR.B	(A3)-1	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	D4,#H'10000*GCTXF+H'100*GCTXS+GCTXT	LOAD.L	A3,#(A6)+OBUGC	DGENC_	NEW		; charge nouveau gencar90$:	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDBOAGC >;--------/; Changement de gencar.; in	A3.L	^paramtres; out	D7.W	erreur; mod	D0..D4, D7.W, A0..A4RDBOAGC:	LOAD.L	A4,#(A6)+OBUGC	; A4 <-- ^buffer des gencars	DGENC_	SEARCH		; cherche	JUMP,NE 90$	SL.L	D4,#CCGCSHI	AND.L	D4,#CCGCMSK	AND.L	(A6)+OIOLC,#-1-CCGCMSK	OR.L	(A6)+OIOLC,D490$:	TEST.W	D7		; retour EQ/NE	RET;----------\\; RDBOASOUL >;----------/; Dbut/fin de soulignement.; in	-; out	D7.W	erreur; mod	D0..D4, D7.W, A0..A4RDBOASOUL:	LOAD.B	D3,#1		; D3 <-- mode soulign	JUMP'	RDBOASBS;----------\\; RDBOABIFF >;----------/; Dbut/fin de biff.; in	-; out	D7.W	erreur; mod	D0..D4, D7.W, A0..A4RDBOABIFF:	LOAD.B	D3,#2		; D3 <-- mode biff	JUMP'	RDBOASBS;----------\\; RDBOASURL >;----------/; Dbut/fin de surlignement.; in	-; out	D7.W	erreur; mod	D0..D4, D7.W, A0..A4RDBOASURL:	LOAD.B	D3,#3		; D3 <-- mode surlign;	JUMP'	RDBOASBSRDBOASBS:	TEST.B	(A6)+OFANIO+0:#BDBFBOA-24 ; option "filtre les commandes boa" ?	JUMP',BS 90$		; oui => 90$	LOAD.L	D4,(A6)+OIOLC	AND.L	D4,#CCSOMSK;	SR.L	D4,#CCSOSHI	SR.L	D4,#8	SR.L	D4,#CCSOSHI-8	TEST.B	D4	JUMP',EQ 50$	CLR.B	D3		; D3 <-- mode normal50$:;	SL.L	D3,#CCSOSHI	SL.L	D3,#8	SL.L	D3,#CCSOSHI-8	AND.L	D3,#CCSOMSK	AND.L	(A6)+OIOLC,#-1-CCSOMSK	OR.L	(A6)+OIOLC,D390$:	RET;--------\\; RDBOAUP >;--------/; Dbut d'exposant ou fin d'indice.; in	-; out	D7.W	erreur; mod	D0..D4, D7.W, A0..A4RDBOAUP:	LOAD.B	D3,#1		; D3 <-- mode exposant	JUMP'	RDBOAUD;----------\\; RDBOADOWN >;----------/; Dbut d'indice ou fin d'exposant.; in	-; out	D7.W	erreur; mod	D0..D4, D7.W, A0..A4RDBOADOWN:	LOAD.B	D3,#2		; D3 <-- mode indice;	JUMP'	RDBOAUDRDBOAUD:	LOAD.L	D4,(A6)+OIOLC	AND.L	D4,#CCEXMSK;	SR.L	D4,#CCEXSHI	SWAP.W	D4	TEST.B	D4	JUMP',EQ 50$	CLR.B	D3		; D3 <-- mode normal50$:;	SL.L	D3,#CCEXSHI	SWAP.W	D3	AND.L	D3,#CCEXMSK	AND.L	(A6)+OIOLC,#-1-CCEXMSK	OR.L	(A6)+OIOLC,D3	RET;-----------\\; RDBOACOLOR >;-----------/; Changement de couleur.; in	A3.L	^paramtres; out	D7.W	erreur; mod	D0..D4, D7.W, A0..A4RDBOACOLOR:	LOAD.W	D7,#1	LOAD.B	D3,(A3)	SUB.B	D3,#'1	JUMP',LO 90$	COMP.B	D3,#8	JUMP',HS 90$;	SL.L	D3,#CCCOSHI	SWAP.W	D3	SL.L	D3,#CCCOSHI-16	AND.L	D3,#CCCOMSK	AND.L	(A6)+OIOLC,#-1-CCCOMSK	OR.L	(A6)+OIOLC,D3	CLR.W	D7		; D7 <-- ok90$:	TEST.W	D7		; retour EQ/NE	RET;--------\\; IOWTEXT >;========/; Sauve toute une zone dans un fichier sur disque.; in	A4.L	^objet texte;	A3.L	^nom du fichier; out	D7.W	erreur; mod	D7.WIOWTEXT:	PUSHM.L	D3..D5,A3..A5	LOAD.L	A5,A4		; A5 <-- ^objet texte	COMP.W	(A5)+OOOBJ,#ICOTX	JUMP',NE 90$	CALL	WROPEN		; ouvre le fichier en sortie	JUMP',NE 90$	CALL	WRHEADTX	; crit l'en-tte	JUMP',NE 80$	CALL	TXPSAUVE	; D4 <-- position actuelle	LOAD.W	D5,D4	CLR.L	D4	CALL	TXQPOSITIONNE	; va au tout dbut20$:	CALL	TXAVANCE	; D3 <-- un caractre	JUMP',NE 70$	CALL	WRCARTX		; crit un caractre	JUMP',NE 80$	JUMP	20$70$:	CLR.W	D7		; D7 <-- ok80$:	PUSH.W	D7	LOAD.W	D4,D5	CALL	TXPPREND	; retourne o l'on tait	POP.W	D7	CALL	WRCLOSE		; ferme le fichier en sortie90$:	POPM.L	D3..D5,A3..A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; IOWTEXTZ >;=========/; Sauve une partie de zone dans un fichier sur disque.; in	A5.L	^objet texte;	A3.L	^nom du fichier;	D4.L	position de dbut;	D5.L	nombre de caractres; out	D7.W	erreur; mod	D7.WIOWTEXTZ:	PUSHM.L	D2..D5,A3	LOAD.L	D2,D5		; D2 <-- nb de caractres	CALL	WROPEN		; ouvre le fichier en sortie	JUMP',NE 90$	CALL	WRHEADTX	; crit l'en-tte	JUMP',NE 80$	PUSH.L	D4	CALL	TXPSAUVE	; D4 <-- position actuelle	LOAD.W	D5,D4	POP.L	D4	CALL	TXQPOSITIONNE	; va au dbut de la zone20$:	CALL	TXAVANCE	; D3 <-- un caractre	JUMP',NE 70$	CALL	WRCARTX		; crit un caractre	JUMP',NE 80$	DEC.L	D2	JUMP,NE	20$70$:	CLR.W	D7		; D7 <-- ok80$:	PUSH.W	D7	LOAD.W	D4,D5	CALL	TXPPREND	; retourne o l'on tait	POP.W	D7	CALL	WRCLOSE		; ferme le fichier en sortie90$:	POPM.L	D2..D5,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; WRHEADTX >;---------/; Ecrit l'en-tte.; in	-; out	D7.W	erreur; mod	D7.WWRHEADTX:	PUSHM.L	D3,D4,A3,A4	CLR.W	D7		; D7 <-- ok	TEST.B	(A6)+OFANIO+0:#BDBLBOA-24 ; option "laisse les commandes boa" ?	JUMP,BS 90$		; oui => 90$	TEST.B	(A6)+OFANIO+0:#BDBFBOA-24 ; option "filtre les commandes boa" ?	JUMP,BS 90$		; oui => 90$	LOAD.L	A4,#(A6)+OBUGC	LOAD.W	D4,#MAXGC-120$:	TEST.B	(A4)+OGCFLG:#BGCUSE	JUMP',BC 80$	LOAD.L	A3,#R16"DEF1$	CALL	WRTEXT		; crit "<BOA>define g_"	JUMP',NE 90$	LOAD.L	A3,#(A4)+OGCTIT	CALL	WRTEXT		; crit le titre	JUMP',NE 90$	LOAD.L	A3,#R16"DEF2$	CALL	WRTEXT		; crit ":<BOA>"	JUMP',NE 90$	LOAD.L	A3,#(A4)+OGCNAM	CALL	WRTEXT		; crit le nom	JUMP',NE 90$	LOAD.L	A3,#R16"DEF3$	CALL	WRTEXT		; crit ";<CR>"	JUMP',NE 90$80$:	LOAD.L	A4,#(A4)+LGGC	; A4 <-- ^gencar suivant	DECJ.W,NMO D4,20$90$:	POPM.L	D3,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RETDEF1$:	.ASCIZ	"<BOA>define g_"DEF2$:	.ASCIZ	":<BOA>"DEF3$:	.ASCIZ	";<CR>"	.EVEN;--------\\; WRCARTX >;--------/; Ecrit un caractre, avec ventuellement quelques commandes boa; juste avant selon son mode.; in	D3.L	caractre; out	D7.W	erreur; mod	D7.WWRCARTX:	PUSHM.L	D1..D4,A3	LOAD.L	D2,D3		; D2 <-- nouveau caractre	LOAD.L	D1,(A6)+OIOLC	; D1 <-- ancien caractre	XOR.L	D1,D2		; D1 <-- changements	CLR.B	D1	TEST.L	D1		; y'a-t-il des changements ?	JUMP,EQ 80$		; non => 80$	TEST.B	(A6)+OFANIO+0:#BDBFBOA-24 ; option "filtre les commandes boa" ?	JUMP,BS 80$		; oui => 80$; Ecrit une commande de caractre.	LOAD.L	D3,D1	AND.L	D3,#CCGCMSK	JUMP',EQ 20$	LOAD.L	A3,#R16"GCD$	CALL	WRTEXT		; crit "<BOA>g_"	JUMP,NE 90$	LOAD.L	D3,D2		; D3 <-- nouveau caractre	AND.L	D3,#CCGCMSK	SR.L	D3,#CCGCSHI	; D3 <-- nouveau gencar	LOAD.L	A3,#(A6)+OBUGC+OGCTIT	MUL.WU	D3,#LGGC	ADD.L	A3,D3	CALL	WRTEXT		; crit le titre du gencar	JUMP,NE 90$	LOAD.L	A3,#R16"GCF$	CALL	WRTEXT		; crit ";"	JUMP,NE 90$; Ecrit une commande de soulignement.20$:	LOAD.L	D3,D1	AND.L	D3,#CCSOMSK	JUMP',EQ 30$	LOAD.L	A3,#R16"SOUL$	LOAD.L	D3,(A6)+OIOLC	AND.L	D3,#CCSOMSK;	SR.L	D3,#CCSOSHI	SR.L	D3,#8	SR.L	D3,#CCSOSHI-8	CALL	WRLBOA		; crit fin de soulignement	JUMP,NE 90$	LOAD.L	D3,D2	AND.L	D3,#CCSOMSK;	SR.L	D3,#CCSOSHI	SR.L	D3,#8	SR.L	D3,#CCSOSHI-8	CALL	WRLBOA		; crit dbut de soulignement	JUMP,NE 90$; Ecrit une commande d'indice/exposant.30$:	LOAD.L	D3,D1	AND.L	D3,#CCEXMSK	JUMP',EQ 40$	LOAD.L	A3,#R16"EXPD$	LOAD.L	D3,(A6)+OIOLC	AND.L	D3,#CCEXMSK;	SR.L	D3,#CCEXSHI	SWAP.W	D3	CALL	WRLBOA		; crit fin d'exposant	JUMP,NE 90$	LOAD.L	A3,#R16"EXPF$	LOAD.L	D3,D2	AND.L	D3,#CCEXMSK;	SR.L	D3,#CCEXSHI	SWAP.W	D3	CALL	WRLBOA		; crit dbut d'exposant	JUMP,NE 90$; Ecrit une commande de couleur.40$:	LOAD.L	D3,D1	AND.L	D3,#CCCOMSK	JUMP',EQ 80$	LOAD.L	A3,#R16"COUL$	LOAD.L	D3,D2	AND.L	D3,#CCCOMSK;	SR.L	D3,#CCCOSHI	SWAP.W	D3	SR.L	D3,#4	CALL	WRLBOA		; crit couleur	JUMP,NE 90$; Ecrit le caractre.80$:	LOAD.L	D3,D2		; D3 <-- caractre	CALL	WRONE		; crit un caractre	JUMP',NE 90$	LOAD.L	(A6)+OIOLC,D3	; OIOLC <-- dernier caractre90$:	POPM.L	D1..D4,A3	TEST.W	D7		; retour EQ/NE	RETGCD$:	.ASCIZ	"<BOA>g_"GCF$:	.ASCIZ	";"SOUL$:	.ASCIZ	""	.ASCIZ	"<BOA>_"	.ASCIZ	"<BOA>biff;"	.ASCIZ	"<BOA>surl;"EXPD$:	.ASCIZ	""	.ASCIZ	"<BOA>down;"	.ASCIZ	"<BOA>up;"EXPF$:	.ASCIZ	""	.ASCIZ	"<BOA>up;"	.ASCIZ	"<BOA>down;"COUL$:	.ASCIZ	"<BOA>color 1;"	.ASCIZ	"<BOA>color 2;"	.ASCIZ	"<BOA>color 3;"	.ASCIZ	"<BOA>color 4;"	.ASCIZ	"<BOA>color 5;"	.ASCIZ	"<BOA>color 6;"	.ASCIZ	"<BOA>color 7;"	.ASCIZ	"<BOA>color 8;"	.EVEN;--------\\; RDOPEN  >;========/; Ouvre le fichier en entre.; in	A3.L	^nom du fichier; out	D7.W	erreur; mod	D7.WRDOPEN:	PUSHM.L	D0,D3,D6	LOAD.W	D3,#2^BOPRD	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier	JUMP',NE 90$	LOAD.W	(A6)+OIOCH,D6	; mm. canal	LOAD.W	(A6)+OIOPT,#LTMIO	CLR.L	(A6)+OIOLC90$:	POPM.L	D0,D3,D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDONE   >;========/; Lit un byte dans le fichier d'entre.; in	-; out	D3.B	byte lu;	D7.W	erreur; mod	D3.L, D7.WRDONE:	PUSHM.L	D4,D6,A4	CLR.W	D7		; D7 <-- ok	LOAD.L	A4,#(A6)+OIOTM	; A4 <-- ^buffer tampon	COMP.W	(A6)+OIOPT,#LTMIO ; reste qq chose ?	JUMP',LO 50$		; oui => 50$				; non =>	LOAD.L	D4,#LTMIO	LOAD.W	D6,(A6)+OIOCH	; D6 <-- canal	FOS	?RDBYTE		; lit tout le buffer	LOAD.W	(A6)+OIONB,#-1	CLR.W	(A6)+OIOPT	; buffer vide	TEST.W	D7		; lecture ok ?	JUMP',EQ 50$		; oui => 50$	COMP.W	D7,#EROUTF	; fin du fichier ?	JUMP',NE 90$		; non => 90$	CLR.W	D7		; D7 <-- ok pour l'instant	LOAD.W	(A6)+OIONB,D4	; mm. lg dernire tranche50$:	TEST.W	(A6)+OIONB	; reste qq chose ?	JUMP',NE 60$		; oui => 60$	LOAD.W	D7,#EROUTF	; D7 <-- fin du fichier	JUMP'	90$60$:	LOAD.W	D4,(A6)+OIOPT	LOAD.B	D3,(A4)+(D4.W)	; D3 <-- un byte du buffer	INC.W	(A6)+OIOPT	; avance "pointeur"	DEC.W	(A6)+OIONB	; diminue reste90$:	POPM.L	D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; RDCLOSE >;========/; Ferme le fichier en entre.; in	D7.W	ok/erreur; out	D7.W	erreur; mod	D7.WRDCLOSE:	PUSHM.L	D5,D6	LOAD.W	D5,D7		; D5 <-- ok/erreur	LOAD.W	D6,(A6)+OIOCH	; D6 <-- canal	FOS	?CLOSE		; ferme le fichier	COMP.W	D7,D5	JUMP',HS 90$	LOAD.W	D7,D5		; D7 <-- erreur la plus grve !90$:	POPM.L	D5,D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; WROPEN  >;========/; Ouvre le fichier en sortie.; in	A3.L	^nom du fichier; out	D7.W	erreur; mod	D7.WWROPEN:	PUSHM.L	D0,D3,D6	LOAD.W	D3,#2^BOPWR!2^BOPEXCL	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre le fichier	JUMP',NE 90$	LOAD.W	(A6)+OIOCH,D6	; mm. canal	CLR.W	(A6)+OIOPT	; buffer vide	LOAD.L	(A6)+OIOLC,#CCGCMSK90$:	POPM.L	D0,D3,D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRLBOA  >;========/; Ecrit la n-ime commande boa d'une liste.; in	A3.L	^liste de commandes boa;	D3.W	rang (0..n); out	D7.W	erreur; mod	D7.WWRLBOA:	PUSHM.L	D3,A310$:	DEC.W	D3	JUMP',NS 40$20$:	TEST.B	(A3+)		; A3 <-- ^texte suivant	JUMP,NE 20$	JUMP	10$40$:	CALL	WRTEXT		; crit la commande boa	POPM.L	D3,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRTEXT  >;========/; Ecrit un texte (.ASCIZ) dans le fichier de sortie.; in	A3.L	^texte termin par <0>; out	D7.W	erreur; mod	D7.WWRTEXT:	PUSHM.L	D4,A3,A4	LOAD.L	A4,A3	LOAD.W	D4,#-110$:	INC.W	D4	TEST.B	(A3+)	JUMP,NE 10$	CALL	WRMANY		; crit tout le .ASCIZ	POPM.L	D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRMANY  >;========/; Ecrit plusieurs bytes dans le fichier de sortie.; in	A4.L	^bytes  crire;	D4.W	nombre de bytes  crire; out	D7.W	erreur; mod	D7.WWRMANY:	PUSHM.L	D3,D4,D6,A2..A4	CLR.W	D7		; D7 <-- ok	LOAD.L	A3,A4		; A3 <-- ^bytes  crire	LOAD.W	D3,D4		; D3 <-- nombre	JUMP,EQ 90$10$:	LOAD.L	A4,#(A6)+OIOTM	; A4 <-- ^dbut buffer	LOAD.W	D4,(A6)+OIOPT	; D4 <-- nb bytes dans buffer	ADD.W	A4,D4		; A4 <-- ^o insrer20$:	COMP.W	D4,#LTMIO	; buffer plein ?	JUMP',EQ 50$	LOAD.B	(A4+),(A3+)	; buffer <-- un byte	INC.W	D4		; D4 <-- un byte de plus	DEC.W	D3	JUMP,NE	20$	LOAD.W	(A6)+OIOPT,D4	; mj offset dans buffer	CLR.W	D7		; D7 <-- ok	JUMP'	90$50$:	LOAD.L	A4,#(A6)+OIOTM	; A4 <-- ^dbut buffer	LOAD.L	D4,#LTMIO	; D4 <-- longueur buffer	LOAD.W	D6,(A6)+OIOCH	; D6 <-- canal	FOS	?WRBYTE		; crit tout le buffer	JUMP',NE 90$		; erreur => 90$	CLR.W	(A6)+OIOPT	; signal buffer vide	JUMP	10$90$:	POPM.L	D3,D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRONE   >;========/; Ecrit un byte dans le fichier de sortie.; in	D3.B	byte  crire; out	D7.W	erreur; mod	D7.WWRONE:	PUSHM.L	D4,D6,A2,A410$:	LOAD.L	A4,#(A6)+OIOTM	; A4 <-- ^dbut buffer	LOAD.W	D4,(A6)+OIOPT	; D4 <-- nb bytes dans buffer	ADD.W	A4,D4		; A4 <-- ^o insrer	COMP.W	D4,#LTMIO	; buffer plein ?	JUMP',EQ 50$	LOAD.B	(A4),D3		; buffer <-- le byte	INC.W	D4		; D4 <-- un byte de plus	LOAD.W	(A6)+OIOPT,D4	; mj offset dans buffer	CLR.W	D7		; D7 <-- ok	JUMP'	90$50$:	LOAD.L	A4,#(A6)+OIOTM	; A4 <-- ^dbut buffer	LOAD.L	D4,#LTMIO	; D4 <-- longueur buffer	LOAD.W	D6,(A6)+OIOCH	; D6 <-- canal	FOS	?WRBYTE		; crit tout le buffer	JUMP',NE 90$		; erreur => 90$	CLR.W	(A6)+OIOPT	; signal buffer vide	JUMP	10$90$:	POPM.L	D4,D6,A2,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; WRCLOSE >;========/; Ecrit le reste du fichier de sortie, puis ferme.; in	D7.W	ok/erreur; out	D7.W	erreur; mod	D7.WWRCLOSE:	PUSHM.L	D4..D6,A4	LOAD.W	D6,(A6)+OIOCH	; D6 <-- canal	LOAD.W	D5,D7		; D5 <-- ok/erreur	JUMP',NE 50$		; erreur => 50$				; ok =>	LOAD.L	A4,#(A6)+OIOTM	; A4 <-- ^buffer tampon	CLR.L	D4	LOAD.W	D4,(A6)+OIOPT	; D4 <-- nb bytes dans buffer	JUMP',EQ 50$		; si vide => 50$				; si reste qq chose =>	FOS	?WRBYTE		; crit tout le buffer	LOAD.W	D5,D750$:	FOS	?CLOSE		; ferme le fichier	COMP.W	D7,D5	JUMP',HS 90$	LOAD.W	D7,D5		; D7 <-- erreur la plus grve !90$:	POPM.L	D4..D6,A4	TEST.W	D7		; retour EQ/NE	RETTEXPEN:	.ASCIZ	".PPAGE"TEXTRA:	.ASCIZ	".TPAGE"TIOPEN:	.ASCIZ	"PAGE"		; nom du logiciel	.ASCIZ	"Mpinceau"	; [M,F] nom des lments manipuls	.ASCIZ	""		; [M,F] nom du contenant	.B	0TIOTRA:	.ASCIZ	"PAGE"		; nom du logiciel	.ASCIZ	"Ftrame"	; [M,F] nom des lments manipuls	.ASCIZ	""		; [M,F] nom du contenant	.B	0	.EVEN	.END