	.SBTTL	PAGECADRE;--------\\; DESWDO  >;========/; Grise toute la fentre et place les icnes.; in	-; out	-; mod	D7.WDESWDO:	PUSHM.L	D2..D4	CALL	ERGMOUSE	; efface les flches dans les rgles	CALL	DESMDEF		; D4 <-- trame grise pour le fond	CALL	DRMDEF	CLR.L	D3	LOAD.L	D4,(A0)+ODFFDY	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; grise toute la fentre	PUSH.L	D4	LOAD.L	D4,#-1	CALL	DRMDEF	POP.L	D4	SWAP.W	D4	LOAD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	SWAP.W	D4	LIB	?DRTRAME	; dessine une bande blanche en haut	CALL	DESINFO		; affiche les informations	CALL	DESINFSC	; affiche l'chelle	CALL	DESINFPA	; affiche le pas	CALL	DESINFFILE	; affiche le nom du dessin	CLR.L	D4	CALL	DRMDEF	LOAD.W	D4,(A0)+ODFDY	SUB.W	D4,#ICOLY	SWAP.W	D4	LOAD.W	D4,#MARGX+GCIMX	LOAD.L	(A6)+ODICO,D4	; ODICO <-- position pour icnes  gauche	CALL	DESICONE	; dessine toutes les icnes	CALL	MEMICONE	; mmorise les icnes de gauche	CALL	MAJICONE	POPM.L	D2..D4	RET;--------\\; DESMDEF >;========/; Dtermine la trame grise pour le fond.; in	-; out	D4.L	trame grise; mod	D4.L, D7.WDESMDEF:	LOAD.L	D4,#H'88882222	; D4 <-- trame pour cran entrelac	COMP.B	(A6)+OMACHINE,#SMAKY8	JUMP',EQ 90$	LOAD.L	D4,#H'88228822	; D4 <-- trame pour joli cran90$:	RET;--------\\; DESINFO >;========/; Dessine les informations tout en haut.; in	-; out	-; mod	D7.WDESINFO:	PUSHM.L	D3,D4,A3	CLR.L	D3	LIB	?SETCURS	LIB	?AFTIM	.B	NOCURS		; pas de curseur	.B	AFINV		; vido inverse	.ASCII	" PAGE "	.B	PAGEREV+'0,'.	.IF	PAGEVERS<10	.B	PAGEVERS+'0	.ELSE	.B	(PAGEVERS/10)+'0,(PAGEVERS-((PAGEVERS/10)*10))+'0	.ENDIF	.B	0	.EVEN	LOAD.B	D3,#AFDIR	LIB	?AFCAR	LOAD.L	A3,#R16"TIHELP	CALL	DESINF3B	; affiche les 3 boutons de la souris	POPM.L	D3,D4,A3	RET;---------\\; DESINF3B >;=========/; Affiche les fonctions des trois boutons de la souris.; in	A3.L	^texte; out	-; mod	D7.WDESINF3B:	PUSHM.L	D3,A3,A4	LOAD.W	D3,#LIHELP	MUL.WU	D3,(A0)+ODFCX	SUB.W	D3,(A0)+ODFDX	NEG.W	D3	CONV.LA.WA D3	LIB	?SETCURS	LOAD.L	A4,#(A6)+OBUDIS	LOAD.B	(A4+),#AFINV	LOAD.B	(A4+),#AFTOUT20$:	LOAD.B	(A4+),(A3+)	JUMP,NE 20$	DEC.L	A4	LOAD.B	(A4+),#AFNORM	LOAD.B	(A4+),#AFDIR	CLR.B	(A4+)	LOAD.L	A3,#(A6)+OBUDIS	LIB	?AFTEXT		; affiche les 3 boutons de la souris	POPM.L	D3,A3,A4	RET;---------\\; DESINFXY >;=========/; Affiche la position x,y de la souris dans les informations.; in	D3.L	position (y;x) ou -1 si hors de l'aire de dessin; out	-; mod	D7.WDESINFXY:	PUSHM.L	D2..D4	LOAD.L	D4,D3		; D4 <-- position (y;x)	LOAD.B	D3,#AFINV	LIB	?AFCAR		; vido inverse	LOAD.W	D3,#POSXY	MUL.WU	D3,(A0)+ODFCX	CONV.LA.WA D3	LIB	?SETCURS	COMP.L	D4,#-1		; hors de l'aire de dessin ?	JUMP',EQ 50$		; oui => 50$				; non =>	LIB	?AFTIM	.ASCIZ	"X="	.EVEN	LOAD.W	D2,#2^BAFDALL	; D2 <-- mode	LOAD.W	D3,#3		; D3 <-- nb digits pour 0..999	PUSH.L	D4	CONV.LA.WA D4	LIB	?AFDEC	POP.L	D4	LIB	?AFTIM	.ASCIZ	" Y="	.EVEN	CLR.W	D4	SWAP.W	D4	LIB	?AFDEC	JUMP'	80$50$:	LIB	?AFTIM	.B	MSPACE,6+6,0	; efface tout	.EVEN80$:	LOAD.B	D3,#AFDIR	LIB	?AFCAR		; vido normale	POPM.L	D2..D4	RET;---------\\; DESINFSC >;=========/; Affiche l'chelle dans les informations.;	OSCALE positif	-->	n:1;	OSCALE ngatif	-->	1:n; in	(A6)+OSCALE.W; out	-; mod	D7.WDESINFSC:	PUSHM.L	D2..D4	LOAD.B	D3,#AFINV	LIB	?AFCAR		; vido inverse	LOAD.W	D3,#POSSCALE	MUL.WU	D3,(A0)+ODFCX	CONV.LA.WA D3	LIB	?SETCURS	LOAD.W	D2,#2^BAFDCM	; D2 <-- mode compact	LOAD.W	D3,#2		; D3 <-- 2 digits au maximum	CLR.L	D4	LOAD.W	D4,(A6)+OSCALE	; D4 <-- +/- chelle	JUMP',NS 50$	JUMP',NE 40$	INC.W	D440$:				; chelle n:1 =>	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	":1"	.EVEN	JUMP'	60$50$:				; chelle 1:n =>	NEG.W	D4	LIB	?AFTIM	.ASCIZ	"1:"	.EVEN	LIB	?AFDEC60$:	COMP.W	D4,#10		; deux digits affichs ?	JUMP',HS 80$		; oui => 80$	LIB	?AFSPACE	; non => affiche encore un espace80$:	LOAD.B	D3,#AFDIR	LIB	?AFCAR		; vido normale	POPM.L	D2..D4	RET;---------\\; DESINFPA >;=========/; Affiche le pas dans les informations.; in	(A6)+OPAS.W; out	-; mod	D7.WDESINFPA:	PUSHM.L	D2..D4	LOAD.B	D3,#AFINV	LIB	?AFCAR		; vido inverse	LOAD.W	D3,#POSPAS	MUL.WU	D3,(A0)+ODFCX	CONV.LA.WA D3	LIB	?SETCURS	LOAD.L	D4,(A6)+OFLAGS	TEST.L	D4:#BFLPAX	JUMP',BC 50$	LIB	?AFTIM	.ASCIZ	"p="	.EVEN	CLR.L	D4	LOAD.W	D4,(A6)+OPAS	; D4 <-- pas	LOAD.W	D2,#2^BAFDCM	; D2 <-- mode compact	LOAD.W	D3,#2		; D3 <-- 2 digits au maximum	LIB	?AFDEC	COMP.W	D4,#10		; deux digits affichs ?	JUMP',HS 80$		; oui => 80$	LIB	?AFSPACE	; non => affiche encore un espace	JUMP'	80$50$:	LIB	?AFTIM	.ASCIZ	"    "		; efface "p=32"	.EVEN80$:	LOAD.B	D3,#AFDIR	LIB	?AFCAR		; vido normale	POPM.L	D2..D4	RET;-----------\\; DESINFFILE >;===========/; Affiche le nom du fichier dans les informations.; in	-; out	-; mod	D7.WDESINFFILE:	PUSHM.L	D2..D4,A3,A4	LOAD.L	A3,#(A6)+OBUNAME	LIB	?BUCAR		; mode rapide	LOAD.B	D3,#AFINV	LIB	?AFCAR		; vido inverse	LOAD.W	D3,#POSFILE	MUL.WU	D3,(A0)+ODFCX	CONV.LA.WA D3	LIB	?SETCURS	CLR.L	D4	LOAD.W	D4,(A0)+ODFDX	DIV.WU	D4,(A0)+ODFCX	; D4 <-- nb car dans toute la largeur	SUB.W	D4,#POSFILE	SUB.W	D4,#LIHELP+1	; D4 <-- nb car restants pour le nom	TEST.B	(A3)	JUMP',EQ 50$	COMP.B	(A3),#CR	JUMP',EQ 50$	LIB	?AFTIM	.B	'"		; guillemet au dbut	.B	AFTOUT	.B	0	.EVEN	SUB.W	D4,#2	LOAD.L	A4,#(A6)+OBUDIS	CALL	PUTINFFILE	; OBUDIS <-- nom du fichier	COMP.W	D3,D4	JUMP',LS 30$	ADD.W	A4,D3	SUB.W	A4,D4		; A4 <-- saute le dbut du nom	LOAD.B	(A4),#5		; dbut de nom <-- triangle "<"	LOAD.W	D3,D430$:	LOAD.L	A3,A4	LIB	?AFTEXT		; affiche le nom, ou seulement la fin	SUB.W	D4,D3		; D4 <-- lg restante	LIB	?AFTIM	.B	AFNORM	.B	'"		; guillemet  la fin	.B	0	.EVEN50$:	TEST.W	D4	JUMP',EQ 80$	LOAD.B	D3,#MSPACE	LIB	?AFCAR		; efface la fin	LOAD.B	D3,D4	LIB	?AFCAR80$:	LOAD.B	D3,#AFDIR	LIB	?AFCAR		; vido normale	LIB	?NOBUCAR	; mode normal	POPM.L	D2..D4,A3,A4	RET;-----------\\; PUTINFFILE >;-----------/; Prpare le nom du fichier  afficher.; in	A3.L	^nom;	A4.L	^buffer; out	D3.W	nb de caractres; mod	D3.L, D7.WPUTINFFILE:	PUSHM.L	D1,D2,A4	LOAD.W	D2,#2^BAFXMI	; D2 <-- affiche en minuscules	LOAD.W	D3,#100		; D3 <-- lg max	LOAD.L	D1,A4	LIB	?PUTXFILE	; OBUDIS <-- nom du fichier20$:	COMP.L	A4,D1	JUMP',EQ 30$	LOAD.B	D3,(-A4)	COMP.B	D3,#':	JUMP',EQ 30$	COMP.B	D3,#'.	JUMP,NE 20$	CLR.B	(A4)		; enlve l'extension30$:	LOAD.L	A4,D1	LOAD.W	D3,#-140$:	INC.W	D3	TEST.B	(A4+)	JUMP,NE 40$	POPM.L	D1,D2,A4	RET;---------\\; DESCADRE >;=========/; Dessine le cadre de la grande matrice, avec les ascenseurs.; in	(A6)+ORPOS.L	position rectangle;	(A6)+ORDIM.L	dimensions rectangle; out	(A6)+OWPOS.L	position fentre;	(A6)+OWDIM.L	dimensions fentre; mod	D7.WDESCADRE:	PUSHM.L	D2..D4,A5	CALL	ERGMOUSE	; efface les flches dans les rgles	LOAD.L	D3,(A6)+ORPOS	LOAD.L	D4,(A6)+ORDIM	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D3	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	TEST.B	(A6)+ODEF+2:#BDEFREG-8 ; rgles prsentes ?	JUMP',BC 20$		; non => 20$	SUB.W	D4,#LGREGLE	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,#LGREGLE	SUB.W	D4,#LGREGLE	SWAP.W	D3	SWAP.W	D420$:	TEST.B	(A6)+ODEF+2:#BDEFASC-8 ; ascenseurs prsents ?	JUMP',BC 25$		; non => 25$	ADD.W	D3,#LGSCROLL-1	SUB.W	D4,#LGSCROLL-1	SWAP.W	D4	SUB.W	D4,#LGSCROLL-1	SWAP.W	D425$:	LOAD.L	(A6)+OWPOS,D3	LOAD.L	(A6)+OWDIM,D4	CLR.L	D4	LOAD.W	D7,#DET_INITSC	PAGE_	DET		; init selon nouvelle chelle	CLR.L	D4	CALL	DRMDEF	LOAD.L	D3,(A6)+ORPOS	LOAD.L	D4,(A6)+ORDIM	LOAD.W	D2,#CLRDOT	LIB	?DRTRAME	; efface toute la grande matrice	LOAD.W	D2,#SETDOT	LIB	?DRRECT		; rectangle autour grande matrice	DEC.W	D3	SWAP.W	D3	DEC.W	D3	SWAP.W	D3	ADD.W	D4,#2	SWAP.W	D4	ADD.W	D4,#2	SWAP.W	D4	LIB	?DRRECT		; double l'paisseur	LOAD.L	A5,#(A6)+OASVER	LOAD.W	D4,(A6)+OWPOS+0	DEC.W	D4	LOAD.W	(A5)+OSCDEBO,D4	LOAD.W	D4,(A6)+OWPOS+2	SUB.W	D4,#LGSCROLL	LOAD.W	(A5)+OSCDEBL,D4	LOAD.W	D4,(A6)+OWDIM+0	ADD.W	D4,#2	LOAD.W	(A5)+OSCHTR,D4	CLR.B	(A5)+OSCHOR	SET.B	(A5)+OSCPAGE	TEST.B	(A6)+ODEF+2:#BDEFASC-8 ; ascenseurs prsents ?	JUMP',BC 40$		; non => 40$	SCROLL_	DRAW		; dessine la cage verticale40$:	LOAD.L	A5,#(A6)+OASHOR	LOAD.W	D4,(A6)+OWPOS+2	DEC.W	D4	LOAD.W	(A5)+OSCDEBO,D4	LOAD.W	D4,(A6)+OWPOS+0	ADD.W	D4,(A6)+OWDIM+0	LOAD.W	(A5)+OSCDEBL,D4	LOAD.W	D4,(A6)+OWDIM+2	ADD.W	D4,#2	LOAD.W	(A5)+OSCHTR,D4	SET.B	(A5)+OSCHOR	SET.B	(A5)+OSCPAGE	TEST.B	(A6)+ODEF+2:#BDEFASC-8 ; ascenseurs prsents ?	JUMP',BC 45$		; non => 45$	SCROLL_	DRAW		; dessine la cage horizontale45$:	CALL	MAJCADRE	POPM.L	D2..D4,A5	RET;---------\\; MAJCADRE >;=========/; Met  jour le cadre (ascenseurs et rgles).; in	-; out	-; mod	D7.WMAJCADRE:	PUSHM.L	D3,D4,A5	CALL	DESREGLE	; dessine les rgles	LOAD.L	A5,#(A6)+OASVER	CLR.W	(A5)+OSCHTV	LOAD.W	D4,(A6)+OPDIM+0	SUB.W	D4,(A6)+OWDIM+0	JUMP',LE 40$	INC.W	D4	LOAD.W	(A5)+OSCHTV,D4	LOAD.W	(A5)+OSCPOSV,(A6)+OPPOS+0	TEST.B	(A6)+ODEF+2:#BDEFASC-8 ; ascenseurs prsents ?	JUMP',BC 40$		; non => 40$	SCROLL_	UPDATE		; dessine la cabine verticale40$:	LOAD.L	A5,#(A6)+OASHOR	CLR.W	(A5)+OSCHTV	LOAD.W	D4,(A6)+OPDIM+2	SUB.W	D4,(A6)+OWDIM+2	JUMP',LE 60$	INC.W	D4	LOAD.W	(A5)+OSCHTV,D4	LOAD.W	(A5)+OSCPOSV,(A6)+OPPOS+2	TEST.B	(A6)+ODEF+2:#BDEFASC-8 ; ascenseurs prsents ?	JUMP',BC 60$		; non => 60$	SCROLL_	UPDATE		; dessine la cabine horizontale60$:	POPM.L	D3,D4,A5	RET;-------------\\; DOKASCENSEUR >;=============/; Agit dans les ascenseurs en fonction d'une touche presse.; in	D3.W	touche presse;	A1.L	^routine d'inversion/nil; out	D7.W	erreur; mod	D7.WDOKASCENSEUR:	PUSHM.L	D3,D4,A5	COMP.B	D3,#'a	JUMP',LO 10$	COMP.B	D3,#'z	JUMP',HI 10$	SUB.B	D3,#'a-'A	; D3 <-- lettre MAJUSCULE10$:	LOAD.L	D4,#SCROLLFUP!2^16	COMP.W	D3,#H'100*(2^BSHOW)+'R	JUMP',EQ 20$	LOAD.L	D4,#SCROLLPUP!2^16	COMP.W	D3,#H'100*(2^BSHOW)+'E	JUMP',EQ 20$	LOAD.L	D4,#SCROLLFDOWN!2^16	COMP.W	D3,#H'100*(2^BSHOW)+'C	JUMP',EQ 20$	LOAD.L	D4,#SCROLLPDOWN!2^16	COMP.W	D3,#H'100*(2^BSHOW)+'X	JUMP',EQ 20$	LOAD.L	D4,#SCROLLFUP!2^16	COMP.W	D3,#H'100*(2^BSHOW)+'D	JUMP',EQ 40$	LOAD.L	D4,#SCROLLPUP!2^16	COMP.W	D3,#H'100*(2^BSHOW)+'S	JUMP',EQ 40$	LOAD.L	D4,#SCROLLFDOWN!2^16	COMP.W	D3,#H'100*(2^BSHOW)+'F	JUMP',EQ 40$	LOAD.L	D4,#SCROLLPDOWN!2^16	COMP.W	D3,#H'100*(2^BSHOW)+'G	JUMP',EQ 40$	JUMP'	80$20$:	LOAD.L	A5,#(A6)+OASVER	TEST.W	(A5)+OSCHTV	JUMP',EQ 80$	CALL	ASCMOVEV	; dplace l'ascenseur vertical ...	CLR.W	D7		; D7 <-- ok	JUMP'	90$40$:	LOAD.L	A5,#(A6)+OASHOR	TEST.W	(A5)+OSCHTV	JUMP',EQ 80$	CALL	ASCMOVEH	; dplace l'ascenseur horizontal ...	CLR.W	D7		; D7 <-- ok	JUMP'	90$80$:	LOAD.W	D7,#190$:	POPM.L	D3,D4,A5	TEST.W	D7		; retour EQ/NE	RET;-------------\\; DOMASCENSEUR >;=============/; Agit dans les ascenseurs en fonction de la souris.; in	D4.L	position de la souris (y;x);	A1.L	^routine d'inversion/nil; out	D7.W	erreur; mod	D7.WDOMASCENSEUR:	PUSHM.L	D1,D4,A5	LOAD.W	D7,#1	TEST.B	(A6)+ODEF+2:#BDEFASC-8 ; ascenseurs prsents ?	JUMP',BC 80$	LOAD.L	D1,D4		; D1 <-- position de la souris	LOAD.L	A5,#(A6)+OASVER	TEST.W	(A5)+OSCHTV	JUMP',EQ 20$	LOAD.W	(A5)+OSCPOSV,(A6)+OPPOS+0	SCROLL_	MOVE		; dans ascenseur vertical ?	JUMP',NE 20$	TCLR.L	D4:#16		; D4 <-- avec rptition	CALL	ASCMOVEV	; dplace l'ascenseur vertical ...	CLR.W	D7		; D7 <-- ok	JUMP'	90$20$:	LOAD.L	D4,D1		; D4 <-- position de la souris	LOAD.L	A5,#(A6)+OASHOR	TEST.W	(A5)+OSCHTV	JUMP',EQ 80$	LOAD.W	(A5)+OSCPOSV,(A6)+OPPOS+2	SCROLL_	MOVE		; dans ascenseur horizontal ?	JUMP',NE 80$	TCLR.L	D4:#16		; D4 <-- avec rptition	CALL	ASCMOVEH	; dplace l'ascenseur horizontal ...	CLR.W	D7		; D7 <-- ok	JUMP'	90$80$:	LOAD.W	D7,#190$:	POPM.L	D1,D4,A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; ASCMOVEH >;=========/; Dplace l'ascenseur horizontal.; in	A5.L	^description ascenseur;	D4.L	SCROLL(F/P)(UP/DOWN);	A1.L	^routine d'inversion/nil; out	-; mod	D7.WASCMOVEH:	PUSHM.L	D2..D4	TEST.B	(A6)+ODEF+2:#BDEFASC-8 ; ascenseurs prsents ?	JUMP',BC 05$	SCROLL_	PRESS		; allume le "bouton"05$:	COMP.L	A1,#0	JUMP',EQ 06$	CALL	(A1)		; teint qq chose !06$:	LOAD.L	D2,D4		; D2 <-- "bouton" de l'ascenseur10$:	LOAD.W	D3,#DASC	; D3 <-- +n point	LOAD.W	D7,#DET_SCALEN	PAGE_	DET		; D3 <-- plus petit (si n:1)	TEST.W	D3	JUMP',NE 12$	INC.W	D312$:	COMP.W	D2,#SCROLLFDOWN	JUMP',EQ 50$	NEG.W	D3		; D3 <-- -n point	COMP.W	D2,#SCROLLFUP	JUMP',EQ 50$	LOAD.W	D3,(A6)+OWDIM+2	; D3 <-- +1 cran	COMP.W	D2,#SCROLLPDOWN	JUMP',EQ 50$	NEG.W	D3		; D3 <-- -1 cran	COMP.W	D2,#SCROLLPUP	JUMP',EQ 50$; Dplacement absolu selon l'ascenseur.	LOAD.L	D4,(A6)+OPPOS	LOAD.W	D4,(A5)+OSCPOSV	CALL	ASCMOVE		; dplace la partie visible	JUMP'	80$; Dplacement selon la quantit dans D3.50$:	LOAD.L	D4,(A6)+OPPOS	ADD.W	D4,D3	CALL	ASCMOVE		; dplace la partie visible	TEST.L	D2:#16		; juste une fois ?	JUMP',BS 80$		; oui => 80$				; non =>	LIB	?IFCAR		; bouton relach ?	JUMP,NE 10$		; non => 10$80$:	TEST.B	(A6)+ODEF+2:#BDEFASC-8 ; ascenseurs prsents ?	JUMP',BC 85$	LOAD.W	D4,D2	SCROLL_	PRESS		; teint le "bouton"85$:	COMP.L	A1,#0	JUMP',EQ 86$	CALL	(A1)		; allume qq chose !86$:	CALL	DESREGLE	; dessine les rgles	POPM.L	D2..D4	RET;---------\\; ASCMOVEV >;=========/; Dplace l'ascenseur vertical.; in	A5.L	^description ascenseur;	D4.L	SCROLL(F/P)(UP/DOWN);	A1.L	^routine d'inversion/nil; out	-; mod	D7.WASCMOVEV:	PUSHM.L	D2..D4	TEST.B	(A6)+ODEF+2:#BDEFASC-8 ; ascenseurs prsents ?	JUMP',BC 05$	SCROLL_	PRESS		; allume le "bouton"05$:	COMP.L	A1,#0	JUMP',EQ 06$	CALL	(A1)		; teint qq chose !06$:	LOAD.L	D2,D4		; D2 <-- "bouton" de l'ascenseur10$:	LOAD.W	D3,#DASC	; D3 <-- +n point	LOAD.W	D7,#DET_SCALEN	PAGE_	DET		; D3 <-- plus petit (si n:1)	TEST.W	D3	JUMP',NE 12$	INC.W	D312$:	COMP.W	D2,#SCROLLFDOWN	JUMP',EQ 50$	NEG.W	D3		; D3 <-- -n point	COMP.W	D2,#SCROLLFUP	JUMP',EQ 50$	LOAD.W	D3,(A6)+OWDIM+0	; D3 <-- +1 cran	COMP.W	D2,#SCROLLPDOWN	JUMP',EQ 50$	NEG.W	D3		; D3 <-- -1 cran	COMP.W	D2,#SCROLLPUP	JUMP',EQ 50$; Dplacement absolu selon l'ascenseur.	LOAD.L	D4,(A6)+OPPOS	SWAP.W	D4	LOAD.W	D4,(A5)+OSCPOSV	SWAP.W	D4	CALL	ASCMOVE		; dplace la partie visible	JUMP'	80$; Dplacement selon la quantit dans D3.50$:	LOAD.L	D4,(A6)+OPPOS	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D4	CALL	ASCMOVE		; dplace la partie visible	TEST.L	D2:#16		; juste une fois ?	JUMP',BS 80$		; oui => 80$				; non =>	LIB	?IFCAR		; bouton relach ?	JUMP,NE 10$		; non => 10$80$:	TEST.B	(A6)+ODEF+2:#BDEFASC-8 ; ascenseurs prsents ?	JUMP',BC 85$	LOAD.W	D4,D2	SCROLL_	PRESS		; teint le "bouton"85$:	COMP.L	A1,#0	JUMP',EQ 86$	CALL	(A1)		; allume qq chose !86$:	CALL	DESREGLE	; dessine les rgles	POPM.L	D2..D4	RET;--------\\; ASCMOVE >;--------/; Dplace la partie visible horizontalement ou verticalement.; in	A5.L	^description ascenseur;	D4.L	nouvelle position (y;x); out	-; mod	D7.WASCMOVE:	PUSHM.L	D3,D4	TEST.W	D4	JUMP',NC 20$	CLR.W	D420$:	COMP.W	D4,(A6)+OASHOR+OSCHTV	JUMP',LO 22$	LOAD.W	D4,(A6)+OASHOR+OSCHTV	JUMP',EQ 22$	DEC.W	D422$:	SWAP.W	D4	TEST.W	D4	JUMP',NC 30$	CLR.W	D430$:	COMP.W	D4,(A6)+OASVER+OSCHTV	JUMP',LO 32$	LOAD.W	D4,(A6)+OASVER+OSCHTV	JUMP',EQ 32$	DEC.W	D432$:	SWAP.W	D4	LOAD.L	(A6)+OPPOS,D4	LOAD.W	(A6)+OASHOR+OSCPOSV,D4	SWAP.W	D4	LOAD.W	(A6)+OASVER+OSCPOSV,D4	TEST.B	(A6)+ODEF+2:#BDEFASC-8 ; ascenseurs prsents ?	JUMP',BC 50$	SCROLL_	UPDATE		; dplace l'ascenseur50$:	LOAD.W	D7,#DESS_OBJETS	PAGE_	DESS		; dessine tous les objets	POPM.L	D3,D4	RET;---------\\; MAJREGLE >;=========/; Met  jour les rgles centimtriques si la partie visible; a t dplace.; in	-; out	-; mod	D7.WMAJREGLE:	PUSHM.L	D4,A5	TEST.B	(A6)+ODEF+2:#BDEFREG-8 ; rgles prsentes ?	JUMP,BC	90$		; non => 90$				; oui =>	LOAD.L	A5,#(A6)+ORGVAR; Regarde les variables pour la rgle horizontale.	LOAD.W	D4,(A6)+OPPOS+2	COMP.W	D4,(A5)+ORGHOR	JUMP',NE 80$; Regarde les variables pour la rgle verticale.	LOAD.W	D4,(A6)+OPPOS+0	COMP.W	D4,(A5)+ORGVOR	JUMP',EQ 90$80$:	CALL	DESREGLE	; redessine les deux rgles90$:	POPM.L	D4,A5	RET;---------\\; DESREGLE >;=========/; Dessine les rgles centimtriques (mme s'il n'y a rien de chang).; in	-; out	-; mod	D7.WDESREGLE:	PUSHM.L	D4,A5	TEST.B	(A6)+ODEF+2:#BDEFREG-8 ; rgles prsentes ?	JUMP,BC	90$		; non => 90$				; oui =>	LOAD.L	A5,#(A6)+ORGVAR; Initialise les variables pour la rgle horizontale.	LOAD.W	(A5)+ORGHPO+2,(A6)+OWPOS+2	LOAD.W	D4,(A6)+OWPOS+0	SUB.W	D4,#LGREGLE	LOAD.W	(A5)+ORGHPO+0,D4	LOAD.W	D4,(A6)+OWDIM+2	INC.W	D4	LOAD.W	(A5)+ORGHLG,D4	LOAD.W	(A5)+ORGHOR,(A6)+OPPOS+2	LOAD.W	(A5)+ORGHSC,(A6)+OSCALE	LOAD.L	D4,#10000*64	DIV.WU	D4,(A6)+OMMX	CONV.LA.WA D4	DIV.WU	D4,(A6)+OFACX	LOAD.W	(A5)+ORGHPA,D4; Initialise les variables pour la rgle verticale.	LOAD.W	D4,(A6)+OWPOS+2	ADD.W	D4,(A6)+OWDIM+2	INC.W	D4	LOAD.W	(A5)+ORGVPO+2,D4	LOAD.W	(A5)+ORGVPO+0,(A6)+OWPOS+0	LOAD.W	D4,(A6)+OWDIM+0	INC.W	D4	LOAD.W	(A5)+ORGVLG,D4	LOAD.W	(A5)+ORGVOR,(A6)+OPPOS+0	LOAD.W	(A5)+ORGVSC,(A6)+OSCALE	LOAD.L	D4,#10000*64	DIV.WU	D4,(A6)+OMMY	CONV.LA.WA D4	DIV.WU	D4,(A6)+OFACY	LOAD.W	(A5)+ORGVPA,D4	SET.B	(A5)+ORGVHB	; rgle verticale de haut en bas	SCROLL_	RUPDATE		; dessine les rgles gradues90$:	POPM.L	D4,A5	RET;---------\\; CALCADRE >;=========/; Calcul la position et les dimensions du rectangle; dans la fentre.; in	-; out	(A6)+ORPOS.L	position rectangle;	(A6)+ORDIM.L	dimensions rectangle; mod	D7.WCALCADRE:	PUSHM.L	D3,D4	LOAD.W	D3,#MARGX	TEST.B	(A6)+ODEF+3:#BDEFICO ; utilise les icnes ?	JUMP',BC 30$		; non => 30$	ADD.W	D3,#(GCIMX+GCICX/2+GCIMX)*3+MARGX30$:	LOAD.W	(A6)+ORPOS+2,D3	LOAD.W	D4,(A0)+ODFDX	SUB.W	D4,D3	SUB.W	D4,#MARGX+1	LOAD.W	(A6)+ORDIM+2,D4	LOAD.W	D3,(A0)+ODFC1Y	ADD.W	D3,(A0)+ODFC2Y	ADD.W	D3,#MARGY	LOAD.W	(A6)+ORPOS+0,D3	LOAD.W	D4,(A0)+ODFDY	SUB.W	D4,D3	SUB.W	D4,#MARGY+1	LOAD.W	(A6)+ORDIM+0,D4	POPM.L	D3,D4	RET; Textes pour les 3 boutons de la souris; --------------------------------------TIHELP:	.ASCIZ	"| dessine | divers | modifie |"LIHELP	=	.-TIHELP	.EVEN	.END