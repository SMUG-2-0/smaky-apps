	.SBTTL	MPAGEEDITTXPREL:				; base pour ^relatifs;--------\\; TXEDIT  >;========/; Edite un pav de texte selon une touche presse.; in	D3.L	touche presse;	A4.L	^objet texte; out	D7.W	erreur; mod	D7.WTXEDIT:	PUSHM.L	D2..D4,A0,A5	LOAD.L	A5,A4		; A5 <-- ^objet texte	COMP.W	(A5)+OOOBJ,#ICOTX	JUMP,NE BIP$	COMP.W	D3,#H'80	JUMP',HS NOACCENT$	COMP.B	D3,#DEL	JUMP',EQ NOACCENT$	COMP.B	D3,#BS	JUMP',NE ACCENT$NOACCENT$:	CALL	NOACCENT	; plus de frappe d'accent flottantACCENT$:	CALL	EXFONC	.WW	CURSOR,KCURS$-TXPREL	.WW	CURSOR!KILL,KCUKI$-TXPREL	.WW	PROGRA!CHANGE,KPRCH$-TXPREL	.WW	0,KEY$-TXPRELKEY$:	CALL	EXKEY	.WW	DELETE,KDEL$-TXPREL	.WW	DEL,KDEL$-TXPREL	.WW	BS,KBS$-TXPREL	.WW	CCIRCON,KCIRCON$-TXPREL	.WW	CTREMA,KTREMA$-TXPREL	.WW	TRIZERO,KTRIZERO$-TXPREL	.WW	POINT,KPOINT$-TXPREL	.WW	FNCT,KFLIP$-TXPREL	.WW	0,INSERT$-TXPRELINSERT$:	COMP.W	D3,#H'80	JUMP,HS BIP$	CALL	ACCENT		; va sous un accent flottant ?	JUMP,EQ OK$		; oui => OK$	CALL	EINSERE	JUMP,NE EXIT$	JUMP	OK$KTRIZERO$:			; insre 3x zro =>	LOAD.B	D3,#'0	CALL	EINSERE	JUMP,NE EXIT$	CALL	EINSERE	JUMP,NE EXIT$	CALL	EINSERE	JUMP,NE EXIT$	JUMP	OK$KPOINT$:			; insre un "." =>	LOAD.B	D3,#'.	CALL	EINSERE	JUMP,NE EXIT$	JUMP	OK$KCIRCON$:	LOAD.W	D4,#CIRCON	; met un circonflxe	JUMP'	KACCENT$KTREMA$:	LOAD.W	D4,#TREMA	; met qq chose comme un trma;	JUMP'	KACCENT$KACCENT$:	TEST.B	(A5)+OOTXACC	JUMP',T KACCENT6$	CALL	TXDONNE		; D3 <-- car "sous" le curseur	JUMP',NE KACCENT5$	; rien => KACCENT5$	CALL	GETACCENT	; calcul lettre accentue	JUMP',NE KACCENT5$	; n'existe pas => KACCENT5$				; existe =>	TEST.B	D3	JUMP',EQ KACCENT5$	PUSH.L	D3	CALL	TXAVANCE	CALL	TXDETRUIT	; dtruit lettre non accentue	POP.L	D3	CALL	TXINSERE	; remplace par lettre accentue	INC.L	(A5)+OOTXNCI	; un caractre de plus insr	INC.L	(A5)+OOTXNCM	; un caractre de plus avanc/recul	JUMP	OK$KACCENT5$:	LOAD.B	D3,D4		; D3 <-- accent	CALL	EINSERE		; insert un accent tout seul	CALL	TXRECULE	; puis recule "dessus"	SET.B	(A5)+OOTXACC	JUMP	OK$KACCENT6$:	CALL	NOACCENT	; plus de frappe d'accent flottant	JUMP	OK$KFLIP$:				; permute deux caractres =>	CALL	TXDETRUIT	JUMP,NE BIP$	LOAD.L	D4,D3	CALL	TXAVANCE	LOAD.L	D3,D4	CALL	TXINSERE	CALL	TXRECULE	INC.L	(A5)+OOTXNCI	; un caractre de plus insr	INC.L	(A5)+OOTXNCM	; un caractre de plus avanc/recul	JUMP	OK$KDEL$:	LOAD.B	D3,#'D	JUMP	ECUKI$KBS$:	LOAD.B	D3,#'F	JUMP	ECUKI$KCURS$:	CALL	EXKEY	.WW	'E,ECURS$-TXPREL	.WW	'R,ECURS$-TXPREL	.WW	'T,ECURS$-TXPREL	.WW	'S,ECURS$-TXPREL	.WW	'D,ECURS$-TXPREL	.WW	'F,ECURS$-TXPREL	.WW	'G,ECURS$-TXPREL	.WW	'X,ECURS$-TXPREL	.WW	'C,ECURS$-TXPREL	.WW	'V,ECURS$-TXPREL	.WW	0,BIP$KCUKI$:	CALL	EXKEY	.WW	'E,ECUKI$-TXPREL	.WW	'R,ECUKI$-TXPREL	.WW	'T,ECUKI$-TXPREL	.WW	'S,ECUKI$-TXPREL	.WW	'D,ECUKI$-TXPREL	.WW	'F,ECUKI$-TXPREL	.WW	'G,ECUKI$-TXPREL	.WW	'X,ECUKI$-TXPREL	.WW	'C,ECUKI$-TXPREL	.WW	'V,ECUKI$-TXPREL	.WW	0,BIP$KPRCH$:	CALL	EXKEY	.WW	'E,EPRCH$-TXPREL	.WW	'R,EPRCH$-TXPREL	.WW	'T,EPRCH$-TXPREL	.WW	'S,EPRCH$-TXPREL	.WW	'D,EPRCH$-TXPREL	.WW	'F,EPRCH$-TXPREL	.WW	'G,EPRCH$-TXPREL	.WW	'X,EPRCH$-TXPREL	.WW	'C,EPRCH$-TXPREL	.WW	'V,EPRCH$-TXPREL	.WW	0,BIP$ECURS$:	CALL	EFLECHE		; D2 <-- +/- dplacement	TEST.L	D2	JUMP,EQ BIP$	JUMP',NS ECURS4$	ADD.L	(A5)+OOTXNCM,D2	; qq caractres de plus avancs/reculsECURS2$:	CALL	TXAVANCE	DEC.L	D2	JUMP,NE ECURS2$	JUMP	OK$ECURS4$:	SUB.L	(A5)+OOTXNCM,D2	; qq caractres de plus avancs/reculsECURS5$:	CALL	TXRECULE	INC.L	D2	JUMP,NE ECURS5$	JUMP	OK$ECUKI$:	CALL	EFLECHE		; D2 <-- +/- dplacement	TEST.L	D2	JUMP,EQ BIP$	JUMP',NS ECUKI4$	ADD.L	(A5)+OOTXNCL,D2	; qq caractres de plus dtruit en avantECUKI2$:	CALL	TXAVANCE	JUMP,NE EXIT$	CALL	TXDETRUIT	JUMP,NE EXIT$	DEC.L	D2	JUMP,NE ECUKI2$	JUMP	OK$ECUKI4$:	SUB.L	(A5)+OOTXNCK,D2	; qq caractres de plus dtruit en arrireECUKI5$:	CALL	TXDETRUIT	JUMP,NE EXIT$	INC.L	D2	JUMP,NE ECUKI5$	JUMP	OK$EPRCH$:	LOAD.B	D4,D3	CALL	EFLECHE		; D2 <-- +/- dplacement	TEST.L	D2	JUMP',NS EPRCH4$	ADD.L	(A5)+OOTXNCM,D2	; qq caractres de plus avancs/reculsEPRCH2$:	LOAD.B	D3,D4	CALL	EMINMAJ	JUMP,NE BIP$	CALL	TXAVANCE	JUMP,NE EXIT$	DEC.L	D2	JUMP,NE EPRCH2$	JUMP	OK$EPRCH4$:	SUB.L	(A5)+OOTXNCM,D2	; qq caractres de plus avancs/reculsEPRCH5$:	CALL	TXRECULE	JUMP,NE EXIT$	LOAD.B	D3,D4	CALL	EMINMAJ	JUMP,NE BIP$	INC.L	D2	JUMP,NE EPRCH5$	JUMP	OK$OK$:	CLR.W	D7		; D7 <-- action effectue correctement	JUMP'	EXIT$BIP$:	LOAD.W	D7,#1		; D7 <-- rien  faire avec cette toucheEXIT$:	POPM.L	D2..D4,A0,A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; EINSERE >;========/; Insre un caractre en mode "environnant".; in	D3.B	caractre  insrer; out	D7.W	erreur; mod	D7.WEINSERE:	PUSHM.L	D1..D4	LOAD.B	D1,D3		; D1 <-- caractre; Cherche le mode du caractre avant le curseur.	CALL	TXPSAUVE	; D4 <-- position du curseur	CALL	TXRECULE	; D3 <-- mode du caractre prcdent	JUMP',EQ 30$	CLR.L	D3		; D3 <-- mode par dfaut30$:	CALL	TXPPREND	; remet le curseur o il tait	LOAD.L	D2,D3; Cherche le mode du caractre aprs le curseur.	CALL	TXPSAUVE	; D4 <-- position du curseur	CALL	TXAVANCE	; D3 <-- mode du caractre suivant	JUMP',EQ 40$	CLR.L	D3		; D3 <-- mode par dfaut40$:	CALL	TXPPREND	; remet le curseur o il tait; Insre le caractre avec le mode le plus grand.	COMP.L	D3,D2	JUMP',HS 50$	LOAD.L	D3,D250$:	LOAD.B	D3,D1		; D3 <-- mode et caractre	CALL	TXINSERE	; insre normalement	INC.L	(A5)+OOTXNCI	; un caractre de plus insr	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; EMINMAJ >;========/; Transforme un caractre, en majuscule ou en minuscule.; in	D3.B	touche majuscule/minuscule; out	D7.W	erreur; mod	D7.WEMINMAJ:	PUSHM.L	D2..D4	LOAD.B	D2,D3	CALL	TXDONNE		; D3 <-- caractre sous le curseur	JUMP',NE 90$	LOAD.B	D4,D3	COMP.B	D2,#'a	JUMP',LO 40$	COMP.B	D2,#'z	JUMP',HI 40$				; en minuscule =>	COMP.B	D3,#'A	JUMP',LO 60$	COMP.B	D3,#'Z	JUMP',HI 60$	ADD.B	D3,#'a-'A	; D3 <-- lettre minuscule	JUMP'	60$40$:				; en majuscule =>	CALL	MINMAJ		; D3 <-- lettre majuscule60$:	COMP.B	D3,D4		; caractre chang ?	JUMP',EQ 90$		; non => 90$	CALL	TXREMPLACE	INC.L	(A5)+OOTXNCI	; un caractre de plus insr	INC.L	(A5)+OOTXNCM	; un caractre de plus avanc/recul90$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; EFLECHE  >;---------/; Calcul l'amplitude d'un dplacement/destruction en fonction; d'une touche flche.; in	D3.B	touche flche; out	D2.L	dplacement (+/-n); mod	D2.L, D7.WEFLECHE:	PUSHM.L	D3..D6,A3	CALL	TXPSAUVE	; D4 <-- numro position actuelle	PUSH.W	D4	CLR.L	D2		; D2 <-- dplacement	COMP.B	D3,#'A-H'40	JUMP',LO NOCTRL$	COMP.B	D3,#'Z-H'40	JUMP',HI NOCTRL$	ADD.B	D3,#H'40NOCTRL$:	CALL	MINMAJ	COMP.B	D3,#'F	JUMP,EQ AONE$	COMP.B	D3,#'D	JUMP,EQ RONE$	LOAD.W	D6,#1		; D6 <-- une fois	LOAD.L	A3,#R16"TWORD	; A3 <-- ^terminateurs de mots	COMP.B	D3,#'G	JUMP,EQ ALIST$	COMP.B	D3,#'S	JUMP,EQ RLIST$	LOAD.L	A3,#R16"TLINE	; A3 <-- ^terminateurs de lignes	COMP.B	D3,#'C	JUMP,EQ ALIST$	COMP.B	D3,#'R	JUMP,EQ RLIST$	LOAD.W	D6,#4		; D6 <-- quatre fois	COMP.B	D3,#'X	JUMP,EQ ALIST$	COMP.B	D3,#'E	JUMP,EQ RLIST$	COMP.B	D3,#'V	JUMP,EQ AEND$	COMP.B	D3,#'T	JUMP,EQ REND$	JUMP	EXIT$AONE$:				; +1 caractre =>	CALL	TXAVANCE	JUMP,NE EXIT$	INC.L	D2	JUMP	EXIT$RONE$:				; -1 caractre =>	CALL	TXRECULE	JUMP,NE EXIT$	DEC.L	D2	JUMP	EXIT$ALIST$:				; +1 mot/ligne =>	CALL	TXAVANCE	JUMP,NE EXIT$	INC.L	D2	CALL	ETESTCAR	JUMP',NE ALIST2$	COMP.B	(A3),#CR	JUMP,NE ALIST$ALIST2$:	CALL	TXAVANCE	JUMP,NE EXIT$	INC.L	D2	CALL	ETESTCAR	JUMP,NE ALIST2$	CALL	TXRECULE	DEC.L	D2	DEC.W	D6	JUMP,NE ALIST$	JUMP	EXIT$RLIST$:				; -1 mot/ligne =>	CALL	TXRECULE	JUMP,NE EXIT$	DEC.L	D2	CALL	ETESTCAR	JUMP',NE RLIST2$	COMP.B	(A3),#CR	JUMP,NE RLIST$RLIST2$:	CALL	TXRECULE	JUMP,NE EXIT$	DEC.L	D2	CALL	ETESTCAR	JUMP,NE RLIST2$	CALL	TXAVANCE	INC.L	D2	DEC.W	D6	JUMP,NE RLIST$	JUMP	EXIT$AEND$:				; fin =>	CALL	TXINFO		; D4 <-- position, D5 <-- nb caractres	LOAD.L	D2,D5	SUB.L	D2,D4	JUMP'	EXIT$REND$:				; dbut =>	CALL	TXINFO		; D4 <-- position, D5 <-- nb caractres	LOAD.L	D2,D4	NEG.L	D2;	JUMP'	EXIT$EXIT$:	POP.W	D4	CALL	TXPPREND	; remet le curseur o il tait	POPM.L	D3..D6,A3	RETTWORD:	.B	SPACE		; terminateurs de mots	.B	TAB	.B	'+	.B	'-	.B	'*	.B	'/	.B	'^	.B	'(	.B	')	.B	'.	.B	':	.B	',	.B	';	.B	'!	.B	'?TLINE:	.B	CR		; terminateurs de lignes	.B	LF	.B	0	.EVEN;---------\\; ETESTCAR >;---------/; Test si le caractre dans D3.B est un terminateur.; in	D3.B	caractre;	A3.L	^liste de terminateurs; out	EQ	terminateur;	NE	autre chose; mod	FETESTCAR:	PUSH.L	A310$:	TEST.B	(A3)	NOTZ	JUMP',NE 90$	COMP.B	D3,(A3+)	JUMP,NE 10$90$:	POP.L	A3	RET;--------\\; ACCENT  >;========/; Caractre aprs un accent flottant frapp.; in	D3.B	caractre aprs accent; out	D7.W	erreur; mod	D7.WACCENT:	PUSHM.L	D3,D4	LOAD.W	D7,#1	TEST.B	(A5)+OOTXACC	JUMP',F 90$	CLR.B	(A5)+OOTXACC	LOAD.L	D4,D3	CALL	TXDONNE		; D3 <-- cherche car prcdent tap	EX.L	D3,D4		; D4 <-- accent, D3 <-- car qui ira "sous"	CALL	GETACCENT	; accent existe ?	JUMP',NE 40$		; non => 40$				; oui =>	TEST.B	D3		; laisse l'accent seul ?	JUMP',EQ 40$		; oui => 40$				; non =>	PUSH.L	D3	CALL	TXAVANCE	CALL	TXDETRUIT	; dtruit l'accent seul	POP.L	D3	CALL	EINSERE		; remplace par lettre accentue	INC.L	(A5)+OOTXNCM	; un caractre de plus avanc/recul	JUMP'	90$40$:	PUSH.W	D7	CALL	TXAVANCE	; saute '^' ou '"'	POP.W	D790$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; GETACCENT >;----------/; Calcul le code correspondant  une lettre (a,e,i,o,u) et ; un accent (^,").; in	D4.B	accent (^,");	D3.B	caractre; out	D7.W	zro => ok (lettre accentue existe);	 D3.B	 lettre accentue;	D7.W	EREOUTB => lettre accentue n'existe pas;	 D3.B	 caractre qui devait aller sous l'accent; mod	D3.B, D7.WGETACCENT:	PUSH.L	A3	LOAD.L	A3,#R16"ACCENT$-310$:	ADD.L	A3,#3		; A3 <-- ^suivant dans table	TEST.B	(A3)		; fin de la table ?	JUMP',EQ 50$		; oui => 50$	COMP.B	D3,(A3)		; lettre trouve dans table ?	JUMP,NE 10$		; non => 10$				; oui =>	COMP.B	D4,#CIRCON	JUMP',EQ 30$	COMP.B	D4,#TREMA	JUMP',NE 50$	LOAD.B	D3,(A3)+2	; D3 <-- lettre accentue (")	CLR.W	D7		; D7 <-- ok	JUMP'	90$30$:	LOAD.B	D3,(A3)+1	; D3 <-- lettre accentue (^)	CLR.W	D7		; D7 <-- ok	JUMP'	90$50$:	LOAD.W	D7,#1		; D7 <-- erreur90$:	POP.L	A3	TEST.W	D7		; retour EQ/NE	RETACCENT$:	.B	'a	' '	.B	'e	' '	.B	'i	' '	.B	'o	' '	.B	'u	' '	.B	SPACE	 0  0	.B	0	.EVEN;---------\\; NOACCENT >;=========/; Annule l'effet d'un ventuel accent flottant tap, alors; que la lettre devant aller "dessous" n'a pas encore t; tape.NOACCENT:	TEST.B	(A5)+OOTXACC	JUMP',F 90$	CLR.B	(A5)+OOTXACC	PUSH.L	D3	CALL	TXAVANCE	; saute l'accent flottant	POP.L	D390$:	RET;--------\\; EXKEY   >;========/; in	D3.B	touche presse; out	-; mod	A0.LEXKEY:	POP.L	A0		; A0 <-- ^table des .WW	PUSH.L	D3	COMP.B	D3,#'a		; minuscule ?	JUMP',LO 10$		; non => 10$	COMP.B	D3,#'z	JUMP',HI 10$	SUB.B	D3,#'a-'A	; oui => transforme10$:	SUB.L	A0,#4		; A0 <-- recule .WW20$:	ADD.L	A0,#4		; A0 <-- saute .WW	TEST.W	(A0)		; table termine ?	JUMP',EQ 50$		; oui => 50$				; non =>	COMP.B	D3,(A0)+1	; code touche trouve ?	JUMP,NE	20$		; non => 20$50$:	LOAD.W	D3,(A0)+2	; D3 <-- adresse relative	LOAD.L	A0,#R16"TXPREL	ADD.W	A0,D3		; A0 <-- adresse absolue	POP.L	D3	JUMP	(A0)		; excute ...;--------\\; EXFONC  >;========/; in	D3.W	touche fonction (dans high); out	-; mod	A0.LEXFONC:	POP.L	A0		; A0 <-- ^table des .WW	PUSH.L	D3	SR.W	D3,#8		; D3 <-- touche fonction	SUB.L	A0,#4		; A0 <-- recule .WW20$:	ADD.L	A0,#4		; A0 <-- saute .WW	TEST.W	(A0)		; table termine ?	JUMP',EQ 50$		; oui => 50$				; non =>	COMP.B	D3,(A0)+1	; code touche fonction trouv ?	JUMP,NE	20$		; non => 20$50$:	LOAD.W	D3,(A0)+2	; D3 <-- adresse relative	LOAD.L	A0,#R16"TXPREL	ADD.W	A0,D3		; A0 <-- adresse absolue	POP.L	D3	JUMP	(A0)		; excute ...	.END