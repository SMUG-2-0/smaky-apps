	.SBTTL	MPAGEDESSIN;-----------\\; _PAGE_DESS >;===========/; ; in	D7.W	numro du sous-appel;	?	selon appel; out	?	selon appel; mod	?	selon appel_PAGE_DESS:	COMP.W	D7,#DESS_INITIMZOOM	JUMP,EQ DESINITIMZOOM	COMP.W	D7,#DESS_OBJETS	JUMP,EQ DESOBJETS	COMP.W	D7,#DESS_OBJET	JUMP,EQ DESOBJET	COMP.W	D7,#DESS_CLEAR	JUMP,EQ DESCLEAR	COMP.W	D7,#DESS_SET	JUMP,EQ DESSET	COMP.W	D7,#DESS_ISHIFT	JUMP,EQ DESISHIFT	COMP.W	D7,#DESS_IRECT	JUMP,EQ DESIRECT	COMP.W	D7,#DESS_USEPEN	JUMP,EQ MATPEN	COMP.W	D7,#DESS_USETRAME	JUMP,EQ MATTRAME	COMP.W	D7,#DESS_XFLECHE	JUMP,EQ XFLECHE	COMP.W	D7,#DESS_XRECTANGLE	JUMP,EQ XRECTANGLE	COMP.W	D7,#DESS_XCERCLE	JUMP,EQ XCERCLE	COMP.W	D7,#DESS_XELLIPSE	JUMP,EQ XELLIPSE	COMP.W	D7,#DESS_XARC	JUMP,EQ XARC	COMP.W	D7,#DESS_XPOLYGONE	JUMP,EQ XPOLYGONE	RET;----------\\; DESOBJETS >;==========/; Dessine tous les objets.; in	-; out	-; mod	D7.WDESOBJETS:	PUSHM.L	D2..D4,A4	PUSH.L	(A6)+OWPOS	PUSH.L	(A6)+OWDIM	PUSH.L	(A6)+OPPOS	PUSH.L	(A6)+OSDIM	LOAD.L	D4,(A6)+OPDIM	COMP.L	D4,(A6)+OPLDIM	; mmes dimensions ?	JUMP,NE 40$		; non => 40$	LOAD.L	D4,(A6)+OPPOS	COMP.L	D4,(A6)+OPLPOS	; mme position ?	JUMP,EQ 85$		; oui => 85$	LOAD.W	D3,(A6)+OPLPOS+0	SUB.W	D3,(A6)+OPPOS+0	SWAP.W	D3	LOAD.W	D3,(A6)+OPLPOS+2	SUB.W	D3,(A6)+OPPOS+2	LOAD.L	D2,D3	CALL	DETSCALEP	; D3 <-- plus grand (si n:1)	LOAD.L	D4,D3	CALL	SCROLLWDO	; essaye de scroller	JUMP,NE 40$	LOAD.L	D4,D2	LOAD.L	D3,(A6)+OPPOS	TEST.W	D4	JUMP',NC 20$	NEG.W	D4	INC.W	D4	ADD.W	D3,(A6)+OSDIM+2	SUB.W	D3,D4	JUMP'	21$20$:	TEST.W	D4	JUMP',NE 21$	LOAD.W	D4,(A6)+OSDIM+221$:	SWAP.W	D3	SWAP.W	D4	TEST.W	D4	JUMP',NC 25$	NEG.W	D4	INC.W	D4	ADD.W	D3,(A6)+OSDIM+0	SUB.W	D3,D4	JUMP'	26$25$:	TEST.W	D4	JUMP',NE 26$	LOAD.W	D4,(A6)+OSDIM+026$:	SWAP.W	D3	SWAP.W	D4	CALL	MWOOBJET40$:	CALL	OPEWDO		; dessine dans la swdo	LOAD.B	D3,#EOP	LIB	?AFCAR		; efface tout	LOAD.L	A4,#(A6)+OUSE	LOAD.L	A4,(A4)+OLNEXT	; A4 <-- ^premier objet	CALL	MAJOBJETS	CALL	CLOWDO		; fin du dessin dans la swdo85$:	POP.L	(A6)+OSDIM	POP.L	(A6)+OPPOS	POP.L	(A6)+OWDIM	POP.L	(A6)+OWPOS	LOAD.L	(A6)+OPLPOS,(A6)+OPPOS	LOAD.L	(A6)+OPLDIM,(A6)+OPDIM	POPM.L	D2..D4,A4	RET;----------\\; SCROLLWDO >;----------/; Essaye de scroller la fentre.; in	D4.L	+/- dplacement (y;x); out	D7.W	erreur; mod	D7.WSCROLLWDO:	PUSHM.L	D3,D4,A3	LOAD.W	D7,#ERDIOUT	; D7 <-- dplacement trop grand ?	LOAD.W	D3,D4	JUMP,NC 20$	NEG.W	D320$:	COMP.W	D3,(A6)+OWDIM+2	; dplacement horizontal trop grand ?	JUMP,HS 90$		; oui => 90$	LOAD.L	D3,D4	SWAP.W	D3	TEST.W	D3	JUMP,NC 22$	NEG.W	D322$:	COMP.W	D3,(A6)+OWDIM+0	; dplacement vertical trop grand ?	JUMP,HS 90$		; oui => 90$	CALL	OPEWDO		; dessine dans la swdo	CALL	_CCMO		; enlve la souris	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWRASTER	CLR.L	(A3)+1	CLR.L	(A3)+5	SWAP.W	D4	LOAD.L	(A3)+11,D4	CLR.L	(A3)+15	LOAD.L	D4,(A6)+OWDIM	SWAP.W	D4	LOAD.L	(A3)+21,D4	LOAD.B	(A3)+25,#LOADDOT	LOAD.W	D3,#26	LIB	?STRING	CALL	CLOWDO		; fin du dessin dans la swdo	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; DESCLEAR >;=========/; Efface un objet dans la fentre de dessin.; in	A4.L	^objet; out	-; mod	D7.WDESCLEAR:	PUSHM.L	D2,A4	PUSH.L	(A6)+OWPOS	PUSH.L	(A6)+OWDIM	PUSH.L	(A6)+OPPOS	PUSH.L	(A6)+OSDIM	CALL	DWOOBJET	; dimensione la fentre selon objet	JUMP',NE 85$	LOAD.W	D2,#CLRDOT	CALL	DESOBJET	; efface l'objet	TSET.B	(A4)+OOFLG:#BOOSEL	CALL	OPEWDO		; dessine dans la swdo	LOAD.L	A4,#(A6)+OUSE	LOAD.L	A4,(A4)+OLNEXT	; A4 <-- ^premier objet	CALL	MAJOBJETS	CALL	CLOWDO		; fin du dessin dans la swdo85$:	POP.L	(A6)+OSDIM	POP.L	(A6)+OPPOS	POP.L	(A6)+OWDIM	POP.L	(A6)+OWPOS	POPM.L	D2,A4	RET;-------\\; DESSET >;=======/; Dessine un objet dans la fentre de dessin.; in	A4.L	^objet; out	-; mod	D7.WDESSET:	PUSH.L	(A6)+OWPOS	PUSH.L	(A6)+OWDIM	PUSH.L	(A6)+OPPOS	PUSH.L	(A6)+OSDIM	CALL	DWOOBJET	; dimensione la fentre selon objet	JUMP',NE 85$	TCLR.B	(A4)+OOFLG:#BOOSEL	CALL	OPEWDO		; dessine dans la swdo	CALL	MAJOBJETS	CALL	CLOWDO		; fin du dessin dans la swdo85$:	POP.L	(A6)+OSDIM	POP.L	(A6)+OPPOS	POP.L	(A6)+OWDIM	POP.L	(A6)+OWPOS	RET;---------\\; DWOOBJET >;---------/; Dimensione la fentre de dessin pour mettre  jour; un objet spcifique.; in	A4.L	^objet; out	D7.W	erreur; mod	D7.WDWOOBJET:	PUSHM.L	D1..D4	LOAD.W	D7,#ERDIOUT	; D7 <-- rien  faire	LOAD.L	D1,(A6)+OPPOS	LOAD.L	D2,(A6)+OSDIM	LOAD.L	D3,(A4)+OODPOS	LOAD.L	D4,(A4)+OODDIM	ADD.W	D2,D1	ADD.W	D4,D3	COMP.W	D4,D1	JUMP,LT 90$	COMP.W	D3,D2	JUMP,GE 90$	COMP.W	D3,D1	JUMP',GE 20$	LOAD.W	D3,D120$:	COMP.W	D4,D2	JUMP',LT 21$	LOAD.W	D4,D221$:	SUB.W	D4,D3	SWAP.W	D1	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	ADD.W	D2,D1	ADD.W	D4,D3	COMP.W	D4,D1	JUMP',LT 90$	COMP.W	D3,D2	JUMP',GE 90$	COMP.W	D3,D1	JUMP',GE 30$	LOAD.W	D3,D130$:	COMP.W	D4,D2	JUMP',LT 31$	LOAD.W	D4,D231$:	SUB.W	D4,D3;	SWAP.W	D1;	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	CALL	MWOOBJET	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; MWOOBJET >;---------/; Initialise pour pouvoir dessiner dans une fentre rduite; par-rapport  tout l'cran.; Units :	[pi]	points internes;		[pe]	points dans l'crans; in	D3.L		nouvelle valeur pour OPPOS;	D4.L		nouvelle valeur pour OSDIM;	(A6)+OPPOS.L	position          [pi];	(A6)+OSDIM.L	dimensions        [pi];	(A6)+OWPOS.L	position          [pe];	(A6)+OWDIM.L	dimensions        [pe]; out	(A6)+OPPOS.L	position          [pi];	(A6)+OPIPOS.L	position initiale [pi];	(A6)+OSDIM.L	dimensions        [pi];	(A6)+OWPOS.L	position          [pe];	(A6)+OWDIM.L	dimensions        [pe]; mod	D7.WMWOOBJET:	PUSHM.L	D0..D4	LOAD.W	D0,(A6)+OSCALE	JUMP,NC 10$	NEG.W	D0	ADD.W	D4,D3	LOAD.W	D2,D3	CONV.LA.WA D2	DIV.WA	D2,D0	MUL.WA	D2,D0	LOAD.W	D3,D2		; D3 <-- OPPOS arrondi (inf) en X	LOAD.W	D2,D4	ADD.W	D2,D0	DEC.W	D2	CONV.LA.WA D2	DIV.WA	D2,D0	MUL.WA	D2,D0	LOAD.W	D4,D2		; D4 <-- OPPOS+OSDIM arrondi (sup) en X	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	LOAD.W	D2,D3	CONV.LA.WA D2	DIV.WA	D2,D0	MUL.WA	D2,D0	LOAD.W	D3,D2		; D3 <-- OPPOS arrondi (inf) en Y	LOAD.W	D2,D4	ADD.W	D2,D0	DEC.W	D2	CONV.LA.WA D2	DIV.WA	D2,D0	MUL.WA	D2,D0	LOAD.W	D4,D2		; D4 <-- OPPOS+OSDIM arrondi (sup) en Y	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D410$:	LOAD.L	D1,(A6)+OWPOS	COMP.W	D3,(A6)+OPPOS+2	JUMP',EQ 24$	JUMP',LT 22$	LOAD.W	D0,D3	SUB.W	D0,(A6)+OPPOS+2	PUSH.L	D3	LOAD.W	D3,D0	CALL	DETSCALEP	; D0 <-- plus grand (si n:1)	LOAD.W	D0,D3	POP.L	D3	ADD.W	D1,D0	JUMP'	24$22$:	LOAD.W	D3,(A6)+OPPOS+224$:	LOAD.W	D0,(A6)+OPPOS+2	ADD.W	D0,(A6)+OSDIM+2	SUB.W	D0,D3	COMP.W	D4,D0	JUMP',LE 26$	LOAD.W	D4,D026$:	PUSH.L	D3	LOAD.W	D3,D4	CALL	DETSCALEP	; D2 <-- plus grand (si n:1)	LOAD.W	D2,D3	POP.L	D3	SWAP.W	D1	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	COMP.W	D3,(A6)+OPPOS+0	JUMP',EQ 34$	JUMP',LT 32$	LOAD.W	D0,D3	SUB.W	D0,(A6)+OPPOS+0	PUSH.L	D3	LOAD.W	D3,D0	CALL	DETSCALEP	; D0 <-- plus grand (si n:1)	LOAD.W	D0,D3	POP.L	D3	ADD.W	D1,D0	JUMP'	34$32$:	LOAD.W	D3,(A6)+OPPOS+034$:	LOAD.W	D0,(A6)+OPPOS+0	ADD.W	D0,(A6)+OSDIM+0	SUB.W	D0,D3	COMP.W	D4,D0	JUMP',LE 36$	LOAD.W	D4,D036$:	PUSH.L	D3	LOAD.W	D3,D4	CALL	DETSCALEP	; D2 <-- plus grand (si n:1)	LOAD.W	D2,D3	POP.L	D3	SWAP.W	D1	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	LOAD.W	D0,(A6)+OWPOS+2	ADD.W	D0,(A6)+OWDIM+2	SUB.W	D0,D1	COMP.W	D2,D0	JUMP',LE 40$	LOAD.W	D2,D040$:	SWAP.W	D1	SWAP.W	D2	LOAD.W	D0,(A6)+OWPOS+0	ADD.W	D0,(A6)+OWDIM+0	SUB.W	D0,D1	COMP.W	D2,D0	JUMP',LE 50$	LOAD.W	D2,D050$:	SWAP.W	D1	SWAP.W	D2	LOAD.L	(A6)+OPIPOS,(A6)+OPPOS	LOAD.L	(A6)+OWPOS,D1	LOAD.L	(A6)+OWDIM,D2	LOAD.L	(A6)+OPPOS,D3	LOAD.L	(A6)+OSDIM,D4	POPM.L	D0..D4	RET;----------\\; MAJOBJETS >;----------/; Met  jour tous les objets dans la fentre de dessin.; in	A4.L	^premier objet; out	-; mod	D7.WMAJOBJETS:	PUSHM.L	D1,D2,A3,A4	LOAD.L	D1,(A6)+OFLAGS	; D1 <-- flags	TEST.L	D1:#BFLGRF	JUMP',BC 20$	LOAD.L	A3,#(A6)+OUSE	LOAD.L	A3,(A3)+OLNEXT	; A3 <-- ^premier objet	COMP.L	A4,A3		; dessine  partir du premier objet ?	JUMP',NE 20$		; non => 20$	CALL	MAJGRILLE	; dessine la grille dessous20$:	LOAD.W	D2,#SETDOT	; D2 <-- mode dfinitif	LOAD.L	A3,#(A6)+OUSE50$:	COMP.L	A4,A3		; fin de la liste ?	JUMP',EQ 80$		; oui => 80$	CALL	DESOBJET	; dessine un objet	LOAD.L	A4,(A4)+OLNEXT	; A4 <-- ^suivant	JUMP	50$80$:	TEST.L	D1:#BFLGRL	JUMP',BC 90$	CALL	MAJGRILLE	; dessine la grille dessus90$:	POPM.L	D1,D2,A3,A4	RET;----------\\; MAJGRILLE >;----------/; Met  jour la grille.; in	-; out	-; mod	D7.WMAJGRILLE:	PUSHM.L	D0..D6	LOAD.L	D2,(A6)+OFLAGS	LOAD.W	D1,#2	TEST.L	D2:#BFLMU2	JUMP',BS 10$	LOAD.W	D1,#3	TEST.L	D2:#BFLMU3	JUMP',BS 10$	LOAD.W	D1,#4	TEST.L	D2:#BFLMU4	JUMP',BS 10$	LOAD.W	D1,#5	TEST.L	D2:#BFLMU5	JUMP',BS 10$	LOAD.W	D1,#6	TEST.L	D2:#BFLMU6	JUMP',BS 10$	LOAD.W	D1,#810$:	LOAD.W	D4,(A6)+OPAS	LOAD.W	D3,(A6)+OSCALE	JUMP',NC 12$	NEG.W	D3	CALL	_CALCPPCM	; D4 <-- plus petit commun multiple	JUMP,NE 90$	COMP.W	D4,(A6)+OPAS	JUMP',EQ 12$	LOAD.W	D1,#112$:	LOAD.W	D3,D4	CALL	DETSCALEP	; D3 <-- plus grand (si n:1)	LOAD.W	D0,D3	COMP.W	D0,#2	JUMP,LO 90$	CALL	_CCMO		; enlve la souris	LOAD.W	D3,(A6)+OPPOS+0	CALL	DETSCALEP	; D3 <-- plus grand (si n:1)	AND.L	D3,#H'FFFF	DIV.WU	D3,D0	CLR.L	D6	LOAD.W	D6,D3		; D6 <-- numro de la ligne	SWAP.W	D3	TEST.W	D3	JUMP',EQ 20$	SUB.W	D3,D0	NEG.W	D3	INC.W	D620$:	CLR.L	D5	LOAD.W	D5,(A6)+OWDIM+0	SUB.W	D5,D3	ADD.W	D5,D0	DEC.W	D5	DIV.WU	D5,D0		; D5 <-- nb de lignes en Y	JUMP,EQ 90$	SWAP.W	D3		; D3 <-- position initiale en Y30$:	PUSHM.L	D5,D6	LOAD.W	D5,D0		; D5 <-- pas normal	DIV.WU	D6,D1	SWAP.W	D6	TEST.W	D6	JUMP',EQ 34$	MUL.WU	D5,D1		; D5 <-- pas plus grossier34$:	LOAD.W	D4,(A6)+OPPOS+2	EX.L	D3,D4	CALL	DETSCALEP	; D4 <-- plus grand (si n:1)	AND.L	D3,#H'FFFF	EX.L	D4,D3	DIV.WU	D4,D5	SWAP.W	D4	TEST.W	D4	JUMP',EQ 40$	SUB.W	D4,D5	NEG.W	D440$:	LOAD.W	D3,D4		; D3 <-- position initiale en X	CLR.L	D2	LOAD.W	D2,(A6)+OWDIM+2	SUB.W	D2,D3	ADD.W	D2,D5	DEC.W	D2	DIV.WU	D2,D5		; D2 <-- nb de points en X	JUMP',EQ 50$	CLR.L	D4		; D4 <-- dY	LOAD.W	D4,D5		; D4 <-- dX	CALL	_HVDOT		; ligne horizontale pointille50$:	POPM.L	D5,D6	SWAP.W	D3	ADD.W	D3,D0		; D3 <-- position suivante en Y	SWAP.W	D3	INC.W	D6		; D6 <-- ligne suivante	DEC.W	D5	JUMP,NE 30$90$:	POPM.L	D0..D6	RET;----------\\; DESISHIFT >;==========/; Inverse un objet slectionn, avec effet tournant brevet !; in	A4.L	^objet quelconque;	D2.W	mode (1=dbut, 2=milieu, 3=fin); out	-; mod	D7.WDESISHIFT:	PUSHM.L	D2..D5,A3	COMP.L	A4,#0	JUMP,EQ EXIT$	COMP.W	D2,#1	JUMP',EQ OPEN$	COMP.W	D2,#2	JUMP',EQ SHIFT$	COMP.W	D2,#3	JUMP',EQ CLOSE$	JUMP	EXIT$OPEN$:	NTREL	?GETSYTIME	; D4 <-- temps processeus (mod D2..D5 !)	LOAD.L	(A6)+OMAPTP,D4	LOAD.B	D3,(A6)+OMAPNB	LOAD.B	D2,#B'10001000	RL.B	D2,D3	LOAD.B	(A6)+OMAPTT,D2	LOAD.B	D2,#B'00001111	RL.B	D2,D3	JUMP	DRAW$SHIFT$:	NTREL	?GETSYTIME	; D4 <-- temps processeus (mod D2..D5 !)	LOAD.L	D5,D4	SUB.L	D4,(A6)+OMAPTP	COMP.L	D4,#250		; s'est-il coul un minimum de temps ?	JUMP,LO EXIT$		; non => EXIT$	LOAD.L	(A6)+OMAPTP,D5	LOAD.W	D3,#1	COMP.W	D4,#250*2	; s'est-il coul vraiment longtemps ?	JUMP',LO SHIFT2$	; non => SHIFT2$	INC.W	D3		; oui => tourne plus vite !SHIFT2$:	LOAD.B	D2,(A6)+OMAPTT	RL.B	D2,#1	LOAD.B	D4,D2	COMP.W	D3,#1	JUMP',EQ SHIFT3$	RL.B	D4,#1	OR.B	D2,D4SHIFT3$:	LOAD.B	(A6)+OMAPTT,D4	ADD.B	(A6)+OMAPNB,D3	JUMP'	DRAW$CLOSE$:	LOAD.B	D2,#B'00001111	LOAD.B	D3,(A6)+OMAPNB	RL.B	D2,D3;	JUMP'	DRAW$DRAW$:	LOAD.L	A3,#(A6)+OBUDIS	LOAD.B	(A3)+0,#MAPTT	LOAD.B	(A3)+1,D2	; map	LOAD.B	(A3)+2,#1	; chelle	LOAD.W	D3,#3	LIB	?STRING	LOAD.W	D2,#INVDOT!TTTDOT	CALL	DESOBJET	; dessine l'objetEXIT$:	POPM.L	D2..D5,A3	RET;---------\\; DESIRECT >;=========/; Inverse la rgion de clipping d'un objet.; in	A4.L	^objet quelconque; out	-; mod	D7.WDESIRECT:	PUSHM.L	D0..D4	COMP.L	A4,#0	JUMP,EQ 90$	CALL	OPEWDO		; dessine dans la swdo	LOAD.W	D2,#INVDOT	CALL	DESOBJET	; inverse l'objet	LIB	?AFTIM	.B	MAPTT	.B	B'00001111	; map	.B	1		; chelle	.B	0	.EVEN	LOAD.L	D3,(A4)+OODPOS	; D3 <-- position	LOAD.L	D4,(A4)+OODDIM	; D4 <-- dimensions	CALL	CONVP3L4	; D3/D4 <-- dans l'cran	CLR.W	D0		; D0 <-- rayon du rectangle	LOAD.W	D2,#INVDOT!TTTDOT	CALL	XRECTANGLE	; dessine le rectangle	CALL	CLOWDO		; fin du dessin dans la swdo90$:	POPM.L	D0..D4	RET;---------\\; DESOBJET >;=========/; Dessine un objet quelconque.; in	A4.L	^objet quelconque;	D2.W	mode de dessin (SETDOT/CLRDOT/INVDOT,etc.); out	-; mod	D7.WDESOBJET:	PUSH.L	D3	COMP.B	D2,#INVDOT	; mode provisoire ?	JUMP',EQ PROV$		; oui => PROV$	COMP.B	D2,#INVDOT!TTTDOT ; mode provisoire ?	JUMP',EQ PROV$		; oui => PROV$	TEST.B	(A4)+OOFLG:#BOOSEL	JUMP,BS EXIT$	TEST.L	D2:#BMDNMSK	JUMP',BS MATOK$	CALL	CLIPOBJET	; objet apparat dans la fentre ?	JUMP,NE EXIT$		; non => EXIT$	LOAD.W	D3,(A4)+OOFSCA	COMP.W	D3,(A6)+OSCALE	; matrice  la bonne chelle ?	JUMP',EQ MATOK$		; oui => MATOK$	CALL	DESINIT		; construit v. les matrices de fondMATOK$:	CALL	DESMASK		; masque v. le fond	LOAD.L	D3,(A4)+OOFOND	TEST.L	D3:#BFDRTT	; dessine le contour ?	JUMP',BS END$		; non => END$	TEST.L	D3:#BFDRTO	; dessine le contour ?	JUMP',BS END$		; non => END$	TEST.L	D3:#BFDRBO	; dessine le contour ?	JUMP',BS END$		; non => END$PROV$:	CALL	DESOBJETONE	; dessine l'objetEND$:	COMP.B	D2,#INVDOT	; mode provisoire ?	JUMP',EQ EXIT$		; oui => EXIT$	COMP.B	D2,#INVDOT!TTTDOT ; mode provisoire ?	JUMP',EQ EXIT$		; oui => EXIT$	CALL	DESTRAME	; trame v. le fond	TEST.B	(A6)+OVUE+3:#BVUMIX-0 ; vue mixte ?	JUMP',BC EXIT$		; non => EXIT$	COMP.W	D2,#SETDOT	JUMP',NE EXIT$	COMP.W	(A0)+ODFPDI+2,#3	JUMP',HS CLEAR$	COMP.W	(A0)+ODFPDI+0,#3	JUMP',LO EXIT$CLEAR$:	PUSH.B	(A6)+OVUE+3	LOAD.B	(A6)+OVUE+3,#2^BVUFIL-0	PUSH.W	D2	LOAD.W	D2,#CLRDOT	CALL	DESOBJETONE	; efface l'objet en fil de fer	POP.W	D2	POP.B	(A6)+OVUE+3EXIT$:	POP.L	D3	RET;------------\\; DESOBJETONE >;------------/; Dessine juste un objet.; in	A4.L	^objet quelconque;	D2.W	mode de dessin (SETDOT/CLRDOT/INVDOT,etc.); out	-; mod	D3.L, D7.WDESOBJETONE:	LOAD.W	D3,(A4)+OOOBJ	COMP.W	D3,#ICODR	JUMP,EQ DESDR	COMP.W	D3,#ICORD	JUMP,EQ DESRDRA	COMP.W	D3,#ICOFL	JUMP,EQ DESFL	COMP.W	D3,#ICOLB	JUMP,EQ DESLB	COMP.W	D3,#ICOCE	JUMP,EQ DESCE	COMP.W	D3,#ICOEL	JUMP,EQ DESEL	COMP.W	D3,#ICOAR	JUMP,EQ DESAR	COMP.W	D3,#ICOIM	JUMP,EQ DESIM	COMP.W	D3,#ICORA	JUMP,EQ DESRDRA	COMP.W	D3,#ICOTM	JUMP,EQ DESTM	COMP.W	D3,#ICOSP	JUMP,EQ DESSP	COMP.W	D3,#ICOPO	JUMP,EQ DESPO	COMP.W	D3,#ICOTX	JUMP,EQ DESTX	RET;--------\\; DESMASK >;--------/; Efface ventuellement le fond avant de dessiner un objet.; in	A4.L	^objet quelconque;	D2.W	mode de dessin (SETDOT/CLRDOT); out	-; mod	D7.WDESMASK:	PUSHM.L	D0..D5,A3	TEST.B	(A6)+OVUE+3:#BVUFIL-0 ; vue en fil de fer ?	JUMP,BS 90$		; oui => 90$	COMP.W	(A4)+OOOBJ,#ICORD	JUMP,EQ 60$	COMP.W	(A4)+OOOBJ,#ICORA	JUMP,EQ 60$	CLR.W	D0	COMP.W	(A4)+OOOBJ,#ICOTX	JUMP,EQ 61$	TEST.L	(A4)+OOFPM	; matrice de fond existe ?	JUMP,EQ 90$		; non => 90$				; oui =>	LOAD.L	D4,(A4)+OOFOND	TEST.L	D4:#BFDONO	JUMP',BS 20$	COMP.B	D2,#CLRDOT	JUMP,EQ 90$20$:	CALL	OPEWDO		; dessine dans la swdo	CALL	_CCMO		; enlve la souris	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWRASTER	LOAD.L	(A3)+1,#H'10000*1+1 ; source: xx yy	LOAD.L	(A3)+5,(A4)+OOFPM ; source: pppp	LOAD.W	D3,(A4)+OODDIM+2	CALL	DETSCALEP	; D3 <-- plus grand (si n:1)	ADD.W	D3,#2+16-1	AND.B	D3,#B'11110000	SR.W	D3,#3	LOAD.W	(A3)+9,D3	; source: ii	CALL	DESMASKPOS	SWAP.W	D3	LOAD.L	(A3)+11,D3	; destination: xx yy	CLR.L	(A3)+15		; destination: pppp (dans l'cran);	CLR.W	(A3)+19		; destination: ii	LOAD.L	D3,(A4)+OODDIM	CALL	DETSCALEP	; D3 <-- plus grand (si n:1)	SWAP.W	D3	LOAD.L	(A3)+21,D3	; dxx dyy	LOAD.B	D3,#CLRDOT!CPLDOT	LOAD.L	D4,(A4)+OOFOND	TEST.L	D4:#BFDONO	JUMP',BC 40$	LOAD.B	D3,D2	OR.B	D3,#CPLDOT40$:	LOAD.B	(A3)+25,D3	LOAD.W	D3,#26	LIB	?STRING		; efface le fond	JUMP	80$60$:				; rectangle =>	LOAD.W	D0,(A4)+OORARAY	; D0 <-- rayon du rectangle61$:	LOAD.L	D3,(A4)+OORAPOS	; D3 <-- position	LOAD.L	D4,(A4)+OORADIM	; D4 <-- dimensions	JUMP,EQ 90$	LOAD.L	D1,(A4)+OOFOND	TEST.L	D1:#BFDOBT	JUMP,BS 90$	CALL	OPEWDO		; dessine dans la swdo	CALL	_CCMO		; enlve la souris	TCLR.L	D2:#BTTTDOT	TCLR.L	D2:#BPENDOT	TEST.L	D1:#BFDONO	JUMP',BS 64$	TEST.L	D1:#BFDOBO	JUMP',BS 66$	TEST.L	D1:#BFDRBO	JUMP',BS 66$	TEST.L	D1:#BFDOTT	JUMP',BS 62$	TEST.L	D1:#BFDRTT	JUMP',BS 62$	COMP.B	D2,#SETDOT	JUMP',NE 62$	LOAD.B	D2,#LOADDOT62$:	LOAD.W	D1,(A4)+OOTRAM	CALL	MATTRAME	; dfinit la trame	JUMP'	72$64$:	LOAD.L	D5,#-1		; D5 <-- trame noire	COMP.B	D2,#SETDOT	JUMP',EQ 70$	CLR.L	D5		; D5 <-- trame blanche	JUMP'	70$66$:	COMP.B	D2,#SETDOT	JUMP',NE 80$	CLR.L	D5		; D5 <-- trame blanche70$:	LOAD.B	D2,#LOADDOT	EX.L	D4,D5	CALL	_DRMDEF	EX.L	D5,D472$:	CALL	CONVP3L4	; D3/D4 <-- dans l'cran	CALL	XTRARECT	; trame le rectangle arrondi80$:	CALL	CLOWDO		; fin du dessin dans la swdo90$:	POPM.L	D0..D5,A3	RET;---------\\; DESTRAME >;---------/; Trame ventuellement le fond aprs avoir dessin un objet.; in	A4.L	^objet quelconque;	D2.W	mode de dessin (SETDOT/CLRDOT); out	-; mod	D7.WDESTRAME:	PUSHM.L	D3,A3	TEST.B	(A6)+OVUE+3:#BVUFIL-0 ; vue en fil de fer ?	JUMP,BS 90$		; oui => 90$	TEST.L	(A4)+OOFPT	; matrice de trame existe ?	JUMP,EQ 90$		; non => 90$				; oui =>	CALL	OPEWDO		; dessine dans la swdo	CALL	_CCMO		; enlve la souris	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWRASTER	LOAD.L	(A3)+1,#H'10000*1+1 ; source: xx yy	LOAD.L	(A3)+5,(A4)+OOFPT ; source: pppp	LOAD.W	D3,(A4)+OODDIM+2	CALL	DETSCALEP	; D3 <-- plus grand (si n:1)	ADD.W	D3,#2+16-1	AND.B	D3,#B'11110000	SR.W	D3,#3	LOAD.W	(A3)+9,D3	; source: ii	CALL	DESMASKPOS	SWAP.W	D3	LOAD.L	(A3)+11,D3	; destination: xx yy	CLR.L	(A3)+15		; destination: pppp (dans l'cran);	CLR.W	(A3)+19		; destination: ii	LOAD.L	D3,(A4)+OODDIM	CALL	DETSCALEP	; D3 <-- plus grand (si n:1)	SWAP.W	D3	LOAD.L	(A3)+21,D3	; dxx dyy	LOAD.B	(A3)+25,D2	LOAD.W	D3,#26	LIB	?STRING		; efface le fond	CALL	CLOWDO		; fin du dessin dans la swdo90$:	POPM.L	D3,A3	RET;-----------\\; DESMASKPOS >;-----------/; Calcule la position pour le coin sup/gauche des matrices de fond.; in	A4.L	^objet; out	D3.L	position pour les matrices de fond (y;x); mod	D3.L, D7.WDESMASKPOS:	PUSH.L	D4	LOAD.L	D3,(A4)+OODPOS	SUB.W	D3,(A6)+OPPOS+2	SWAP.W	D3	SUB.W	D3,(A6)+OPPOS+0	SWAP.W	D3	CALL	DETSCALEP	; D3 <-- plus grand (si n:1)	LOAD.W	D4,(A6)+OSCALE	JUMP',EQ 90$	JUMP',NS 40$	SUB.W	D3,D4	INC.W	D3	SWAP.W	D3	SUB.W	D3,D4	INC.W	D3	SWAP.W	D3	JUMP'	90$40$:	INC.W	D3	SWAP.W	D3	INC.W	D3	SWAP.W	D390$:	POP.L	D4	RET;------\\; DESTM >;------/; Dessine un objet trait  main leve.; in	A4.L	^objet trait  main leve;	D2.W	mode de dessin (SETDOT/CLRDOT/INVDOT); out	-; mod	D7.WDESTM:	PUSHM.L	D0..D4,A3,A4	CALL	OPEWDO		; dessine dans la swdo	COMP.B	D2,#INVDOT	; dessin "provisoire" ?	JUMP',EQ 20$		; oui => 20$ (pas encore de pinceau)	COMP.B	D2,#INVDOT!TTTDOT	JUMP',EQ 20$	TEST.B	(A6)+OVUE+3:#BVUFIL-0 ; vue en fil de fer ?	JUMP',BS 20$		; oui => 20$	LOAD.W	D1,(A4)+OOPEN	; D1 <-- numro du pinceau	CALL	MATPEN		; dfinit le bon pinceau20$:	LOAD.L	A3,#(A4)+OOTMPTS ; A3 <-- ^premier point	LOAD.W	D0,(A4)+OOTMNBP	; D0 <-- nb de points	SUB.W	D0,#1+130$:	LOAD.L	D3,(A3+)	LOAD.L	D4,(A3)	CALL	CONVP3P4	; D3/D4 <-- dans l'cran	CALL	SEGMENT		; trace un bout de trait  main leve	TSET.L	D2:#BNCTDOT	; D2 <-- plus de rz du traitill	DECJ.W,NMO D0,30$	CALL	CLOWDO		; fin du dessin dans la swdo	POPM.L	D0..D4,A3,A4	RET;------\\; DESSP >;------/; Dessine un objet spline.; in	A4.L	^objet spline;	D2.W	mode de dessin (SETDOT/CLRDOT/INVDOT); out	-; mod	D7.WDESSP:	PUSHM.L	D0..D4,A3,A4	CALL	OPEWDO		; dessine dans la swdo	COMP.B	D2,#INVDOT	; dessin "provisoire" ?	JUMP',EQ 20$		; oui => 20$ (pas encore de pinceau)	COMP.B	D2,#INVDOT!TTTDOT	JUMP',EQ 20$	TEST.B	(A6)+OVUE+3:#BVUFIL-0 ; vue en fil de fer ?	JUMP',BS 20$		; oui => 20$	LOAD.W	D1,(A4)+OOPEN	; D1 <-- numro du pinceau	CALL	MATPEN		; dfinit le bon pinceau20$:	LOAD.L	A3,#(A4)+OOSPPTC ; A3 <-- ^premier point	LOAD.W	D0,(A4)+OOSPNBC	; D0 <-- nb de points	SUB.W	D0,#1+130$:	LOAD.L	D3,(A3+)	LOAD.L	D4,(A3)	CALL	CONVP3P4	; D3/D4 <-- dans l'cran	CALL	SEGMENT		; trace un bout de trait  main leve	TSET.L	D2:#BNCTDOT	; D2 <-- plus de rz du traitill	DECJ.W,NMO D0,30$	CALL	CLOWDO		; fin du dessin dans la swdo	POPM.L	D0..D4,A3,A4	RET;------\\; DESDR >;------/; Dessine un objet droite.; in	A4.L	^objet droite;	D2.W	mode de dessin (SETDOT/CLRDOT/INVDOT); out	-; mod	D7.WDESDR:	PUSHM.L	D1..D4,A4	LOAD.L	D3,(A4)+OODRPOS	; D3 <-- position	LOAD.L	D4,(A4)+OODRDIM	; D4 <-- dimensions	JUMP,EQ 90$	CALL	OPEWDO		; dessine dans la swdo	COMP.B	D2,#INVDOT	; dessin "provisoire" ?	JUMP',EQ 20$		; oui => 20$ (pas encore de pinceau)	COMP.B	D2,#INVDOT!TTTDOT	JUMP',EQ 20$	TEST.B	(A6)+OVUE+3:#BVUFIL-0 ; vue en fil de fer ?	JUMP',BS 20$		; oui => 20$	LOAD.W	D1,(A4)+OOPEN	; D1 <-- numro du pinceau	CALL	MATPEN		; dfinit le bon pinceau20$:	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	D1,(A4)+OODRTYP	; D1 <-- type	CALL	INCLDROITE	; D4 <-- coin oppos	CALL	CONVP3P4	; D3/D4 <-- dans l'cran	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LIB	?DRSEG		; dessine la droite	CALL	CLOWDO		; fin du dessin dans la swdo90$:	POPM.L	D1..D4,A4	RET;------\\; DESLB >;------/; Dessine un objet ligne brise.; in	A4.L	^objet ligne brise;	D2.W	mode de dessin (SETDOT/CLRDOT/INVDOT); out	-; mod	D7.WDESLB:	PUSHM.L	D0..D4,A3,A4	CALL	OPEWDO		; dessine dans la swdo	COMP.B	D2,#INVDOT	; dessin "provisoire" ?	JUMP',EQ 20$		; oui => 20$ (pas encore de pinceau)	COMP.B	D2,#INVDOT!TTTDOT	JUMP',EQ 20$	TEST.B	(A6)+OVUE+3:#BVUFIL-0 ; vue en fil de fer ?	JUMP',BS 20$		; oui => 20$	LOAD.W	D1,(A4)+OOPEN	; D1 <-- numro du pinceau	CALL	MATPEN		; dfinit le bon pinceau20$:	LOAD.L	A3,#(A4)+OOLBPTS ; A3 <-- ^premier point	LOAD.W	D0,(A4)+OOLBNBP	; D0 <-- nb de points	SUB.W	D0,#1+1	JUMP',NS 80$30$:	LOAD.L	D3,(A3+)	LOAD.L	D4,(A3)	CALL	CONVP3P4	; D3/D4 <-- dans l'cran	CALL	SEGMENT		; trace un bout de ligne brise	TSET.L	D2:#BNCTDOT	; D2 <-- plus de rz du traitill	DECJ.W,NMO D0,30$	TEST.B	(A4)+OOLBMOF	JUMP',EQ 80$	LOAD.L	D3,(A3)	LOAD.L	D4,(A4)+OOLBPTS	CALL	CONVP3P4	; D3/D4 <-- dans l'cran	CALL	SEGMENT		; ferme la ligne brise80$:	CALL	CLOWDO		; fin du dessin dans la swdo	POPM.L	D0..D4,A3,A4	RET;------\\; DESFL >;------/; Dessine un objet flche.; in	A4.L	^objet flche;	D2.W	mode de dessin (SETDOT/CLRDOT/INVDOT); out	-; mod	D7.WDESFL:	PUSHM.L	D1..D4,A4	LOAD.L	D3,(A4)+OOFLPOS	; D3 <-- position	LOAD.L	D4,(A4)+OOFLDIM	; D4 <-- dimensions	JUMP,EQ 90$	CALL	OPEWDO		; dessine dans la swdo	COMP.B	D2,#INVDOT	; dessin "provisoire" ?	JUMP',EQ 20$		; oui => 20$ (pas encore de pinceau)	COMP.B	D2,#INVDOT!TTTDOT	JUMP',EQ 20$	TEST.B	(A6)+OVUE+3:#BVUFIL-0 ; vue en fil de fer ?	JUMP',BS 20$		; oui => 20$	LOAD.W	D1,(A4)+OOPEN	; D1 <-- numro du pinceau	CALL	MATPEN		; dfinit le bon pinceau20$:	CALL	CONVP3L4	; D3/D4 <-- dans l'cran	LOAD.L	D1,(A4)+OOFLTYP	; D1 <-- type	CALL	XFLECHE		; dessine la flche	CALL	CLOWDO		; fin du dessin dans la swdo90$:	POPM.L	D1..D4,A4	RET;--------\\; DESRDRA >;--------/; Dessine un objet rectangle droit/arrondi.; in	A4.L	^objet rectangle droit/arrondi;	D2.W	mode de dessin (SETDOT/CLRDOT/INVDOT); out	-; mod	D7.WDESRDRA:	PUSHM.L	D0..D6	LOAD.L	D3,(A4)+OORAPOS	; D3 <-- position	LOAD.L	D4,(A4)+OORADIM	; D4 <-- dimensions	JUMP',EQ 90$	CALL	OPEWDO		; dessine dans la swdo	COMP.B	D2,#INVDOT	; dessin "provisoire" ?	JUMP',EQ 20$		; oui => 20$	COMP.B	D2,#INVDOT!TTTDOT	JUMP',EQ 20$	TEST.B	(A6)+OVUE+3:#BVUFIL-0 ; vue en fil de fer ?	JUMP',BS 20$		; oui => 20$	LOAD.W	D1,(A4)+OOPEN	; D1 <-- numro du pinceau	CALL	MATPEN		; dfinit le bon pinceau20$:	CALL	CONVP3L4	; D3/D4 <-- dans l'cran	LOAD.W	D0,(A4)+OORARAY	; D0 <-- rayon du rectangle	CALL	XRECTANGLE	; dessine le rectangle	CALL	CLOWDO		; fin du dessin dans la swdo90$:	POPM.L	D0..D6	RET;------\\; DESPO >;------/; Dessine un objet polygone.; in	A4.L	^objet polygone;	D2.W	mode de dessin (SETDOT/CLRDOT/INVDOT); out	-; mod	D7.WDESPO:	PUSHM.L	D1..D4	LOAD.L	D3,(A4)+OOPOPOS	; D3 <-- position	LOAD.L	D4,(A4)+OOPODIM	; D4 <-- dimensions	JUMP,EQ 90$	CALL	OPEWDO		; dessine dans la swdo	COMP.B	D2,#INVDOT	; dessin "provisoire" ?	JUMP',EQ 20$		; oui => 20$	COMP.B	D2,#INVDOT!TTTDOT	JUMP',EQ 20$	TEST.B	(A6)+OVUE+3:#BVUFIL-0 ; vue en fil de fer ?	JUMP',BS 20$		; oui => 20$	LOAD.W	D1,(A4)+OOPEN	; D1 <-- numro du pinceau	CALL	MATPEN		; dfinit le bon pinceau20$:	CALL	CONVP3L4	; D3/D4 <-- dans l'cran	LOAD.L	D1,(A4)+OOPOTYP	CALL	XPOLYGONE	; dessine un polygone quelconque	CALL	CLOWDO		; fin du dessin dans la swdo90$:	POPM.L	D1..D4	RET;------\\; DESCE >;------/; Dessine un objet cercle.; in	A4.L	^objet cercle;	D2.W	mode de dessin (SETDOT/CLRDOT/INVDOT); out	-; mod	D7.WDESCE:	PUSHM.L	D1..D4	LOAD.L	D3,(A4)+OOCEPOS	; D3 <-- position	LOAD.L	D4,(A4)+OOCEDIM	; D4 <-- dimensions	JUMP,EQ 90$	CALL	OPEWDO		; dessine dans la swdo	COMP.B	D2,#INVDOT	; dessin "provisoire" ?	JUMP',EQ 20$		; oui => 20$	COMP.B	D2,#INVDOT!TTTDOT	JUMP',EQ 20$	TEST.B	(A6)+OVUE+3:#BVUFIL-0 ; vue en fil de fer ?	JUMP',BS 20$		; oui => 20$	LOAD.W	D1,(A4)+OOPEN	; D1 <-- numro du pinceau	CALL	MATPEN		; dfinit le bon pinceau20$:	CALL	CONVP3L4	; D3/D4 <-- dans l'cran	LOAD.L	D1,(A4)+OOCETYP	CALL	XCERCLE		; dessine un cercle quelconque	CALL	CLOWDO		; fin du dessin dans la swdo90$:	POPM.L	D1..D4	RET;------\\; DESEL >;------/; Dessine un objet ellipse.; in	A4.L	^objet ellipse;	D2.W	mode de dessin (SETDOT/CLRDOT/INVDOT); out	-; mod	D7.WDESEL:	PUSHM.L	D1..D4	LOAD.L	D3,(A4)+OOELPOS	; D3 <-- position	LOAD.L	D4,(A4)+OOELDIM	; D4 <-- dimensions	JUMP,EQ 90$	CALL	OPEWDO		; dessine dans la swdo	COMP.B	D2,#INVDOT	; dessin "provisoire" ?	JUMP',EQ 20$		; oui => 20$	COMP.B	D2,#INVDOT!TTTDOT	JUMP',EQ 20$	TEST.B	(A6)+OVUE+3:#BVUFIL-0 ; vue en fil de fer ?	JUMP',BS 20$		; oui => 20$	LOAD.W	D1,(A4)+OOPEN	; D1 <-- numro du pinceau	CALL	MATPEN		; dfinit le bon pinceau20$:	CALL	CONVP3L4	; D3/D4 <-- dans l'cran	LOAD.L	D1,(A4)+OOELTYP	CALL	XELLIPSE	; dessine une ellipse quelconque	CALL	CLOWDO		; fin du dessin dans la swdo90$:	POPM.L	D1..D4	RET;------\\; DESAR >;------/; Dessine un objet arc.; in	A4.L	^objet arc;	D2.W	mode de dessin (SETDOT/CLRDOT/INVDOT); out	-; mod	D7.WDESAR:	PUSHM.L	D0..D4	LOAD.L	D3,(A4)+OOARPOS	; D3 <-- position	LOAD.L	D4,(A4)+OOARDIM	; D4 <-- dimensions	JUMP,EQ 90$	CALL	OPEWDO		; dessine dans la swdo	COMP.B	D2,#INVDOT	; dessin "provisoire" ?	JUMP',EQ 20$		; oui => 20$	COMP.B	D2,#INVDOT!TTTDOT	JUMP',EQ 20$	TEST.B	(A6)+OVUE+3:#BVUFIL-0 ; vue en fil de fer ?	JUMP',BS 20$		; oui => 20$	LOAD.W	D1,(A4)+OOPEN	; D1 <-- numro du pinceau	CALL	MATPEN		; dfinit le bon pinceau20$:	CALL	CONVP3L4	; D3/D4 <-- dans l'cran	LOAD.W	D0,(A4)+OOARANG	LOAD.L	D1,(A4)+OOARTYP	CALL	XARC		; dessine un arc quelconque	CALL	CLOWDO		; fin du dessin dans la swdo90$:	POPM.L	D0..D4	RET;------\\; DESIM >;------/; Dessine un objet image.; in	A4.L	^objet image;	D2.W	mode de dessin (SETDOT/CLRDOT/INVDOT); out	-; mod	D7.WDESIM:	PUSHM.L	D0..D4,A2,A3	LOAD.L	D3,(A4)+OOIMPOS	; D3 <-- position	LOAD.L	D4,(A4)+OOIMDIM	; D4 <-- dimensions	JUMP,EQ 90$	CALL	OPEWDO		; dessine dans la swdo	ADD.W	D4,D3	DEC.W	D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	DEC.W	D4	SWAP.W	D3	SWAP.W	D4	CALL	CONVP3P4	; D3/D4 <-- dans l'cran	COMP.B	D2,#INVDOT!TTTDOT	JUMP',NE 30$20$:	CLR.W	D0		; D0 <-- rayon	CALL	XRECTANGLE	; dessine juste le pourtour	JUMP	80$30$:	COMP.W	D2,#INVDOT!2^BMDPOI	JUMP',NE 32$	LOAD.L	D1,(A4)+OOIMDIM	COMP.L	D1,(A4)+OOIMDIL	; dimensions changes ?	JUMP,NE 20$		; oui => 20$32$:	CALL	_CCMO		; enlve la souris	SUB.W	D4,D3	JUMP',NC 41$	NEG.W	D4	SUB.W	D3,D441$:	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	JUMP',NC 42$	NEG.W	D4	SUB.W	D3,D442$:;	SWAP.W	D3;	SWAP.W	D4	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWRASTER	CLR.L	(A3)+1	LOAD.L	A2,#(A4)+OOIMMAT	LOAD.L	(A3)+5,A2	LOAD.W	(A3)+9,(A4)+OOIMIIX	LOAD.L	(A3)+11,D3	CLR.L	(A3)+15	CLR.W	(A3)+19	LOAD.L	(A3)+21,D4	LOAD.B	(A3)+25,D2	TEST.L	(A4)+OOIMPMZ	JUMP',EQ 44$	LOAD.L	(A3)+5,(A4)+OOIMPMZ	LOAD.W	(A3)+9,(A4)+OOIMZIX44$:	LOAD.W	D3,#26	LIB	?STRING		; affiche l'image80$:	CALL	CLOWDO		; fin du dessin dans la swdo90$:	POPM.L	D0..D4,A2,A3	RET;------\\; DESTX >;------/; Dessine un objet pav de texte.; in	A4.L	^objet texte;	D2.W	mode de dessin (SETDOT/CLRDOT/INVDOT); out	-; mod	D7.WDESTX:	PUSHM.L	D0..D4,A5	LOAD.L	D3,(A4)+OOTXPOS	; D3 <-- position	LOAD.L	D4,(A4)+OOTXDIM	; D4 <-- dimensions	JUMP,EQ 90$	CALL	OPEWDO		; dessine dans la swdo	COMP.B	D2,#INVDOT!TTTDOT	JUMP',EQ 20$	COMP.W	D2,#INVDOT!2^BMDPOI	JUMP',EQ 20$	COMP.W	D2,#INVDOT!2^BMDCRE	JUMP',NE 30$20$:	CALL	DESTXRECT	; dessine juste le pourtour	JUMP'	80$30$:	COMP.B	D2,#INVDOT	JUMP',NE 40$	CALL	DESTXRECT	; dessine aussi le pourtour40$:	CALL	_CCMO		; enlve la souris	LOAD.L	A5,A4		; A5 <-- ^objet texte	CALL	EDAFTEXT80$:	CALL	CLOWDO		; fin du dessin dans la swdo90$:	POPM.L	D0..D4,A5	RET;----------\\; DESTXRECT >;----------/; Dessine le rectangle englobant un pav de texte.; in	D3.L	position;	D4.L	;	D2.B	mode; out	-; mod	D7.WDESTXRECT:	PUSHM.L	D0..D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	CALL	CONVP3P4	; D3/D4 <-- dans l'cran	DEC.W	D3	INC.W	D4	SWAP.W	D3	SWAP.W	D4	DEC.W	D3	INC.W	D4	SWAP.W	D3	SWAP.W	D4	COMP.B	D2,#INVDOT	JUMP',NE 30$	LIB	?AFTIM	.B	MAPTT	.B	B'01010101	; map	.B	1		; chelle	.B	0	.EVEN	TSET.L	D2:#BTTTDOT30$:	CLR.W	D0		; D0 <-- rayon	CALL	XRECTANGLE	; dessine juste le pourtour	POPM.L	D0..D4	RET;----------\\; CLIPOBJET >;==========/; Regarde si un objet apparat, mme partiellement, dans une fentre; rectangulaire donne dans D3/D4.; in	A4.L	^objet quelconque; out	D7.W	EQ => reconvrement;		NE => aucun recouvrement; mod	D7.WCLIPOBJET:	PUSHM.L	D2..D4	LOAD.L	D3,(A6)+OPPOS	LOAD.L	D4,(A6)+OSDIM	LOAD.W	D7,#ERDIOUT	; D7 <-- pas de recouvrement	ADD.W	D3,D4	LOAD.W	D2,(A4)+OODPOS+2	COMP.W	D2,D3	JUMP',GE 90$	SUB.W	D3,D4	ADD.W	D2,(A4)+OODDIM+2	COMP.W	D2,D3	JUMP',LT 90$	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4	LOAD.W	D2,(A4)+OODPOS+0	COMP.W	D2,D3	JUMP',GE 90$	SUB.W	D3,D4	ADD.W	D2,(A4)+OODDIM+0	COMP.W	D2,D3	JUMP',LT 90$	CLR.W	D7		; D7 <-- recouvrement90$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; CONVP3L4 >;=========/; Converti deux points pour pouvoir dessiner dans l'cran.; in	D3.L	P(y;x)   [pi];	D4.L	D(dy;dx) [pi]; out	D3.L	P3(y;x)  [pe];	D4.L	P4(y;x)  [pe]; mod	D3.L, D4.L, D7.WCONVP3L4:	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4;	JUMP	CONVP3P4;---------\\; CONVP3P4 >;=========/; Converti deux points pour pouvoir dessiner dans l'cran.; in	D3.L	P3(y;x) [pi];	D4.L	P4(y;x) [pi]; out	D3.L	P3(y;x) [pe];	D4.L	P4(y;x) [pe]; mod	D3.L, D4.L, D7.WCONVP3P4:	SUB.W	D3,(A6)+OPPOS+2	SUB.W	D4,(A6)+OPPOS+2	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,(A6)+OPPOS+0	SUB.W	D4,(A6)+OPPOS+0	SWAP.W	D3	SWAP.W	D4	CALL	DETSCALEP	; D3 <-- plus grand (si n:1)	EX.L	D3,D4	CALL	DETSCALEP	; D4 <-- plus grand (si n:1)	EX.L	D4,D3	RET	.END