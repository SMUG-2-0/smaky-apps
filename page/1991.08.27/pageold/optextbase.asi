	.SBTTL	OPTEXTBASE.ASI;----------\\; EDGETPOSZ >;==========/; Cherche la position dans le texte en fonction de la; position de la souris, pour slectionner une zone.; Ne place pas le curseur !; in	A1.L	^objet texte;	D4.L	position de la souris (y;x); out	D4.L	position dans le buffer;	D7.W	erreur; mod	D4.L, D7.WEDGETPOSZ:	LOAD.L	(A5)+OTXPMO,D4	LOAD.L	(A5)+OTXPMB,#-1	LOAD.W	(A5)+OTXOP,#OPPOSZ	CALL	EDAFTEXT	; OTXPMB <-- position dans le buffer	CLR.W	(A5)+OTXOP	LOAD.L	D4,(A5)+OTXPMB	; D4 <-- position dans le buffer	COMP.L	D4,#-1		; position trouve ?	JUMP',NE 90$		; oui => 90$	LOAD.W	D7,#1		; D7 <-- erreur90$:	TEST.W	D7		; retour EQ/NE	RET;---------\\; EDGETPOS >;=========/; Cherche la position dans le texte en fonction de la; position de la souris.; in	A1.L	^objet texte;	D4.L	position de la souris (y;x); out	D4.L	position dans le buffer;	D7.W	erreur; mod	D4.L, D7.WEDGETPOS:	TEST.L	(A1)+OOBA	; pav de texte tourn ?	JUMP',EQ NOROT$		; non => NOROT$	PUSH.L	D1	PUSH.L	(A1)+OOBA	LOAD.W	D1,(A4)+OOBA+0	; D1 <-- angle de rotation	CALL	INVANGLE	; D1 <-- angle inverse	LOAD.W	(A1)+OOBA+0,D1	CALL	EDPOSROT	; D4 <-- nouvelle position (y;x)	POP.L	(A1)+OOBA	POP.L	D1NOROT$:	LOAD.L	(A5)+OTXPMO,D4	LOAD.L	(A5)+OTXPMB,#-1	LOAD.W	(A5)+OTXOP,#OPPOS	CALL	EDAFTEXT	; OTXPMB <-- position dans le buffer	CLR.W	(A5)+OTXOP	LOAD.L	D4,(A5)+OTXPMB	; D4 <-- position dans le buffer	COMP.L	D4,#-1		; position trouve ?	JUMP',NE 90$		; oui => 90$	LOAD.W	D7,#1		; D7 <-- erreur90$:	TEST.W	D7		; retour EQ/NE	RET;----------\\; EDINVZONE >;==========/; Inverse une zone.; in	A1.L	^objet texte;	D4.L	dbut zone;	D5.L	fin zone; out	-; mod	D7.WEDINVZONE:	PUSHM.L	D1..D5	COMP.L	D4,D5	JUMP',EQ 90$	JUMP',LO 20$	EX.L	D4,D5		; D4 toujours avant D5 !20$:	LOAD.L	(A5)+OTXZOD,D4	LOAD.L	(A5)+OTXZOF,D5	LOAD.W	(A5)+OTXZOP+0,#H'7FFF	CLR.L	(A5)+OTXZOL	LOAD.W	(A5)+OTXOP,#OPZONE	CALL	EDAFTEXT	; inverse une zone	CLR.W	(A5)+OTXOP	LOAD.W	D1,#-1	CALL	EDIZONECAR	; inverse la dernire zone90$:	POPM.L	D1..D5	RET;-----------\\; EDCALCBBOX >;===========/; Calcule la "bounding box" de tout le texte.; in	A1.L	^objet texte; out	D3.L	coin sup/gauche (y;x);	D4.L	coin inf/droite (y;x); mod	D3.L, D4.L, D7.WEDCALCBBOX:	PUSHM.L	D1,D2	LOAD.L	(A5)+OTXBB1,#H'7FFF7FFF	LOAD.L	(A5)+OTXBB2,#H'80008000	LOAD.W	(A5)+OTXOP,#OPBBOX	CALL	EDAFTEXT	; calcule la "bbox"	CLR.W	(A5)+OTXOP	LOAD.L	D1,(A5)+OTXPOS	LOAD.L	D2,(A5)+OTXDIM	ADD.W	D2,D1	SWAP.W	D1	SWAP.W	D2	ADD.W	D2,D1	SWAP.W	D1	SWAP.W	D2	LOAD.L	D3,(A5)+OTXBB1	LOAD.L	D4,(A5)+OTXBB2	CALL	RECTOR		; D3/D4 <-- rectangle "bbox"	POPM.L	D1,D2	RET;---------\\; EDAFTEXT >;=========/; Affiche tout un pav de texte.; in	A1.L	^objet texte;	D2.L	mode de dessin;	D1.L	mode de la vue; out	-; mod	D7.WEDAFTEXT:	PUSHM.L	D1..D4,A4	LOAD.L	(A5)+OTXMOD,D2	; OTXMOD <-- mode	LOAD.L	(A5)+OTXVUE,D1	; OTXVUE <-- vue	LOAD.L	D3,(A1)+OOBP1	LOAD.L	D4,(A1)+OOBP3	SUB.W	D4,D3	JUMP',NC OKX$	NEG.W	D4	SUB.W	D3,D4OKX$:	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	JUMP',NC OKY$	NEG.W	D4	SUB.W	D3,D4OKY$:	SWAP.W	D3	SWAP.W	D4	COMP.L	D3,(A1)+OOBP1	JUMP',EQ OKP$	LOAD.W	D1,(A1)+OOBA+0	JUMP',EQ OKP$	LOAD.L	A4,A1		; A4 <-- ^objet	EX.L	D4,D3	CALL	GETPX	EX.L	D3,D4OKP$:	LOAD.L	(A5)+OTXPOS,D3	LOAD.L	(A5)+OTXDIM,D4	CALL	EDINIDIM	; init pour EDGETDIM	LOAD.L	(A5)+OTXCPB,(A1)+OOBPOC	CALL	TXPSAUVE	; D4 <-- no de la position	PUSH.W	D4		; stack <-- no position initiale	COMP.W	(A5)+OTXOP,#OPPOS	JUMP,EQ POS$	COMP.W	(A5)+OTXOP,#OPPOSZ	JUMP,EQ POSZ$	COMP.W	(A5)+OTXOP,#OPZONE	JUMP,EQ ZONE$	COMP.W	(A5)+OTXOP,#OPBBOX	JUMP,EQ BBOX$	TEST.L	(A1)+OOBPTL	; table OTLxxx existe ?	JUMP,EQ ALL$		; non => ALL$	CLR.W	D4	TEST.L	(A1)+OOBNCI	JUMP',EQ NCI$	INC.W	D4NCI$:	TEST.L	(A1)+OOBNCK	JUMP',EQ NCK$	INC.W	D4NCK$:	TEST.L	(A1)+OOBNCL	JUMP',EQ NCL$	INC.W	D4NCL$:	TEST.L	(A1)+OOBNCM	JUMP',EQ NCM$	INC.W	D4NCM$:	TEST.W	D4		; rien de modifi ?	JUMP,EQ QUICK$		; oui => QUICK$	COMP.W	D4,#1		; plus d'un paramtre modifi ?	JUMP,NE ALL$		; oui => ALL$	TEST.L	(A1)+OOBNCI	JUMP,NE INS$	TEST.L	(A1)+OOBNCK	JUMP,NE KILAR$	TEST.L	(A1)+OOBNCL	JUMP,NE KILAV$	TEST.L	(A1)+OOBNCM	JUMP,NE MOVE$	JUMP	ALL$INS$:				; insertion =>	TEST.L	(A1)+OOBA	; pav de texte tourn ?	JUMP,NE ALL$		; oui => ALL$	LOAD.L	D4,(A1)+OOBNCI	CALL	EDAFTEXTIFAV	; seulement dans mme ligne ?	JUMP',NE INS2$		; non => INS2$	CALL	EDAFONE		; affiche juste une ligne	JUMP'	MOVE$INS2$:	CALL	EDAFREST	; affiche les lignes restantes	JUMP	MOVE$KILAR$:				; destruction en arrire =>	JUMP	ALL$KILAV$:				; destruction en avant =>	JUMP	ALL$;;?	LOAD.L	D4,(A1)+OOBNCL;;?	NEG.L	D4;;?	CALL	EDAFTEXTIFAV	; seulement dans mme ligne ?;;?	JUMP',NE KILAV2$	; non => KILAV2$;;?	CALL	EDAFONE		; affiche juste une ligne;;?	JUMP'	MOVE$;;?KILAV2$:;;?	CALL	EDAFREST	; affiche les lignes restantes;;?	JUMP'	MOVE$QUICK$:	CALL	EDAFTEXTIDEM	; affiche rapidement	JUMP'	MOVE$ALL$:	CALL	EDAFTEXTALL	; affiche tout	JUMP'	MOVE$POS$:				; positionnement =>	CALL	EDAFTEXTPOS	CALL	EDAFTEXTCURS	; place le curseur	JUMP'	END$POSZ$:				; positionnement =>	CALL	EDAFTEXTPOS	JUMP'	END$ZONE$:				; inversion d'une zone =>	CALL	EDAFTEXTINZ	JUMP'	END$BBOX$:				; calcule la "bbox" =>	CALL	EDAFTEXTALL	JUMP'	END$MOVE$:	CALL	EDAFTEXTCURS	; place le curseur	CLR.L	(A1)+OOBNCI	CLR.L	(A1)+OOBNCK	CLR.L	(A1)+OOBNCL	CLR.L	(A1)+OOBNCMEND$:	POP.W	D4		; D4 <-- no position initiale	CALL	TXPPREND	; remet le curseur o il tait	POPM.L	D1..D4,A4	RET;---------\\; EDAFCURS >;=========/; Affiche le curseur en mode inverse.; in	A1.L	^objet texte; out	-; mod	D7.WEDAFCURS:	PUSHM.L	D2..D4	LOAD.L	D3,(A5)+OTXCP1	; D3 <-- P1 curseur	COMP.L	D3,#-1	JUMP',EQ EXIT$	LOAD.L	D4,(A5)+OTXCP2	; D4 <-- P2 curseur	LOAD.W	D2,#INVDOT	LOAD.W	D7,#DR_LINEM	PAGE_	DRAW		; dessine une barre verticaleEXIT$:	POPM.L	D2..D4	RET;-------------\\; EDAFTEXTIFAV >;-------------/; Aprs avoir insr (+) ou dtruit (-) des caractres en AVANT,; regarde si la modification n'affecte que la ligne o est le curseur.; En sortie, on est directement positionn au dbut de la ligne;  afficher !; in	A1.L	^objet texte;	D4.L	nb de caractres insrs/dtruits en avant (+/-); out	D2.L	position (y;x);	A4.L	^dans table OTLxxx;	D7.W	ok => que la ligne concerne; mod	D2.L, D7.W, A4.LEDAFTEXTIFAV:	PUSHM.L	D0,D1,D3..D6	LOAD.L	D1,D4		; D1 <-- +/- nb	LOAD.L	D4,(A1)+OOBPOC	; D4 <-- position actuelle	SUB.L	D4,D1		; D4 <-- ancienne position	LOAD.L	A4,(A1)+OOBPTL	; A4 <-- ^table OTLxxx	CLR.L	D2		; D2 <-- position20$:	COMP.L	D4,(A4)+OTLPOS	JUMP',LO 24$	LOAD.W	D3,(A4)+OTLIL	JUMP',EQ 22$	ADD.W	D2,D3		; D2 <-- position en Y suivante	LOAD.L	A4,#(A4)+LTL	JUMP	20$22$:	COMP.L	D4,(A4)+OTLPOS	; est-on tout  la fin ?	JUMP,NE 70$		; non => 70$24$:	LOAD.L	A4,#(A4)-LTL	SUB.W	D2,(A4)+OTLIL	SWAP.W	D2	LOAD.B	(A5)+OTXFLI,(A4)+OTLFLI	LOAD.L	D4,(A4)+OTLPOS	CALL	TXQPOSITIONNE	; va au dbut de la ligne	CALL	EDCOUPELINE	; D3/D4/D5/D6 <-- paramtres	AND.L	D3,#H'FFFF	; D3 <-- nb car dans nouvelle ligne	LOAD.L	D0,(A4)+LTL+OTLPOS	SUB.L	D0,(A4)+OTLPOS	; D0 <-- nb car dans ancienne ligne	ADD.L	D0,D1	COMP.L	D0,D3	JUMP',NE 80$	CALL	EDMAXH1H2	; OTXMH1/H2 <-- max h1/h2	LOAD.W	D0,(A5)+OTXMIL	COMP.W	D0,(A4)+OTLIL	JUMP',NE 80$	LOAD.W	D0,(A5)+OTXMBL	COMP.W	D0,(A4)+OTLBL	JUMP',NE 80$	LOAD.W	(A4)+OTLNC,D3	LOAD.W	(A4)+OTLLX,D4	LOAD.W	(A4)+OTLNS,D5	LOAD.L	(A4)+OTLLC,D6	PUSH.L	A450$:	LOAD.L	A4,#(A4)+LTL	ADD.L	(A4)+OTLPOS,D1	; ajuste la fin de la table	TEST.W	(A4)+OTLIL	JUMP,NE 50$	POP.L	A4	CLR.W	D7		; D7 <-- dans mme ligne	JUMP'	90$70$:	LOAD.L	A4,(A1)+OOBPTL	; A4 <-- ^table OTLxxx	CLR.L	D2	CLR.L	D4	CALL	TXQPOSITIONNE	; va au dbut du texte	SET.B	(A5)+OTXFLI80$:	LOAD.W	D7,#1		; D7 <-- toutes les lignes restantes90$:	POPM.L	D0,D1,D3..D6	TEST.W	D7		; retour EQ/NE	RET;------------\\; EDAFTEXTPOS >;------------/; Trouve la position dans le buffer en fonction de la position; de la souris.; in	(A5)+OTXPMO.L	position de la souris (y;x); out	(A5)+OTXPMB.L	position dans le buffer; mod	D7.WEDAFTEXTPOS:	PUSHM.L	D0..D4,A4	TEST.L	(A1)+OOBPTL	JUMP,EQ 90$	LOAD.W	D3,(A1)+OOBICA	ADD.W	(A5)+OTXDIM+2,D3	LOAD.L	A4,(A1)+OOBPTL	; A4 <-- ^table OTLxxx	CLR.L	D2		; D2 <-- position20$:	TEST.W	(A4)+OTLIL	JUMP,EQ 90$	LOAD.W	D1,D2	ADD.W	D1,(A5)+OTXPOS+0	LOAD.W	D0,(A5)+OTXPMO+0 ; D0 <-- position de la souris (y)	COMP.W	D0,D1		; trop en haut ?	JUMP',LT 26$	ADD.W	D1,(A4)+OTLIL	COMP.W	D0,D1		; trop en bas ?	JUMP',LT 30$26$:	ADD.W	D2,(A4)+OTLIL	; D2 <-- position en Y suivante	LOAD.L	A4,#(A4)+LTL	JUMP	20$30$:	SWAP.W	D2	LOAD.B	(A5)+OTXFLI,(A4)+OTLFLI	LOAD.W	(A5)+OTXMH1,(A4)+OTLH1	LOAD.W	(A5)+OTXMH2,(A4)+OTLH2	LOAD.W	(A5)+OTXMBL,(A4)+OTLBL	LOAD.W	(A5)+OTXMIL,(A4)+OTLIL	LOAD.W	(A5)+OTXMNC,(A4)+OTLNC	LOAD.W	(A5)+OTXMLX,(A4)+OTLLX	LOAD.W	(A5)+OTXMNS,(A4)+OTLNS	LOAD.L	(A5)+OTXMLC,(A4)+OTLLC	LOAD.L	D4,(A4)+OTLPOS	CALL	TXQPOSITIONNE	; va au dbut de la ligne	CALL	EDAFLINEQ	; positionne le curseur	COMP.L	(A5)+OTXPMB,#-1	; position trouve ?	JUMP',NE 90$		; oui => 90$	LOAD.L	D4,(A4)+OTLPOS	; D4 <-- position dbut de la ligne	LOAD.W	D3,(A5)+OTXPMO+2	COMP.W	D3,(A5)+OTXPOS+2 ; souris  gauche du pav ?	JUMP',LE 80$		; oui => 80$	LOAD.L	D4,(A1)+OOBPOC	; D4 <-- position dbut de la ligne suivante	JUMP',EQ 80$	COMP.W	(A5)+OTXOP,#OPPOS	JUMP',NE 80$	DEC.L	D4		; D4 <-- position fin de la ligne80$:	LOAD.L	(A5)+OTXPMB,D490$:	POPM.L	D0..D4,A4	RET;------------\\; EDAFTEXTINZ >;------------/; Inverse une zone (mise en vidence).; in	(A5)+OTXZOD.L	dbut zone;	(A5)+OTXZOF.L	fin zone; out	-; mod	D7.WEDAFTEXTINZ:	PUSHM.L	D0..D4,A4	TEST.L	(A1)+OOBPTL	JUMP,EQ 90$	LOAD.L	A4,(A1)+OOBPTL	; A4 <-- ^table OTLxxx	LOAD.L	D0,(A5)+OTXZOD	LOAD.L	D1,(A5)+OTXZOF	CLR.L	D2		; D2 <-- position20$:	TEST.W	(A4)+OTLIL	JUMP,EQ 90$	COMP.L	D0,(A4)+LTL+OTLPOS	JUMP',HI 40$	COMP.L	D1,(A4)+OTLPOS	JUMP',LO 40$	LOAD.B	(A5)+OTXFLI,(A4)+OTLFLI	LOAD.W	(A5)+OTXMH1,(A4)+OTLH1	LOAD.W	(A5)+OTXMH2,(A4)+OTLH2	LOAD.W	(A5)+OTXMBL,(A4)+OTLBL	LOAD.W	(A5)+OTXMIL,(A4)+OTLIL	LOAD.W	(A5)+OTXMNC,(A4)+OTLNC	LOAD.W	(A5)+OTXMLX,(A4)+OTLLX	LOAD.W	(A5)+OTXMNS,(A4)+OTLNS	LOAD.L	(A5)+OTXMLC,(A4)+OTLLC	LOAD.L	D4,(A4)+OTLPOS	CALL	TXQPOSITIONNE	; va au dbut de la ligne	PUSH.L	D2	SWAP.W	D2	CALL	EDAFLINEQ	; inverse une partie de la zone	POP.L	D240$:	ADD.W	D2,(A4)+OTLIL	; D2 <-- position en Y suivante	LOAD.L	A4,#(A4)+LTL	JUMP	20$90$:	POPM.L	D0..D4,A4	RET;-------------\\; EDAFTEXTCURS >;-------------/; Place simplement le curseur dans un texte qui n'a pas chang.; in	A1.L	^objet texte; out	-; mod	D7.WEDAFTEXTCURS:	PUSHM.L	D2..D4,A4	LOAD.L	(A5)+OTXCP1,#-1	TEST.L	(A1)+OOBPTL	JUMP,EQ 90$	LOAD.W	D3,(A1)+OOBICA	ADD.W	(A5)+OTXDIM+2,D3	LOAD.L	A4,(A1)+OOBPTL	; A4 <-- ^table OTLxxx	LOAD.L	D4,(A5)+OTXCPB	CLR.L	D2		; D2 <-- position20$:	COMP.L	D4,(A4)+OTLPOS	JUMP',LO 24$	LOAD.W	D3,(A4)+OTLIL	JUMP',EQ 24$	ADD.W	D2,D3		; D2 <-- position en Y suivante	LOAD.L	A4,#(A4)+LTL	JUMP	20$24$:	LOAD.L	A4,#(A4)-LTL	SUB.W	D2,(A4)+OTLIL	SWAP.W	D2	LOAD.B	(A5)+OTXFLI,(A4)+OTLFLI	LOAD.W	(A5)+OTXMH1,(A4)+OTLH1	LOAD.W	(A5)+OTXMH2,(A4)+OTLH2	LOAD.W	(A5)+OTXMBL,(A4)+OTLBL	LOAD.W	(A5)+OTXMIL,(A4)+OTLIL	LOAD.W	(A5)+OTXMNC,(A4)+OTLNC	LOAD.W	(A5)+OTXMLX,(A4)+OTLLX	LOAD.W	(A5)+OTXMNS,(A4)+OTLNS	LOAD.L	(A5)+OTXMLC,(A4)+OTLLC	LOAD.L	D4,(A4)+OTLPOS	CALL	TXQPOSITIONNE	; va au dbut de la ligne	LOAD.W	(A5)+OTXOP,#OPCURS	CALL	EDAFLINEQ	; positionne le curseur	CLR.W	(A5)+OTXOP	COMP.L	(A5)+OTXCP1,#-1	; position du curseur trouve ?	JUMP,NE 90$		; oui => 90$	COMP.B	D3,#CR	JUMP',EQ 50$	SWAP.W	D2	SUB.W	D2,(A5)+OTXMIL	; Y <-- ligne prcdente	SWAP.W	D2	JUMP'	60$50$:	CLR.W	D2		; X <-- au dbut de la ligne	SET.B	(A5)+OTXFLI60$:	TEST.B	(A5)+OTXFLI	; premire ligne ?	JUMP',F 62$		; non => 62$	ADD.W	D2,(A1)+OOBRMR62$:	LOAD.L	D4,D2	ADD.W	D4,(A5)+OTXPOS+2	SWAP.W	D4	ADD.W	D4,(A5)+OTXPOS+0	SWAP.W	D4	LOAD.L	D2,D4	CALL	EDPOSROT	; D4 <-- P'(y;x) v. tourn	LOAD.L	(A5)+OTXCP1,D4	; OTXCP1 <-- position du curseur	LOAD.L	D4,D2	SWAP.W	D4	ADD.W	D4,(A5)+OTXMIL	SWAP.W	D4	CALL	EDPOSROT	; D4 <-- P'(y;x) v. tourn	LOAD.L	(A5)+OTXCP2,D4	; OTXCP2 <-- position du curseur90$:	POPM.L	D2..D4,A4	RET;-------------\\; EDAFTEXTIDEM >;-------------/; Affiche tout un pav de texte non modifi.; in	A1.L	^objet texte; out	-; mod	D7.WEDAFTEXTIDEM:	TEST.L	(A1)+OOBPTL	; table des lignes existe ?	JUMP,EQ EDAFTEXTALL	; non => EDAFTEXTALL	PUSHM.L	D2..D4,A4	LOAD.L	A4,(A1)+OOBPTL	; A4 <-- ^dans OTLxxx	CLR.L	D2		; D2 <-- tout en haut	LOAD.W	D3,(A1)+OOBICA	ADD.W	(A5)+OTXDIM+2,D320$:	TEST.W	(A4)+OTLIL	JUMP,EQ 90$	TEST.L	(A1)+OOBA	; pav de texte tourn ?	JUMP',NE 30$		; oui => 30$	LOAD.W	D4,D2	ADD.W	D4,(A4)+OTLBL	SUB.W	D4,(A4)+OTLH1	ADD.W	D4,(A5)+OTXPOS+0	SWAP.W	D4	LOAD.W	D7,#MA_OBJDRAW	PAGE_	MATH		; D4 <-- position [scr]	SWAP.W	D4	COMP.W	D4,(A0)+ODFFDY	; dpasse le bas de la swdo de dessin ?	JUMP',GE 50$		; oui => 50$	LOAD.W	D4,D2	ADD.W	D4,(A4)+OTLBL	ADD.W	D4,(A4)+OTLH2	ADD.W	D4,(A5)+OTXPOS+0	SWAP.W	D4	LOAD.W	D7,#MA_OBJDRAW	PAGE_	MATH		; D4 <-- position [scr]	SWAP.W	D4	TEST.W	D4		; dpasse le haut de la swdo de dessin ?	JUMP',NS 50$		; oui => 50$30$:	LOAD.L	D4,(A4)+OTLPOS	CALL	TXQPOSITIONNE	; va au dbut de la ligne	LOAD.B	(A5)+OTXFLI,(A4)+OTLFLI	LOAD.W	(A5)+OTXMH1,(A4)+OTLH1	LOAD.W	(A5)+OTXMH2,(A4)+OTLH2	LOAD.W	(A5)+OTXMBL,(A4)+OTLBL	LOAD.W	(A5)+OTXMIL,(A4)+OTLIL	LOAD.W	(A5)+OTXMNC,(A4)+OTLNC	LOAD.W	(A5)+OTXMLX,(A4)+OTLLX	LOAD.W	(A5)+OTXMNS,(A4)+OTLNS	LOAD.L	(A5)+OTXMLC,(A4)+OTLLC	PUSH.L	D2	SWAP.W	D2	CALL	EDAFLINEQ	; affiche une ligne	POP.L	D2	TEST.W	D7	JUMP',NE 90$		; si dbordement => 90$50$:	ADD.W	D2,(A4)+OTLIL	; D2 <-- position suivante	LOAD.L	A4,#(A4)+LTL	; A4 <-- ^suivant dans OTLxxx	JUMP	20$90$:	POPM.L	D2..D4,A4	RET;------------\\; EDAFTEXTALL >;------------/; Affiche compltement tout un pav de texte.; in	A1.L	^objet texte; out	-; mod	D7.WEDAFTEXTALL:	PUSHM.L	D1..D4,A4	CALL	EDNEWTL		; rserve un nouveau buffer OTLxxx	JUMP,NE 90$	CLR.L	D4	CALL	TXQPOSITIONNE	; revient au dbut	LOAD.L	A4,(A1)+OOBPTL	; A4 <-- ^dans OTLxxx	CLR.L	D2		; D2 <-- tout en haut	CLR.W	D1		; D1 <-- toutes les lignes	SET.B	(A5)+OTXFLI	; premire ligne	LOAD.W	D3,(A1)+OOBICA	ADD.W	(A5)+OTXDIM+2,D3	JUMP'	30$20$:	SET.B	(A5)+OTXFLI	; premire ligne	COMP.B	D3,#CR	JUMP',EQ 30$	COMP.B	D3,#EOP	JUMP',EQ 30$	CLR.B	(A5)+OTXFLI	; ligne(s) suivante(s)30$:	LOAD.L	(A4)+OTLPOS,(A1)+OOBPOC	LOAD.B	(A4)+OTLFLI,(A5)+OTXFLI	CLR.W	(A5)+OTXMIL	; faudra refaire EDMAXH1H2	CALL	EDAFLINE	; affiche une ligne	JUMP',NE 60$		; si dbordement => 60$	LOAD.W	(A4)+OTLH1,(A5)+OTXMH1	LOAD.W	(A4)+OTLH2,(A5)+OTXMH2	LOAD.W	(A4)+OTLBL,(A5)+OTXMBL	LOAD.W	(A4)+OTLIL,(A5)+OTXMIL	LOAD.W	(A4)+OTLNC,(A5)+OTXMNC	LOAD.W	(A4)+OTLLX,(A5)+OTXMLX	LOAD.W	(A4)+OTLNS,(A5)+OTXMNS	LOAD.L	(A4)+OTLLC,(A5)+OTXMLC	LOAD.L	A4,#(A4)+LTL	; A4 <-- ^suivant dans OTLxxx	LOAD.L	(A4)+OTLPOS,(A1)+OOBPOC	COMP.B	D3,#EOP	JUMP',EQ 60$	LOAD.L	D4,(A1)+OOBPOC	COMP.L	D4,(A1)+OOBNBC	; fin du pav de texte ?	JUMP',HS 60$		; oui => 60$	DEC.W	D1		; encore une ligne ?	JUMP,NE 20$		; oui => 20$60$:	CLR.W	(A4)+OTLIL	LOAD.W	D7,#DR_BMUPDALL	PAGE_	DRAW		; indique qu'il faut tout mettre  jour90$:	POPM.L	D1..D4,A4	RET;--------\\; EDNEWTL >;--------/; Rserve de la mmoire pour un nouveau buffer OTLxxx.; in	A1.L	^objet texte; out	-; mod	D7.WEDNEWTL:	PUSHM.L	D1..D4,A3,A4; Libre ventuellement l'ancien buffer.	TEST.L	(A1)+OOBPTL	JUMP',EQ 20$	LOAD.L	A4,(A1)+OOBPTL	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire OTLxxx	CLR.L	(A1)+OOBPTL; Cherche l'interligne minimal dans D2.W.20$:	CLR.W	D1	LOAD.W	D2,#-122$:	LOAD.W	D3,D1	CALL	EDGETDIM	; A3/A4/D3/D4 <-- ^gencar/^chasses/h1;h2/interl	JUMP',NE 28$	LOAD.W	D4,(A4)+((256*2)+'E)*2 ; D4 <--   h1 de "E"	ADD.W	D4,(A4)+((256*4)+'p)*2 ; D4 <-- + h2 de "p"	COMP.W	D4,(A1)+OOBILM	JUMP',HS 24$	LOAD.W	D4,(A1)+OOBILM24$:	ADD.W	D4,(A1)+OOBILA	; D4 <-- interligne de ce gencar	JUMP',NC 25$	CLR.W	D425$:	TEST.W	(A1)+OOBILV	; y a-t-il une hauteur des lignes vides ?	JUMP',LE 26$		; non => 26$	COMP.W	D4,(A1)+OOBILV	JUMP',LS 26$	LOAD.W	D4,(A1)+OOBILV26$:	COMP.W	D2,D4	JUMP',LS 28$	LOAD.W	D2,D4		; D2 <-- h1+h2 le plus petit28$:	INC.W	D1	COMP.W	D1,#16	JUMP,LO 22$	COMP.W	D2,#-1	JUMP',NE 40$	LOAD.W	D2,#40*FACMMPT; Calcule le nombre maximal de lignes possibles.40$:	CLR.L	D4	LOAD.W	D4,(A5)+OTXDIM+0 ; D4 <-- hauteur maximale du pav	DIV.WU	D4,D2		; D4 <-- nb max de lignes possibles	ADD.W	D4,#10		; D4 <-- p'tite rserve !	LOAD.W	(A1)+OOBNTL,D4	MUL.WU	D4,#LTL	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^nouveau buffer OTLxxx	JUMP',NE 90$	LOAD.L	(A1)+OOBPTL,A490$:	POPM.L	D1..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; EDAFREST >;---------/; Affiche quelques lignes d'un pav de texte.; in	A1.L	^objet texte;	A4.L	^dans OTLxxx;	D2.L	position initiale (y;x); out	-; mod	D7.WEDAFREST:	PUSHM.L	D2..D4,A4	LOAD.W	D3,(A1)+OOBICA	ADD.W	(A5)+OTXDIM+2,D3	JUMP'	30$20$:	SET.B	(A5)+OTXFLI	; premire ligne	COMP.B	D3,#CR	JUMP',EQ 30$	COMP.B	D3,#EOP	JUMP',EQ 30$	CLR.B	(A5)+OTXFLI	; ligne(s) suivante(s)30$:	LOAD.L	(A4)+OTLPOS,(A1)+OOBPOC	LOAD.B	(A4)+OTLFLI,(A5)+OTXFLI	CLR.W	(A5)+OTXMIL	; faudra refaire EDMAXH1H2	CALL	EDAFLINE	; affiche une ligne	JUMP',NE 60$		; si dbordement => 60$	LOAD.W	(A4)+OTLH1,(A5)+OTXMH1	LOAD.W	(A4)+OTLH2,(A5)+OTXMH2	LOAD.W	(A4)+OTLBL,(A5)+OTXMBL	LOAD.W	(A4)+OTLIL,(A5)+OTXMIL	LOAD.W	(A4)+OTLNC,(A5)+OTXMNC	LOAD.W	(A4)+OTLLX,(A5)+OTXMLX	LOAD.W	(A4)+OTLNS,(A5)+OTXMNS	LOAD.L	(A4)+OTLLC,(A5)+OTXMLC	LOAD.L	A4,#(A4)+LTL	; A4 <-- ^suivant dans OTLxxx	LOAD.L	(A4)+OTLPOS,(A1)+OOBPOC	COMP.B	D3,#EOP	JUMP',EQ 60$	LOAD.L	D4,(A1)+OOBPOC	COMP.L	D4,(A1)+OOBNBC	; fin du pav de texte ?	JUMP,LO 20$		; non => 20$60$:	CLR.W	(A4)+OTLIL	LOAD.L	D3,D2	SWAP.W	D3	ADD.W	D3,(A5)+OTXPOS+0	LOAD.W	D4,(A5)+OTXPOS+0	ADD.W	D4,(A5)+OTXDIM+0	SWAP.W	D4	SWAP.W	D3	LOAD.W	D3,(A5)+OTXPOS+2	LOAD.W	D4,(A5)+OTXDIM+2	ADD.W	D4,D3	LOAD.W	D7,#DR_BMBBOX	PAGE_	DRAW		; affichera jusqu' la fin (efface)	POPM.L	D2..D4,A4	RET;--------\\; EDAFONE >;--------/; Affiche juste une ligne d'un pav de texte.; in	A1.L	^objet texte;	A4.L	^dans OTLxxx;	D2.L	position initiale (y;x); out	-; mod	D7.WEDAFONE:	PUSH.L	D3	LOAD.W	D3,(A1)+OOBICA	ADD.W	(A5)+OTXDIM+2,D3	LOAD.B	(A5)+OTXFLI,(A4)+OTLFLI	LOAD.W	(A5)+OTXMH1,(A4)+OTLH1	LOAD.W	(A5)+OTXMH2,(A4)+OTLH2	LOAD.W	(A5)+OTXMBL,(A4)+OTLBL	LOAD.W	(A5)+OTXMIL,(A4)+OTLIL	LOAD.W	(A5)+OTXMNC,(A4)+OTLNC	LOAD.W	(A5)+OTXMLX,(A4)+OTLLX	LOAD.W	(A5)+OTXMNS,(A4)+OTLNS	LOAD.L	(A5)+OTXMLC,(A4)+OTLLC	CALL	EDAFLINEQ	; affiche une ligne	POP.L	D3	RET;---------\\; EDAFLINE >;---------/; Affiche toute une ligne complte en entier et intgralement (mais si).; Avance le curseur au dbut de la ligne suivante.; in	D2.L	position;	A1.L	^objet texte; out	D2.L	^plus loin;	D3.B	dernier caractre;	D7.W	NE => dbordement; mod	D2.L, D3.L, D7.WEDAFLINE:	PUSHM.L	D3..D6	CALL	EDCOUPELINE	; D3/D4/D5/D6 <-- paramtres	LOAD.W	(A5)+OTXMNC,D3	; OTXMNC <-- nb de caractres	LOAD.W	(A5)+OTXMLX,D4	; OTXMLX <-- largeur	LOAD.W	(A5)+OTXMNS,D5	; OTXMNS <-- nb d'espaces	LOAD.L	(A5)+OTXMLC,D6	; OTXMLC <-- dernier caractre	POPM.L	D3..D6;	CALL	EDAFLINEQ;	TEST.W	D7		; retour EQ/NE;	RET;----------\\; EDAFLINEQ >;----------/; Affiche toute une ligne complte en entier et intgralement (mais si).; Avance le curseur au dbut de la ligne suivante.; in	D2.L	position;	A1.L	^objet texte; out	D2.L	^plus loin;	D3.B	dernier caractre;	D7.W	NE => dbordement; mod	D2.L, D3.L, D7.WEDAFLINEQ:	PUSHM.L	D0,D1,D4..D6,A4	PUSH.W	(A5)+OTXPOS+2	PUSH.W	(A5)+OTXDIM+2	TEST.B	(A5)+OTXFLI	; premire ligne ?	JUMP',F 02$		; non => 02$	LOAD.W	D3,(A1)+OOBRMR	LOAD.W	D4,(A5)+OTXDIM+2	SUB.W	D4,D3	JUMP',LE 02$	LOAD.W	(A5)+OTXDIM+2,D4	ADD.W	(A5)+OTXPOS+2,D302$:	LOAD.W	A4,(A5)+OTXMNC	; A4 <-- nb de caractres	LOAD.W	D4,(A5)+OTXMLX	; D4 <-- largeur	LOAD.W	D5,(A5)+OTXMNS	; D5 <-- nb d'espaces	LOAD.L	D6,(A5)+OTXMLC	; D6 <-- dernier caractre	CALL	EDCALCSAJEX	; D0/D5 <-- reste/nb pour les SAJEXs	TEST.W	(A5)+OTXMIL	; h1/h2 dj connus ?	JUMP',NE 04$		; oui => 04$	LOAD.W	D3,(A5)+OTXMNC	; D3 <-- nb de caractres	CALL	EDMAXH1H2	; OTXMH1/H2 <-- max h1/h204$:	LOAD.W	D7,#1		; D7 <-- a dborde	CLR.W	D2		; X <-- au dbut de la ligne	SWAP.W	D2	LOAD.W	D3,D2	ADD.W	D2,(A5)+OTXMBL	SWAP.W	D2;;?	ADD.W	D3,(A5)+OTXMIL	COMP.W	D3,(A5)+OTXDIM+0 ; dpasse le bas du pav ?	JUMP,HI 90$		; oui => 90$; Met ventuellement quelques espaces au dbut de la ligne pour; justifier dans les modes drapeau  gauche et centr.	LOAD.W	D3,(A5)+OTXDIM+2	SUB.W	D3,D4		; D3 <-- largeur laisse vide	JUMP',LO 15$	TEST.B	(A1)+OOBJUF:#BTXJUG ; drapeau  gauche ?	JUMP',BS 10$	SR.W	D3,#1	TEST.B	(A1)+OOBJUF:#BTXJUC ; centr ?	JUMP',BC 15$10$:	PUSH.L	D5	CLR.L	D5	LOAD.W	D5,D3	PUSH.W	(A5)+OTXOP	CLR.W	(A5)+OTXOP	CALL	EDAFSAJEX	; affiche un sajex au dbut de la ligne	POP.W	(A5)+OTXOP	POP.L	D5; Affiche tous les caractres de la ligne.15$:	LOAD.W	D4,(A5)+OTXMNC	; D4 <-- nb de caractres	LOAD.B	D3,#SPACE20$:	LOAD.B	D1,D3		; D1 <-- dernier caractre	TEST.W	D4	JUMP,EQ 30$	DEC.W	D4	CALL	TXAVANCE	; D3 <-- caractre suivant	CALL	EDAFCAR		; affiche un caractre	TEST.B	(A1)+OOBJUF:#BTXJUA ; align ?	JUMP,BC 20$		; non => 20$				; oui =>	COMP.B	D3,#SPACE	JUMP',NE 26$	COMP.B	D3,D1		; dernier caractre tait dj un espace ?	JUMP',EQ 26$		; oui => 26$	TEST.B	(A1)+OOBJUE	JUMP',EQ 27$	CLR.L	D3	LOAD.B	D3,(A1)+OOBJUE	SUB.L	D3,#100	NEG.L	D3	DIV.WU	D3,#525$:	CALL	EDAFSAJEX	; affiche un "sajex"	DEC.W	D3	JUMP,NC 25$	LOAD.B	D3,#SPACE	JUMP	20$26$:	TEST.B	(A1)+OOBJUE	; espacement entre les caractres ?	JUMP,EQ 20$		; non => 20$27$:	CALL	EDAFSAJEX	; affiche un "sajex"	JUMP	20$; Affiche l'ventuel caractre de fin de ligne.30$:	LOAD.L	D3,D6	TEST.B	D3	JUMP',EQ 42$	COMP.B	D3,#-1	JUMP',EQ 42$	COMP.B	D3,#SPACE	JUMP',EQ 42$	COMP.B	D3,#TAB	JUMP',EQ 42$	COMP.B	D3,#CR	JUMP',EQ 42$	COMP.B	D3,#EOP	JUMP',EQ 42$	CALL	EDAFCAR		; affiche le tiret42$:	SWAP.W	D2	SUB.W	D2,(A5)+OTXMBL	ADD.W	D2,(A5)+OTXMIL	; Y <-- ligne suivante	SWAP.W	D2	TEST.W	(A5)+OTXOP	JUMP',NE 80$	TEST.B	(A5)+OTXVUE+3:#BVUEPROV-0	JUMP',BC 80$	PUSH.L	D3	LOAD.L	D3,D2	LOAD.L	D4,D2	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,(A5)+OTXMIL	ADD.W	D3,(A5)+OTXPOS+0	ADD.W	D4,(A5)+OTXPOS+0	SWAP.W	D4	SWAP.W	D3	LOAD.W	D3,(A5)+OTXPOS+2	LOAD.W	D4,(A5)+OTXDIM+2	ADD.W	D4,D3	LOAD.W	D7,#DR_BMBBOX	PAGE_	DRAW		; affichera toute la ligne (pour effacer la fin)	POP.L	D380$:	CLR.W	D7		; D7 <-- ok90$:	POP.W	(A5)+OTXDIM+2	POP.W	(A5)+OTXPOS+2	POPM.L	D0,D1,D4..D6,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; EDCALCSAJEX >;------------/; Calcul la largeur des "sajex" en mode align.; in	A4.W	nb de caractres;	D4.W	largeur de la ligne;	D5.W	nb d'espaces;	D6.B	dernier caractre (zro/SPACE/tiret/CR); out	D5.L	reste/nb pour les SAJEXs;	D0.L	rpartiteur du reste; mod	D0.L, D5.L, D7.WEDCALCSAJEX:	PUSHM.L	D3,D4	COMP.B	D6,#CR		; fin de ligne force ?	JUMP,EQ 80$		; oui => 80$	COMP.B	D6,#EOP		; fin du texte ?	JUMP,EQ 80$		; oui => 80$	COMP.B	D6,#-1		; fin du texte ?	JUMP,EQ 80$		; oui => 80$	COMP.B	D6,#TAB		; tabulateur ?	JUMP,EQ 80$		; oui => 80$	CLR.L	D3	LOAD.B	D3,(A1)+OOBJUE	; espaces entre tous les caractres ?	JUMP',EQ 40$		; non => 40$				; oui =>	SUB.L	D3,#100	NEG.L	D3	DIV.WU	D3,#5	MUL.WU	D5,D3	ADD.W	D5,A4		; D5 <-- nb de caractres + nb d'espaces	DEC.W	D5	COMP.B	D6,#SPACE	JUMP',NE 30$	DEC.W	D530$:	COMP.B	D6,#'-	JUMP',NE 40$	INC.W	D540$:	CLR.L	D3	LOAD.W	D3,(A5)+OTXDIM+2	SUB.W	D3,D4		; D3 <-- largeur laisse vide	TEST.W	D5	JUMP',LE 80$	CLR.L	D0	LOAD.W	D0,D5	DIV.WU	D3,D5	LOAD.L	D5,D3		; D5 <-- reste/nb	SWAP.W	D3	TEST.W	D3	JUMP',EQ 85$	DIV.WU	D0,D3	LOAD.W	D3,D0	SWAP.W	D0	LOAD.W	D0,D3	SR.W	D0,#1		; D0 <-- rpartiteur du reste	JUMP',NE 90$	INC.W	D0	JUMP'	90$80$:	CLR.L	D5		; D5 <-- n'aligne pas !85$:	CLR.L	D090$:	POPM.L	D3,D4	RET;------------\\; EDCOUPELINE >;------------/; Dtermine o il faut couper dans une ligne trop longue.; N'avance pas le curseur dans la ligne !; in	A1.L	^objet texte; out	D3.W	nb de caractre  avancer (0..n);	D4.W	largeur de la ligne;	D5.W	nb d'espaces (0..n);	D6.B	dernier caractre (zro/SPACE/tiret/CR/EOP/-1); mod	D3.L, D4.L, D5.L, D6.L, D7.WEDCOUPELINE:	PUSHM.L	D0..D2,A4	PUSH.W	(A5)+OTXPOS+2	PUSH.W	(A5)+OTXDIM+2	TEST.B	(A5)+OTXFLI	; premire ligne ?	JUMP',F 04$		; non => 04$	LOAD.W	D3,(A1)+OOBRMR	LOAD.W	D4,(A5)+OTXDIM+2	SUB.W	D4,D3	JUMP',LE 04$	LOAD.W	(A5)+OTXDIM+2,D4	ADD.W	(A5)+OTXPOS+2,D304$:	CALL	TXPSAUVE	; D4 <-- no de la position	PUSH.W	D4		; stack <-- no position dbut ligne	CLR.W	D2		; D2 <-- nb caractres dans dernier mot	CLR.W	D4		; D4 <-- position dans la ligne	CLR.W	D5		; D5 <-- nb d'espaces10$:	COMP.W	D4,(A5)+OTXDIM+2 ; largeur ligne atteinte ?	JUMP,HI 40$		; oui => 40$	CALL	TXAVANCE	; D3 <-- caractre suivant	JUMP,NE 75$	COMP.B	D3,#CR	JUMP,EQ 70$	COMP.B	D3,#EOP	JUMP,EQ 70$;;?	COMP.B	D3,#TAB;;?	JUMP,EQ 30$	INC.W	D2		; D2 <-- +1 caractre	CALL	EDGETLGC	; D1 <-- largeur du caractre	ADD.W	D4,D1		; D4 <-- avance dans la ligne	COMP.B	D3,#SPACE	JUMP,EQ 10$20$:	COMP.W	D4,(A5)+OTXDIM+2 ; largeur ligne atteinte ?	JUMP,HI 40$		; oui => 40$	CALL	TXAVANCE	; D3 <-- caractre suivant	JUMP,NE 75$	COMP.B	D3,#CR	JUMP,EQ 70$	COMP.B	D3,#EOP	JUMP,EQ 70$;;?	COMP.B	D3,#TAB;;?	JUMP,EQ 30$	INC.W	D2		; D2 <-- +1 caractre	CALL	EDGETLGC	; D1 <-- largeur du caractre	ADD.W	D4,D1		; D4 <-- avance dans la ligne	COMP.B	D3,#SPACE	JUMP,NE 20$	CLR.W	D2		; D2 <-- rz avance dans mot	INC.W	D5		; D5 <-- +1 espace	JUMP	10$;;?30$:				; tabulateur =>;;?	LOAD.W	D2,D4;;?	CALL	RGNEXT		; D2 <-- position suivante;;?	JUMP',NE 34$;;?	COMP.W	D2,(A5)+OTXDIM+2 ; largeur ligne atteinte ?;;?	JUMP',HI 34$		; oui => 34$;;?	LOAD.W	D4,D2;;?	CLR.W	D2		; D2 <-- rz avance dans mot;;?	JUMP	10$34$:	CALL	TXRECULE	; recule le tabulateur	LOAD.B	D6,#TAB	JUMP	90$40$:	TEST.W	D5		; un seul mot ?	JUMP',NE 50$		; non => 50$				; oui =>	CALL	TXRECULE	; D3 <-- caractre prcdent	CALL	EDGETLGC	; D1 <-- largeur du caractre	SUB.W	D4,D1		; D4 <-- recule dans la ligne	LOAD.W	D1,D4	CALL	TXPSAUVE	; D4 <-- no de la position	PUSH.W	D4	LOAD.W	D4,(SP)+2	; D4 <-- no position dbut ligne	CALL	TXPREMET	; revient au dbut de la ligne	LOAD.W	D4,D1	LOAD.W	D2,(A5)+OTXDIM+2 ; D2 <-- lg max coupable	CALL	EDCOUPEMOT	; essaye de couper dans le mot suivant	JUMP',NE 44$	POP.W	D4		; D4 <-- no position fin ligne	CALL	TXPANNULE	LOAD.W	D4,D2		; D4 <-- largeur de la ligne	JUMP'	58$44$:	LOAD.W	D1,D4	POP.W	D4		; D4 <-- no position fin ligne	CALL	TXPPREND	; va  la fin de la ligne	LOAD.W	D4,D1	CLR.B	D6	JUMP	90$50$:	DEC.W	D5		; D5 <-- ne compte pas le dernier espace	TEST.W	D2	JUMP',EQ 54$52$:	CALL	TXRECULE	; D3 <-- caractre prcdent	CALL	EDGETLGC	; D1 <-- largeur du caractre	SUB.W	D4,D1		; D4 <-- recule dans la ligne	DEC.W	D2	JUMP,NE 52$54$:	LOAD.W	D2,(A5)+OTXDIM+2	SUB.W	D2,D4		; D2 <-- lg max coupable	CALL	TXRECULE	; D3 <-- caractre prcdent (espace)	CALL	EDGETLGC	; D1 <-- largeur du dernier espace	SUB.W	D4,D1		; D4 <-- n'affiche pas le dernier espace	CALL	TXAVANCE	; annule le TXRECULE !	CALL	EDCOUPEMOT	; essaye de couper dans le mot suivant	JUMP',NE 60$	INC.W	D5		; D5 <-- un mot de plus	ADD.W	D4,D2		; D4 <-- reste	ADD.W	D4,D1		; D4 <-- ajoute le dernier espace58$:	TEST.L	D2:#16		; tiret dj dans le mot ?	JUMP',BC 90$		; non => 90$	CLR.B	D6	JUMP'	90$60$:	LOAD.B	D6,#SPACE	JUMP'	90$70$:	LOAD.B	D6,D3		; D6 <-- CR/EOP	JUMP'	90$75$:	LOAD.B	D6,#-1		; D6 <-- EOT90$:	LOAD.L	D3,(A1)+OOBPOC	LOAD.W	D1,D4	POP.W	D4		; D4 <-- no position dbut ligne	CALL	TXPPREND	; revient au dbut de la ligne	LOAD.W	D4,D1	SUB.L	D3,(A1)+OOBPOC	; D3 <-- nb de caractre  avancer	POP.W	(A5)+OTXDIM+2	POP.W	(A5)+OTXPOS+2	POPM.L	D0..D2,A4	RET;-----------\\; EDCOUPEMOT >;-----------/; Essaye de couper dans un mot.;;	   D2;	|<---->|;	 construction;	 ^;	 A3; in	A1.L	^objet texte;	D2.W	lg max coupable; out	D2.W	lg rcupre grce  la coupure;		si 2^16 = 1 --> tiret dj dans le mot;	D6.B	caractre tiret (si D2:#16=0);	D7.W	ok/erreur; mod	D2.L, D6.L, D7.WEDCOUPEMOT:	PUSHM.L	D0,D1,D3..D5,A2..A4	CALL	TXPSAUVE	PUSH.W	D4		; stack <-- no position dbut mot	LOAD.W	D5,D2		; D5 <-- lg max coupable	JUMP,LE 80$	TEST.B	(A1)+OOBJUF:#BTXJUM ; autorise les divisions dans les mots ?	JUMP,BC 80$		; non => 80$	LOAD.W	D3,D2	MUL.WU	D3,#100	DIV.WU	D3,(A5)+OTXDIM+2 ; D3 <-- lg max coupable en %	CLR.W	D4	LOAD.B	D4,(A1)+OOBJUD	COMP.W	D3,D4	JUMP,LO 80$	LOAD.L	A3,#(A5)+OBUMOT	; A3 <-- ^buffer pour mot	LOAD.L	A2,#(A5)+OBULMO	; A2 <-- ^buffer pour lg caractres	LOAD.W	D4,#LBUMOT-1	; D4 <-- nb car. max pour le mot	CLR.W	D0		; D0 <-- position dans le mot	CLR.W	D2		; D2 <-- compte nb car. avancs	CLR.L	D610$:	CALL	TXAVANCE	; D3 <-- caractre suivant	JUMP',NE 20$	TEST.L	D6	JUMP',NE 12$	LOAD.L	D6,D3		; D6 <-- premier caractre du mot12$:	COMP.B	D3,#SPACE	; fin du mot ?	JUMP',EQ 20$		; oui => 20$	COMP.B	D3,#TAB	JUMP',EQ 20$	COMP.B	D3,#CR	JUMP',EQ 20$	COMP.B	D3,#EOP	JUMP',EQ 20$	INC.W	D2		; D2 <-- +1 caractre avanc	LOAD.B	(A3+),D3	; OBUMOT <-- un caractre	LOAD.W	(A2+),D0	; OBULMO <-- position	CALL	EDGETLGC	; D1 <-- largeur du caractre	ADD.W	D0,D1		; D0 <-- position dans le mot	DEC.W	D4	JUMP,NE	10$	JUMP	80$20$:	TEST.W	D2	JUMP,EQ 80$	LOAD.L	A3,#(A5)+OBUMOT	; A3 <-- ^mot	LOAD.W	D3,D2		; D3 <-- lg mot	LOAD.L	A4,#(A5)+OBUCOUP ; A4 <-- ^buffer	LOAD.W	D4,#LBUCOUP	; D4 <-- lg buffer	COUPE_	HASH		; cherche la liste des coupures	JUMP,NE 80$; Cherche la coupure optimale dans la liste rendue.	LOAD.B	D6,#'-	LOAD.L	D3,D6		; D3 <-- tiret avec gencar 1er car. du mot	CALL	EDGETLGC	; D1 <-- largeur d'un "-"	CLR.W	D430$:	INC.W	D4	TEST.B	(A4+)	JUMP,NE	30$	DEC.L	A4		; A4 <-- ^dernire coupure	LOAD.L	A2,#(A5)+OBULMO	; A2 <-- ^buffer pour lg caractres40$:	DEC.W	D4	JUMP,EQ 80$	CLR.W	D3	LOAD.B	D3,(-A4)	; D3 <-- position coupure (nb car)	JUMP,EQ 80$	JUMP',NS 50$				; coupe en ajoutant un tiret =>	SL.W	D3,#1	LOAD.W	D2,(A2)+(D3.W)	; D2 <-- lg du mot jusque l	ADD.W	D2,D1		; D2 <-- lg du mot avec le tiret	COMP.W	D2,D5		; reste assez de place en bout de ligne ?	JUMP,HI 40$		; non => 40$	SR.W	D3,#1	TCLR.L	D2:#16	JUMP'	60$50$:				; coupe sans ajouter de tiret =>	TCLR.L	D3:#7	SL.W	D3,#1	LOAD.W	D2,(A2)+(D3.W)	; D2 <-- lg du mot jusque l	COMP.W	D2,D5		; reste assez de place en bout de ligne ?	JUMP,HI 40$		; non => 40$	SR.W	D3,#1	TSET.L	D2:#1660$:	POP.W	D4		; D4 <-- no position dbut mot	CALL	TXPPREND	; revient o l'on tait	LOAD.W	D4,D362$:	CALL	TXAVANCE	DEC.W	D4	JUMP,NE 62$	CLR.W	D7		; D7 <-- coupure effectue	JUMP'	90$80$:	POP.W	D4		; D4 <-- no position dbut mot	CALL	TXPPREND	; revient o l'on tait	LOAD.W	D7,#1		; D7 <-- coupure pas faite !90$:	POPM.L	D0,D1,D3..D5,A2..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; EDMAXH1H2 >;----------/; Cherche les valeurs maximales pour h1 et h2.; in	D3.W		nb de caractre  avancer (0..n); out	(A5)+OTXMH1.W	h1 max;	(A5)+OTXMH2.W	h2 max;	(A5)+OTXMBL.W	ligne de base;	(A5)+OTXMIL.W	interligne; mod	D7.W	.PC	PCVAR	.LOC	0OEDMNBC:.BLKB	2		; nb de caractresOEDMH1C:.BLKB	2		; h1 caractreOEDMH2C:.BLKB	2		; h2 caractreOEDMH1R:.BLKB	2		; h1 rfrence "E"OEDMH2R:.BLKB	2		; h2 rfrence "p"OEDMHIE:.BLKB	2		; +/- hauteur si indice/exposantLEDM:	.PC	PCCODEEDMAXH1H2:	PUSHM.L	D0..D6,A3,A4	CALL	TXPSAUVE	; D4 <-- no de la position	PUSH.W	D4		; stack <-- no position dbut ligne	SUB.L	SP,#LEDM	; SP <-- ^variables	CLR.W	(SP)+OEDMH1C	; OEDMH1R <-- h1 max	CLR.W	(SP)+OEDMH2C	; OEDMH2R <-- h2 max	CLR.W	(SP)+OEDMH1R	; OEDMH1R <-- h1 max	CLR.W	(SP)+OEDMH2R	; OEDMH2R <-- h2 max	LOAD.W	D2,D3		; D2 <-- nb de caractres	JUMP,EQ END$	LOAD.W	(SP)+OEDMNBC,D2	LOAD.L	D6,#-1		; D6 <-- dernier gencarLOOP$:	CALL	TXAVANCE	; D3 <-- caractre suivant	JUMP,NE END$	COMP.B	D3,#CR	JUMP',NE NOVIDE$	COMP.W	(SP)+OEDMNBC,#1	JUMP,EQ VIDE$NOVIDE$:	CLR.W	D1	LOAD.B	D1,D3		; D1 <-- caractre	AND.L	D3,#CCGCMSK!CCEXMSK	COMP.L	D3,D6		; toujours le mme gencar ?	JUMP,EQ H2R$		; oui => H2R$	LOAD.L	D6,D3	LOAD.L	D0,D3	AND.L	D0,#CCEXMSK;	SR.L	D0,#CCEXSHI	SWAP.W	D0		; D0 <-- rang de l'exposant	AND.W	D3,#CCGCMSK	SR.W	D3,#CCGCSHI	; D3 <-- numro du gencar	CALL	EDGETDIM	; A3/A4/D3/D4 <-- ^gencar/^chasses/h1;h2/interl	JUMP,NE H2C$	LOAD.W	D4,(A4)+((256*2)+'E)*2 ; D4 <-- h1 de "E"	LOAD.W	D5,(A4)+((256*4)+'p)*2 ; D5 <-- h2 de "p"	CLR.W	D3		; D3 <-- normal	TEST.W	D0	JUMP',EQ EXP$	LOAD.W	D3,D4	SR.W	D3,#1		; D3 <-- 1/2 h1 de "E"	COMP.W	D0,#2	JUMP',EQ EXP$	NEG.W	D3		; D3 <-- -1/2 h1 de "E"EXP$:	LOAD.W	(SP)+OEDMHIE,D3	ADD.W	D4,D3		; D4 <-- h1 selon exposant/indice	JUMP',NC H1REX$	CLR.W	D4H1REX$:	ADD.W	D5,D3		; D5 <-- h2 selon exposant/indice	JUMP',NC H2REX$	CLR.W	D5H2REX$:	COMP.W	D4,(SP)+OEDMH1R	JUMP',LS H1R$	LOAD.W	(SP)+OEDMH1R,D4	; OEDMH1R <-- h1 maxH1R$:	COMP.W	D5,(SP)+OEDMH2R	JUMP',LS H2R$	LOAD.W	(SP)+OEDMH2R,D5	; OEDMH2R <-- h2 maxH2R$:	SL.W	D1,#1	LOAD.L	A3,#(A4)+(256*2)*2	LOAD.W	D4,(A3)+(D1.W)	; D4 <-- h1 du caractre	LOAD.L	A3,#(A4)+(256*4)*2	LOAD.W	D5,(A3)+(D1.W)	; D5 <-- h2 du caractre	LOAD.W	D3,(SP)+OEDMHIE	ADD.W	D4,D3		; D4 <-- h1 selon exposant/indice	JUMP',NC H1CEX$	CLR.W	D4H1CEX$:	ADD.W	D5,D3		; D5 <-- h2 selon exposant/indice	JUMP',NC H2CEX$	CLR.W	D5H2CEX$:	COMP.W	D4,(SP)+OEDMH1C	JUMP',LS H1C$	LOAD.W	(SP)+OEDMH1C,D4	; OEDMH1C <-- h1 maxH1C$:	COMP.W	D5,(SP)+OEDMH2C	JUMP',LS H2C$	LOAD.W	(SP)+OEDMH2C,D5	; OEDMH2C <-- h2 maxH2C$:	DEC.W	D2	JUMP,NE LOOP$END$:	LOAD.W	D2,(SP)+OEDMH1R	OR.W	D2,(SP)+OEDMH2R	; h1 et h2 nuls ?	JUMP',NE NONULL$	; non => NONULL$	LOAD.W	(SP)+OEDMH1R,#20*FACMMPT	LOAD.W	(SP)+OEDMH2R,#20*FACMMPT	CLR.W	D3	CALL	EDGETDIM	; A3/A4/D3/D4 <-- ^gencar/^chasses/h1;h2/interl	JUMP',NE NULL$	LOAD.W	(SP)+OEDMH1R,(A4)+((256*2)+'E)*2 ; OEDMH1R <-- h1 de "E"	LOAD.W	(SP)+OEDMH2R,(A4)+((256*4)+'p)*2 ; OEDMH2R <-- h2 de "p"NULL$:	LOAD.W	(SP)+OEDMH1C,(SP)+OEDMH1R	LOAD.W	(SP)+OEDMH2C,(SP)+OEDMH2RNONULL$:	LOAD.W	(A5)+OTXMH1,(SP)+OEDMH1C	LOAD.W	(A5)+OTXMH2,(SP)+OEDMH2C	LOAD.W	D4,(A1)+OOBILM	LOAD.W	D2,(SP)+OEDMH1R	ADD.W	D2,(SP)+OEDMH2R	COMP.W	D4,D2	JUMP',HS ILMIN$	LOAD.W	D4,D2ILMIN$:	ADD.W	D4,(A1)+OOBILA	JUMP',NC ILOK$	CLR.W	D4ILOK$:	LOAD.W	(A5)+OTXMIL,D4	SUB.W	D4,(SP)+OEDMH1R	SUB.W	D4,(SP)+OEDMH2R	ASR.W	D4,#1	ADD.W	D4,(SP)+OEDMH1R	LOAD.W	(A5)+OTXMBL,D4	JUMP	EXIT$VIDE$:	TEST.W	(A1)+OOBILV	JUMP,LE NOVIDE$	LOAD.W	D0,(A1)+OOBILV	; D0 <-- h1 de ILV	CLR.W	D1		; D1 <-- h2 nul	CLR.W	D6	LOAD.B	D6,D3	SL.W	D6,#1	AND.W	D3,#CCGCMSK	SR.W	D3,#CCGCSHI	; D3 <-- numro du gencar	CALL	EDGETDIM	; A3/A4/D3/D4 <-- ^gencar/^chasses/h1;h2/interl	JUMP',NE VIDE4$	LOAD.L	A3,#(A4)+(256*2)*2	LOAD.W	D4,(A3)+(D6.W)	; D4 <-- h1 de <CR>	LOAD.L	A3,#(A4)+(256*4)*2	LOAD.W	D5,(A3)+(D6.W)	; D5 <-- h2 de <CR>	LOAD.W	D3,D4	ADD.W	D3,D5		; D3 <-- h1+h2	COMP.W	D3,D0	JUMP',HI VIDE4$	SUB.W	D0,D5	LOAD.W	D1,D5VIDE4$:	LOAD.W	(A5)+OTXMBL,D0	LOAD.W	(A5)+OTXMH1,D0	LOAD.W	(A5)+OTXMH2,D1	ADD.W	D0,D1	LOAD.W	(A5)+OTXMIL,D0;	JUMP'	EXIT$EXIT$:	ADD.L	SP,#LEDM	; POP variables	POP.W	D4		; D4 <-- no position dbut ligne	CALL	TXPPREND	; revient au dbut de la ligne	POPM.L	D0..D6,A3,A4	RET;----------\\; EDAFSAJEX >;----------/; Affiche un sajex (en ralit, avance sans rien afficher).; in	D2.L	position (y;x);	D5.L	reste/nb;	D0.L	rpartiteur du reste; out	D2.L	position suivante (y;x);	D5.L	nouveau reste;	D0.L	nouvelle rpartition du reste; mod	D0.L, D2.L, D5.L, D7.WEDAFSAJEX:	PUSH.W	D1	LOAD.W	D1,D5		; D1 <-- avance selon "nb"	TEST.W	D0	JUMP',EQ 20$	DEC.W	D0	JUMP',NE 40$	SWAP.W	D0	PUSH.W	D0	SWAP.W	D0	POP.W	D0		; D0[low] <-- D0[high]20$:	SWAP.W	D5	TEST.W	D5		; encore un reste ?	JUMP',EQ 30$		; non => 30$	DEC.W	D5		; D5 <-- un reste de moins	INC.W	D1		; D1 <-- avance selon "reste"30$:	SWAP.W	D540$:	COMP.W	(A5)+OTXOP,#OPPOS	JUMP',EQ POS$	COMP.W	(A5)+OTXOP,#OPPOSZ	JUMP',EQ POS$	COMP.W	(A5)+OTXOP,#OPZONE	JUMP',EQ ZONE$	JUMP'	END$POS$:	PUSH.L	D0	CLR.L	D0		; D0 <-- idem gauche/droite	CALL	EDPOSCAR	; positionne v. le curseur	POP.L	D0	JUMP'	END$ZONE$:	CALL	EDIZONECAR	; inverse une zone;	JUMP'	END$END$:	ADD.W	D2,D1		; D2 <-- avance	POP.W	D1	RET;--------\\; EDAFCAR >;--------/; Affiche un caractre.; in	D3.L	caractre;	D2.L	position (y;x); out	D2.L	position suivante (y;x); mod	D2.L, D7.WEDAFCAR:	PUSHM.L	D0,D1,D3..D5,A2..A4	CLR.W	D5	LOAD.B	D5,D3		; D5 <-- caractre	LOAD.L	D0,D3	AND.L	D0,#CCEXMSK;	SR.L	D0,#CCEXSHI	SWAP.W	D0		; D0 <-- rang de l'exposant	AND.W	D3,#CCGCMSK	SR.W	D3,#CCGCSHI	; D3 <-- numro du gencar	CALL	EDGETDIM	; A3/A4/D3/D4 <-- ^gencar/^chasses/h1;h2/interl	JUMP,NE EXIT$	LOAD.L	D3,D2		; D3 <-- position normale	TEST.W	D0	JUMP',EQ NOEXP$	LOAD.W	D4,(A4)+((256*2)+'E)*2 ; D4 <-- h1 de "E"	SR.W	D4,#1		; D4 <-- 1/2 h1 de "E"	COMP.W	D0,#2	JUMP',EQ EXP$	NEG.W	D4		; D4 <-- -1/2 h1 de "E"EXP$:	SWAP.W	D3	ADD.W	D3,D4		; D3 <-- position selon exposant/indice	SWAP.W	D3NOEXP$:	LOAD.W	D1,(A5)+OTXOP	COMP.W	D1,#OPCURS	JUMP,EQ CURS$	COMP.W	D1,#OPPOS	JUMP,EQ POS$	COMP.W	D1,#OPPOSZ	JUMP,EQ POS$	COMP.W	D1,#OPZONE	JUMP,EQ ZONE$	COMP.W	D1,#OPBBOX	JUMP,EQ BBOX$	LOAD.L	D1,D2		; D1 <-- position normale	LOAD.L	D4,D3		; D4 <-- position selon exposant/indice	ADD.W	D4,(A5)+OTXPOS+2	SWAP.W	D4	ADD.W	D4,(A5)+OTXPOS+0	SWAP.W	D4	TEST.L	(A1)+OOBA	; pav de texte tourn ?	JUMP',EQ NOROT$		; non => NOROT$	CALL	EDPOSROT	; D4 <-- nouvelle position (y;x)NOROT$:	LOAD.W	D3,D5		; D3 <-- caractre	TEST.B	(A5)+OTXVUE+3:#BVUEPROV-0	JUMP',BS 12$	COMP.B	D3,#CADRATIN	; cadratin ?	JUMP',NE 10$		; non => 10$	LOAD.B	D3,#SPACE	; oui => comme un espace10$:	COMP.B	D3,#CR		; fin de ligne ?	JUMP',NE 11$		; non => 11$	LOAD.B	D3,#SPACE	; oui => comme un espace11$:	COMP.B	D3,#EOP		; fin de ligne ?	JUMP',NE 12$		; non => 12$	LOAD.B	D3,#SPACE	; oui => comme un espace12$:	LOAD.L	D2,(A5)+OTXMOD	; D2 <-- mode d'affichage	EX.L	A4,A3		; A4 <-- ^gencar bitmap, A3 <-- ^chasses	LOAD.W	D7,#DR_CHARQ	LOAD.L	A2,(A5)+OADDRAW	CALL	(A2)		; PAGE_DRAW, affiche un caractre	LOAD.L	D2,D1	SL.W	D3,#1	LOAD.W	D1,(A3)+(D3.W)	; D1 <-- largeur du caractre	ADD.W	D1,(A1)+OOBICA	; D1 <-- largeur caractre + intercaractre	JUMP',NC 47$	CLR.W	D147$:	ADD.W	D2,D1		; D2 <-- position suivante	JUMP	EXIT$CURS$:	LOAD.L	D4,(A1)+OOBPOC	DEC.L	D4	COMP.L	D4,(A5)+OTXCPB	; est-on sur le curseur ?	JUMP',NE CURS5$		; non => CURS5$	LOAD.L	D4,D3	ADD.W	D4,(A5)+OTXPOS+2	SWAP.W	D4	ADD.W	D4,(A5)+OTXPOS+0	LOAD.L	D1,D4	SUB.W	D4,(A4)+((256*2)+'E)*2 ; D4 <-- -h1 de "E"	SWAP.W	D4	CALL	EDPOSROT	; D4 <-- P'(y;x) v. tourn	LOAD.L	(A5)+OTXCP1,D4	; OTXCP1 <-- position (y;x)	LOAD.L	D4,D1	ADD.W	D4,(A4)+((256*4)+'p)*2 ; D4 <-- +h2 de "p"	SWAP.W	D4	CALL	EDPOSROT	; D4 <-- P'(y;x) v. tourn	LOAD.L	(A5)+OTXCP2,D4	; OTXCP2 <-- position (y;x)CURS5$:	SL.W	D5,#1	LOAD.W	D1,(A4)+(D5.W)	; D1 <-- largeur du caractre	ADD.W	D1,(A1)+OOBICA	; D1 <-- largeur caractre + intercaractre	JUMP',NC CURS8$	CLR.W	D1CURS8$:	ADD.W	D2,D1		; D2 <-- position suivante	JUMP	EXIT$POS$:	SL.W	D5,#1	LOAD.W	D1,(A4)+(D5.W)	; D1 <-- largeur du caractre	ADD.W	D1,(A1)+OOBICA	; D1 <-- largeur caractre + intercaractre	JUMP',NC POS8$	CLR.W	D1POS8$:	LOAD.L	D0,#-1		; D0 <-- recule si on est  gauche	CALL	EDPOSCAR	; positionne v. le curseur	ADD.W	D2,D1		; D2 <-- avance dans la ligne	JUMP	EXIT$ZONE$:	SL.W	D5,#1	LOAD.W	D1,(A4)+(D5.W)	; D1 <-- largeur du caractre	ADD.W	D1,(A1)+OOBICA	; D1 <-- largeur caractre + intercaractre	JUMP',NC ZONE8$	CLR.W	D1ZONE8$:	CALL	EDIZONECAR	; inverse une zone	ADD.W	D2,D1		; D2 <-- avance dans la ligne	JUMP	EXIT$BBOX$:	COMP.B	D5,#CADRATIN	; cadratin ?	JUMP',EQ BBOX5$	COMP.B	D5,#CR		; fin de ligne ?	JUMP',EQ BBOX5$	COMP.B	D5,#EOP		; fin de ligne ?	JUMP',EQ BBOX5$	PUSH.L	D2	LOAD.W	D1,D5	SL.W	D1,#1	LOAD.L	A2,#(A4)+(D1.W)	LOAD.L	D2,D3		; D2 <-- position selon exposant/indice	ADD.W	D2,(A5)+OTXPOS+2	SWAP.W	D2	ADD.W	D2,(A5)+OTXPOS+0	SWAP.W	D2	LOAD.L	D1,D2	SUB.W	D1,(A2)+256*2	; D1 <-- -XMIN	SWAP.W	D1	SUB.W	D1,(A2)+256*4	; D1 <-- -YMIN	SWAP.W	D1	ADD.W	D2,(A2)+256*6	; D2 <-- +XMAX	SWAP.W	D2	ADD.W	D2,(A2)+256*8	; D2 <-- +YMAX	SWAP.W	D2	LOAD.L	D3,(A5)+OTXBB1	LOAD.L	D4,(A5)+OTXBB2	CALL	RECTOR	LOAD.L	(A5)+OTXBB1,D3	LOAD.L	(A5)+OTXBB2,D4	POP.L	D2BBOX5$:	SL.W	D5,#1	LOAD.W	D1,(A4)+(D5.W)	; D1 <-- largeur du caractre	ADD.W	D1,(A1)+OOBICA	; D1 <-- largeur caractre + intercaractre	JUMP',NC BBOX8$	CLR.W	D1BBOX8$:	ADD.W	D2,D1		; D2 <-- avance dans la ligne;	JUMP'	EXIT$EXIT$:	POPM.L	D0,D1,D3..D5,A2..A4	RET;---------\\; EDPOSROT >;---------/; Fait tourner un point.; in	D4.L	P (y;x); out	D4.L	P'(y;x); mod	D4.L, D7.WEDPOSROT:	PUSHM.L	D1,D3	LOAD.W	D1,(A1)+OOBA+0	; D1 <-- angle de rotation	JUMP',EQ EXIT$	LOAD.L	D3,(A5)+OTXPOS	; D3 <-- centre de symtrie	LIB	?CALCPSYM	; D4 <-- nouvelle position (y;x)EXIT$:	POPM.L	D1,D3	RET;---------\\; EDPOSCAR >;---------/; Positionne ventuellement le curseur.; in	D2.L	position (y;x);	D1.W	largeur (-1 si dernire);	D0.L	avance si on est  gauche du caractre; out	-; mod	D7.WEDPOSCAR:	PUSHM.L	D1..D5	ADD.W	D2,(A5)+OTXPOS+2	SWAP.W	D2	SUB.W	D2,(A5)+OTXMBL	ADD.W	D2,(A5)+OTXPOS+0	SWAP.W	D2	LOAD.L	D4,(A5)+OTXPMO	; D4 <-- position de la souris	SWAP.W	D4	SWAP.W	D2	COMP.W	D4,D2		; trop en haut ?	JUMP',LT 90$	ADD.W	D2,(A5)+OTXMIL	COMP.W	D4,D2		; trop en bas ?	JUMP',GE 90$	SWAP.W	D4	SWAP.W	D2	COMP.W	D4,D2		; trop  gauche ?	JUMP',LT 30$	ADD.W	D2,D1	COMP.W	D4,D2		; trop  droite ?	JUMP',GE 90$	LOAD.L	D3,(A1)+OOBPOC	; D3 <-- position  droite du caractre	LOAD.W	D5,D1	SR.W	D5,#1	SUB.W	D2,D5	COMP.W	D4,D2	JUMP',GE 40$	ADD.L	D3,D0		; D3 <-- position  gauche du caractre	JUMP'	40$30$:	COMP.L	(A5)+OTXPMB,#-1	; position trouve ?	JUMP',NE 90$		; oui => 90$	LOAD.L	D3,(A1)+OOBPOC	DEC.L	D340$:	LOAD.L	(A5)+OTXPMB,D3	; OTXPMB <-- position o est la souris	LOAD.L	(A5)+OTXCPB,D390$:	POPM.L	D1..D5	RET;-----------\\; EDIZONECAR >;-----------/; Inverse une zone dans une mme ligne.; in	D2.L	position (y;x);	D1.W	largeur (-1 si dernire); out	-; mod	D7.WEDIZONECAR:	PUSHM.L	D2..D4	COMP.W	D1,#-1		; inverse s'ki reste ?	JUMP,EQ 40$		; oui => 40$	LOAD.L	D4,(A1)+OOBPOC	DEC.L	D4	COMP.L	D4,(A5)+OTXZOF	JUMP,HS 90$	COMP.L	D4,(A5)+OTXZOD	JUMP,LO 90$	LOAD.L	D3,D2	ADD.W	D3,(A5)+OTXPOS+2	SWAP.W	D3	SUB.W	D3,(A5)+OTXMBL	ADD.W	D3,(A5)+OTXPOS+0	SWAP.W	D3	LOAD.W	D4,(A5)+OTXMIL	; D4 <-- hauteur	SWAP.W	D4	LOAD.W	D4,D1		; D4 <-- largeur	LOAD.L	D2,D3	SWAP.W	D2	COMP.W	D2,(A5)+OTXZOP+0 ; mme position verticale ?	JUMP',NE 40$		; non => 40$;;?	LOAD.W	D2,(A5)+OTXZOP+2;;?	ADD.W	D2,(A5)+OTXZOL+2;;?	COMP.W	D2,D3;;?	JUMP',NE 40$	ADD.W	D3,D4	SUB.W	D3,(A5)+OTXZOP+2	LOAD.W	(A5)+OTXZOL+2,D3	JUMP	90$40$:	PUSHM.L	D3,D4	LOAD.L	D3,(A5)+OTXZOP	LOAD.L	D4,(A5)+OTXZOL	JUMP',EQ 50$	LOAD.W	D2,(A1)+OOBICA	ADD.W	D2,(A5)+OTXPOS+2	ADD.W	D2,(A5)+OTXDIM+2	INC.W	D2	COMP.W	D3,D2	JUMP',HS 50$	SUB.W	D2,D3		; D2 <-- largeur  ne pas dpasser	COMP.W	D4,D2		; dpasse  droite ?	JUMP',LS 44$		; non => 44$	LOAD.W	D4,D2		; D4 <-- largeur maximale44$:	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#INVDOT	LOAD.W	D7,#DR_TRAME	PAGE_	DRAW		; inverse un caractre50$:	POPM.L	D3,D4	LOAD.L	(A5)+OTXZOP,D3	LOAD.L	(A5)+OTXZOL,D490$:	POPM.L	D2..D4	RET;----------\\; EDGETLGCT >;----------/; Calcule la largeur d'un caractre  chasse variable,; en tenant compte des tabulateurs.; in	D3.L	caractre;	D2.L	position dans la ligne; out	D1.W	largeur du caractre; mod	D1.L, D7.WEDGETLGCT:;;?	COMP.B	D3,#TAB;;?	JUMP',NE EDGETLGC;;?;;?	PUSH.L	D2;;?	LOAD.W	D1,D2;;?	CALL	RGNEXT		; D2 <-- position suivante;;?	SUB.W	D2,D1;;?	LOAD.W	D1,D2		; D1 <-- largeur;;?	POP.L	D2;;?	RET;---------\\; EDGETLGC >;---------/; Calcule la largeur d'un caractre  chasse variable.; in	D3.L	caractre; out	D1.W	largeur du caractre; mod	D1.L, D7.WEDGETLGC:	PUSHM.L	D2..D4,A3,A4	CLR.W	D2	LOAD.B	D2,D3		; D2 <-- caractre	AND.W	D3,#CCGCMSK	SR.W	D3,#CCGCSHI	; D3 <-- numro du gencar	CALL	EDGETDIM	; A3/A4/D3/D4 <-- ^gencar/^chasses/h1;h2/interl	JUMP',NE ERROR$	COMP.B	D2,#CADRATIN	; cadratin ?	JUMP',NE 10$		; non => 10$	LOAD.B	D2,#SPACE	; oui => comme un espace10$:	COMP.B	D2,#CR		; fin de ligne ?	JUMP',NE 11$		; non => 11$	LOAD.B	D2,#SPACE	; oui => comme un espace11$:	COMP.B	D2,#EOP		; fin de ligne ?	JUMP',NE 12$		; non => 12$	LOAD.B	D2,#SPACE	; oui => comme un espace12$:	SL.W	D2,#1	LOAD.W	D1,(A4)+(D2.W)	; D1 <-- largeur du caractre	ADD.W	D1,(A1)+OOBICA	; D1 <-- ajoute l'intercaractre	JUMP',NC EXIT$ERROR$:	CLR.W	D1		; D1 <-- largeur nulleEXIT$:	POPM.L	D2..D4,A3,A4	RET;---------\\; EDINIDIM >;---------/; Initialise pour EDGETDIM.; in	-; out	-; mod	D7.WEDINIDIM:	PUSHM.L	D4,A4	LOAD.W	(A5)+OTXLCH,#-1	LOAD.L	A4,#(A5)+OTXLCG	LOAD.W	D4,#16-1LOOP$:	CLR.L	(A4+)	DECJ.W,NMO D4,LOOP$	POPM.L	D4,A4	RET;---------\\; EDGETDIM >;---------/; Donne qq paramtres sur le caractre.; in	D3.W	numro du caractre; out	A3.L	^gencar bitmap (et non descripteur, pour DR_CHARQ !);	A4.L	^table de chasse  [obj];	D3.L	hauteurs (h1;h2)  [obj];	D4.W	interligne        [obj];	D7.W	erreur; mod	D3.L, D4.L, D7.W, A3.L, A4.LEDGETDIM:	PUSHM.L	D0..D2,A2	LOAD.W	D2,D3		; D2 <-- numro du caractre	COMP.W	D3,(A5)+OTXLCH	; est-ce toujours le mme caractre ?	JUMP',EQ SAME$		; oui => SAME$	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D0,#IDENTCHAR	LOAD.W	D1,#opDGETDIM	PAGE_	OBJCALL		; A2/A3/A4/D3/D4 <-- paramtres	JUMP',NE EXIT$	LOAD.W	(A5)+OTXLCH,D2	LOAD.L	(A5)+OTXLCD,A3	LOAD.L	(A5)+OTXLCC,A4	LOAD.L	(A5)+OTXLCJ,D3	LOAD.W	(A5)+OTXLCI,D4	JUMP'	BITMAP$SAME$:	LOAD.L	A3,(A5)+OTXLCD	; A3 <-- ^descripteur	LOAD.L	A4,(A5)+OTXLCC	; A4 <-- ^chasses	LOAD.L	D3,(A5)+OTXLCJ	; D3 <-- h1/h2	LOAD.W	D4,(A5)+OTXLCI	; D4 <-- interligneBITMAP$:	SL.W	D2,#2		; D2 <-- *4	LOAD.L	A2,#(A5)+OTXLCG	TEST.L	(A2)+(D2.W)	; ^gencar bitmap existe ?	JUMP',NE TAKE$		; oui => TAKE$	PUSH.L	A4	LOAD.L	A4,A3		; A4 <-- ^descripteur	LOAD.L	D1,(A1)+OOBA	; D1 <-- angle de rotation	LOAD.W	D7,#DR_GETPGC	; A3 <-- ^gencar bitmap	PAGE_	DRAW	POPM.L	A4	JUMP',NE EXIT$	LOAD.L	(A2)+(D2.W),A3TAKE$:	LOAD.L	A3,(A2)+(D2.W)	; A3 <-- ^gencar bitmap	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D2,A2	TEST.W	D7		; retour EQ/NE	RET;--------\\; RECTOR  >;========/; Effectue un "ou" (union) entre deux rectangles.; in	D1/D2	P1/P2 rectangle A;	D3/D4	P1/P2 rectangle B; out	D3/D4	P1/P2 rectangle A ! B; mod	D3.L, D4.LRECTOR:	COMP.W	D3,D1	JUMP',LE 20$	LOAD.W	D3,D120$:	COMP.W	D4,D2	JUMP',GE 22$	LOAD.W	D4,D222$:	SWAP.W	D1	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	COMP.W	D3,D1	JUMP',LE 40$	LOAD.W	D3,D140$:	COMP.W	D4,D2	JUMP',GE 42$	LOAD.W	D4,D242$:	SWAP.W	D1	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	RET	.END