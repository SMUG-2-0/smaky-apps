	.SBTTL	PAGEDETECT;----------\\; PGODETECT >;==========/; Dtecte dans quelle poigne est la souris.; in	A4.L	^objet quelconque;	D4.L	position de la souris; out	D0.W	numro de la poigne trouve;	D7.W	erreur; mod	D0.L, D7.WPGODETECT:	PUSHM.L	D2..D4	LOAD.W	D7,#DET_POINT	PAGE_	DET		; D3 <-- point o est la souris	JUMP,NE 90$	LOAD.W	D2,D3		; D2 <-- position en X	LOAD.L	D4,D3	SWAP.W	D4		; D4 <-- position en Y	CLR.W	D020$:	CALL	POSPOIGNEE	; D3 <-- position d'une poigne	JUMP',NE 90$	SUB.W	D3,#DPOIGNEE	COMP.W	D2,D3		; trop  gauche ?	JUMP',LT 50$	ADD.W	D3,#DPOIGNEE*2	COMP.W	D2,D3		; trop  droite ?	JUMP',GE 50$	SWAP.W	D3	SUB.W	D3,#DPOIGNEE	COMP.W	D4,D3		; trop haut ?	JUMP',LT 50$	ADD.W	D3,#DPOIGNEE*2	COMP.W	D4,D3		; trop bas ?	JUMP',LT 90$50$:	INC.W	D0		; D0 <-- poigne suivante	JUMP	20$90$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; PGOUPDATE >;==========/; Met  jour l'affichage d'un objet modifi.; in	A4.L	^objet; out	-; mod	D7.WPGOUPDATE:	PUSHM.L	D1..D6,A1..A5	LOAD.L	A5,A4	COMP.W	(A4)+OOOBJ,#ICOTX	JUMP,NE 90$	CLR.L	D3		; D3 <-- position source	LOAD.L	A3,(A6)+OPOIPM1	; A3 <-- ^source	LOAD.W	D5,(A6)+OWDIM+2	ADD.W	D5,#16-1	SR.W	D5,#4	SL.W	D5,#1		; D5 <-- Iy source	CLR.L	D4		; D4 <-- position destination	LOAD.L	A4,(A6)+OPOIPM2	; A4 <-- ^destination	LOAD.W	D6,D5		; D6 <-- Iy destination	LOAD.L	D2,(A6)+OWDIM	; D2 <-- dimensions	LOAD.W	D1,#LOADDOT	; D1 <-- mode	LOAD.L	A2,A0	LOAD.L	A1,(A6)+ORASTER	CALL	(A1)		; matrice 2 <-- matrice 1	LOAD.L	D4,D2	CALL	OPEDISMAT	; dessine dans la matrice 2	INC.W	(A6)+OWUSE	PUSH.L	(A6)+OWPOS	CLR.L	(A6)+OWPOS	LOAD.W	(A6)+OTXAFD,#H'7FFF	CLR.W	(A6)+OTXAFF	LOAD.L	A4,A5	LOAD.W	D2,#INVDOT	LOAD.W	D7,#DESS_OBJET	PAGE_	DESS		; dessine l'objet;;?	LOAD.B	D3,(A6)+OSPLOP	; D3 <-- outil;;?	LOAD.W	D7,#TEXT_RGIDRAW;;?	PAGE_	TEXT		; dessine les rgles	TEST.W	(A6)+OTXAFF	JUMP',EQ 40$	LOAD.W	D2,#SETDOT	CALL	PGOINV		; remet les poignes40$:	POP.L	(A6)+OWPOS	DEC.W	(A6)+OWUSE	CALL	CLODISMAT	CALL	PGORESTORE	; affiche  l'cran90$:	POPM.L	D1..D6,A1..A5	RET;--------\\; PGOSAVE >;========/; Sauve le contenu de l'cran en mmoire.; in	A4.L	^objet; out	D7.W	erreur; mod	D7.WPGOSAVE:	PUSHM.L	D1..D6,A1..A4	CALL	PGOFREE		; libre v. les matrices	COMP.W	(A4)+OOOBJ,#ICOTX	JUMP,NE 90$	LOAD.W	D4,(A6)+OWDIM+2	ADD.W	D4,#16-1	SR.W	D4,#4	SL.W	D4,#1	MUL.WU	D4,(A6)+OWDIM+0	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour matrice 1	JUMP',NE 90$	LOAD.L	(A6)+OPOIPM1,A4	GESMEM	?GETMEM		; demande mmoire pour matrice 2	JUMP',NE 90$	LOAD.L	(A6)+OPOIPM2,A4	CALL	CCMO		; enlve la souris	LOAD.L	D3,(A6)+OWPOS	; D3 <-- position source	LOAD.L	A3,#0		; A3 <-- source dans l'cran	CLR.L	D4		; D4 <-- position destination	LOAD.L	A4,(A6)+OPOIPM1	; A4 <-- ^destination	LOAD.W	D6,(A6)+OWDIM+2	ADD.W	D6,#16-1	SR.W	D6,#4	SL.W	D6,#1		; D6 <-- Iy destination	LOAD.L	D2,(A6)+OWDIM	; D2 <-- dimensions	LOAD.W	D1,#LOADDOT	; D1 <-- mode	LOAD.L	A2,A0	LOAD.L	A1,(A6)+ORASTER	CALL	(A1)		; matrice 1 <-- contenu de l'cran	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D6,A1..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; PGORESTORE >;===========/; Remet le contenu de la matrice 2 dans l'cran.; in	A5.L	^objet texte; out	-; mod	D7.WPGORESTORE:	PUSHM.L	D1..D6,A1..A4	TEST.L	(A6)+OPOIPM2	JUMP,EQ 90$;;?	LOAD.W	D1,(A6)+OTXAFD	; D1 <-- dbut zone affiche;;?	LOAD.W	D2,(A6)+OTXAFF	; D2 <-- fin zone affiche;;?	JUMP,EQ 90$	TEST.W	(A6)+OTXAFF	JUMP,EQ 90$	CLR.W	D1	LOAD.W	D2,(A6)+OWDIM+0	LOAD.L	D3,(A5)+OOTXPOS	LOAD.L	D4,(A5)+OOTXDIM	ADD.W	D4,D3	SUB.W	D3,(A6)+OPPOS+2	SUB.W	D4,(A6)+OPPOS+2	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SUB.W	D3,(A6)+OPPOS+0	SUB.W	D4,(A6)+OPPOS+0	SWAP.W	D3	SWAP.W	D4	LOAD.W	D7,#DET_SCALEP	PAGE_	DET		; D3 <-- plus grand (si n:1)	EX.L	D3,D4	LOAD.W	D7,#DET_SCALEP	PAGE_	DET		; D4 <-- plus grand (si n:1)	EX.L	D4,D3	SWAP.W	D3	SWAP.W	D4	TEST.W	D1	JUMP',NC 20$	CLR.W	D120$:	COMP.W	D1,D3	JUMP',GE 22$	LOAD.W	D1,D322$:	COMP.W	D2,(A6)+OWDIM+0	JUMP',LE 24$	LOAD.W	D2,(A6)+OWDIM+024$:	COMP.W	D2,D4	JUMP',LE 26$	LOAD.W	D2,D426$:	SWAP.W	D1	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	CLR.W	D1	TEST.W	D3	JUMP',NS 32$	LOAD.W	D1,D332$:	LOAD.W	D2,(A6)+OWDIM+2	COMP.W	D2,D4	JUMP',LE 36$	LOAD.W	D2,D436$:	LOAD.L	D3,D1	LOAD.L	D4,D1	SUB.W	D2,D3		; D2 <-- largeur	ADD.W	D4,(A6)+OWPOS+2	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	SUB.W	D2,D3		; D2 <-- hauteur	ADD.W	D4,(A6)+OWPOS+0	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	CALL	CCMO		; enlve la souris	LOAD.L	A3,(A6)+OPOIPM2	; A3 <-- ^source	LOAD.W	D5,(A6)+OWDIM+2	ADD.W	D5,#16-1	SR.W	D5,#4	SL.W	D5,#1		; D5 <-- Iy destination	LOAD.L	A4,#0		; A4 <-- destination dans l'cran	LOAD.W	D1,#LOADDOT	; D1 <-- mode	LOAD.L	A2,A0	LOAD.L	A1,(A6)+ORASTER	CALL	(A1)		; cran <-- matrice 190$:	POPM.L	D1..D6,A1..A4	RET;--------\\; PGOFREE >;========/; Libre les matrices 1 et 2.; in	-; out	-; mod	D7.WPGOFREE:	PUSHM.L	D1,A4	TEST.L	(A6)+OPOIPM1	JUMP',EQ 20$	LOAD.L	A4,(A6)+OPOIPM1	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	CLR.L	(A6)+OPOIPM120$:	TEST.L	(A6)+OPOIPM2	JUMP',EQ 30$	LOAD.L	A4,(A6)+OPOIPM2	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	CLR.L	(A6)+OPOIPM230$:	POPM.L	D1,A4	RET;---------\\; PGOBEGIN >;=========/; Dbut du dplacement d'une poigne bouge par la souris.; in	A4.L	^objet quelconque;	D0.W	numro de la poigne dplace; out	-; mod	D7.WPGOBEGIN:	PUSHM.L	D2	COMP.W	(A4)+OOOBJ,#ICOSP	JUMP',EQ SPLINE$	COMP.W	(A4)+OOOBJ,#ICOIM	JUMP',EQ IMAGE$	COMP.W	(A4)+OOOBJ,#ICOTX	JUMP',EQ TEXT$	JUMP'	EXIT$SPLINE$:	TCLR.B	(A4)+OOFLG:#BOOSKP	JUMP'	EXIT$IMAGE$:	LOAD.L	(A4)+OOIMDIL,(A4)+OOIMDIM	JUMP'	EXIT$TEXT$:	LOAD.L	(A6)+OTXOPO,(A4)+OOTXPOS	LOAD.L	(A6)+OTXODI,(A4)+OOTXDIM	LOAD.W	D2,#INVDOT!2^BMDPOI	LOAD.W	D7,#DESS_OBJET	PAGE_	DESS		; dessine le pav;	JUMP'	EXIT$EXIT$:	POPM.L	D2	RET;--------\\; PGOMOVE >;========/; Dplace une poigne bouge par la souris.; in	A4.L	^objet quelconque;	D3.L	nouvelle position (y;x);	D0.W	numro de la poigne dplace; out	-; mod	D7.WPGOMOVE:	PUSHM.L	D1..D5,A3	CALL	OPEWDO		; dessine dans la swdo	LOAD.L	D1,D3		; D1 <-- position en Y;X	LOAD.W	D2,D3		; D2 <-- position en X	LOAD.L	D4,D3	SWAP.W	D4		; D4 <-- position en Y	CALL	POSPOIGNEE	; D3 <-- position de la poigne	JUMP,NE EXIT$	COMP.W	(A4)+OOOBJ,#ICOSP	JUMP',NE CLR$	TEST.W	D0	JUMP',NE MOVEY$CLR$:	PUSH.W	D2	LOAD.W	D2,#INVDOT!2^BMDPOI	LOAD.W	D7,#DESS_OBJET	PAGE_	DESS		; efface l'objet	POP.W	D2	SUB.W	D2,D3		; D2 <-- dplacement en X	SWAP.W	D3	SUB.W	D4,D3		; D4 <-- dplacement en Y	COMP.B	(A6)+OSTRHV,#ICOHORIZ	JUMP',NE MOVEX$	CLR.W	D4		; D4 <-- bloque le dplacement en YMOVEX$:	COMP.B	(A6)+OSTRHV,#ICOVERTI	JUMP',NE MOVEY$	CLR.W	D2		; D2 <-- bloque le dplacement en XMOVEY$:	LOAD.W	D3,(A4)+OOOBJ	COMP.W	D3,#ICOTM	JUMP,EQ TML$	COMP.W	D3,#ICOSP	JUMP,EQ SPLINE$	COMP.W	D3,#ICOLB	JUMP,EQ LINEB$	COMP.W	D3,#ICODR	JUMP,EQ LINE$	COMP.W	D3,#ICOFL	JUMP,EQ LINE$	COMP.W	D3,#ICORD	JUMP,EQ RECT$	COMP.W	D3,#ICORA	JUMP,EQ RECT$	COMP.W	D3,#ICOPO	JUMP',EQ CIRC$	COMP.W	D3,#ICOCE	JUMP',EQ CIRC$	COMP.W	D3,#ICOEL	JUMP',EQ CIRC$	COMP.W	D3,#ICOAR	JUMP',EQ ARC$	COMP.W	D3,#ICOIM	JUMP,EQ RECT$	COMP.W	D3,#ICOTX	JUMP,EQ RECT$	JUMP	OK$CIRC$:	LOAD.L	D3,(A4)+OOCETYP	TEST.L	D3:#BCEMRAY	JUMP',BC LINE$CIRC2$:	COMP.W	D0,#1	JUMP,EQ DR$	TEST.W	D0	JUMP,EQ CENTER$	JUMP	EXIT$ARC$:	LOAD.L	D3,(A4)+OOARTYP	TEST.L	D3:#BARQ	JUMP,BC CIRC2$	COMP.W	D0,#4	JUMP,EQ ANG$	COMP.W	D0,#3	JUMP,EQ ANG$	JUMP'	LINE$RECT$:	COMP.W	D0,#4	JUMP,EQ UR$	COMP.W	D0,#3	JUMP,EQ DL$LINE$:	COMP.W	D0,#2	JUMP,EQ DR$	COMP.W	D0,#1	JUMP,EQ UL$	TEST.W	D0	JUMP,EQ CENTER$	JUMP	OK$SPLINE$:	TEST.W	D0	JUMP',EQ TML$	LOAD.L	A3,#(A4)+OOSPPTF	LOAD.W	D3,D0	DEC.W	D3	COMP.W	D3,(A4)+OOSPNBF	JUMP,HS EXIT$	SL.W	D3,#2	LOAD.L	D3,(A3)+(D3.W)	TSET.B	(A4)+OOFLG:#BOOSKP	JUMP',BS SPLNXT$	LOAD.L	(A4)+OODPOS,D3SPLNXT$:	CALL	PGOMOVEISP	; efface l'ancienne flche	COMP.B	(A6)+OSTRHV,#ICOVERTI	JUMP',EQ SPLX$	LOAD.W	(A4)+OODPOS+2,D2SPLX$:	COMP.B	(A6)+OSTRHV,#ICOHORIZ	JUMP',EQ SPLY$	LOAD.W	(A4)+OODPOS+0,D4SPLY$:	CALL	PGOMOVEISP	; dessine la nouvelle flche	JUMP	EXIT$LINEB$:	TEST.W	D0	JUMP',EQ TML$	LOAD.L	A3,#(A4)+OOLBPTS	LOAD.W	D3,D0	DEC.W	D3	COMP.W	D3,(A4)+OOLBNBP	JUMP,HS EXIT$	SL.W	D3,#2	ADD.W	(A3)+(D3.W)+2,D2	ADD.W	(A3)+(D3.W)+0,D4	JUMP	OK$TML$:	TEST.W	D0	JUMP,NE EXIT$	SWAP.W	D4	LOAD.W	D4,D2		; D4 <-- +/- dplacement (dy;dx)	LOAD.W	D7,#DET_MOVOBJET	PAGE_	DET		; dplace l'objet	LOAD.W	D7,#DET_INITQ	PAGE_	DET		; ajuste pour les dtections	JUMP	OK$CENTER$:	SWAP.W	D4	LOAD.W	D4,D2		; D4 <-- +/- dplacement (dy;dx)	LOAD.W	D7,#DET_MOVOBJET	PAGE_	DET		; dplace l'objet	JUMP	OK$UL$:	ADD.W	(A4)+OODRPOS+2,D2	ADD.W	(A4)+OODRPOS+0,D4	SUB.W	(A4)+OODRDIM+2,D2	SUB.W	(A4)+OODRDIM+0,D4	JUMP	OK$DR$:	ADD.W	(A4)+OODRDIM+2,D2	ADD.W	(A4)+OODRDIM+0,D4	JUMP	OK$DL$:	ADD.W	(A4)+OODRPOS+2,D2	SUB.W	(A4)+OODRDIM+2,D2	ADD.W	(A4)+OODRDIM+0,D4	JUMP	OK$UR$:	ADD.W	(A4)+OODRPOS+0,D4	ADD.W	(A4)+OODRDIM+2,D2	SUB.W	(A4)+OODRDIM+0,D4	JUMP	OK$ANG$:	LOAD.L	D3,(A4)+OOARPOS	LOAD.L	D4,D1	LOAD.L	D5,D3	ADD.W	D5,(A4)+OOARRAY	LIB	?CALCANGLE	; D2 <-- angle	SUB.W	D2,(A4)+OOARAND	JUMP',NC ANG2$	NEG.W	D2ANG2$:	SL.W	D2,#1	COMP.W	D2,#360	JUMP',LO ANG3$	SUB.W	D2,#360*2	NEG.W	D2ANG3$:	LOAD.W	(A4)+OOARANG,D2;	JUMP	OK$OK$:	COMP.W	(A4)+OOOBJ,#ICOIM	JUMP',NE NOIM$	TEST.W	D0	JUMP',EQ NOIM$	TEST.B	(A6)+OSTRHO	JUMP',EQ NOIM$	CALL	PGOMOVEHOMOTNOIM$:	LOAD.W	D2,#INVDOT!2^BMDPOI	LOAD.W	D7,#DESS_OBJET	PAGE_	DESS		; allume l'objetEXIT$:	CALL	CLOWDO		; fin du dessin dans la swdo	POPM.L	D1..D5,A3	RET;-------------\\; PGOMOVEHOMOT >;-------------/; Modifie le dplacement en Y pour rester homottoque (et tic...).; in	A4.L	^objet; out	-; mod	D7.WPGOMOVEHOMOT:	PUSH.L	D4	LOAD.W	D4,(A4)+OOIMDIM+2	MUL.WA	D4,(A4)+OOIMLGY	DIV.WA	D4,(A4)+OOIMLGX	LOAD.W	(A4)+OOIMDIM+0,D4	POP.L	D4	RET;-----------\\; PGOMOVEISP >;-----------/; Inverse la flche pour indiquer le dplacement d'un point.; in	A4.L	^objet spline;	D3.L	origine (y;x); out	-; mod	D7.WPGOMOVEISP:	PUSHM.L	D1..D4	CALL	CCMO		; enlve la souris	LOAD.L	D4,(A4)+OODPOS	COMP.L	D3,D4	JUMP',EQ 90$	SUB.W	D3,(A6)+OPPOS+2	SUB.W	D4,(A6)+OPPOS+2	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,(A6)+OPPOS+0	SUB.W	D4,(A6)+OPPOS+0	SWAP.W	D3	SWAP.W	D4	LOAD.W	D7,#DET_SCALEP	PAGE_	DET		; D3 <-- plus grand (si n:1)	EX.L	D3,D4	LOAD.W	D7,#DET_SCALEP	PAGE_	DET		; D3 <-- plus grand (si n:1)	EX.L	D4,D3	PUSH.W	(A6)+OSCALE	CLR.W	(A6)+OSCALE	LOAD.W	D2,#INVDOT	LOAD.L	D1,#2^BFLQQ!2^BFLE1i!2^BFLL16!2^BFLA27!2^BFLF2	LOAD.W	D7,#DESS_XFLECHE	PAGE_	DESS		; inverse la flche	POP.W	(A6)+OSCALE	LOAD.W	D4,#4	LIB	?DRCERCLE	; inverse le point de dpart90$:	POPM.L	D1..D4	RET;-------\\; PGOEND >;=======/; Fin du dplacement d'une poigne bouge par la souris.; in	A4.L		^objet quelconque;	D0.W		numro de la poigne dplace;	D0.L		point  crer (si OSPLOP=ICOSPLADD);	(A6)+OSPLOP.B	opration si spline (ICOSPLxxx); out	A4.L		^objet (v. ailleurs);	D7.W		erreur; mod	D7.W, A4.LPGOEND:	PUSHM.L	D1..D6,A1..A3	COMP.W	(A4)+OOOBJ,#ICOSP	JUMP',EQ SPLINE$	COMP.W	(A4)+OOOBJ,#ICOLB	JUMP,EQ LINEB$	COMP.W	(A4)+OOOBJ,#ICOIM	JUMP,EQ IMAGE$	COMP.W	(A4)+OOOBJ,#ICOTX	JUMP,EQ TEXT$	LOAD.W	D7,#DET_INITQ	PAGE_	DET		; ajuste pour les dtections	CLR.W	D7		; D7 <-- ok	JUMP	EXIT$SPLINE$:	COMP.B	(A6)+OSPLOP,#ICOSPLMOV	JUMP',NE SPLCLR$	TEST.W	D0	JUMP',EQ SPLCLR$	TCLR.B	(A4)+OOFLG:#BOOSKP	JUMP,BC EXIT$	LOAD.L	A3,#(A4)+OOSPPTF	LOAD.W	D1,D0	DEC.W	D1	SL.W	D1,#2	LOAD.L	D3,(A3)+(D1.W)	CALL	OPEWDO		; dessine dans la swdo	CALL	PGOMOVEISP	; efface la dernire flche	CALL	CLOWDO		; fin du dessin dans la swdo	LOAD.L	(A3)+(D1.W),(A4)+OODPOSSPLCLR$:	LOAD.W	D2,#INVDOT	LOAD.W	D7,#DESS_OBJET	PAGE_	DESS		; efface la spline	PUSH.B	(A6)+OOUTIL	PUSH.W	(A6)+OSLPEN	PUSH.W	(A6)+OSLTRA	PUSH.L	(A6)+OMFOND	LOAD.B	(A6)+OOUTIL,#ICOCRAYON	LOAD.W	(A6)+OSLPEN,(A4)+OOPEN	LOAD.W	(A6)+OSLTRA,(A4)+OOTRAM	LOAD.L	(A6)+OMFOND,(A4)+OOFOND	LOAD.B	(A6)+OSPLOF,(A4)+OOSPMOF	LOAD.L	A3,#(A6)+OSPLPT	LOAD.L	A2,#(A4)+OOSPPTF	LOAD.W	D2,(A4)+OOSPNBFSPLOP2$:	LOAD.L	(A3+),(A2+)	; OSPLPT <-- points fixes	DEC.W	D2	JUMP,NE SPLOP2$	LOAD.L	(A3),#-1	LOAD.L	A2,(A4)+OLNEXT	LOAD.W	D7,#BASE_REMOVE	PAGE_	BASE		; supprime l'objet spline	COMP.B	(A6)+OSPLOP,#ICOSPLSUB	JUMP',EQ SPLSUB$	COMP.B	(A6)+OSPLOP,#ICOSPLADD	JUMP',NE SPLCL$SPLADD$:	LOAD.L	D4,D0		; D4 <-- point  ajouter	LOAD.W	D3,#MAXSPLINE	CALL	SPLADD		; ajoute un point	JUMP,NE SPLCL8$	JUMP'	SPLCL$SPLSUB$:	LOAD.L	A1,#(A6)+OSPLPT	LOAD.W	D3,D0	DEC.W	D3	SL.W	D3,#2	ADD.W	A1,D3		; A1 <-- ^point  supprimer	CALL	SPLKILL		; supprime juste le point;	JUMP'	SPLCL$SPLCL$:	CALL	SPLOPEN		; A3 <-- ^table des droites, D6 <-- canal	JUMP',NE SPLCL8$	CALL	SPLMI		; dessine la spline provisoire	LOAD.L	A4,A2		; A4 <-- insre  la mme place qu'avant !	CALL	SPLINSOBJ	; A4 <-- cre l'objet spline	JUMP',NE SPLCL7$	TSET.B	(A4)+OOFLG:#BOOSEL	POP.L	(A6)+OMFOND	POP.W	(A6)+OSLTRA	POP.W	(A6)+OSLPEN	POP.B	(A6)+OOUTIL	CALL	SPLCLOSE	; ferme la table des droites	CLR.W	D7		; D7 <-- ok	JUMP	EXIT$SPLCL7$:	PUSH.W	D7	CALL	SPLMI		; efface la spline provisoire	POP.W	D7SPLCL8$:	POP.L	(A6)+OMFOND	POP.W	(A6)+OSLTRA	POP.W	(A6)+OSLPEN	POP.B	(A6)+OOUTIL	JUMP	EXIT$LINEB$:	LOAD.W	D2,#INVDOT	LOAD.W	D7,#DESS_OBJET	PAGE_	DESS		; efface la ligne brise	PUSH.B	(A6)+OOUTIL	PUSH.W	(A6)+OSLPEN	PUSH.W	(A6)+OSLTRA	PUSH.L	(A6)+OMFOND	LOAD.B	(A6)+OOUTIL,#ICOCRAYON	LOAD.W	(A6)+OSLPEN,(A4)+OOPEN	LOAD.W	(A6)+OSLTRA,(A4)+OOTRAM	LOAD.L	(A6)+OMFOND,(A4)+OOFOND	LOAD.B	(A6)+OLIBOF,(A4)+OOLBMOF	LOAD.L	A3,#(A6)+OSPLPT	LOAD.L	A2,#(A4)+OOLBPTS	LOAD.W	D2,(A4)+OOLBNBP	JUMP',EQ LBOP3$LBOP2$:	LOAD.L	(A3+),(A2+)	; OSPLPT <-- points fixes	DEC.W	D2	JUMP,NE LBOP2$LBOP3$:	LOAD.L	(A3),#-1	LOAD.L	A2,(A4)+OLNEXT	LOAD.W	D7,#BASE_REMOVE	PAGE_	BASE		; supprime l'objet ligne brise	COMP.B	(A6)+OSPLOP,#ICOSPLSUB	JUMP',EQ LBSUB$	COMP.B	(A6)+OSPLOP,#ICOSPLADD	JUMP',NE LBCL$LBADD$:	LOAD.L	D4,D0		; D4 <-- point  ajouter	PUSH.B	(A6)+OSPLOF	LOAD.B	(A6)+OSPLOF,(A6)+OLIBOF	LOAD.W	D3,#MAXLINEB	CALL	SPLADD		; ajoute un point	POP.B	(A6)+OSPLOF	TEST.W	D7	JUMP',NE LBCL8$	JUMP'	LBCL$LBSUB$:	LOAD.L	A1,#(A6)+OSPLPT	LOAD.W	D3,D0	DEC.W	D3	SL.W	D3,#2	ADD.W	A1,D3		; A1 <-- ^point  supprimer	CALL	SPLKILL		; supprime juste le point;	JUMP'	LBCL$LBCL$:	LOAD.L	A4,A2		; A4 <-- insre  la mme place qu'avant !	CALL	LBINSOBJ	; A4 <-- cre l'objet ligne briseLBCL8$:	POP.L	(A6)+OMFOND	POP.W	(A6)+OSLTRA	POP.W	(A6)+OSLPEN	POP.B	(A6)+OOUTIL	TEST.W	D7	JUMP,NE EXIT$	TSET.B	(A4)+OOFLG:#BOOSEL	LOAD.W	D2,#INVDOT	LOAD.W	D7,#DESS_OBJET	PAGE_	DESS		; dessine la ligne brise	CLR.W	D7	JUMP	EXIT$IMAGE$:	TEST.W	D0		; poigne centrale ?	JUMP',EQ IMAGE5$	; oui => IMAGE5$	LOAD.W	D2,#INVDOT!2^BMDPOI	LOAD.W	D7,#DESS_OBJET	PAGE_	DESS		; efface l'image	LOAD.W	D7,#DESS_INITIMZOOM	PAGE_	DESS		; calcule la matrice zoome	LOAD.W	D2,#INVDOT	LOAD.W	D7,#DESS_OBJET	PAGE_	DESS		; dessine l'imageIMAGE5$:	LOAD.W	D7,#DET_INITQ	PAGE_	DET		; ajuste pour les dtections	CLR.W	D7	JUMP	EXIT$TEXT$:	LOAD.W	D2,#INVDOT!2^BMDPOI	LOAD.W	D7,#DESS_OBJET	PAGE_	DESS		; efface le pav	PUSH.L	(A4)+OOTXPOS	PUSH.L	(A4)+OOTXDIM	LOAD.L	(A4)+OOTXPOS,(A6)+OTXOPO	LOAD.L	(A4)+OOTXDIM,(A6)+OTXODI	LOAD.W	D2,#INVDOT	LOAD.W	D7,#DESS_OBJET	PAGE_	DESS		; efface le pav	POP.L	(A4)+OOTXDIM	POP.L	(A4)+OOTXPOS	LOAD.W	D2,#INVDOT	LOAD.W	D7,#DESS_OBJET	PAGE_	DESS		; dessine le pav	LOAD.W	D7,#DET_INITQ	PAGE_	DET		; ajuste pour les dtections	CLR.W	D7;	JUMP	EXIT$EXIT$:	POPM.L	D1..D6,A1..A3	TEST.W	D7		; retour EQ/NE	RET;-------\\; PGOINV >;=======/; Allume ou teint les poignes d'un objet.; in	A4.L	^objet quelconque;	D2.W	mode (SETDOT/CLRDOT); out	-; mod	D7.WPGOINV:	PUSHM.L	D0,D3	LOAD.B	D3,(A6)+OSPLOP	COMP.B	D3,#ICOTXCURS	JUMP,EQ 90$	COMP.B	D3,#ICOTXDDD	JUMP,EQ 90$	COMP.B	D3,#ICOTXTABM	JUMP,EQ 90$	COMP.B	D3,#ICOTXTABD	JUMP,EQ 90$	COMP.B	D3,#ICOTXTABG	JUMP,EQ 90$	COMP.B	D3,#ICOTXTABC	JUMP,EQ 90$	COMP.B	D3,#ICOTXTABN	JUMP,EQ 90$	CALL	OPEWDO		; dessine dans la swdo	COMP.B	D2,#CLRDOT	JUMP',EQ 40$; Allume les poignes dans l'ordre croissant.	LOAD.W	D0,#-120$:	INC.W	D0		; D0 <-- poigne suivante	CALL	POSPOIGNEE	; D3 <-- position d'une poigne	JUMP',NE 80$	CALL	INVPOIGNEE	; allume une poigne	JUMP	20$; Eteint les poignes dans l'ordre dcroissant, afin de rsoudre; correctement le cas des poignes superposes !40$:	LOAD.W	D0,#MAXPOIGNEE+142$:	DEC.W	D0	JUMP',NS 80$	CALL	POSPOIGNEE	; D3 <-- position d'une poigne	JUMP,NE 42$	CALL	INVPOIGNEE	; teint une poigne	JUMP	42$80$:	CALL	CLOWDO		; fin du dessin dans la swdo90$:	POPM.L	D0,D3	RET;-----------\\; INVPOIGNEE >;-----------/; Allume ou teint une poigne.; Lorsque la poigne est allume, on sauve au pralable ce qui est dessous.; Lorsque la poigne est teinte, on remet simplement ce qui tait dessous.; in	D0.W	numro de la poigne;	D2.W	mode (SETDOT/CLRDOT);	D3.L	coordonne de la poigne; out	-; mod	D7.WINVPOIGNEE:	PUSHM.L	D1..D5,A2..A4	CALL	CCMO		; enlve la souris	SUB.W	D3,(A6)+OPPOS+2	SWAP.W	D3	SUB.W	D3,(A6)+OPPOS+0	SWAP.W	D3	LOAD.W	D7,#DET_SCALEP	PAGE_	DET		; D3 <-- plus grand (si n:1)	SUB.W	D3,#7	SWAP.W	D3	SUB.W	D3,#7	LOAD.L	D5,D3		; D5 <-- coordonne (x;y) (!)	LOAD.L	A2,#(A6)+OPOIPFE	LOAD.W	D3,D0	SL.W	D3,#2	ADD.W	A2,D3		; A2 <-- ^^buffer/nil	COMP.B	D2,#CLRDOT	JUMP,EQ 50$				; met une poigne =>	TEST.L	(A2)	JUMP',NE 20$	LOAD.L	D4,#32	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour sauver sous une poigne	JUMP,NE 80$	LOAD.L	(A2),A420$:	LOAD.L	A4,(A2)		; A4 <-- ^buffer pour sauver sous une poigne	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWRASTER	LOAD.L	(A3)+1,D5	; source: xx yy	CLR.L	(A3)+5		; source: pppp (dans l'cran);	CLR.W	(A3)+9		; source: ii	CLR.L	(A3)+11		; destination: xx yy	LOAD.L	(A3)+15,A4	; destination: pppp	LOAD.W	(A3)+19,#2	; destination: ii	LOAD.L	(A3)+21,#H'10000*15+15	LOAD.B	(A3)+25,#LOADDOT	LOAD.W	D3,#26	LIB	?STRING		; sauve le fond;	LOAD.L	A3,#(A6)+OBUDIS+1;	LOAD.B	(A3)+0,#DRAWRASTER	LOAD.W	(A3)+1,#16	; source: xx (pour fond)	CLR.W	(A3)+3		; source: yy	LOAD.L	A4,(A6)+OPGICO	; A4 <-- ^gencar des icnes	LOAD.W	D3,#ICOPOIM	TEST.W	D0	JUMP',EQ 30$	LOAD.W	D3,#ICOPOIE30$:	MUL.WU	D3,(A4)+OGCMSB	ADD.L	D3,#OGCMAT	ADD.L	A4,D3		; A4 <-- ^bonne matrice	LOAD.L	(A3)+5,A4	; source: pppp (dans IIP21)	LOAD.W	(A3)+9,#GCICX/8	; source: ii	LOAD.L	(A3)+11,D5	; destination: xx yy	CLR.L	(A3)+15		; destination: pppp (dans l'cran)	CLR.W	(A3)+19		; destination: ii;	LOAD.L	(A3)+21,#H'10000*15+15	LOAD.B	(A3)+25,#CLRDOT	LOAD.W	D3,#26	LIB	?STRING		; efface selon l'icne du fond	CLR.W	(A3)+1		; source: xx (pour chair)	LOAD.B	(A3)+25,#SETDOT	LOAD.W	D3,#26	LIB	?STRING		; dessine selon l'icne de la chair	JUMP	80$50$:				; enlve une poigne =>	TEST.L	(A2)	JUMP,EQ 80$	LOAD.L	A4,(A2)		; A4 <-- ^contenu de dessous la poigne	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWRASTER	CLR.L	(A3)+1		; source: xx yy	LOAD.L	(A3)+5,A4	; source: pppp	LOAD.W	(A3)+9,#2	; source: ii	LOAD.L	(A3)+11,D5	; destination: xx yy	CLR.L	(A3)+15		; destination: pppp (dans l'cran);	CLR.W	(A3)+19		; destination: ii	LOAD.L	(A3)+21,#H'10000*15+15	LOAD.B	(A3)+25,#LOADDOT	LOAD.W	D3,#26	LIB	?STRING		; remet le fond	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	CLR.L	(A2)80$:	POPM.L	D1..D5,A2..A4	RET;-----------\\; POSPOIGNEE >;-----------/; Donne la position d'une poigne.; in	A4.L	^objet;	D0.W	numro de la poigne; out	D3.L	coordonne de la poigne;	D7.W	erreur; mod	D3.L, D7.WPOSPOIGNEE:	PUSHM.L	D1,D2,D4,D5,A3	LOAD.W	D7,#ERDIOUT	LOAD.W	D3,(A4)+OOOBJ	COMP.W	D3,#ICOTM	JUMP,EQ TML$	COMP.W	D3,#ICOSP	JUMP,EQ SPLINE$	COMP.W	D3,#ICOLB	JUMP,EQ LINEB$	COMP.W	D3,#ICODR	JUMP,EQ LINE$	COMP.W	D3,#ICOFL	JUMP,EQ LINE$	COMP.W	D3,#ICORD	JUMP,EQ RECT$	COMP.W	D3,#ICORA	JUMP,EQ RECT$	COMP.W	D3,#ICOPO	JUMP',EQ CIRC$	COMP.W	D3,#ICOCE	JUMP',EQ CIRC$	COMP.W	D3,#ICOEL	JUMP',EQ CIRC$	COMP.W	D3,#ICOAR	JUMP',EQ ARC$	COMP.W	D3,#ICOIM	JUMP,EQ RECT$	COMP.W	D3,#ICOTX	JUMP,EQ RECT$	JUMP	EXIT$CIRC$:	LOAD.L	D4,(A4)+OOCETYP	TEST.L	D4:#BCEMRAY	JUMP',BC LINE$CIRC2$:	COMP.W	D0,#1	JUMP,EQ DR$	TEST.W	D0	JUMP,EQ UL$	JUMP	EXIT$ARC$:	LOAD.L	D4,(A4)+OOARTYP	TEST.L	D4:#BARQ	JUMP,BC CIRC2$	COMP.W	D0,#4	JUMP,EQ ANGA$	COMP.W	D0,#3	JUMP,EQ ANGD$	JUMP'	LINE$RECT$:	COMP.W	D0,#4	JUMP,EQ UR$	COMP.W	D0,#3	JUMP,EQ DL$LINE$:	COMP.W	D0,#2	JUMP,EQ DR$	COMP.W	D0,#1	JUMP,EQ UL$	TEST.W	D0	JUMP',EQ CENTER$	JUMP	EXIT$SPLINE$:	TEST.W	D0	JUMP',EQ TML$	LOAD.L	A3,#(A4)+OOSPPTF	LOAD.W	D3,D0	DEC.W	D3	COMP.W	D3,(A4)+OOSPNBF	JUMP,HS EXIT$	SL.W	D3,#2	LOAD.L	D3,(A3)+(D3.W)	JUMP	OK$LINEB$:	TEST.W	D0	JUMP',EQ TML$	LOAD.L	A3,#(A4)+OOLBPTS	LOAD.W	D3,D0	DEC.W	D3	COMP.W	D3,(A4)+OOLBNBP	JUMP,HS EXIT$	SL.W	D3,#2	LOAD.L	D3,(A3)+(D3.W)	JUMP	OK$TML$:	TEST.W	D0	JUMP,NE EXIT$	LOAD.L	D3,(A4)+OODPOS	LOAD.L	D4,(A4)+OODDIM	ASR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	ASR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	JUMP	OK$CENTER$:	LOAD.L	D3,(A4)+OODRPOS	LOAD.L	D4,(A4)+OODRDIM	ASR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	ASR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	JUMP	OK$UL$:	LOAD.L	D3,(A4)+OODRPOS	JUMP	OK$DR$:	LOAD.L	D3,(A4)+OODRPOS	LOAD.L	D4,(A4)+OODRDIM	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	JUMP	OK$DL$:	LOAD.L	D3,(A4)+OODRPOS	LOAD.L	D4,(A4)+OODRDIM	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	JUMP	OK$UR$:	LOAD.L	D3,(A4)+OODRPOS	LOAD.L	D4,(A4)+OODRDIM	ADD.W	D3,D4	JUMP	OK$ANGD$:	LOAD.W	D1,(A4)+OOARAND	LOAD.W	D2,(A4)+OOARANG	SR.W	D2,#1	SUB.W	D1,D2		; D1 <-- angle de dpart	JUMP',NC ANGD2$	ADD.W	D1,#360ANGD2$:	LOAD.L	D3,(A4)+OOARPOS	LOAD.W	D4,(A4)+OOARRAY	SWAP.W	D4	LOAD.W	D4,(A4)+OOARRAY	LIB	?CALCPELLI	LOAD.L	D3,D5	JUMP'	OK$ANGA$:	LOAD.W	D1,(A4)+OOARAND	LOAD.W	D2,(A4)+OOARANG	SR.W	D2,#1	SUB.W	D1,D2		; D1 <-- angle de dpart	JUMP',NC ANGA2$	ADD.W	D1,#360ANGA2$:	ADD.W	D1,(A4)+OOARANG	; D1 <-- angle d'arrive	COMP.W	D1,#360	JUMP',LO ANGA3$	SUB.W	D1,#360ANGA3$:	LOAD.L	D3,(A4)+OOARPOS	LOAD.W	D4,(A4)+OOARRAY	SWAP.W	D4	LOAD.W	D4,(A4)+OOARRAY	LIB	?CALCPELLI	LOAD.L	D3,D5;	JUMP'	OK$OK$:	CLR.W	D7		; D7 <-- ok	TEST.W	D0		; poigne centrale ?	JUMP',NE EXIT$		; non => EXIT$				; oui =>	LOAD.W	D7,#DET_RNDPAS	PAGE_	DET		; D3 <-- position arrondie selon le pas	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1,D2,D4,D5,A3	TEST.W	D7		; retour EQ/NE	RET	.END