	.SBTTL	MPAGETEXT;-----------\\; _PAGE_TEXT >;===========/; ; in	D7.W	numro du sous-appel;	?	selon appel; out	?	selon appel; mod	?	selon appel_PAGE_TEXT:	COMP.W	D7,#TEXT_EDIT	JUMP,EQ TXEDIT	COMP.W	D7,#TEXT_ICURSOR	JUMP,EQ TXICURSOR	COMP.W	D7,#TEXT_PCURSOR	JUMP,EQ TXPCURSOR	COMP.W	D7,#TEXT_DZONE	JUMP,EQ TXDZONE	COMP.W	D7,#TEXT_EZONE	JUMP,EQ TXEZONE	COMP.W	D7,#TEXT_OPMOUSE	JUMP,EQ TXOPMOUSE	COMP.W	D7,#TEXT_RGMOVE	JUMP,EQ RGMOVE	COMP.W	D7,#TEXT_RGIDRAW	JUMP,EQ RGIDRAW	RET;----------\\; TXICURSOR >;==========/; Inverse le curseur dans un pav de texte.; in	A4.L	^objet; out	-; mod	D7.WTXICURSOR:	PUSHM.L	D2..D4	COMP.W	(A4)+OOOBJ,#ICOTX	JUMP,NE 90$	CALL	OPEWDO		; dessine dans la swdo	LOAD.W	D2,#INVDOT	INC.B	(A6)+OTXCUC	; OTXCUC <-- compteur	LOAD.B	D3,(A6)+OTXCUS	; D3 <-- dernire touches super-shift	TEST.B	(A6)+OTXCUC:#0	JUMP',BC 20$	LIB	?GETSHIFT	; D3 <-- touches super-shift	LOAD.B	(A6)+OTXCUS,D320$:	TEST.L	D3:#BCURSOR	; touche (CURSOR) enfonce ?	JUMP',BS 40$		; oui => 40$	LOAD.L	D3,(A6)+OTXCUP	; D3 <-- position	LOAD.W	D4,(A6)+OTXCUH	; D4 <-- hauteur	SWAP.W	D4	CLR.W	D4		; D4 <-- largeur	CALL	CONVP3L4	; D3/D4 <-- dans l'cran	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LIB	?DRSEG		; dessine la droite du curseur	JUMP'	80$40$:	LOAD.L	D3,(A6)+OTXCUP	; D3 <-- position	SWAP.W	D3	ADD.W	D3,(A6)+OTXCUB	; D3 <-- centre	SWAP.W	D3	CLR.L	D4	CALL	CONVP3L4	; D3/D4 <-- dans l'cran	PUSH.L	D3	AND.L	D3,#H'FFFF	LOAD.W	D4,(A0)+ODFFDY	SWAP.W	D4	CLR.W	D4	LIB	?DRSEG		; dessine la droite verticale	POP.L	D3	CLR.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	LIB	?DRSEG		; dessine la droite horizontale80$:	CALL	CLOWDO		; fin du dessin dans la swdo90$:	POPM.L	D2..D4	RET;----------\\; TXPCURSOR >;==========/; Positionne le curseur dans un pav de texte.; in	A4.L	^objet;	D4.L	position de la souris; out	D7.W	erreur; mod	D7.WTXPCURSOR:	PUSHM.L	D4,A5	COMP.W	(A4)+OOOBJ,#ICOTX	JUMP',NE 80$	LOAD.L	A5,A4		; A5 <-- ^objet texte	CALL	EDGETPOS	; D4 <-- position dans le buffer	JUMP',NE 80$	CALL	TXPOSITIONNE	; positionne le curseur	JUMP'	90$80$:	LOAD.W	D7,#1		; D7 <-- c'est rat90$:	POPM.L	D4,A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; TXDZONE >;========/; Dessine une zone dans un objet texte.; in	A4.L	^objet texte; out	D4.L	dbut zone;	D5.L	fin zone;	D7.W	erreur; mod	D4.L, D5.L, D7.WTXDZONE:	PUSHM.L	D1..D3,A5	PUSH.L	(A6)+OTXCUP	PUSH.W	(A6)+OTXCUH	PUSH.W	(A6)+OTXCUB	COMP.W	(A4)+OOOBJ,#ICOTX	JUMP,NE 90$	LOAD.L	A5,A4		; A5 <-- ^objet texte	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE 90$	CALL	EDGETPOS	; D4 <-- position dans le buffer	JUMP,NE 90$	LOAD.L	D1,D4		; D1 <-- position dbut	LOAD.L	D2,D4		; D2 <-- position fin20$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	JUMP',NE 80$	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP,NE 20$	CALL	EDGETPOS	; D4 <-- position dans le buffer	JUMP,NE 20$	COMP.L	D4,D2	JUMP,EQ 20$	LOAD.L	D5,D2	CALL	EDINVZONE	; inverse la zone en plus ou en moins	LOAD.L	D2,D4	JUMP	20$80$:	LOAD.L	D4,D1	LOAD.L	D5,D2	CLR.W	D7		; D7 <-- ok90$:	POP.W	(A6)+OTXCUB	POP.W	(A6)+OTXCUH	POP.L	(A6)+OTXCUP	POPM.L	D1..D3,A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; TXEZONE >;========/; Efface une zone dans un objet texte.; in	A4.L	^objet texte;	D4.L	dbut zone;	D5.L	fin zone; out	-; mod	D7.WTXEZONE:	PUSHM.L	A5	COMP.W	(A4)+OOOBJ,#ICOTX	JUMP',NE 90$	LOAD.L	A5,A4		; A5 <-- ^objet texte	CALL	EDINVZONE90$:	POPM.L	A5	RET;----------\\; TXOPMOUSE >;==========/; Effectue une opration selon le mmenu texte.; in	A4.L	^objet texte;	D2.W	opration (dtruit, dplace, etc.);	D3.W	sous-opration (selon sous-menu);	D4.L	dbut zone;	D5.L	fin zone; out	D7.W	erreur; mod	D7.WTXOPMOUSE:	PUSHM.L	D0..D5,A5	LOAD.L	A5,A4		; A5 <-- ^objet texte	COMP.W	(A4)+OOOBJ,#ICOTX	JUMP,NE OK$	COMP.L	D4,D5	JUMP,EQ OK$	JUMP',LO NOEX$	EX.L	D4,D5		; D4 toujours avant D5 !NOEX$:	AND.L	D3,#H'FFFF	COMP.W	D2,#1	JUMP,EQ DETR$	COMP.W	D2,#2	JUMP,EQ DEPL$	COMP.W	D2,#3	JUMP,EQ DUPL$	COMP.W	D2,#4	JUMP,EQ CAR$	COMP.W	D2,#5	JUMP,EQ SOUL$	COMP.W	D2,#6	JUMP,EQ EXP$	COMP.W	D2,#7	JUMP,EQ COUL$	COMP.W	D2,#8	JUMP,EQ MIMA$	JUMP	EXIT$DETR$:	EX.L	D4,D5	CALL	TXPOSITIONNE	; va  la fin	SUB.L	D4,D5		; D4 <-- nombre de caractresDETR2$:	CALL	TXDETRUIT	; dtruit toute la zone	DEC.L	D4	JUMP,NE DETR2$	JUMP	OK$DEPL$:	LOAD.W	D7,#1	JUMP	EXIT$DUPL$:	LOAD.W	D7,#1	JUMP	EXIT$CAR$:	SL.L	D3,#CCGCSHI	; D3 <-- nouveau mode	LOAD.L	D2,#CCGCMSK	; D2 <-- masque	JUMP'	OPER$SOUL$:	SL.L	D3,#8	SL.L	D3,#CCSOSHI-8	; D3 <-- nouveau mode	LOAD.L	D2,#CCSOMSK	; D2 <-- masque	JUMP'	OPER$EXP$:	SL.L	D3,#8	SL.L	D3,#CCEXSHI-8	; D3 <-- nouveau mode	LOAD.L	D2,#CCEXMSK	; D2 <-- masque	JUMP'	OPER$COUL$:	SL.L	D3,#8	SL.L	D3,#8	SL.L	D3,#CCCOSHI-8-8	; D3 <-- nouveau mode	LOAD.L	D2,#CCCOMSK	; D2 <-- masque;	JUMP'	OPER$OPER$:	SUB.L	D5,D4		; D5 <-- nmobre de caractres	CALL	TXMODE		; modifie le mode	JUMP	EXIT$MIMA$:	SUB.L	D5,D4		; D5 <-- nmobre de caractres	CALL	TXPOSITIONNE	; va au dbut de la zone	LOAD.B	D4,#'a	TEST.W	D3	JUMP',EQ MIMA2$	LOAD.B	D4,#'AMIMA2$:	LOAD.B	D3,D4	CALL	EMINMAJ	JUMP',NE EXIT$	CALL	TXAVANCE	JUMP',NE OK$	DEC.L	D5	JUMP,NE MIMA2$;	JUMP'	OK$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D5,A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; EDGETPOS >;=========/; Cherche la position dans le texte en fonction de la; position de la souris.; in	A5.L	^objet texte;	D4.L	position de la souris; out	D4.L	position dans le buffer;	D7.W	erreur; mod	D4.L, D7.WEDGETPOS:	PUSH.L	D3	CALL	DETPOINT	; D3 <-- point o est la souris	JUMP',NE 90$	LOAD.L	(A6)+OTXPMO,D3	LOAD.L	(A6)+OTXPMB,#-1	SET.B	(A6)+OTXFLP	CALL	EDAFTEXT	; OTXPMB <-- position dans le buffer	CLR.B	(A6)+OTXFLP	LOAD.L	D4,(A6)+OTXPMB	; D4 <-- position dans le buffer	COMP.L	D4,#-1	JUMP',NE 90$	LOAD.W	D7,#1		; D7 <-- pas trouv90$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;----------\\; EDINVZONE >;==========/; Inverse une zone.; in	A5.L	^objet texte;	D4.L	dbut zone;	D5.L	fin zone; out	-; mod	D7.WEDINVZONE:	PUSHM.L	D1..D5	COMP.L	D4,D5	JUMP',EQ 90$	JUMP',LO 20$	EX.L	D4,D5		; D4 toujours avant D5 !20$:	LOAD.L	(A6)+OTXZOD,D4	LOAD.L	(A6)+OTXZOF,D5	CALL	OPEWDO		; dessine dans la swdo	LOAD.L	D4,#-1	CALL	DRMDEF		; trame noire	LOAD.W	(A6)+OTXZOP+0,#H'7FFF	CLR.L	(A6)+OTXZOL	SET.B	(A6)+OTXFLZ	CALL	EDAFTEXT	; inverse une zone	CLR.B	(A6)+OTXFLZ	LOAD.W	D1,#-1	CALL	EDIZONECAR	; inverse la dernire zone	CALL	CLOWDO		; fin du dessin dans la swdo90$:	POPM.L	D1..D5	RET;---------\\; EDAFTEXT >;=========/; Affiche tout un pav de texte.; in	A5.L		^objet texte;	D2.W		mode de dessin; out	(A6)+OTXCUP.L	position du curseur; mod	D7.WEDAFTEXT:	PUSHM.L	D1..D4,A4	LOAD.W	(A6)+OTXMOD,D2	; OTXMOD <-- mode	LOAD.L	D3,(A5)+OOTXPOS	LOAD.L	D4,(A5)+OOTXDIM	ADD.W	D3,(A5)+OOTXRMG	SUB.W	D4,(A5)+OOTXRMG	SUB.W	D4,(A5)+OOTXRMD	JUMP,LE 95$	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,(A5)+OOTXRMH	SUB.W	D4,(A5)+OOTXRMH	SUB.W	D4,(A5)+OOTXRMB	JUMP,LE 95$	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A6)+OTXPOS,D3	LOAD.L	(A6)+OTXDIM,D4	LOAD.L	(A6)+OTXPOR,(A5)+OOTXPOC	CALL	TXPSAUVE	; D4 <-- no de la position	PUSH.W	D4		; stack <-- no position initiale	TEST.B	(A6)+OTXFLP	; positionnement ?	JUMP,T	60$		; oui => 60$	TEST.B	(A6)+OTXFLZ	; inversion d'une zone ?	JUMP,T	65$		; oui => 65$	COMP.B	D2,#INVDOT	JUMP,NE 70$	CLR.W	D4	TEST.L	(A5)+OOTXNCI	JUMP',EQ 20$	INC.W	D420$:	TEST.L	(A5)+OOTXNCK	JUMP',EQ 21$	INC.W	D421$:	TEST.L	(A5)+OOTXNCL	JUMP',EQ 22$	INC.W	D422$:	TEST.L	(A5)+OOTXNCM	JUMP',EQ 23$	INC.W	D423$:	COMP.W	D4,#1		; plus d'un paramtre modifi ?	JUMP,NE 80$		; oui => 80$	TEST.L	(A5)+OOTXNCI	JUMP,NE 30$	TEST.L	(A5)+OOTXNCK	JUMP,NE 40$	TEST.L	(A5)+OOTXNCL	JUMP,NE 50$	TEST.L	(A5)+OOTXNCM	JUMP,NE 82$	JUMP	80$30$:				; insertion =>JUMP 80$	CLR.W	D1	LOAD.L	D4,(A5)+OOTXNCI	CALL	EDAFTEXTIFAV	; seulement dans mme ligne ?	JUMP',NE 32$		; non => 32$	INC.W	D1		; D1 <-- juste une ligne32$:	CALL	EDAFLINES	; affiche qq lignes	JUMP	82$40$:				; destruction en arrire =>	JUMP	80$50$:				; destruction en avant =>JUMP 80$	CLR.W	D1	LOAD.L	D4,(A5)+OOTXNCL	NEG.L	D4	CALL	EDAFTEXTIFAV	; seulement dans mme ligne ?	JUMP',NE 52$		; non => 52$	INC.W	D1		; D1 <-- juste une ligne52$:	CALL	EDAFLINES	; affiche qq lignes	JUMP'	82$60$:				; positionnement =>	CALL	EDAFTEXTPOS	JUMP'	82$65$:				; inversion d'une zone =>	CALL	EDAFTEXTINZ	JUMP'	84$70$:	CALL	EDAFTEXTIDEM	; affiche rapidement	JUMP'	82$80$:	CALL	EDAFTEXTALL82$:	CALL	EDAFTEXTCURS	; place le curseur84$:	CLR.L	(A5)+OOTXNCI	CLR.L	(A5)+OOTXNCK	CLR.L	(A5)+OOTXNCL	CLR.L	(A5)+OOTXNCM90$:	POP.W	D4		; D4 <-- no position initiale	CALL	TXPPREND	; remet le curseur o il tait95$:	POPM.L	D1..D4,A4	RET;-------------\\; EDAFTEXTIFAV >;-------------/; Aprs avoir insr (+) ou dtruit (-) des caractres en AVANT,; regarde si la modification n'affecte que la ligne o est le curseur.; En sortie, on est directement positionn au dbut de la ligne;  afficher !; in	A5.L	^objet texte;	D4.L	nb de caractres insrs/dtruits en avant (+/-); out	D2.L	position (y;x);	A4.L	^dans OTLxxx;	D7.W	ok => que la ligne concerne; mod	D2.L, D7.WEDAFTEXTIFAV:	PUSHM.L	D1,D3..D6	LOAD.L	D1,D4		; D1 <-- +/- nb	LOAD.L	D4,(A5)+OOTXPOC	; D4 <-- position actuelle	SUB.L	D4,D1		; D4 <-- ancienne position	LOAD.L	A4,(A5)+OOTXPTL	; A4 <-- ^table OTLxxx	CLR.L	D2		; D2 <-- position20$:	COMP.L	D4,(A4)+OTLPOS	JUMP',LO 24$	LOAD.W	D3,(A4)+OTLIL	JUMP',EQ 22$	ADD.W	D2,D3		; D2 <-- position en Y suivante	LOAD.L	A4,#(A4)+LTL	JUMP	20$22$:	COMP.L	D4,(A4)+OTLPOS	; est-on tout  la fin ?	JUMP,NE 70$		; non => 70$24$:	LOAD.L	A4,#(A4)-LTL	SUB.W	D2,(A4)+OTLIL	SWAP.W	D2	LOAD.B	(A6)+OTXFLI,(A4)+OTLFLI	LOAD.L	D4,(A4)+OTLPOS	CALL	TXQPOSITIONNE	; va au dbut de la ligne	PUSH.W	(A6)+OTXPOS+2	PUSH.W	(A6)+OTXDIM+2	TEST.B	(A6)+OTXFLI	; premire ligne ?	JUMP',F 40$		; non => 40$	LOAD.W	D3,(A5)+OOTXRMR	SUB.W	D3,(A5)+OOTXRMG	LOAD.W	D4,(A6)+OTXDIM+2	SUB.W	D4,D3	JUMP',LE 40$	LOAD.W	(A6)+OTXDIM+2,D4	ADD.W	(A6)+OTXPOS+2,D340$:	CALL	EDCOUPELINE	; D3/D4/D5/D6 <-- paramtres	POP.W	(A6)+OTXDIM+2	POP.W	(A6)+OTXPOS+2	AND.L	D3,#H'FFFF	; D3 <-- nb car dans nouvelle ligne	LOAD.L	D4,(A4)+LTL+OTLPOS	SUB.L	D4,(A4)+OTLPOS	; D4 <-- nb car dans ancienne ligne	ADD.L	D4,D1	COMP.L	D4,D3	JUMP',NE 80$	PUSH.L	A450$:	LOAD.L	A4,#(A4)+LTL	ADD.L	(A4)+OTLPOS,D1	; ajuste la fin de la table	TEST.W	(A4)+OTLIL	JUMP,NE 50$	POP.L	A4	CLR.W	D7		; D7 <-- dans mme ligne	JUMP'	90$70$:	LOAD.L	A4,(A5)+OOTXPTL	; A4 <-- ^table OTLxxx	CLR.L	D2	CLR.L	D4	CALL	TXQPOSITIONNE	; va au dbut du texte	SET.B	(A6)+OTXFLI80$:	LOAD.W	D7,#190$:	POPM.L	D1,D3..D6	TEST.W	D7		; retour EQ/NE	RET;------------\\; EDAFTEXTPOS >;------------/; Trouve la position dans le buffer en fonction de la position; de la souris.; in	(A6)+OTXPMO.L	position de la souris (y;x); out	(A6)+OTXPMB.L	position dans le buffer; mod	D7.WEDAFTEXTPOS:	PUSHM.L	D0..D4,A4	TEST.L	(A5)+OOTXPTL	JUMP,EQ 90$	LOAD.L	A4,(A5)+OOTXPTL	; A4 <-- ^table OTLxxx	CLR.L	D2		; D2 <-- position20$:	TEST.W	(A4)+OTLIL	JUMP,EQ 90$	LOAD.W	D1,D2	ADD.W	D1,(A6)+OTXPOS+0	LOAD.W	D0,(A6)+OTXPMO+0 ; D0 <-- position de la souris (y)	COMP.W	D0,D1		; trop en haut ?	JUMP',LT 26$	ADD.W	D1,(A4)+OTLIL	COMP.W	D0,D1		; trop en bas ?	JUMP',LT 30$26$:	ADD.W	D2,(A4)+OTLIL	; D2 <-- position en Y suivante	LOAD.L	A4,#(A4)+LTL	JUMP	20$30$:	SWAP.W	D2	LOAD.B	(A6)+OTXFLI,(A4)+OTLFLI	LOAD.W	(A6)+OTXMH1,(A4)+OTLH1	LOAD.W	(A6)+OTXMH2,(A4)+OTLH2	LOAD.W	(A6)+OTXMIL,(A4)+OTLIL	LOAD.L	D4,(A4)+OTLPOS	CALL	TXQPOSITIONNE	; va au dbut de la ligne	CALL	EDAFLINE	; positionne le curseur90$:	POPM.L	D0..D4,A4	RET;------------\\; EDAFTEXTINZ >;------------/; Inverse une zone (mise en vidence).; in	(A6)+OTXZOD.L	dbut zone;	(A6)+OTXZOF.L	fin zone; out	-; mod	D7.WEDAFTEXTINZ:	PUSHM.L	D0..D4,A4	TEST.L	(A5)+OOTXPTL	JUMP,EQ 90$	LOAD.L	A4,(A5)+OOTXPTL	; A4 <-- ^table OTLxxx	LOAD.L	D0,(A6)+OTXZOD	LOAD.L	D1,(A6)+OTXZOF	CLR.L	D2		; D2 <-- position20$:	TEST.W	(A4)+OTLIL	JUMP,EQ 90$	COMP.L	D0,(A4)+LTL+OTLPOS	JUMP',HI 40$	COMP.L	D1,(A4)+OTLPOS	JUMP',LO 40$	LOAD.B	(A6)+OTXFLI,(A4)+OTLFLI	LOAD.W	(A6)+OTXMH1,(A4)+OTLH1	LOAD.W	(A6)+OTXMH2,(A4)+OTLH2	LOAD.W	(A6)+OTXMIL,(A4)+OTLIL	LOAD.L	D4,(A4)+OTLPOS	CALL	TXQPOSITIONNE	; va au dbut de la ligne	PUSH.L	D2	SWAP.W	D2	CALL	EDAFLINE	; inverse une partie de la zone	POP.L	D240$:	ADD.W	D2,(A4)+OTLIL	; D2 <-- position en Y suivante	LOAD.L	A4,#(A4)+LTL	JUMP	20$90$:	POPM.L	D0..D4,A4	RET;-------------\\; EDAFTEXTCURS >;-------------/; Place simplement le curseur dans un texte qui n'a pas chang.; in	-; out	-; mod	D7.WEDAFTEXTCURS:	PUSHM.L	D2..D4,A4	LOAD.L	(A6)+OTXCUP,#-1	TEST.L	(A5)+OOTXPTL	JUMP,EQ 90$	LOAD.L	A4,(A5)+OOTXPTL	; A4 <-- ^table OTLxxx	LOAD.L	D4,(A6)+OTXPOR	CLR.L	D2		; D2 <-- position20$:	COMP.L	D4,(A4)+OTLPOS	JUMP',LO 24$	LOAD.W	D3,(A4)+OTLIL	JUMP',EQ 24$	ADD.W	D2,D3		; D2 <-- position en Y suivante	LOAD.L	A4,#(A4)+LTL	JUMP	20$24$:	LOAD.L	A4,#(A4)-LTL	SUB.W	D2,(A4)+OTLIL	SWAP.W	D2	LOAD.B	(A6)+OTXFLI,(A4)+OTLFLI	LOAD.W	(A6)+OTXMH1,(A4)+OTLH1	LOAD.W	(A6)+OTXMH2,(A4)+OTLH2	LOAD.W	(A6)+OTXMIL,(A4)+OTLIL	LOAD.L	D4,(A4)+OTLPOS	CALL	TXQPOSITIONNE	; va au dbut de la ligne	SET.B	(A6)+OTXFLC	; dplacement du curseur	CALL	EDAFLINE	; positionne le curseur	CLR.B	(A6)+OTXFLC	COMP.L	(A6)+OTXCUP,#-1	; position du curseur trouve ?	JUMP,NE 90$		; oui => 90$	COMP.B	D3,#CR	JUMP',EQ 50$	SWAP.W	D2	SUB.W	D2,(A6)+OTXMIL	; Y <-- ligne prcdente	SWAP.W	D2	JUMP'	60$50$:	CLR.W	D2		; X <-- au dbut de la ligne	SET.B	(A6)+OTXFLI60$:	TEST.B	(A6)+OTXFLI	; premire ligne ?	JUMP',F 62$		; non => 62$	ADD.W	D2,(A5)+OOTXRMR	SUB.W	D2,(A5)+OOTXRMG62$:	ADD.W	D2,(A6)+OTXPOS+2	SWAP.W	D2	ADD.W	D2,(A6)+OTXPOS+0	SWAP.W	D2	LOAD.L	(A6)+OTXCUP,D2	; OTXCUP <-- position du curseur	LOAD.W	D2,(A6)+OTXMH1	LOAD.W	(A6)+OTXCUB,D2	; OTXCUB <-- base du curseur	ADD.W	D2,(A6)+OTXMH2	LOAD.W	(A6)+OTXCUH,D2	; OTXCUH <-- hauteur du curseur90$:	POPM.L	D2..D4,A4	RET;-------------\\; EDAFTEXTIDEM >;-------------/; Affiche tout un pav de texte non modifi.; in	A5.L	^objet texte; out	-; mod	D7.WEDAFTEXTIDEM:	TEST.L	(A5)+OOTXPTL	JUMP,EQ EDAFTEXTALL	PUSHM.L	D2..D4,A4	LOAD.L	A4,(A5)+OOTXPTL	; A4 <-- ^dans OTLxxx	CLR.L	D2		; D2 <-- tout en haut	LOAD.W	D3,(A5)+OOTXITC+2	TEST.B	(A5)+OOTXITC+1:#BTXICM-16	JUMP',BC 10$	NEG.W	D310$:	ADD.W	(A6)+OTXDIM+2,D320$:	TEST.W	(A4)+OTLIL	JUMP,EQ 90$	LOAD.W	D3,D2	ADD.W	D3,(A6)+OTXPOS+0	SUB.W	D3,(A6)+OPPOS+0	CALL	DETSCALEP	; D3 <-- plus grand (si n:1)	COMP.W	D3,(A0)+ODFFDY	JUMP',GE 50$	LOAD.W	D4,D3	LOAD.W	D3,(A4)+OTLIL	CALL	DETSCALEP	; D3 <-- plus grand (si n:1)	ADD.W	D3,D4	JUMP',NS 50$	LOAD.L	D4,(A4)+OTLPOS	CALL	TXQPOSITIONNE	; va au dbut de la ligne	LOAD.B	(A6)+OTXFLI,(A4)+OTLFLI	LOAD.W	(A6)+OTXMH1,(A4)+OTLH1	LOAD.W	(A6)+OTXMH2,(A4)+OTLH2	LOAD.W	(A6)+OTXMIL,(A4)+OTLIL	PUSH.L	D2	SWAP.W	D2	CALL	EDAFLINE	; affiche une ligne	POP.L	D2	TEST.W	D7	JUMP',NE 90$		; si dbordement => 90$50$:	ADD.W	D2,(A4)+OTLIL	; D2 <-- position suivante	ADD.L	A4,#LTL		; A4 <-- ^suivant dans OTLxxx	JUMP	20$90$:	POPM.L	D2..D4,A4	RET;------------\\; EDAFTEXTALL >;------------/; Affiche compltement tout un pav de texte.; in	A5.L	^objet texte; out	-; mod	D7.WEDAFTEXTALL:	PUSHM.L	D1..D4,A4	CALL	EDNEWTL		; rserve un nouveau buffer OTLxxx	JUMP',NE 90$	CLR.L	D4	CALL	TXQPOSITIONNE	; revient au dbut	LOAD.L	A4,(A5)+OOTXPTL	; A4 <-- ^dans OTLxxx	CLR.L	D2		; D2 <-- tout en haut	CLR.W	D1		; D1 <-- toutes les lignes	SET.B	(A6)+OTXFLI	; premire ligne	CALL	EDAFLINES90$:	POPM.L	D1..D4,A4	RET;----------\\; EDAFLINES >;----------/; Affiche quelques lignes d'un pav de texte.; in	A5.L	^objet texte;	A4.L	^dans OTLxxx;	D2.L	position initiale (y;x);	D1.W	nb de lignes (zro si toutes); out	-; mod	D7.WEDAFLINES:	PUSHM.L	D1..D4,A2,A4	LOAD.W	D3,(A5)+OOTXITC+2	TEST.B	(A5)+OOTXITC+1:#BTXICM-16	JUMP',BC 10$	NEG.W	D310$:	ADD.W	(A6)+OTXDIM+2,D3	JUMP'	30$20$:	SET.B	(A6)+OTXFLI	; premire ligne	COMP.B	D3,#CR	JUMP',EQ 30$	COMP.B	D3,#EOP	JUMP',EQ 30$	CLR.B	(A6)+OTXFLI	; ligne(s) suivante(s)30$:	LOAD.L	(A4)+OTLPOS,(A5)+OOTXPOC	LOAD.B	(A4)+OTLFLI,(A6)+OTXFLI	CLR.W	(A6)+OTXMIL	; faudra refaire EDMAXH1H2	CALL	EDAFLINE	; affiche une ligne	JUMP',NE 60$		; si dbordement => 60$	LOAD.W	(A4)+OTLH1,(A6)+OTXMH1	LOAD.W	(A4)+OTLH2,(A6)+OTXMH2	LOAD.W	(A4)+OTLIL,(A6)+OTXMIL	ADD.L	A4,#LTL		; A4 <-- ^suivant dans OTLxxx	LOAD.L	(A4)+OTLPOS,(A5)+OOTXPOC	COMP.B	D3,#EOP	JUMP',EQ 60$	LOAD.L	D4,(A5)+OOTXPOC	COMP.L	D4,(A5)+OOTXNBC	; fin du pav de texte ?	JUMP',HS 60$		; oui => 60$	DEC.W	D1		; encore une ligne ?	JUMP,NE 20$		; oui => 20$60$:	CLR.W	(A4)+OTLIL	POPM.L	D1..D4,A2,A4	RET;--------\\; EDNEWTL >;--------/; Rserve de la mmoire pour un nouveau buffer OTLxxx.; in	A5.L	^objet texte; out	-; mod	D7.WEDNEWTL:	PUSHM.L	D1..D4,A4; Libre ventuellement l'ancien buffer.	TEST.L	(A5)+OOTXPTL	JUMP',EQ 20$	LOAD.L	A4,(A5)+OOTXPTL	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire OTLxxx	CLR.L	(A5)+OOTXPTL; Cherche l'interligne minimal dans D2.W.20$:	LOAD.L	D2,(A5)+OOTXITL	TEST.L	D2:#BTXILF	; interligne fixe ?	JUMP',BS 40$	LOAD.L	A4,#(A6)+OBUGC	LOAD.W	D4,#MAXGC-1	LOAD.W	D3,#-122$:	TEST.B	(A4)+OGCFLG:#BGCUSE	JUMP',BC 24$	LOAD.W	D1,(A4)+OGC1Y	ADD.W	D1,(A4)+OGC2Y	COMP.W	D3,D1	JUMP',LS 24$	LOAD.W	D3,D1		; D3 <-- interligne le plus petit24$:	LOAD.L	A4,#(A4)+LGGC	; A4 <-- ^gencar suivant	DECJ.W,NMO D4,22$	COMP.W	D2,D3	JUMP',HS 40$	LOAD.W	D2,D3		; D2 <-- interligne le plus petit possible; Calcule le nombre maximal de lignes possibles.40$:	CLR.L	D4	LOAD.W	D4,(A5)+OOTXDIM+0 ; D4 <-- hauteur maximale du pav	DIV.WU	D4,D2		; D4 <-- nb max de lignes possibles	ADD.W	D4,#10		; D4 <-- p'tite rserve !	LOAD.W	(A5)+OOTXNTL,D4	MUL.WU	D4,#LTL	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^nouveau buffer OTLxxx	JUMP',NE 90$	LOAD.L	(A5)+OOTXPTL,A490$:	POPM.L	D1..D4,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; EDAFLINE >;---------/; Affiche toute une ligne complte en entier et intgralement (mais si).; Avance le curseur au dbut de la ligne suivante.; in	D2.L	position;	A5.L	^objet texte; out	D2.L	^plus loin;	D3.B	dernier caractre;	D7.W	NE => dbordement; mod	D2.L, D3.L, D7.WEDAFLINE:	PUSHM.L	D0,D1,D4..D6,A4	PUSH.W	(A6)+OTXPOS+2	PUSH.W	(A6)+OTXDIM+2	TEST.B	(A6)+OTXFLI	; premire ligne ?	JUMP',F 02$		; non => 02$	LOAD.W	D3,(A5)+OOTXRMR	SUB.W	D3,(A5)+OOTXRMG	LOAD.W	D4,(A6)+OTXDIM+2	SUB.W	D4,D3	JUMP',LE 02$	LOAD.W	(A6)+OTXDIM+2,D4	ADD.W	(A6)+OTXPOS+2,D302$:	CALL	EDCOUPELINE	; D3/D4/D5/D6 <-- paramtres	LOAD.W	A4,D3		; A4 <-- nb de caractres	CALL	EDCALCSAJEX	; D0/D5 <-- reste/nb pour les SAJEXs	TEST.W	(A6)+OTXMIL	; h1/h2 dj connus ?	JUMP',NE 04$		; oui => 04$	CALL	EDMAXH1H2	; OTXMH1/H2 <-- max h1/h204$:	LOAD.W	D7,#1		; D7 <-- a dborde	CLR.W	D2		; X <-- au dbut de la ligne	SWAP.W	D2	ADD.W	D2,(A6)+OTXMH1	LOAD.W	D3,D2	SWAP.W	D2	ADD.W	D3,(A6)+OTXMH2	COMP.W	D3,(A6)+OTXDIM+0 ; dpasse le bas du pav ?	JUMP,HI 90$		; oui => 90$; Met ventuellement quelques espaces au dbut de la ligne pour; justifier dans les modes drapeau  gauche et centr.	LOAD.W	D3,(A6)+OTXDIM+2	SUB.W	D3,D4		; D3 <-- largeur laisse vide	JUMP,LO 15$	TEST.B	(A5)+OOTXJUS+1:#BTXJUG-16 ; drapeau  gauche ?	JUMP',BS 10$	SR.W	D3,#1	TEST.B	(A5)+OOTXJUS+1:#BTXJUC-16 ; centr ?	JUMP',BC 15$10$:	PUSH.L	D5	CLR.L	D5	LOAD.W	D5,D3	PUSH.B	(A6)+OTXFLZ	PUSH.B	(A6)+OTXFLP	CLR.B	(A6)+OTXFLZ	; n'inverse pas la zone	CLR.B	(A6)+OTXFLP	; ne positionne pas	CALL	EDAFSAJEX	; affiche un sajex au dbut de la ligne	POP.B	(A6)+OTXFLP	POP.B	(A6)+OTXFLZ	POP.L	D5; Affiche tous les caractres de la ligne.15$:	LOAD.W	D4,A4		; D4 <-- nb de caractres	LOAD.B	D3,#SPACE20$:	LOAD.B	D1,D3		; D1 <-- dernier caractre	TEST.W	D4	JUMP,EQ 30$	DEC.W	D4	PUSHM.L	D0,D5	LOAD.L	D0,D2		; D0 <-- position avant le caractre	CALL	TXAVANCE	; D3 <-- caractre suivant	CALL	EDAFCAR		; affiche un caractre	TEST.B	(A6)+OTXFLC	; dplacement du curseur ?	JUMP',F 23$		; non => 23$	LOAD.L	D5,(A5)+OOTXPOC	DEC.L	D5	COMP.L	D5,(A6)+OTXPOR	; est-on sur le curseur ?	JUMP',NE 23$		; non => 23$				; oui =>	ADD.W	D0,(A6)+OTXPOS+2	SWAP.W	D0	ADD.W	D0,(A6)+OTXPOS+0	SUB.W	D0,(A6)+OTXMH1	SWAP.W	D0	LOAD.L	(A6)+OTXCUP,D0	; OTXCUP <-- position du curseur	LOAD.W	D0,(A6)+OTXMH1	LOAD.W	(A6)+OTXCUB,D0	; OTXCUB <-- base du curseur	ADD.W	D0,(A6)+OTXMH2	LOAD.W	(A6)+OTXCUH,D0	; OTXCUH <-- hauteur du curseur23$:	POPM.L	D0,D5	TEST.B	(A5)+OOTXJUS+1:#BTXJUA-16 ; align ?	JUMP,BC 20$		; non => 20$				; oui =>	COMP.B	D3,#SPACE	JUMP',NE 26$	COMP.B	D3,D1		; dernier caractre tait dj un espace ?	JUMP',EQ 26$		; oui => 26$	TEST.B	(A5)+OOTXJUS+3	JUMP',EQ 27$	CLR.L	D3	LOAD.B	D3,(A5)+OOTXJUS+3	SUB.L	D3,#100	NEG.L	D3	DIV.WU	D3,#525$:	CALL	EDAFSAJEX	; affiche un "sajex"	DEC.W	D3	JUMP,NC 25$	LOAD.B	D3,#SPACE	JUMP	20$26$:	TEST.B	(A5)+OOTXJUS+3	; espacement entre les caractres ?	JUMP,EQ 20$		; non => 20$27$:	CALL	EDAFSAJEX	; affiche un "sajex"	JUMP	20$; Affiche l'ventuel caractre de fin de ligne.30$:	LOAD.L	D3,D6	TEST.B	D3	JUMP',EQ 42$	COMP.B	D3,#-1	JUMP',EQ 42$	COMP.B	D3,#SPACE	JUMP',EQ 42$	COMP.B	D3,#TAB	JUMP',EQ 42$	COMP.B	D3,#CR	JUMP',EQ 42$	COMP.B	D3,#EOP	JUMP',EQ 42$	CALL	EDAFCAR		; affiche le tiret42$:	SWAP.W	D2	SUB.W	D2,(A6)+OTXMH1	ADD.W	D2,(A6)+OTXMIL	; Y <-- ligne suivante	SWAP.W	D2	CLR.W	D7		; D7 <-- ok90$:	POP.W	(A6)+OTXDIM+2	POP.W	(A6)+OTXPOS+2	POPM.L	D0,D1,D4..D6,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; EDCALCSAJEX >;------------/; Calcul la largeur des "sajex" en mode align.; in	A4.W	nb de caractres;	D4.W	largeur de la ligne;	D5.W	nb d'espaces;	D6.B	dernier caractre (zro/SPACE/tiret/CR); out	D5.L	reste/nb pour les SAJEXs;	D0.L	rpartiteur du reste; mod	D0.L, D5.L, D7.WEDCALCSAJEX:	PUSHM.L	D3,D4	COMP.B	D6,#CR		; fin de ligne force ?	JUMP,EQ 80$		; oui => 80$	COMP.B	D6,#EOP		; fin du texte ?	JUMP,EQ 80$		; oui => 80$	COMP.B	D6,#-1		; fin du texte ?	JUMP,EQ 80$		; oui => 80$	COMP.B	D6,#TAB		; tabulateur ?	JUMP,EQ 80$		; oui => 80$	CLR.L	D3	LOAD.B	D3,(A5)+OOTXJUS+3 ; espaces entre tous les caractres ?	JUMP',EQ 40$		; non => 40$				; oui =>	SUB.L	D3,#100	NEG.L	D3	DIV.WU	D3,#5	MUL.WU	D5,D3	ADD.W	D5,A4		; D5 <-- nb de caractres + nb d'espaces	DEC.W	D5	COMP.B	D6,#SPACE	JUMP',NE 30$	DEC.W	D530$:	COMP.B	D6,#'-	JUMP',NE 40$	INC.W	D540$:	CLR.L	D3	LOAD.W	D3,(A6)+OTXDIM+2	SUB.W	D3,D4		; D3 <-- largeur laisse vide	TEST.W	D5	JUMP',LE 80$	CLR.L	D0	LOAD.W	D0,D5	DIV.WU	D3,D5	LOAD.L	D5,D3		; D5 <-- reste/nb	SWAP.W	D3	TEST.W	D3	JUMP',EQ 85$	DIV.WU	D0,D3	LOAD.W	D3,D0	SWAP.W	D0	LOAD.W	D0,D3	SR.W	D0,#1		; D0 <-- rpartiteur du reste	JUMP',NE 90$	INC.W	D0	JUMP'	90$80$:	CLR.L	D5		; D5 <-- n'aligne pas !85$:	CLR.L	D090$:	POPM.L	D3,D4	RET;------------\\; EDCOUPELINE >;------------/; Dtermine o il faut couper dans une ligne trop longue.; N'avance pas le curseur dans la ligne !; in	A5.L	^objet texte; out	D3.W	nb de caractre  avancer (0..n);	D4.W	largeur de la ligne;	D5.W	nb d'espaces (0..n);	D6.B	dernier caractre (zro/SPACE/tiret/CR/EOP/-1); mod	D3.L, D4.L, D5.L, D6.L, D7.WEDCOUPELINE:	PUSHM.L	D0..D2,A4	CALL	TXPSAUVE	; D4 <-- no de la position	PUSH.W	D4		; stack <-- no position dbut ligne	CLR.W	D2		; D2 <-- nb caractres dans dernier mot	CLR.W	D4		; D4 <-- position dans la ligne	CLR.W	D5		; D5 <-- nb d'espaces10$:	COMP.W	D4,(A6)+OTXDIM+2 ; largeur ligne atteinte ?	JUMP,HI 40$		; oui => 40$	CALL	TXAVANCE	; D3 <-- caractre suivant	JUMP,NE 75$	COMP.B	D3,#CR	JUMP,EQ 70$	COMP.B	D3,#EOP	JUMP,EQ 70$	COMP.B	D3,#TAB	JUMP,EQ 30$	INC.W	D2		; D2 <-- +1 caractre	CALL	EDGETLGC	; D1 <-- largeur du caractre	ADD.W	D4,D1		; D4 <-- avance dans la ligne	COMP.B	D3,#SPACE	JUMP,EQ 10$20$:	COMP.W	D4,(A6)+OTXDIM+2 ; largeur ligne atteinte ?	JUMP,HI 40$		; oui => 40$	CALL	TXAVANCE	; D3 <-- caractre suivant	JUMP,NE 75$	COMP.B	D3,#CR	JUMP,EQ 70$	COMP.B	D3,#EOP	JUMP,EQ 70$	COMP.B	D3,#TAB	JUMP,EQ 30$	INC.W	D2		; D2 <-- +1 caractre	CALL	EDGETLGC	; D1 <-- largeur du caractre	ADD.W	D4,D1		; D4 <-- avance dans la ligne	COMP.B	D3,#SPACE	JUMP,NE 20$	CLR.W	D2		; D2 <-- rz avance dans mot	INC.W	D5		; D5 <-- +1 espace	JUMP	10$30$:				; tabulateur =>	LOAD.W	D2,D4	CALL	RGNEXT		; D2 <-- position suivante	JUMP',NE 34$	COMP.W	D2,(A6)+OTXDIM+2 ; largeur ligne atteinte ?	JUMP',HI 34$		; oui => 34$	LOAD.W	D4,D2	CLR.W	D2		; D2 <-- rz avance dans mot	JUMP	10$34$:	CALL	TXRECULE	; recule le tabulateur	LOAD.B	D6,#TAB	JUMP	90$40$:	TEST.W	D5		; un seul mot ?	JUMP',NE 50$		; non => 50$				; oui =>	CALL	TXRECULE	; D3 <-- caractre prcdent	CALL	EDGETLGC	; D1 <-- largeur du caractre	SUB.W	D4,D1		; D4 <-- recule dans la ligne	LOAD.W	D1,D4	CALL	TXPSAUVE	; D4 <-- no de la position	PUSH.W	D4	LOAD.W	D4,(SP)+2	; D4 <-- no position dbut ligne	CALL	TXPREMET	; revient au dbut de la ligne	LOAD.W	D4,D1	LOAD.W	D2,(A6)+OTXDIM+2 ; D2 <-- lg max coupable	CALL	EDCOUPEMOT	; essaye de couper dans le mot suivant	JUMP',NE 44$	POP.W	D4		; D4 <-- no position fin ligne	CALL	TXPANNULE	LOAD.W	D4,D2		; D4 <-- largeur de la ligne	JUMP'	58$44$:	LOAD.W	D1,D4	POP.W	D4		; D4 <-- no position fin ligne	CALL	TXPPREND	; va  la fin de la ligne	LOAD.W	D4,D1	CLR.B	D6	JUMP	90$50$:	DEC.W	D5		; D5 <-- ne compte pas le dernier espace	TEST.W	D2	JUMP',EQ 54$52$:	CALL	TXRECULE	; D3 <-- caractre prcdent	CALL	EDGETLGC	; D1 <-- largeur du caractre	SUB.W	D4,D1		; D4 <-- recule dans la ligne	DEC.W	D2	JUMP,NE 52$54$:	LOAD.W	D2,(A6)+OTXDIM+2	SUB.W	D2,D4		; D2 <-- lg max coupable	CALL	TXRECULE	; D3 <-- caractre prcdent (espace)	CALL	EDGETLGC	; D1 <-- largeur du dernier espace	SUB.W	D4,D1		; D4 <-- n'affiche pas le dernier espace	CALL	TXAVANCE	; annule le TXRECULE !	CALL	EDCOUPEMOT	; essaye de couper dans le mot suivant	JUMP',NE 60$	INC.W	D5		; D5 <-- un mot de plus	ADD.W	D4,D2		; D4 <-- reste	ADD.W	D4,D1		; D4 <-- ajoute le dernier espace58$:	TEST.L	D2:#16		; tiret dj dans le mot ?	JUMP',BC 90$		; non => 90$	CLR.B	D6	JUMP'	90$60$:	LOAD.B	D6,#SPACE	JUMP'	90$70$:	LOAD.B	D6,D3		; D6 <-- CR/EOP	JUMP'	90$75$:	LOAD.B	D6,#-1		; D6 <-- EOT90$:	LOAD.L	D3,(A5)+OOTXPOC	LOAD.W	D1,D4	POP.W	D4		; D4 <-- no position dbut ligne	CALL	TXPPREND	; revient au dbut de la ligne	LOAD.W	D4,D1	SUB.L	D3,(A5)+OOTXPOC	; D3 <-- nb de caractre  avancer	POPM.L	D0..D2,A4	RET;-----------\\; EDCOUPEMOT >;-----------/; Essaye de couper dans un mot.;;	   D2;	|<---->|;	 construction;	 ^;	 A3; in	A5.L	^objet texte;	D2.W	lg max coupable; out	D2.W	lg rcupre grce  la coupure;		si 2^16 = 1 --> tiret dj dans le mot;	D6.L	caractre tiret (si D2:#16=0);	D7.W	ok/erreur; mod	D2.L, D6.L, D7.WEDCOUPEMOT:	PUSHM.L	D0,D1,D3..D5,A1,A3,A4	CALL	TXPSAUVE	PUSH.W	D4		; stack <-- no position dbut mot	LOAD.W	D5,D2		; D5 <-- lg max coupable	JUMP,LE 80$	TEST.B	(A5)+OOTXJUS+1:#BTXJUM-16 ; autorise les divisions dans les mots ?	JUMP,BC 80$		; non => 80$	LOAD.W	D3,D2	MUL.WU	D3,#100	DIV.WU	D3,(A6)+OTXDIM+2 ; D3 <-- lg max coupable en %	CLR.W	D4	LOAD.B	D4,(A5)+OOTXJUS+2	COMP.W	D3,D4	JUMP,LO 80$	LOAD.L	A3,#(A6)+OBUMOT	; A3 <-- ^buffer pour mot	LOAD.L	A1,#(A6)+OBULMO	; A1 <-- ^buffer pour lg caractres	LOAD.W	D4,#LBUMOT-1	; D4 <-- nb car. max pour le mot	CLR.W	D0		; D0 <-- position dans le mot	CLR.W	D2		; D2 <-- compte nb car. avancs	CLR.L	D610$:	CALL	TXAVANCE	; D3 <-- caractre suivant	JUMP',NE 20$	TEST.L	D6	JUMP',NE 12$	LOAD.L	D6,D3		; D6 <-- premier caractre du mot12$:	COMP.B	D3,#SPACE	; fin du mot ?	JUMP',EQ 20$		; oui => 20$	COMP.B	D3,#TAB	JUMP',EQ 20$	COMP.B	D3,#CR	JUMP',EQ 20$	COMP.B	D3,#EOP	JUMP',EQ 20$	INC.W	D2		; D2 <-- +1 caractre avanc	LOAD.B	(A3+),D3	; OBUMOT <-- un caractre	LOAD.W	(A1+),D0	; OBULMO <-- position	CALL	EDGETLGC	; D1 <-- largeur du caractre	ADD.W	D0,D1		; D0 <-- position dans le mot	DEC.W	D4	JUMP,NE	10$	JUMP	80$20$:	TEST.W	D2	JUMP,EQ 80$	LOAD.L	A3,#(A6)+OBUMOT	; A3 <-- ^mot	LOAD.W	D3,D2		; D3 <-- lg mot	LOAD.L	A4,#(A6)+OBUCOUP ; A4 <-- ^buffer	LOAD.W	D4,#LBUCOUP	; D4 <-- lg buffer	COUPE_	HASH		; cherche la liste des coupures	JUMP,NE 80$; Cherche la coupure optimale dans la liste rendue.	LOAD.B	D6,#'-	LOAD.L	D3,D6		; D3 <-- tiret avec gencar 1er car. du mot	CALL	EDGETLGC	; D1 <-- largeur d'un "-"	CLR.W	D430$:	INC.W	D4	TEST.B	(A4+)	JUMP,NE	30$	DEC.L	A4		; A4 <-- ^dernire coupure	LOAD.L	A1,#(A6)+OBULMO	; A1 <-- ^buffer pour lg caractres40$:	DEC.W	D4	JUMP,EQ 80$	CLR.W	D3	LOAD.B	D3,(-A4)	; D3 <-- position coupure (nb car)	JUMP,EQ 80$	JUMP',NS 50$				; coupe en ajoutant un tiret =>	SL.W	D3,#1	LOAD.W	D2,(A1)+(D3.W)	; D2 <-- lg du mot jusque l	ADD.W	D2,D1		; D2 <-- lg du mot avec le tiret	COMP.W	D2,D5		; reste assez de place en bout de ligne ?	JUMP,HI 40$		; non => 40$	SR.W	D3,#1	TCLR.L	D2:#16	JUMP'	60$50$:				; coupe sans ajouter de tiret =>	TCLR.L	D3:#7	SL.W	D3,#1	LOAD.W	D2,(A1)+(D3.W)	; D2 <-- lg du mot jusque l	COMP.W	D2,D5		; reste assez de place en bout de ligne ?	JUMP,HI 40$		; non => 40$	SR.W	D3,#1	TSET.L	D2:#1660$:	POP.W	D4		; D4 <-- no position dbut mot	CALL	TXPPREND	; revient o l'on tait	LOAD.W	D4,D362$:	CALL	TXAVANCE	DEC.W	D4	JUMP,NE 62$	CLR.W	D7		; D7 <-- coupure effectue	JUMP'	90$80$:	POP.W	D4		; D4 <-- no position dbut mot	CALL	TXPPREND	; revient o l'on tait	LOAD.W	D7,#1		; D7 <-- coupure pas faite !90$:	POPM.L	D0,D1,D3..D5,A1,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; EDMAXH1H2 >;----------/; Cherche les valeurs maximales pour h1 et h2.; in	D3.W		nb de caractre  avancer (0..n); out	(A6)+OTXMH1.W	h1 max;	(A6)+OTXMH2.W	h2 max;	(A6)+OTXMIL.W	interligne; mod	D7.WEDMAXH1H2:	PUSHM.L	D0..D4,A2	CALL	TXPSAUVE	; D4 <-- no de la position	PUSH.W	D4		; stack <-- no position dbut ligne	CLR.W	D0		; D0 <-- h1 max	CLR.W	D1		; D1 <-- h2 max	LOAD.W	D2,D3	JUMP',EQ 50$20$:	CALL	TXAVANCE	; D3 <-- caractre suivant	JUMP',NE 50$	CALL	EDPTGC		; A2 <-- ^dans OBUGC	COMP.W	D0,(A2)+OGC1Y	JUMP',HS 30$	LOAD.W	D0,(A2)+OGC1Y	; D0 <-- h1 max30$:	COMP.W	D1,(A2)+OGC2Y	JUMP',HS 32$	LOAD.W	D1,(A2)+OGC2Y	; D1 <-- h2 max32$:	DEC.W	D2	JUMP,NE 20$50$:	LOAD.W	D2,D0	OR.W	D2,D1		; h1 et h2 nuls ?	JUMP',NE 60$		; non => 60$	LOAD.W	D0,(A6)+OBUGC+OGC1Y	LOAD.W	D1,(A6)+OBUGC+OGC2Y60$:	LOAD.W	(A6)+OTXMH1,D0	LOAD.W	(A6)+OTXMH2,D1	LOAD.L	D4,(A5)+OOTXITL	TEST.L	D4:#BTXILF	JUMP',BS 70$	LOAD.W	D2,D0	ADD.W	D2,D1	COMP.W	D4,D2	JUMP',HS 70$	LOAD.W	D4,D270$:	LOAD.W	(A6)+OTXMIL,D4	POP.W	D4		; D4 <-- no position dbut ligne	CALL	TXPPREND	; revient au dbut de la ligne	POPM.L	D0..D4,A2	RET;----------\\; EDAFSAJEX >;----------/; Affiche un sajex (en ralit, avance sans rien afficher).; in	D2.L	position (y;x);	D5.L	reste/nb;	D0.L	rpartiteur du reste; out	D2.L	position suivante (y;x);	D5.L	nouveau reste;	D0.L	nouvelle rpartition du reste; mod	D0.L, D2.L, D5.L, D7.WEDAFSAJEX:	PUSH.W	D1	LOAD.W	D1,D5		; D1 <-- avance selon "nb"	TEST.W	D0	JUMP',EQ 20$	DEC.W	D0	JUMP',NE 40$	SWAP.W	D0	PUSH.W	D0	SWAP.W	D0	POP.W	D0		; D0[low] <-- D0[high]20$:	SWAP.W	D5	TEST.W	D5		; encore un reste ?	JUMP',EQ 30$		; non => 30$	DEC.W	D5		; D5 <-- un reste de moins	INC.W	D1		; D1 <-- avance selon "reste"30$:	SWAP.W	D540$:	TEST.B	(A6)+OTXFLP	; positionnement ?	JUMP',T 50$		; oui => 50$	TEST.B	(A6)+OTXFLZ	; inversion d'une zone ?	JUMP',T 60$		; oui => 60$	JUMP'	80$50$:	PUSH.L	D0	CLR.L	D0		; D0 <-- idem gauche/droite	CALL	EDPOSCAR	; positionne v. le curseur	POP.L	D0	JUMP'	80$60$:	CALL	EDIZONECAR	; inverse une zone;	JUMP'	80$80$:	ADD.W	D2,D1		; D2 <-- avance	POP.W	D1	RET;--------\\; EDAFCAR >;--------/; Affiche un caractre.; in	D3.L	caractre;	D2.L	position (y;x);	A3.L	^aprs le caractre; out	D2.L	position suivante (y;x); mod	D2.L, D7.WEDAFCAR:	PUSHM.L	D0,D1,D3..D6,A0..A4	CALL	EDPTGC		; A2 <-- ^dans OBUGC	COMP.B	(A6)+OTXMOD+1,#INVDOT	JUMP',EQ 12$	COMP.B	D3,#CADRATIN	; cadratin ?	JUMP',NE 10$		; non => 10$	LOAD.B	D3,#SPACE	; oui => comme un espace10$:	COMP.B	D3,#CR		; fin de ligne ?	JUMP',NE 11$		; non => 11$	LOAD.B	D3,#SPACE	; oui => comme un espace11$:	COMP.B	D3,#EOP		; fin de ligne ?	JUMP',NE 12$		; non => 12$	LOAD.B	D3,#SPACE	; oui => comme un espace12$:	TEST.B	(A6)+OTXFLP	; positionnement ?	JUMP,T	60$		; oui => 60$	TEST.B	(A6)+OTXFLZ	; inversion d'une zone ?	JUMP,T	70$		; oui => 70$	TEST.B	(A6)+OTXFLC	; dplacement du curseur ?	JUMP,T	80$		; oui => 80$	COMP.B	D3,#TAB	JUMP',NE 20$	LOAD.W	D1,D2	CALL	RGNEXT		; D2 <-- position suivante	COMP.B	(A6)+OTXMOD+1,#INVDOT	JUMP,NE 90$	SUB.W	D1,D2	NEG.W	D1		; D1 <-- longueur	CALL	EDAFTAB		; affiche un tabulateur	JUMP	90$20$:	PUSH.L	D2		; stack <-- position (y;x)	LOAD.L	D4,D2		; D4 <-- position (y;x)	ADD.W	D4,(A6)+OTXPOS+2	SUB.W	D4,(A6)+OPPOS+2	SWAP.W	D4	SUB.W	D4,(A2)+OGC1Y	ADD.W	D4,(A6)+OTXPOS+0	SUB.W	D4,(A6)+OPPOS+0	SWAP.W	D4	EX.L	D3,D4	CALL	DETSCALEP	; D4 <-- plus grand (si n:1)	EX.L	D4,D3	LOAD.L	A4,#0		; A4 <-- destination dans l'cran	LOAD.L	A1,(A2)+OGCPT	; A1 <-- ^gencar; Vrifie si le caractre fait partie des caractres contenus; dans le gnrateur.	CLR.W	D1		; D6 <-- largeur du caractre	CLR.W	D0	LOAD.B	D0,D3		; D0 <-- code du caractre	COMP.B	D0,(A1)+OGCLCA	; code caractre trop grand ?	JUMP,HI 45$		; oui => 45$	SUB.B	D0,(A1)+OGCFCA	; code caractre trop petit ?	JUMP,LO 45$		; oui => 45$; Cherche les informations utiles dans les 3 tables d'entte; du gnrateur (largeur, hauteur 1 et 2).	LOAD.W	D2,(A1)+OGCMHD	; D2 <-- hauteur totale matrice	SWAP.W	D2	LOAD.L	A3,#(A1)+OGCWID	; A3 <-- ^table des largeurs	CLR.W	D2	LOAD.B	D2,(A3)+(D0.W)	; D2 <-- largeur matrice	PUSH.W	D2		; stack <-- largeur caractre	LOAD.L	D3,D2	CALL	DETSCALEP	; D3 <-- plus grand (si n:1)	COMP.W	D4,(A0)+ODFFDX	; dpasse  droite ?	JUMP,GE 40$	ADD.W	D4,D3		; dpasse  gauche ?	JUMP,NS 40$	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	COMP.W	D4,(A0)+ODFFDY	; dpasse en haut ?	JUMP,GE 40$	ADD.W	D4,D3		; dpasse en bas ?	JUMP,NS 40$	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	CLR.L	D1	LOAD.B	D1,(A1)+OGCLCA	SUB.B	D1,(A1)+OGCFCA	INC.B	D1		; D1 <-- nb car dans gnrateur	ADD.L	A3,D1		; A3 <-- skip width(s)	ADD.L	A3,D1		; A3 <-- swip heigth(s) above baseline	ADD.L	A3,D1		; A3 <-- swip heigth(s) under baseline	MUL.WU	D0,(A1)+OGCMSB	; D0 <-- * matrix size (in bytes)	ADD.L	A3,D0		; A3 <-- ^matrix dans GENCAR	CLR.L	D3	CLR.W	D5	LOAD.B	D5,(A1)+OGCMWB	; D5 <-- incrment Y ds GENCAR	LOAD.W	D1,(A6)+OTXMOD	; D1 <-- mode d'affichage	TEST.W	(A6)+OSCALE	JUMP',EQ 30$	CALL	EDSTRCAR	; A3/D2/D5 <-- ^matrice stretche30$:	LOAD.L	A2,A0		; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+ORASTER	CALL	(A1)		; GRA_RASTER	CALL	EDAFDF		; OTXAFD/F <-- dbut/fin zone affiche	TEST.W	(A6)+OSCALE	JUMP',EQ 40$	LOAD.L	A4,A3	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire stretche40$:	POP.W	D1		; D1 <-- largeur caractre45$:	LOAD.W	D2,(A5)+OOTXITC+2	TEST.B	(A5)+OOTXITC+1:#BTXICM-16	JUMP',BC 46$	NEG.W	D246$:	ADD.W	D1,D2		; D1 <-- largeur caractre + intercaractre	JUMP',NC 47$	CLR.W	D147$:	POP.L	D2		; D2 <-- position (y;x)	ADD.W	D2,D1		; D2 <-- avance dans la ligne	JUMP'	90$60$:				; positionnement =>	CALL	EDGETLGCT	; D1 <-- largeur du caractre	LOAD.L	D0,#-1		; D0 <-- recule si on est  gauche	CALL	EDPOSCAR	; positionne v. le curseur	ADD.W	D2,D1		; D2 <-- avance dans la ligne	JUMP'	90$70$:				; inversion d'une zone =>	CALL	EDGETLGCT	; D1 <-- largeur du caractre	CALL	EDIZONECAR	; inverse une zone	ADD.W	D2,D1		; D2 <-- avance dans la ligne	JUMP'	90$80$:				; dplacement du curseur =>	CALL	EDGETLGCT	; D1 <-- largeur du caractre	ADD.W	D2,D1		; D2 <-- avance dans la ligne;	JUMP'	90$90$:	POPM.L	D0,D1,D3..D6,A0..A4	RET;--------\\; EDAFTAB >;--------/; Affiche un tabulateur.; in	D2.L	position fin (y;x);	D1.W	longueur;	A2.L	^dans OBUGC; out	-; mod	D7.WEDAFTAB:	PUSHM.L	D2..D4	TEST.W	D1	JUMP,LE 90$	SUB.W	D2,D1		; D2 <-- position dbut	ADD.W	D2,(A6)+OTXPOS+2	SWAP.W	D2	ADD.W	D2,(A6)+OTXPOS+0	LOAD.W	D3,(A2)+OGC1Y	SR.W	D3,#2	INC.W	D3		; D3 <-- (OGC1Y/4)+1	SUB.W	D2,D3	SWAP.W	D2	LOAD.L	D3,D2	CLR.L	D4	LOAD.W	D4,D1	CALL	CONVP3L4	; D3/D4 <-- dans l'cran	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.B	(A0)+ODFTTM,#B'00100010	LOAD.B	(A0)+ODFTTS,#1	PUSHM.L	D3,D4	LOAD.W	D2,#INVDOT!TTTDOT	ADD.W	D3,D4	DEC.W	D3	NEG.W	D4	PUSH.L	D3	LIB	?DRSEG		; trace une ligne horizontale	POP.L	D3	LOAD.B	(A0)+ODFTTM,#B'01010101;	LOAD.B	(A0)+ODFTTS,#1	LOAD.W	D4,#-3	SWAP.W	D4	LOAD.W	D4,#-5	PUSH.L	D3	LIB	?DRSEG		; partie suprieure flche	POP.L	D3	ADD.W	D3,#-2	SWAP.W	D3	ADD.W	D3,#+1	SWAP.W	D3	LOAD.W	D4,#+1	SWAP.W	D4	LOAD.W	D4,#-3	LIB	?DRSEG		; partie infrieure flche	POPM.L	D3,D4	LOAD.L	D2,D4	LOAD.L	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,#3	ADD.W	D4,#3+3	SWAP.W	D3	SWAP.W	D4	CALL	EDAFDF		; OTXAFD/F <-- dbut/fin zone affiche90$:	POPM.L	D2..D4	RET;--------\\; EDAFDF  >;--------/; Mmorise les positions de dbut et de fin de la zone affiche.; in	D4.L	position (y;x);	D2.L	dimensions (dy;dx); out	-; mod	D7.WEDAFDF:	PUSHM.L	D0,D1,D2,D4	LOAD.W	D0,(A6)+OTXAFD	LOAD.W	D1,(A6)+OTXAFF	SWAP.W	D2	SWAP.W	D4	COMP.W	D0,D4	JUMP',LE 30$	LOAD.W	D0,D4		; D0 <-- minimum en Y30$:	ADD.W	D4,D2	COMP.W	D1,D4	JUMP',GE 32$	LOAD.W	D1,D4		; D1 <-- maximum en Y32$:	LOAD.W	(A6)+OTXAFD,D0	LOAD.W	(A6)+OTXAFF,D1	POPM.L	D0,D1,D2,D4	RET;---------\\; EDPOSCAR >;---------/; Positionne ventuellement le curseur.; in	D2.L	position (y;x);	D1.W	largeur (-1 si dernire);	D0.L	avance si on est  gauche du caractre; out	-; mod	D7.WEDPOSCAR:	PUSHM.L	D1..D5	ADD.W	D2,(A6)+OTXPOS+2	SWAP.W	D2	SUB.W	D2,(A6)+OTXMH1	ADD.W	D2,(A6)+OTXPOS+0	SWAP.W	D2	LOAD.L	D4,(A6)+OTXPMO	; D4 <-- position de la souris	SWAP.W	D4	SWAP.W	D2	COMP.W	D4,D2		; trop en haut ?	JUMP',LT 90$	ADD.W	D2,(A6)+OTXMIL	COMP.W	D4,D2		; trop en bas ?	JUMP',GE 90$	SWAP.W	D4	SWAP.W	D2	COMP.W	D4,D2		; trop  gauche ?	JUMP',LT 90$	ADD.W	D2,D1	COMP.W	D4,D2		; trop  droite ?	JUMP',GE 90$	LOAD.L	D3,(A5)+OOTXPOC	; D3 <-- position  droite du caractre	LOAD.W	D5,D1	SR.W	D5,#1	SUB.W	D2,D5	COMP.W	D4,D2	JUMP',GE 40$	ADD.L	D3,D0		; D3 <-- position  gauche du caractre40$:	LOAD.L	(A6)+OTXPMB,D3	; OTXPMB <-- position o est la souris	LOAD.L	(A6)+OTXPOR,D390$:	POPM.L	D1..D5	RET;-----------\\; EDIZONECAR >;------------/; Inverse une zone dans une mme ligne.; in	D2.L	position (y;x);	D1.W	largeur (-1 si dernire); out	-; mod	D7.WEDIZONECAR:	PUSHM.L	D2..D4	COMP.W	D1,#-1		; inverse s'ki reste ?	JUMP,EQ 40$		; oui => 40$	LOAD.L	D4,(A5)+OOTXPOC	DEC.L	D4	COMP.L	D4,(A6)+OTXZOF	JUMP,HS 90$	COMP.L	D4,(A6)+OTXZOD	JUMP,LO 90$	LOAD.L	D3,D2	ADD.W	D3,(A6)+OTXPOS+2	SWAP.W	D3	SUB.W	D3,(A6)+OTXMH1	ADD.W	D3,(A6)+OTXPOS+0	SWAP.W	D3	LOAD.W	D4,(A6)+OTXMIL	; D4 <-- hauteur	SWAP.W	D4	LOAD.W	D4,D1		; D4 <-- largeur	LOAD.L	D2,D3	SWAP.W	D2	COMP.W	D2,(A6)+OTXZOP+0 ; mme position verticale ?	JUMP',NE 40$		; non => 40$;;?	LOAD.W	D2,(A6)+OTXZOP+2;;?	ADD.W	D2,(A6)+OTXZOL+2;;?	COMP.W	D2,D3;;?	JUMP',NE 40$	ADD.W	D3,D4	SUB.W	D3,(A6)+OTXZOP+2	LOAD.W	(A6)+OTXZOL+2,D3	JUMP	90$40$:	PUSHM.L	D3,D4	LOAD.L	D3,(A6)+OTXZOP	LOAD.L	D4,(A6)+OTXZOL	JUMP',EQ 50$	LOAD.W	D2,(A5)+OOTXITC+2	TEST.B	(A5)+OOTXITC+1:#BTXICM-16	JUMP',BS 42$	NEG.W	D242$:	ADD.W	D2,(A6)+OTXPOS+2	ADD.W	D2,(A6)+OTXDIM+2	INC.W	D2	COMP.W	D3,D2	JUMP',HS 50$	SUB.W	D2,D3		; D2 <-- largeur  ne pas dpasser	COMP.W	D4,D2		; dpasse  droite ?	JUMP',LS 44$		; non => 44$	LOAD.W	D4,D2		; D4 <-- largeur maximale44$:	CALL	CONVP3L4	; D3/D4 <-- dans l'cran	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,#INVDOT	LIB	?DRTRAME	; inverse un caractre50$:	POPM.L	D3,D4	LOAD.L	(A6)+OTXZOP,D3	LOAD.L	(A6)+OTXZOL,D490$:	POPM.L	D2..D4	RET;---------\\; EDSTRCAR >;---------/; Construit une matrice de caractre stretche.; in	A3.L	^caractre;	D2.L	dimensions;	D5.W	Iy; out	A3.L	^caractre;	D2.L	dimensions;	D5.W	Iy;	D7.W	erreur; mod	EDSTRCAR:	PUSHM.L	D1,D3,D4,A0,A4	LOAD.L	A0,#(A6)+OSTRETCH	LOAD.L	(A0)+OSTRSPT,A3	LOAD.W	(A0)+OSTRSDX,D5	CLR.L	(A0)+OSTRS0	LOAD.L	(A0)+OSTRS2,D2	EX.L	D3,D2	CALL	DETSCALEP	; D2 <-- plus grand (si n:1)	EX.L	D2,D3	LOAD.W	D5,D2	ADD.W	D5,#16-1	SR.W	D5,#4	SL.W	D5,#1		; D5 <-- nouveau Iy	LOAD.L	D4,D2	SWAP.W	D4	MUL.WU	D4,D5	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM	JUMP',NE 90$	GESMEM	?CLEARMEM	LOAD.L	A3,A4		; A3 <-- ^nouveau	LOAD.L	(A0)+OSTRDPT,A3	LOAD.W	(A0)+OSTRDDX,D5	CLR.L	(A0)+OSTRD0	CLR.W	(A0)+OSTRD1+0	CLR.W	(A0)+OSTRD3+2	LOAD.L	(A0)+OSTRD2,D2	LOAD.W	(A0)+OSTRD1+2,D2	SWAP.W	D2	LOAD.W	(A0)+OSTRD3+0,D2	SWAP.W	D2	ST_	RECT	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1,D3,D4,A0,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; EDGETLGCT >;----------/; Calcule la largeur d'un caractre  chasse variable,; en tenant compte des tabulateurs.; in	D3.L	caractre;	D2.L	position dans la ligne; out	D1.W	largeur du caractre; mod	D1.L, D7.WEDGETLGCT:	COMP.B	D3,#TAB	JUMP',NE EDGETLGC	PUSH.L	D2	LOAD.W	D1,D2	CALL	RGNEXT		; D2 <-- position suivante	SUB.W	D2,D1	LOAD.W	D1,D2		; D1 <-- largeur	POP.L	D2	RET;---------\\; EDGETLGC >;---------/; Calcule la largeur d'un caractre  chasse variable.; in	D3.L	caractre; out	D1.W	largeur du caractre; mod	D1.L, D7.WEDGETLGC:	PUSHM.L	D3,A2	CALL	EDPTGC		; A2 <-- ^dans OBUGC	CLR.W	D1		; D1 <-- largeur nulle	COMP.B	D3,#CADRATIN	; cadratin ?	JUMP',NE 10$		; non => 10$	LOAD.B	D3,#SPACE	; oui => comme un espace10$:	COMP.B	D3,#CR		; fin de ligne ?	JUMP',NE 11$		; non => 11$	LOAD.B	D3,#SPACE	; oui => comme un espace11$:	COMP.B	D3,#EOP		; fin de ligne ?	JUMP',NE 12$		; non => 12$	LOAD.B	D3,#SPACE	; oui => comme un espace12$:	AND.W	D3,#H'7F	LOAD.L	A2,(A2)+OGCPT	; A2 <-- ^gencar	COMP.B	D3,(A2)+OGCLCA	; aprs le dernier caractre ?	JUMP',HI 90$	SUB.B	D3,(A2)+OGCFCA	; avant le premier caractre ?	JUMP',LO 90$	LOAD.L	A2,#(A2)+OGCWID	; A2 <-- ^table des largeurs	CLR.W	D1	LOAD.B	D1,(A2)+(D3.W)	; D1 <-- largeur	LOAD.W	D3,(A5)+OOTXITC+2	TEST.B	(A5)+OOTXITC+1:#BTXICM-16	JUMP',BC 50$	NEG.W	D350$:	ADD.W	D1,D3		; D1 <-- ajoute l'intercaractre	JUMP',NC 90$	CLR.W	D190$:	POPM.L	D3,A2	RET;-------\\; EDPTGC >;-------/; Cherche le ^gencar d'un caractre quelconque.; in	D3.L	caractre complet; out	A2.L	^dans OBUGC; mod	A2.LEDPTGC:	PUSH.L	D3	LOAD.L	A2,#(A6)+OBUGC	AND.W	D3,#CCGCMSK	SR.W	D3,#CCGCSHI	; D3 <-- numro du gencar	MUL.WU	D3,#LGGC	ADD.L	A2,D3		; A2 <-- ^gencar dans obugc	POP.L	D3	RET;--------\\; TXINFO  >;========/; Donne quelques informations sur un objet texte.; in	A5.L	^objet texte; out	D4.L	position actuelle du curseur;	D5.L	nombre de caractres; mod	D4.L, D5.L, D7.WTXINFO:	LOAD.L	D4,(A5)+OOTXPOC	; D4 <-- position du curseur	LOAD.L	D5,(A5)+OOTXNBC	; D5 <-- nombre de caractres	CLR.W	D7		; retour EQ	RET;--------------\\; TXQPOSITIONNE >;==============/; Positionne rapidement le curseur n'importe o dans un objet texte.; La position de la ligne n'est pas mise  jour (OOTXPLI) !; in	A5.L	^objet texte;	D4.L	nouvelle position; out	D7.W	erreur; mod	D7.WTXQPOSITIONNE:	PUSHM.L	D2..D4,A4	LOAD.L	D3,(A5)+OOTXPOC	SUB.L	D3,D4	JUMP,EQ 80$	JUMP',NC 10$	NEG.L	D3		; D3 <-- |cart|10$:	COMP.L	D3,#20		; cart suffisement petit ?	JUMP,LO 50$		; oui => 50$; Positionne le curseur en parcourant tous les blocs.	LOAD.W	D7,#1		; D7 <-- hors de la zone	LOAD.L	A4,(A5)+OOTXFBT	CLR.L	D320$:	ADD.L	D3,(A4)+OBTNBC	COMP.L	D4,D3		; va dans ce bloc ?	JUMP',LS 30$		; oui => 30$				; non =>	LOAD.L	D2,(A4)+OBTNEXT	JUMP',EQ 90$	LOAD.L	A4,D2		; A4 <-- ^bloc suivant	JUMP	20$30$:	LOAD.L	(A5)+OOTXPPB,A4	LOAD.L	(A5)+OOTXPOC,D4	SUB.L	D3,(A4)+OBTNBC	SUB.L	D4,D3	LOAD.L	(A5)+OOTXPPR,D4	JUMP'	80$; Positionne le curseur en avanant ou en reculant un peu.50$:	COMP.L	D4,(A5)+OOTXPOC	JUMP',LO 70$60$:	CALL	TXAVANCE	COMP.L	D4,(A5)+OOTXPOC	; position atteinte ?	JUMP,NE 60$		; non => 60$	JUMP'	80$70$:	CALL	TXRECULE	COMP.L	D4,(A5)+OOTXPOC	; position atteinte ?	JUMP,NE 70$		; non => 70$;	JUMP'	80$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D4,A4	TEST.W	D7		; retour EQ/NE	RET;-------------\\; TXPOSITIONNE >;=============/; Positionne le curseur n'importe o dans un objet texte.; in	A5.L	^objet texte;	D4.L	nouvelle position; out	D7.W	erreur; mod	D7.WTXPOSITIONNE:	PUSHM.L	D0..D4,A3,A4	LOAD.L	D3,(A5)+OOTXPOC	SUB.L	D3,D4	JUMP,EQ 80$	JUMP',NC 10$	NEG.L	D3		; D3 <-- |cart|10$:	COMP.L	D3,#100		; cart suffisement petit ?	JUMP,LO 50$		; oui => 50$; Positionne le curseur en parcourant tous les blocs.	LOAD.W	D7,#1		; D7 <-- hors de la zone	LOAD.L	A4,(A5)+OOTXFBT	CLR.L	D3	CLR.L	D0		; D0 <-- position en ligne20$:	LOAD.L	D2,(A4)+OBTNBC	ADD.L	D3,D2	COMP.L	D4,D3		; va dans ce bloc ?	JUMP',LS 30$		; oui => 30$				; non =>	CALL	TXPOSCLIN	; D0 <-- position en ligne	LOAD.L	D2,(A4)+OBTNEXT	JUMP',EQ 90$	LOAD.L	A4,D2		; A4 <-- ^bloc suivant	JUMP	20$30$:	LOAD.L	(A5)+OOTXPPB,A4	LOAD.L	(A5)+OOTXPOC,D4	SUB.L	D3,D2	SUB.L	D4,D3	LOAD.L	(A5)+OOTXPPR,D4	LOAD.L	D2,D4	CALL	TXPOSCLIN	; D0 <-- position en ligne	LOAD.L	(A5)+OOTXPLI,D0	JUMP'	80$; Positionne le curseur en avanant ou en reculant un peu.50$:	COMP.L	D4,(A5)+OOTXPOC	JUMP',LO 70$60$:	CALL	TXAVANCE	COMP.L	D4,(A5)+OOTXPOC	; position atteinte ?	JUMP,NE 60$		; non => 60$	JUMP'	80$70$:	CALL	TXRECULE	COMP.L	D4,(A5)+OOTXPOC	; position atteinte ?	JUMP,NE 70$		; non => 70$;	JUMP'	80$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; TXPOSCLIN >;----------/; Compte  quelle ligne est le curseur.; in	A4.L	^bloc;	D2.L	nb de caractres;	D0.L	position en ligne; out	D0.L	nouvelle position; mod	D0.L, D1.L, D2.L, A3.LTXPOSCLIN:	LOAD.L	A3,#(A4)+LBT	DEC.W	D2		; D2 <-- -1  cause NMO	JUMP',NS 90$20$:	LOAD.W	D1,(A3+)	; D1 <-- caractre brut	COMP.B	D1,#CR	JUMP',EQ 40$	COMP.B	D1,#LF	JUMP',NE 42$40$:	INC.L	D0		; D0 <-- avance d'une ligne42$:	DECJ.W,NMO D2,20$90$:	RET;---------\\; TXPSAUVE >;=========/; Sauve la position actuelle du curseur.; in	A5.L	^objet texte; out	D4.W	numro de la position;	D7.W	erreur; mod	D4.L, D7.WTXPSAUVE:	PUSH.L	A4	LOAD.L	A4,#(A5)+OOTXSP	CLR.W	D410$:	TEST.L	(A4)+OSPPPB	; lment libre ?	JUMP',EQ 40$		; oui => 40$	LOAD.L	A4,#(A4)+LSP	; A4 <-- ^lment suivant	INC.W	D4	COMP.W	D4,#MAXSP	JUMP,LO 10$	LOAD.W	D7,#1	JUMP'	90$40$:	LOAD.L	(A4)+OSPPOC,(A5)+OOTXPOC	LOAD.L	(A4)+OSPPLI,(A5)+OOTXPLI	LOAD.L	(A4)+OSPPPB,(A5)+OOTXPPB	LOAD.L	(A4)+OSPPPR,(A5)+OOTXPPR	CLR.W	D7		; D7 <-- ok90$:	POP.L	A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; TXPANNULE >;==========/; Annule l'effet d'une TXPSAUVE.; A utiliser  la place de TXPPREND !; in	A5.L	^objet texte;	D4.W	numro de la position; out	D7.W	erreur; mod	D7.WTXPANNULE:	PUSHM.L	D4,A4	LOAD.L	A4,#(A5)+OOTXSP	MUL.WU	D4,#LSP	ADD.L	A4,D4		; A4 <-- ^lment selon numro	CLR.L	(A4)+OSPPPB	; libre l'lment	POPM.L	D4,A4	CLR.W	D7		; retour EQ	RET;---------\\; TXPREMET >;=========/; Remet le curseur  une position sauve.; TXPSAUVE TXPREMET TXPREMET ... TXPANNULE; in	A5.L	^objet texte;	D4.W	numro de la position; out	D7.W	erreur; mod	D7.WTXPREMET:	PUSHM.L	D4,A4	LOAD.L	A4,#(A5)+OOTXSP	MUL.WU	D4,#LSP	ADD.L	A4,D4		; A4 <-- ^lment selon numro	LOAD.L	(A5)+OOTXPOC,(A4)+OSPPOC	LOAD.L	(A5)+OOTXPLI,(A4)+OSPPLI	LOAD.L	(A5)+OOTXPPB,(A4)+OSPPPB	LOAD.L	(A5)+OOTXPPR,(A4)+OSPPPR	POPM.L	D4,A4	CLR.W	D7		; retour EQ	RET;---------\\; TXPPREND >;=========/; Remet le curseur  une position sauve.; ATTENTION:	Entre le "sauve" et le "prend", il ne faut pas;		faire de "insre", de "dtruit", etc.; in	A5.L	^objet texte;	D4.W	numro de la position; out	D7.W	erreur; mod	D7.WTXPPREND:	PUSHM.L	D4,A4	LOAD.L	A4,#(A5)+OOTXSP	MUL.WU	D4,#LSP	ADD.L	A4,D4		; A4 <-- ^lment selon numro	LOAD.L	(A5)+OOTXPOC,(A4)+OSPPOC	LOAD.L	(A5)+OOTXPLI,(A4)+OSPPLI	LOAD.L	(A5)+OOTXPPB,(A4)+OSPPPB	LOAD.L	(A5)+OOTXPPR,(A4)+OSPPPR	CLR.L	(A4)+OSPPPB	; libre l'lment	POPM.L	D4,A4	CLR.W	D7		; retour EQ	RET;--------\\; TXDONNE >;========/; Donne le caractre  droite du curseur, dans un objet texte.; in	A5.L	^objet texte; out	D3.L	caractre  droite du curseur;	D7.W	erreur; mod	D3.L, D7.WTXDONNE:	PUSH.L	A4	LOAD.W	D7,#1		; D7 <-- hors de la zone	LOAD.L	A4,(A5)+OOTXPPB	; A4 <-- ^bloc o est le curseur	LOAD.L	D3,(A5)+OOTXPPR	COMP.L	D3,(A4)+OBTNBC	JUMP',LO 30$	LOAD.L	D3,(A4)+OBTNEXT	JUMP',EQ 90$	LOAD.L	A4,D3		; A4 <-- ^bloc suivant	CLR.L	D330$:	SL.L	D3,#1	LOAD.W	D3,(A4)+(D3.L)+LBT ; D3 <-- caractre cod	CALL	CARDECO		; D3 <-- caractre complet	CLR.W	D7		; D7 <-- ok90$:	POP.L	A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; TXREMPLACE >;===========/; Remplace le caractre  droite du curseur, dans un objet texte.; in	A5.L	^objet texte;	D3.L	nouveau caractre; out	D7.W	erreur; mod	D7.WTXREMPLACE:	PUSHM.L	D2..D4,A4	LOAD.W	D7,#1		; D7 <-- hors de la zone	LOAD.L	A4,(A5)+OOTXPPB	; A4 <-- ^bloc o est le curseur	LOAD.L	D4,(A5)+OOTXPPR	COMP.L	D4,(A4)+OBTNBC	JUMP',LO 30$	LOAD.L	D4,(A4)+OBTNEXT	JUMP',EQ 90$	LOAD.L	A4,D4		; A4 <-- ^bloc suivant	CLR.L	D430$:	CALL	CARCODE		; D3 <-- caractre cod	JUMP',NE 90$	SL.L	D4,#1	LOAD.W	D2,(A4)+(D4.L)+LBT ; D2 <-- caractre prcdent	LOAD.W	(A4)+(D4.L)+LBT,D3 ; remplace le caractre	COMP.B	D3,#CR	JUMP',EQ 40$	COMP.B	D3,#LF	JUMP',NE 42$40$:	INC.L	(A5)+OOTXNBL	; une ligne de plus42$:	COMP.B	D2,#CR	JUMP',EQ 50$	COMP.B	D2,#LF	JUMP',NE 52$50$:	DEC.L	(A5)+OOTXNBL	; une ligne de moins52$:	SET.B	(A5)+OOTXMAJ	; mise  jour ncessaire	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D4,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; TXACHERCHE >;===========/; Cherche un caractre en avant, dans un objet texte.; Si le caractre n'est pas trouv, la position du curseur; n'est pas change !; in	A5.L	^objet texte;	D3.L	caractre cherch;	D2.L	masque ventuel;	D5.W	mode (si 2^0=1 --> min=maj); out	D4.L	position juste avant le caractre trouv;	D7.W	erreur; mod	D4.L, D7.WTXACHERCHE:	PUSHM.L	D0..D3,D5,D6,A2..A4	TEST.L	D5:#0		; minuscules = majuscules ?	JUMP',BC 10$		; non => 10$	CALL	MINMAJ		; D3 <-- caractre majuscule cherch10$:	LOAD.L	D6,D3	AND.L	D6,D2		; D6 <-- caractre cherch; Cherche le premier bloc o chercher.	LOAD.W	D7,#1		; D7 <-- hors de la zone	LOAD.L	A4,(A5)+OOTXPPB	; A4 <-- ^bloc o est le curseur	LOAD.L	D3,(A5)+OOTXPPR	COMP.L	D3,(A4)+OBTNBC	JUMP',LO 20$	LOAD.L	D3,(A4)+OBTNEXT	JUMP,EQ 90$	LOAD.L	A4,D3		; A4 <-- ^bloc suivant	CLR.L	D320$:	LOAD.L	D4,(A4)+OBTNBC	SUB.L	D4,D3		; D4 <-- nb de caractres restant dans ce bloc	LOAD.L	D0,D3		; D0 <-- position dans le bloc	LOAD.L	D1,(A5)+OOTXPOC	; D1 <-- position absolue	SL.L	D3,#1	LOAD.L	A3,#(A4)+(D3.L)+LBT	LOAD.L	A2,(A5)+OOTXPLI	; A2 <-- position en ligne	LOAD.L	D3,D2	CLR.B	D3	TEST.L	D3		; cherche aussi le mode ?	JUMP,EQ 40$		; non => 40$; Cherche un caractre complet (avec le mode).30$:	DEC.W	D432$:	LOAD.W	D3,(A3+)	CALL	CARDECO		; D3 <-- caractre complet	AND.L	D3,D2	TEST.L	D5:#0		; minuscules = majuscules ?	JUMP',BC 34$		; non => 34$	CALL	MINMAJ		; D3 <-- caractre majuscule34$:	COMP.L	D3,D6		; caractre trouv ?	JUMP,EQ 70$		; oui => 70$	INC.L	D0		; D0 <-- position dans le bloc suivante	INC.L	D1		; D1 <-- position absolue suivante	COMP.B	D3,#CR	JUMP',EQ 36$	COMP.B	D3,#LF	JUMP',NE 37$36$:	INC.L	A2		; A2 <-- position ligne suivante37$:	DECJ.W,NMO D4,32$	LOAD.L	D4,(A4)+OBTNEXT	JUMP,EQ 90$	LOAD.L	A4,D4		; A4 <-- ^bloc suivant	LOAD.L	D4,(A4)+OBTNBC	CLR.L	D0		; D0 <-- position dans le bloc	LOAD.L	A3,#(A4)+LBT	JUMP	30$; Cherche un caractre rduit (juste le code ASCII).40$:	TEST.L	D5:#0		; minuscules = majuscules ?	JUMP',BC 50$		; non => 50$41$:	DEC.W	D442$:	LOAD.W	D3,(A3+)	; D3 <-- caractre ASCII	CALL	MINMAJ		; D3 <-- caractre majuscule	COMP.B	D3,D6		; caractre trouv ?	JUMP,EQ 70$		; oui => 70$	INC.L	D0		; D0 <-- position dans le bloc suivante	INC.L	D1		; D1 <-- position absolue suivante	COMP.B	D3,#CR	JUMP',EQ 46$	COMP.B	D3,#LF	JUMP',NE 47$46$:	INC.L	A2		; A2 <-- position ligne suivante47$:	DECJ.W,NMO D4,42$	LOAD.L	D4,(A4)+OBTNEXT	JUMP,EQ 90$	LOAD.L	A4,D4		; A4 <-- ^bloc suivant	LOAD.L	D4,(A4)+OBTNBC	CLR.L	D0		; D0 <-- position dans le bloc	LOAD.L	A3,#(A4)+LBT	JUMP	41$50$:	DEC.W	D452$:	LOAD.W	D3,(A3+)	; D3 <-- caractre ASCII	COMP.B	D3,D6		; caractre trouv ?	JUMP',EQ 70$		; oui => 70$	INC.L	D0		; D0 <-- position dans le bloc suivante	INC.L	D1		; D1 <-- position absolue suivante	COMP.B	D3,#CR	JUMP',EQ 56$	COMP.B	D3,#LF	JUMP',NE 57$56$:	INC.L	A2		; A2 <-- position ligne suivante57$:	DECJ.W,NMO D4,52$	LOAD.L	D4,(A4)+OBTNEXT	JUMP',EQ 90$	LOAD.L	A4,D4		; A4 <-- ^bloc suivant	LOAD.L	D4,(A4)+OBTNBC	CLR.L	D0		; D0 <-- position dans le bloc	LOAD.L	A3,#(A4)+LBT	JUMP	50$70$:	LOAD.L	(A5)+OOTXPPB,A4	LOAD.L	(A5)+OOTXPPR,D0	LOAD.L	(A5)+OOTXPOC,D1	LOAD.L	(A5)+OOTXPLI,A2	LOAD.L	D4,D1		; D4 <-- position	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D3,D5,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; TXRCHERCHE >;===========/; Cherche un caractre en arrire, dans un objet texte.; Si le caractre n'est pas trouv, la position du curseur; n'est pas change !; in	A5.L	^objet texte;	D3.L	caractre cherch;	D2.L	masque ventuel;	D5.W	mode (si 2^0=1 --> min=maj); out	D4.L	position juste avant le caractre trouv;	D7.W	erreur; mod	D4.L, D7.WTXRCHERCHE:	PUSHM.L	D0..D3,D5,D6,A2..A4	TEST.L	D5:#0		; minuscules = majuscules ?	JUMP',BC 10$		; non => 10$	CALL	MINMAJ		; D3 <-- caractre majuscule cherch10$:	LOAD.L	D6,D3	AND.L	D6,D2		; D6 <-- caractre cherch; Cherche le premier bloc o chercher.	LOAD.W	D7,#1		; D7 <-- hors de la zone	LOAD.L	A4,(A5)+OOTXPPB	; A4 <-- ^bloc o est le curseur	LOAD.L	D3,(A5)+OOTXPPR	JUMP',NE 20$	LOAD.L	D3,(A4)+OBTPREV	JUMP,EQ 90$	LOAD.L	A4,D3		; A4 <-- ^bloc prcdent	LOAD.L	D3,(A4)+OBTNBC20$:	LOAD.L	D4,D3		; D4 <-- nb de caractres restant dans ce bloc	LOAD.L	D0,D3		; D0 <-- position dans le bloc	LOAD.L	D1,(A5)+OOTXPOC	; D1 <-- position absolue	SL.L	D3,#1	LOAD.L	A3,#(A4)+(D3.L)+LBT	LOAD.L	A2,(A5)+OOTXPLI	; A2 <-- position en ligne	LOAD.L	D3,D2	CLR.B	D3	TEST.L	D3		; cherche aussi le mode ?	JUMP,EQ 40$		; non => 40$; Cherche un caractre complet (avec le mode).30$:	DEC.W	D432$:	LOAD.W	D3,(-A3)	CALL	CARDECO		; D3 <-- caractre complet	AND.L	D3,D2	TEST.L	D5:#0		; minuscules = majuscules ?	JUMP',BC 34$		; non => 34$	CALL	MINMAJ		; D3 <-- caractre majuscule34$:	COMP.L	D3,D6		; caractre trouv ?	JUMP,EQ 70$		; oui => 70$	DEC.L	D0		; D0 <-- position dans le bloc prcdente	DEC.L	D1		; D1 <-- position absolue prcdente	COMP.B	D3,#CR	JUMP',EQ 36$	COMP.B	D3,#LF	JUMP',NE 37$36$:	DEC.L	A2		; A2 <-- position ligne prcdente37$:	DECJ.W,NMO D4,32$	LOAD.L	D4,(A4)+OBTPREV	JUMP,EQ 90$	LOAD.L	A4,D4		; A4 <-- ^bloc prcdent	LOAD.L	D4,(A4)+OBTNBC	LOAD.L	D0,D4		; D0 <-- position dans le bloc	LOAD.L	A3,#(A4)+(D4.L)+LBT	ADD.L	A3,D4	JUMP	30$; Cherche un caractre rduit (juste le code ASCII).40$:	TEST.L	D5:#0		; minuscules = majuscules ?	JUMP',BC 50$		; non => 50$41$:	DEC.W	D442$:	LOAD.W	D3,(-A3)	; D3 <-- caractre ASCII	CALL	MINMAJ		; D3 <-- caractre majuscule	COMP.B	D3,D6		; caractre trouv ?	JUMP,EQ 70$		; oui => 70$	DEC.L	D0		; D0 <-- position dans le bloc prcdente	DEC.L	D1		; D1 <-- position absolue prcdente	COMP.B	D3,#CR	JUMP',EQ 46$	COMP.B	D3,#LF	JUMP',NE 47$46$:	DEC.L	A2		; A2 <-- position ligne prcdente47$:	DECJ.W,NMO D4,42$	LOAD.L	D4,(A4)+OBTPREV	JUMP,EQ 90$	LOAD.L	A4,D4		; A4 <-- ^bloc prcdent	LOAD.L	D4,(A4)+OBTNBC	LOAD.L	D0,D4		; D0 <-- position dans le bloc	LOAD.L	A3,#(A4)+(D4.L)+LBT	ADD.L	A3,D4	JUMP	41$50$:	DEC.W	D452$:	LOAD.W	D3,(-A3)	; D3 <-- caractre ASCII	COMP.B	D3,D6		; caractre trouv ?	JUMP',EQ 70$		; oui => 70$	DEC.L	D0		; D0 <-- position dans le bloc prcdente	DEC.L	D1		; D1 <-- position absolue prcdente	COMP.B	D3,#CR	JUMP',EQ 56$	COMP.B	D3,#LF	JUMP',NE 57$56$:	DEC.L	A2		; A2 <-- position ligne prcdente57$:	DECJ.W,NMO D4,52$	LOAD.L	D4,(A4)+OBTPREV	JUMP,EQ 90$	LOAD.L	A4,D4		; A4 <-- ^bloc prcdent	LOAD.L	D4,(A4)+OBTNBC	LOAD.L	D0,D4		; D0 <-- position dans le bloc	LOAD.L	A3,#(A4)+(D4.L)+LBT	ADD.L	A3,D4	JUMP	50$70$:	LOAD.L	(A5)+OOTXPPB,A4	LOAD.L	(A5)+OOTXPPR,D0	LOAD.L	(A5)+OOTXPOC,D1	LOAD.L	(A5)+OOTXPLI,A2	LOAD.L	D4,D1		; D4 <-- position	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D3,D5,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; TXAVANCE >;=========/; Avance d'un caractre dans un objet texte.; in	A5.L	^objet texte; out	D3.L	caractre avanc;	D7.W	erreur; mod	D3.L, D7.WTXAVANCE:	PUSHM.L	D4,A4	LOAD.W	D7,#1		; D7 <-- hors de la zone	LOAD.L	A4,(A5)+OOTXPPB	; A4 <-- ^bloc o est le curseur	LOAD.L	D4,(A5)+OOTXPPR	COMP.L	D4,(A4)+OBTNBC	JUMP',LO 50$	LOAD.L	D4,(A4)+OBTNEXT	JUMP',EQ 90$	LOAD.L	A4,D4		; A4 <-- ^bloc suivant	LOAD.L	(A5)+OOTXPPB,A4	CLR.L	D4	LOAD.L	(A5)+OOTXPPR,D450$:	SL.L	D4,#1	LOAD.W	D3,(A4)+(D4.L)+LBT ; D3 <-- caractre saut;;?	CALL	CARDECO		; D3 <-- caractre complet	LOAD.B	D4,D3	CLR.B	D3		; D3 <-- codage	RR.W	D3,#6		; D3 <-- /256 puis *4	LOAD.L	A4,#(A6)+OTXCOD	LOAD.L	D3,(A4)+(D3.W)	LOAD.B	D3,D4	INC.L	(A5)+OOTXPPR	; avance la position du curseur dans ce bloc	INC.L	(A5)+OOTXPOC	; avance la position du curseur	COMP.B	D3,#CR	JUMP',EQ 70$	COMP.B	D3,#LF	JUMP',NE 72$70$:	INC.L	(A5)+OOTXPLI	; avance d'une ligne72$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; TXRECULE >;=========/; Recule d'un caractre dans un objet texte.; in	A5.L	^objet texte; out	D3.L	caractre recul;	D7.W	erreur; mod	D3.L, D7.WTXRECULE:	PUSHM.L	D4,A4	LOAD.W	D7,#1		; D7 <-- hors de la zone	LOAD.L	A4,(A5)+OOTXPPB	; A4 <-- ^bloc o est le curseur	LOAD.L	D4,(A5)+OOTXPPR	JUMP',NE 50$	LOAD.L	D4,(A4)+OBTPREV	JUMP',EQ 90$	LOAD.L	A4,D4		; A4 <-- ^bloc prcdent	LOAD.L	(A5)+OOTXPPB,A4	LOAD.L	D4,(A4)+OBTNBC	LOAD.L	(A5)+OOTXPPR,D450$:	DEC.L	D4	SL.L	D4,#1	LOAD.W	D3,(A4)+(D4.L)+LBT ; D3 <-- caractre saut;;?	CALL	CARDECO		; D3 <-- caractre complet	LOAD.B	D4,D3	CLR.B	D3		; D3 <-- codage	RR.W	D3,#6		; D3 <-- /256 puis *4	LOAD.L	A4,#(A6)+OTXCOD	LOAD.L	D3,(A4)+(D3.W)	LOAD.B	D3,D4	DEC.L	(A5)+OOTXPPR	; recule la position du curseur dans ce bloc	DEC.L	(A5)+OOTXPOC	; recule la position du curseur	COMP.B	D3,#CR	JUMP',EQ 70$	COMP.B	D3,#LF	JUMP',NE 72$70$:	DEC.L	(A5)+OOTXPLI	; recule d'une ligne72$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; TXMODE  >;========/; Modifie le mode d'une suite de caractres, dans un objet texte.; Ne modifie pas la position du curseur !; in	A5.L	^objet texte;	D3.L	nouveau mode;	D2.L	masque ventuel;	D4.L	position de dbut;	D5.L	nombre de caractres; out	D7.W	erreur; mod	D7.WTXMODE:	PUSHM.L	D0..D5,A3,A4	CLR.B	D2		; D2 <-- ne modifie jamais le caractre ASCII	LOAD.L	D0,D3	AND.L	D0,D2		; D0 <-- nouveau mode	NOT.L	D2		; D2 <-- masque; Cherche le premier caractre  modifier.	LOAD.W	D7,#1		; D7 <-- hors de la zone	LOAD.L	A4,(A5)+OOTXFBT	CLR.L	D320$:	ADD.L	D3,(A4)+OBTNBC	COMP.L	D4,D3		; va dans ce bloc ?	JUMP',LO 24$		; oui => 24$	LOAD.L	D1,(A4)+OBTNEXT	JUMP,EQ 90$	LOAD.L	A4,D1		; A4 <-- ^bloc suivant	JUMP	20$24$:	LOAD.L	D1,D4	SUB.L	D1,D3	ADD.L	D1,(A4)+OBTNBC	SL.L	D1,#1	LOAD.L	A3,#(A4)+(D1.L)+LBT	SUB.L	D3,D4	LOAD.L	D4,D3		; D4 <-- nb de caractres restant; Modifie tous les caractres de la zone.30$:	DEC.W	D432$:	LOAD.W	D3,(A3+)	CALL	CARDECO		; D3 <-- caractre complet	LOAD.L	D1,D3	AND.L	D3,D2		; D3 <-- masque	OR.L	D3,D0		; D3 <-- nouveau mode	COMP.L	D3,D1		; qq chose de chang ?	JUMP',EQ 34$		; non => 34$				; oui =>	CALL	CARCODE		; D3 <-- caractre cod	JUMP',NE 90$	LOAD.W	(A3)-2,D3	SET.B	(A5)+OOTXMAJ	; mise  jour ncessaire34$:	DEC.L	D5		; encore un caractre ?	JUMP',EQ 80$		; non => 80$	DECJ.W,NMO D4,32$	LOAD.W	D7,#1		; D7 <-- hors de la zone	LOAD.L	D4,(A4)+OBTNEXT	JUMP',EQ 90$	LOAD.L	A4,D4		; A4 <-- ^bloc suivant	LOAD.L	D4,(A4)+OBTNBC	LOAD.L	A3,#(A4)+LBT	JUMP	30$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0..D5,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; TXINSERE >;=========/; Insre un caractre dans un objet texte.; in	A5.L	^objet texte;	D3.L	caractre  insrer; out	D7.W	erreur; mod	D7.WTXINSERE:	PUSHM.L	D1,D3,D4,A1..A4	CALL	CARCODE		; D3 <-- caractre cod	JUMP,NE 90$	LOAD.L	A4,(A5)+OOTXPPB	; A4 <-- ^bloc o est le curseur	COMP.L	(A4)+OBTNBC,#LBTCAR ; encore de la place dans ce bloc ?	JUMP,LO 50$		; oui => 50$; Ajoute un nouveau bloc aprs le bloc actuel (qui est plein).	LOAD.L	A3,A4		; A3 <-- ^bloc prcdent	LOAD.L	A2,(A3)+OBTNEXT	; A2 <-- ^bloc suivant	LOAD.L	D4,#LBT+(LBTCAR*2)	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour nouveau bloc	JUMP,NE 90$	LOAD.L	(A4)+OBTNEXT,A2	LOAD.L	(A4)+OBTPREV,A3	LOAD.L	(A3)+OBTNEXT,A4	LOAD.L	D1,A2	JUMP',EQ 30$	LOAD.L	(A2)+OBTPREV,A430$:	LOAD.L	D1,#LBTCAR	LOAD.L	D4,(A5)+OOTXPPR	SUB.L	D1,D4	JUMP',NE 40$	CLR.L	(A4)+OBTNBC	; ne contient encore rien	LOAD.L	(A5)+OOTXPPB,A4	CLR.L	(A5)+OOTXPPR	JUMP'	50$40$:	LOAD.L	(A4)+OBTNBC,D1	DEC.W	D1	SL.L	D4,#1	LOAD.L	A1,#(A3)+(D4.L)+LBT	LOAD.L	A2,#(A4)+LBT42$:	LOAD.W	(A2+),(A1+)	DECJ.W,NMO D1,42$	LOAD.L	A4,A3	LOAD.L	(A4)+OBTNBC,(A5)+OOTXPPR; Insre un caractre dans le bloc actuel.50$:	LOAD.L	D1,(A4)+OBTNBC	LOAD.L	A3,#(A4)+(D1.L)+LBT	ADD.L	A3,D1	SUB.L	D1,(A5)+OOTXPPR	JUMP',EQ 65$	DEC.W	D1	LOAD.L	A2,#(A3)+260$:	LOAD.W	(-A2),(-A3)	; pousse dans le bloc	DECJ.W,NMO D1,60$65$:	LOAD.W	(A3),D3		; bloc <-- met le nouveau caractre	INC.L	(A4)+OBTNBC	; un caractre de plus dans ce bloc	INC.L	(A5)+OOTXNBC	; un caractre de plus	INC.L	(A5)+OOTXPPR	; avance la position du curseur dans ce bloc	INC.L	(A5)+OOTXPOC	; avance la position du curseur	COMP.B	D3,#CR	JUMP',EQ 70$	COMP.B	D3,#LF	JUMP',NE 72$70$:	INC.L	(A5)+OOTXNBL	; une ligne de plus	INC.L	(A5)+OOTXPLI	; avance d'une ligne72$:	SET.B	(A5)+OOTXMAJ	; mise  jour ncessaire	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1,D3,D4,A1..A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; TXDETRUIT >;==========/; Dtruit le caractre plac juste avant le curseur dans un objet texte.; in	A5.L	^objet texte; out	D3.L	caractre dtruit;	D7.W	erreur; mod	D3.L, D7.WTXDETRUIT:	PUSHM.L	D1,D4,A2..A4	LOAD.L	A4,(A5)+OOTXPPB	; A4 <-- ^bloc o est le curseur	LOAD.L	D4,(A5)+OOTXPPR	; est-on au dbut du bloc ?	JUMP',NE 20$		; non => 20$				; oui =>	LOAD.W	D7,#1	LOAD.L	D4,(A4)+OBTPREV	JUMP,EQ 90$	LOAD.L	A4,D4		; A4 <-- ^bloc prcdent	LOAD.L	(A5)+OOTXPPB,A4	LOAD.L	D4,(A4)+OBTNBC	LOAD.L	(A5)+OOTXPPR,D4; Supprime un caractre dans le bloc actuel.20$:	LOAD.L	A3,#(A4)+(D4.L)+LBT	ADD.L	A3,D4	LOAD.W	D3,(A3)-2	; D3 <-- caractre dtruit	CALL	CARDECO		; D3 <-- caractre complet	LOAD.L	D1,(A4)+OBTNBC	SUB.L	D1,D4	JUMP',EQ 35$	DEC.W	D1	LOAD.L	A2,#(A3)-230$:	LOAD.W	(A2+),(A3+)	; compactifie le bloc	DECJ.W,NMO D1,30$35$:	DEC.L	(A4)+OBTNBC	; un caractre de moins dans ce bloc	DEC.L	(A5)+OOTXNBC	; un caractre de moins	DEC.L	(A5)+OOTXPPR	; recule la position du curseur dans ce bloc	DEC.L	(A5)+OOTXPOC	; recule la position du curseur	COMP.B	D3,#CR	JUMP',EQ 40$	COMP.B	D3,#LF	JUMP',NE 42$40$:	DEC.L	(A5)+OOTXNBL	; une ligne de moins	DEC.L	(A5)+OOTXPLI	; recule d'une ligne42$:	SET.B	(A5)+OOTXMAJ	; mise  jour ncessaire; Supprime le bloc actuel, s'il est entirement vide.50$:	TEST.L	(A4)+OBTNBC	; bloc entirement vide ?	JUMP,NE 80$		; non => 80$				; oui =>	LOAD.L	A3,(A4)+OBTPREV	; A3 <-- ^bloc prcdent	LOAD.L	A2,(A4)+OBTNEXT	; A2 <-- ^bloc suivant	LOAD.L	D4,A3	JUMP',NE 60$	LOAD.L	D4,A2	JUMP,EQ 80$				; bloc prcdent n'existe pas =>	LOAD.L	A3,A2	CLR.L	(A3)+OBTPREV	LOAD.L	(A5)+OOTXFBT,A3	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire du bloc	LOAD.L	(A5)+OOTXPPB,A3	CLR.L	(A5)+OOTXPPR	JUMP'	80$60$:	LOAD.L	D4,A2	JUMP',NE 65$				; bloc suivant n'existe pas =>	CLR.L	(A3)+OBTNEXT	JUMP'	70$65$:	LOAD.L	(A3)+OBTNEXT,A2	LOAD.L	(A2)+OBTPREV,A370$:	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire du bloc	LOAD.L	(A5)+OOTXPPB,A3	LOAD.L	(A5)+OOTXPPR,(A3)+OBTNBC80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1,D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; TXINIT  >;========/; Initialise un objet texte. Il sera vide et prt  tre utilis.; S'il contenait quelque chose, il est correctement vid.; in	A5.L	^objet texte; out	D7.W	erreur; mod	D7.WTXINIT:	PUSHM.L	D1,D4,A4	TEST.L	(A5)+OOTXFBT	JUMP',EQ 25$; Libre tous les bloc de texte utiliss, sauf le premier.	LOAD.L	A4,(A5)+OOTXFBT	LOAD.L	D4,(A4)+OBTNEXT	; D4 <-- ^deuxime bloc20$:	TEST.L	D4	JUMP',EQ 30$	LOAD.L	A4,D4		; A4 <-- ^bloc  supprimer	LOAD.L	D4,(A4)+OBTNEXT	; D4 <-- ^bloc suivant	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre un bloc	JUMP	20$; Cre un nouveau bloc libre.25$:	LOAD.L	D4,#LBT+(LBTCAR*2)	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour nouveau bloc	JUMP,NE 90$	LOAD.L	(A5)+OOTXFBT,A4; Initialise le premier (et unique) bloc.30$:	LOAD.L	A4,(A5)+OOTXFBT	CLR.L	(A4)+OBTPREV	CLR.L	(A4)+OBTNEXT	CLR.L	(A4)+OBTNBC	LOAD.L	(A5)+OOTXPPB,A4	CLR.L	(A5)+OOTXNBC	LOAD.L	(A5)+OOTXNBL,#1	CLR.L	(A5)+OOTXPOC	CLR.L	(A5)+OOTXPLI	CLR.L	(A5)+OOTXPPR	TCLR.B	(A5)+OOTXMAJ:#BTXMIO ; mise  jour disque pas ncessaire	TSET.B	(A5)+OOTXMAJ:#BTXMAF ; mise  jour affichage ncessaire	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1,D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; TXKILL  >;========/; Libre la mmoire d'un objet texte.; in	A5.L	^objet texte; out	-; mod	D7.WTXKILL:	PUSHM.L	D1,D4,A4	TEST.L	(A5)+OOTXPTL	JUMP',EQ 20$	LOAD.L	A4,(A5)+OOTXPTL	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire OTLxxx	CLR.L	(A5)+OOTXPTL20$:	TEST.L	(A5)+OOTXFBT	JUMP',EQ 90$; Libre tous les bloc de texte utiliss.	LOAD.L	A4,(A5)+OOTXFBT	CLR.L	(A5)+OOTXFBT30$:	LOAD.L	D4,(A4)+OBTNEXT	; D4 <-- ^bloc suivant	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre un bloc	TEST.L	D4	JUMP',EQ 90$	LOAD.L	A4,D4		; A4 <-- ^bloc  supprimer	JUMP	30$90$:	POPM.L	D1,D4,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CARDECO >;--------/; Dcode un caractre.; in	D3.W	caractre cod; out	D3.L	caractre complet; mod	D3.LCARDECO:	PUSH.B	D3		; stack <-- code du caractre	PUSH.L	A3	CLR.B	D3		; D3 <-- codage	RR.W	D3,#6		; D3 <-- /256 puis *4	LOAD.L	A3,#(A6)+OTXCOD	LOAD.L	D3,(A3)+(D3.W)	POP.L	A3	POP.B	D3		; D3 <-- caractre complet	RET;--------\\; CARCODE >;--------/; Code un caractre.; in	D3.L	caractre complet; out	D3.W	caractre cod;	D7.W	erreur; mod	D3.L, D7.WCARCODE:	PUSHM.L	D0,D2,D4,D5,A4	LOAD.B	D2,D3		; D2 <-- code du caractre	LOAD.B	D3,#1		; D3 <-- mode; Cherche si le mode demand existe dj.	LOAD.L	A4,#(A6)+OTXCOD	LOAD.W	D4,#TXMMAX-120$:	COMP.L	D3,(A4+)	; mode trouv ?	JUMP',EQ 37$		; oui => 37$	DECJ.W,NMO D4,20$; Cherche un emplacement libre.30$:	LOAD.L	A4,#(A6)+OTXCOD	LOAD.W	D4,#TXMMAX-132$:	TEST.L	(A4+)		; emplacement libre ?	JUMP',EQ 35$		; oui => 35$	DECJ.W,NMO D4,32$	JUMP'	40$35$:	LOAD.L	(A4)-4,D3	; OTXCOD <-- nouveau mode37$:	LOAD.W	D3,#TXMMAX-1	SUB.W	D3,D4		; D3 <-- codage (0..255)	RL.W	D3,#8	LOAD.B	D3,D2		; D3 <-- caractre cod	CLR.W	D7		; D7 <-- ok	JUMP'	90$; Regarde s'il existe des emplacements occups devenus inutiles,; car plus utiliss dans le texte.40$:	LOAD.W	D7,#190$:	POPM.L	D0,D2,D4,D5,A4	TEST.W	D7		; retour EQ/NE	RET	.END