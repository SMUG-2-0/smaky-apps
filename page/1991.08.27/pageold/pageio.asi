	.SBTTL	PAGEIOEFFACE:	CALL	DBOXEFFACE	; faut-il effacer ...	JUMP,NE _ERROR	COMP.W	D3,#F1	JUMP,NE _LOOP40$:	LOAD.L	A3,#(A6)+OUSE	LOAD.L	A4,(A3)+OLNEXT	COMP.L	A4,A3		; fin de la liste ?	JUMP,EQ _REFAIT		; oui => _REFAIT	LOAD.W	D7,#BASE_REMOVE	PAGE_	BASE		; enlve de la base de donnes	JUMP	40$PREND:	LOAD.L	A3,#(A6)+OBUNAME	CALL	DBOXPREND	; demande le nom ...	JUMP,NE _ERROR	COMP.W	D3,#F1	JUMP,NE _LOOP	PUSH.L	A340$:	LOAD.L	A3,#(A6)+OUSE	LOAD.L	A4,(A3)+OLNEXT	COMP.L	A4,A3		; fin de la liste ?	JUMP',EQ 44$		; oui => 44$	LOAD.W	D7,#BASE_REMOVE	PAGE_	BASE		; enlve de la base de donnes	JUMP	40$44$:	POP.L	A3	LOAD.W	D7,#IO_RPAGE	PAGE_	IO		; lit un fichier ".PAGE"	JUMP,EQ _REFAIT	CALL	DBOXERROR	; affiche l'erreur ...	JUMP	PRENDAJOUTE:	LOAD.L	A3,#(A6)+OAJNAME	LOAD.L	D4,(A6)+OAJFAN	CALL	DBOXAJOUTE	; demande le nom ...	JUMP,NE _ERROR	COMP.W	D3,#F1	JUMP,NE _LOOP	LOAD.L	(A6)+OAJFAN,D4	TEST.L	D4:#14	JUMP,BS AJIMAGE	JUMP	_LOOPSAUVE:	LOAD.L	A3,#(A6)+OBUNAME	CALL	DBOXCREATE	; demande le nom ...	JUMP,NE _ERROR	COMP.W	D3,#F1	JUMP,NE _LOOP	LOAD.W	D7,#IO_WPAGE	PAGE_	IO		; crit un fichier ".PAGE"	JUMP,EQ _LOOP	CALL	DBOXERROR	; affiche l'erreur ...	JUMP	SAUVEAJIMAGE:	CALL	WAITMOUSE	; met le sablier	LOAD.W	D3,#2^BOPRD	LOAD.L	D0,#FOS?OPEN	CALL	ERCALL		; ouvre l'image	JUMP',EQ 20$	COMP.W	D7,#ERKSTO	JUMP,EQ _LOOP	PUSH.W	D7	CLR.B	D3	CALL	SELMO		; outil = flche	CALL	SCMO		; remet la flche	CALL	NORMMOUSE	; remet la flche	LOAD.W	D3,#BIPERR	LIB	?BEEP		; fait un bruit	POP.W	D7	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	DBOX_	MERROR		; affiche l'erreur	JUMP	AJOUTE20$:	LOAD.L	A2,#(A6)+OBUHIMA ; A2 <-- ^en-tte image	LOAD.L	A4,A2	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 26$	COMP.B	(A4)+0,#H'82	; commence par en-tte binaire ?	JUMP',NE 22$		; non => 22$				; oui =>	CLR.B	D3	LOAD.L	D4,#256	FOS	?SPOS		; saute l'en-tte binaire	JUMP,NE 26$	LOAD.L	D4,#LGHIMA	FOS	?RDBYTE		; lit l'en-tte	JUMP,NE 26$22$:	LOAD.W	D4,(A2)+OIMDLX	; D3 <-- largeur de l'image	ADD.W	D4,#8-1	SR.W	D4,#3	MUL.WU	D4,(A2)+OIMDLY	; D4 <-- taille de l'image	ADD.L	D4,#OOIMMAT	LOAD.W	D3,#ICOIM	CLR.W	D2		; D2 <-- mode normal	LOAD.W	D7,#BASE_INSERT	PAGE_	BASE		; A4 <-- ^objet image	JUMP,NE 26$	LOAD.L	A5,A4		; A5 <-- ^objet image	LOAD.W	(A4)+OOTRAM,(A6)+OSLTRA	LOAD.L	(A5)+OOFOND,(A6)+OMFOND	LOAD.L	(A5)+OOIMPOS,(A6)+OPPOS	LOAD.W	D3,(A2)+OIMDLX	; D3 <-- largeur	LOAD.W	D4,(A2)+OIMDLY	; D4 <-- hauteur	LOAD.W	(A5)+OOIMDIM+2,D3	LOAD.W	(A5)+OOIMDIM+0,D4	LOAD.W	(A5)+OOIMLGX,D3	LOAD.W	(A5)+OOIMLGY,D4	ADD.W	D3,#8-1	SR.W	D3,#3	LOAD.W	(A5)+OOIMIIX,D3	LOAD.L	A4,#(A5)+OOIMMAT	LOAD.L	D4,(A2)+OIMNBB	; D4 <-- taille de l'image	TEST.B	(A2)+OIMCOD	; image code ?	JUMP',NE 24$		; oui => 24$				; non =>	FOS	?RDBYTE		; lit tout le data de l'image	JUMP'	28$24$:				; image code =>	LOAD.L	A3,A4		; A3 <-- ^pour image dcode	LOAD.L	A4,#(A4)-IMLBUF	; A4 <-- ^pour image code	FOS	?RDBYTE		; lit toute l'image code	JUMP',NE 28$	GRA_	DECOIMA		; dcode l'image ...	JUMP',NE 28$26$:	PUSH.W	D7	FOS	?CLOSE		; ferme l'image	POP.W	D7	JUMP,NE _ERROR	LOAD.L	A4,A5		; A4 <-- ^objet image	LOAD.W	D7,#DESS_INITIMZOOM	PAGE_	DESS		; calcule la matrice zoome	TSET.B	(A4)+OOFLG:#BOOSEL	JUMP	POIGNEE228$:	PUSH.W	D7	LOAD.L	A4,A5	LOAD.W	D7,#BASE_REMOVE	PAGE_	BASE		; libre l'objet image	FOS	?CLOSE		; ferme l'image	POP.W	D7	JUMP	_ERROR;----------\\; RDSTPRINT >;==========/; Lit le status de l'imprimante.; in	-; out	D7.W	erreur; mod	D7.WRDSTPRINT:	PUSHM.L	D3,D4,A2..A4	LOAD.W	(A6)+OFACX,#5	LOAD.W	(A6)+OFACY,#2	LOAD.W	(A6)+OMMX,#(254000/360)+1 ; 360e d'inch	LOAD.W	(A6)+OMMY,#(254000/144)+1 ; 144e d'inch	LOAD.L	A2,(A6)+OCAPRINT	LOAD.L	D4,#LGPRI0	; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OSTPRI	; A4 <-- ^buffer	PRINTA_	RSTATUS		; OPRSTA <-- status de l'imprimante	JUMP',NE 80$	LOAD.W	D4,(A4)+OPRGLX	SR.W	D4,#3	LOAD.W	(A6)+OFACX,D4	LOAD.W	D4,(A4)+OPRGLY	SR.W	D4,#3	LOAD.W	(A6)+OFACY,D4	LOAD.W	(A6)+OMMX,(A4)+OPRUMX+2	LOAD.W	(A6)+OMMY,(A4)+OPRUMY+280$:.IF DATEPRO	LOAD.L	A3,#R16"FILE1$	LOAD.L	D3,#DEFATT	FOS	?CHATR	FOS	?DELETE		; sabotage ...	LIB	?GETSHIFT	TEST.L	D3:#BPROGRA	JUMP,BS 90$	LIB	?RDCLOCK	; D4 <-- |w|j|m|a|	LOAD.W	D3,D4		; D3 <--     |m|a|	CLR.B	D3		; D3 <--     |m|-|	SWAP.W	D4		; D4 <-- |m|a|w|j|	AND.L	D4,#H'00FF00FF	; D4 <-- |-|a|-|j|	OR.W	D4,D3		; D4 <-- |-|a|m|j|	COMP.L	D4,#DATELOW	JUMP',LO 85$	COMP.L	D4,#DATEHIGH	JUMP',LS 90$85$:	LOAD.L	A3,#R16"FILE2$	LOAD.L	D3,#DEFATT	FOS	?CHATR	FOS	?DELETE		; sabotage ...	LOAD.W	D7,#ERSYNT.ENDIF90$:	POPM.L	D3,D4,A2..A4	TEST.W	D7		; retour EQ/NE	RETFILE1$:	.ASCIZ	"#:PAGE!CODE"FILE2$:	.ASCIZ	"#:SMA_PAGE.LIB"	.EVEN	.END