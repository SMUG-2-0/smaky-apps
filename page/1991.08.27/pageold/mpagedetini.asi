	.SBTTL	MPAGEDETINI;--------\\; DETINIT >;========/; Initialise les paramtres de dtection pour un objet quelconque,; et refait la matrice de fond.; in	A4.L	^objet quelconque; out	-; mod	D7.W	erreurDETINIT:	LOAD.W	(A4)+OOFSCA,#-1	; faudra reconstruire les matrices de fond;	CALL	DETINITQ;	RET;---------\\; DETINITQ >;=========/; Initialise les paramtres de dtection pour un objet quelconque.; in	A4.L	^objet quelconque; out	-; mod	D7.W	erreurDETINITQ:	COMP.W	(A4)+OOOBJ,#ICOTM	JUMP,EQ IDETTM	COMP.W	(A4)+OOOBJ,#ICOSP	JUMP,EQ IDETSP	COMP.W	(A4)+OOOBJ,#ICODR	JUMP,EQ IDETDR	COMP.W	(A4)+OOOBJ,#ICOLB	JUMP,EQ IDETLB	COMP.W	(A4)+OOOBJ,#ICOFL	JUMP,EQ IDETFL	COMP.W	(A4)+OOOBJ,#ICORD	JUMP,EQ IDETRDRA	COMP.W	(A4)+OOOBJ,#ICORA	JUMP,EQ IDETRDRA	COMP.W	(A4)+OOOBJ,#ICOPO	JUMP,EQ IDETPO	COMP.W	(A4)+OOOBJ,#ICOCE	JUMP,EQ IDETCE	COMP.W	(A4)+OOOBJ,#ICOEL	JUMP,EQ IDETEL	COMP.W	(A4)+OOOBJ,#ICOAR	JUMP,EQ IDETAR	COMP.W	(A4)+OOOBJ,#ICOIM	JUMP,EQ IDETIM	COMP.W	(A4)+OOOBJ,#ICOTX	JUMP,EQ IDETTX	RET;-------\\; IDETTM >;-------/; Initialise les paramtres de dtection pour un objet trait  main leve.; in	A4.L	^objet trait  main leve; out	-; mod	D7.WIDETTM:	PUSHM.L	D0,A3	LOAD.L	A3,#(A4)+OOTMPTS ; A3 <-- ^premier point	LOAD.W	D0,(A4)+OOTMNBP	; D0 <-- nb de points	CALL	IDETPOINTS	POPM.L	D0,A3	RET;-------\\; IDETSP >;-------/; Initialise les paramtres de dtection pour un objet spline.; in	A4.L	^objet spline; out	-; mod	D7.WIDETSP:	PUSHM.L	D0,A3	LOAD.L	A3,#(A4)+OOSPPTC ; A3 <-- ^premier point	LOAD.W	D0,(A4)+OOSPNBC	; D0 <-- nb de points	CALL	IDETPOINTS	POPM.L	D0,A3	RET;-------\\; IDETLB >;-------/; Initialise les paramtres de dtection pour un objet ligne brise.; in	A4.L	^objet ligne brise; out	-; mod	D7.WIDETLB:	PUSHM.L	D0,A3	LOAD.L	A3,#(A4)+OOLBPTS ; A3 <-- ^premier point	LOAD.W	D0,(A4)+OOLBNBP	; D0 <-- nb de points	CALL	IDETPOINTS	POPM.L	D0,A3	RET;-----------\\; IDETPOINTS >;-----------/; Initialise les paramtres de dtection pour une liste de points (un nuage).; in	A4.L	^objet;	A3.L	^premier point;	D0.W	nb de points; out	-; mod	D7.WIDETPOINTS:	PUSHM.L	D0..D4,A3	LOAD.W	D1,#H'7FFF	; D1 <-- X min	CLR.W	D2		; D2 <-- X max	LOAD.W	D3,D1		; D3 <-- Y min	CLR.W	D4		; D4 <-- Y max20$:	COMP.W	D1,(A3)+2	JUMP',LE 30$	LOAD.W	D1,(A3)+230$:	COMP.W	D2,(A3)+2	JUMP',GE 31$	LOAD.W	D2,(A3)+231$:	COMP.W	D3,(A3)+0	JUMP',LE 32$	LOAD.W	D3,(A3)+032$:	COMP.W	D4,(A3)+0	JUMP',GE 33$	LOAD.W	D4,(A3)+033$:	ADD.L	A3,#4		; A3 <-- ^point suivant	DEC.W	D0	JUMP,NE 20$	CALL	MATPENDIM	; D0 <-- dimensions du pinceau	SUB.W	D1,D0	ADD.W	D2,D0	SWAP.W	D0	SUB.W	D3,D0	ADD.W	D4,D0	LOAD.W	(A4)+OODPOS+2,D1	SUB.W	D2,D1	LOAD.W	(A4)+OODDIM+2,D2	LOAD.W	(A4)+OODPOS+0,D3	SUB.W	D4,D3	LOAD.W	(A4)+OODDIM+0,D4	POPM.L	D0..D4,A3	RET;-------\\; IDETDR >;-------/; Initialise les paramtres de dtection pour un objet droite.; in	A4.L	^objet droite; out	-; mod	D7.WIDETDR:	PUSHM.L	D0..D4	LOAD.L	D3,(A4)+OODRPOS	; D3 <-- position	LOAD.L	D4,(A4)+OODRDIM	; D4 <-- dimensions	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	D1,(A4)+OODRTYP	; D1 <-- type	CALL	INCLDROITE	; D4 <-- coin oppos	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A4)+OODRDIM,D4	CALL	MATPENDIM	; D0 <-- dimensions du pinceau	TEST.W	D4	JUMP',NC 20$	NEG.W	D4	SUB.W	D3,D420$:	SUB.W	D3,D0	ADD.W	D4,D0	ADD.W	D4,D0	SWAP.W	D3	SWAP.W	D4	SWAP.W	D0		; D0 <-- hauteur du pinceau	TEST.W	D4	JUMP',NC 30$	NEG.W	D4	SUB.W	D3,D430$:	SUB.W	D3,D0	ADD.W	D4,D0	ADD.W	D4,D0	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A4)+OODPOS,D3	LOAD.L	(A4)+OODDIM,D4	POPM.L	D0..D4	RET;-------\\; IDETFL >;-------/; Initialise les paramtres de dtection pour un objet flche.; in	A4.L	^objet flche; out	-; mod	D7.WIDETFL:	PUSHM.L	D0..D4,A3	LOAD.L	D3,(A4)+OOFLPOS	; D3 <-- position	LOAD.L	D4,(A4)+OOFLDIM	; D4 <-- dimensions	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	D1,(A4)+OOFLTYP	; D1 <-- type	LOAD.L	A3,#(A6)+OBUDIS	PUSH.W	(A6)+OSCALE	CLR.W	(A6)+OSCALE	; met l'chelle 1:1	CALL	CALFLECHE	; OBUDIS <-- coordonnes	POP.W	(A6)+OSCALE	LOAD.L	D0,D4	SUB.W	D0,D3	SWAP.W	D3	SWAP.W	D0	SUB.W	D0,D3	SWAP.W	D3	SWAP.W	D0	LOAD.L	(A4)+OOFLDIM,D0	LOAD.W	D1,#H'7FFF	; D1 <-- X min	CLR.W	D2		; D2 <-- X max	LOAD.W	D3,D1		; D3 <-- Y min	CLR.W	D4		; D4 <-- Y max20$:	LOAD.L	D0,(A3)	OR.L	D0,(A3)+4	; encore des points ?	JUMP',EQ 40$		; non => 40$	COMP.W	D1,(A3)+2	JUMP',LE 30$	LOAD.W	D1,(A3)+230$:	COMP.W	D2,(A3)+2	JUMP',GE 31$	LOAD.W	D2,(A3)+231$:	COMP.W	D3,(A3)+0	JUMP',LE 32$	LOAD.W	D3,(A3)+032$:	COMP.W	D4,(A3)+0	JUMP',GE 33$	LOAD.W	D4,(A3)+033$:	ADD.L	A3,#4		; A3 <-- ^point suivant	JUMP	20$40$:	CALL	MATPENDIM	; D0 <-- dimensions du pinceau	SUB.W	D1,D0	ADD.W	D2,D0	SWAP.W	D0	SUB.W	D3,D0	ADD.W	D4,D0	LOAD.W	(A4)+OODPOS+2,D1	SUB.W	D2,D1	LOAD.W	(A4)+OODDIM+2,D2	LOAD.W	(A4)+OODPOS+0,D3	SUB.W	D4,D3	LOAD.W	(A4)+OODDIM+0,D4	POPM.L	D0..D4,A3	RET;---------\\; IDETRDRA >;---------/; Initialise les paramtres de dtection pour un objet rectangle droit/arrondi.; in	A4.L	^objet rectangle droit/arrondi; out	-; mod	D7.WIDETRDRA:	PUSHM.L	D0,D2..D4	CALL	MATPENDIM	; D0 <-- dimensions du pinceau	LOAD.L	D3,(A4)+OORAPOS	LOAD.L	D4,(A4)+OORADIM	TEST.W	D4	JUMP',NC 20$	NEG.W	D4	SUB.W	D3,D420$:	SUB.W	D3,D0	ADD.W	D4,D0	ADD.W	D4,D0	SWAP.W	D3	SWAP.W	D4	SWAP.W	D0		; D0 <-- hauteur du pinceau	TEST.W	D4	JUMP',NC 30$	NEG.W	D4	SUB.W	D3,D430$:	SUB.W	D3,D0	ADD.W	D4,D0	ADD.W	D4,D0	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A4)+OODPOS,D3	LOAD.L	(A4)+OODDIM,D4	POPM.L	D0,D2..D4	RET;-------\\; IDETPO >;-------/; Initialise les paramtres de dtection pour un objet polygone.; in	A4.L	^objet polygone; out	-; mod	D7.WIDETPO:	PUSHM.L	D0..D6,A3	LOAD.L	D3,(A4)+OOPOPOS	; D3 <-- position	LOAD.L	D4,(A4)+OOPODIM	; D4 <-- dimensions	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	D6,(A4)+OOPOTYP	; D6 <-- mode	TEST.L	D6:#BPOMDIA	JUMP',BC 20$	PUSH.L	D4	SUB.W	D4,D3	ASR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	ASR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	POP.L	D420$:	LOAD.L	(A4)+OOPOCEN,D3	; OOPOCEN <-- centre pour dtection	LOAD.W	D1,#3	TEST.L	D6:#BPO3	JUMP',BS 50$	INC.W	D1	TEST.L	D6:#BPO4	JUMP',BS 50$	INC.W	D1	TEST.L	D6:#BPO5	JUMP',BS 50$	INC.W	D1	TEST.L	D6:#BPO6	JUMP',BS 50$	ADD.W	D1,#2	TEST.L	D6:#BPO8	JUMP',BS 50$	ADD.W	D1,#2;	TEST.L	D6:#BPO10;	JUMP',BS 50$50$:	CALL	CALCRAYON	; D5 <-- rayon	LOAD.W	(A4)+OOPORAY,D5	; OOPORAY <-- rayon pour dtection	LOAD.L	(A6)+OCCERC,D3	ADD.W	D3,D5	CALL	XTOURNE		; D2 <-- angle initial	LOAD.W	(A4)+OOPOAND,D2	; OOPOAND <-- angle de dpart	SWAP.W	D1		; D1 <-- nb de cts	LOAD.W	D1,(A4)+OOPOAND	; D1 <-- angle de dpart	LOAD.L	D3,(A4)+OOPOCEN	; D3 <-- centre (y;x)	LOAD.W	D4,(A4)+OOPORAY	; D4 <-- Ry	SWAP.W	D4	LOAD.W	D4,(A4)+OOPORAY	; D4 <-- Rx	LOAD.L	A3,#(A6)+OBUDIS	CALL	CALPOLYGONE	; OBUDIS <-- coordonnes	LOAD.W	D1,#H'7FFF	; D1 <-- X min	LOAD.W	D2,D1		; D2 <-- Y min	CLR.W	D3		; D3 <-- X max	CLR.W	D4		; D4 <-- Y max54$:	LOAD.L	D0,(A3+)	JUMP',NE 55$	TEST.L	(A3)	JUMP',EQ 59$55$:	COMP.W	D1,D0	JUMP',LE 56$	LOAD.W	D1,D0		; D1 <-- X min56$:	COMP.W	D3,D0	JUMP',GE 57$	LOAD.W	D3,D0		; D3 <-- X max57$:	SWAP.W	D0	COMP.W	D2,D0	JUMP',LE 58$	LOAD.W	D2,D0		; D2 <-- Y min58$:	COMP.W	D4,D0	JUMP,GE 54$	LOAD.W	D4,D0		; D4 <-- Y max	JUMP	54$59$:	SUB.W	D3,D1		; D3 <-- largeur	SUB.W	D4,D2		; D4 <-- hauteur	SWAP.W	D4	LOAD.W	D4,D3	LOAD.W	D3,D2	SWAP.W	D3	LOAD.W	D3,D1	CALL	MATPENDIM	; D0 <-- dimensions du pinceau	DEC.W	D3	ADD.W	D4,#2	SUB.W	D3,D0	ADD.W	D4,D0	ADD.W	D4,D0	SWAP.W	D0	SWAP.W	D3	SWAP.W	D4	DEC.W	D3	ADD.W	D4,#2	SUB.W	D3,D0	ADD.W	D4,D0	ADD.W	D4,D0	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A4)+OODPOS,D3	LOAD.L	(A4)+OODDIM,D4	POPM.L	D0..D6,A3	RET;-------\\; IDETCE >;-------/; Initialise les paramtres de dtection pour un objet cercle.; in	A4.L	^objet cercle; out	-; mod	D7.WIDETCE:	PUSHM.L	D0..D5	LOAD.L	D3,(A4)+OOCEPOS	; D3 <-- position	LOAD.L	D4,(A4)+OOCEDIM	; D4 <-- dimensions	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	D1,(A4)+OOCETYP	; D1 <-- mode	TEST.L	D1:#BCEMDIA	JUMP',BC 20$	PUSH.L	D4	SUB.W	D4,D3	ASR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	ASR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	POP.L	D420$:	LOAD.L	(A4)+OOCECEN,D3	; OOCECEN <-- centre pour dtection	CALL	CALCRAYON	; D5 <-- rayon	LOAD.W	(A4)+OOCERAY,D5	; OOCERAY <-- rayon pour dtection	SUB.W	D3,D5	SWAP.W	D3	SUB.W	D3,D5	SWAP.W	D3	SL.W	D5,#1	LOAD.W	D4,D5	SWAP.W	D4	LOAD.W	D4,D5	CALL	MATPENDIM	; D0 <-- dimensions du pinceau	DEC.W	D3	ADD.W	D4,#2	SUB.W	D3,D0	ADD.W	D4,D0	ADD.W	D4,D0	SWAP.W	D0	SWAP.W	D3	SWAP.W	D4	DEC.W	D3	ADD.W	D4,#2	SUB.W	D3,D0	ADD.W	D4,D0	ADD.W	D4,D0	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A4)+OODPOS,D3	LOAD.L	(A4)+OODDIM,D4	POPM.L	D0..D5	RET;-------\\; IDETEL >;-------/; Initialise les paramtres de dtection pour un objet ellipse.; in	A4.L	^objet ellipse; out	-; mod	D7.WIDETEL:	PUSHM.L	D0..D4	LOAD.L	D3,(A4)+OOELPOS	; D3 <-- position	LOAD.L	D4,(A4)+OOELDIM	; D4 <-- dimensions	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	D1,(A4)+OOELTYP	; D1 <-- mode	TEST.L	D1:#BELMDIA	JUMP',BC 20$	PUSH.L	D4	SUB.W	D4,D3	ASR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	ASR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	POP.L	D420$:	LOAD.L	(A4)+OOELCEN,D3	; OOELCEN <-- centre pour dtection	SUB.W	D4,D3		; D4 <-- rx 	JUMP',GE 23$	NEG.W	D423$:	SUB.W	D3,D4	SL.W	D4,#1	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- ry	JUMP',GE 24$	NEG.W	D424$:	SUB.W	D3,D4	SL.W	D4,#1	SWAP.W	D3	SWAP.W	D4	CALL	MATPENDIM	; D0 <-- dimensions du pinceau	DEC.W	D3	ADD.W	D4,#2	SUB.W	D3,D0	ADD.W	D4,D0	ADD.W	D4,D0	SWAP.W	D0	SWAP.W	D3	SWAP.W	D4	DEC.W	D3	ADD.W	D4,#2	SUB.W	D3,D0	ADD.W	D4,D0	ADD.W	D4,D0	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A4)+OODPOS,D3	LOAD.L	(A4)+OODDIM,D4	POPM.L	D0..D4	RET;-------\\; IDETAR >;-------/; Initialise les paramtres de dtection pour un objet arc.; in	A4.L	^objet arc; out	-; mod	D7.WIDETAR:	PUSHM.L	D0..D6,A3	LOAD.L	D3,(A4)+OOARPOS	; D3 <-- position	LOAD.L	D4,(A4)+OOARDIM	; D4 <-- dimensions	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	D6,(A4)+OOARTYP	; D6 <-- type	TEST.L	D6:#BARQ	JUMP,BS 50$				; ARC 1/2 OU 1/4 =>	TEST.L	D6:#BAREL	JUMP',BS 22$	CALL	CALCRAYON	; D5 <-- rayon	LOAD.W	(A4)+OOARRAY,D5	; OOARRAY <-- rayon pour dtection22$:	CLR.W	D0	SUB.W	D4,D3		; D4 <-- rx 	JUMP',GE 23$	NEG.W	D4	ADD.W	D0,#223$:	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- ry	JUMP',GE 24$	NEG.W	D4	ADD.W	D0,#424$:	SWAP.W	D3	SWAP.W	D4	TEST.L	D0:#2	JUMP',BC 26$	TNOT.L	D0:#1		; D0 <-- 0,2,4,6 selon cadrant26$:	LOAD.W	D1,#B'11000000	; D1 <-- arcs pour 1/4 cercle	TEST.L	D6:#BAR4	JUMP',BS 27$	LOAD.W	D1,#B'11110000	; D1 <-- arcs pour 1/2 cercle;	TEST.L	D6:#BAR2;	JUMP',BS 27$;	LOAD.W	D1,#B'11111111	; D1 <-- arcs pour cercle complet27$:	RR.B	D1,D0		; D1 <-- tourne les arcs selon le cadrant	TEST.L	D6:#BAREL	JUMP',BS 30$	LOAD.W	D4,D5		; D4 <-- Ry	SWAP.W	D4	LOAD.W	D4,D5		; D4 <-- Rx30$:	CLR.L	D0	LOAD.B	D2,D1	AND.B	D2,#B'00001111	JUMP',EQ 34$	SWAP.W	D0	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,D4	ADD.W	D0,D4	SWAP.W	D4	SWAP.W	D3	SWAP.W	D034$:	LOAD.B	D2,D1	AND.B	D2,#B'00111100	JUMP',EQ 35$	SUB.W	D3,D4	ADD.W	D0,D435$:	LOAD.B	D2,D1	AND.B	D2,#B'11110000	JUMP',EQ 36$	SWAP.W	D0	SWAP.W	D4	ADD.W	D0,D4	SWAP.W	D4	SWAP.W	D036$:	LOAD.B	D2,D1	AND.B	D2,#B'11000011	JUMP',EQ 37$	ADD.W	D0,D437$:	LOAD.L	D4,D0	JUMP	60$50$:				; ARC QUELCONQUE =>	CALL	CALCRAYON	; D5 <-- rayon	LOAD.W	(A4)+OOARRAY,D5	; OOARRAY <-- rayon pour dtection	LOAD.L	(A6)+OCCERC,D3	ADD.W	D3,D5	CALL	XTOURNE		; D2 <-- angle initial	LOAD.W	(A4)+OOARAND,D2	; OOARAND <-- angle de dpart	LOAD.L	A3,#(A6)+OBUDIS	CALL	CALDETARC	; OBUDIS <-- coordonnes	LOAD.W	D1,#H'7FFF	; D1 <-- X min	LOAD.W	D2,D1		; D2 <-- Y min	CLR.W	D3		; D3 <-- X max	CLR.W	D4		; D4 <-- Y max54$:	LOAD.L	D0,(A3+)	JUMP',NE 55$	TEST.L	(A3)	JUMP',EQ 59$55$:	COMP.W	D1,D0	JUMP',LE 56$	LOAD.W	D1,D0		; D1 <-- X min56$:	COMP.W	D3,D0	JUMP',GE 57$	LOAD.W	D3,D0		; D3 <-- X max57$:	SWAP.W	D0	COMP.W	D2,D0	JUMP',LE 58$	LOAD.W	D2,D0		; D2 <-- Y min58$:	COMP.W	D4,D0	JUMP,GE 54$	LOAD.W	D4,D0		; D4 <-- Y max	JUMP	54$59$:	SUB.W	D3,D1		; D3 <-- largeur	SUB.W	D4,D2		; D4 <-- hauteur	SWAP.W	D4	LOAD.W	D4,D3	LOAD.W	D3,D2	SWAP.W	D3	LOAD.W	D3,D160$:	CALL	MATPENDIM	; D0 <-- dimensions du pinceau	DEC.W	D3	ADD.W	D4,#2	SUB.W	D3,D0	ADD.W	D4,D0	ADD.W	D4,D0	SWAP.W	D0	SWAP.W	D3	SWAP.W	D4	DEC.W	D3	ADD.W	D4,#2	SUB.W	D3,D0	ADD.W	D4,D0	ADD.W	D4,D0	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A4)+OODPOS,D3	LOAD.L	(A4)+OODDIM,D4	POPM.L	D0..D6,A3	RET;-------\\; IDETIM >;-------/; Initialise les paramtres de dtection pour un objet image.; in	A4.L	^objet image; out	-; mod	D7.WIDETIM:	PUSHM.L	D2..D4	LOAD.L	D3,(A4)+OOIMPOS	LOAD.L	D4,(A4)+OOIMDIM	TEST.W	D4	JUMP',NC 20$	NEG.W	D4	SUB.W	D3,D420$:	DEC.W	D3	ADD.W	D4,#2	SWAP.W	D3	SWAP.W	D4	TEST.W	D4	JUMP',NC 22$	NEG.W	D4	SUB.W	D3,D422$:	DEC.W	D3	ADD.W	D4,#2	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A4)+OODPOS,D3	LOAD.L	(A4)+OODDIM,D4	POPM.L	D2..D4	RET;-------\\; IDETTX >;-------/; Initialise les paramtres de dtection pour un objet pav de texte.; in	A4.L	^objet image; out	-; mod	D7.WIDETTX:	PUSHM.L	D2..D4	LOAD.L	D3,(A4)+OOTXPOS	LOAD.L	D4,(A4)+OOTXDIM	TEST.W	D4	JUMP',NC 20$	NEG.W	D4	SUB.W	D3,D420$:	DEC.W	D3	ADD.W	D4,#2	SWAP.W	D3	SWAP.W	D4	TEST.W	D4	JUMP',NC 22$	NEG.W	D4	SUB.W	D3,D422$:	DEC.W	D3	ADD.W	D4,#2	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A4)+OODPOS,D3	LOAD.L	(A4)+OODDIM,D4	POPM.L	D2..D4	RET;----------\\; CALDETARC >;----------/; Calcule tous les points remarquable d'un arc de cercle pour; permettre de calculer son plus petit rectangle englobant,; en vue des dtections.;	          |;	      oooo4oooo             C: Pc (centre);	    oo    |    oo;	   o      |      D          D: Pd (dpart);	   o      |      o          A: Pa (arrive);	---3------C------1--->;	   o      |      o    x     1: P1 (0 degrs);	   o      |      o          2: P2 (90 degrs);	    oo    |    oo           3: P3 (180 degrs);	      oAoo2oooo             4: P4 (270 degrs);	          |;	          V  y; in	A4.L	^objet arc de cercle quelconque;	A3.L	^buffer pour coordonnes; out	-; mod	D7.WCALDETARC:	PUSHM.L	D1..D6,A3	LOAD.L	D6,(A4)+OOARTYP	; D6 <-- mode	LOAD.L	D3,(A4)+OOARPOS	; D3 <-- centre	TEST.L	D6:#BARTRA	; tranche de gteau ?	JUMP,BC 10$		; non => 10$	LOAD.L	(A3+),D3	; buffer <-- Pc10$:	LOAD.W	D1,(A4)+OOARAND	LOAD.W	D2,(A4)+OOARANG	SR.W	D2,#1	SUB.W	D1,D2		; D1 <-- angle de dpart	JUMP',NC 20$	ADD.W	D1,#36020$:;	LOAD.L	D3,(A4)+OOARPOS	LOAD.W	D4,(A4)+OOARRAY	SWAP.W	D4	LOAD.W	D4,(A4)+OOARRAY	LIB	?CALCPELLI	LOAD.L	(A3+),D5	; buffer <-- Pd	ADD.W	D1,(A4)+OOARANG	; D1 <-- angle d'arrive	COMP.W	D1,#360	JUMP',LO 22$	SUB.W	D1,#36022$:;	LOAD.L	D3,(A4)+OOARPOS;	LOAD.W	D4,(A4)+OOARRAY;	SWAP.W	D4;	LOAD.W	D4,(A4)+OOARRAY	LIB	?CALCPELLI	LOAD.L	(A3+),D5	; buffer <-- Pa	LOAD.W	D1,(A4)+OOARAND	LOAD.W	D2,(A4)+OOARANG	SR.W	D2,#1	SUB.W	D1,D2		; D1 <-- angle de dpart	JUMP',NC 32$	ADD.W	D1,#36032$:	LOAD.W	D2,D1	ADD.W	D2,(A4)+OOARANG	; D2 <-- angle d'arrive	COMP.W	D2,#360	JUMP',LO 33$	SUB.W	D2,#36033$:	CLR.W	D3	CALL	CALDETARCANGLE	; arc passe par 0 degrs ?	JUMP',NE 40$		; non => 40$	LOAD.L	D3,(A4)+OOARPOS	ADD.W	D3,(A4)+OOARRAY	LOAD.L	(A3+),D3	; buffer <-- P140$:	LOAD.W	D3,#90	CALL	CALDETARCANGLE	; arc passe par 90 degrs ?	JUMP',NE 42$		; non => 42$	LOAD.L	D3,(A4)+OOARPOS	SWAP.W	D3	ADD.W	D3,(A4)+OOARRAY	SWAP.W	D3	LOAD.L	(A3+),D3	; buffer <-- P242$:	LOAD.W	D3,#180	CALL	CALDETARCANGLE	; arc passe par 180 degrs ?	JUMP',NE 44$		; non => 44$	LOAD.L	D3,(A4)+OOARPOS	SUB.W	D3,(A4)+OOARRAY	LOAD.L	(A3+),D3	; buffer <-- P344$:	LOAD.W	D3,#270	CALL	CALDETARCANGLE	; arc passe par 270 degrs ?	JUMP',NE 46$		; non => 46$	LOAD.L	D3,(A4)+OOARPOS	SWAP.W	D3	SUB.W	D3,(A4)+OOARRAY	SWAP.W	D3	LOAD.L	(A3+),D3	; buffer <-- P446$:	CLR.L	(A3+)	CLR.L	(A3+)	POPM.L	D1..D6,A3	RET;---------------\\; CALDETARCANGLE >;---------------/; Regarde si un angle est inclu dans un arc.; in	D1.W	angle de dpart;	D2.W	angle d'arrive;	D3.W	angle cherch; out	D7.W	erreur; mod	D7.WCALDETARCANGLE:	CLR.W	D7		; D7 <-- angle inclu	COMP.W	D1,D2	JUMP',HS 40$	COMP.W	D3,D1	JUMP',LO 80$	COMP.W	D3,D2	JUMP',HI 80$	JUMP'	90$40$:	COMP.W	D3,D1	JUMP',HS 90$	COMP.W	D3,D2	JUMP',LS 90$80$:	LOAD.W	D7,#ERDIOUT	; D7 <-- angle en dehors90$:	TEST.W	D7		; retour EQ/NE	RET	.END