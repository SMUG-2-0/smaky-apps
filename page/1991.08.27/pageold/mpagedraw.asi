	.SBTTL	MPAGEDRAW;--------\\; XFLECHE >;--------/; Dessine une flche quelconque.; in	D3.L	coordonne d'un coin;	D4.L	coordonne coin oppos;	D2.B	mode de dessin;	D1.L	type (BFLxxxx); out	-; mod	D7.WXFLECHE:	PUSHM.L	D1..D4,A3	LOAD.L	A3,#(A6)+OBUDIS	CALL	CALFLECHE	; OBUDIS <-- coordonnes20$:	LOAD.L	D3,(A3+)	LOAD.L	D4,(A3+)	LOAD.L	D1,D3	OR.L	D1,D4	JUMP',EQ 90$	CALL	SEGMENT		; trace une droite	JUMP	20$90$:	POPM.L	D1..D4,A3	RET;--------\\; SEGMENT >;--------/; Dessine un segment de droite.; Si on est compltement en dehors, ne fait rien (clipping).; Ceci acclre beaucoup avec le pinceau, car le module GRA ; essaye toujours de dessiner ce qu'il peut, mme si y'a de; toute faon rien de rien (quel est l'ne qui a crit a) !; (*)	Dans le cas d'un traitill, il faut dessiner la droite;	mme si tout est cach, pour mettre  jour la position;	relative dans le traitill !!!; in	D3.L	coordonne d'un coin;	D4.L	coordonne coin oppos;	D2.B	mode de dessin; out	-; mod	D7.WSEGMENT:	PUSHM.L	D0,D1,D3,D5,D6	TEST.L	D2:#BTTTDOT	; traitill ?	JUMP,BS 50$		; oui => 50$, voir (*)	CLR.W	D0	CLR.W	D1	TEST.L	D2:#BPENDOT	JUMP',BC 10$	LOAD.W	D0,(A0)+ODFPDI+2	INC.W	D0		; D0 <-- demi-largeur pinceau	LOAD.W	D1,(A0)+ODFPDI+0	INC.W	D1		; D1 <-- demi-hauteur pinceau10$:	LOAD.L	D5,D3	LOAD.L	D6,D4	COMP.W	D5,D6	JUMP',LE 20$	EX.L	D5,D620$:	SUB.W	D5,D0	ADD.W	D6,D0	JUMP',NS 90$	COMP.W	D5,(A0)+ODFFDX	JUMP',GE 90$	SWAP.W	D5	SWAP.W	D6	COMP.W	D5,D6	JUMP',LE 30$	EX.L	D5,D630$:	SUB.W	D5,D1	ADD.W	D6,D1	JUMP',NS 90$	COMP.W	D5,(A0)+ODFFDY	JUMP',GE 90$50$:	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LIB	?DRSEG90$:	POPM.L	D0,D1,D3,D5,D6	RET;----------\\; CALFLECHE >;----------/; Effectue quelques calculs pour dessiner une droite quelconque (flche).; in	D3.L	coordonne d'un coin;	D4.L	coordonne coin oppos;	D1.L	type (BFLxxxx);	A3.L	^buffer pour coordonnes; out	D4.L	coordonne coin oppos ajuste; mod	D4.L, D7.WCALFLECHE:	PUSHM.L	D0..D3,D5,D6,A3	CALL	INCLDROITE	; D4 <-- coin oppos	PUSH.L	D4	TEST.L	D1:#BFLE2e	JUMP,BS 50$	TEST.L	D1:#BFLE1e	JUMP,BS 50$				; FLECHE INTERIEURE =>	TEST.L	D1:#BFLF2	JUMP',BS 30$				; flche  deux droites (forme en "V") =>	LOAD.L	(A3+),D3	LOAD.L	(A3+),D4	; trace ligne de base	TEST.L	D1:#BFLE2i	JUMP',BC 20$	CALL	CALIFLECHE	LOAD.L	(A3+),D3	LOAD.L	(A3+),D5	LOAD.L	(A3+),D3	LOAD.L	(A3+),D620$:	TEST.L	D1:#BFLE2i	JUMP',BS 21$	TEST.L	D1:#BFLE1i	JUMP,BC 90$21$:	EX.L	D3,D4	CALL	CALIFLECHE	LOAD.L	(A3+),D3	LOAD.L	(A3+),D5	LOAD.L	(A3+),D3	LOAD.L	(A3+),D6	JUMP	90$30$:				; flche  3 droites (triangle) =>	PUSH.L	D3	PUSH.L	D4	TEST.L	D1:#BFLE2i	JUMP',BC 40$	CALL	CALIFLECHE	LOAD.L	(SP)+4,D7	; stack <-- modifie D3	LOAD.L	(A3+),D3	LOAD.L	(A3+),D5	LOAD.L	(A3+),D5	LOAD.L	(A3+),D6	LOAD.L	(A3+),D6	LOAD.L	(A3+),D340$:	TEST.L	D1:#BFLE2i	JUMP',BS 41$	TEST.L	D1:#BFLE1i	JUMP',BC 45$41$:	EX.L	D3,D4	CALL	CALIFLECHE	LOAD.L	(SP)+0,D7	; stack <-- modifie D4	LOAD.L	(A3+),D3	LOAD.L	(A3+),D5	LOAD.L	(A3+),D5	LOAD.L	(A3+),D6	LOAD.L	(A3+),D6	LOAD.L	(A3+),D345$:	POP.L	D4	POP.L	D3	LOAD.L	(A3+),D3	LOAD.L	(A3+),D4	; trace ligne de base	JUMP	90$50$:				; FLECHE EXTERIEURE =>	TEST.L	D1:#BFLF2	JUMP',BS 70$				; flche  deux droites (forme en "V") =>	PUSH.L	D3	PUSH.L	D4	TEST.L	D1:#BFLE2e	JUMP',BC 60$	CALL	CALEFLECHE	LOAD.L	(SP)+4,D0	; stack <-- modifie D3	LOAD.L	(A3+),D3	LOAD.L	(A3+),D5	LOAD.L	(A3+),D3	LOAD.L	(A3+),D660$:	TEST.L	D1:#BFLE2e	JUMP',BS 61$	TEST.L	D1:#BFLE1e	JUMP',BC 65$61$:	EX.L	D3,D4	CALL	CALEFLECHE	LOAD.L	(SP)+0,D0	; stack <-- modifie D4	LOAD.L	(A3+),D3	LOAD.L	(A3+),D5	LOAD.L	(A3+),D3	LOAD.L	(A3+),D665$:	POP.L	D4	POP.L	D3	LOAD.L	(A3+),D3	LOAD.L	(A3+),D4	; trace ligne de base	JUMP	90$70$:				; flche  3 droites (triangle) =>	LOAD.L	(A3+),D3	LOAD.L	(A3+),D4	; trace ligne de base	TEST.L	D1:#BFLE2e	JUMP',BC 80$	CALL	CALEFLECHE	LOAD.L	(A3+),D3	LOAD.L	(A3+),D5	LOAD.L	(A3+),D5	LOAD.L	(A3+),D6	LOAD.L	(A3+),D6	LOAD.L	(A3+),D3	LOAD.L	(A3+),D7	LOAD.L	(A3+),D080$:	TEST.L	D1:#BFLE2e	JUMP',BS 81$	TEST.L	D1:#BFLE1e	JUMP',BC 90$81$:	EX.L	D3,D4	CALL	CALEFLECHE	LOAD.L	(A3+),D3	LOAD.L	(A3+),D5	LOAD.L	(A3+),D5	LOAD.L	(A3+),D6	LOAD.L	(A3+),D6	LOAD.L	(A3+),D3	LOAD.L	(A3+),D7	LOAD.L	(A3+),D0;	JUMP	90$90$:	CLR.L	(A3+)	CLR.L	(A3+)	POP.L	D4		; D4 <-- coin oppos ajust	POPM.L	D0..D3,D5,D6,A3	RET;-----------\\; CALIFLECHE >;-----------/; Calcul les coordonnes des trois points D5-D6-D7; pour une flche intrieure.;	               D5;	               |\;	               | \;	               |  \;	D4 +-----------+---> D3;	             D7|  //;	               | //;	               |//;	               D6; in	D3.L	point o mettre la flche (y;x);	D4.L	autre extrmit (y;x);	D1.B	type (BFLxxxx); out	D5.L	une extrmit;	D6.L	l'autre extrmit;	D7.L	point intermdiaire; mod	D5.L, D6.L, D7.LCALIFLECHE:	PUSHM.L	D0..D4	LOAD.L	D6,D1		; D6 <-- type	LOAD.W	D1,D4	SUB.W	D1,D3		; D1 <-- dx	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,D4	SUB.W	D2,D3		; D2 <-- dy	SWAP.W	D3	PUSH.L	D3	LOAD.W	D3,#32	TEST.L	D6:#BFLL32	JUMP',BS 20$	LOAD.W	D3,#16	TEST.L	D6:#BFLL16	JUMP',BS 20$	LOAD.W	D3,#8	TEST.L	D6:#BFLL8	JUMP',BS 20$	LOAD.W	D3,#420$:	CALL	DETSCALEP	; D3 <-- plus grand (si n:1)	LOAD.W	D0,D3	POP.L	D3	CALL	PYTHAGORE	LOAD.L	D7,D3	ADD.W	D7,D1	SWAP.W	D7	ADD.W	D7,D2	SWAP.W	D7		; D7 <-- P7(y;x)	TEST.L	D6:#BFLA45	JUMP',BS 50$	LOAD.W	D0,#1	TEST.L	D6:#BFLA27	JUMP',BS 40$	INC.W	D0	TEST.L	D6:#BFLA14	JUMP',BS 40$	INC.W	D040$:	ASR.W	D1,D0	ASR.W	D2,D050$:	LOAD.L	D5,D7	SUB.W	D5,D2	SWAP.W	D5	ADD.W	D5,D1	SWAP.W	D5	LOAD.L	D6,D7	ADD.W	D6,D2	SWAP.W	D6	SUB.W	D6,D1	SWAP.W	D6	POPM.L	D0..D4	RET;-----------\\; CALEFLECHE >;-----------/; Calcul les coordonnes des quatre points D5-D6-D7-D0; pour une flche extrieure.;	                  D5;	                 //|;	                // |;	               //  |;	D4 +-----------+---+---+;	             D3 \  |D7  D0;	                 \ |;	                  \|;	                  D6; in	D3.L	point o mettre la flche (y;x);	D4.L	autre extrmit (y;x);	D1.B	type (BFLxxxx); out	D5.L	une extrmit;	D6.L	l'autre extrmit;	D7.L	point intermdiaire;	D0.L	3me extrmit; mod	D5.L, D6.L, D7.LCALEFLECHE:	PUSHM.L	D1..D4	LOAD.L	D6,D1		; D6 <-- type	LOAD.W	D1,D4	SUB.W	D1,D3	NEG.W	D1		; D1 <-- dx	SWAP.W	D3	SWAP.W	D4	LOAD.W	D2,D4	SUB.W	D2,D3	NEG.W	D2		; D2 <-- dy	SWAP.W	D3	PUSH.L	D3	LOAD.W	D3,#32	TEST.L	D6:#BFLL32	JUMP',BS 20$	LOAD.W	D3,#16	TEST.L	D6:#BFLL16	JUMP',BS 20$	LOAD.W	D3,#8	TEST.L	D6:#BFLL8	JUMP',BS 20$	LOAD.W	D3,#420$:	CALL	DETSCALEP	; D3 <-- plus grand (si n:1)	LOAD.W	D0,D3	POP.L	D3	CALL	PYTHAGORE	LOAD.L	D7,D3	ADD.W	D7,D1	SWAP.W	D7	ADD.W	D7,D2	SWAP.W	D7		; D7 <-- P7(y;x)	ADD.W	D3,D1	ADD.W	D3,D1	SWAP.W	D3	ADD.W	D3,D2	ADD.W	D3,D2	SWAP.W	D3		; D3 <-- P0(y;x)	TEST.L	D6:#BFLA45	JUMP',BS 50$	LOAD.W	D0,#1	TEST.L	D6:#BFLA27	JUMP',BS 40$	INC.W	D0	TEST.L	D6:#BFLA14	JUMP',BS 40$	INC.W	D040$:	ASR.W	D1,D0	ASR.W	D2,D050$:	LOAD.L	D5,D7	SUB.W	D5,D2	SWAP.W	D5	ADD.W	D5,D1	SWAP.W	D5	LOAD.L	D6,D7	ADD.W	D6,D2	SWAP.W	D6	SUB.W	D6,D1	SWAP.W	D6	LOAD.L	D0,D3		; D0 <-- P0(y;x)	POPM.L	D1..D4	RET;-----------\\; XRECTANGLE >;-----------/; Dessine un rectangle quelconque (v. avec coins arrondis).; in	D3.L	coordonne d'un coin;	D4.L	coordonne coin oppos;	D2.B	mode de dessin;	D0.W	rayon; out	-; mod	D7.WXRECTANGLE:	PUSHM.L	D0..D4	CALL	CALRECTANGLE	; D0 <-- rayon possible	EX.L	D1,D3	EX.L	D2,D4	CALL	ORDONNE	EX.L	D3,D1	EX.L	D4,D2	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D1,D0		; D1 <-- rayon	LIB	?DRRECTA	; dessine un rectangle arrondi	POPM.L	D0..D4	RET;---------\\; XTRARECT >;---------/; Dessine une trame rectangulaire quelconque (v. avec coins arrondis).; in	D3.L	coordonne d'un coin;	D4.L	coordonne coin oppos;	D2.B	mode de dessin;	D0.W	rayon; out	-; mod	D7.WXTRARECT:	PUSHM.L	D0..D4	CALL	CALRECTANGLE	; D0 <-- rayon possible	EX.L	D1,D3	EX.L	D2,D4	CALL	ORDONNE	EX.L	D3,D1	EX.L	D4,D2	SUB.W	D4,D3	INC.W	D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	INC.W	D4	SWAP.W	D3	SWAP.W	D4	LOAD.W	D1,D0		; D1 <-- rayon	LIB	?DRTRAMEA	; dessine une trame arrondie	POPM.L	D0..D4	RET;-------------\\; CALRECTANGLE >;-------------/; Calcule le rayon possible pour un rectangle vide ou une trame; rectangulaire aux coins arrondis.; in	D3.L	coordonne d'un coin;	D4.L	coordonne coin oppos;	D0.W	rayon quelconque; out	D0.W	rayon possible; mod	D0.L, D7.WCALRECTANGLE:	PUSHM.L	D3,D4	SUB.W	D3,D4	JUMP',NC 10$	NEG.W	D3		; D3 <-- |largeur|10$:	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	JUMP',NC 12$	NEG.W	D4		; D4 <-- |hauteur|12$:	SWAP.W	D3	COMP.W	D3,D4	JUMP',LS 20$	LOAD.W	D3,D4		; D3 <-- MIN(largeur,hauteur)20$:	SR.W	D3,#1		; D3 <-- rayon minimum	SUB.W	D3,#2	COMP.W	D0,D3	JUMP',LE 90$	CLR.W	D0	COMP.W	D3,#3	JUMP',LE 90$	LOAD.W	D0,#3	COMP.W	D3,#4	JUMP',LE 90$	LOAD.W	D0,#4	COMP.W	D3,#8	JUMP',LE 90$	LOAD.W	D0,#8	COMP.W	D3,#12	JUMP',LE 90$	LOAD.W	D0,#12	COMP.W	D3,#16	JUMP',LE 90$	LOAD.W	D0,#1690$:	POPM.L	D3,D4	RET;--------\\; XCERCLE >;--------/; Dessine un cercle quelconque.; in	D3.L	coordonne d'un coin;	D4.L	coordonne coin oppos;	D2.B	mode de dessin;	D1.L	type; out	-; mod	D7.WXCERCLE:	PUSHM.L	D1..D5	TEST.L	D1:#BCEMDIA	JUMP',BC 10$	PUSH.L	D4	SUB.W	D4,D3	ASR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	ASR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	POP.L	D410$:	CALL	CALCRAYON	; D5 <-- rayon	COMP.W	D5,#2	JUMP',LS 90$	LOAD.W	D4,D5		; D4 <-- Ry	SWAP.W	D4	LOAD.W	D4,D5		; D4 <-- Rx	LOAD.W	D1,#B'11111111	; D1 <-- arcs pour cercle complet	CALL	ELLIPSE		; dessine un cercle90$:	POPM.L	D1..D5	RET;---------\\; XELLIPSE >;---------/; Dessine une ellipse quelconque.; in	D3.L	coordonne d'un coin;	D4.L	coordonne coin oppos;	D2.B	mode de dessin;	D1.L	type; out	-; mod	D7.WXELLIPSE:	PUSHM.L	D1..D5	TEST.L	D1:#BELMDIA	JUMP',BC 10$	PUSH.L	D4	SUB.W	D4,D3	ASR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	ASR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	POP.L	D410$:	SUB.W	D4,D3		; D4 <-- rx 	JUMP',GE 23$	NEG.W	D423$:	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- ry	JUMP',GE 24$	NEG.W	D424$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D1,#B'11111111	; D1 <-- arcs pour ellipse complte	CALL	ELLIPSE		; dessine une ellipse90$:	POPM.L	D1..D5	RET;-----\\; XARC >;-----/; Dessine un arc quelconque.; in	D3.L	coordonne d'un coin;	D4.L	coordonne coin oppos;	D2.B	mode de dessin;	D0.W	angle;	D1.L	type; out	-; mod	D7.WXARC:	PUSHM.L	D0..D6	LOAD.L	D6,D1		; D6 <-- type	TEST.L	D6:#BARQ	JUMP,BS 40$				; ARC 1/2 OU 1/4 =>	TEST.L	D6:#BAREL	JUMP',BS 22$	CALL	CALCRAYON	; D5 <-- rayon22$:	CLR.W	D0	SUB.W	D4,D3		; D4 <-- rx 	JUMP',GE 23$	NEG.W	D4	ADD.W	D0,#223$:	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- ry	JUMP',GE 24$	NEG.W	D4	ADD.W	D0,#424$:	SWAP.W	D3	SWAP.W	D4	TEST.L	D0:#2	JUMP',BC 26$	TNOT.L	D0:#1		; D0 <-- 0,2,4,6 selon cadrant26$:	LOAD.W	D1,#B'11000000	; D1 <-- arcs pour 1/4 cercle	TEST.L	D6:#BAR4	JUMP',BS 27$	LOAD.W	D1,#B'11110000	; D1 <-- arcs pour 1/2 cercle;	TEST.L	D6:#BAR2;	JUMP',BS 27$;	LOAD.W	D1,#B'11111111	; D1 <-- arcs pour cercle complet27$:	RR.B	D1,D0		; D1 <-- tourne les arcs selon le cadrant	TEST.L	D6:#BAREL	JUMP',BS 28$	LOAD.W	D4,D5		; D4 <-- Ry	SWAP.W	D4	LOAD.W	D4,D5		; D4 <-- Rx28$:	CALL	ELLIPSE		; dessine un cercle ou une ellipse	JUMP	90$40$:				; ARC QUELCONQUE =>	TEST.W	D0	JUMP,EQ 90$	CALL	CALCRAYON	; D5 <-- rayon	PUSHM.L	D2,D3	LOAD.L	(A6)+OCCERC,D3	ADD.W	D3,D5	CALL	XTOURNE		; D2 <-- angle initial	LOAD.W	D1,D2	LOAD.W	D2,D0	SR.W	D2,#1	SUB.W	D1,D2		; D1 <-- angle de dpart	JUMP',NC 44$	ADD.W	D1,#36044$:	LOAD.W	D2,D1	ADD.W	D2,D0		; D2 <-- angle d'arrive	SWAP.W	D1	LOAD.W	D1,D2		; D1 <-- angles (a;d)	SWAP.W	D1	POPM.L	D2,D3	LOAD.W	D4,D5		; D4 <-- Ry	SWAP.W	D4	LOAD.W	D4,D5		; D4 <-- Rx	TEST.L	D6:#BARTRA	JUMP',BS 48$	LIB	?DRARC		; dessine un arc de cercle	JUMP'	90$48$:	LIB	?DRTRANCHE	; dessine un tranche de gteau (miam);	JUMP'	90$90$:	POPM.L	D0..D6	RET;--------\\; ELLIPSE >;--------/; Dessine un arc de cercle ou d'ellipse.; in	D3.L	origine centre (y;x);	D4.L	rayons (ry;rx);	D2.W	mode de dessin;	D1.W	octants  dessiner; out	-; mod	D7.WELLIPSE:	COMP.W	D4,#3	JUMP',HS 22$	SWAP.W	D4	COMP.W	D4,#3	JUMP',HS 20$	SWAP.W	D4	JUMP'	90$20$:	SWAP.W	D422$:	LIB	?DRELLIPSE	; dessine un cercle ou une ellipse90$:	RET;----------\\; XPOLYGONE >;----------/; Dessine un polygone avec un nombre quelconque de cts.; in	D3.L	origine (y;x);	D4.L	arrive (y;x);	D2.B	mode de dessin;	D1.L	type; out	-; mod	D7.WXPOLYGONE:	PUSHM.L	D0..D5,A3	TEST.L	D1:#BPOMDIA	JUMP',BC 10$	PUSH.L	D4	SUB.W	D4,D3	ASR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	ASR.W	D4,#1	ADD.W	D3,D4	SWAP.W	D3;	SWAP.W	D4	POP.L	D410$:	LOAD.W	D0,#3	TEST.L	D1:#BPO3	JUMP',BS 20$	INC.W	D0	TEST.L	D1:#BPO4	JUMP',BS 20$	INC.W	D0	TEST.L	D1:#BPO5	JUMP',BS 20$	INC.W	D0	TEST.L	D1:#BPO6	JUMP',BS 20$	ADD.W	D0,#2	TEST.L	D1:#BPO8	JUMP',BS 20$	ADD.W	D0,#2;	TEST.L	D1:#BPO10;	JUMP',BS 20$20$:	CALL	CALCRAYON	; D5 <-- rayon	PUSHM.L	D2,D3	LOAD.L	(A6)+OCCERC,D3	ADD.W	D3,D5	CALL	XTOURNE		; D2 <-- angle initial	LOAD.W	D1,D0		; D1 <-- nb de cts	SWAP.W	D1	LOAD.W	D1,D2		; D1 <-- angle	POPM.L	D2,D3	LOAD.W	D4,D5		; D4 <-- Ry	SWAP.W	D4	LOAD.W	D4,D5		; D4 <-- Rx	LOAD.L	A3,#(A6)+OBUDIS	CALL	CALPOLYGONE	; OBUDIS <-- coordonnes40$:	LOAD.L	D3,(A3+)	LOAD.L	D4,(A3+)	LOAD.L	D1,D3	OR.L	D1,D4	JUMP',EQ 90$	CALL	SEGMENT		; trace une droite	TSET.L	D2:#BNCTDOT	; D2 <-- plus de rz du traitill	JUMP	40$90$:	POPM.L	D0..D5,A3	RET;------------\\; CALPOLYGONE >;------------/; Calcule un polygone  "n" cts.; Le polygone est inscrit dans l'ellipse D3/D4.; Un sommet est toujours prsent  l'angle de dpart.; in	D3.L	origine centre (y;x);	D4.L	rayons (ry;rx);	D1.L	angles de dpart en degrs et nombre de cts (n;d);		 d: 0..360 (dans le sens des aiguilles de la montre);		 n: 3,4,5,6,8,9,10;	A3.L	^buffer pour coordonnes; out	D7.W	erreur; mod	D7.WCALPOLYGONE:	PUSHM.L	D0..D6,A3	LOAD.L	D0,D1		; D1 <-- angle de dpart	SWAP.W	D0		; D0 <-- nb de cts	LOAD.W	D7,#ERDIOUT	; D7 <-- a va pas la tte !	COMP.W	D0,#3		; moins qu'un triangle ?	JUMP,LO 90$	COMP.W	D0,#10	JUMP,HI 90$	LOAD.L	D6,#360	DIV.WU	D6,D0		; D6 <-- incrment pour l'angle	SWAP.W	D6	TEST.W	D6		; reste  la division ?	JUMP,NE 90$		; oui => 90$	SWAP.W	D6	LIB	?CALCPELLI	; D5 <-- point sur l'ellipse20$:	ADD.W	D1,D6		; D1 <-- angle suivant	LOAD.L	(A3+),D5	LIB	?CALCPELLI	; D5 <-- arrive (point sur l'ellipse)	LOAD.L	(A3+),D5	DEC.W	D0		; encore un ct ?	JUMP,NE 20$		; oui => 20$	CLR.W	D7		; D7 <-- ok90$:	CLR.L	(A3+)	CLR.L	(A3+)	POPM.L	D0..D6,A3	RET;---------\\; ROTTRAME >;---------/; Modifie ventuellement une trame en fonction de l'origine dans la page.; Cette routine fut une vritable terreur  mettre au point, mme si elle; n'en a pas l'air !; in	D5/D6	trame; out	D5/D6	trame; mod	D5.L, D6.LROTTRAME:	PUSHM.L	D3,D4; Dcale la trame selon le dplacement vertical.	LOAD.W	D3,(A6)+OPPOS+0	CALL	DETSCALEP	; D3 <-- plus grand (si n:1)	LOAD.W	D4,D3	SUB.W	D4,(A0)+ODFFY	AND.W	D4,#H'0007	DEC.W	D4		; D4 <-- -1  cause NMO	JUMP',NS 30$20$:	RL.L	D5,#8	RL.L	D6,#8	LOAD.B	D3,D5	LOAD.B	D5,D6		; EX.B D5,D6	LOAD.B	D6,D3	DECJ.W,NMO D4,20$; Dcale la trame selon le dplacement horizontal.30$:	LOAD.W	D3,(A6)+OPPOS+2	CALL	DETSCALEP	; D3 <-- plus grand (si n:1)	LOAD.W	D4,D3;	SUB.W	D4,(A0)+ODFFX	; surtout pas !	AND.W	D4,#H'0007	JUMP',EQ 90$	RR.B	D5,D4	RR.L	D5,#8	RR.B	D5,D4	RR.L	D5,#8	RR.B	D5,D4	RR.L	D5,#8	RR.B	D5,D4	RR.L	D5,#8	RR.B	D6,D4	RR.L	D6,#8	RR.B	D6,D4	RR.L	D6,#8	RR.B	D6,D4	RR.L	D6,#8	RR.B	D6,D4	RR.L	D6,#890$:	POPM.L	D3,D4	RET;--------\\; OPEWDO  >;--------/; Utilise la swdo de dessin, si ncessaire.; in	-; out	-; mod	D7.WOPEWDO:	TEST.W	(A6)+OWUSE	JUMP',NE 20$	PUSHM.L	D3,A3	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DIMWDO	LOAD.W	(A3)+1,(A6)+OWPOS+2	LOAD.W	(A3)+3,(A6)+OWPOS+0	LOAD.W	(A3)+5,(A6)+OWDIM+2	LOAD.W	(A3)+7,(A6)+OWDIM+0	LOAD.W	D3,#9	LIB	?STRING	POPM.L	D3,A320$:	INC.W	(A6)+OWUSE	RET;--------\\; CLOWDO  >;--------/; Ferme la swdo de dessin, si ncessaire.; in	-; out	-; mod	D7.WCLOWDO:	DEC.W	(A6)+OWUSE	JUMP',NE 90$	PUSHM.L	D3,A3	LOAD.L	A3,#(A6)+OBUDIS+1	LOAD.B	(A3)+0,#DIMWDO	CLR.L	(A3)+1	LOAD.W	(A3)+5,(A0)+ODFDX	LOAD.W	(A3)+7,(A0)+ODFDY	LOAD.W	D3,#9	LIB	?STRING	POPM.L	D3,A390$:	RET;--------\\; ORDONNE >;========/; Ordonne D1.L et D2.L pour que D1 soit en haut  gauche et; D2 en bas  droite (D1<D2).; in	D1.L	position d'un coin;	D2.L	position de l'autre coin; out	D1.L	position d'un coin;	D2.L	position de l'autre coin; mod	D1.L, D2.LORDONNE:	PUSH.W	D3	COMP.W	D1,D2	JUMP',LE 10$	LOAD.W	D3,D1	LOAD.W	D1,D2		; EX.W D1,D2	LOAD.W	D2,D310$:	SWAP.W	D1	SWAP.W	D2	COMP.W	D1,D2	JUMP',LE 15$	LOAD.W	D3,D1	LOAD.W	D1,D2		; EX.W D1,D2	LOAD.W	D2,D315$:	SWAP.W	D1	SWAP.W	D2	POP.W	D3	RET	.END