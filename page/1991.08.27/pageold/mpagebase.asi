	.SBTTL	MPAGEBASE;-----------\\; _PAGE_BASE >;===========/; ; in	D7.W	numro du sous-appel;	?	selon appel; out	?	selon appel; mod	?	selon appel_PAGE_BASE:	COMP.W	D7,#BASE_INIT	JUMP,EQ INIT	COMP.W	D7,#BASE_INSERT	JUMP,EQ INSERT	COMP.W	D7,#BASE_DUPLICATA	JUMP,EQ DUPLICATA	COMP.W	D7,#BASE_REMOVE	JUMP,EQ REMOVE	COMP.W	D7,#BASE_FIRST	JUMP,EQ FIRST	COMP.W	D7,#BASE_LAST	JUMP,EQ LAST	RET;----------\\; DUPLICATA >;==========/; Effectue un double d'un objet quelconque.; in	A4.L	^objet quelconque; out	A3.L	^double de l'objet;	D7.W	erreur; mod	D7.W, A3.LDUPLICATA:	PUSHM.L	D2..D4,A4	LOAD.L	A3,A4	LOAD.W	D4,(A4)+OLLG	CLR.W	D3		; D3 <-- pas un objet !	CLR.W	D2		; D2 <-- ajoute  la fin de la liste	CALL	INSERT		; A4 <-- ^objet	JUMP,NE 90$	PUSHM.L	A3,A4	LOAD.L	A3,#(A3)+LGL	LOAD.L	A4,#(A4)+LGL	SUB.W	D4,#LGL	SR.W	D4,#1		; D4 <-- /2 car .W	DEC.W	D4		; D4 <-- -1 car NMO40$:	LOAD.W	(A4+),(A3+)	DECJ.W,NMO D4,40$	POPM.L	A3,A4	CLR.L	(A4)+OOFPM	; on ne peut pas doubler la matrice de fond !	CLR.L	(A4)+OOFPT	; on ne peut pas doubler la matrice de trame !	COMP.W	(A4)+OOOBJ,#ICOIM	JUMP',NE 50$	CLR.L	(A4)+OOIMPMZ	; on ne peut pas doubler la matrice zoome !50$:	COMP.W	(A4)+OOOBJ,#ICOTX	JUMP',NE 52$	CLR.L	(A4)+OOTXFBT	CLR.L	(A4)+OOTXPTL	EX.L	A5,A4	CALL	TXINIT		; initialise un objet texte vide	EX.L	A4,A552$:	LOAD.L	A3,A490$:	POPM.L	D2..D4,A4	TEST.W	D7		; retour EQ/NE	RET;-------\\; INSERT >;=======/; Ajoute un objet dans la liste.; in	D4.W	longueur de l'objet (pair);	D3.W	objet (ICOxx);	D2.W	mode;	A4.L	^objet avant lequel insrer/nil (si D2=1); out	A4.L	^objet;	D7.W	erreur; mod	D7.W, A4.LINSERT:	PUSHM.L	D1,D3,D4,A0..A3	LOAD.W	D7,#ERPFULL	; D7 <-- c'est plein	LOAD.L	A0,A4	LOAD.W	D1,D3		; D1 <-- objet; Cherche un trou ayant exactement la bonne longueur en parcourant; la liste des objets libres.	LOAD.L	A3,#(A6)+OFREE	LOAD.L	A4,(A3)+OLPREV20$:	COMP.L	A4,A3		; fin de la liste ?	JUMP',EQ 30$		; oui => 30$	COMP.W	D4,(A4)+OLLG	; juste la bonne place ici ?	JUMP',EQ 40$		; oui => 40$	LOAD.L	A4,(A4)+OLPREV	; A4 <-- ^suivant	JUMP	20$; Cherche un trou pouvant se transformer en deux (un objet suivi d'un trou); en parcourant la liste des objets libres.30$:	ADD.W	D4,#LGL		; D4 <-- lg minimale pour ddoubler un objet;	LOAD.L	A3,#(A6)+OFREE	LOAD.L	A4,(A3)+OLPREV32$:	COMP.L	A4,A3		; fin de la liste ?	JUMP,EQ 90$		; oui => 90$	COMP.W	D4,(A4)+OLLG	; assez (mais trop) de place ici ?	JUMP',LS 50$		; oui => 50$	LOAD.L	A4,(A4)+OLPREV	; A4 <-- ^suivant	JUMP	32$; Remplace le trou par un objet ayant exactement la mme longueur.40$:				; juste la place =>	CALL	SUBLIST		; enlve de la liste des libres	JUMP'	55$; Remplace le trou par un objet suivit d'un trou plus petit.50$:				; trop de place =>	SUB.W	D4,#LGL		; D4 <-- lg pour l'objet	LOAD.L	A3,(A4)+OLNEXT	LOAD.L	A2,(A4)+OLPREV	LOAD.L	A1,#(A4)+(D4.W)	LOAD.W	D3,(A4)+OLLG	SUB.W	D3,D4	LOAD.W	(A1)+OLLG,D3	LOAD.L	(A1)+OLPREV,(A4)+OLPREV	LOAD.L	(A1)+OLNEXT,(A4)+OLNEXT	LOAD.L	(A3)+OLPREV,A1	LOAD.L	(A2)+OLNEXT,A1	LOAD.W	(A4)+OLLG,D455$:	LOAD.L	A3,#(A6)+OUSE	; A3 <-- ajoute  la fin de la liste (devant)	COMP.W	D2,#1	JUMP',NE 56$	COMP.L	A0,#0	JUMP',EQ 56$	LOAD.L	A3,A0		; A3 <-- ajoute n'importe o56$:	CALL	ADDLIST		; ajoute  la liste des utiliss; Rempli l'objet avec des zros.	LOAD.L	A3,#(A4)+LGL	; A3 <-- ^dbut du data	LOAD.W	D4,(A4)+OLLG	; D4 <-- lg de l'objet	SUB.W	D4,#LGL		; D4 <-- n'efface pas le dbut	SR.W	D4,#1		; D4 <-- /2 car .W	DEC.W	D4		; D4 <-- -1 car NMO	CLR.W	D3		; D3 <-- pour effacer plus vite que CLR.W (A3+) !60$:	LOAD.W	(A3+),D3	; efface le data	DECJ.W,NMO D4,60$	LOAD.W	(A4)+OOOBJ,D1	; OOOBJ <-- type de l'objet	COMP.W	D1,#ICOTX	JUMP',NE 80$	EX.L	A5,A4	CALL	TXINIT		; initialise un objet texte vide	EX.L	A4,A580$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1,D3,D4,A0..A3	TEST.W	D7		; retour EQ/NE	RET;-------\\; REMOVE >;=======/; Supprime un objet dans la liste.; in	A4.L	^objet; out	D7.W	erreur; mod	D7.WREMOVE:	PUSHM.L	D1,A3,A4	TEST.L	(A4)+OOFPM	; matrice de fond existe ?	JUMP',EQ 20$		; non => 20$	LOAD.L	A3,A4	LOAD.L	A4,(A4)+OOFPM	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la matrice du fond	LOAD.L	A4,A320$:	TEST.L	(A4)+OOFPT	; matrice de trame existe ?	JUMP',EQ 25$		; non => 25$	LOAD.L	A3,A4	LOAD.L	A4,(A4)+OOFPT	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la matrice de trame	LOAD.L	A4,A325$:	COMP.W	(A4)+OOOBJ,#ICOTX	JUMP',NE 30$	EX.L	A5,A4	CALL	TXKILL		; libre l'objet texte	EX.L	A4,A530$:	CALL	SUBLIST		; enlve de la liste des utiliss	LOAD.L	A3,#(A6)+OFREE	CALL	ADDLIST		; ajoute  la liste des libres40$:	CALL	APPEND		; essaye d'appondre deux trous	JUMP,NE 40$		; si fait qq chose => essaye encore	POPM.L	D1,A3,A4	CLR.W	D7		; retour EQ	RET;--------\\; APPEND  >;--------/; Tente d'appondre un trou au suivant ou au prcdent.; in	A4.L	^trou; out	A4.L	^trou appondu avec un autre;	D7.W	EQ => rien n'a t appondu; mod	D7.W, A4.LAPPEND:	PUSHM.L	D3,A2,A3	CLR.W	D7		; D7 <-- rien fait; Si l'objet devenu trou est suivi d'un autre trou, fusionne les deux; trous en un seul.	LOAD.L	A3,A4	ADD.W	A3,(A4)+OLLG	COMP.L	A3,(A4)+OLPREV	; trou juste aprs ?	JUMP',NE 20$		; non => 20$				; oui =>	LOAD.W	D3,(A3)+OLLG	ADD.W	(A4)+OLLG,D3	LOAD.L	A2,(A3)+OLPREV	LOAD.L	(A4)+OLPREV,A2	LOAD.L	(A2)+OLNEXT,A4	INC.W	D7		; D7 <-- deux trous appondus	JUMP'	30$20$:	LOAD.L	A3,A4	ADD.W	A3,(A4)+OLLG	COMP.L	A3,(A4)+OLNEXT	; trou juste aprs ?	JUMP',NE 30$		; non => 30$				; oui =>	LOAD.W	D3,(A3)+OLLG	ADD.W	(A4)+OLLG,D3	LOAD.L	A2,(A3)+OLNEXT	LOAD.L	(A4)+OLNEXT,A2	LOAD.L	(A2)+OLPREV,A4	INC.W	D7		; D7 <-- deux trous appondus; Si l'objet devenu trou est prcd d'un autre trou, fusionne les deux; trous en un seul.30$:	LOAD.L	A3,(A4)+OLPREV	ADD.W	A3,(A3)+OLLG	COMP.L	A3,A4		; trou juste avant ?	JUMP',NE 40$		; non => 40$				; oui =>	LOAD.L	A3,(A4)+OLPREV	LOAD.W	D3,(A4)+OLLG	ADD.W	(A3)+OLLG,D3	LOAD.L	A2,(A4)+OLNEXT	LOAD.L	(A3)+OLNEXT,A2	LOAD.L	(A2)+OLPREV,A3	LOAD.L	A4,A3	INC.W	D7		; D7 <-- deux trous appondus	JUMP'	90$40$:	LOAD.L	A3,(A4)+OLNEXT	ADD.W	A3,(A3)+OLLG	COMP.L	A3,A4		; trou juste avant ?	JUMP',NE 90$		; non => 90$				; oui =>	LOAD.L	A3,(A4)+OLNEXT	LOAD.W	D3,(A4)+OLLG	ADD.W	(A3)+OLLG,D3	LOAD.L	A2,(A4)+OLPREV	LOAD.L	(A3)+OLPREV,A2	LOAD.L	(A2)+OLNEXT,A3	LOAD.L	A4,A3	INC.W	D7		; D7 <-- deux trous appondus90$:	POPM.L	D3,A2,A3	TEST.W	D7		; retour EQ/NE	RET;------\\; FIRST >;======/; Met un objet au dbut de la liste, c'est--dire tout derrire.; in	A4.L	^objet; out	D7.W	erreur; mod	D7.WFIRST:	PUSH.L	A3	CALL	SUBLIST		; supprime de la liste	LOAD.L	A3,#(A6)+OUSE	; A3 <-- ajoute  la fin de la liste	LOAD.L	A3,(A3)+OLNEXT	CALL	ADDLIST		; remet au dbut de la liste	POP.L	A3	CLR.W	D7		; D7 <-- ok	RET;-----\\; LAST >;=====/; Met un objet  la fin de la liste, c'est--dire tout devant.; in	A4.L	^objet; out	D7.W	erreur; mod	D7.WLAST:	PUSH.L	A3	CALL	SUBLIST		; supprime de la liste	LOAD.L	A3,#(A6)+OUSE	; A3 <-- ajoute  la fin de la liste	CALL	ADDLIST		; remet  la fin de la liste	POP.L	A3	CLR.W	D7		; D7 <-- ok	RET;--------\\; ADDLIST >;--------/; Ajoute un lment dans une liste ( la fin).; in	A3.L	^lment de base (ou n'importe lequel);	A4.L	^lment  ajouter; out	-; mod	-ADDLIST:	PUSH.L	A2	LOAD.L	A2,(A3)+OLPREV	LOAD.L	(A3)+OLPREV,A4	LOAD.L	(A2)+OLNEXT,A4	LOAD.L	(A4)+OLPREV,A2	LOAD.L	(A4)+OLNEXT,A3	POP.L	A2	RET;--------\\; SUBLIST >;--------/; Supprime un lment dans une liste.; in	A4.L	^lment  supprimer; out	-; mod	-SUBLIST:	PUSHM.L	A2,A3	LOAD.L	A2,(A4)+OLNEXT	; A2 <-- ^objet suivant	LOAD.L	A3,(A4)+OLPREV	; A3 <-- ^objet prcdent	LOAD.L	(A2)+OLPREV,A3	LOAD.L	(A3)+OLNEXT,A2	POPM.L	A2,A3	RET;-----\\; INIT >;=====/; Initialise les listes.; in	A4.L	^zone mmoire;	D4.W	lg mmoire; out	-; mod	D7.WINIT:	PUSHM.L	A3	LOAD.L	A3,#(A6)+OFREE	LOAD.L	(A3)+OLNEXT,A4	LOAD.L	(A3)+OLPREV,A4	LOAD.L	(A4)+OLNEXT,A3	LOAD.L	(A4)+OLPREV,A3	LOAD.W	(A4)+OLLG,D4	LOAD.L	A3,#(A6)+OUSE	LOAD.L	(A3)+OLNEXT,A3	LOAD.L	(A3)+OLPREV,A3	POPM.L	A3	RET	.END