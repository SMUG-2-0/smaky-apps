	.SBTTL	OPTEXTEDIT.ASITXPREL:				; base pour ^relatifs;----------\\; EDITMMENU >;==========/; Agit dans le texte selon le mmenu traditionnel (ddd).; in	A1.L	^objet texte; out	D7.W	erreur; mod	D7.WEDITMMENU:	PUSHM.L	D1..D5,A2..A4	LOAD.L	D4,(A5)+OTXZO1	LOAD.L	D5,(A5)+OTXZO2	COMP.L	D4,D5	JUMP',NE SELOK$	CALL	ESELMOT		; D4/D5 <-- dbut/fin d'un mot	CALL	EDINVZONE	; inverse la nouvelle partie de la zone	LOAD.L	(A5)+OTXZO1,D4	LOAD.L	(A5)+OTXZO2,D5SELOK$:	LOAD.L	A3,#R16"ITABLE$ILOOP$:	LOAD.W	D3,(A3+)	; D3 <-- code de l'icne interne	JUMP',EQ IEND$	CALL	XopGETICONE	; A4 <-- ^matrice	LOAD.W	D3,(A3+)	; D3 <-- code de l'icne PAGE	LOAD.W	D7,#DR_PUTICO	PAGE_	DRAW		; IPP21 <-- matrice de l'icne	JUMP	ILOOP$IEND$:	LOAD.L	D4,#2000	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire pour construire mmenu	JUMP,NE CLEAR$	LOAD.L	D5,A4	LOAD.L	A3,D5		; A3 <-- ^buffer pour construire m-menu	LOAD.L	A2,D5	LOAD.L	A4,#R16"MMENU$	CALL	MENUBUF		; buffer <-- menu principal	CALL	MENUAJUST	; buffer <-- tous les sous-(sous-)menus	LOAD.L	A3,D5		; A3 <-- ^buffer avec m-menu	LOAD.L	A4,#(A5)+OMPATX	; A4 <-- ^paramtres	CLR.L	(A4)+(LMM*0)+OMMINA	LOAD.L	(A4)+(LMM*1)+OMMINA,(A5)+OMCHG	CLR.L	(A4)+(LMM*2)+OMMINA	CLR.L	(A4)+(LMM*3)+OMMINA	CLR.L	(A4)+(LMM*4)+OMMINA	CLR.L	(A4)+(LMM*5)+OMMINA	CLR.L	(A4)+(LMM*6)+OMMINA	TSET.B	(A4)+(LMM*0)+OMMINA+3:#2 ; grise la case "dplace"	TSET.B	(A4)+(LMM*0)+OMMINA+3:#3 ; grise la case "duplique"	TSET.B	(A4)+(LMM*0)+OMMINA+3:#5 ; grise la case "soulign"	LOAD.W	D7,#IO_DICOSTATUS	PAGE_	IO		; D4 <-- zro si dico pas charg	JUMP',EQ DICO5$	TSET.B	(A4)+(LMM*0)+OMMINA+2:#8-8 ; grise la case "dictionnaire"DICO5$:	LOAD.W	D7,#MI_MMENUS	PAGE_	MISC		; attend choix selon mmenus ...	PUSHM.L	D7,A4	LOAD.L	A4,D5	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre mmoire pour construire mmenu	POPM.L	D7,A4	TEST.W	D7	JUMP,NE CLEAR$	LOAD.W	D2,(A4)+(LMM*0)+OMMSEL	COMP.W	D2,#1	JUMP',EQ OPER$	COMP.W	D2,#2	JUMP',EQ OPER$	COMP.W	D2,#3	JUMP',EQ OPER$	LOAD.W	D3,(A4)+(LMM*1)+OMMSEL	COMP.W	D2,#4	JUMP',EQ OPER$	LOAD.W	D3,(A4)+(LMM*2)+OMMSEL	COMP.W	D2,#5	JUMP',EQ OPER$	LOAD.W	D3,(A4)+(LMM*3)+OMMSEL	COMP.W	D2,#6	JUMP',EQ OPER$	LOAD.W	D3,(A4)+(LMM*4)+OMMSEL	COMP.W	D2,#7	JUMP',EQ OPER$	LOAD.W	D3,(A4)+(LMM*5)+OMMSEL	COMP.W	D2,#8	JUMP',EQ OPER$	LOAD.W	D3,(A4)+(LMM*6)+OMMSEL	COMP.W	D2,#9	JUMP',EQ OPER$	JUMP'	CLEAR$OPER$:	LOAD.L	D4,(A5)+OTXZO1	LOAD.L	D5,(A5)+OTXZO2	CALL	EDINVZONE	; efface toute la zone	CALL	EDITOPMOUSE	; effectue une action dans le texte	JUMP'	EXIT$CLEAR$:	PUSH.W	D7	LOAD.L	D4,(A5)+OTXZO1	LOAD.L	D5,(A5)+OTXZO2	CALL	EDINVZONE	; efface toute la zone	POP.W	D7EXIT$:	POPM.L	D1..D5,A2..A4	TEST.W	D7		; retour EQ/NE	RETITABLE$:	.W	ICOGENCAR,ICOUSER+0	.W	ICOSOUL,ICOUSER+1	.W	ICOUPDOWN,ICOUSER+2	.W	ICOMINMAJ,ICOUSER+3	.W	ICOSNORM,ICOUSER+4	.W	ICOSDOWN,ICOUSER+5	.W	ICOSMID,ICOUSER+6	.W	ICOSUP,ICOUSER+7	.W	ICOUDNORM,ICOUSER+8	.W	ICOUDUP,ICOUSER+9	.W	ICOUDDOWN,ICOUSER+10	.W	ICOMMMIN,ICOUSER+11	.W	ICOMMMAJ,ICOUSER+12	.W	ICOMINMAJACC,ICOUSER+13	.W	ICONBFIX,ICOUSER+14	.W	ICONBPROP,ICOUSER+15	.W	ICOCHERCHE,ICOUSER+16	.W	ICOCHERCHEAR,ICOUSER+17	.W	ICOCHERCHEAV,ICOUSER+18	.W	ICOCHANGE,ICOUSER+19	.W	ICOZDETRUIT,ICOUSER+20	.W	ICOZDEPLACE,ICOUSER+21	.W	ICOZDUPLIQUE,ICOUSER+22	.W	0MMENU$:	.ASCIZ	" "	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+20	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  dtruit"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+21	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  dplace"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+22	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  duplique"	.B	-1	.BW	-2,-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+0	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  caractre"	.BW	-2,SOUL$-MMENU$	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+1	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  soulign"	.BW	-2,EXP$-MMENU$	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+2	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  exposant"	.B	-1	.BW	-2,MINMAJ$-MMENU$	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+3	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  transforme"	.BW	-2,DICO$-MMENU$	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODICO	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  dictionnaire"	.BW	-2,SEARCH$-MMENU$	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+16	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  cherche"	.B	0SOUL$:	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+4	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  normal "	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+5	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  soulign "	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+6	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  biff "	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+7	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  surlign "	.B	0EXP$:	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+8	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  normal "	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+9	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  exposant "	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+10	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  indice "	.B	0MINMAJ$:	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+11	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  minuscules "	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+12	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  majuscules "	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+13	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  idem + accents "	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+14	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  fixes "	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+15	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  proportionnels "	.B	0DICO$:	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODICOVE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  vrifie.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODICOMA	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  marque"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODICOAD	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  conserve.."	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODICOAC	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  accorde.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODICOCO	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  conjugue.."	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODICOSY	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  synonymes.."	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODICOFA	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  famille.."	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICODICONB	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  nombre.."	.B	0SEARCH$:	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+17	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  cherche"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+18	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  cherche"	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICT	.B	ICOUSER+19	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  change.."	.B	0	.EVEN;----------\\; MENUAJUST >;----------/; Ajuste les pointeurs relatifs du menu pre qui vient d'tre; mis dans le buffer.; in	A2.L	^dbut du menu pre;	A3.L	^buffer;	A4.L	^mmenu; out	A3.L	^plus loin;	A4.L	^plus loin; mod	D7.W, A3.L, A4.LMENUAJUST:	PUSHM.L	D3,D4,A1,A2	LOAD.L	A1,A220$:	TEST.B	(A2)		; fin du mmenu ?	JUMP,EQ EXIT$		; oui => EXIT$30$:	LOAD.B	D3,(A2+)	JUMP,EQ 20$	COMP.B	D3,#-2	JUMP,NE 30$				; ^sous-menu =>	LOAD.B	D3,(A2+)	SL.W	D3,#8	LOAD.B	D3,(A2+)	; D3 <-- ^relatif	LOAD.L	D4,A3	SUB.L	D4,A1	LOAD.B	(A2)-1,D4	RR.W	D4,#8	LOAD.B	(A2)-2,D4	; buffer <-- ^relatif au sous-menu	RR.W	D4,#8	PUSH.L	A2	PUSH.L	A3	TEST.W	D3		; .BW -2,-n  ?	JUMP',NS 50$		; oui => 50$				; non =>	CALL	MENUBUF		; buffer <-- sous-menu	JUMP'	52$50$:	CALL	MENUSPEC	; buffer <-- sous-menu52$:	POP.L	A2	CALL	MENUAJUST	; paf, rcursif !!!	POP.L	A2	JUMP	30$EXIT$:	POPM.L	D3,D4,A1,A2	RET;--------\\; MENUBUF >;--------/; Met un mmenu dans un buffer.; in	A3.L	^buffer;	A4.L	^mmenu; out	A3.L	^plus loin;	A4.L	^plus loin; mod	D7.W, A3.L, A4.LMENUBUF:	PUSH.W	D310$:	TEST.B	(A4)		; fin du mmenu ?	JUMP',EQ 80$20$:	LOAD.B	D3,(A4+)	LOAD.B	(A3+),D3	; buffer <-- .ASCIZ	JUMP,EQ 10$	COMP.B	D3,#-2	JUMP,NE	20$	LOAD.B	(A3+),(A4+)	; buffer <-- <^rel-high>	LOAD.B	(A3+),(A4+)	; buffer <-- <^rel-low>	JUMP	20$80$:	INC.L	A4	CLR.B	(A3+)		; buffer <-- terminateur	POP.W	D3	RET;---------\\; MENUSPEC >;---------/; Met un mmenu spcial dans un buffer.; in	D3.W	type du menu spcial (-);	D4.W	^relatif;	A2.L	^pour mj. ^relatif;	A3.L	^buffer; out	A3.L	^plus loin; mod	D7.W, A3.LMENUSPEC:	PUSHM.L	D0,D1,D3,A4	COMP.W	D3,#-1	JUMP',EQ CHAR$	JUMP'	EXIT$; Construit le sous-menu des caractres.CHAR$:	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D0,#IDENTCHAR	LOAD.W	D1,#opDGETMENU	PAGE_	OBJCALL		; construit le mmenu	LOAD.L	(A5)+OMCHG,D3	; OMCHG <-- cases grises;	JUMP	EXIT$EXIT$:	POPM.L	D0,D1,D3,A4	RET;------------\\; EDITOPMOUSE >;============/; Effectue une opration selon le mmenu texte.; in	A1.L	^objet texte;	D2.W	opration (dtruit, dplace, etc.);	D3.W	sous-opration (selon sous-menu);	D4.L	dbut zone;	D5.L	fin zone; out	D7.W	erreur; mod	D7.WEDITOPMOUSE:	PUSHM.L	D0..D6,A3	COMP.L	D4,D5	JUMP,EQ OK$	JUMP',LO NOEX$	EX.L	D4,D5		; D4 toujours avant D5 !NOEX$:	AND.L	D3,#H'FFFF	COMP.W	D2,#1	JUMP,EQ DETR$	COMP.W	D2,#2	JUMP,EQ DEPL$	COMP.W	D2,#3	JUMP,EQ DUPL$	COMP.W	D2,#4	JUMP,EQ CAR$	COMP.W	D2,#5	JUMP,EQ SOUL$	COMP.W	D2,#6	JUMP,EQ EXP$	COMP.W	D2,#7	JUMP,EQ MIMA$	COMP.W	D2,#8	JUMP,EQ DICO$	COMP.W	D2,#9	JUMP,EQ SEARCH$	JUMP	EXIT$DETR$:	EX.L	D4,D5	CALL	TXPOSITIONNE	; va  la fin	SUB.L	D4,D5		; D4 <-- nombre de caractresDETR2$:	CALL	TXDETRUIT	; dtruit toute la zone	INC.L	(A1)+OOBNCK	; un caractre de plus dtruit en arrire	DEC.L	D4	JUMP,NE DETR2$	JUMP	OK$DEPL$:	LOAD.W	D7,#1	JUMP	EXIT$DUPL$:	LOAD.W	D7,#1	JUMP	EXIT$CAR$:	SL.L	D3,#CCGCSHI	; D3 <-- nouveau mode	LOAD.L	D2,#CCGCMSK	; D2 <-- masque	JUMP'	OPER$SOUL$:	SL.L	D3,#8	SL.L	D3,#CCSOSHI-8	; D3 <-- nouveau mode	LOAD.L	D2,#CCSOMSK	; D2 <-- masque	JUMP'	OPER$EXP$:	SL.L	D3,#8	SL.L	D3,#CCEXSHI-8	; D3 <-- nouveau mode	LOAD.L	D2,#CCEXMSK	; D2 <-- masque;	JUMP'	OPER$OPER$:	SUB.L	D5,D4		; D5 <-- nombre de caractres	CALL	TXMODE		; modifie le mode	CALL	EMODALL		; signal qu'il faudra tout redessiner	JUMP	EXIT$MIMA$:	SUB.L	D5,D4		; D5 <-- nombre de caractres	CALL	TXPOSITIONNE	; va au dbut de la zone	LOAD.B	D4,#'a	TEST.W	D3	JUMP',EQ MIMA2$	LOAD.B	D4,#'A	COMP.W	D3,#1	JUMP',EQ MIMA2$	LOAD.B	D4,#H'80	COMP.W	D3,#2	JUMP',EQ MIMA2$	LOAD.B	D4,#H'81	COMP.W	D3,#3	JUMP',EQ MIMA2$	LOAD.B	D4,#H'82MIMA2$:	LOAD.B	D3,D4	CALL	EMINMAJ	JUMP,NE EXIT$	CALL	TXAVANCE	JUMP',NE MIMA8$	DEC.L	D5	JUMP,NE MIMA2$MIMA8$:	CALL	EMODALL		; signal qu'il faudra tout redessiner	JUMP	OK$DICO$:	SUB.L	D5,D4		; D5 <-- nombre de caractres	COMP.W	D3,#0	JUMP',EQ DICOVE$	COMP.W	D3,#1	JUMP',EQ DICOMA$	COMP.W	D3,#2	JUMP',EQ DICOAD$	COMP.W	D3,#3	JUMP',EQ DICOAC$	COMP.W	D3,#4	JUMP',EQ DICOCO$	COMP.W	D3,#5	JUMP',EQ DICOSY$	COMP.W	D3,#6	JUMP',EQ DICOFA$	COMP.W	D3,#7	JUMP',EQ DICONB$	JUMP	EXIT$DICOVE$:	CALL	DICOVERIF	JUMP'	DICOEXIT$DICOMA$:	CALL	DICOMARK	JUMP'	DICOEXIT$DICOAD$:	CALL	DICOADD	JUMP'	DICOEXIT$DICOAC$:	CALL	DICOACCORD	JUMP'	DICOEXIT$DICOCO$:	CALL	DICOCONJ	JUMP'	DICOEXIT$DICOSY$:	CALL	DICOSYNO	JUMP'	DICOEXIT$DICOFA$:	CALL	DICOFAMILLE	JUMP'	DICOEXIT$DICONB$:	CALL	DICONOMB;	JUMP'	DICOEXIT$DICOEXIT$:	PUSH.W	D7	CALL	EMODALL		; signal qu'il faudra tout redessiner	POP.W	D7	JUMP	EXIT$SEARCH$:	LOAD.W	D2,D3		; D2 <-- sous-opration	SUB.L	D5,D4		; D5 <-- nombre de caractres	CALL	TXPOSITIONNE	JUMP,NE EXIT$	LOAD.L	A3,#(A5)+OCH1	; A3 <-- ^chane de recherche	LOAD.W	D4,#MAXCH-2	LOAD.L	D6,D5SEARCH2$:	DEC.W	D4	JUMP',EQ SEARCH3$	CALL	TXAVANCE	JUMP',NE SEARCH3$	CALL	NOSUPPL		; D3 <-- caractre < 128	LOAD.B	(A3+),D3	; chane de recherche <-- caractres	DEC.L	D5	JUMP,NE SEARCH2$SEARCH3$:	CLR.B	(A3)	CLR.B	(A5)+OCH2	; chane de substitution <-- vide	COMP.W	D2,#0	JUMP',EQ SEARCHAR$	COMP.W	D2,#1	JUMP',EQ SEARCHAV$	COMP.W	D2,#2	JUMP',EQ CHANGE$	JUMP	EXIT$SEARCHAR$:	CALL	TXRECULE	; revient au dbut de la chane	DEC.L	D6	JUMP,NE SEARCHAR$	LOAD.L	D3,#H'100*(2^BSEARCH)+'D	CALL	EDITEVENT	; cherche en arrire	JUMP'	EXIT$SEARCHAV$:	LOAD.L	D3,#H'100*(2^BSEARCH)+'F	CALL	EDITEVENT	; cherche en avant	JUMP'	EXIT$CHANGE$:	CALL	TXRECULE	; revient au dbut de la chane	DEC.L	D6	JUMP,NE CHANGE$	CALL	TXRECULE	LOAD.L	D3,#H'100*(2^BCHANGE)+DEFINE+SHIFT	CALL	EDITEVENT	JUMP'	EXIT$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D6,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; EDITEVENT >;==========/; Edite un pav de texte selon une touche presse.; in	A1.L	^objet texte;	D3.L	touche presse;	D4.L	position de la souris (si D3=KEYM?P); out	D7.W	erreur; mod	D7.WEDITEVENT:	PUSHM.L	D2..D4; Dbranchements principaux selon les touches super-shift.	COMP.W	D3,#H'80	JUMP',HS NOACCENT$	COMP.B	D3,#DEL	JUMP',EQ NOACCENT$	COMP.B	D3,#BS	JUMP',NE ACCENT$NOACCENT$:	CALL	NOACCENT	; plus de frappe d'accent flottantACCENT$:	CALL	EXFONC	.WW	CURSOR,KCURS$-TXPREL	.WW	CURSOR!KILL,KCUKI$-TXPREL	.WW	PROGRA!CHANGE,KPRCH$-TXPREL	.WW	SEARCH,KSEAR$-TXPREL	.WW	CHANGE,KCHAN$-TXPREL	.WW	SEARCH!CHANGE,KSECH$-TXPREL	.WW	0,KEY$-TXPRELKEY$:	CALL	EXKEY	.WW	KEYMGP,CLIC$-TXPREL	.WW	KEYMMP,CLIC$-TXPREL	.WW	KEYMDP,CLIC$-TXPREL	.WW	DELETE,KDEL$-TXPREL	.WW	DEL,KDEL$-TXPREL	.WW	BS,KBS$-TXPREL	.WW	CCIRCON,KCIRCON$-TXPREL	.WW	CTREMA,KTREMA$-TXPREL	.WW	TRIZERO,KTRIZERO$-TXPREL	.WW	POINT,KPOINT$-TXPREL	.WW	FNCT,KFLIP$-TXPREL	.WW	F1,KPREND$-TXPREL	.WW	F2,KAJOUTE$-TXPREL	.WW	F3,KSAUVE$-TXPREL	.WW	DEFINE,KCHANGE$-TXPREL	.WW	0,INSERT$-TXPREL; Actions spciales, sans touches super-shift.CLIC$:	CALL	EDGETPOS	; D4 <-- position	JUMP,NE EXIT$	CALL	TXPOSITIONNE	; positionne le curseur	JUMP,NE EXIT$	JUMP	OK$KPREND$:	CALL	IORALL		; lit un texte	JUMP	OK$KAJOUTE$:	CALL	IORADD		; ajoute un texte	JUMP	OK$KSAUVE$:	CALL	IOWALL		; crit un texte	JUMP	OK$KCHANGE$:	CALL	DBOXCHANGE	; demande recherche/substitution ...	COMP.W	D3,#F1	JUMP,EQ ISEAR$	COMP.W	D3,#F4	JUMP,EQ ICNT$	COMP.W	D3,#F7	JUMP,EQ ICHAN$	JUMP	OK$; Insertion des caractres, avec gestion du pav numrique.INSERT$:	COMP.W	D3,#H'80	JUMP,HS BIP$	CALL	ACCENT		; va sous un accent flottant ?	JUMP,EQ OK$		; oui => OK$	CALL	EINSERE	JUMP,NE EXIT$	JUMP	OK$KTRIZERO$:			; insre 3x zro =>	LOAD.B	D3,#'0	CALL	EINSERE	JUMP,NE EXIT$	CALL	EINSERE	JUMP,NE EXIT$	CALL	EINSERE	JUMP,NE EXIT$	JUMP	OK$KPOINT$:			; insre un "." =>	LOAD.B	D3,#'.	CALL	EINSERE	JUMP,NE EXIT$	JUMP	OK$KCIRCON$:	LOAD.W	D4,#CIRCON	; met un circonflxe	JUMP'	KACCENT$KTREMA$:	LOAD.W	D4,#TREMA	; met qq chose comme un trma;	JUMP'	KACCENT$KACCENT$:	TEST.B	(A1)+OOBACC	JUMP',T KACCENT6$	CALL	TXDONNE		; D3 <-- car "sous" le curseur	JUMP',NE KACCENT5$	; rien => KACCENT5$	CALL	GETACCENT	; calcul lettre accentue	JUMP',NE KACCENT5$	; n'existe pas => KACCENT5$				; existe =>	TEST.B	D3	JUMP',EQ KACCENT5$	PUSH.L	D3	CALL	TXAVANCE	CALL	TXDETRUIT	; dtruit lettre non accentue	POP.L	D3	CALL	TXINSERE	; remplace par lettre accentue	INC.L	(A1)+OOBNCI	; un caractre de plus insr	INC.L	(A1)+OOBNCM	; un caractre de plus avanc/recul	JUMP	OK$KACCENT5$:	LOAD.B	D3,D4		; D3 <-- accent	CALL	EINSERE		; insert un accent tout seul	CALL	TXRECULE	; puis recule "dessus"	SET.B	(A1)+OOBACC	JUMP	OK$KACCENT6$:	CALL	NOACCENT	; plus de frappe d'accent flottant	JUMP	OK$KFLIP$:				; permute deux caractres =>	CALL	TXDETRUIT	JUMP,NE BIP$	LOAD.L	D4,D3	CALL	TXAVANCE	LOAD.L	D3,D4	CALL	TXINSERE	CALL	TXRECULE	INC.L	(A1)+OOBNCI	; un caractre de plus insr	INC.L	(A1)+OOBNCM	; un caractre de plus avanc/recul	JUMP	OK$KDEL$:	LOAD.B	D3,#'D	JUMP	ECUKI$KBS$:	LOAD.B	D3,#'F	JUMP	ECUKI$; Table pour les diffrentes combinaisons de touches super-shift.KCURS$:	CALL	EXKEY	.WW	'E,ECURS$-TXPREL	.WW	'R,ECURS$-TXPREL	.WW	'T,ECURS$-TXPREL	.WW	'S,ECURS$-TXPREL	.WW	'D,ECURS$-TXPREL	.WW	'F,ECURS$-TXPREL	.WW	'G,ECURS$-TXPREL	.WW	'X,ECURS$-TXPREL	.WW	'C,ECURS$-TXPREL	.WW	'V,ECURS$-TXPREL	.WW	0,BIP$-TXPRELKCUKI$:	CALL	EXKEY	.WW	'E,ECUKI$-TXPREL	.WW	'R,ECUKI$-TXPREL	.WW	'T,ECUKIQ$-TXPREL	.WW	'S,ECUKI$-TXPREL	.WW	'D,ECUKI$-TXPREL	.WW	'F,ECUKI$-TXPREL	.WW	'G,ECUKI$-TXPREL	.WW	'X,ECUKI$-TXPREL	.WW	'C,ECUKI$-TXPREL	.WW	'V,ECUKIQ$-TXPREL	.WW	0,BIP$-TXPRELKPRCH$:	CALL	EXKEY	.WW	'E,EPRCH$-TXPREL	.WW	'R,EPRCH$-TXPREL	.WW	'T,EPRCHQ$-TXPREL	.WW	'S,EPRCH$-TXPREL	.WW	'D,EPRCH$-TXPREL	.WW	'F,EPRCH$-TXPREL	.WW	'G,EPRCH$-TXPREL	.WW	'X,EPRCH$-TXPREL	.WW	'C,EPRCH$-TXPREL	.WW	'V,EPRCHQ$-TXPREL	.WW	0,BIP$-TXPRELKSEAR$:	CALL	EXKEY	.WW	'R,ECNTAR$-TXPREL	.WW	'D,ESEARAR$-TXPREL	.WW	'F,ESEARAV$-TXPREL	.WW	'C,ECNTAV$-TXPREL	.WW	',,EDICOAR$-TXPREL	.WW	'.,EDICOAV$-TXPREL	.WW	0,BIP$-TXPRELKCHAN$:	CALL	EXKEY	.WW	'D,ECHANGAR$-TXPREL	.WW	'F,ECHANGAV$-TXPREL	.WW	'R,ECHANGTR$-TXPREL	.WW	'C,ECHANGTV$-TXPREL	.WW	',,EDICOAR$-TXPREL	.WW	'.,EDICOAV$-TXPREL	.WW	DEFINE,KCHANGE$-TXPREL	.WW	DEFINE+SHIFT,KCHANGE$-TXPREL	.WW	0,BIP$-TXPRELKSECH$:	CALL	EXKEY	.WW	',,EDICOAR$-TXPREL	.WW	'.,EDICOAV$-TXPREL	.WW	0,BIP$-TXPREL; (CURSOR) = Dplacement du curseur.ECURS$:	CALL	EFLECHE		; D2 <-- +/- dplacement	TEST.L	D2	JUMP,EQ BIP$	JUMP',NS ECURS4$	ADD.L	(A1)+OOBNCM,D2	; qq caractres de plus avancs/reculsECURS2$:	CALL	TXAVANCE	DEC.L	D2	JUMP,NE ECURS2$	JUMP	OK$ECURS4$:	SUB.L	(A1)+OOBNCM,D2	; qq caractres de plus avancs/reculsECURS5$:	CALL	TXRECULE	INC.L	D2	JUMP,NE ECURS5$	JUMP	OK$; (CURSOR-KILL) = destructions autour du curseur.ECUKIQ$:	CALL	EFLECHE		; D2 <-- +/- dplacement	TEST.L	D2	JUMP,EQ BIP$	CALL	DBOXSURE	; demande ...	JUMP,NE BIP$	JUMP'	ECUKI1$ECUKI$:	CALL	EFLECHE		; D2 <-- +/- dplacementECUKI1$:	TEST.L	D2	JUMP,EQ BIP$	JUMP',NS ECUKI4$	ADD.L	(A1)+OOBNCL,D2	; qq caractres de plus dtruit en avantECUKI2$:	CALL	TXAVANCE	JUMP,NE EXIT$	CALL	TXDETRUIT	JUMP,NE EXIT$	DEC.L	D2	JUMP,NE ECUKI2$	JUMP	OK$ECUKI4$:	SUB.L	(A1)+OOBNCK,D2	; qq caractres de plus dtruit en arrireECUKI5$:	CALL	TXDETRUIT	JUMP,NE EXIT$	INC.L	D2	JUMP,NE ECUKI5$	JUMP	OK$; (PROGRA-CHANGE) = transformations minuscules <--> majuscules.EPRCHQ$:	LOAD.B	D4,D3	CALL	EFLECHE		; D2 <-- +/- dplacement	TEST.L	D2	JUMP,EQ BIP$	CALL	DBOXSURE	; demande ...	JUMP,NE BIP$	JUMP'	EPRCH1$EPRCH$:	LOAD.B	D4,D3	CALL	EFLECHE		; D2 <-- +/- dplacementEPRCH1$:	TEST.L	D2	JUMP,EQ BIP$	JUMP',NS EPRCH4$	ADD.L	(A1)+OOBNCM,D2	; qq caractres de plus avancs/reculsEPRCH2$:	LOAD.B	D3,D4	CALL	EMINMAJ	JUMP,NE BIP$	CALL	TXAVANCE	JUMP,NE EXIT$	DEC.L	D2	JUMP,NE EPRCH2$	JUMP	OK$EPRCH4$:	SUB.L	(A1)+OOBNCM,D2	; qq caractres de plus avancs/reculsEPRCH5$:	CALL	TXRECULE	JUMP,NE EXIT$	LOAD.B	D3,D4	CALL	EMINMAJ	JUMP,NE BIP$	INC.L	D2	JUMP,NE EPRCH5$	JUMP	OK$; (SEARCH) = recherche et comptages.ESEARAR$:	CALL	ECHERCHEAR	; cherche en arrire	JUMP,NE EXIT$	JUMP	OK$ESEARAV$:	CALL	ECHERCHEAV	; cherche en avant	JUMP,NE EXIT$	JUMP	OK$ECNTAV$:	CALL	TXPSAUVE	PUSH.W	D4	CLR.L	D2		; D2 <-- nombre d'occurencesECNTAV2$:	CALL	ECHERCHEAV	; cherche en avant	JUMP',NE ECNTAV3$	INC.L	D2		; D2 <-- une occurence de plus	JUMP	ECNTAV2$ECNTAV3$:	POP.W	D4	CALL	TXPPREND	; remet le curseur o il tait	LOAD.L	D4,D2		; D4 <-- nombre d'occurences	CALL	DBOXOCCURENCE	; affiche le nombre d'occurences ...	JUMP,NE EXIT$	JUMP	OK$ECNTAR$:	CALL	TXPSAUVE	PUSH.W	D4	CLR.L	D2		; D2 <-- nombre d'occurencesECNTAR2$:	CALL	ECHERCHEAR	; cherche en arrire	JUMP',NE ECNTAR3$	INC.L	D2		; D2 <-- une occurence de plus	JUMP	ECNTAR2$ECNTAR3$:	POP.W	D4	CALL	TXPPREND	; remet le curseur o il tait	LOAD.L	D4,D2		; D4 <-- nombre d'occurences	CALL	DBOXOCCURENCE	; affiche le nombre d'occurences ...	JUMP,NE EXIT$	JUMP	OK$; (CHANGE) = recherches puis substitutions.ECHANGAR$:	CALL	ECHERCHEAR	; cherche en arrire	JUMP,NE EXIT$	CALL	ESUBSTITUEAR	; effectue la substitution	JUMP,NE EXIT$	JUMP	OK$ECHANGAV$:	CALL	TXRECULE	CALL	ECHERCHEAV	; cherche en avant	JUMP,NE EXIT$	CALL	ESUBSTITUEAV	; effectue la substitution	JUMP,NE EXIT$	JUMP	OK$ECHANGTR$:	CALL	ECHERCHEAR	; cherche en arrire	JUMP,NE OK$	CALL	ESUBSTITUEAR	; effectue la substitution	JUMP,NE EXIT$	JUMP	ECHANGTR$ECHANGTV$:	CALL	TXRECULE	CALL	ECHERCHEAV	; cherche en avant	JUMP,NE OK$	CALL	ESUBSTITUEAV	; effectue la substitution	JUMP,NE EXIT$	JUMP	ECHANGTV$; Diverses recherches pour les marques du dictionnaire.EDICOAV$:	PUSH.L	(A5)+OCH1	PUSH.L	(A5)+OCHM1	PUSH.L	(A5)+OCHC1	LOAD.L	(A5)+OCH1,#H'1000000*MARKFM	CLR.L	(A5)+OCHM1	CLR.L	(A5)+OCHC1	CALL	ECHERCHEAV	; cherche fin faute en avant	POP.L	(A5)+OCHC1	POP.L	(A5)+OCHM1	POP.L	(A5)+OCH1	TEST.W	D7	JUMP,NE EXIT$	JUMP'	EDICOVR$EDICOAR$:	PUSH.L	(A5)+OCH1	PUSH.L	(A5)+OCHM1	PUSH.L	(A5)+OCHC1	LOAD.L	(A5)+OCH1,#H'1000000*MARKFM	CLR.L	(A5)+OCHM1	CLR.L	(A5)+OCHC1	CALL	ECHERCHEAR	; cherche fin faute en arrire	POP.L	(A5)+OCHC1	POP.L	(A5)+OCHM1	POP.L	(A5)+OCH1	TEST.W	D7	JUMP,NE EXIT$;	JUMP'	EDICOVR$EDICOVR$:	LOAD.W	D2,D3	SR.W	D2,#8		; D2 <-- touches super-shift	COMP.B	D2,#SEARCH	JUMP,EQ OK$	LOAD.L	D4,(A1)+OOBPOCEDICOVR2$:	CALL	TXRECULE	JUMP',NE EDICOVR8$	COMP.B	D3,#MARKDM	JUMP,NE EDICOVR2$	CALL	TXAVANCE	CALL	TXDETRUIT	; dtruit le MARKDM	INC.L	(A1)+OOBNCL	; un caractre de plus dtruit en avant	LOAD.L	D0,(A1)+OOBPOC	LOAD.L	D1,#-1EDICOVR4$:	INC.L	D1	CALL	TXAVANCE	JUMP',NE EDICOVR8$	COMP.B	D3,#MARKFM	JUMP,NE EDICOVR4$	CALL	TXDETRUIT	; dtruit le MARKFM	INC.L	(A1)+OOBNCK	; un caractre de plus dtruit en arrire	JUMP'	EDICODB$EDICOVR8$:	CALL	TXPOSITIONNE	JUMP	BIP$EDICODB$:	COMP.B	D2,#SEARCH!CHANGE	JUMP,NE OK$	LOAD.L	D4,D0		; D4 <-- position	LOAD.L	D5,D1		; D5 <-- nb de caractres	CALL	DICOVERIF	; vrifie juste le mot	JUMP,NE EXIT$	JUMP	OK$; Recherches interractives avec dbox.ISEAR$:	TEST.B	(A5)+OCHFAN+2:#BCHAR-8	JUMP,BS ISEARAR$ISEARAV$:	CALL	ECHERCHEAV	; cherche en avant	JUMP,NE BIP$	CALL	EDISPLAY	; affiche le pav de texte	CALL	ESETZONE	; met en vidence les caractres trouvs	CALL	DBOXCHERCHE	; SUIVANT/STOP ...	PUSH.W	D7	CALL	ECLRZONE	; enlve la mise en vidence	POP.W	D7	JUMP,NE BIP$	COMP.W	D3,#F1		; suivant ?	JUMP,EQ ISEARAV$	; oui => ISEARAV$	JUMP	OK$ISEARAR$:	CALL	ECHERCHEAR	; cherche en arrire	JUMP,NE BIP$	CALL	EDISPLAY	; affiche le pav de texte	CALL	ESETZONE	; met en vidence les caractres trouvs	CALL	DBOXCHERCHE	; SUIVANT/STOP ...	PUSH.W	D7	CALL	ECLRZONE	; enlve la mise en vidence	POP.W	D7	JUMP,NE BIP$	COMP.W	D3,#F1		; suivant ?	JUMP,EQ ISEARAR$	; oui => ISEARAR$	JUMP	OK$; Comptages interractifs avec dbox.ICNT$:	TEST.B	(A5)+OCHFAN+2:#BCHAR-8	JUMP,BS ECNTAR$	JUMP	ECNTAV$; Substitutions interractives avec dbox.ICHAN$:	TEST.B	(A5)+OCHFAN+2:#BCHAR-8	JUMP,BS ICHANAR$ICHANAV$:	CALL	ECHERCHEAV	; cherche en avant	JUMP,NE BIP$	CALL	EDISPLAY	; affiche le pav de texte	CALL	ESETZONE	; met en vidence les caractres trouvs	CALL	DBOXSUBSTITUE	; CHANGE/SUIVANT/PARTOUT/UN/STOP ...	PUSH.W	D7	CALL	ECLRZONE	; enlve la mise en vidence	POP.W	D7	JUMP,NE BIP$	COMP.W	D3,#F1		; CHANGE ?	JUMP',EQ ICHANSAV$	; oui => ICHANSAV$	COMP.W	D3,#F4		; SUIVANT ?	JUMP,EQ ICHANAV$	; oui => ICHANAV$	COMP.W	D3,#F7		; PARTOUT ?	JUMP',EQ ICHANAAV$	; oui => ICHANAAV$	COMP.W	D3,#F10		; UN ?	JUMP',EQ ICHANSAV$	; oui => ICHANSAV$	JUMP	OK$ICHANSAV$:	CALL	ESUBSTITUEAV	; effectue la substitution	JUMP,NE BIP$	CALL	EDISPLAY	; affiche le pav de texte	COMP.W	D3,#F1		; CHANGE ?	JUMP,EQ ICHANAV$	; oui => ICHANAV$	JUMP	OK$ICHANAAV$:	CALL	ESUBSTITUEAV	; effectue la substitution	JUMP,NE BIP$	CALL	ECHERCHEAV	; cherche en avant	JUMP,EQ ICHANAAV$	CALL	EDISPLAY	; affiche le pav de texte	JUMP	OK$ICHANAR$:	CALL	ECHERCHEAR	; cherche en arrire	JUMP,NE BIP$	CALL	EDISPLAY	; affiche le pav de texte	CALL	ESETZONE	; met en vidence les caractres trouvs	CALL	DBOXSUBSTITUE	; CHANGE/SUIVANT/PARTOUT/UN/STOP ...	PUSH.W	D7	CALL	ECLRZONE	; enlve la mise en vidence	POP.W	D7	JUMP,NE BIP$	COMP.W	D3,#F1		; CHANGE ?	JUMP',EQ ICHANSAR$	; oui => ICHANSAR$	COMP.W	D3,#F4		; SUIVANT ?	JUMP,EQ ICHANAR$	; oui => ICHANAR$	COMP.W	D3,#F7		; PARTOUT ?	JUMP',EQ ICHANAAR$	; oui => ICHANAAR$	COMP.W	D3,#F10		; UN ?	JUMP',EQ ICHANSAR$	; oui => ICHANSAR$	JUMP	OK$ICHANSAR$:	CALL	ESUBSTITUEAR	; effectue la substitution	JUMP,NE BIP$	CALL	EDISPLAY	; affiche le pav de texte	COMP.W	D3,#F1		; CHANGE ?	JUMP,EQ ICHANAR$	; oui => ICHANAR$	JUMP	OK$ICHANAAR$:	CALL	ESUBSTITUEAR	; effectue la substitution	JUMP,NE BIP$	CALL	ECHERCHEAR	; cherche en arrire	JUMP,EQ ICHANAAR$	CALL	EDISPLAY	; affiche le pav de texte	JUMP	OK$OK$:	CLR.W	D7		; D7 <-- action effectue correctement	JUMP'	EXIT$BIP$:	LOAD.W	D7,#ERPBIP	; D7 <-- rien  faire avec cette toucheEXIT$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; EDISPLAY >;---------/; Affiche le texte.; in	A1.L	^objet texte; out	-; mod	D7.WEDISPLAY:	PUSHM.L	D3,A0,A4	LOAD.L	A4,A1		; A4 <-- ^objet	LOAD.L	A0,A5		; A0 <-- ^variables globales	CLR.W	D3		; D3 <-- affichage minimal	CALL	XopEDITDRAW	; affiche le nouveau pav de texte	POPM.L	D3,A0,A4	RET;---------\\; ESETZONE >;---------/; Allume les caractres trouvs.; in	A1.L	^objet;	D4.L	nb de caractres; out	D4.L	premier caractre;	D5.L	dernier caractre; mod	D4.L, D5.L, D7.WESETZONE:	LOAD.W	D7,#DR_WDOOPEN	PAGE_	DRAW		; dessine dans la swdo	LOAD.L	D5,D4	LOAD.L	D4,(A1)+OOBPOC	ADD.L	D5,D4	CALL	EDINVZONE	; met en vidence les caractres trouvs	LOAD.W	D7,#DR_WDOCLOSE	PAGE_	DRAW		; fin du dessin dans la swdo	RET;---------\\; ECLRZONE >;---------/; Allume les caractres trouvs.; in	A1.L	^objet;	D4.L	premier caractre;	D5.L	dernier caractre; out	D4.L	nb de caractres; mod	D4.L, D7.WECLRZONE:	LOAD.W	D7,#DR_WDOOPEN	PAGE_	DRAW		; dessine dans la swdo	CALL	EDINVZONE	; efface la mise en vidence	SUB.L	D4,D5	NEG.L	D4	LOAD.W	D7,#DR_WDOCLOSE	PAGE_	DRAW		; fin du dessin dans la swdo	RET;--------\\; EMODALL >;========/; Signal qu'il faudra tout redessiner, en refaisant; la justification.; in	A1.L	^objet texte; out	-; mod	D7.WEMODALL:	PUSHM.L	D1,A4	TEST.L	(A1)+OOBPTL	JUMP',EQ EXIT$	LOAD.L	A4,(A1)+OOBPTL	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire OTLxxx	CLR.L	(A1)+OOBPTLEXIT$:	POPM.L	D1,A4	RET;--------\\; EINSERE >;========/; Insre un caractre en mode "environnant".; in	D3.B	caractre  insrer; out	D7.W	erreur; mod	D7.WEINSERE:	PUSHM.L	D1..D4	LOAD.B	D1,D3		; D1 <-- caractre; Si le buffer est vide, cherche le caractre choisi.	TEST.L	(A1)+OOBNBC	; y a-t-il des caractres ?	JUMP',NE 20$		; oui => 20$	LOAD.W	D3,(A1)+OOBCHAR	; D3 <-- caractre slectionn	SL.L	D3,#CCGCSHI	AND.L	D3,#CCGCMSK	; D3 <-- mode par dfaut	JUMP'	50$; Cherche le mode du caractre avant le curseur.20$:	CALL	TXPSAUVE	; D4 <-- position du curseur	CALL	TXRECULE	; D3 <-- mode du caractre prcdent	JUMP',EQ 30$	CLR.L	D3		; D3 <-- mode par dfaut30$:	CALL	TXPPREND	; remet le curseur o il tait	LOAD.L	D2,D3; Cherche le mode du caractre aprs le curseur.	CALL	TXPSAUVE	; D4 <-- position du curseur	CALL	TXAVANCE	; D3 <-- mode du caractre suivant	JUMP',EQ 40$	CLR.L	D3		; D3 <-- mode par dfaut40$:	CALL	TXPPREND	; remet le curseur o il tait; Insre le caractre avec le mode le plus grand.	COMP.L	D3,D2	JUMP',HS 50$	LOAD.L	D3,D250$:	LOAD.L	D2,(A5)+OFRMSK	NOT.L	D2	AND.L	D3,D2		; D3 <-- masque selon frappe	OR.L	D3,(A5)+OFRCAR	; D3 <-- mode selon frappe	LOAD.B	D3,D1		; D3 <-- mode et caractre	CALL	TXINSERE	; insre normalement	INC.L	(A1)+OOBNCI	; un caractre de plus insr	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ECHERCHEAV >;===========/; Cherche en avant selon le dialogue "change".; Si elle est trouve, le curseur est plac sur le premier caractre.; Si elle n'est pas trouve, le curseur reste immobile !; in	-; out	D4.L	longueur de la chane trouve;	D7.W	erreur; mod	D4.L, D7.WECHERCHEAV:	PUSHM.L	D0..D3,D5,A3	LOAD.L	A3,#(A5)+OCH1	; A3 <-- ^chane de recherche	LOAD.L	D2,(A5)+OCHM1	LOAD.B	D2,#H'FF	; D2 <-- masque de recherche	CALL	TXPSAUVE	PUSH.W	D4		; stack <-- position actuelle	LOAD.L	D0,(A1)+OOBPOC10$:	CALL	TXAVANCE	JUMP,NE 80$; Cherche rapidement le premier caractre de la chane.	LOAD.L	D3,(A5)+OCHC1	LOAD.B	D3,(A3)		; D3 <-- premier caractre	CLR.W	D5		; D5 <-- mode	TEST.B	(A5)+OCHFAN+3:#BCHMIMA-0	JUMP',BC 20$	TSET.L	D5:#020$:	CALL	TXACHERCHE	; cherche le premier caractre	JUMP',NE 80$; Cherche normalement si le reste de la chane correspond.	CALL	ECHERCHECP	; chane complte trouve ?	JUMP,NE 10$; Fin de la recherche. En cas d'erreur, remet le curseur o il tait.80$:	LOAD.W	D3,D7	JUMP',NE 82$	SUB.L	D0,(A1)+OOBPOC	NEG.L	D0	ADD.L	(A1)+OOBNCM,D0	; qq caractres de plus avancs/reculs	POP.W	D4	CALL	TXPANNULE	; annule le BPSAUVE	JUMP'	84$82$:	POP.W	D4	CALL	TXPPREND	; remet le curseur o il tait	LOAD.W	D3,#ERPNOTF	; D7 <-- pas trouv84$:	LOAD.W	D7,D3		; D7 <-- ok/erreur	LOAD.L	D4,D1		; D4 <-- nombre de caractres trouvs	POPM.L	D0..D3,D5,A3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ECHERCHEAR >;===========/; Cherche en arrire selon le dialogue "change".; Si elle est trouve, le curseur est plac sur le premier caractre.; Si elle n'est pas trouve, le curseur reste immobile !; in	-; out	D4.L	longueur de la chane trouve;	D7.W	erreur; mod	D4.L, D7.WECHERCHEAR:	PUSHM.L	D0..D3,D5,A3	LOAD.L	A3,#(A5)+OCH1	; A3 <-- ^chane de recherche	LOAD.L	D2,(A5)+OCHM1	LOAD.B	D2,#H'FF	; D2 <-- masque de recherche	CALL	TXPSAUVE	PUSH.W	D4		; stack <-- position actuelle	LOAD.L	D0,(A1)+OOBPOC; Cherche rapidement le premier caractre de la chane.10$:	LOAD.L	D3,(A5)+OCHC1	LOAD.B	D3,(A3)		; D3 <-- premier caractre	CLR.W	D5		; D5 <-- mode	TEST.B	(A5)+OCHFAN+3:#BCHMIMA-0	JUMP',BC 20$	TSET.L	D5:#020$:	CALL	TXRCHERCHE	; cherche le premier caractre	JUMP',NE 80$	CALL	TXRECULE	JUMP',NE 80$; Cherche normalement si le reste de la chane correspond.	CALL	ECHERCHECP	; chane complte trouve ?	JUMP,NE 10$; Fin de la recherche. En cas d'erreur, remet le curseur o il tait.80$:	LOAD.W	D3,D7	JUMP',NE 82$	SUB.L	D0,(A1)+OOBPOC	ADD.L	(A1)+OOBNCM,D0	; qq caractres de plus avancs/reculs	POP.W	D4	CALL	TXPANNULE	; annule le BPSAUVE	JUMP'	84$82$:	POP.W	D4	CALL	TXPPREND	; remet le curseur o il tait	LOAD.W	D3,#ERPNOTF	; D7 <-- pas trouv84$:	LOAD.W	D7,D3		; D7 <-- ok/erreur	LOAD.L	D4,D1		; D4 <-- nombre de caractres trouvs	POPM.L	D0..D3,D5,A3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ECHERCHECP >;-----------/; Regarde si le curseur est au dbut de la chane de recherche complte.; in	A3.L	^chane de recherche;	D2.L	masque de recherche; out	D1.L	nombre de caractres trouvs;	D7.W	erreur; mod	D1.L, D7.WECHERCHECP:	PUSHM.L	D3,D4,A3	CALL	TXPSAUVE	PUSH.W	D4		; stack <-- position dbut chane	TEST.B	(A5)+OCHFAN+3:#BCHMOT-0	JUMP',BC 10$	CALL	TXRECULE	JUMP',NE 10$	CALL	ECHERCHEMO	; lettre ou chiffre ?	JUMP,EQ 75$		; oui => 75$	CALL	TXAVANCE10$:	CLR.L	D1		; D1 <-- nombre de caractres trouvs20$:	LOAD.L	D4,(A5)+OCHC1	LOAD.B	D4,(A3+)	; D4 <-- caractre de la chane	JUMP,EQ 50$	COMP.B	D4,#'*	JUMP',NE 30$	TEST.B	(A5)+OCHFAN+3:#BCHJOKER-0	JUMP,BS 40$30$:	CALL	TXAVANCE	; D3 <-- caractre du texte	JUMP,NE 75$	INC.L	D1		; D1 <-- un caractre de plus	COMP.B	D4,#'?	JUMP',NE 32$	TEST.B	(A5)+OCHFAN+3:#BCHJOKER-0	JUMP,BS 20$32$:	AND.L	D3,D2		; D3 <-- masque	AND.L	D4,D2		; D4 <-- masque	TEST.B	(A5)+OCHFAN+3:#BCHMIMA-0	JUMP',BC 36$	CALL	MINMAJ		; D3 <-- majuscule	EX.L	D4,D3	CALL	MINMAJ		; D4 <-- majuscule	EX.L	D3,D436$:	COMP.L	D3,D4		; compare deux caractres	JUMP,EQ 20$	JUMP'	75$40$:				; toile rencontre =>	LOAD.L	D4,(A5)+OCHC1	LOAD.B	D4,(A3+)	; D4 <-- caractre aprs l'toile	JUMP,EQ 50$	AND.L	D4,D2		; D4 <-- masque	TEST.B	(A5)+OCHFAN+3:#BCHMIMA-0	JUMP',BC 42$	EX.L	D4,D3	CALL	MINMAJ		; D4 <-- majuscule	EX.L	D3,D442$:	CALL	TXAVANCE	; D3 <-- caractre du texte	JUMP,NE 75$	INC.L	D1		; D1 <-- un caractre de plus	TEST.B	(A5)+OCHFAN+3:#BCHMOT-0	JUMP',BC 44$	CALL	ECHERCHEMO	; lettre ou chiffre ?	JUMP,NE 75$		; non => 75$44$:	AND.L	D3,D2		; D3 <-- masque	TEST.B	(A5)+OCHFAN+3:#BCHMIMA-0	JUMP',BC 46$	CALL	MINMAJ		; D3 <-- majuscule46$:	COMP.L	D3,D4		; compare deux caractres	JUMP,NE 42$	JUMP	20$50$:				; fin chane de recherche =>	TEST.B	(A5)+OCHFAN+3:#BCHMOT-0	JUMP',BC 70$	CALL	TXAVANCE	JUMP',NE 70$	CALL	ECHERCHEMO	; lettre ou chiffre ?	JUMP',EQ 75$		; oui => 75$70$:	CLR.W	D7		; D7 <-- trouv	JUMP'	80$75$:	LOAD.W	D7,#ERPNOTF	; D7 <-- pas trouv80$:	LOAD.W	D3,D7	POP.W	D4	CALL	TXPPREND	; revient au dbut de la chane	LOAD.W	D7,D3	POPM.L	D3,D4,A3	TEST.W	D7		; retour EQ/NE	RET;-----------\\; ECHERCHEMO >;-----------/; Regarde si un caractre est une lettre ou un chiffre.; in	D3.B	caractre; out	D7.W	EQ => c'est une lettre/chiffre;		NE => autre caractre; mod	D3.B, D7.WECHERCHEMO:	CALL	MINMAJ	LOAD.W	D7,#1		; D7 <-- autre chose	COMP.B	D3,#'0	JUMP',LO 90$	COMP.B	D3,#'9	JUMP',LS 80$	COMP.B	D3,#'A	JUMP',LO 90$	COMP.B	D3,#'Z	JUMP',HI 90$80$:	CLR.W	D7		; D7 <-- lettre ou chiffre90$:	TEST.W	D7		; retour EQ/NE	RET;-------------\\; ESUBSTITUEAR >;=============/; Remplace la chane de recherche par la chane de substitution.; Le curseur est plac au dbut de la chane substitue.; in	D4.L	longueur de la chane trouve; out	D4.L	longueur de la chane substitue;	D7.W	erreur; mod	D4.L, D7.WESUBSTITUEAR:	CALL	ESUBSTITUEAV	JUMP',EQ 20$	RET20$:	PUSHM.L	D3,D422$:	CALL	TXRECULE	; recule au dbut	JUMP',NE 24$	INC.L	(A1)+OOBNCM	; un caractre de plus recul	DEC.L	D4	JUMP,NE 22$24$:	POPM.L	D3,D4	CLR.W	D7		; D7 <-- ok	RET;-------------\\; ESUBSTITUEAV >;=============/; Remplace la chane de recherche par la chane de substitution.; Le curseur est plac  la fin de la chane substitue.; in	D4.L	longueur de la chane trouve; out	D4.L	longueur de la chane substitue;	D7.W	erreur; mod	D4.L, D7.WESUBSTITUEAV:	PUSHM.L	D1..D3,A3; Supprime d'abord la chane de recherche.	CLR.L	D220$:	CALL	TXAVANCE	JUMP',NE 30$	TEST.L	D2	JUMP',NE 22$	LOAD.L	D2,D3		; D2 <-- premier caractre dtruit22$:	CALL	TXDETRUIT	; dtruit un caractre en avant	INC.L	(A1)+OOBNCL	; un caractre de plus dtruit en avant	DEC.L	D4		; encore un caractre ?	JUMP,NE 20$		; oui => 20$; Insre la chane de substitution.30$:	LOAD.L	A3,#(A5)+OCH2	; A3 <-- ^chane de substitution	CLR.L	D450$:	LOAD.L	D3,D2	LOAD.B	D3,(A3+)	; D3 <-- caractre, avec mode du premier dtruit	JUMP',EQ 80$	LOAD.L	D1,(A5)+OCHM2	NOT.L	D1	AND.L	D3,D1	OR.L	D3,(A5)+OCHC2	CALL	TXINSERE	JUMP',NE 90$	INC.L	(A1)+OOBNCI	; un caractre de plus insr	INC.L	D4		; D4 <-- longueur de la chane de substitution	JUMP	50$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D3,A3	TEST.W	D7		; retour EQ/NE	RET;--------\\; EMINMAJ >;========/; Transforme un caractre, en majuscule ou en minuscule.; in	D3.B	touche majuscule/minuscule;		H'80 = majuscules accentues;		H'81 = chiffres fixes;		H'82 = chiffres proportionnels; out	D7.W	erreur; mod	D7.WEMINMAJ:	PUSHM.L	D2..D4	LOAD.B	D2,D3	CALL	TXDONNE		; D3 <-- caractre sous le curseur	JUMP,NE EXIT$	LOAD.B	D4,D3	COMP.B	D2,#H'80	JUMP',EQ MAJACC$	COMP.B	D2,#H'81	JUMP',EQ FIX$	COMP.B	D2,#H'82	JUMP',EQ PROP$	COMP.B	D2,#'a	JUMP',LO MINUS$	COMP.B	D2,#'z	JUMP',HI MINUS$MAJUS$:				; en minuscule =>	CALL	MAJMIN		; D3 <-- lattre majuscule	JUMP'	CHANGE$MINUS$:				; en majuscule =>	CALL	MINMAJ		; D3 <-- lettre majuscule	JUMP'	CHANGE$MAJACC$:			; en majuscule accentue =>	CALL	MINMAJACC	; D3 <-- lettre majuscule accentue	JUMP'	CHANGE$FIX$:	COMP.B	D3,#H'E6	JUMP',LO CHANGE$	COMP.B	D3,#H'EF	JUMP',HI CHANGE$	SUB.B	D3,#H'E6-'0	JUMP'	CHANGE$PROP$:	COMP.B	D3,#'0	JUMP',LO CHANGE$	COMP.B	D3,#'9	JUMP',HI CHANGE$	ADD.B	D3,#H'E6-'0;	JUMP'	CHANGE$CHANGE$:	COMP.B	D3,D4		; caractre chang ?	JUMP',EQ EXIT$		; non => EXIT$	CALL	TXREMPLACE	INC.L	(A1)+OOBNCI	; un caractre de plus insr	INC.L	(A1)+OOBNCM	; un caractre de plus avanc/reculEXIT$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; ESELMOT >;========/; Slectionne tout un mot.; in	D4.L	position n'importe o; out	D4.L	position dbut mot;	D5.L	position fin mot; mod	D4.L, D5.L, D7.WESELMOT:	PUSHM.L	D0..D3	LOAD.L	D0,D4	CALL	TXPSAUVE	; D4 <-- numro position actuelle	EX.L	D0,D4	CALL	TXQPOSITIONNE	; positionne (rapidement)	LOAD.B	D3,#'S	CALL	EFLECHE		; D2 <-- dplacement pour reculer au dbut du mot	LOAD.L	D1,D2	LOAD.B	D3,#'G	CALL	EFLECHE		; D2 <-- dplacement pour avancer  la fin du mot	LOAD.L	D5,D4	ADD.L	D5,D2		; D5 <-- position fin mot	ADD.L	D4,D1		; D4 <-- position dbut mot	EX.L	D0,D4	CALL	TXPPREND	; remet le curseur o il tait	LOAD.L	D4,D0	POPM.L	D0..D3	RET;---------\\; EFLECHE  >;---------/; Calcul l'amplitude d'un dplacement/destruction en fonction; d'une touche flche.; in	D3.B	touche flche; out	D2.L	dplacement (+/-n); mod	D2.L, D7.WEFLECHE:	PUSHM.L	D3..D6,A3	CALL	TXPSAUVE	; D4 <-- numro position actuelle	PUSH.W	D4	CLR.L	D2		; D2 <-- dplacement	COMP.B	D3,#'A-H'40	JUMP',LO NOCTRL$	COMP.B	D3,#'Z-H'40	JUMP',HI NOCTRL$	ADD.B	D3,#H'40NOCTRL$:	CALL	MINMAJ	COMP.B	D3,#'F	JUMP,EQ AONE$	COMP.B	D3,#'D	JUMP,EQ RONE$	LOAD.W	D6,#1		; D6 <-- une fois	LOAD.L	A3,#R16"TWORD	; A3 <-- ^terminateurs de mots	COMP.B	D3,#'G	JUMP,EQ ALIST$	COMP.B	D3,#'S	JUMP,EQ RLIST$	LOAD.L	A3,#R16"TLINE	; A3 <-- ^terminateurs de lignes	COMP.B	D3,#'C	JUMP,EQ ALIST$	COMP.B	D3,#'R	JUMP,EQ RLIST$	LOAD.W	D6,#4		; D6 <-- quatre fois	COMP.B	D3,#'X	JUMP,EQ ALIST$	COMP.B	D3,#'E	JUMP,EQ RLIST$	COMP.B	D3,#'V	JUMP,EQ AEND$	COMP.B	D3,#'T	JUMP,EQ REND$	JUMP	EXIT$AONE$:				; +1 caractre =>	CALL	TXAVANCE	JUMP,NE EXIT$	INC.L	D2	JUMP	EXIT$RONE$:				; -1 caractre =>	CALL	TXRECULE	JUMP,NE EXIT$	DEC.L	D2	JUMP	EXIT$ALIST$:				; +1 mot/ligne =>	CALL	TXAVANCE	JUMP,NE EXIT$	INC.L	D2	CALL	ETESTCAR	JUMP',NE ALIST2$	COMP.B	(A3),#CR	JUMP,NE ALIST$ALIST2$:	CALL	TXAVANCE	JUMP,NE EXIT$	INC.L	D2	CALL	ETESTCAR	JUMP,NE ALIST2$	CALL	TXRECULE	DEC.L	D2	DEC.W	D6	JUMP,NE ALIST$	JUMP	EXIT$RLIST$:				; -1 mot/ligne =>	CALL	TXRECULE	JUMP,NE EXIT$	DEC.L	D2	CALL	ETESTCAR	JUMP',NE RLIST2$	COMP.B	(A3),#CR	JUMP,NE RLIST$RLIST2$:	CALL	TXRECULE	JUMP,NE EXIT$	DEC.L	D2	CALL	ETESTCAR	JUMP,NE RLIST2$	CALL	TXAVANCE	INC.L	D2	DEC.W	D6	JUMP,NE RLIST$	JUMP	EXIT$AEND$:				; fin =>	CALL	TXINFO		; D4 <-- position, D5 <-- nb caractres	LOAD.L	D2,D5	SUB.L	D2,D4	JUMP'	EXIT$REND$:				; dbut =>	CALL	TXINFO		; D4 <-- position, D5 <-- nb caractres	LOAD.L	D2,D4	NEG.L	D2;	JUMP'	EXIT$EXIT$:	POP.W	D4	CALL	TXPPREND	; remet le curseur o il tait	POPM.L	D3..D6,A3	RETTWORD:	.B	SPACE		; terminateurs de mots	.B	TAB	.B	'+	.B	'-	.B	'*	.B	'/	.B	'^	.B	'(	.B	')	.B	'.	.B	':	.B	',	.B	';	.B	'!	.B	'?TLINE:	.B	CR		; terminateurs de lignes	.B	LF	.B	0	.EVEN;---------\\; ETESTCAR >;---------/; Test si le caractre dans D3.B est un terminateur.; in	D3.B	caractre;	A3.L	^liste de terminateurs; out	EQ	terminateur;	NE	autre chose; mod	FETESTCAR:	PUSH.L	A310$:	TEST.B	(A3)	NOTZ	JUMP',NE EXIT$	COMP.B	D3,(A3+)	JUMP,NE 10$EXIT$:	POP.L	A3	RET;--------\\; ACCENT  >;========/; Caractre aprs un accent flottant frapp.; in	D3.B	caractre aprs accent; out	D7.W	erreur; mod	D7.WACCENT:	PUSHM.L	D3,D4	LOAD.W	D7,#ERPBIP	TEST.B	(A1)+OOBACC	JUMP',F EXIT$	CLR.B	(A1)+OOBACC	LOAD.L	D4,D3	CALL	TXDONNE		; D3 <-- cherche car prcdent tap	EX.L	D3,D4		; D4 <-- accent, D3 <-- car qui ira "sous"	CALL	GETACCENT	; accent existe ?	JUMP',NE 40$		; non => 40$				; oui =>	TEST.B	D3		; laisse l'accent seul ?	JUMP',EQ 40$		; oui => 40$				; non =>	PUSH.L	D3	CALL	TXAVANCE	CALL	TXDETRUIT	; dtruit l'accent seul	POP.L	D3	CALL	EINSERE		; remplace par lettre accentue	INC.L	(A1)+OOBNCM	; un caractre de plus avanc/recul	JUMP'	EXIT$40$:	PUSH.W	D7	CALL	TXAVANCE	; saute '^' ou '"'	POP.W	D7EXIT$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; GETACCENT >;----------/; Calcul le code correspondant  une lettre (a,e,i,o,u) et ; un accent (^,").; in	D4.B	accent (^,");	D3.B	caractre; out	D7.W	zro => ok (lettre accentue existe);	 D3.B	 lettre accentue;	D7.W	EREOUTB => lettre accentue n'existe pas;	 D3.B	 caractre qui devait aller sous l'accent; mod	D3.B, D7.WGETACCENT:	PUSH.L	A3	LOAD.L	A3,#R16"ACCENT$-310$:	ADD.L	A3,#3		; A3 <-- ^suivant dans table	TEST.B	(A3)		; fin de la table ?	JUMP',EQ 50$		; oui => 50$	COMP.B	D3,(A3)		; lettre trouve dans table ?	JUMP,NE 10$		; non => 10$				; oui =>	COMP.B	D4,#CIRCON	JUMP',EQ 30$	COMP.B	D4,#TREMA	JUMP',NE 50$	LOAD.B	D3,(A3)+2	; D3 <-- lettre accentue (")	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$30$:	LOAD.B	D3,(A3)+1	; D3 <-- lettre accentue (^)	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$50$:	LOAD.W	D7,#ERPBIP	; D7 <-- erreurEXIT$:	POP.L	A3	TEST.W	D7		; retour EQ/NE	RETACCENT$:	.B	'a	' '	.B	'e	' '	.B	'i	' '	.B	'o	' '	.B	'u	' '	.B	SPACE	 0  0	.B	0	.EVEN;---------\\; NOACCENT >;=========/; Annule l'effet d'un ventuel accent flottant tap, alors; que la lettre devant aller "dessous" n'a pas encore t; tape.NOACCENT:	TEST.B	(A1)+OOBACC	JUMP',F EXIT$	CLR.B	(A1)+OOBACC	PUSH.L	D3	CALL	TXAVANCE	; saute l'accent flottant	POP.L	D3EXIT$:	RET;--------\\; EXKEY   >;========/; in	D3.B	touche presse; out	-; mod	A0.LEXKEY:	POP.L	A0		; A0 <-- ^table des .WW	PUSH.L	D3	COMP.B	D3,#'a		; minuscule ?	JUMP',LO 10$		; non => 10$	COMP.B	D3,#'z	JUMP',HI 10$	SUB.B	D3,#'a-'A	; oui => transforme10$:	COMP.B	D3,#F0+SHIFT	JUMP',LO 12$	COMP.B	D3,#F15+SHIFT	JUMP',HI 12$	SUB.B	D3,#SHIFT	; (SHIFT-Fn) --> (Fn)12$:	SUB.L	A0,#4		; A0 <-- recule .WW20$:	ADD.L	A0,#4		; A0 <-- saute .WW	TEST.W	(A0)		; table termine ?	JUMP',EQ 50$		; oui => 50$				; non =>	COMP.B	D3,(A0)+1	; code touche trouve ?	JUMP,NE	20$		; non => 20$50$:	LOAD.W	D3,(A0)+2	; D3 <-- adresse relative	LOAD.L	A0,#R16"TXPREL	ADD.W	A0,D3		; A0 <-- adresse absolue	POP.L	D3	JUMP	(A0)		; excute ...;--------\\; EXFONC  >;========/; in	D3.W	touche fonction (dans high); out	-; mod	A0.LEXFONC:	POP.L	A0		; A0 <-- ^table des .WW	PUSH.L	D3	SR.W	D3,#8		; D3 <-- touche fonction	SUB.L	A0,#4		; A0 <-- recule .WW20$:	ADD.L	A0,#4		; A0 <-- saute .WW	TEST.W	(A0)		; table termine ?	JUMP',EQ 50$		; oui => 50$				; non =>	COMP.B	D3,(A0)+1	; code touche fonction trouv ?	JUMP,NE	20$		; non => 20$50$:	LOAD.W	D3,(A0)+2	; D3 <-- adresse relative	LOAD.L	A0,#R16"TXPREL	ADD.W	A0,D3		; A0 <-- adresse absolue	POP.L	D3	JUMP	(A0)		; excute ...	.END