	.SBTTL	OPTEXTDICO.ASI;----------\\; DICOVERIF >;==========/; Vrifie l'orthographe d'une zone quelconque.; in	A1.L	^objet texte;	D4.L	position;	D5.L	nb de caractres; out	D7.W	erreur; mod	D7.WDICOVERIF:	PUSHM.L	D0..D6,A0,A2..A4	LOAD.W	D7,#MI_WAITMOUSE	PAGE_	MISC		; met le sablier	LOAD.L	D0,D4	CALL	DICOOPTEXT	; A4/D4 <-- ^texte/lg	JUMP,NE 90$	LOAD.L	A0,A4	LOAD.L	D1,D4		; A0/D1 <-- ^texte/lg	LOAD.L	A2,A4	LOAD.L	D2,D4		; A2/D2 <-- ^texte/lg	CLR.W	(A5)+ODINBF	CLR.B	(A5)+ODIBM	; aucun mot  changer partout40$:	LOAD.L	A4,A0	LOAD.L	D4,D1		; A4/D4 <-- ^phrase complte	LOAD.L	A3,A2	LOAD.L	D3,D2		; A3/D3 <-- ^o vrifier	LOAD.W	D7,#IO_DICOLOAD	PAGE_	IO		; D6 <-- canal	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX	LOAD.W	D7,#MI_WAITMOUSE	PAGE_	MISC		; met le sablier	DICO_	JUSTE		; est-ce juste ?	PUSH.W	D7	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX	POP.W	D7	JUMP,EQ 80$	COMP.W	D7,#ERKSTO	JUMP,EQ 70$	ADD.L	D2,A2	SUB.L	D2,A4	SUB.L	D2,D4	LOAD.L	A2,A4	ADD.L	A2,D4		; A2 <-- ^plus loin	LOAD.L	D6,A4	LOAD.L	D5,D4	INC.W	(A5)+ODINBF	; une faute de plus	LOAD.L	D3,D0	ADD.L	D3,D6	SUB.L	D3,A0	CALL	DICOMASC	; met  jour l'ascenseur	LOAD.L	A3,A4	LOAD.L	D3,D4	CALL	DICOCTEXI	; mot  changer partout ?	JUMP',EQ 50$		; oui => 50$	LOAD.L	A3,A0	LOAD.L	D3,D1	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX	PUSH.L	D6	LOAD.W	D7,#IO_DICOLOAD	PAGE_	IO		; D6 <-- canal	DICO_	CHANGE		; change un mot ...	POP.L	D6	PUSH.W	D7	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX	POP.W	D7	JUMP,NE 90$	COMP.W	D3,#F1		; remplace-un ?	JUMP',EQ 50$	COMP.W	D3,#F3		; remplace-tout ?	JUMP',EQ 60$	COMP.W	D3,#F10		; stoppe ?	JUMP,EQ 90$	JUMP	40$50$:				; remplace-un =>	LOAD.L	D3,D0	ADD.L	D3,D6	SUB.L	D3,A0	CALL	DICOCHMOT	; change un mot	JUMP,NE 90$	JUMP	40$60$:				; remplace-tout =>	LOAD.L	D3,D0	ADD.L	D3,D6	SUB.L	D3,A0	CALL	DICOCHMOT	; change un mot	JUMP',NE 90$	LOAD.L	A3,D6	LOAD.L	D3,D5	CALL	DICOCTMEM	; mmorise le mot	JUMP	40$70$:				; stoppe =>	LOAD.L	D4,D0	ADD.L	D4,A4	SUB.L	D4,A0	CALL	TXPOSITIONNE	JUMP'	85$80$:	LOAD.B	D3,#BIPDONE	LIB	?BEEP		; indique que c'est fini	TEST.W	(A5)+ODINBF	; y a-t-il eu des fautes ?	JUMP',NE 85$		; oui => 85$	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX	LOAD.W	D7,#IO_DICOLOAD	PAGE_	IO		; D6 <-- canal	DICO_	OK		; indique que tout est ok ...	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX85$:	CLR.W	D7		; D7 <-- ok90$:	CALL	DICOCLTEXT	; ferme le buffer de texte	POPM.L	D0..D6,A0,A2..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DICOMARK >;=========/; Marque les fautes d'orthographe d'une zone quelconque.; in	A1.L	^objet texte;	D4.L	position;	D5.L	nb de caractres; out	D7.W	erreur; mod	D7.WDICOMARK:	PUSHM.L	D0..D6,A0,A2..A4	LOAD.W	D7,#MI_WAITMOUSE	PAGE_	MISC		; met le sablier	LOAD.L	D0,D4	CALL	DICOOPTEXT	; A4/D4 <-- ^texte/lg	JUMP,NE 90$	LOAD.L	A0,A4	LOAD.L	D1,D4		; A0/D1 <-- ^texte/lg	LOAD.L	A2,A4	LOAD.L	D2,D4		; A2/D2 <-- ^texte/lg	CLR.W	(A5)+ODINBF	LOAD.L	D5,#-140$:	LOAD.L	A4,A0	LOAD.L	D4,D1		; A4/D4 <-- ^phrase complte	LOAD.L	A3,A2	LOAD.L	D3,D2		; A3/D3 <-- ^o vrifier	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX	LOAD.W	D7,#MI_WAITMOUSE	PAGE_	MISC		; met le sablier	DICO_	JUSTE		; est-ce juste ?	PUSH.W	D7	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX	POP.W	D7	JUMP,EQ 80$	COMP.W	D7,#ERKSTO	JUMP,EQ 70$	ADD.L	D2,A2	SUB.L	D2,A4	SUB.L	D2,D4	LOAD.L	A2,A4	ADD.L	A2,D4		; A2 <-- ^plus loin	INC.W	(A5)+ODINBF	; une faute de plus	LOAD.L	D3,D0	ADD.L	D3,A4	SUB.L	D3,A0	CALL	DICOMAMOT	; marque un mot	COMP.L	D5,#-1	JUMP',NE 50$	LOAD.L	D5,D3		; D5 <-- position premire faute50$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	40$70$:				; stoppe =>	LOAD.L	D4,D0	ADD.L	D4,A4	SUB.L	D4,A0	CALL	TXPOSITIONNE	JUMP'	85$80$:	LOAD.B	D3,#BIPDONE	LIB	?BEEP		; indique que c'est fini	TEST.W	(A5)+ODINBF	; y a-t-il eu des fautes ?	JUMP',EQ 82$		; non => 82$				; oui =>	LOAD.L	D4,D5	INC.L	D4	CALL	TXPOSITIONNE	; va au dbut de la premire faute	JUMP'	85$82$:	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX	DICO_	OK		; indique que tout est ok ...	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX85$:	CLR.W	D7		; D7 <-- ok90$:	CALL	DICOCLTEXT	; ferme le buffer de texte	POPM.L	D0..D6,A0,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DICOADD >;========/; Ajoute un mot dans le dictionnaire.; in	A1.L	^objet texte;	D4.L	position;	D5.L	nb de caractres; out	D7.W	erreur; mod	D7.WDICOADD:	PUSHM.L	D0..D6,A2..A4	LOAD.W	D7,#MI_WAITMOUSE	PAGE_	MISC		; met le sablier	LOAD.L	D0,D4	CALL	DICOOPTEXT	; A4/D4 <-- ^texte/lg	JUMP',NE 90$	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX	DICO_	ADD		; conserve un mot ...	PUSH.W	D7	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX	POP.W	D790$:	CALL	DICOCLTEXT	; ferme le buffer de texte	POPM.L	D0..D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DICOCONJ >;=========/; Conjugue un verbe quelconque.; in	A1.L	^objet texte;	D4.L	position;	D5.L	nb de caractres; out	D7.W	erreur; mod	D7.WDICOCONJ:	PUSHM.L	D0..D6,A4	LOAD.W	D7,#MI_WAITMOUSE	PAGE_	MISC		; met le sablier	LOAD.L	D0,D4	CALL	DICOOPTEXT	; A4/D4 <-- ^texte/lg	JUMP',NE 90$	LOAD.L	D5,D4	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX	DICO_	CONJ		; conjugue un verbe ...	PUSH.W	D7	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX	POP.W	D7	JUMP',NE 90$	COMP.W	D3,#F1		; remplace ?	JUMP',NE 90$	LOAD.L	D3,D0	CALL	DICOCHMOT	; change un mot90$:	CALL	DICOCLTEXT	; ferme le buffer de texte	POPM.L	D0..D6,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DICOACCORD >;===========/; Accorde un mot quelconque.; in	A1.L	^objet texte;	D4.L	position;	D5.L	nb de caractres; out	D7.W	erreur; mod	D7.WDICOACCORD:	PUSHM.L	D0..D6,A4	LOAD.W	D7,#MI_WAITMOUSE	PAGE_	MISC		; met le sablier	LOAD.L	D0,D4	CALL	DICOOPTEXT	; A4/D4 <-- ^texte/lg	JUMP',NE 90$	LOAD.L	D5,D4	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX	DICO_	ACCORD		; accorde le mot ...	PUSH.W	D7	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX	POP.W	D7	JUMP',NE 90$	COMP.W	D3,#F1		; remplace ?	JUMP',NE 90$	LOAD.L	D3,D0	CALL	DICOCHMOT	; change un mot90$:	CALL	DICOCLTEXT	; ferme le buffer de texte	POPM.L	D0..D6,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DICOSYNO >;=========/; Trouve le synonyme d'un mot quelconque.; in	A1.L	^objet texte;	D4.L	position;	D5.L	nb de caractres; out	D7.W	erreur; mod	D7.WDICOSYNO:	PUSHM.L	D0..D6,A3,A4	LOAD.W	D7,#MI_WAITMOUSE	PAGE_	MISC		; met le sablier	LOAD.L	D0,D4	CALL	DICOOPMOT	; A4/D4 <-- ^texte/lg, A3/D3 <-- ^mot/lg	JUMP',NE 90$	LOAD.L	D5,D3	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX	DICO_	SYNO		; synonyme du mot ...	PUSH.W	D7	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX	POP.W	D7	JUMP',NE 90$	COMP.W	D3,#F1		; remplace ?	JUMP',NE 90$	LOAD.L	D3,D0	CALL	DICOCHMOT	; change un mot90$:	CALL	DICOCLTEXT	; ferme le buffer de texte	POPM.L	D0..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; DICOFAMILLE >;============/; Trouve les mots de la mme famille.; in	A1.L	^objet texte;	D4.L	position;	D5.L	nb de caractres; out	D7.W	erreur; mod	D7.WDICOFAMILLE:	PUSHM.L	D0..D6,A3,A4	LOAD.W	D7,#MI_WAITMOUSE	PAGE_	MISC		; met le sablier	LOAD.L	D0,D4	CALL	DICOOPMOT	; A4/D4 <-- ^texte/lg, A3/D3 <-- ^mot/lg	JUMP',NE 90$	LOAD.L	D5,D3	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX	DICO_	FAMILLE		; mme famille ...	PUSH.W	D7	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX	POP.W	D7	JUMP',NE 90$	COMP.W	D3,#F1		; remplace ?	JUMP',NE 90$	LOAD.L	D3,D0	CALL	DICOCHMOT	; change un mot90$:	CALL	DICOCLTEXT	; ferme le buffer de texte	POPM.L	D0..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DICONOMB >;=========/; Transforme un nombre.; in	A1.L	^objet texte;	D4.L	position;	D5.L	nb de caractres; out	D7.W	erreur; mod	D7.WDICONOMB:	PUSHM.L	D0..D6,A4	LOAD.W	D7,#MI_WAITMOUSE	PAGE_	MISC		; met le sablier	LOAD.L	D0,D4	CALL	DICOOPTEXT	; A4/D4 <-- ^texte/lg	JUMP',NE 90$	LOAD.L	D5,D4	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX	DICO_	CHIFFRE		; transforme un chiffre ...	PUSH.W	D7	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX	POP.W	D7	JUMP',NE 90$	COMP.W	D3,#F1		; remplace ?	JUMP',NE 90$	LOAD.L	D3,D0	CALL	DICOCHMOT	; change un mot90$:	CALL	DICOCLTEXT	; ferme le buffer de texte	POPM.L	D0..D6,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DICOMAJ >;========/; Met  jour les dictionnaires privs.; in	-; out	D3.W	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDICOMAJ:	PUSH.L	D6	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX	LOAD.W	D7,#IO_DICOLOAD	PAGE_	IO		; D6 <-- canal	DICO_	MAJ		; met  jour ...	PUSH.W	D7	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX	POP.W	D7	POP.L	D6	TEST.W	D7		; retour EQ/NE	RET;----------\\; DICOVTEMP >;==========/; Vide TEMP.; in	-; out	D7.W	erreur; mod	D7.WDICOVTEMP:	PUSHM.L	D3,D6	LOAD.W	D7,#IO_DICOLOAD	PAGE_	IO		; D6 <-- canal	CLR.W	D3	DICO_	VTEMP		; vide TEMP	POPM.L	D3,D6	TEST.W	D7		; retour EQ/NE	RET;--------\\; DICODEF >;========/; Choix des dfinitions gnrales.; in	-; out	D7.W	erreur; mod	D7.WDICODEF:	PUSHM.L	D3,D4,D6	LOAD.W	D7,#DB_OPEN1	PAGE_	DBOX	LOAD.W	D7,#IO_DICOLOAD	PAGE_	IO		; D6 <-- canal	CLR.W	D3	DICO_	DEF		; choix des dfinitions ...	PUSH.W	D7	LOAD.W	D7,#DB_CLOSE1	PAGE_	DBOX	POP.W	D7	POPM.L	D3,D4,D6	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DICOOPTEXT >;-----------/; Ouvre le buffer de texte.; in	D4.L	position;	D5.L	nb de caractres; out	A4/D4.L	^texte/lg;	D6.L	canal DICO;	D7.W	erreur; mod	D4.L, D6.L, D7.W, A4.LDICOOPTEXT:	PUSHM.L	D1,D3	LOAD.W	D7,#IO_DICOLOAD	PAGE_	IO		; D6 <-- canal	JUMP',NE 90$	CALL	TXPOSITIONNE	; va au dbut de la zone  vrifier	JUMP',NE 90$	LOAD.L	D4,D5	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire pour texte	JUMP',NE 90$	LOAD.L	(A5)+ODIPBT,A420$:	CALL	TXAVANCE	JUMP',NE 22$	CALL	NOSUPPL		; D3 <-- caractre < 128	LOAD.B	(A4+),D3	; buffer <-- caractres	DEC.L	D4	JUMP,NE 20$22$:	LOAD.L	A4,(A5)+ODIPBT	; A4 <-- ^texte	LOAD.L	D4,D5		; D4 <-- lg90$:	POPM.L	D1,D3	TEST.W	D7		; retour EQ/NE	RET;----------\\; DICOOPMOT >;----------/; Ouvre le buffer de texte.; in	D4.L	position;	D5.L	nb de caractres; out	A4/D4.L	^texte/lg;	A3/D3.L	^mot/lg;	D6.L	canal DICO;	D7.W	erreur; mod	D3.L, D4.L, D6.L, D7.W, A3.L, A4.LDICOOPMOT:	PUSHM.L	D0..D2	LOAD.W	D7,#IO_DICOLOAD	PAGE_	IO		; D6 <-- canal	JUMP',NE 90$	LOAD.L	D0,#200		; D0 <-- lg  reculer	COMP.L	D0,D4	JUMP',LS 10$	LOAD.L	D0,D410$:	LOAD.L	D1,#200		; D1 <-- lg  avancer	LOAD.L	D3,(A1)+OOBNBC	SUB.L	D3,D4	SUB.L	D3,D5	COMP.L	D1,D3	JUMP',LS 12$	LOAD.L	D1,D312$:	LOAD.L	D2,D4		; D2 <-- position dbut mot	SUB.L	D4,D0	CALL	TXPOSITIONNE	; va au dbut de la zone  vrifier	JUMP',NE 90$	LOAD.L	D4,D5	ADD.L	D4,D0	ADD.L	D4,D1	PUSH.L	D1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^mmoire pour texte	POPM.L	D1	JUMP',NE 90$	LOAD.L	(A5)+ODIPBT,A420$:	CALL	TXAVANCE	JUMP',NE 22$	CALL	NOSUPPL		; D3 <-- caractre < 128	LOAD.B	(A4+),D3	; buffer <-- caractres	DEC.L	D4	JUMP,NE 20$22$:	LOAD.L	D4,D2	ADD.L	D4,D5	CALL	TXPOSITIONNE	; va  la fin du mot	JUMP',NE 90$	LOAD.L	A4,(A5)+ODIPBT	; A4 <-- ^texte	LOAD.L	D4,D5	ADD.L	D4,D0	ADD.L	D4,D1		; D4 <-- lg	LOAD.L	A3,#(A4)+(D0.L)	; A3 <-- ^mot	LOAD.L	D3,D5		; D3 <-- lg90$:	POPM.L	D0..D2	TEST.W	D7		; retour EQ/NE	RET;-----------\\; DICOCLTEXT >;-----------/; Ferme le buffer de texte.; in	-; out	-; mod	-DICOCLTEXT:	PUSHM.L	D1,D7,A4	TEST.L	(A5)+ODIPBT	JUMP',EQ 90$	LOAD.L	A4,(A5)+ODIPBT	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le buffer de texte	CLR.L	(A5)+ODIPBT90$:	POPM.L	D1,D7,A4	RET;----------\\; DICOCTEXI >;----------/; Cherche si c'est un mot  changer partout.; in	A3/D3.L	^ancien mot/lg; out	D7.W	ok;	 A4/D4.L ^nouveau mot/lg;	D7.W	erreur;	 A4/D4.L inchang; mod	D4.L, D7.W, A4.LDICOCTEXI:	PUSHM.L	D1,D2,A0,A2	LOAD.L	A2,#(A5)+ODIBM	CLR.B	D2	LOAD.W	D7,#1		; D7 <-- pas trouv20$:	COMP.B	D2,(A2)		; fin rencontre ?	JUMP,EQ 90$		; oui => 90$	LOAD.L	A0,A3	LOAD.L	D1,D330$:	COMP.B	D2,(A2)	JUMP',EQ 34$	DEC.L	D1	JUMP',NS 36$	COMP.B	(A2+),(A0+)	JUMP,EQ 30$	JUMP'	36$34$:	TEST.L	D1	JUMP',EQ 50$36$:	COMP.B	D2,(A2+)	; A2 <-- ^saute ancien mot	JUMP,NE 36$38$:	COMP.B	D2,(A2+)	; A2 <-- ^saute nouveau mot	JUMP,NE 38$	JUMP	20$50$:	LOAD.L	A4,#(A2)+1	; A4 <-- ^nouveau mot	LOAD.L	A2,A4	LOAD.L	D4,#-152$:	INC.L	D4		; D4 <-- lg nouveau mot	COMP.B	D2,(A2+)	JUMP,NE 52$	CLR.W	D7		; D7 <-- trouv90$:	POPM.L	D1,D2,A0,A2	TEST.W	D7		; retour EQ/NE	RET;----------\\; DICOCTMEM >;----------/; Mmorise un mot  changer partout.; in	A3/D3.L	^ancien mot/lg;	A4/D4.L	^nouveau mot/lg; out	-; mod	D7.WDICOCTMEM:	PUSHM.L	D2..D4,A0,A2..A4	LOAD.L	A2,#(A5)+ODIBM	LOAD.L	A0,A2	CLR.B	D220$:	COMP.B	D2,(A2)		; fin rencontre ?	JUMP',EQ 30$		; oui => 30$22$:	COMP.B	D2,(A2+)	; A2 <-- ^saute ancien mot	JUMP,NE 22$24$:	COMP.B	D2,(A2+)	; A2 <-- ^saute nouveau mot	JUMP,NE 24$	JUMP	20$30$:	ADD.L	A0,#LDIBM	SUB.L	A0,D3	SUB.L	A0,D4	SUB.L	A0,#2		; A0 <-- ^adresse  ne pas dpasser	COMP.L	A2,A0		; reste assez de place ?	JUMP,HS 90$		; non => 90$40$:	LOAD.B	(A2+),(A3+)	; ODIBM <-- ancien mot	DEC.W	D3	JUMP,NE 40$	CLR.B	(A2+)42$:	LOAD.B	(A2+),(A4+)	; ODIBM <-- nouveau mot	DEC.W	D4	JUMP,NE 42$	CLR.B	(A2+)	CLR.B	(A2+)90$:	POPM.L	D2..D4,A0,A2..A4	RET;---------\\; DICOMASC >;---------/; Met  jour l'ascenseur  une position donne.; in	D3.L	position; out	-; mod	D7.WDICOMASC:	PUSH.L	D4	LOAD.L	D4,D3	CALL	TXPOSITIONNE	; va au dbut du mot  changer	POP.L	D4	RET;----------\\; DICOCHMOT >;----------/; Change un mot dans le texte.; in	D0.L	position dbut phrase;	D3.L	position dbut ancien mot;	A4/D4.L	^nouveau mot/lg;	D5.L	lg de l'ancien mot; out	D0.L	position dbut phrase;	D7.W	erreur; mod	D0.L, D7.WDICOCHMOT:	PUSHM.L	D2..D5,A4	ADD.L	D0,D4	SUB.L	D0,D5		; D0 <-- nouvelle position	EX.L	D4,D3	CALL	TXPOSITIONNE	; va au dbut du mot  changer	EX.L	D3,D4	JUMP,NE 90$	INC.L	(A1)+OOBNCM	; qq caractres de plus avancs/reculs20$:	TEST.W	D5	JUMP',EQ 30$	CALL	TXAVANCE	CALL	TXDETRUIT	; dtruit un caractre de l'ancien mot	INC.L	(A1)+OOBNCL	; un caractre de plus dtruit en avant	DEC.W	D5	LOAD.B	D2,D330$:	LOAD.B	D3,(A4+)	COMP.B	D2,#'A	JUMP',LO 32$	COMP.B	D2,#'Z		; lettre majuscule ?	JUMP',LS 31$		; oui => 31$	COMP.B	D2,#H'80	JUMP',LO 32$	COMP.B	D2,#H'9F	; lettre majuscule ?	JUMP',LS 31$		; oui => 31$	COMP.B	D2,#H'A8	JUMP',LO 32$	COMP.B	D2,#H'AB	; lettre majuscule ?	JUMP',HI 32$		; non => 32$31$:	CALL	MINMAJ32$:	CALL	TXINSERE	; insre un caractre du nouveau mot	JUMP',NE 90$	INC.L	(A1)+OOBNCI	; un caractre de plus insr	DEC.W	D4	JUMP,NE 20$50$:	DEC.W	D5	JUMP',NS 60$	CALL	TXAVANCE	CALL	TXDETRUIT	; dtruit un caractre de l'ancien mot	INC.L	(A1)+OOBNCL	; un caractre de plus dtruit en avant	JUMP	50$60$:	CALL	EDISPLAY	; affiche le nouveau pav de texte	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D2..D5,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; DICOMAMOT >;----------/; Marque un mot dans le texte (>...<).; in	D0.L	position dbut phrase;	D3.L	position dbut mot;	D4.L	lg du mot; out	D0.L	position dbut phrase;	D7.W	erreur; mod	D0.L, D7.WDICOMAMOT:	PUSHM.L	D3,D4	ADD.L	D0,#2		; D0 <-- nouvelle position	EX.L	D4,D3	CALL	TXPOSITIONNE	; va au dbut du mot  marquer	EX.L	D3,D4	JUMP',NE 90$	INC.L	(A1)+OOBNCM	; qq caractres de plus avancs/reculs	CALL	TXAVANCE	CALL	TXRECULE	LOAD.B	D3,#MARKDM	CALL	TXINSERE	INC.L	(A1)+OOBNCI	; un caractre de plus insr20$:	DEC.W	D4	JUMP',NS 30$	CALL	TXAVANCE	JUMP	20$30$:	LOAD.B	D3,#MARKFM	CALL	TXINSERE	INC.L	(A1)+OOBNCI	; un caractre de plus insr	CALL	EDISPLAY	; affiche le nouveau pav de texte	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D3,D4	TEST.W	D7		; retour EQ/NE	RET	.END