	.SBTTL	OPARCDRAW.ASI;--------\\; DRARC   >;========/; Trace un arc de cercle ou d'ellipse quelconque.; in	D3.L	P1;	D4.L	P2;	D1.L	angle de dpart;	D2.L	angle d'arrive;	A2.L	^routine "line" (in D3/D4 = P1/P2); in	D3.L	origine centre (y;x);	D4.L	rayons (ry;rx);	D2.B	mode;	D1.L	angles de dpart et d'arrive en degrs (a;d);		 d: 0..360 (dans le sens des aiguilles de la montre);		 a: 0..360 (>d); out	D7.W	erreur; mod	D7.WDRARC:	PUSHM.L	D0..D6	SWAP.W	D1		; D1 <-- angle de dpart	SWAP.W	D2		; D2 <-- angle d'arrive	COMP.W	D1,D2		; dpart = arrive ?	JUMP,EQ EXIT$		; oui => EXIT$	CLR.L	D6		; D6 <-- position initialeLOOP$:	PUSHM.L	D3..D5	CALL	CALCPELLI	; D5 <-- nouveau point	LOAD.L	D4,D5		; D4 <-- arrive segment	LOAD.L	D3,D6		; D3 <-- dpart segment	LOAD.L	D6,D5		; D6 <-- position suivante	TEST.L	D3	JUMP',EQ SKIP$	CALL	(A2)SKIP$:	POPM.L	D3..D5	COMP.W	D1,D2	JUMP',HS EXIT$	ADD.W	D1,#6		; D1 <-- angle suivant	COMP.W	D1,D2	JUMP,LS LOOP$	LOAD.W	D1,D2	JUMP	LOOP$EXIT$:	POPM.L	D0..D6	RET;----------\\; CALCPELLI >;==========/; Calcul les coordonnes d'un point situ sur une ellipse.; in	D1.W	angle (0..360), dans le sens des aiguilles de la montre;	D3.L	centre (y;x);	D4.L	rayons (ry;rx); out	D5.L	point (y;x); mod	D5.L, D7.WCALCPELLI:	PUSH.L	D2	CALL	CALCSIN		; D2 <-- 10000*sin(a)	SWAP.W	D4	MUL.WA	D2,D4	SWAP.W	D4	ADD.L	D2,#10000/2	DIV.WA	D2,#10000	SWAP.W	D3	ADD.W	D2,D3	SWAP.W	D3	LOAD.W	D5,D2	SWAP.W	D5	CALL	CALCCOS		; D2 <-- 10000*cos(a)	MUL.WA	D2,D4	ADD.L	D2,#10000/2	DIV.WA	D2,#10000	ADD.W	D2,D3	LOAD.W	D5,D2	POP.L	D2	RET;--------\\; CALCCOS >;========/; Calcul rapidement un cosinus.; in	D1.W	angle (0..360), dans le sens des aiguilles de la montre; out	D2.W	cosinus (-10000..+10000); mod	D2.L, D7.WCALCCOS:	PUSH.L	D1	TEST.W	D1	JUMP',NC 10$	ADD.W	D1,#36010$:	CONV.LA.WA D1	DIV.WU	D1,#360	SWAP.W	D1		; D1 <-- 0..360-1	SUB.W	D1,#90	NEG.W	D1	JUMP',NC 50$	ADD.W	D1,#36050$:	CALL	CALCSIN	POP.L	D1	RET;--------\\; CALCSIN >;========/; Calcul rapidement un sinus.; in	D1.W	angle (0..360), dans le sens des aiguilles de la montre; out	D2.W	sinus (-10000..+10000); mod	D2.L, D7.WCALCSIN:	PUSHM.L	D1,A1	LOAD.L	A1,#R16"TSINUS	TEST.W	D1	JUMP',NC 10$	ADD.W	D1,#36010$:	CONV.LA.WA D1	DIV.WU	D1,#360	SWAP.W	D1		; D1 <-- 0..360-1	COMP.W	D1,#90	JUMP',LS 40$	COMP.W	D1,#180	JUMP',LS 30$	COMP.W	D1,#270	JUMP',LS 20$				; angle 270..360 =>	SUB.W	D1,#360	NEG.W	D1	SL.W	D1,#1	LOAD.W	D2,(A1)+(D1.W)	NEG.W	D2	JUMP'	90$20$:				; angle 180..270 =>	SUB.W	D1,#180	SL.W	D1,#1	LOAD.W	D2,(A1)+(D1.W)	NEG.W	D2	JUMP'	90$30$:				; angle 90..180 =>	SUB.W	D1,#180	NEG.W	D1	SL.W	D1,#1	LOAD.W	D2,(A1)+(D1.W)	JUMP'	90$40$:				; angle 0..90 =>	SL.W	D1,#1	LOAD.W	D2,(A1)+(D1.W);	JUMP'	90$90$:	POPM.L	D1,A1	RETTSINUS:	.W	0,175,349,523,698,872,1045,1219,1392,1564		; 0..9	.W	1736,1908,2079,2250,2419,2588,2756,2924,3090,3256	; 10..19	.W	3420,3584,3746,3907,4067,4226,4384,4540,4795,4848	; 20..29	.W	5000,5150,5299,5446,5592,5736,5878,6018,6157,6293	; 30..39	.W	6428,6561,6691,6820,6947,7071,7193,7314,7431,7547	; 40..49	.W	7660,7771,7880,7986,8090,8192,8290,8387,8480,8572	; 50..59	.W	8660,8746,8829,8910,8988,9063,9135,9205,9272,9336	; 60..69	.W	9397,9455,9511,9563,9613,9659,9703,9744,9781,9816	; 70..79	.W	9848,9877,9903,9925,9945,9962,9976,9986,9994,9998	; 80..89	.W	10000							; 90	.END