	.SBTTL	OPNUMDBOX.ASI;---------\\; DBOXNUM  >;=========/; Demande le numro initial.; in	A4.L	^objet; out	D3.W	dernire touche (F1/F0);	D7.W	rponse; mod	D3.L, D7.WDBOXNUM:	PUSHM.L	D0..D2,D4,D5,A0..A4	LOAD.L	A0,(A5)+OPDDIS	; A0 <-- ^descripteur fentre	LOAD.L	A1,A4		; A1 <-- ^objet	LOAD.L	A2,#R16"TDBOX$	LOAD.W	D7,#DB_MEMPT	PAGE_	DBOX		; mj ^table dbox	LOAD.W	(A5)+ODBP1,(A5)+ONUM	LOAD.L	A3,#(A5)+OTEXT	LOAD.L	A4,#(A5)+ODBP2GET$:	LOAD.B	(A4+),(A3+)	; ODBP2 <-- texte fixe	JUMP,NE GET$	LOAD.L	A2,#R16"TDBOX_NUM	LOAD.L	D4,(A5)+OFAN	; D4 <-- fanions	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.W	D7,#DB_OPEN	PAGE_	DBOX		; ouvre la DBOX	JUMP,NE EXIT$	PUSH.L	D4	LOAD.W	D2,#SETDOT	LOAD.W	D3,(A0)+ODFCY	MUL.WU	D3,#5	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	LIB	?DRSEG		; trait horizontal en haut	LOAD.W	D1,(A0)+ODFCX	MUL.WU	D1,#22+1	LOAD.W	D3,D1	LOAD.W	D4,(A0)+ODFCY	MUL.WU	D4,#4	SWAP.W	D4	LIB	?DRSEG	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	SUB.W	D4,D3	LIB	?DRSEG	LOAD.W	D3,(A0)+ODFCY	MUL.WU	D3,#12	SWAP.W	D3	CLR.L	D4	LOAD.W	D4,(A0)+ODFFDX	LIB	?DRSEG		; trait horizontal en bas	POP.L	D4	CLR.W	D2AFF$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_AFF	PAGE_	DBOX		; affiche le paramtre	INC.W	D2	COMP.W	D2,#2	JUMP,LO AFF$	CLR.W	D2NLINE$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_MEDIT	PAGE_	DBOXLOOP$:	LOAD.W	D7,#MI_SCMO	PAGE_	MISC		; remet la souris	DBOX_	EDIT		; attend une action ...	LOAD.W	D7,#DB_ZEROCR	PAGE_	DBOX		; remplace <CR> par <0>	PUSH.L	A1	LOAD.L	A1,#R16"TKEY_NUM	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	POP.L	A1	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#CLEAR	JUMP',EQ UNDO$	COMP.W	D3,#CR	JUMP',EQ RETURN$	COMP.W	D3,#ENTER	JUMP',EQ ENTER$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,#2	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$ENTER$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	JUMP	LOOP$KEYDBOX$:			; KEYDBOX =>	COMP.W	D3,#KEYDBOX+100	JUMP',HS KLINE$	LOAD.L	D1,#H'FFFFFF00	COMP.B	D3,#8	JUMP',LO KEYDBOX2$	LOAD.L	D1,#H'FFFF00FF;	COMP.B	D3,#16;	JUMP',LO KEYDBOX2$;	LOAD.L	D1,#H'FF00FFFF;	COMP.B	D3,#24;	JUMP',LO KEYDBOX2$;	LOAD.L	D1,#H'00FFFFFFKEYDBOX2$:	AND.L	D4,D1		; D4 <-- teint toute la range	TSET.L	D4:D3		; D4 <-- allume juste le bon	JUMP	LOOP$KLINE$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	COMP.B	D3,#100	JUMP',HS CLINE$	JUMP	LOOP$CLINE$:	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$CLIC$:	LOAD.W	D7,#DB_CLIC	PAGE_	DBOX	JUMP,EQ LOOP$	JUMP	BIP$OK$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	LOAD.W	(A5)+ONUM,(A5)+ODBP1	LOAD.L	A3,#(A5)+OTEXT	LOAD.L	A4,#(A5)+ODBP2PUT$:	LOAD.B	(A3+),(A4+)	; OTEXT <-- texte fixe	JUMP,NE PUT$	LOAD.L	(A5)+OFAN,D4END$:	LOAD.W	D7,#DB_CLOSE	PAGE_	DBOX		; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A0..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	ODBP1,DBTYPNS,-999,+999,1,2^BDBGCLABEL!100,0,4+2	.W	ODBP2,DBTYPA,0,0,0,2^BDBGCLABEL!101,1,21	.W	-1TDBOX_NUM:	.W	10$-TDBOX_NUM	.W	20$-TDBOX_NUM	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Numro de la premire page "	.B	ODBLABEL,100	.B	ODBCLINE,(4+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Texte fixe "	.B	ODBLABEL,101	.B	ODBXLINE,22,LTEXT,0,KEYDBOX/H'100,101,TDBNORM	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCR,ODBCR,ODBCR2	.B	ODBTABX,22	.B	ODBLCIRCLE,BFAN123!2^7!2^6,KEYDBOX/H'100,BFAN123	.ASCIZ	" 1,2,3.."	.B	ODBCR	.B	ODBLCIRCLE,BFANJC!2^7!2^6,KEYDBOX/H'100,BFANJC	.ASCIZ	" centr"	.B	ODBTABX,22	.B	ODBLCIRCLE,BFANRMI!2^7!2^6,KEYDBOX/H'100,BFANRMI	.ASCIZ	" i,ii,iii.."	.B	ODBCR	.B	ODBLCIRCLE,BFANJD!2^7!2^6,KEYDBOX/H'100,BFANJD	.ASCIZ	" appuy  gauche"	.B	ODBTABX,22	.B	ODBLCIRCLE,BFANRMA!2^7!2^6,KEYDBOX/H'100,BFANRMA	.ASCIZ	" I,II,III.."	.B	ODBCR	.B	ODBLCIRCLE,BFANJG!2^7!2^6,KEYDBOX/H'100,BFANJG	.ASCIZ	" appuy  droite"	.B	ODBCR	.B	ODBLCIRCLE,BFANJA!2^7!2^6,KEYDBOX/H'100,BFANJA	.ASCIZ	" droite/gauche selon recto/verso"	.B	ODBCR	.B	ODBLCIRCLE,BFANJAI!2^7!2^6,KEYDBOX/H'100,BFANJAI	.ASCIZ	" gauche/droite selon recto/verso"	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_NUM:	.W	F1,F2,F3,0		DOKF1-TKEY_NUM	.W	F0,F13,F14,F15,0	DOKF0-TKEY_NUM	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_NUM	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_NUM	.W	0;--------\\; DOK...  >;========/DOKMGR:	LOAD.W	D3,#KEYMGR	RETDOKMGP:	LOAD.W	D3,#KEYMGP	RETDOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RET	.END