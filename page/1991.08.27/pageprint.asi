     .B      B'11001100,B'11001100,B'11001100,B'11001100        .B      B'00110011,B'00110011,B'00110011,B'00110011        .B      B'00110011,B'00110011,B'00110011,B'00110011        .B      B'11001100,B'11001100,B'11001100,B'11001100        .B      B'11001100,B'11001100,B'11001100,B'11001100        .B      B'00000000,B'00000000,B'00000000,B'00000000        .B      B'10101010,B'10101010,B'10101010,B'10101010        .B      B'01010101,B'01010101,B'01010101,B'01010101        .B      B'10101010,B'10101010,B'10101010,B'10101010        .B      B'01010101,B'01010101,B'01010101,B'01010101        .B      B'10101010,B'10101010,B'10101010,B'10101010        .B      B'01010101,B'01010101,B'01010101,B'01010101        .B      B'10101010,B'10101010,B'10101010,B'10101010        .B      B'01010101,B'01010101,B'01010101,B'01010101;----------\\; GETPRIDIP >;==========/; Donne les dimensions et les marges de la prsentations.; in	-; out	D4.L	dimensions de la feuille    [obj];	D3.L	marges (suprieure;gauche)  [obj];	D2.L	marges (infrieure;droite)  [obj];	D7.W	erreur; mod	D2.L, D3.L, D4.L, D7.WGETPRIDIP:	PUSHM.L	D1,A4	PUSH.B	(A6)+OIFPRI	SET.B	(A6)+OIFPRI	; impression en cours	CALL	GETRESOL	; D3 <-- facteurs d'chelle (P2;P1)	JUMP,NE EXIT$	LOAD.W	(A6)+OSCAP1X,D3	LOAD.W	(A6)+OSCAP1Y,D3	SWAP.W	D3	LOAD.W	(A6)+OSCAP2X,D3	LOAD.W	(A6)+OSCAP2Y,D3	LOAD.L	A4,#(A6)+OVPSTA	; A4 <-- ^buffer	LOAD.W	D4,(A4)+OPRMGI	ADD.W	D4,(A4)+OPRITL	; hlas ncessaire !	MUL.WU	D4,#8	DIV.WU	D4,(A4)+OPRGLX	SWAP.W	D4		; D4 <-- marge infrieure (pp)	LOAD.W	D1,(A4)+OPRMGD	MUL.WU	D1,#8	DIV.WU	D1,(A4)+OPRGLX	LOAD.W	D4,D1		; D4 <-- marge droite (pp)	CALL	SCALEN		; D4 <-- marges [obj]	LOAD.L	D2,D4	LOAD.W	D4,(A4)+OPRMGS	MUL.WU	D4,#8	DIV.WU	D4,(A4)+OPRGLX	SWAP.W	D4		; D4 <-- marge suprieure (pp)	LOAD.W	D1,(A4)+OPRMGG	MUL.WU	D1,#8	DIV.WU	D1,(A4)+OPRGLX	LOAD.W	D4,D1		; D4 <-- marge gauche (pp)	CALL	SCALEN		; D4 <-- marges [obj]	LOAD.L	D3,D4	LOAD.W	D4,(A4)+OPRHTP	MUL.WU	D4,#8	DIV.WU	D4,(A4)+OPRGLX	SWAP.W	D4		; D4 <-- hauteur (pp)	LOAD.W	D1,(A4)+OPRLGPH	MUL.WU	D1,#8	DIV.WU	D1,(A4)+OPRGLX	LOAD.W	D4,D1		; D4 <-- largeur (pp)	CALL	SCALEN		; D4 <-- dimensions page [obj]	CLR.W	D7		; D7 <-- okEXIT$:	POP.B	(A6)+OIFPRI	POPM.L	D1,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; GETPRIDIM >;==========/; Donne les dimensions et les marges minimales (hard) de la feuille.; in	-; out	D4.L	dimensions de la feuille    [obj];	D3.L	marges (suprieure;gauche)  [obj];	D2.L	marges (infrieure;droite)  [obj];	D7.W	erreur; mod	D2.L, D3.L, D4.L, D7.WGETPRIDIM:	PUSHM.L	D1,A4	PUSH.B	(A6)+OIFPRI	SET.B	(A6)+OIFPRI	; impression en cours	CALL	GETRESOL	; D3 <-- facteurs d'chelle (P2;P1)	JUMP,NE EXIT$	LOAD.W	(A6)+OSCAP1X,D3	LOAD.W	(A6)+OSCAP1Y,D3	SWAP.W	D3	LOAD.W	(A6)+OSCAP2X,D3	LOAD.W	(A6)+OSCAP2Y,D3	LOAD.L	A4,#(A6)+OVPSTA	; A4 <-- ^buffer	LOAD.W	D4,(A4)+OPRMGIH	ADD.W	D4,(A4)+OPRITL	; hlas ncessaire !	MUL.WU	D4,#8	DIV.WU	D4,(A4)+OPRGLX	SWAP.W	D4		; D4 <-- marge infrieure (pp)	LOAD.W	D1,(A4)+OPRMGDH	MUL.WU	D1,#8	DIV.WU	D1,(A4)+OPRGLX	LOAD.W	D4,D1		; D4 <-- marge droite (pp)	CALL	SCALEN		; D4 <-- marges [obj]	LOAD.L	D2,D4	LOAD.W	D4,(A4)+OPRMGSH	MUL.WU	D4,#8	DIV.WU	D4,(A4)+OPRGLX	SWAP.W	D4		; D4 <-- marge suprieure (pp)	LOAD.W	D1,(A4)+OPRMGGH	MUL.WU	D1,#8	DIV.WU	D1,(A4)+OPRGLX	LOAD.W	D4,D1		; D4 <-- marge gauche (pp)	CALL	SCALEN		; D4 <-- marges [obj]	LOAD.L	D3,D4	LOAD.W	D4,(A4)+OPRHTP	MUL.WU	D4,#8	DIV.WU	D4,(A4)+OPRGLX	SWAP.W	D4		; D4 <-- hauteur (pp)	LOAD.W	D1,(A4)+OPRLGPH	MUL.WU	D1,#8	DIV.WU	D1,(A4)+OPRGLX	LOAD.W	D4,D1		; D4 <-- largeur (pp)	CALL	SCALEN		; D4 <-- dimensions page [obj]	CLR.W	D7		; D7 <-- okEXIT$:	POP.B	(A6)+OIFPRI	POPM.L	D1,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; GETRESOL >;=========/; Lit le status de l'imprimante.;	       Xpt * 1600;	Xpp = ------------;	       UMX * GLX;	;	P1 = 1600 /8;	P2 = (UMX * GLX) /8; in	-; out	D3.L	facteurs d'chelle (P2;P1);	D7.W	erreur; mod	D3.L, D7.WGETRESOL:	PUSHM.L	D4,A2..A4	LOAD.L	A2,(A6)+OCAPRINT	LOAD.L	D4,#LGPRI1	; D4 <-- longueur demande	LOAD.L	A4,#(A6)+OVPSTA	; A4 <-- ^buffer	PRINTA_	RSTATUS		; OPRSTA <-- status de l'imprimante	JUMP',NE EXIT$	LOAD.W	D3,(A4)+OPRUMX+2	MUL.WU	D3,(A4)+OPRGLX	; D3 <-- P2	DIV.WU	D3,#8	SWAP.W	D3	LOAD.W	D3,#1600/8	; D3 <-- P1	TEST.W	(A6)+OPRSC1	JUMP',LE EXIT$	TEST.W	(A6)+OPRSC2	JUMP',LE EXIT$	LOAD.W	D4,D3	MUL.WU	D4,(A6)+OPRSC2	DIV.WU	D4,(A6)+OPRSC1	; D3 <-- P1 selon un v. changement d'chelle	LOAD.W	D3,D4EXIT$:	POPM.L	D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; GETPRINT >;=========/; Donne le mode d'impression.; in	-; out	D4.L	mode d'impression (BPRIxxx); mod	D4.L, D7.WGETPRINT:	CLR.L	D4		; D4 <-- mode normal	TEST.B	(A6)+OIFPRI	; impression en cours ?	JUMP',F EXIT$		; non => EXIT$	LOAD.L	D4,(A6)+OPRINT	; D4 <-- mode d'impressionEXIT$:	RET;--------\\; PRINTPS >;========/; Impression PostScript.; in	-; out	D7.W	erreur; mod	D7.WPRINTPS:	PUSHM.L	D1,D3,D4,D6,A2..A4	CALL	WAITMOUSE	; souris: met le sablier	SET.B	(A6)+OIFPPS	; dbut impression PostScript	LOAD.L	A3,#R16"NMPAGEPS	LOAD.W	D3,#PPS_FIRST	LIB_	OPEN	JUMP,NE EXIT9$	LOAD.W	(A6)+OCHPAGEPS,D1	LOAD.L	D4,(A6)+ODESYD	PPS_	OPEN		; A2 <-- "canal"	JUMP,NE EXIT8$	LOAD.L	(A6)+OCAPAGEPS,A2	LOAD.L	D6,(A6)+ODFACH	; D6 <-- canal	CALL	LSTA_FIRST	; A4 <-- ^premier objet	JUMP',NE DEND$DLOOP$:	PUSH.L	A4	LOAD.W	D4,(A4)+OobjIDENT ; D4 <-- identificateur	LOAD.L	A4,(A4)+OobjPDATA ; A4 <-- ^data de l'objet;	LOAD.L	A2,(A6)+OCAPAGEPS	PPS_	INITDEF		; donne un objet de dfinition	POPM.L	A4	JUMP',NE EXIT7$	CALL	LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ DLOOP$DEND$:	CLR.L	(A6)+ODESY1	LOAD.L	(A6)+ODESY2,(A6)+ODESYD	CLR.L	(A6)+OWDOY1	LOAD.L	(A6)+OWDOY2,(A6)+ODESYD	CLR.L	(A6)+OWDIY1	LOAD.L	(A6)+OWDIY2,(A6)+ODESYD	CALL	DESOBJETS	; dessine tous les objetsEXIT7$:	PUSH.W	D7;	LOAD.L	A2,(A6)+OCAPAGEPS	PPS_	CLOSE	POP.W	D7EXIT8$:	PUSH.W	D7	LOAD.W	D1,(A6)+OCHPAGEPS	LIB_	CLOSE	POP.W	D7EXIT9$:	CLR.B	(A6)+OIFPPS	; fin impression PostScript	CALL	NORMMOUSE	; souris: enlve le sablier	POPM.L	D1,D3,D4,D6,A2..A4	TEST.W	D7		; retour EQ/NE	RETNMPAGEPS:	.ASCIZ	"PAGEPS"		.EVEN	.END