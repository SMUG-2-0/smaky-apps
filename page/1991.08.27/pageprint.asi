	.SBTTL	PAGEPRINT.ASINBLPRINT =	192		; imprime par tranches de 200 lignes (*); (*)	Doit tre multiple de 4  cause des trames de QUADCONV !REPDX	=	32		; largeur des represREPDY	=	32		; hauteur des represDOIMPRIME:	CALL	PRINTALL	; imprime tout ...	JUMP,NE _2ERROR	JUMP	_2LOOP;---------\\; PRINTALL >;=========/; Imprime toute la page.; in	-; out	D7.W	erreur; mod	D7.WPRINTALL:	PUSHM.L	D1..D5,A2..A5	PUSH.W	(A6)+OPAGE	PUSH.L	(A6)+OVUE	PUSH.L	(A6)+OGRID	PUSH.L	(A6)+OCALCA	PUSH.W	(A6)+OIDCAL+OIDHTV	PUSH.L	(A6)+OWDIY1	PUSH.L	(A6)+OWDIY2	PUSH.L	(A6)+OWDOY1	PUSH.L	(A6)+OWDOY2	PUSH.L	(A6)+ODESY1	PUSH.L	(A6)+ODESY2	SET.B	(A6)+OIFPRI	; impression en cours	LOAD.W	D7,#ERPAILOP	TEST.L	(A6)+OCAPRINT	JUMP,EQ EXIT$	CALL	DBOXPRINT	; demande comment imprimer ...	JUMP,NE EXIT$	COMP.W	D3,#F1	JUMP,NE EXIT$	LOAD.W	(A6)+OCALCA+2,(A6)+OPRINT+2	NOT.W	(A6)+OCALCA+2	LOAD.L	(A6)+OVUE,#-1	LOAD.L	(A6)+OGRID,#2^BGRIDPAN!2^BGRIDMU4!2^BGRIDGRN	TEST.B	(A6)+OPRINT+0:#BPRIPS-24 ; impression PostScript ?	JUMP,BS PS$		; oui => PS$	CLR.L	D3		; D3 <-- mode	TSET.L	D3:#BPRNOFILE	; D3 <-- pas de fichier en sortie	TSET.L	D3:#BPRNOINTERV	; D3 <-- pas de page de ..  ..	TSET.L	D3:#BPRCHOIX	; D3 <-- case (CHOIX) active	LOAD.L	A3,#(A6)+OBUNAME ; A3 <-- ^nom du fichier	LOAD.L	A4,#(A6)+OBUPRES ; A4 <-- ^nom de la prsentation	CLR.B	(A4)	LOAD.L	A5,#R16"NAME$	; A5 <-- ^nom du logiciel	CLR.L	D2		; D2 <-- longueur du document (!)	LOAD.L	A2,(A6)+OCAPRINT	CALL	DBOXOPEN1	PRINTA_	OPPRINT		; ouvre l'impression ...	PUSH.W	D7	CALL	DBOXCLOSE1	POP.W	D7	JUMP,NE EXIT$	CALL	GETPRIDIM	; D4/D3/D2 <-- dimensions/marges papier	JUMP,NE CLOSE$	LOAD.L	D1,D3	COMP.W	(A6)+OVPSTA+OPRZ,#1	JUMP',EQ OKZOOM$	CALL	DBOXZPRINT	; avertissement ...	JUMP,NE CLOSE$	COMP.W	D3,#F1	JUMP,NE CLOSE$OKZOOM$:	LOAD.L	D3,D1	LOAD.W	D5,(A6)+OPRFROM	DEC.W	D5		; D5 <-- premire page  imprimerPAGE$:	CALL	PRINTONE	; imprime une page	JUMP',NE CLOSE$	INC.W	D5		; D5 <-- page suivante	COMP.W	D5,(A6)+OPRTO	JUMP,LO PAGE$CLOSE$:	PUSH.W	D7	LOAD.L	A2,(A6)+OCAPRINT	PRINTA_	CLPRINT		; ferme l'imprimante	POP.W	D7	JUMP'	EXIT$PS$:	CALL	PRINTPS		; impression PostScriptEXIT$:	CLR.B	(A6)+OIFPRI	; fin de l'impression	POP.L	(A6)+ODESY2	POP.L	(A6)+ODESY1	POP.L	(A6)+OWDOY2	POP.L	(A6)+OWDOY1	POP.L	(A6)+OWDIY2	POP.L	(A6)+OWDIY1	POP.W	(A6)+OIDCAL+OIDHTV	POP.L	(A6)+OCALCA	POP.L	(A6)+OGRID	POP.L	(A6)+OVUE	POP.W	(A6)+OPAGE	POPM.L	D1..D5,A2..A5	TEST.W	D7		; retour EQ/NE	RETNAME$:	.ASCIZ	"PAGE"	.EVEN;---------\\; PRINTONE >;---------/; Imprime une page constitue de plusieurs calques.; Une page peut correspondre  plusieurs pages physiques sur l'imprimante !; in	D5.W	page  imprimer (0..n);	D4.L	dimensions de la feuille    [obj];	D3.L	marges (suprieure;gauche)  [obj];	D2.L	marges (infrieure;droite)  [obj]; out	D7.W	erreur; mod	D7.WPRINTONE:	PUSHM.L	D1..D5	LOAD.W	(A6)+OPAGE,D5	PUSH.L	D4	CALL	_2GROUPNBCALQUE	; D4 <-- nb total de calques	LOAD.W	(A6)+OIDCAL+OIDHTV,D4	POP.L	D4	CALL	PRINTBOA	; imprime les "boa"	JUMP,NE EXIT$	LOAD.L	D5,(A6)+ODESYD	; D5 <-- dimensions dessin	COMP.W	D4,D5		; dessin plus large que le papier ?	JUMP',HS RNDX$		; non => RNDX$	LOAD.W	D1,D5	SUB.W	D1,#10*FACMMPT	; D1 <-- largeur dessin -1mm	COMP.W	D4,D1	JUMP',LO RNDX$	LOAD.W	D5,D4		; D5 <-- largeur papierRNDX$:	TEST.B	(A6)+OPRINT+0:#BPRIQR-24 ; repres ?	JUMP',BC NOLX$	LOAD.W	D1,D4	SUB.W	D1,D3	SUB.W	D1,D2		; D1 <-- largeur du papier utilisable	COMP.W	D5,D1	JUMP',HS NOLX$	LOAD.W	D1,D4	SUB.W	D1,D3	SUB.W	D1,D2		; D1 <-- largeur du papier utilisable	SUB.W	D1,D5		; D1 <-- largeur du papier en trop	SR.W	D1,#1	LOAD.W	D3,D1	NEG.W	D3	ADD.W	D5,D1	LOAD.W	D4,D5	JUMP'	DIMX$NOLX$:	SUB.W	D4,D2	SUB.W	D5,D2DIMX$:	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	COMP.W	D4,D5		; dessin plus haut que le papier ?	JUMP',HS RNDY$		; non => RNDY$	LOAD.W	D1,D5	SUB.W	D1,#10*FACMMPT	; D1 <-- hauteur dessin -1mm	COMP.W	D4,D1	JUMP',LO RNDY$	LOAD.W	D5,D4		; D5 <-- hauteur papierRNDY$:	TEST.B	(A6)+OPRINT+0:#BPRIQR-24 ; repres ?	JUMP',BC NOLY$	LOAD.W	D1,D4	SUB.W	D1,D3	SUB.W	D1,D2		; D1 <-- hauteur du papier utilisable	PUSH.L	D4	LOAD.W	D4,#REPDY	CALL	SCALEN		; D4 <-- hauteur d'un repre	SUB.W	D1,D4	SUB.W	D1,D4		; D1 <-- hauteur moins les deux repres	POP.L	D4	COMP.W	D5,D1	JUMP',HS NOLY$	LOAD.W	D1,D4	SUB.W	D1,D3	SUB.W	D1,D2		; D1 <-- hauteur du papier utilisable	SUB.W	D1,D5		; D1 <-- hauteur du papier en trop	SR.W	D1,#1	LOAD.W	D3,D1	NEG.W	D3	ADD.W	D5,D1	LOAD.W	D4,D5	JUMP'	DIMY$NOLY$:	SUB.W	D4,D2	SUB.W	D5,D2DIMY$:LOOPY$:	COMP.W	D4,D5	JUMP',LS OKY$	LOAD.W	D4,D5OKY$:	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	PUSHM.L	D3,D4LOOPX$:	COMP.W	D4,D5	JUMP',LS OKX$	LOAD.W	D4,D5OKX$:	TEST.B	(A6)+OPRINT+0:#BPRIQB-24	JUMP',BC NOQB$	CLR.W	D2		; D2 <-- noir	CALL	PRINTPAGE	; imprime une page	JUMP,NE POP$NOQB$:	TEST.B	(A6)+OPRINT+0:#BPRIQC-24	JUMP',BC NOQC$	LOAD.W	D2,#1		; D2 <-- cyan	CALL	PRINTPAGE	; imprime une page	JUMP,NE POP$NOQC$:	TEST.B	(A6)+OPRINT+0:#BPRIQM-24	JUMP',BC NOQM$	LOAD.W	D2,#2		; D2 <-- magenta	CALL	PRINTPAGE	; imprime une page	JUMP,NE POP$NOQM$:	TEST.B	(A6)+OPRINT+0:#BPRIQY-24	JUMP',BC NOQY$	LOAD.W	D2,#3		; D2 <-- jaune	CALL	PRINTPAGE	; imprime une page	JUMP,NE POP$NOQY$:	LOAD.L	D2,(A6)+OPRINT	AND.L	D2,#2^BPRIQC!2^BPRIQM!2^BPRIQY!2^BPRIQB	JUMP',NE QUAD$	LOAD.W	D2,#-1		; D2 <-- normal	CALL	PRINTPAGE	; imprime une page	JUMP',NE POP$QUAD$:	LOAD.W	D2,D4	SUB.W	D2,D3		; D2 <-- largeur imprime	ADD.W	D3,D2	ADD.W	D4,D2	COMP.W	D3,D5	JUMP,LO LOOPX$	POPM.L	D3,D4	SWAP.W	D3	SWAP.W	D4	SWAP.W	D5	LOAD.W	D2,D4	SUB.W	D2,D3		; D2 <-- hauteur imprime	ADD.W	D3,D2	ADD.W	D4,D2	COMP.W	D3,D5	JUMP,LO LOOPY$	JUMP'	EXIT$POP$:	POPM.L	D3,D4EXIT$:	POPM.L	D1..D5	TEST.W	D7		; retour EQ/NE	RET;---------\\; PRINTBOA >;---------/; Imprime les commandes "boa" pour les marges.; in	-; out	D7.W	erreur; mod	D7.WPRINTBOA:	PUSHM.L	D4,A2..A4	LOAD.L	A4,#(A6)+OIOTM	; A4 <-- ^buffer	LOAD.L	A3,#R16"TXMG$	CALL	PUTTX$	CLR.L	D4	LOAD.W	D4,(A6)+OVPSTA+OPRMGGH	CALL	PUTANUM	LOAD.L	A3,#R16"TXLG$	CALL	PUTTX$	CLR.L	D4	LOAD.W	D4,(A6)+OVPSTA+OPRLGPH	SUB.W	D4,(A6)+OVPSTA+OPRMGGH	SUB.W	D4,(A6)+OVPSTA+OPRMGDH	CALL	PUTANUM	LOAD.L	A3,#R16"TXMS$	CALL	PUTTX$	CLR.L	D4	LOAD.W	D4,(A6)+OVPSTA+OPRMGSH	CALL	PUTANUM	LOAD.L	A3,#R16"TXMI$	CALL	PUTTX$	CLR.L	D4	LOAD.W	D4,(A6)+OVPSTA+OPRMGIH	CALL	PUTANUM	LOAD.L	A3,#R16"TXEND$	CALL	PUTTX$	LOAD.L	D4,A4	LOAD.L	A4,#(A6)+OIOTM	; A4 <-- ^buffer	SUB.L	D4,A4		; D4 <-- lg	LOAD.L	A2,(A6)+OCAPRINT	PRINTA_	WRPRINT		; crit les commandes boa	POPM.L	D4,A2..A4	TEST.W	D7		; retour EQ/NE	RETPUTTX$:	LOAD.B	(A4+),(A3+)	JUMP,NE PUTTX$	DEC.L	A4	RETTXMG$:	.ASCIZ	"<BOA>marge "TXLG$:	.ASCIZ	"p;<BOA>large "TXMS$:	.ASCIZ	"p;<BOA>marsup "TXMI$:	.ASCIZ	"p;<BOA>marinf "TXEND$:	.ASCIZ	"p;"	.EVEN;---------\\; PRINTEOP >;---------/; Imprime une fin de page.; in	-; out	D7.W	erreur; mod	D7.WPRINTEOP:	PUSHM.L	D4,A2,A4	LOAD.L	A4,#(A6)+OIOTM	; A4 <-- ^buffer	LOAD.B	(A4),#EOP	LOAD.L	D4,#1		; D4 <-- lg	LOAD.L	A2,(A6)+OCAPRINT	PRINTA_	WRPRINT		; crit une fin de page	POPM.L	D4,A2,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; PRINTPAGE >;----------/; Imprime une page en plusieurs parties.; in	D2.W	couleur demande (-1,0..3);	D3.L	coin sup/gauche;	D4.L	coin inf/droite; out	D7.W	erreur; mod	D7.WPRINTPAGE:	PUSHM.L	D3..D6	PUSH.L	D4	CALL	SCALEP	LOAD.L	(A6)+OPRIP2,D4	LOAD.L	D4,D3	CALL	SCALEP	LOAD.L	(A6)+OPRIP1,D4	POP.L	D4	LOAD.L	D6,D4	SWAP.W	D6		; D6 <-- jusqu'o aller	EX.L	D5,D4	LOAD.W	D4,#NBLPRINT	CALL	SCALEN		; D5 <-- hauteur d'une tranche	EX.L	D4,D5LOOP$:	SWAP.W	D3	SWAP.W	D4	LOAD.W	D4,D3	ADD.W	D4,D5		; D4 <-- bas de la tranche	COMP.W	D4,D6		; tranche trop haute ?	JUMP',LT TRUNC$		; non => TRUNC$	LOAD.W	D4,D6		; D4 <-- position maximaleTRUNC$:	SWAP.W	D4	SWAP.W	D3	CALL	PRINTPART	; imprime une tranche	JUMP',NE EXIT$	SWAP.W	D3	SWAP.W	D4	LOAD.W	D3,D4		; D3 <-- haut de la tranche suivante	COMP.W	D3,D6		; est-on arriv tout en bas ?	JUMP',GE EOP$		; oui => EOP$	SWAP.W	D4	SWAP.W	D3	JUMP	LOOP$EOP$:	CALL	PRINTEOP	; imprime une fin de pageEXIT$:	PUSH.W	D7	PUSH.L	(A6)+OROOT	CLR.L	(A6)+OROOT	CALL	_2OBJGIVMEM	; libre toute la mmoire possible	POP.L	(A6)+OROOT	POP.W	D7	POPM.L	D3..D6	TEST.W	D7		; retour EQ/NE	RET;----------\\; PRINTPART >;----------/; Imprime une partie de page.; in	D2.W	couleur demande (-1,0..3);	D3.L	coin sup/gauche;	D4.L	coin inf/droite; out	D7.W	erreur; mod	D7.WPRINTPART:	PUSHM.L	D0..D6,A0..A5	LOAD.L	A1,#0		; A1 <-- pas encore de buffer	LOAD.L	A5,A1		; A5 <-- pas encore de buffer	LOAD.L	A0,(A6)+OPDDIS	; A0 <-- ^descripteur de la fentre	LOAD.L	(A6)+ODESY1,D3	LOAD.L	(A6)+ODESY2,D4	EX.L	D4,D3	CALL	SCALEP	EX.L	D3,D4	CALL	SCALEP	LOAD.L	(A6)+OPRIT1,D3	LOAD.L	(A6)+OPRIT2,D4	CLR.W	D0	LOAD.B	D0,(A0)+ODFCNP	; D0 <-- nb de bits/pixel	COMP.W	D0,#1		; cran couleur ?	JUMP',EQ COUL$		; non => COUL$	TEST.W	D2		; quadrichromie ?	JUMP',NC COUL$		; oui => COUL$	LOAD.W	D2,#4		; D2 <-- mode "RGB"COUL$:	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	D6,D4		; D6 <-- dimensions (dy;dx)	ADD.W	D6,#16-1	SR.W	D6,#4	SL.W	D6,#4		; D6 <-- largeur modulo 16	LOAD.W	D5,D6	SR.W	D5,#3		; D5 <-- largeur en bytes	LOAD.L	D4,D6	SWAP.W	D4	MUL.WU	D4,D5		; D4 <-- taille ncesssaire	ADD.L	D4,#LGHIMA+IMLBUF	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^buffer d'impression	JUMP,NE EXIT$	GESMEM	?CLEARMEM	LOAD.L	A1,A4	TEST.W	D2		; quadrichromie ?	JUMP',NS NOQUAD$	; non => NOQUAD$	LOAD.L	D4,D6	SWAP.W	D4	MUL.WU	D4,D0	MUL.WU	D4,D5		; D4 <-- taille ncesssaire;	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^buffer pour dessiner en couleur	JUMP,NE EXIT$	GESMEM	?CLEARMEM	LOAD.L	A5,A4NOQUAD$:	PUSH.L	(A6)+OPRINT	PUSH.L	(A0)+ODFABS	PUSH.L	(A0)+ODFY	PUSH.L	(A0)+ODFDY	PUSH.L	(A0)+ODFFY	PUSH.L	(A0)+ODFFDY	PUSH.L	(A0)+ODFWBY	PUSH.L	(A0)+ODFWEY	PUSH.W	(A0)+ODFIIX	PUSH.W	(A0)+ODFIIY	PUSH.W	(A0)+ODFCNB	PUSH.B	(A0)+ODFCNP	PUSH.B	(A0)+ODFCMD	LOAD.W	D3,#BPRIQB	TEST.W	D2	JUMP',EQ CMY$	LOAD.W	D3,#BPRIQC	COMP.W	D2,#1	JUMP',EQ CMY$	LOAD.W	D3,#BPRIQM	COMP.W	D2,#2	JUMP',EQ CMY$	LOAD.W	D3,#BPRIQY	COMP.W	D2,#3	JUMP',NE NOCMY$CMY$:	LOAD.L	D4,(A6)+OPRINT	AND.L	D4,#-1-(2^BPRIQC!2^BPRIQM!2^BPRIQY!2^BPRIQB)	TSET.L	D4:D3	LOAD.L	(A6)+OPRINT,D4NOCMY$:	LOAD.L	A4,#(A1)+LGHIMA+IMLBUF	TEST.W	D2		; quadrichromie ?	JUMP',NS ABS$		; non => ABS$	LOAD.L	A4,A5ABS$:	LOAD.L	(A0)+ODFABS,A4	CLR.L	(A6)+OWDIY1	LOAD.L	(A6)+OWDIY2,D6	CLR.L	(A6)+OWDOY1	LOAD.L	(A6)+OWDOY2,D6	CLR.L	(A0)+ODFY	LOAD.L	(A0)+ODFDY,D6	CLR.L	(A0)+ODFFY	LOAD.L	(A0)+ODFFDY,D6	CLR.L	(A0)+ODFWBY	LOAD.L	(A0)+ODFWEY,D6	LOAD.W	(A0)+ODFIIX,#1	LOAD.W	(A0)+ODFIIY,D5	LOAD.W	(A0)+ODFCNB,#2	; ODFCNB <-- 2 couleurs (noir et blanc)	LOAD.B	(A0)+ODFCNP,#1	; ODFCNP <-- 1 bit/pixel	CLR.B	(A0)+ODFCMD	; ODFCMD <-- mode noir/blanc	TEST.W	D2		; quadrichromie ?	JUMP',NS DRAW$		; non => DRAW$;	LOAD.W	(A0)+ODFIIX,#1	LOAD.W	D4,D5	MUL.WU	D4,D0	LOAD.W	(A0)+ODFIIY,D4	LOAD.W	D4,D0	MUL.WU	D4,D4	LOAD.W	(A0)+ODFCNB,D4	; ODFCNB <-- n^2 couleurs	LOAD.B	(A0)+ODFCNP,D0	; ODFCNP <-- n bits/pixel	LOAD.B	(A0)+ODFCMD,#2	; ODFCMD <-- mode couleurDRAW$:	CALL	DESOBJETS	; dessine tous les objets	TEST.W	D2		; quadrichromie ?	JUMP',NS PRINT$		; non => PRINT$	PUSHM.L	D5,D6,A5	LOAD.L	D4,D6		; D4 <-- dimensions	MUL.WU	D5,D0		; D5 <-- Iy source	LOAD.W	D6,D0		; D6 <-- nb de bits/pixel	LOAD.L	A4,A5	LOAD.L	A5,#(A1)+LGHIMA+IMLBUF	CALL	QUADCONV	; conversion en une couleur de base	POPM.L	D5,D6,A5	LOAD.L	A4,#(A1)+LGHIMA+IMLBUF	LOAD.L	(A0)+ODFABS,A4	LOAD.W	(A0)+ODFIIY,D5	LOAD.W	(A0)+ODFCNB,#2	; ODFCNB <-- 2 couleurs (noir et blanc)	LOAD.B	(A0)+ODFCNP,#1	; ODFCNP <-- 1 bit/pixel	CLR.B	(A0)+ODFCMD	; ODFCMD <-- mode noir/blanc	TEST.B	(A6)+OPRINT+0:#BPRIQR-24	JUMP',BC PRINT$	CALL	PRINTREPS	; dessine les represPRINT$:	TEST.B	(A6)+OPRINT+0:#BPRIMI-24	JUMP',BC NOMIR$	CALL	QUADMIROIR	; miroir rapide ...NOMIR$:	POP.B	(A0)+ODFCMD	POP.B	(A0)+ODFCNP	POP.W	(A0)+ODFCNB	POP.W	(A0)+ODFIIY	POP.W	(A0)+ODFIIX	POP.L	(A0)+ODFWEY	POP.L	(A0)+ODFWBY	POP.L	(A0)+ODFFDY	POP.L	(A0)+ODFFY	POP.L	(A0)+ODFDY	POP.L	(A0)+ODFY	POP.L	(A0)+ODFABS	POP.L	(A6)+OPRINT	LOAD.B	(A1)+OIMTYP,#H'81;	LOAD.B	(A1)+OIMCOD,#H'00	LOAD.B	(A1)+OIMBIP,#H'01	LOAD.B	(A1)+OIMDIR,#H'02	LOAD.W	(A1)+OIMDLX,D6	SWAP.W	D6	LOAD.W	(A1)+OIMDLY,D6	MUL.WU	D6,D5	LOAD.L	(A1)+OIMNBB,D6	LOAD.L	A4,#(A1)+LGHIMA	LOAD.L	A3,#(A1)+LGHIMA+IMLBUF	LOAD.L	A2,A1		; A2 <-- ^en-tte	GRA_	CODEIMA		; code la partie d'image	JUMP',NE CODE$	LOAD.L	A3,A4		; A3 <-- ^image codeCODE$:	LOAD.L	A4,A1		; A4 <-- ^en-tte	LOAD.L	D4,#LGHIMA	LOAD.L	A2,(A6)+OCAPRINT	PRINTA_	WRPRINT		; crit l'en-tte	JUMP',NE EXIT$	LOAD.L	A4,A3		; A4 <-- ^image code ou non	LOAD.L	D4,(A1)+OIMNBB;	LOAD.L	A2,(A6)+OCAPRINT	PRINTA_	WRPRINT		; crit une trancheEXIT$:	COMP.L	A1,#0	JUMP',EQ GIVA1$	PUSH.W	D7	LOAD.L	A4,A1	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le buffer d'impression	POP.W	D7GIVA1$:	COMP.L	A5,#0	JUMP',EQ GIVA5$	PUSH.W	D7	LOAD.L	A4,A5	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le buffer d'impression	POP.W	D7GIVA5$:	POPM.L	D0..D6,A0..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; PRINTREPS >;==========/; Dessine les repres dans le bitmap noir/blanc.; in	D2.W	couleur demande (-1,0..4); out	-; mod	D7.WPRINTREPS:	PUSHM.L	D2..D4	LOAD.L	D4,(A6)+OPRIP1	CALL	PRINTREP	; dessine un repre (sup/gauche)	PUSH.W	D2	ADD.W	D4,#REPDX+20	LOAD.W	D2,#100		; D2 <-- repre des carrs	CALL	PRINTREP	; dessine un repre	ADD.W	D4,#REPDX+10	LOAD.W	D2,#101		; D2 <-- repre des carrs	CALL	PRINTREP	; dessine un repre	ADD.W	D4,#REPDX+10	LOAD.W	D2,#102		; D2 <-- repre des trames	CALL	PRINTREP	; dessine un repre	POP.W	D2	ADD.W	D4,#REPDX+20	CALL	PRINTREPC	; dessine les repres des couleurs	LOAD.W	D4,(A6)+OPRIP1+0	SWAP.W	D4	LOAD.W	D4,(A6)+OPRIP2+2	SUB.W	D4,#REPDX	CALL	PRINTREP	; dessine un repre (sup/droite)	LOAD.W	D4,(A6)+OPRIP2+0	SUB.W	D4,#REPDY	SWAP.W	D4	LOAD.W	D4,(A6)+OPRIP1+2	CALL	PRINTREP	; dessine un repre (inf/gauche)	PUSH.W	D2	ADD.W	D4,#REPDX+20	LOAD.W	D2,#100		; D2 <-- repre des carrs	CALL	PRINTREP	; dessine un repre	ADD.W	D4,#REPDX+10	LOAD.W	D2,#101		; D2 <-- repre des carrs	CALL	PRINTREP	; dessine un repre	ADD.W	D4,#REPDX+10	LOAD.W	D2,#102		; D2 <-- repre des trames	CALL	PRINTREP	; dessine un repre	POP.W	D2;;?	ADD.W	D4,#REPDX+20;;?	CALL	PRINTREPC	; dessine les repres des couleurs	LOAD.W	D4,(A6)+OPRIP2+0	SUB.W	D4,#REPDY	SWAP.W	D4	LOAD.W	D4,(A6)+OPRIP2+2	SUB.W	D4,#REPDX	CALL	PRINTREP	; dessine un repre (inf/droite)	POPM.L	D2..D4	RET;----------\\; PRINTREPC >;----------/; Dessine les repres des couleurs.; in	D2.W	couleur demande (-1,0..4);	D4.L	coin sup/gauche du repre; out	-; mod	D7.WPRINTREPC:	PUSHM.L	D0..D4,A3	SUB.W	D4,(A6)+OPRIT1+2	SWAP.W	D4	SUB.W	D4,(A6)+OPRIT1+0	JUMP,NS EXIT$	LOAD.W	D3,D4	ADD.W	D3,#REPDY	COMP.W	D3,(A0)+ODFFDY	JUMP,HS EXIT$	SWAP.W	D4	LOAD.B	D1,#B'10000000	; D1 <-- masque noir    (N-------)	TEST.W	D2	JUMP',EQ MAP$	LOAD.B	D1,#B'01110001	; D1 <-- masque cyan    (-NCB---G)	COMP.W	D2,#1	JUMP',EQ MAP$	LOAD.B	D1,#B'01011100	; D1 <-- masque magenta (-N-BMR--)	COMP.W	D2,#2	JUMP',EQ MAP$	LOAD.B	D1,#B'01000111	; D1 <-- masque jaune   (-N---RYG)	COMP.W	D2,#3	JUMP,NE EXIT$MAP$:	LOAD.B	D3,#AFINV	LIB	?AFCAR		; passe en vido inverse	LOAD.L	D3,D4		; D3 <-- origine (y;x)	LOAD.L	D4,#-1	CALL	_2DRMDEF	; trame 100%	LOAD.L	A3,#R16"TEXT$	LOAD.W	D0,#8-1LOOP$:	RL.B	D1,#1	JUMP',CC NEXT$	LOAD.L	D4,#H'10000*REPDY+REPDX	LOAD.W	D2,#LOADDOT	LIB	?DRTRAME	; dessine un carr plein	PUSH.L	D3	ADD.W	D3,#REPDX/2	LOAD.W	D4,(A0)+ODFC2X	SR.W	D4,#1	SUB.W	D3,D4	SWAP.W	D3	ADD.W	D3,#REPDY/2	LOAD.W	D4,(A0)+ODFC1Y	SR.W	D4,#1	ADD.W	D3,D4	DEC.W	D3	SWAP.W	D3	LIB	?SETCURS	LOAD.B	D3,(A3)	LIB	?AFCAR		; dessine un caractre	POP.L	D3NEXT$:	ADD.W	D3,#REPDX+5	; D3 <-- position suivante	INC.L	A3		; A3 <-- ^caractre suivant	DECJ.W,NMO D0,LOOP$	LOAD.B	D3,#AFDIR	LIB	?AFCAR		; passe en vido directeEXIT$:	POPM.L	D0..D4,A3	RETTEXT$:	.ASCII	"**CBMRYG"	; black,black,cyan,blue,magenta,red,yellow,green	.EVEN;---------\\; PRINTREP >;---------/; Dessine un repre dans le bitmap noir/blanc.; in	D2.W	couleur demande (-1,0..4,100..102);	D4.L	coin sup/gauche du repre; out	-; mod	D7.WPRINTREP:	PUSHM.L	D1..D5,A1..A4	LOAD.L	A3,#R16"TMREPB$	TEST.W	D2	JUMP',EQ REP$	LOAD.L	A3,#R16"TMREPC$	COMP.W	D2,#1	JUMP',EQ REP$	LOAD.L	A3,#R16"TMREPM$	COMP.W	D2,#2	JUMP',EQ REP$	LOAD.L	A3,#R16"TMREPY$	COMP.W	D2,#3	JUMP',EQ REP$	LOAD.L	A3,#R16"TMREPS1$	COMP.W	D2,#100	JUMP',EQ REP$	LOAD.L	A3,#R16"TMREPS2$	COMP.W	D2,#101	JUMP',EQ REP$	LOAD.L	A3,#R16"TMREPT$	COMP.W	D2,#102	JUMP',NE EXIT$REP$:	CLR.L	D3	LOAD.W	D5,#REPDX/8	LOAD.L	A4,#0		; A4 <-- destination (dans le bitmap)	SUB.W	D4,(A6)+OPRIT1+2	SWAP.W	D4	SUB.W	D4,(A6)+OPRIT1+0	SWAP.W	D4	LOAD.L	D2,#H'10000*REPDY+REPDX	LOAD.W	D1,#LOADDOT	LOAD.L	A2,A0		; A2 <-- ^descripteur bitmap	LOAD.L	A1,(A6)+ORASTER	CALL	(A1)		; GRA_RASTER, met le repreEXIT$:	POPM.L	D1..D5,A1..A4	RETTMREPB$:        .B      B'11111100,B'00000001,B'00000000,B'00000000        .B      B'11111110,B'00000001,B'00000000,B'00000000        .B      B'11000110,B'00000001,B'00000000,B'00000000        .B      B'11000110,B'00000001,B'00000000,B'00000000        .B      B'11111100,B'00000001,B'00000000,B'00000000        .B      B'11111110,B'00000001,B'00000000,B'00000000        .B      B'11000011,B'00000001,B'00000000,B'00000000        .B      B'11000011,B'00000001,B'00000000,B'00000000        .B      B'11111111,B'00000001,B'00000000,B'00000000        .B      B'11111110,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'11111111,B'11111111,B'11111111,B'11111111        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000000,B'00000000,B'00000000TMREPC$:        .B      B'00000000,B'00000001,B'00000000,B'00111110        .B      B'00000000,B'00000001,B'00000000,B'01111111        .B      B'00000000,B'00000001,B'00000000,B'11100011        .B      B'00000000,B'00000001,B'00000000,B'11000000        .B      B'00000000,B'00000001,B'00000000,B'11000000        .B      B'00000000,B'00000001,B'00000000,B'11000000        .B      B'00000000,B'00000001,B'00000000,B'11000000        .B      B'00000000,B'00000001,B'00000000,B'11100011        .B      B'00000000,B'00000001,B'00000000,B'01111111        .B      B'00000000,B'00000001,B'00000000,B'00111110        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'11111111,B'11111111,B'11111111,B'11111111        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000000,B'00000000,B'00000000TMREPM$:        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'00000000,B'00000001,B'00000000,B'00000000        .B      B'0000000