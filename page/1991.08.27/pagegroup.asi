	.SBTTL	PAGEGROUP.ASI;-------------\\; GROUPNEWPAGE >;=============/; Cre une nouvelle page dans le document.; in	D4.W	page frre cadet (0..n); out	D7.W	erreur; mod	D7.WGROUPNEWPAGE:	PUSHM.L	D3,D4,D6,A3,A4	LOAD.L	D6,(A6)+OOBACH	; D6 <-- canal de l'arbre des objets	LOAD.W	D3,D4		; D3 <-- page cherche	LOAD.W	D4,#-1		; D4 <-- pas de calque	CALL	LSTA_BEGIN	; A4 <-- ^page frre cadet	JUMP',EQ INSERT$	LOAD.L	A4,#0		; A4 <-- pas de frre connuINSERT$:	LOAD.L	A3,#0		; A3 <-- pas de pre connu	LOAD.W	D4,#LIP		; D4 <-- data pour l'instance de la page	CALL	LSTA_INSERT	; cre une nouvelle page	JUMP',NE EXIT$	LOAD.W	(A4)+OobjIDENT,#IDENTPAGE	LOAD.L	A3,A4		; A3 <-- ^pre (page)	LOAD.L	A4,#0		; A4 <-- pas de frre	CLR.W	D4		; D4 <-- pas de data	CALL	LSTA_INSERT	; cre un nouveau calqueEXIT$:	POPM.L	D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;------------\\; GROUPNBPAGE >;============/; Donne le nombre total de pages.; in	-; out	D4.W	nombre de pages (1..n); mod	D4.L, D7.WGROUPNBPAGE:	PUSHM.L	D3,D6,A4	CLR.W	D4	LOAD.L	D6,(A6)+OOBACH	; D6 <-- canal de l'arbre des objets	LOAD.W	D3,#-1		; D3 <-- toutes les pages	CALL	LSTA_FIRST	; A4 <-- ^premire page	JUMP',NE EXIT$LOOP$:	INC.W	D4		; D4 <-- une page de plus	CALL	LSTA_NEXTF	; A4 <-- ^page suivante	JUMP,EQ LOOP$EXIT$:	POPM.L	D3,D6,A4	RET;---------------\\; GROUPNEWCALQUE >;===============/; Cre un nouveau calque dans la page courante.; in	D4.W	calque frre cadet (0..n); out	D7.W	erreur; mod	D7.WGROUPNEWCALQUE:	PUSHM.L	D3,D4,D6,A3,A4	LOAD.L	A3,#0		; A3 <-- pas de pre connu	LOAD.L	D6,(A6)+OOBACH	; D6 <-- canal de l'arbre des objets	LOAD.W	D3,(A6)+OPAGE	; D3 <-- page cherche;	LOAD.W	D4,D4		; D4 <-- calque cherch	CALL	LSTA_BEGIN	; A4 <-- ^calque frre cadet	JUMP',EQ INSERT$	LOAD.W	D4,#-1		; D4 <-- pas de calque cherch	CALL	LSTA_BEGIN	; A4 <-- ^page pre	JUMP',NE EXIT$	LOAD.L	A3,A4		; A3 <-- ^page pre	LOAD.L	A4,#0		; A4 <-- pas de frre connuINSERT$:	CLR.W	D4		; D4 <-- pas de data	CALL	LSTA_INSERT	; cre un nouveau calqueEXIT$:	POPM.L	D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------------\\; GROUPNBCALQUE >;==============/; Donne le nombre total de calques dans la page courante.; in	-; out	D4.W	nombre de calques (1..n); mod	D4.L, D7.WGROUPNBCALQUE:	PUSHM.L	D2,D3,D6,A4	CLR.W	D2	LOAD.L	D6,(A6)+OOBACH	; D6 <-- canal de l'arbre des objets	LOAD.W	D3,(A6)+OPAGE	; D3 <-- page courante	LOAD.W	D4,#-1		; D4 <-- tous les calques	CALL	LSTA_FIRST	; A4 <-- ^premier calque	JUMP',NE EXIT$LOOP$:	INC.W	D2		; D2 <-- un calque de plus	CALL	LSTA_NEXTF	; A4 <-- ^calque suivant	JUMP,EQ LOOP$EXIT$:	LOAD.W	D4,D2	POPM.L	D2,D3,D6,A4	RET;------------\\; GROUPDEVANT >;============/; Met tous les objets slectionns devant un frre cadet.; Les objets slectionns doivent tre frre avec l'objet en (A4) !; in	A4.L	^frre cadet; out	D7.W	erreur; mod	D7.WGROUPDEVANT:	PUSHM.L	D4,A2..A4	PUSH.L	(A6)+OAPOS	LOAD.W	D7,#ERPBIP	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP,BS EXIT$	LOAD.L	A3,A4	CALL	LSTA_PREVP	; A4 <-- ^pre  tous	CALL	LSTA_NB		; D4 <-- nb de fils	TEST.W	D4	JUMP',EQ EXIT$LOOP$:	LOAD.L	A2,A4	CALL	LSTA_NEXT	; A4 <-- ^frre suivant	JUMP',NE EXIT$	TEST.B	(A4)+OobjFLAGS:#BobjFLAG ; objet dj trait ?	JUMP,BS LOOP$		; oui => LOOP$	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	CALL	ARBRESUB	; enlve de l'arbre	CALL	ARBREADDFA	; remet au frre cadet	TSET.B	(A4)+OobjFLAGS:#BobjFLAG ; signal objet dj trait	LOAD.L	A3,A4		; A3 <-- rfrence o ajouter le prochain fils	LOAD.L	A4,A2NEXT$:	DEC.W	D4	JUMP,NE LOOP$	CLR.W	D7		; D7 <-- okEXIT$:	CALL	GROUPKFLAG	; enlve BobjFLAG partout !	POP.L	(A6)+OAPOS	POPM.L	D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------------\\; GROUPDERRIERE >;==============/; Met tous les objets slectionns derrire un frre cadet.; Les objets slectionns doivent tre frre avec l'objet en (A4) !; in	A4.L	^frre cadet; out	D7.W	erreur; mod	D7.WGROUPDERRIERE:	PUSHM.L	D4,A2..A4	PUSH.L	(A6)+OAPOS	LOAD.W	D7,#ERPBIP	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP,BS EXIT$	LOAD.L	A3,A4	CALL	LSTA_PREVP	; A4 <-- ^pre  tous	CALL	LSTA_NB		; D4 <-- nb de fils	TEST.W	D4	JUMP',EQ EXIT$LOOP$:	LOAD.L	A2,A4	CALL	LSTA_NEXT	; A4 <-- ^frre suivant	JUMP',NE EXIT$	TEST.B	(A4)+OobjFLAGS:#BobjFLAG ; objet dj trait ?	JUMP,BS LOOP$		; oui => LOOP$	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BC NEXT$	CALL	ARBRESUB	; enlve de l'arbre	CALL	ARBREADDFC	; remet au frre an	TSET.B	(A4)+OobjFLAGS:#BobjFLAG ; signal objet dj trait	LOAD.L	A4,A2NEXT$:	DEC.W	D4	JUMP,NE LOOP$	CLR.W	D7		; D7 <-- okEXIT$:	CALL	GROUPKFLAG	; enlve BobjFLAG partout !	POP.L	(A6)+OAPOS	POPM.L	D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; GROUPKFLAG >;===========/; Enlve le flag  tous les objets.; in	-; out	-; mod	-GROUPKFLAG:	PUSHM.L	D7,A4	CALL	LSTA_PCFIRST	; A4 <-- ^premier objet	JUMP',NE EXIT$LOOP$:	TCLR.B	(A4)+OobjFLAGS:#BobjFLAG	CALL	LSTA_NEXT	; A4 <-- ^objet suivant	JUMP,EQ LOOP$EXIT$:	POPM.L	D7,A4	RET;------------\\; GROUPBBFILS >;============/; Calcule la plus petite bbox possible englobant tous les fils d'un objet.; in	A4.L	^objet; out	D3/D4	bbox des fils; mod	D3.L, D4.L, D7.WGROUPBBFILS:	PUSHM.L	D1,D2,A2..A4	PUSH.L	(A6)+OAPOS	LOAD.L	D3,#H'7FFF7FFF	; D3 <-- +infini	LOAD.L	D4,#H'80008000	; D4 <-- -infini	TEST.W	(A4)+OobjNB	; y a-t-il des fils ?	JUMP',EQ END$		; non => END$	LOAD.L	A3,A4		; A3 <-- ^pre	CALL	LSTA_NEXT	; A4 <-- ^frre cadet	JUMP',NE END$LOOP$:	EX.L	D1,D3	EX.L	D2,D4	CALL	LSTA_BBOX	; D1/D2 <-- bbox d'un fils	EX.L	D1,D3	EX.L	D2,D4	CALL	RECTOR		; D3/D4 <-- union de toutes les bbox	CALL	LSTA_NEXTF	; A4 <-- ^frre suivant	JUMP',NE END$	LOAD.L	A2,A4	CALL	LSTA_PREVP	; A4 <-- ^pre	COMP.L	A4,A3		; toujours le mme pre ?	JUMP',NE END$		; non => END$	LOAD.L	A4,A2	JUMP	LOOP$END$:	COMP.L	D3,#H'7FFF7FFF	; a-t-on trouv au moins un fils ?	JUMP',NE EXIT$		; oui => EXIT$	CLR.L	D3	CLR.L	D4		; D3/D4 <-- y pas d'fils !EXIT$:	POP.L	(A6)+OAPOS	POPM.L	D1,D2,A2..A4	RET;-----------\\; GROUPDFILS >;===========/; Dplace tous les fils d'un pre, mais pas les petits-fils.; in	A4.L	^objet;	D4.L	dplacement (dy;dx); out	-; mod	D7.WGROUPDFILS:	PUSHM.L	A2..A4	PUSH.L	(A6)+OAPOS	TEST.L	D4		; dplacement nul ?	JUMP',EQ EXIT$		; oui => EXIT$	TEST.W	(A4)+OobjNB	; y a-t-il des fils ?	JUMP',EQ EXIT$		; non => EXIT$	LOAD.L	A3,A4		; A3 <-- ^pre	CALL	LSTA_NEXT	; A4 <-- ^frre cadet	JUMP',NE EXIT$LOOP$:	CALL	GROUPDEPL	; dplace un fils	CALL	LSTA_NEXTF	; A4 <-- ^frre suivant	JUMP',NE EXIT$	LOAD.L	A2,A4	CALL	LSTA_PREVP	; A4 <-- ^pre	COMP.L	A4,A3		; toujours le mme pre ?	JUMP',NE EXIT$		; non => EXIT$	LOAD.L	A4,A2	JUMP	LOOP$EXIT$:	POP.L	(A6)+OAPOS	POPM.L	A2..A4	RET;---------\\; GROUPABS >;=========/; Rend la position d'un objet absolue, et non plus relative au pre.; L'objet reste cependant le fils de son pre !; in	A4.L	^objet; out	-; mod	D7.WGROUPABS:	PUSHM.L	D3,D4,A3,A4	TEST.B	(A4)+OobjFLAGS:#BobjABS	JUMP',BS EXIT$	LOAD.L	A3,A4		; A3 <-- ^fils	CALL	LSTA_PREVP	; A4 <-- ^pre (*)	CALL	LSTA_BBOX	; D3/D4 <-- bbox du pre	LOAD.L	A4,A3		; A4 <-- ^fils	LOAD.L	D4,D3		; D4 <-- dplacement	CALL	GROUPDEPL	; dplace le fils	TSET.B	(A4)+OobjFLAGS:#BobjABSEXIT$:	POPM.L	D3,D4,A3,A4	RET;---------\\; GROUPREL >;=========/; Rend la position d'un objet relative  son pre, et non plus absolue.; L'objet est toujours le fils de son pre !; in	A4.L	^objet; out	-; mod	D7.WGROUPREL:	PUSHM.L	D3,D4,A3,A4	TEST.B	(A4)+OobjFLAGS:#BobjABS	JUMP',BC EXIT$	LOAD.L	A3,A4		; A3 <-- ^fils	CALL	LSTA_PREVP	; A4 <-- ^pre (*)	CALL	LSTA_BBOX	; D3/D4 <-- bbox du pre	LOAD.L	A4,A3		; A4 <-- ^fils	LOAD.L	D4,D3	NEG.W	D4	SWAP.W	D4	NEG.W	D4	SWAP.W	D4		; D4 <-- dplacement	CALL	GROUPDEPL	; dplace le fils	TCLR.B	(A4)+OobjFLAGS:#BobjABSEXIT$:	POPM.L	D3,D4,A3,A4	RET; (*)	Ne teste pas l'erreur aprs LSTA_PREVP, car OARLIM n'est pas;	forcment initialis (et les objets ont obligatoirement un pre) !;----------\\; GROUPSRCP >;==========/; Cherche quel est l'objet GROUP qui peut contenir entirement; un objet indpendant.; in	A4.L	^objet; out	A3.L	^objet GROUP pouvant devenir le pre;	D7.W	erreur; mod	D7.W, A3.LGROUPSRCP:	PUSHM.L	D1..D4,D6,A4	CALL	LSTA_BBOX	LOAD.L	D1,D3	LOAD.L	D2,D4		; D1/D2 <-- bbox futur fils	LOAD.L	A3,A4		; A3 <-- futur fils	CALL	LSTA_PCLAST	; A4 <-- ^dernier objet	JUMP',NE EXIT$LOOP$:	COMP.L	A4,A3		; est-ce que le pre veut devenir fils de lui-mme ?	JUMP',EQ NEXT$		; oui => NEXT$	COMP.W	(A4)+OobjIDENT,#IDENTFGROUP	JUMP',LO NEXT$	COMP.W	(A4)+OobjIDENT,#IDENTLGROUP	JUMP',HS NEXT$	CALL	LSTA_BBOX	; D3/D4 <-- bbox pre ventuel	CALL	RECTTEST	; D7 <-- nb de points de D1/D2 inclus dans D3/D4	COMP.W	D7,#2		; entirement inclu ?	JUMP',NE NEXT$		; non => NEXT$	LOAD.L	A3,A4		; A3 <-- ^objet pouvant tre pre	CLR.W	D7	JUMP'	EXIT$NEXT$:	CALL	LSTA_PREV	; A4 <-- ^objet prcdent	JUMP,EQ LOOP$EXIT$:	POPM.L	D1..D4,D6,A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; GROUPADOPT >;===========/; Dplace un objet pour qu'il devienne le fils d'un autre pre (adoption).; Sa position relative change, mais pas sa position absolue !; in	A4.L	^objet;	A3.L	^futur pre; out	D7.W	erreur; mod	D7.WGROUPADOPT:	PUSHM.L	D2..D4	CALL	LSTA_BBOX	LOAD.L	D2,D3		; D2 <-- bbox1 fils	EX.L	A3,A4	CALL	LSTA_BBOX	; D3 <-- bbox1 pre	EX.L	A3,A4	SUB.W	D2,D3	SUB.W	D2,(A4)+OobjBBOX1+2	SWAP.W	D2	SWAP.W	D3	SUB.W	D2,D3	SUB.W	D2,(A4)+OobjBBOX1+0	SWAP.W	D2	SWAP.W	D3	LOAD.L	D4,D2		; D4 <-- dplacement	CALL	ARBRESUB	; enlve de l'arbre source	CALL	ARBREADDFI	; ajoute un fils au pre	CALL	GROUPDEPL	; dplace le fils	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;----------\\; GROUPDEAD >;==========/; Supprime un objet, mais pas ses fils qui sont adopts par le grand-pre (dcs).; La position relative des fils change, mais pas la position absolue !; Tous les fils sont slectionns.; in	A4.L	^objet; out	A4.L	^fils ain;	D7.W	erreur; mod	D7.W, A4.LGROUPDEAD:	PUSHM.L	D4,A2,A3	LOAD.L	D4,(A4)+OobjBBOX1 ; D4 <-- dplacement pour les fils	LOAD.L	A2,A4		; A2 <-- ^pre (qui va mourir)	LOAD.L	A3,A4		; A3 <-- rfrence o ajouter le prochain filsLOOP$:	TEST.W	(A2)+OobjNB	; le pre a-t-il encore des fils ?	JUMP',EQ DEAD$		; non => DEAD$	LOAD.L	A4,A2	CALL	LSTA_NEXT	; A4 <-- ^fils suivant	JUMP',NE EXIT$	CALL	ARBRESUB	; enlve de l'arbre source	CALL	ARBREADDFA	; ajoute un fils au grand-pre	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BS DEPL$	CALL	LSTO_HEXTEND	; tend l'objet	JUMP',NE EXIT$DEPL$:	CALL	GROUPDEPL	; dplace le fils	LOAD.L	A3,A4		; A3 <-- rfrence o ajouter le prochain fils	JUMP	LOOP$DEAD$:	LOAD.L	A4,A2	CALL	LSTA_REMOVE	; dcs du pre !	LOAD.L	A4,A3		; A4 <-- ^fils an	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D4,A2,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; GROUPDEPL >;----------/; Dplace un objet slectionn ou non.; in	A4.L	^objet;	D4.L	dplacement (dy;dx); out	D7.W	erreur; mod	D7.WGROUPDEPL:	TEST.L	D4		; dplacement nul ?	JUMP',EQ OK$		; oui => OK$	TEST.B	(A4)+OobjFLAGS:#BobjEXTEND	JUMP',BS SEL$	CALL	LSTO_HEXTEND	; tend l'objet	JUMP',NE EXIT$	CALL'	GROUPDEPLSEL	; dplace l'objet	CALL	LSTO_HCOMPACT	; compacte l'objet	JUMP'	EXIT$SEL$:	CALL'	GROUPDEPLSEL	; dplace l'objetOK$:	CLR.W	D7		; D7 <-- okEXIT$:	TEST.W	D7		; retour EQ/NE	RET;-------------\\; GROUPDEPLSEL >;-------------/; Dplace un objet slectionn (c'est--dire tendu).; in	A4.L	^objet;	D4.L	dplacement (dy;dx); out	-; mod	D7.WGROUPDEPLSEL:	PUSHM.L	D1,D3,D4,A2	LOAD.L	(A6)+OZONP1,D4	; paramtre 1 <-- dplacement	LOAD.L	A2,#R16"DEPL$	; A2 <-- ^routine de transformation	LOAD.W	D3,#ZONEMOVEBEGIN	LOAD.W	D1,#opZONEMOVE	CALL	OBJCALLD	; dbut du dplacement	LOAD.W	D3,#ZONEMOVEDRAG	LOAD.W	D1,#opZONEMOVE	CALL	OBJCALLD	; dplace l'objet	LOAD.W	D3,#ZONEMOVEEND	LOAD.W	D1,#opZONEMOVE	CALL	OBJCALLD	; fin du dplacement	LOAD.L	D4,(A4)+OobjBBOX1	CALL	(A2)	LOAD.L	(A4)+OobjBBOX1,D4	LOAD.L	D4,(A4)+OobjBBOX2	CALL	(A2)	LOAD.L	(A4)+OobjBBOX2,D4	POPM.L	D1,D3,D4,A2	RETDEPL$:	ADD.W	D4,(A6)+OZONP1+2	SWAP.W	D4	ADD.W	D4,(A6)+OZONP1+0	SWAP.W	D4	RET	.END