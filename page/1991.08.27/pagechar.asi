	.SBTTL	PAGECHAR.ASI;---------\\; DRGETPGC >;=========/; Cherche un gencar bitmap d'aprs son descripteur.; in	A4.L	^descripteur du caractre (odgbm*);	D1.L	angle de rotation (degrs rels); out	A3.L	^gencar bitmap;	D7.W	erreur; mod	D7.W, A3.LDRGETPGC:	JUMP	CHGETPGC	; A3 <-- ^gencar bitmap;--------\\; DRCHAR  >;========/; Dessine un caractre.; in	D3.W	code du caractre;	D4.L	position du centre (y;x);	D2.L	mode de dessin;	D1.L	angle de rotation (degrs rels);	A4.L	^descripteur du caractre (odgbm*); out	D7.W	erreur; mod	D7.WDRCHAR:	PUSHM.L	A3,A4	CALL	CHGETPGC	; A3 <-- ^gencar bitmap	LOAD.L	A4,A3	CALL	DRCHARQ	POPM.L	A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DRCHARQ >;========/; Dessine un caractre rapidement.; in	D3.W	code du caractre (0..255);	D4.L	position du centre (y;x);	D2.L	mode de dessin;	A4.L	^gencar bitmap (!); out	D7.W	erreur; mod	D7.WDRCHARQ:	PUSHM.L	D0..D6,A1..A4	TEST.B	(A6)+OIFPPS	; impression PostScript en cours ?	JUMP,T	PPS$		; oui => PPS$	TEST.B	(A6)+OIFFRAG	; fragmentation en cours ?	JUMP,T	FRAG$		; oui => FRAG$	CALL	_2CONVOBJDRAW	; D4 <- position [scr]	JUMP,NE EXIT$	LOAD.L	D0,D4		; D0 <-- position [scr]	LOAD.L	D1,D2		; D1 <-- mode de dessin	LOAD.W	D6,D3		; D6 <-- caractre	LOAD.L	A3,A4		; A3 <-- ^gencar bitmap; Regarde si le caractre est compltement en dehors de la; sous-fentre de dessin. Si oui, ne construit pas la matrice.	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.W	D2,D3	SL.W	D2,#1		; D2 <-- dcalage pour .W	LOAD.W	D4,D0	LOAD.L	A4,#(A3)+oxcbmXMINS	SUB.W	D4,(A4)+(D2.W)	; D4 <-- extrme gauche	COMP.W	D4,(A2)+ODFFDX	JUMP,GE EXIT$	LOAD.W	D4,D0	LOAD.L	A4,#(A3)+oxcbmXMAXS	ADD.W	D4,(A4)+(D2.W)	; D4 <-- extrme droite	JUMP,NS EXIT$	LOAD.L	D4,D0	SWAP.W	D4	LOAD.L	A4,#(A3)+oxcbmYMINS	SUB.W	D4,(A4)+(D2.W)	; D4 <-- extrme haut	COMP.W	D4,(A2)+ODFFDY	JUMP,GE EXIT$	LOAD.L	D4,D0	SWAP.W	D4	LOAD.L	A4,#(A3)+oxcbmYMAXS	ADD.W	D4,(A4)+(D2.W)	; D4 <-- extrme bas	JUMP,NS EXIT$; Construit la matrice du caractre, si ncessaire.	TEST.L	(A6)+OBMABS	; bitmap existe ?	JUMP',NE NORM$		; oui => NORM$	TCLR.L	D1:#BTTTDOT	COMP.B	D1,#INVDOT	JUMP',NE NOPROV$	PUSH.W	D1	LOAD.L	D1,(A6)+OVUE	POP.W	D1NOPROV$:	TEST.L	D1:#BVUECHAR	JUMP,BC TRAME$NORM$:	CLR.L	D5	LOAD.L	A1,(A6)+OBMMAT	CALL	(A1)		; XCAR_BMMATRIX, A4/D3/D4/D5 <-- ^matrice du caractre	JUMP,NE EXIT$	SWAP.W	D5		; D5 <-- largeur en bytes	TEST.W	D5		; ancien module XCAR ?	JUMP',NE IYOK$		; non => IYOK$	LOAD.W	D5,D4	ADD.W	D5,#16-1	SR.W	D5,#4	SL.W	D5,#1		; D5 <-- largeur en bytes (multiple de words)IYOK$:	TEST.L	(A6)+OBMABS	; bitmap existe ?	JUMP,NE BITMAP$		; oui => BITMAP$; Dessine le caractre directement dans l'cran.	CALL	_2CCMO		; enlve la souris	LOAD.L	D2,D4		; D2 <-- dimensions	LOAD.L	D4,D0	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- position destination	SWAP.W	D3	SWAP.W	D4	CLR.L	D3		; D3 <-- position source	LOAD.L	A3,A4		; A3 <-- ^source (matrice)	LOAD.L	A4,#0		; A4 <-- ^destination (dans l'cran);	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+ORASTER	CALL	(A1)		; GRA_RASTER, dessine un caractre	JUMP	OK$; Dessine une trame  la place du caractre.TRAME$:	COMP.B	D6,#SPACE	JUMP,EQ OK$	COMP.B	D6,#CR	JUMP,EQ OK$	CALL	_2CCMO		; enlve la souris	LOAD.L	D4,D0		; D4 <-- position	SWAP.W	D4	LOAD.L	A4,#(A3)+oxcbmYMINS	LOAD.W	D3,(A4)+(D2.W)	; D3 <-- coin	SUB.W	D4,D3	LOAD.L	A4,#(A3)+oxcbmYMAXS	ADD.W	D3,(A4)+(D2.W)	; D3 <-- hauteur	JUMP',NE TYOK$	INC.W	D3		; D3 <-- hauteur d'au moins une ligne !TYOK$:	SWAP.W	D3	SWAP.W	D4	LOAD.L	A4,#(A3)+oxcbmXMINS	LOAD.W	D3,(A4)+(D2.W)	; D3 <-- coin	SUB.W	D4,D3	LOAD.L	A4,#(A3)+oxcbmXMAXS	ADD.W	D3,(A4)+(D2.W)	; D3 <-- largeur	JUMP',NE TXOK$	INC.W	D3		; D3 <-- largeur d'au moins un point !TXOK$:	LOAD.L	A4,#R16"TRA0$	COMP.B	D1,#CLRDOT	JUMP',EQ TDRAW$	LOAD.L	A4,#R16"TRA1$TDRAW$:	CLR.L	(A2)+ODFTPM	; annule XTRAME;	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+OTRAME	CALL	(A1)		; GRA2_TRAME, dessine un caractre	JUMP	OK$; Dessine le caractre dans le bitmap en mmoire.BITMAP$:	LOAD.L	D2,D4		; D2 <-- dimensions	LOAD.L	D4,D0	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3		; D4 <-- position destination	SWAP.W	D3	SWAP.W	D4	LOAD.L	A3,A4		; A3 <-- ^source (matrice)	LOAD.L	A4,#0		; A4 <-- ^destination (dans l'cran=bitmap)	PUSH.L	D4	LOAD.L	D3,D4		; D3 <-- coin sup/gauche du caractre	LOAD.L	D4,D2	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3		; D4 <-- coin inf/droite du caractre	SWAP.W	D3	SWAP.W	D4	CALL	DRBMBBOXQ	; bitmap <-- indique o l'on va dessiner	POP.L	D4	CLR.L	D3		; D3 <-- position source;	LOAD.L	A2,(A6)+OPDDIS	; A2 <-- ^descripteur de la fentre	LOAD.L	A1,(A6)+ORASTER	CALL	(A1)		; GRA_RASTER, dessine un caractre	JUMP'	OK$; Impression PostScript.PPS$:	PUSH.L	D3	LOAD.W	D0,#IDENTCHAR	LOAD.W	D1,#opDGETUSE	CALL	_1OBJCALL	; D3 <-- caractre utilise	LOAD.W	D1,D3		; D1 <-- caractre utilise	POP.L	D3	LOAD.L	A2,(A6)+OCAPAGEPS	PPS_	DRCHAR	JUMP'	EXIT$; Fragmente un caractre.FRAG$:	CALL	CHFRAG		; fragmente le caractre;	JUMP'	OK$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D6,A1..A4	TEST.W	D7		; retour EQ/NE	RETTRA1$:	.B	H'AA,H'55,H'AA,H'55,H'AA,H'55,H'AA,H'55TRA0$:	.B	H'00,H'00,H'00,H'00,H'00,H'00,H'00,H'00	.EVEN;---------\\; CHGETPGC >;---------/; Cherche un gencar bitmap d'aprs son descripteur.; in	A4.L	^descripteur du caractre (odgbm*);	D1.L	angle de rotation (degrs rels); out	A3.L	^gencar bitmap;	D7.W	erreur; mod	D7.W, A3.LCHGETPGC:	PUSHM.L	D2..D4,A1,A2,A4; Cherche si ce descripteur est dj utilis.	LOAD.W	D4,(A4)+odgbmCORPS	CALL	_2SCALEP	; D4 <-- corps selon l'chelle	JUMP,NE EXIT$	LOAD.L	A3,#(A6)+OTADG	LOAD.W	D3,#MAXTADG-1SRC$:	LOAD.L	A1,A3	LOAD.L	A2,A4	LOAD.W	D2,#(odgbmCORPS/4)-1SRC2$:	COMP.L	(A1+),(A2+)	; compare les noms	JUMP',NE SRC9$	DECJ.W,NMO D2,SRC2$	COMP.W	D4,(A3)+odgbmCORPS	JUMP',NE SRC9$	COMP.L	D1,(A3)+odgbmROTATE	JUMP',NE SRC9$	LOAD.L	A1,#(A3)+odgbmZOOMY	LOAD.L	A2,#(A4)+odgbmZOOMY	LOAD.W	D2,#((ldgbm-odgbmZOOMY)/2)-1SRC4$:	COMP.W	(A1+),(A2+)	; compare le reste	JUMP',NE SRC9$	DECJ.W,NMO D2,SRC4$	LOAD.L	A4,A3	JUMP	USE5$SRC9$:	LOAD.L	A3,#(A3)+LTADG	; A3 <-- ^descripteur suivant	DECJ.W,NMO D3,SRC$; S'il ne reste pas assez de mmoire libre, libre qq gencar.GIVE$:	PUSHM.L	D4,D5	GESMEM	?ARGMEM	LOAD.L	D3,D4		; D3 <-- taille mmoire libre	POPM.L	D4,D5	COMP.L	D3,#80000	; reste au moins 80 Kbytes ?	JUMP',HS FREE$		; oui => FREE$	LOAD.L	A3,#(A6)+OTADG	LOAD.W	D3,#MAXTADG-1	LOAD.L	D2,#-1GIVE2$:	TEST.B	(A3)		; descripteur libre ?	JUMP',EQ GIVE4$		; oui => GIVE4$	COMP.L	D2,(A3)+OTADGUS	JUMP',LO GIVE4$	LOAD.L	D2,(A3)+OTADGUS	LOAD.L	A2,A3		; A2 <-- ^descripteur le plus vieuxGIVE4$:	LOAD.L	A3,#(A3)+LTADG	; A3 <-- ^descripteur suivant	DECJ.W,NMO D3,GIVE2$	COMP.L	D2,#-1	JUMP',EQ FREE$	LOAD.L	A3,(A2)+OTADGPT	; A3 <-- ^gencar bitmap	XCAR_	BMCLOSE		; libre le gencar bitmap le plus vieux	JUMP	GIVE$; Cherche un descripteur libre.FREE$:	LOAD.L	A3,#(A6)+OTADG	LOAD.W	D3,#MAXTADG-1FREE2$:	TEST.B	(A3)		; descripteur libre ?	JUMP',EQ USE$		; oui => USE$	LOAD.L	A3,#(A3)+LTADG	; A3 <-- ^descripteur suivant	DECJ.W,NMO D3,FREE2$; Cherche le descripteur le plus vieux.	LOAD.L	A3,#(A6)+OTADG	LOAD.W	D3,#MAXTADG-1	LOAD.L	D2,#-1OLD$:	COMP.L	D2,(A3)+OTADGUS	JUMP',LO OLD9$	LOAD.L	D2,(A3)+OTADGUS	LOAD.L	A2,A3		; A2 <-- ^descripteur le plus vieuxOLD9$:	LOAD.L	A3,#(A3)+LTADG	; A3 <-- ^descripteur suivant	DECJ.W,NMO D3,OLD$	LOAD.L	A3,(A2)+OTADGPT	; A3 <-- ^gencar bitmap	XCAR_	BMCLOSE		; libre le gencar bitmap le plus vieux	LOAD.L	A3,A2; Utilise le descripteur cherch.USE$:	LOAD.L	A1,A3	LOAD.L	A2,A4	LOAD.W	D2,#(ldgbm/2)-1USE2$:	LOAD.W	(A1+),(A2+)	; OTADG <-- descripteur	DECJ.W,NMO D2,USE2$	LOAD.W	(A3)+odgbmCORPS,D4	LOAD.L	(A3)+odgbmROTATE,D1	LOAD.L	A4,A3		; A4 <-- ^descripteur dans OTADG	XCAR_	BMOPEN		; A3 <-- ^gencar bitmap	JUMP',EQ USE4$	CLR.B	(A4)		; libre le descripteur	JUMP'	EXIT$USE4$:	LOAD.L	(A4)+OTADGPT,A3	; OTADGPT <-- ^gencar bitmapUSE5$:	INC.L	(A6)+OUSDG	; une utilisation de plus	LOAD.L	(A4)+OTADGUS,(A6)+OUSDG	LOAD.L	A3,(A4)+OTADGPT	; A3 <-- ^gencar bitmap	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D4,A1,A2,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; CHFLUSH >;========/; Libre tous les gencars en attente.; in	-; out	-; mod	D7.WCHFLUSH:	PUSHM.L	D4,A3,A4	LOAD.L	A4,#(A6)+OTADG	LOAD.W	D4,#MAXTADG-1LOOP$:	TEST.B	(A4)		; descripteur libre ?	JUMP',EQ NEXT$		; oui => NEXT$	LOAD.L	A3,(A4)+OTADGPT	; A3 <-- ^gencar bitmap	XCAR_	BMCLOSE		; libre le gencar bitmap	CLR.B	(A4)NEXT$:	LOAD.L	A4,#(A4)+LTADG	; A4 <-- ^descripteur suivant	DECJ.W,NMO D4,LOOP$	POPM.L	D4,A3,A4	RET;--------\\; CHFRAG  >;--------/; Fragmente un caractre.; in	D3.W	code du caractre;	D4.L	position du centre (y;x);	A4.L	^gencar bitmap (!); out	-; mod	D7.WCHFRAG:	PUSHM.L	D1,D2,D4,A2..A4	LOAD.L	D1,D4		; D1 <-- position du centre	LOAD.L	A4,(A4)+oxcbmPDESC ; A4 <-- ^descripteur (odgbm*)	LOAD.L	A3,#(A6)+OFRAPD	LOAD.W	D4,#(ldgbm/2)-1XFER$:	LOAD.W	(A3+),(A4+)	; OFRAPD <-- descripteur gencar bitmap	DECJ.W,NMO D4,XFER$	LOAD.L	A4,#(A6)+OFRAPD	; A4 <-- ^descripteur gencar bitmap	LOAD.W	D4,(A4)+odgbmCORPS ; D4 <-- corps [scr]	CALL	_2SCALEN	; D4 <-- corps [obj]	LOAD.W	(A4)+odgbmCORPS,D4	LOAD.L	D4,D1		; D4 <-- position du centre	PUSH.W	(A6)+OSCALE	CLR.W	(A6)+OSCALE	; met l'chelle 1:1	LOAD.L	D1,(A4)+odgbmROTATE ; D1 <-- angle de rotation	CALL	CHGETPGC	; A3 <-- ^gencar bitmap	LOAD.L	A4,#R16"PUT$	XCAR_	FRAGMENT	; fragmente le caractre	POP.W	(A6)+OSCALE	LOAD.W	D2,#2		; D2 <-- lg ncessaire	CALL	FRAGBUFF	; A2 <-- ^buffer	JUMP',NE EXIT$	LOAD.W	(A2),#IDFRAGCHENDEXIT$:	POPM.L	D1,D2,D4,A2..A4	RET; in	A6.L	^variables de l'utilisateur;	D3.L	P1 (y;x);	D4.L	P2 (y;x);	D5.L	P3 (y;x);	D6.L	P4 (y;x); out	-; mod	D7.WPUT$:	PUSHM.L	D2,A2	COMP.L	D3,D4	JUMP',NE PBUFF$	COMP.L	D3,D5	JUMP',NE PBUFF$	COMP.L	D3,D6		; P1=P2=P3=P4, voir (*) ?	JUMP',EQ PEXIT$		; oui => PEXIT$PBUFF$:	LOAD.W	D2,#2+4+4+4+4	; D2 <-- lg ncessaire	CALL	FRAGBUFF	; A2 <-- ^buffer	JUMP',NE PEXIT$	LOAD.W	(A2+),#IDFRAGCHCURVE	LOAD.L	(A2+),D3	LOAD.L	(A2+),D4	LOAD.L	(A2+),D5	LOAD.L	(A2+),D6PEXIT$:	POPM.L	D2,A2	RET; (*)	Certains caractres, tel le "a" du Futura (FSP00), ont une;	droite de longueur nulle. Ce test permet de l'ignorer !	.END