	.SBTTL	OPJUSTREGLE.ASIRGDIMY		=	31	; hauteur d'une rgle [scr]GCICH		=	11	; hauteur des icnes IPP07 [scr]GCICX		=	20	; place horizontale d'une icne [scr]GCICXN		=	80	; largeur pour le nom [scr];--------\\; XopDUSE >;========/; Utilise une rgle.; in	A0.L	canal;	D2.W	opration;	A2.L	^table de justification (si D2=1);	+	selon opration; out	+	selon opration;	D7.W	erreur; mod	D7.W, +XopDUSE:	PUSHM.L	A0,A5	LOAD.L	A5,A0		; A5 <-- ^variables globales	LOAD.L	A0,(A5)+OPDDIS	; A0 <-- ^descripteur fentre	COMP.W	D2,#1	JUMP',EQ OPEN$	COMP.W	D2,#2	JUMP',EQ CLOSE$	COMP.W	D2,#3	JUMP',EQ DETECT$	COMP.W	D2,#4	JUMP',EQ ACTION$	LOAD.W	D7,#1	JUMP'	EXIT$OPEN$:	PUSH.L	D4	LOAD.L	D4,#H'10000*COLORFHELP+COLORCHELP	LOAD.W	D7,#DR_COLORINIT	PAGE_	DRAW		; spcifie les couleurs	POP.L	D4	CALL	RGOPEN	JUMP'	EXIT$CLOSE$:	CALL	RGCLOSE	JUMP'	EXIT$DETECT$:	CALL	RGDETECT	JUMP'	EXIT$ACTION$:	PUSH.L	D4	LOAD.L	D4,#H'10000*COLORFHELP+COLORCHELP	LOAD.W	D7,#DR_COLORINIT	PAGE_	DRAW		; spcifie les couleurs	POP.L	D4	CALL	RGACTION;	JUMP'	EXIT$EXIT$:	POPM.L	A0,A5	TEST.W	D7		; retour EQ/NE	RET;---------\\; RGACTION >;=========/; Action dans une rgle.; in	A4.L	^table des justifications/nil si par dfaut; out	D2.W	nouvelle justification (-1 si rgle modifie);	D7.W	erreur; mod	D2.L, D7.WRGACTION:	PUSHM.L	A4	COMP.L	A4,#0		; objet par dfaut ?	JUMP',NE NODEF$		; non => NODEF$	LOAD.L	A4,(A5)+OPDEF	; A4 <-- ^objet justification par dfautNODEF$:	CALL	RGIFMOVE	; souris dans une icne fixe ?	JUMP',EQ MODIF$	COMP.W	D7,#ERDIOUT	JUMP',NE EXIT$	CALL	RGIMMOVE	; souris dans une icne mobile ?	JUMP',NE EXIT$	LOAD.W	D2,#-1MODIF$:	COMP.W	D2,#-1	JUMP',NE EXIT$	INC.W	(A5)+ORGLAF	; faudra redessiner la rgle !EXIT$:	POPM.L	A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; RGDETECT >;=========/; Regarde si la souris survole la rgle.; in	D4.L	position de la souris (y;x)  [scr]; out	D7.W	erreur (si ailleurs); mod	D7.WRGDETECT:	PUSH.L	D4	LOAD.W	D7,#1	TEST.L	(A5)+ORGLPO	; y a-t-il une rgle visible ?	JUMP',EQ EXIT$		; non => EXIT$	LOAD.W	D7,#MA_SCROBJ	PAGE_	MATH		; D4 <-- position [obj]	JUMP',NE EXIT$	LOAD.W	D7,#1	COMP.W	D4,(A5)+ORGPP1+2	JUMP',LT EXIT$	COMP.W	D4,(A5)+ORGPP2+2	JUMP',GE EXIT$	SWAP.W	D4	COMP.W	D4,(A5)+ORGPP1+0	JUMP',LT EXIT$	COMP.W	D4,(A5)+ORGPP2+0	JUMP',GE EXIT$	CLR.W	D7		; D7 <-- dans la rgleEXIT$:	POP.L	D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; RGOPEN  >;========/; Dessine une nouvelle rgle.; in	D3.L	coin inf/gauche (y;x)  [obj];	D4.W	largeur (dx)  [obj];	A2.L	^table de justification; out	-; mod	D7.WRGOPEN:	PUSHM.L	D1..D4	COMP.L	D3,(A5)+ORGLPO	; est-ce que la rgle est toujours  la mme place ?	JUMP',NE MOVE$		; non => MOVE$	COMP.W	D4,(A5)+ORGLLG	JUMP,EQ DRAW$MOVE$:	CALL	RGCLOSE		; enlve l'ancienne rgle	LOAD.L	(A5)+ORGLPO,D3	LOAD.W	(A5)+ORGLLG,D4	CLR.L	(A5)+ORGLJU	LOAD.W	D2,D4		; D2 <-- largeur [obj]	LOAD.W	D4,#RGDIMY	LOAD.W	D7,#MA_SCALEN	PAGE_	MATH		; D4 <-- hauteur [obj]	LOAD.W	D1,D4	LOAD.L	D4,D3		; D4 <-- P2 [obj]	ADD.W	D4,D2	SWAP.W	D3	SUB.W	D3,D1		; D3 <-- P1 [obj]	SWAP.W	D3	LOAD.L	D1,D3	LOAD.L	D2,D4	LOAD.W	D4,#3	LOAD.W	D7,#MA_SCALEN	PAGE_	MATH		; D4 <-- marge [obj]	SUB.W	D1,D4	LOAD.W	D4,#3+1	LOAD.W	D7,#MA_SCALEN	PAGE_	MATH		; D4 <-- marge [obj]	ADD.W	D2,D4	LOAD.W	D4,#3+2	LOAD.W	D7,#MA_SCALEN	PAGE_	MATH		; D4 <-- marge [obj]	SWAP.W	D1	SUB.W	D1,D4	SWAP.W	D1	SWAP.W	D2	SUB.W	D2,D4	SWAP.W	D2	LOAD.L	D3,D1	LOAD.L	D4,D2	LOAD.W	D7,#DR_BMVISUPLY	PAGE_	DRAW		; D3/D4 <-- toujours visibles !	LOAD.L	(A5)+ORGPP1,D3	LOAD.L	(A5)+ORGPP2,D4	CALL	RGSAVWDO	; sauve le contenu de la swdo	JUMP,NE EXIT$	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.W	D7,#MA_SCALEP	PAGE_	MATH		; D4 <-- dimensions [scr]	LOAD.L	(A5)+ORGDIM,D4DRAW$:	TEST.W	(A5)+ORGLAF	; faut-il redessiner la rgle ?	JUMP',NE DRAW2$		; oui => DRAW2$	COMP.L	A2,(A5)+ORGLJU	; toujours le mme contenu ?	JUMP',EQ OK$		; oui => OK$DRAW2$:	LOAD.L	(A5)+ORGLJU,A2	; ORGLJU <-- ^dernire table	CLR.W	(A5)+ORGLAF	; le dessin est fait	LOAD.L	D3,(A5)+ORGPP1	LOAD.L	D4,(A5)+ORGPP2	LOAD.W	D7,#DR_BMOPENPLY	PAGE_	DRAW		; dbut du dessin dans un bitmap	JUMP',NE ERROR$	LOAD.L	D4,D3		; D4 <-- P1 [obj]	LOAD.W	D7,#MA_OBJDRAW	PAGE_	MATH	LOAD.L	(A5)+ORGORI,D4	; ORGORI <-- origine (ngative)	CALL	RGDRAW		; dessine toute la rgle	LOAD.W	D7,#DR_BMUPDALL	PAGE_	DRAW		; indique qu'il faut tout mettre  jour	LOAD.W	D7,#DR_BMCLOSE	PAGE_	DRAW		; fin du dessin dans un bitmap (affiche)OK$:	CLR.W	D7		; D7 <-- ok	JUMP'	EXIT$ERROR$:	PUSH.W	D7	LOAD.L	D3,(A5)+ORGPP1	LOAD.L	D4,(A5)+ORGPP2	CALL	RGGETWDO	; restitue le contenu de la swdo	POP.W	D7EXIT$:	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; RGCLOSE >;========/; Enlve une ancienne rgle.; in	-; out	-; mod	D7.WRGCLOSE:	PUSHM.L	D3,D4	CLR.L	(A5)+ORGLPO	CLR.W	(A5)+ORGLLG	CLR.L	(A5)+ORGLJU	LOAD.L	D3,(A5)+ORGPP1	LOAD.L	D4,(A5)+ORGPP2	CALL	RGGETWDO	; restitue le contenu de la swdo	POPM.L	D3,D4	RET;--------\\; RGDRAW  >;========/; Dessine toute la rgle.; in	A2.L	^table de justification; out	-; mod	D7.WRGDRAW:	PUSHM.L	D1..D4,A3	LOAD.W	D2,#SETDOT	; D2 <-- mode de dessin	CLR.L	D3	LOAD.L	D4,(A5)+ORGDIM	DEC.W	D4	SWAP.W	D4	DEC.W	D4	SWAP.W	D4	CALL	RGRECT		; dessine rectangle autour	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,#GCICH+1	LOAD.W	D4,D3	SWAP.W	D4	SWAP.W	D3	CALL	RGLINE		; dessine une ligne horizontale	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,#GCICH+1	LOAD.W	D4,D3	SWAP.W	D4	SWAP.W	D3	CALL	RGLINE		; dessine une ligne horizontale	LOAD.L	D4,#H'10000*1+4	LOAD.W	D3,#GCICXN-4	LOAD.L	A3,#(A2)+OJSNAME	CALL	RGTEXT		; affiche le nom de la rgle	LOAD.L	D3,#H'10000*1+GCICXN	LOAD.L	D4,#H'10000*(1+GCICH)+GCICXN	CALL	RGLINE		; dessine ligne verticale	LOAD.L	D3,#H'10000*1+0	LOAD.L	D4,#H'10000*(GCICH+1)	LOAD.W	D3,(A5)+ORGDIM+2	DEC.W	D3		; D3 <-- position premire icne	LOAD.W	D1,#5-1IFVERT$:	SUB.W	D3,#GCICX	; D3 <-- position suivante	COMP.W	D3,#GCICXN	; encore assez de place ?	JUMP',LT IFDRAW$	; non => IFDRAW$	LOAD.W	D4,D3	CALL	RGLINE		; dessine une ligne verticale	DECJ.W,NMO D1,IFVERT$IFDRAW$:	CALL	RGIFDRAWT	; dessine l'icne de tabulation	CALL	RGIFDRAWC	; dessine l'icne du caractre	CALL	RGIFDRAWJ	; dessine l'icne de justification	CALL	RGIFDRAWI	; dessine l'icne d'interligne	CALL	RGIFDRAWE	; dessine l'icne d'espacement	CLR.W	D2IMLOOP$:	CALL	RGIMINV		; allume une icne variable (marge, tabulateur, etc.)	JUMP',NE IMEND$	INC.W	D2	JUMP	IMLOOP$IMEND$:	CALL	RGGRAD		; dessine la graduation	POPM.L	D1..D4,A3	RET;--------\\; RGGRAD  >;========/; Dessine la graduation dans la rgle.; in	-; out	-; mod	D7.WRGGRAD:	PUSHM.L	D1..D4	LOAD.W	D1,#10*FACMMPT	; D1 <-- incrment (1mm)	LOAD.W	D4,D1	LOAD.W	D7,#MA_SCALEP	PAGE_	MATH		; D4 <-- dimensions [scr]	COMP.W	D4,#2	JUMP',HI GO$	LOAD.W	D1,#50*FACMMPT	; D1 <-- incrment (5mm)	LOAD.W	D4,D1	LOAD.W	D7,#MA_SCALEP	PAGE_	MATH		; D4 <-- dimensions [scr]	COMP.W	D4,#2	JUMP',HI GO$	LOAD.W	D1,#100*FACMMPT	; D1 <-- incrment (1cm)GO$:	CLR.W	D4		; D4 <-- distance initialeLOOP$:	LOAD.W	D3,#5		; D3 <-- long	CLR.L	D2	LOAD.W	D2,D4	DIV.WU	D2,#100*FACMMPT	; multiple de 1cm ?	SWAP.W	D2	TEST.W	D2	JUMP',EQ DRAW$	LOAD.W	D3,#4		; D3 <-- moyen	CLR.L	D2	LOAD.W	D2,D4	DIV.WU	D2,#50*FACMMPT	; multiple de 5mm ?	SWAP.W	D2	TEST.W	D2	JUMP',EQ DRAW$	LOAD.W	D3,#2		; D3 <-- courtDRAW$:	CALL	RGGRADONE	; dessine un trait	JUMP',NE EXIT$	ADD.W	D4,D1		; D4 <-- distance suivante	JUMP	LOOP$EXIT$:	POPM.L	D1..D4	RET;----------\\; RGGRADONE >;----------/; Dessine un trait pour la graduation.; in	D4.W	distance depuis la gauche [obj];	D3.W	hauteur; out	D7.W	erreur (si dpasse  droite); mod	D7.WRGGRADONE:	PUSHM.L	D2..D4	LOAD.W	D7,#MA_SCALEP	PAGE_	MATH		; D4 <-- dimensions [scr]	LOAD.W	D2,D3;;?	LOAD.L	D3,#H'10000*(GCICH+1+GCICH+1+5)+3	LOAD.L	D3,#H'10000*(GCICH+1+GCICH+2)+3	ADD.W	D3,D4	LOAD.L	D4,D3	SWAP.W	D4;;?	SUB.W	D4,D2	ADD.W	D4,D2	SWAP.W	D4	LOAD.W	D7,#1	COMP.W	D3,(A5)+ORGDIM+2 ; dpasse  droite ?	JUMP',GE EXIT$		; oui => EXIT$	LOAD.W	D2,#SETDOT	CALL	RGLINE		; dessine un trait vertical	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;---------\\; RGIMMOVE >;=========/; Dplace une icne mobile avec la souris.; in	-; out	D7.W	erreur; mod	D7.WRGIMMOVE:	PUSHM.L	D1..D5,A4	LOAD.L	D3,(A5)+ORGPP1	LOAD.L	D4,(A5)+ORGPP2	LOAD.W	D7,#DR_SCOPENPLY	PAGE_	DRAW		; dbut du dessin dans l'cran	JUMP,NE EXIT$	CALL	RGIFMOUSE	; D4 <-- position de la souris	CALL	RGIMDET		; D2 <-- icne montre	JUMP,NE OUT$	CALL	RGIMINV		; teint l'icne	TEST.W	D2		; marge gauche ?	JUMP',NE CLR$		; non => CLR$	INC.W	D2	CALL	RGIMINV		; teint le renfoncement	DEC.W	D2CLR$:	CALL	RGIMIMARK	; allume la premire marque	LOAD.L	D5,D4	COMP.W	D2,#3		; est-ce un tabulateur ?	JUMP',LO LOOP$		; non => LOOP$	LOAD.L	A4,(A5)+ORGLJU	; A4 <-- ^table de justification	CALL	RGTABSUB	; enlve le tabulateur	LOAD.W	D1,D3LOOP$:	LOAD.W	D7,#MI_SCMO	PAGE_	MISC		; remet la souris	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP',NE END$	CALL	RGIFMOUSE	; D4 <-- position de la souris	CALL	RGIMPAS		; D4 <-- position selon le pas [obj]	COMP.L	D4,D5		; position change ?	JUMP,EQ LOOP$		; non => LOOP$	EX.L	D4,D5	CALL	RGIMIMARK	; teint la marque	LOAD.L	D4,D5	CALL	RGIMIMARK	; allume la marque	CALL	RGIMAFPOS	; affiche la position	JUMP	LOOP$END$:	LOAD.L	D4,D5	CALL	RGIMIMARK	; teint la dernire marque	LOAD.W	D3,D1	CALL	RGIMPUT		; positionne l'icne	JUMP',NE OUT$	CALL	RGIMINV		; allume l'icne	CLR.W	D7		; D7 <-- okOUT$:	PUSH.W	D7	LOAD.W	D7,#DR_SCCLOSE	PAGE_	DRAW		; fin du dessin dans l'cran	POP.W	D7EXIT$:	POPM.L	D1..D5,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; RGIMPAS >;--------/; Arrondi la position horizontale sur un pas.; in	D2.W	rang de l'icne mobile (0..n);	D4.W	position horizontale [scr]; out	D4.W	position horizontale [obj]; mod	D4.W, D7.WRGIMPAS:	SWAP.W	D4	PUSH.W	D4	SWAP.W	D4	CALL	RGCONVSCROBJ	; D4 <-- position [obj]	COMP.W	D2,#2		; icne marge droite ?	JUMP',EQ RIGHT$		; oui => RIGHT$	CALL	RGCONVPAS	; D4 <-- au pas	JUMP'	LIMIT$RIGHT$:	SUB.W	D4,(A5)+ORGLLG	NEG.W	D4	CALL	RGCONVPAS	; D4 <-- au pas	SUB.W	D4,(A5)+ORGLLG	NEG.W	D4LIMIT$:	TEST.W	D4	JUMP',NC MIN$	CLR.W	D4MIN$:	COMP.W	D4,(A5)+ORGLLG	JUMP',LT EXIT$	LOAD.W	D4,(A5)+ORGLLGEXIT$:	SWAP.W	D4	POP.W	D4	SWAP.W	D4	RET;----------\\; RGIMIMARK >;----------/; Inverse la marque de dplacement.; in	D4.L	position (y;x)  [scr;obj]; out	-; mod	D7.WRGIMIMARK:	PUSHM.L	D2..D4	SWAP.W	D4	TEST.W	D4	JUMP,NS EXIT$	COMP.W	D4,#RGDIMY	JUMP,GT EXIT$	SWAP.W	D4	TEST.W	D4	JUMP',NC OUTG$	CLR.W	D4OUTG$:	COMP.W	D4,(A5)+ORGLLG	JUMP',LT OUTD$	LOAD.W	D4,(A5)+ORGLLGOUTD$:	LOAD.W	D7,#MA_SCALEP	PAGE_	MATH		; D4 <-- dimensions [scr]	ADD.W	D4,#3	PUSH.W	(A5)+ORGORI+0	CLR.W	(A5)+ORGORI+0	PUSH.W	(A0)+ODFFY	PUSH.W	(A0)+ODFFDY	PUSH.W	(A0)+ODFWBY	PUSH.W	(A0)+ODFWEY	CLR.W	(A0)+ODFFY	LOAD.W	(A0)+ODFFDY,(A0)+ODFDY	LOAD.W	D3,(A0)+ODFY	LOAD.W	(A0)+ODFWBY,D3	ADD.W	D3,(A0)+ODFDY	LOAD.W	(A0)+ODFWEY,D3	LOAD.W	D3,D4	SWAP.W	D3	SWAP.W	D4	CLR.W	D3	LOAD.W	D4,(A0)+ODFFDY	SWAP.W	D4	SWAP.W	D3	LOAD.W	D2,#INVDOT	CALL	RGLINE		; inverse une ligne verticale	POP.W	(A0)+ODFWEY	POP.W	(A0)+ODFWBY	POP.W	(A0)+ODFFDY	POP.W	(A0)+ODFFY	POP.W	(A5)+ORGORI+0EXIT$:	POPM.L	D2..D4	RET;----------\\; RGIMAFPOS >;----------/; Affiche la position.; in	D4.L	position (y;x)  [scr;obj];	D2.W	rang de l'icne mobile (0..n); out	-; mod	D7.WRGIMAFPOS:	PUSHM.L	D2..D4,A2..A4	LOAD.L	A2,(A5)+ORGLJU	; A2 <-- ^table de justification	LOAD.L	A3,#(A5)+OBUDIS	LOAD.L	A4,A3	LOAD.B	(A4+),#SPACE	SWAP.W	D4	TEST.W	D4	JUMP',NS CLEAR$	COMP.W	D4,#RGDIMY	JUMP',GT CLEAR$	SWAP.W	D4	COMP.W	D2,#1		; icne renfoncement ?	JUMP',EQ RENF$	COMP.W	D2,#2		; icne marge droite ?	JUMP',NE PUT$		; non => PUT$RIGHT$:	SUB.W	D4,(A5)+ORGLLG	NEG.W	D4	JUMP'	PUT$RENF$:	SUB.W	D4,(A2)+OJSESPGPUT$:	TEST.W	D4	JUMP',NC SIGN$	NEG.W	D4	LOAD.B	(A4+),#'-SIGN$:	LOAD.W	D7,#MI_PUTUNUM	PAGE_	MISC		; OBUDIS <-- nombre, avec unitsCLEAR$:	LOAD.W	D3,#(GCICXN/8)-1SPACE$:	LOAD.B	(A4+),#SPACE	DECJ.W,NMO D3,SPACE$	CLR.B	(A4)	LOAD.L	D4,#H'10000*1+4	LOAD.W	D3,#GCICXN-4	LOAD.W	D2,#LOADDOT	CALL	RGTEXT		; affiche le nom de la rgle	INC.W	(A5)+ORGLAF	; faudra redessiner la rgle !	POPM.L	D2..D4,A2..A4	RET;--------\\; RGIMDET >;========/; Dtecte dans quelle icne mobile est la souris.; in	D4.L	position (y;x)  [scr]; out	D4.W	position   (x)  [obj];	D2.W	rang de l'icne mobile (0..n);	D7.W	erreur; mod	D2.L, D7.WRGIMDET:	PUSHM.L	D0,D1,D3,D5	SWAP.W	D4	SUB.W	D4,#GCICH+1	JUMP,LT ERROR$	COMP.W	D4,#GCICH+1	JUMP,GE ERROR$	LOAD.W	D5,D4		; D5 <-- position relative verticale	SWAP.W	D4	LOAD.W	D1,D4	SUB.W	D4,#5	CALL	RGCONVSCROBJ	; D4 <-- position [obj]	LOAD.W	D0,D4		; D0 <-- limite gauche	LOAD.W	D4,D1	ADD.W	D4,#5	CALL	RGCONVSCROBJ	; D4 <-- position [obj]	LOAD.W	D1,D4		; D1 <-- limite droite	CLR.W	D2LOOP$:	CALL	RGIMPOS		; D3/D4 <-- icne/position [obj]	JUMP',NE ERROR$	COMP.W	D4,D0	JUMP',LT NEXT$	COMP.W	D4,D1	JUMP',GE NEXT$	COMP.W	D3,#ICORGRENF	JUMP',EQ RENF$	COMP.W	D3,#ICORGMARGG	JUMP',NE EXIT$MARGG$:	COMP.W	D5,#(GCICH+1)/2	JUMP',GE EXIT$	JUMP'	NEXT$RENF$:	COMP.W	D5,#(GCICH+1)/2	JUMP',LT EXIT$;	JUMP'	NEXT$NEXT$:	INC.W	D2	JUMP	LOOP$ERROR$:	LOAD.W	D2,#-1	LOAD.W	D7,#ERDIOUTEXIT$:	POPM.L	D0,D1,D3,D5	TEST.W	D7		; retour EQ/NE	RET;--------\\; RGIMINV >;========/; Inverse une icne mobile.; in	D2.W	rang de l'icne mobile (0..n); out	D7.W	erreur; mod	D7.WRGIMINV:	PUSHM.L	D2..D4	LOAD.W	D7,#1	COMP.W	D2,#-1	JUMP',EQ EXIT$	CALL	RGIMPOS		; D3/D4 <-- icne/position [obj]	JUMP',NE EXIT$	LOAD.W	D2,#INVDOT	CALL	RGIMDRAW	; inverse une icne	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2..D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; RGIMPOS >;--------/; Calcule la position d'une icne mobile.;;	0  -->	marge gauche;	1  -->	renfoncement;	2  -->	marge droite;	3..-->	tabulateurs..; in	D2.W	rang de l'icne mobile (0..n); out	D3.W	icne (ICORG*);	D4.W	position depuis la gauche [obj];	D7.W	erreur; mod	D3.L, D4.L, D7.WRGIMPOS:	PUSHM.L	D2,A2	LOAD.L	A2,(A5)+ORGLJU	; A2 <-- ^table de justification	LOAD.W	D7,#1	COMP.W	D2,#-1	JUMP,EQ EXIT$	DEC.W	D2	JUMP',NS LEFT$	DEC.W	D2	JUMP',NS RENF$	DEC.W	D2	JUMP',NS RIGHT$TAB$:	LOAD.L	A2,#(A2)+OJSTABSTALOOP$:	TEST.L	(A2+)	JUMP',EQ EXIT$	DEC.W	D2	JUMP,NC TALOOP$	LOAD.W	D3,(-A2)	; D3 <-- icne	LOAD.W	D4,(-A2)	; D4 <-- position	JUMP'	OK$LEFT$:	LOAD.W	D3,#ICORGMARGG	LOAD.W	D4,(A2)+OJSESPG	JUMP'	OK$RENF$:	LOAD.W	D3,#ICORGRENF	LOAD.W	D4,(A2)+OJSESPG	ADD.W	D4,(A2)+OJSESPR	JUMP'	OK$RIGHT$:	LOAD.W	D3,#ICORGMARGD	LOAD.W	D4,(A5)+ORGLLG	SUB.W	D4,(A2)+OJSESPD;	JUMP'	OK$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2,A2	TEST.W	D7		; retour EQ/NE	RET;--------\\; RGIMPUT >;--------/; Positionne une icne mobile.; in	D2.W	rang de l'icne mobile (0..n);	D3.W	icne (si tabulateur);	D4.L	position de la souris (y;x)  [scr;obj]; out	D2.W	rang de l'icne mobile (0..n,-1);	D7.W	erreur; mod	D2.L, D7.WRGIMPUT:	PUSHM.L	D4,A2,A4	LOAD.L	A2,(A5)+ORGLJU	; A2 <-- ^table de justification	LOAD.W	D7,#1	COMP.W	D2,#-1	JUMP,EQ EXIT$	TEST.W	D4	JUMP',NC OUTG$	CLR.W	D4OUTG$:	COMP.W	D4,(A5)+ORGLLG	JUMP',LT OUTD$	LOAD.W	D4,(A5)+ORGLLGOUTD$:	LOAD.W	D7,#1	TEST.W	D2	JUMP',EQ LEFT$	COMP.W	D2,#1	JUMP',EQ RENF$	COMP.W	D2,#2	JUMP',EQ RIGHT$TAB$:	SWAP.W	D4	TEST.W	D4	JUMP',NS TABSUB$	COMP.W	D4,#RGDIMY	JUMP',GT TABSUB$	SWAP.W	D4	LOAD.L	A4,(A5)+ORGLJU	; A4 <-- ^table de justification	CALL	RGTABADD	; remet le tabulateur	JUMP'	EXIT$TABSUB$:	LOAD.W	D2,#-1		; D2 <-- y'a plus d'icne	JUMP'	OK$LEFT$:	LOAD.W	(A2)+OJSESPG,D4	NEG.W	D4		; D4 <-- minimum pour le renfoncement	COMP.W	D4,(A2)+OJSESPR	JUMP',LE LEFT2$	LOAD.W	(A2)+OJSESPR,D4LEFT2$:	LOAD.W	D4,(A5)+ORGLLG	SUB.W	D4,(A2)+OJSESPG	SUB.W	D4,(A2)+OJSESPD	; D4 <-- maximum pour le renfoncement	SUB.W	D4,#50*FACMMPT	COMP.W	D4,(A2)+OJSESPR	JUMP',GE LEFT3$	LOAD.W	(A2)+OJSESPR,D4LEFT3$:	JUMP'	OK$RENF$:	SUB.W	D4,(A2)+OJSESPG	LOAD.W	(A2)+OJSESPR,D4	JUMP'	OK$RIGHT$:	SUB.W	D4,(A5)+ORGLLG	NEG.W	D4	LOAD.W	(A2)+OJSESPD,D4;	JUMP'	OK$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D4,A2,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; RGIMDRAW >;---------/; Dessine une icne de tabulation.; in	D2.W	mode de dessin;	D3.B	icne;	D4.W	distance depuis la gauche [obj]; out	-; mod	D7.WRGIMDRAW:	PUSHM.L	D1,D3,D4	LOAD.W	D7,#MA_SCALEP	PAGE_	MATH		; D4 <-- dimensions [scr]	ADD.W	D4,#3	SWAP.W	D4	LOAD.W	D4,#GCICH+2	SWAP.W	D4	LOAD.W	D1,#6	COMP.B	D3,#ICORGMARGD	JUMP',EQ ONE$	LOAD.W	D1,#7	COMP.B	D3,#ICORGTABG	JUMP',EQ ONE$	LOAD.W	D1,#3	COMP.B	D3,#ICORGTABI	JUMP',EQ ONE$	COMP.B	D3,#ICORGTABC	JUMP',EQ TWO$	COMP.B	D3,#ICORGTABN	JUMP',EQ TWO$	LOAD.W	D1,#1ONE$:	SUB.W	D4,D1		; D4 <-- correction selon le "milieu" de l'icne	CALL	RGICONE		; dessine une icne	JUMP'	EXIT$TWO$:	INC.W	D4	CALL	RGICONE		; dessine la partie de droite	SUB.W	D4,#8+8	LOAD.B	D3,#ICORGTABG	CALL	RGICONE		; dessine la partie de gaucheEXIT$:	POPM.L	D1,D3,D4	RET;---------\\; RGIFMOVE >;=========/; Action dans une icne d'une rgle.; in	A4.L	^table des justifications/nil si par dfaut; out	D2.W	nouvelle justification (-1 si rgle modifie);	D7.W	erreur; mod	D2.L, D7.WRGIFMOVE:	PUSHM.L	D0,D1,D3,D4,A2..A4	LOAD.L	D3,(A5)+ORGPP1	LOAD.L	D4,(A5)+ORGPP2	LOAD.W	D7,#DR_SCOPENPLY	PAGE_	DRAW		; dbut du dessin dans l'cran	JUMP,NE EXIT$	CALL	RGIFMOUSE	; D4 <-- position de la souris	CALL	RGIFDET		; D2 <-- icne	JUMP,NE OUT$	CALL	RGIFINV		; allume la premire icne	LOAD.W	D1,D2LOOP$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP',NE END$	CALL	RGIFMOUSE	; D4 <-- position de la souris	CALL	RGIFDET		; D2 <-- icne	COMP.W	D2,D1		; toujours dans la mme icne ?	JUMP,EQ LOOP$		; oui => LOOP$	COMP.W	D2,#-1	JUMP',NE CHANGE$	COMP.W	D1,#5		; ancien=tab et nouveau=rien ?	JUMP',EQ TABADD$	; oui => TABADD$CHANGE$:	EX.L	D1,D2	CALL	RGIFINV		; teint l'icne	LOAD.W	D2,D1	CALL	RGIFINV		; allume l'icne	JUMP	LOOP$TABADD$:	LOAD.W	D2,D1	CALL	RGIFINV		; teint la dernire icne	LOAD.W	D3,(A5)+ORGTAB	; D3 <-- tabulateur  ajouter	CALL	RGTABMOVE	; D4 <-- ajoute un tabulateur ...	JUMP',NE TABADD8$	LOAD.L	A4,(A5)+ORGLJU	; A4 <-- ^table de justification	CALL	RGCONVPAS	; D4 <-- position selon le pas [obj]	CALL	RGTABADD	; ajoute un tabulateur	JUMP',NE TABADD8$	LOAD.W	D2,#INVDOT	CALL	RGIMDRAW	; allume le tabulateur	CLR.W	D7		; D7 <-- okTABADD8$:	PUSH.W	D7	LOAD.W	D7,#DR_SCCLOSE	PAGE_	DRAW		; fin du dessin dans l'cran	POP.W	D7	JUMP,NE RIEN$	JUMP	ALL$END$:	LOAD.W	D2,D1	CALL	RGIFINV		; teint la dernire icne	LOAD.W	D7,#DR_SCCLOSE	PAGE_	DRAW		; fin du dessin dans l'cran	LOAD.L	A4,(A5)+ORGLJU	; A4 <-- ^table de justification	LOAD.L	A2,A4		; A2 <-- ^table de justification	TEST.W	D2	JUMP',EQ NAME$	COMP.W	D2,#5	JUMP',EQ TABUL$	COMP.W	D2,#4	JUMP',EQ CHAR$	COMP.W	D2,#3	JUMP,EQ JUSTIF$	COMP.W	D2,#2	JUMP,EQ INTERL$	COMP.W	D2,#1	JUMP,EQ ESPACE$	JUMP	RIEN$NAME$:	CALL	RGIFMNAME	; choix d'un autre nom ...	JUMP,EQ RIEN$	COMP.W	D7,#1	JUMP,EQ OK$	LOAD.L	D2,A4	SUB.L	D2,(A5)+OPDEF	DIV.WU	D2,#LDJUST	; D2 <-- rang de l'actuelle	LOAD.L	A4,(A5)+OPDEF	; A4 <-- ^objet	PUSH.L	A0	LOAD.L	A0,A5		; A0 <-- canal	CALL	XopDTSELECT	; choix d'une justification ...	POPM.L	A0	JUMP,NE EXIT$	TEST.W	D4	JUMP,NE ALL$	JUMP	EXIT$TABUL$:	CALL	RGIFMTAB	; choix selon mmenu ...	JUMP,EQ RIEN$	CLR.W	D0	CALL	DBOXTABUL	; choix des tabulateurs ...	JUMP,NE EXIT$	COMP.W	D3,#F0	JUMP,EQ RIEN$	JUMP	ALL$CHAR$:	CALL	RGIFMCHAR	; choix selon mmenu ...	JUMP,EQ RIEN$	COMP.W	D7,#1	JUMP,EQ ALL$	CLR.W	D0	CALL	DBOXCHAR	; choix du caractre ...	JUMP,NE EXIT$	COMP.W	D3,#F0	JUMP,EQ RIEN$	JUMP	ALL$JUSTIF$:	CALL	RGIFMJUST	; choix selon mmenu ...	JUMP,EQ RIEN$	COMP.W	D7,#1	JUMP,EQ ALL$	CLR.W	D0	CALL	DBOXJUSTIF	; choix de la justification ...	JUMP,NE EXIT$	COMP.W	D3,#F1	JUMP,NE RIEN$	JUMP	ALL$INTERL$:	CALL	RGIFMINT	; choix selon mmenu ...	JUMP',EQ RIEN$	COMP.W	D7,#1	JUMP',EQ ALL$	CLR.W	D0	CALL	DBOXINTERL	; choix de l'interligne ...	JUMP',NE EXIT$	COMP.W	D3,#F1	JUMP',NE RIEN$	JUMP'	ALL$ESPACE$:	CALL	RGIFMESP	; choix selon mmenu ...	JUMP,EQ RIEN$	COMP.W	D7,#1	JUMP',EQ ALL$	CLR.W	D0	CALL	DBOXESPACE	; choix de l'espacement ...	JUMP',NE EXIT$	COMP.W	D3,#F1	JUMP',NE RIEN$	JUMP'	ALL$RIEN$:	LOAD.W	D7,#ERPBIP	JUMP'	EXIT$ALL$:	LOAD.W	D2,#-1		; D2 <-- faudra tout refaireOK$:	CLR.W	D7	JUMP'	EXIT$OUT$:	PUSH.W	D7	LOAD.W	D7,#DR_SCCLOSE	PAGE_	DRAW		; fin du dessin dans l'cran	POP.W	D7EXIT$:	POPM.L	D0,D1,D3,D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; RGIFMNAME  >;-----------/; Choix d'un nom de justification.; in	A4.L	^table de justification; out	D2.W	nouvelle justification;	D7.W	erreur; mod	D2.L, D7.WRGIFMNAME:	PUSH.L	A1	LOAD.L	D2,A4	SUB.L	D2,(A5)+OPDEF	DIV.WU	D2,#LDJUST	; D2 <-- rang de l'actuelle	LOAD.L	A1,#R16"CMMENU$	CALL	RGIFMMENU1	; choix selon mmenu ...	POP.L	A1	TEST.W	D7		; retour EQ/NE	RETCMMENU$:	LOAD.L	A4,(A5)+OPDEF	; A4 <-- ^objet	CALL	XopDGETMENU	; buffer <-- construit le mmenu	RET;---------\\; RGIFMTAB >;---------/; Choix dans le mmenu pour les tabulateurs.; in	A2.L	^table de justification; out	D7.W	0=rien, 1=all, 2=dialogue; mod	D7.WRGIFMTAB:	PUSHM.L	D2..D4,A3	LOAD.W	D3,(A5)+ORGTAB	SUB.W	D3,#ICORGTABD	CLR.W	D2	TSET.L	D2:D3		; D2 <-- case avec "vu"	CLR.W	D3	LOAD.L	A3,#R16"TMMENU$	CALL	RGIFMMENU2	; choix selon mmenu ...	JUMP',NE EXIT$	TEST.W	D3	JUMP',EQ RIEN$	LOAD.W	D7,#2		; D7 <-- dialogue ncessaire	COMP.W	D3,#6	JUMP',HS EXIT$	ADD.W	D3,#ICORGTABD-1	LOAD.W	(A5)+ORGTAB,D3	LOAD.L	D3,(A5)+ORGPP1	LOAD.L	D4,(A5)+ORGPP2	LOAD.W	D7,#DR_SCOPENPLY	PAGE_	DRAW		; dbut du dessin dans l'cran	JUMP',NE RIEN$	CALL	RGIFDRAWT	; dessine l'icne de tabulation	LOAD.W	D7,#DR_SCCLOSE	PAGE_	DRAW		; fin du dessin dans l'cranRIEN$:	CLR.W	D7		; D7 <-- rien  faireEXIT$:	POPM.L	D2..D4,A3	TEST.W	D7		; retour EQ/NE	RETTMMENU$:	.ASCIZ	" "	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICTP	.B	ICORGTABD	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"   droite      <-3>"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICTP	.B	ICORGTABG	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"   gauche      <-3>"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICTP	.B	ICORGTABG,ICORGTABC	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  centr      <-3>"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICTP	.B	ICORGTABG,ICORGTABN	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  dcimal     <-3>"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICTP	.B	ICORGTABI	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"   indentateur <-3>"	.B	-1	.ASCIZ	"     autre.."	.B	0	.EVEN;----------\\; RGIFMCHAR >;----------/; Choix dans le mmenu pour le caractre.; in	A2.L	^table de justification; out	D7.W	0=rien, 1=all, 2=dialogue; mod	D7.WRGIFMCHAR:	PUSHM.L	D2,A1	LOAD.W	D2,(A2)+OJSCHAR	LOAD.L	A1,#R16"CMMENU$	CALL	RGIFMMENU1	; choix selon mmenu ...	COMP.W	D7,#1		; changement ?	JUMP',NE EXIT$	LOAD.W	(A2)+OJSCHAR,D2EXIT$:	POPM.L	D2,A1	TEST.W	D7		; retour EQ/NE	RETCMMENU$:	PUSHM.L	D0,D1	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D0,#IDENTCHAR	LOAD.W	D1,#opDGETMENU	PAGE_	OBJCALL		; construit le mmenu	POPM.L	D0,D1	RET;----------\\; RGIFMJUST >;----------/; Choix dans le mmenu pour la justification.; in	A2.L	^table de justification; out	D7.W	0=rien, 1=all, 2=dialogue; mod	D7.WRGIFMJUST:	PUSHM.L	D2..D4,A3	LOAD.W	D3,#3	TEST.B	(A2)+OJSMODE:#BJSMDC	JUMP',BS MMENU$	DEC.W	D3	TEST.B	(A2)+OJSMODE:#BJSMDG	JUMP',BS MMENU$	DEC.W	D3	TEST.B	(A2)+OJSMODE:#BJSMDD	JUMP',BS MMENU$	DEC.W	D3MMENU$:	CLR.W	D2	TSET.L	D2:D3		; D2 <-- case avec "vu"	TEST.B	(A2)+OJSMODE:#BJSMDM	JUMP',BC MMENU2$	TSET.L	D2:#4MMENU2$:	CLR.W	D3	LOAD.L	A3,#R16"TMMENU$	CALL	RGIFMMENU2	; choix selon mmenu ...	JUMP',NE EXIT$	TEST.W	D3	JUMP',EQ RIEN$	LOAD.W	D7,#2		; D7 <-- dialogue ncessaire	COMP.W	D3,#6	JUMP',HS EXIT$	COMP.W	D3,#5	JUMP',EQ DIVMOT$	DEC.W	D3	TCLR.B	(A2)+OJSMODE:#BJSMDA	TCLR.B	(A2)+OJSMODE:#BJSMDD	TCLR.B	(A2)+OJSMODE:#BJSMDG	TCLR.B	(A2)+OJSMODE:#BJSMDC	TSET.B	(A2)+OJSMODE:D3	LOAD.L	D3,(A5)+ORGPP1	LOAD.L	D4,(A5)+ORGPP2	LOAD.W	D7,#DR_SCOPENPLY	PAGE_	DRAW		; dbut du dessin dans l'cran	JUMP',NE ALL$	CALL	RGIFDRAWJ	; dessine l'icne de justification	LOAD.W	D7,#DR_SCCLOSE	PAGE_	DRAW		; fin du dessin dans l'cran	JUMP'	ALL$DIVMOT$:	TNOT.B	(A2)+OJSMODE:#BJSMDMALL$:	LOAD.W	D7,#1		; D7 <-- faudra tout refaire	JUMP'	EXIT$RIEN$:	CLR.W	D7		; D7 <-- rien  faireEXIT$:	POPM.L	D2..D4,A3	TEST.W	D7		; retour EQ/NE	RETTMMENU$:	.ASCIZ	" "	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICTP	.B	ICORGJUSTA	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  align           <-3>"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICTP	.B	ICORGJUSTD	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  drapeau  droite <-3>"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICTP	.B	ICORGJUSTG	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  drapeau  gauche <-3>"	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICTP	.B	ICORGJUSTC	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  centr           <-3>"	.B	-1	.B	SPACE	.B	USEGC,GCICF,GCICS,GCICTP	.B	ICORGCOUPE	.B	USEGC,GCTXF,GCTXS,GCTXT	.ASCIZ	"  divisions        <-3>"	.B	-1	.ASCIZ	"    autre.."	.B	0	.EVEN;---------\\; RGIFMINT >;---------/; Choix dans le mmenu pour l'interligne.; in	A2.L	^table de justification; out	D7.W	0=rien, 1=all, 2=dialogue; mod	D7.WRGIFMINT:	PUSHM.L	D2..D4,A3	LOAD.W	D3,#5	TEST.B	(A2)+OJSILFL+1:#BJSIL20-16	JUMP',BS MMENU$	DEC.W	D3	TEST.B	(A2)+OJSILFL+1:#BJSIL15-16	JUMP',BS MMENU$	DEC.W	D3	TEST.B	(A2)+OJSILFL+1:#BJSIL12-16	JUMP',BS MMENU$	DEC.W	D3	TEST.B	(A2)+OJSILFL+1:#BJSIL10-16	JUMP',BS MMENU$	DEC.W	D3	TEST.B	(A2)+OJSILFL+1:#BJSIL08-16	JUMP',BS MMENU$	DEC.W	D3MMENU$:	LOAD.W	D4,D3	CLR.W	D2	TSET.L	D2:D3		; D2 <-- case avec "vu"	CLR.W	D3	LOAD.L	A3,#R16"TMMENU$	CALL	RGIFMMENU2	; choix selon mmenu ...	JUMP',NE EXIT$	TEST.W	D3	JUMP',EQ RIEN$	LOAD.W	D7,#2		; D7 <-- dialogue ncessaire	COMP.W	D3,#7	JUMP',HS EXIT$	DEC.W	D3	TCLR.B	(A2)+OJSILFL+1:#BJSIL05-16	TCLR.B	(A2)+OJSILFL+1:#BJSIL08-16	TCLR.B	(A2)+OJSILFL+1:#BJSIL10-16	TCLR.B	(A2)+OJSILFL+1:#BJSIL12-16	TCLR.B	(A2)+OJSILFL+1:#BJSIL15-16	TCLR.B	(A2)+OJSILFL+1:#BJSIL20-16	TSET.B	(A2)+OJSILFL+1:D3ALL$:	LOAD.W	D7,#1		; D7 <-- faudra tout refaire	JUMP'	EXIT$RIEN$:	CLR.W	D7		; D7 <-- rien  faireEXIT$:	POPM.L	D2..D4,A3	TEST.W	D7		; retour EQ/NE	RETTMMENU$:	.ASCIZ	" "	.B	-1	.ASCIZ	/ interligne x 0.5 <-3>/	.ASCIZ	/     "      x 0.8 <-3>/	.ASCIZ	/     "      x 1   <-3>/	.ASCIZ	/     "      x 1.2 <-3>/	.ASCIZ	/     "      x 1.5 <-3>/	.ASCIZ	/     "      x 2   <-3>/	.B	-1	.ASCIZ	" autre.."	.B	0	.EVEN;---------\\; RGIFMESP >;---------/; Choix dans le mmenu pour l'espacement.; in	A2.L	^table de justification; out	D7.W	0=rien, 1=all, 2=dialogue; mod	D7.WRGIFMESP:	PUSHM.L	D2..D4,A3	CLR.W	D2	TEST.W	(A2)+OJSESPH	JUMP',EQ ESPH$	TSET.L	D2:#0ESPH$:	TEST.W	(A2)+OJSESPB	JUMP',EQ ESPB$	TSET.L	D2:#1ESPB$:	CLR.W	D3	LOAD.L	A3,#R16"TMMENU$	CALL	RGIFMMENU2	; choix selon mmenu ...	JUMP',NE EXIT$	TEST.W	D3	JUMP',EQ RIEN$	LOAD.W	D7,#2		; D7 <-- dialogue ncessaire	COMP.W	D3,#3	JUMP',HS EXIT$	LOAD.L	A3,#(A2)+OJSESPH	DEC.W	D3	JUMP',EQ ESPM$	LOAD.L	A3,#(A2)+OJSESPBESPM$:	TEST.W	(A3)	JUMP',EQ ESPV$	CLR.W	(A3)	JUMP'	ALL$ESPV$:	LOAD.W	(A3),#50*FACMMPTALL$:	LOAD.W	D7,#1		; D7 <-- faudra tout refaire	JUMP'	EXIT$RIEN$:	CLR.W	D7		; D7 <-- rien  faireEXIT$:	POPM.L	D2..D4,A3	TEST.W	D7		; retour EQ/NE	RETTMMENU$:	.ASCIZ	" "	.B	-1	.ASCIZ	" espacement avant <-3>"	.ASCIZ	" espacement aprs <-3>"	.B	-1	.ASCIZ	" autre.."	.B	0	.EVEN;-----------\\; RGIFMMENU1 >;-----------/; Choix d'un nom de justification ou de caractre.; in	D2.W	rang actuel;	A1.L	^routine pour construire le mmenu; out	D2.W	nouveau rang;	D7.W	erreur; mod	D2.L, D7.WRGIFMMENU1:	PUSHM.L	D0,D1,D3..D5,A2..A4	LOAD.W	D0,D2		; D0 <-- rang de l'actuelle	LOAD.L	D4,#500	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^buffer	JUMP,NE EXIT9$	LOAD.L	A2,A4		; A2 <-- ^buffer	LOAD.L	A3,A2		; A3 <-- ^buffer	LOAD.B	(A3+),#SPACE	; buffer <-- case vide	CLR.B	(A3+)	LOAD.B	(A3+),#-1	CALL	(A1)		; buffer <-- construit le mmenu	LOAD.W	D1,D3		; D1 <-- cases grises	DEC.L	A3	LOAD.L	A4,#R16"TLAST$LXFER$:	LOAD.B	(A3+),(A4+)	; buffer <-- dernire case	JUMP,NE LXFER$	CLR.B	(A3)		; buffer <-- terminateur mmenu; Cherche le nom le plus long.	LOAD.L	A3,#(A2)+3	; A3 <-- ^mmenu (aprs la case vide)	CLR.W	D2	CLR.W	D5LGLOOP$:	TEST.B	(A3)	JUMP',EQ LGEND$	CLR.W	D3LGNAME$:	INC.W	D3		; D3 <-- longueur d'un nom	TEST.B	(A3+)	JUMP,NE LGNAME$	INC.W	D5		; D5 <-- nb de cases	COMP.W	D2,D3	JUMP,HS LGLOOP$	LOAD.W	D2,D3		; D2 <-- longueur maximale	JUMP	LGLOOP$LGEND$:	DEC.W	D5		; D5 <-- ne compte pas la case "autre" (dernire); Ajoute un "vu" dans le mmenu.	LOAD.L	A3,#(A2)+3	; A3 <-- ^mmenu (aprs la case vide)VULOOP$:	TEST.B	(A3)	JUMP,EQ MMENU$	DEC.W	D0		; ajoute le "vu" ici ?	JUMP',NS VUCASE$	; oui => VUCASE$VUSKIP$:	TEST.B	(A3+)	JUMP,NE VUSKIP$	JUMP	VULOOP$VUCASE$:	CLR.W	D3VULG$:	INC.W	D3		; D3 <-- lg case o ajouter "vu"	TEST.B	(A3+)	JUMP,NE VULG$	SUB.W	D2,D3	ADD.W	D2,#1+4+1+4	; D2 <-- lg  creuser	CLR.W	D3VUEND$:	INC.W	D3	TEST.B	(A3+)	JUMP',EQ VUEND4$VUEND2$:	INC.W	D3	TEST.B	(A3+)	JUMP,NE VUEND2$	JUMP	VUEND$VUEND4$:	LOAD.L	A4,#(A3)+(D2.W)VUXFER$:	LOAD.B	(-A4),(-A3)	; creuse dans le mmenu !	DEC.W	D3	JUMP,NE VUXFER$	DEC.L	A3	SUB.W	D2,#4+1+4VUSPACE$:	LOAD.B	(A3+),#SPACE	DEC.W	D2	JUMP,NE VUSPACE$	LOAD.B	(A3+),#USEGC	LOAD.B	(A3+),#GCICF	LOAD.B	(A3+),#GCICS	LOAD.B	(A3+),#GCICTP	LOAD.B	(A3+),#ICORGVU	; met le signe "vu"	LOAD.B	(A3+),#USEGC	LOAD.B	(A3+),#GCTXF	LOAD.B	(A3+),#GCTXS	LOAD.B	(A3+),#GCTXT	CLR.B	(A3); Choix selon le mmenu.MMENU$:	LOAD.W	D0,D5		; D0 <-- nb de cases	LOAD.L	A4,#(A5)+OPAMM	CLR.W	(A4)+OMMSEL	RL.L	D1,#1	LOAD.L	(A4)+OMMINA,D1	LOAD.L	A3,A2		; A3 <-- ^mmenu	CLR.L	D5	LIB	?MMENUS		; choix dans mmenu ...	JUMP',NE EXIT$	LOAD.W	D2,(A4)+OMMSEL	DEC.W	D2	JUMP',NS RIEN$	LOAD.W	D7,#2		; D7 <-- dialogue ncessaire	COMP.W	D2,D0	JUMP',HS EXIT$	LOAD.W	D7,#1		; D7 <-- changement	JUMP'	EXIT$RIEN$:	CLR.W	D7		; D7 <-- rien  faireEXIT$:	PUSH.W	D7	LOAD.L	A4,A2	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; rend le buffer	POP.W	D7EXIT9$:	POPM.L	D0,D1,D3..D5,A2..A4	TEST.W	D7		; retour EQ/NE	RETTLAST$:	.B	-1	.ASCIZ	" autre.."	.EVEN;-----------\\; RGIFMMENU2 >;-----------/; Construit un mmenu avec les p'tits "vu".; in	A3.L	^mmenu;	D3.W	case initiale;	D2.W	cases avec "vu"; out	D3.W	case slectionne;	D7.W	erreur; mod	D3.L, D7.WRGIFMMENU2:	PUSHM.L	D2,D4,A3,A4	LOAD.L	A4,#(A5)+OBUDISILOOP$:	TEST.B	(A3)	JUMP',EQ AEND$LLOOP$:	LOAD.B	D4,(A3+)	LOAD.B	(A4+),D4	JUMP,EQ ILOOP$	COMP.B	D4,#USEGC	JUMP',EQ TREE$	COMP.B	D4,#-3	JUMP,NE LLOOP$	DEC.L	A4	RR.W	D2,#1		; faut-il mettre un "vu" ?	JUMP,CC LLOOP$		; non => LLOOP$	LOAD.B	(A4+),#USEGC	LOAD.B	(A4+),#GCICF	LOAD.B	(A4+),#GCICS	LOAD.B	(A4+),#GCICTP	LOAD.B	(A4+),#ICORGVU	; met le signe "vu"	LOAD.B	(A4+),#USEGC	LOAD.B	(A4+),#GCTXF	LOAD.B	(A4+),#GCTXS	LOAD.B	(A4+),#GCTXT	JUMP	LLOOP$TREE$:	LOAD.B	(A4+),(A3+)	; buffer <-- fonte	LOAD.B	(A4+),(A3+)	; buffer <-- style	LOAD.B	(A4+),(A3+)	; buffer <-- taille	JUMP	LLOOP$AEND$:	CLR.B	(A4)	LOAD.L	A3,#(A5)+OBUDIS	LIB	?MMENU		; choix selon mmenu ...	POPM.L	D2,D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; RGIFDRAWT >;==========/; Dessine l'icne de tabulation.; in	A2.L	^table de justification; out	-; mod	D7.WRGIFDRAWT:	PUSHM.L	D1..D4	LOAD.W	D2,#5	CALL	RGIFPOS		; D3/D4 <-- P1/P2 de l'icne	JUMP',NE EXIT$	EX.L	D4,D3	ADD.W	D4,D3	ASR.W	D4,#1	SUB.W	D4,#5+4-1	; chasse espace = 5 !	LOAD.W	D2,#LOADDOT	LOAD.W	D1,(A5)+ORGTAB	COMP.W	D1,#ICORGTABC	JUMP',EQ TWO$	COMP.W	D1,#ICORGTABN	JUMP',EQ TWO$	LOAD.W	D3,#SPACE	CALL	RGICONE	LOAD.W	D3,D1	CALL	RGICONE		; dessine l'icne de tabulation	LOAD.W	D3,#SPACE	CALL	RGICONE	JUMP'	EXIT$TWO$:	INC.W	D4	LOAD.W	D3,#ICORGTABG	CALL	RGICONE	LOAD.W	D3,D1	CALL	RGICONE		; dessine l'icne de tabulationEXIT$:	POPM.L	D1..D4	RET;----------\\; RGIFDRAWC >;==========/; Dessine l'icne du caractre.; in	A2.L	^table de justification; out	-; mod	D7.WRGIFDRAWC:	PUSHM.L	D2..D4	LOAD.W	D2,#4	CALL	RGIFPOS		; D3/D4 <-- P1/P2 de l'icne	JUMP',NE EXIT$	EX.L	D4,D3	ADD.W	D4,D3	ASR.W	D4,#1	SUB.W	D4,#4-1	LOAD.W	D3,#ICORGCHAR	LOAD.W	D2,#LOADDOT	CALL	RGICONE		; dessine l'icne du caractreEXIT$:	POPM.L	D2..D4	RET;----------\\; RGIFDRAWJ >;==========/; Dessine l'icne de justification.; in	A2.L	^table de justification; out	-; mod	D7.WRGIFDRAWJ:	PUSHM.L	D2..D4	LOAD.W	D2,#3	CALL	RGIFPOS		; D3/D4 <-- P1/P2 de l'icne	JUMP',NE EXIT$	EX.L	D4,D3	ADD.W	D4,D3	ASR.W	D4,#1	SUB.W	D4,#4-1	LOAD.W	D3,#ICORGJUSTA	TEST.B	(A2)+OJSMODE:#BJSMDA	JUMP',BS DRAW$	LOAD.W	D3,#ICORGJUSTD	TEST.B	(A2)+OJSMODE:#BJSMDD	JUMP',BS DRAW$	LOAD.W	D3,#ICORGJUSTG	TEST.B	(A2)+OJSMODE:#BJSMDG	JUMP',BS DRAW$	LOAD.W	D3,#ICORGJUSTCDRAW$:	LOAD.W	D2,#LOADDOT	CALL	RGICONE		; dessine l'icne de justificationEXIT$:	POPM.L	D2..D4	RET;----------\\; RGIFDRAWI >;==========/; Dessine l'icne d'interligne.; in	A2.L	^table de justification; out	-; mod	D7.WRGIFDRAWI:	PUSHM.L	D2..D4	LOAD.W	D2,#2	CALL	RGIFPOS		; D3/D4 <-- P1/P2 de l'icne	JUMP',NE EXIT$	EX.L	D4,D3	ADD.W	D4,D3	ASR.W	D4,#1	SUB.W	D4,#4-1	LOAD.W	D3,#ICORGINTERL	LOAD.W	D2,#LOADDOT	CALL	RGICONE		; dessine l'icne d'interligneEXIT$:	POPM.L	D2..D4	RET;----------\\; RGIFDRAWE >;==========/; Dessine l'icne d'espacement.; in	A2.L	^table de justification; out	-; mod	D7.WRGIFDRAWE:	PUSHM.L	D2..D4	LOAD.W	D2,#1	CALL	RGIFPOS		; D3/D4 <-- P1/P2 de l'icne	JUMP',NE EXIT$	EX.L	D4,D3	ADD.W	D4,D3	ASR.W	D4,#1	SUB.W	D4,#4-1	LOAD.W	D3,#ICORGESPACE	LOAD.W	D2,#LOADDOT	CALL	RGICONE		; dessine l'icne d'espacementEXIT$:	POPM.L	D2..D4	RET;--------\\; RGIFDET >;========/; Dtecte dans quelle icne est la souris.; in	D4.L	position (y;x); out	D2.W	rang de l'icne (0..n);	D7.W	erreur; mod	D2.L, D7.WRGIFDET:	PUSHM.L	D0,D1,D3,D4	LOAD.W	D0,D4		; D0 <-- position en X	LOAD.L	D1,D4	SWAP.W	D1		; D1 <-- position en Y	CLR.W	D2LOOP$:	CALL	RGIFPOS		; D3/D4 <-- P1/P2 de l'icne	JUMP',NE ERROR$	COMP.W	D0,D3	JUMP',LT NEXT$	COMP.W	D0,D4	JUMP',GE NEXT$	SWAP.W	D3	SWAP.W	D4	COMP.W	D1,D3	JUMP',LT NEXT$	COMP.W	D1,D4	JUMP',LT EXIT$NEXT$:	INC.W	D2	JUMP	LOOP$ERROR$:	LOAD.W	D2,#-1	LOAD.W	D7,#ERDIOUTEXIT$:	POPM.L	D0,D1,D3,D4	TEST.W	D7		; retour EQ/NE	RET;--------\\; RGIFINV >;========/; Inverse une icne.; in	D2.W	rang de l'icne (0..n); out	-; mod	D7.WRGIFINV:	PUSHM.L	D2..D4	COMP.W	D2,#-1	JUMP',EQ EXIT$	LOAD.L	D4,#-1	CALL	RGMDEF	CALL	RGIFPOS		; D3/D4 <-- P1/P2 de l'icne	JUMP',NE EXIT$	LOAD.W	D2,#INVDOT	CALL	RGTRAME		; inverse l'icneEXIT$:	POPM.L	D2..D4	RET;--------\\; RGIFPOS >;========/; Calcule la position et les dimensions d'une icne.; in	D2.W	rang de l'icne (0..n); out	D3.L	coin sup/gauche (y;x);	D4.L	coin inf/droite (y;x);	D7.W	erreur; mod	D3.L, D4.L, D7.WRGIFPOS:	PUSH.L	D2	LOAD.W	D7,#1	COMP.W	D2,#6	JUMP',HS EXIT$	TEST.W	D2	JUMP',EQ NAME$	LOAD.L	D3,#H'10000*1	LOAD.W	D3,(A5)+ORGDIM+2	MUL.WU	D2,#GCICX	SUB.W	D3,D2	COMP.W	D3,#GCICXN	; dpasse sur le nom ?	JUMP',LT EXIT$		; oui => EXIT$	LOAD.L	D4,#H'10000*GCICH+(GCICX-1)	JUMP'	OK$NAME$:	LOAD.L	D3,#H'10000*1+1	LOAD.L	D4,#H'10000*GCICH+(GCICXN-1)OK$:	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	ADD.W	D4,D3	SWAP.W	D3	SWAP.W	D4	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	D2	TEST.W	D7		; retour EQ/NE	RET;----------\\; RGTABMOVE >;==========/; Dplace un tabulateur.; in	D3.W	icne (ICORGTAB?); out	D4.W	nouvelle position (x)  [obj];	D7.W	erreur; mod	D4.L, D7.WRGTABMOVE:	PUSHM.L	D2,D3,D5	LOAD.W	D2,D3		; D2 <-- icne	CALL	RGIFMOUSE	; D4 <-- position de la souris	JUMP,NE EXIT$	CALL	RGTABINV	; allume le premier tabulateur	LOAD.L	D5,D4LOOP$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris dplace ?	JUMP',NE END$	CALL	RGIFMOUSE	; D4 <-- position de la souris	EX.L	D4,D5	CALL	RGTABINV	; teint le tabulateur	LOAD.L	D4,D5	CALL	RGTABINV	; allume le tabulateur	PUSH.W	D2	LOAD.W	D2,#3		; D2 <-- tabulateur	CALL	RGIMPAS		; D4 <-- position selon le pas [obj]	CALL	RGIMAFPOS	; affiche la position	POP.W	D2	JUMP	LOOP$END$:	LOAD.L	D4,D5	CALL	RGTABINV	; teint le dernier tabulateur	LOAD.W	D7,#1	SWAP.W	D4	COMP.W	D4,#GCICH+1	JUMP',LT EXIT$	COMP.W	D4,#GCICH+1+GCICH+1+8	JUMP',GE EXIT$	SWAP.W	D4	CALL	RGCONVSCROBJ	; D4 <-- position [obj]	LOAD.W	D7,#1	LOAD.L	A4,(A5)+ORGLJU	; A4 <-- ^table de justification	COMP.W	D4,(A4)+OJSESPG	JUMP',LT EXIT$	LOAD.W	D3,(A5)+ORGLLG	SUB.W	D3,(A4)+OJSESPD	COMP.W	D4,D3	JUMP',GE EXIT$	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D2,D3,D5	TEST.W	D7		; retour EQ/NE	RET;---------\\; RGTABINV >;---------/; Inverse un tabulateur en dplacement.; in	D2.W	icne;	D4.L	position (y;x)  [scr]; out	-; mod	D7.WRGTABINV:	PUSHM.L	D2..D4	SWAP.W	D4	SUB.W	D4,#8		; D4 <-- coin sup/gauche de l'icne	SWAP.W	D4	LOAD.W	D3,D2	LOAD.W	D2,#1	COMP.W	D3,#ICORGTABD	JUMP',EQ ONE$	LOAD.W	D2,#3	COMP.W	D3,#ICORGTABI	JUMP',EQ ONE$	LOAD.W	D2,#7	COMP.W	D3,#ICORGTABG	JUMP',NE TWO$ONE$:	SUB.W	D4,D2	LOAD.W	D2,#INVDOT	CALL	RGICONE		; inverse un tabulateur	JUMP'	EXIT$TWO$:	INC.W	D4	LOAD.W	D2,#INVDOT	CALL	RGICONE		; inverse un tabulateur	LOAD.W	D3,#ICORGTABG	SUB.W	D4,#8+8	CALL	RGICONE		; inverse un tabulateurEXIT$:	POPM.L	D2..D4	RET;---------\\; RGTABADD >;=========/; Ajoute un tabulateur dans une table de justification.; in	A4.L	^table de justification;	D4.W	position [obj];	D3.W	icne (ICORGTAB?); out	D7.W	erreur; mod	D7.WRGTABADD:	PUSHM.L	D1,D2,A2,A3	LOAD.L	A3,#(A4)+OJSTABS	CLR.W	D1SRC$:	TEST.L	(A3)		; fin de la table ?	JUMP',EQ INS$	COMP.W	D4,(A3)	JUMP',EQ REPLACE$	JUMP',LO INS$	ADD.L	A3,#4		; A3 <-- ^tabulateur suivant	INC.W	D1	JUMP	SRC$INS$:	CLR.W	D2INS2$:	INC.W	D2	INC.W	D1	TEST.L	(A3+)	JUMP,NE INS2$	LOAD.W	D7,#1	COMP.W	D1,#JSMAXTAB	JUMP',HI EXIT$	LOAD.L	A2,#(A3)+4XFER$:	LOAD.L	(-A2),(-A3)	DEC.W	D2	JUMP,NE XFER$REPLACE$:	LOAD.W	(A3+),D4	LOAD.W	(A3),D3	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1,D2,A2,A3	TEST.W	D7		; retour EQ/NE	RET;---------\\; RGTABSUB >;=========/; Enlve un tabulateur dans une table de justification.; in	A4.L	^table de justification;	D4.W	position [obj]; out	D3.W	icne (ICORGTAB?);	D7.W	erreur; mod	D3.L, D7.WRGTABSUB:	PUSHM.L	A2,A3	LOAD.L	A3,#(A4)+OJSTABS	LOAD.W	D7,#1SRC$:	TEST.L	(A3)		; fin de la table ?	JUMP',EQ EXIT$	COMP.W	D4,(A3)	JUMP',EQ KILL$	ADD.L	A3,#4		; A3 <-- ^tabulateur suivant	JUMP	SRC$KILL$:	LOAD.W	D3,(A3)+2	; D3 <-- icne	LOAD.L	A2,#(A3)+4XFER$:	LOAD.L	(A3+),(A2+)	JUMP,NE XFER$	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	A2,A3	TEST.W	D7		; retour EQ/NE	RET;----------\\; RGIFMOUSE >;==========/; Lit la position de la souris.; in	-; out	D4.L	position;	D7.W	erreur; mod	D4.L, D7.WRGIFMOUSE:	PUSH.L	D3	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP',NE EXIT$	SUB.W	D4,(A0)+ODFFX	SUB.W	D4,(A5)+ORGORI+2	JUMP',NC OKX$	LOAD.W	D7,#ERDIOUTOKX$:	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	SUB.W	D4,(A5)+ORGORI+0	JUMP',NC OKY$	LOAD.W	D7,#ERDIOUTOKY$:	SWAP.W	D4	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;--------\\; RGMDEF  >;========/; Dfini la demi-trame super-rapidement.; in	D4.L	demi-trame; out	-; mod	D7.WRGMDEF:	LOAD.L (A0)+ODFTRA+0,D4	LOAD.L (A0)+ODFTRA+4,D4;;?	CLR.L	(A0)+ODFTPM	; annule XTRAME	RET;--------\\; RGTRAME >;========/; Dessine une trame dans une rgle.; in	D3.L	coin sup/gauche (y;x);	D4.L	coin inf/droite (y;x);	D2.W	mode de dessin; out	-; mod	D7.WRGTRAME:	PUSHM.L	D3,D4	SUB.W	D4,D3	ADD.W	D3,(A5)+ORGORI+2	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	ADD.W	D3,(A5)+ORGORI+0	SWAP.W	D3	SWAP.W	D4	LIB	?DRTRAME	POPM.L	D3,D4	RET;--------\\; RGRECT  >;========/; Dessine un rectangle dans une rgle.; in	D3.L	coin sup/gauche (y;x);	D4.L	coin inf/droite (y;x);	D2.W	mode de dessin; out	-; mod	D7.WRGRECT:	PUSHM.L	D3,D4	SUB.W	D4,D3	ADD.W	D3,(A5)+ORGORI+2	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	ADD.W	D3,(A5)+ORGORI+0	SWAP.W	D3	SWAP.W	D4	LIB	?DRRECT	POPM.L	D3,D4	RET;--------\\; RGLINE  >;========/; Dessine une ligne dans une rgle.; in	D3.L	dpart (y;x);	D4.L	arrive (y;x);	D2.W	mode de dessin; out	-; mod	D7.WRGLINE:	PUSHM.L	D3,D4	SUB.W	D4,D3	ADD.W	D3,(A5)+ORGORI+2	SWAP.W	D3	SWAP.W	D4	SUB.W	D4,D3	ADD.W	D3,(A5)+ORGORI+0	SWAP.W	D3	SWAP.W	D4	LIB	?DRSEG	POPM.L	D3,D4	RET;--------\\; RGTEXT  >;========/; Affiche tout un texte.; in	A3.L	^texte <0>;	D2.W	mode de dessin;	D3.W	lg maximale;	D4.L	coin sup/gauche (y;x); out	-; mod	D7.WRGTEXT:	PUSHM.L	D3..D5,A3	LOAD.W	D5,D3		; D5 <-- lg maximale	ADD.W	D5,D4		; D5 <-- max  ne pas dpasser	SUB.W	D5,#8LOOP$:	LOAD.B	D3,(A3+)	; D3 <-- un caractre	JUMP',EQ EXIT$	COMP.W	D4,D5		; dpasse  droite ?	JUMP',GE EXIT$		; oui => EXIT$	CALL	RGICONE		; affiche un caractre	JUMP	LOOP$EXIT$:	POPM.L	D3..D5,A3	RET;--------\\; RGICONE >;========/; Affiche une icne de IPP07.; in	D2.W	mode de dessin;	D3.B	caractre (0..127);	D4.L	coin sup/gauche (y;x); out	D4.L	coin sup/gauche suivant; mod	D4.L, D7.WRGICONE:	PUSHM.L	D0..D3,D5,A1..A4	LOAD.W	D7,#MI_CCMO	PAGE_	MISC		; enlve la souris	PUSH.L	D4	ADD.W	D4,(A5)+ORGORI+2	SWAP.W	D4	ADD.W	D4,(A5)+ORGORI+0	SWAP.W	D4	CLR.W	D0	LOAD.B	D0,D3	LOAD.L	A1,(A5)+OPPICO	; A1 <-- ^gencar IPP07	LOAD.L	A3,#(A1)+OGCWID+128*3	LOAD.W	D3,D0	MUL.WU	D3,(A1)+OGCMSB	ADD.L	A3,D3		; A3 <-- ^source (matrice)	CLR.L	D3		; D3 <-- position source	CLR.W	D5	LOAD.B	D5,(A1)+OGCMWB	; D5 <-- Iy source	LOAD.L	A4,#0		; A4 <-- ^destination (cran);	LOAD.L	D4,D4		; D4 <-- position destination	LOAD.W	D1,D2		; D1 <-- mode	LOAD.W	D2,(A1)+OGCMHD	; D2 <-- hauteur	SWAP.W	D2	LOAD.L	A1,#(A1)+OGCWID	CLR.W	D2	LOAD.B	D2,(A1)+(D0.W)	; D2 <-- largeur	LOAD.L	A2,A0	GRA_	RASTER		; affiche une icne	POP.L	D4	ADD.W	D4,D2		; D4 <-- position suivante	POPM.L	D0..D3,D5,A1..A4	RET;----------\\; RGCONVPAS >;==========/; Conversion selon le pas.; in	D4.W	valeur [obj]; out	D4.W	valeur [obj]; mod	D4.LRGCONVPAS:	ADD.W	D4,#(10*FACMMPT)/2	CONV.LA.WA D4	DIV.WA	D4,#10*FACMMPT	MUL.WA	D4,#10*FACMMPT	; D4 <-- pas de 1mm	RET;-------------\\; RGCONVSCROBJ >;=============/; Conversion [scr] -> [obj].; in	D4.W	valeur [scr]; out	D4.W	valeur [obj]; mod	D4.W, D7.WRGCONVSCROBJ:	SWAP.W	D4	PUSH.W	D4	SWAP.W	D4	SUB.W	D4,#3	LOAD.W	D7,#MA_SCALEN	PAGE_	MATH		; D4 <-- dimensions [obj]	SWAP.W	D4	POP.W	D4	SWAP.W	D4	RET;---------\\; RGSAVWDO >;---------/; Sauve le contenu de la swdo.; in	D3.L	P1 (y;x)  [obj];	D4.L	P2 (y;x)  [obj]; out	D7.W	erreur; mod	D7.WRGSAVWDO:	PUSHM.L	D1..D6,A2..A4	CLR.W	D7		; D7 <-- ok	TEST.L	(A5)+ORGPSV	; dj sauv ?	JUMP,NE EXIT$		; oui => EXIT$	LOAD.W	D7,#DR_SCOPENPLY	PAGE_	DRAW		; dbut du dessin dans l'cran	JUMP,NE EXIT$	LOAD.W	D4,(A0)+ODFFDX	ADD.W	D4,#16-1	SR.W	D4,#4	SL.W	D4,#1	TEST.B	(A0)+ODFCMD	JUMP',EQ NOCOUL$	SL.W	D4,#2		; D4 <-- largeur *4NOCOUL$:	LOAD.W	D6,D4		; D6 <-- Iy destination	MUL.WU	D4,(A0)+ODFFDY	ADD.L	D4,#32	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- demande mmoire pour le bitmap	JUMP',NE ERROR$	LOAD.L	(A5)+ORGPSV,A4	LOAD.W	D7,#MI_CCMO	PAGE_	MISC		; enlve la souris	LOAD.L	A3,#0		; A3 <-- ^source (cran)	CLR.L	D3		; D3 <-- origine source	CLR.W	D5	CLR.L	D4		; D4 <-- origine destination	LOAD.L	D2,(A0)+ODFFDY	; D2 <-- dimensions	LOAD.L	A2,A0	TEST.B	(A0)+ODFCMD	JUMP',NE COUL$	LOAD.W	D1,#LOADDOT	GRA_	RASTER		; mmoire <-- cran	JUMP'	OK$COUL$:	LOAD.W	D1,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	GRA_	CRASTER		; mmoire <-- cran couleurOK$:	CLR.W	D7		; D7 <-- okERROR$:	PUSH.W	D7	LOAD.W	D7,#DR_SCCLOSE	PAGE_	DRAW		; fin du dessin dans l'cran	POP.W	D7EXIT$:	POPM.L	D1..D6,A2..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; RGGETWDO >;---------/; Restitue le contenu de la swdo.; in	D3.L	P1 (y;x)  [obj];	D4.L	P2 (y;x)  [obj]; out	-; mod	D7.WRGGETWDO:	PUSHM.L	D1..D6,A2..A4	TEST.L	(A5)+ORGPSV	; bitmap sauv existe ?	JUMP,EQ EXIT$		; non => EXIT$	LOAD.W	D7,#DR_SCOPENPLY	PAGE_	DRAW		; dbut du dessin dans l'cran	JUMP,NE EXIT$	LOAD.W	D7,#MI_CCMO	PAGE_	MISC		; enlve la souris	LOAD.L	A3,(A5)+ORGPSV	; A3 <-- ^source (mmoire)	CLR.L	D3		; D3 <-- origine source	LOAD.W	D5,(A0)+ODFFDX	ADD.W	D5,#16-1	SR.W	D5,#4	SL.W	D5,#1		; D5 <-- Iy source	TEST.B	(A0)+ODFCMD	JUMP',EQ NOCOUL$	SL.W	D5,#2		; D5 <-- largeur *4NOCOUL$:	LOAD.L	A4,#0		; A4 <-- ^destination (cran)	CLR.L	D4		; D4 <-- origine destination	LOAD.L	D2,(A0)+ODFFDY	; D2 <-- dimensions	LOAD.L	A2,A0	TEST.B	(A0)+ODFCMD	JUMP',NE COUL$	LOAD.W	D1,#LOADDOT	GRA_	RASTER		; cran <-- mmoire	JUMP'	GIVMEM$COUL$:	LOAD.W	D1,#LOADDOT!2^BSRCCOUL!2^BDSTCOUL	GRA_	CRASTER		; cran <-- mmoire couleurGIVMEM$:	LOAD.L	A4,A3	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire pour le bitmap	CLR.L	(A5)+ORGPSV	; plus de bitmap sauv	LOAD.W	D7,#DR_SCCLOSE	PAGE_	DRAW		; fin du dessin dans l'cranEXIT$:	POPM.L	D1..D6,A2..A4	RET	.END