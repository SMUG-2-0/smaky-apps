	.SBTTL	OPPENMATRIX.ASI;-----------\\; XopDGETDIM >;===========/; Donne les demi-dimensions du pinceau d'un objet.; in	A0.L	canal;	A4.L	^table des pinceaux/nil si par dfaut;	D3.W	numro du pinceau; out	D4.L	demi-dimensions du pinceau (dy;dx);	D7.W	erreur; mod	D4.L, D7.WXopDGETDIM:	PUSHM.L	D3,A4,A5	LOAD.L	A5,A0		; A5 <-- ^variables globales	COMP.L	A4,#0		; objet par dfaut ?	JUMP',NE NODEF$		; non => NODEF$	LOAD.L	A4,(A5)+OPDEF	; A4 <-- ^objet pinceau par dfautNODEF$:	MUL.WU	D3,#LDPEN	LOAD.L	D4,(A4)+(D3.L)+OPENLY ; D4 <-- dimensions	SR.W	D4,#1	INC.W	D4	SWAP.W	D4	SR.W	D4,#1	INC.W	D4	SWAP.W	D4	POPM.L	D3,A4,A5	CLR.W	D7		; retour EQ	RET;-----------\\; XopDGETUSE >;===========/; Donne le pinceau utilis.; in	A0.L	canal; out	D3.W	numro du pinceau utilis;	D7.W	erreur; mod	D3.L, D7.WXopDGETUSE:	LOAD.W	D3,(A0)+OPUSE	; D3 <-- pinceau utilis	CLR.W	D7		; D7 <-- ok	RET;--------\\; XopDUSE >;========/; Utilise la bonne matrice pour le pinceau.; in	A0.L	canal;	A4.L	^table des pinceaux/nil si par dfaut;	D3.W	numro du pinceau;	D2.W	mode initial; out	D2.W	mode v. avec pinceau (-1 si rien);	D7.W	erreur; mod	D2.L, D7.WXopDUSE:	PUSHM.L	D1,D3,D4,A0,A3..A5	LOAD.L	A5,A0		; A5 <-- ^variables globales	LOAD.L	A0,(A5)+OPDDIS	; A0 <-- ^descripteur fentre	LOAD.W	(A5)+OPUSE,D3	; OPUSE <-- pinceau utilis	LOAD.W	D7,#DR_GETPRINT	PAGE_	DRAW		; D4 <-- mode d'impression	TEST.L	D4:#BPRIPS	; impression PostScript ?	JUMP,BS OK$		; oui => OK$	COMP.L	A4,#0		; objet par dfaut ?	JUMP',NE NODEF$		; non => NODEF$	LOAD.L	A4,(A5)+OPDEF	; A4 <-- ^objet pinceau par dfautNODEF$:	LOAD.L	A3,A4		; A3 <-- ^table des pinceaux	TEST.L	(A5)+OPMAT	JUMP',EQ GIVE$	LOAD.L	A4,(A5)+OPMAT	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	CLR.L	(A5)+OPMATGIVE$:	MUL.WU	D3,#LDPEN	ADD.L	A3,D3		; A3 <-- ^pinceau	TEST.W	(A3)+OPENLX	; pinceau nul ?	JUMP',EQ NUL$	TEST.W	(A3)+OPENLY	; pinceau nul ?	JUMP',NE NONUL$		; non => NONUL$NUL$:	LOAD.W	D2,#-1		; D2 <-- mode spcial (rien)	JUMP	OK$NONUL$:	LOAD.L	D4,(A3)+OPENLY	; D3 <-- dimensions	LOAD.W	D7,#MA_SCALEP	PAGE_	MATH		; D4 <-- plus grand si n:1	TEST.W	D4		; largeur nulle ?	JUMP',NE NULX$	INC.W	D4NULX$:	SWAP.W	D4	TEST.W	D4		; hauteur nulle ?	JUMP',NE NULY$	INC.W	D4NULY$:	SWAP.W	D4	COMP.L	D4,#H'10000*1+1	; pinceau de 1x1 ?	JUMP',EQ UNUN$		; oui => UNUN$	LOAD.L	D3,(A3)+OPENFA	; D3 <-- fanions	CALL	MATPENCREATE	; A4 <-- ^matrice	JUMP,NE EXIT$	LOAD.L	(A5)+OPMAT,A4	CALL	MATPENUSE	; utilise le pinceau	OR.W	D2,#PENDOTUNUN$:	TEST.B	(A3)+OPENFA+2:#BPENTT-8	JUMP,BC COLOR$	LOAD.L	A4,A3		; A4 <-- ^pinceau	LOAD.L	A3,(A5)+OPDDIS	; A3 <-- ^descripteur fentre	CLR.W	(A3)+ODFPTO	LOAD.L	D4,(A4)+OPENT1	TEST.W	D4	JUMP',NC V1$	CLR.W	D4V1$:	SWAP.W	D4	TEST.W	D4	JUMP',NC T1$	CLR.W	D4T1$:	SWAP.W	D4	LOAD.W	D7,#MA_SCALEP	PAGE_	MATH		; D4 <-- plus grand si n:1	SWAP.W	D4	TEST.W	D4	JUMP',NE T1N$	INC.W	D4T1N$:	SWAP.W	D4	LOAD.L	(A3)+ODFPT1,D4	; <p1> et <v1>	LOAD.L	D4,(A4)+OPENT3	TEST.W	D4	JUMP',NC V2$	CLR.W	D4V2$:	SWAP.W	D4	TEST.W	D4	JUMP',NC T2$	CLR.W	D4T2$:	SWAP.W	D4	LOAD.W	D7,#MA_SCALEP	PAGE_	MATH		; D4 <-- plus grand si n:1	SWAP.W	D4	TEST.W	D4	JUMP',NE T2N$	INC.W	D4T2N$:	SWAP.W	D4	LOAD.L	(A3)+ODFPT3,D4	; <p2> et <v2>	LOAD.L	D4,(A4)+OPENT5	TEST.W	D4	JUMP',NC V3$	CLR.W	D4V3$:	SWAP.W	D4	TEST.W	D4	JUMP',NC T3$	CLR.W	D4T3$:	SWAP.W	D4	LOAD.W	D7,#MA_SCALEP	PAGE_	MATH		; D4 <-- plus grand si n:1	SWAP.W	D4	TEST.W	D4	JUMP',NE T3N$	INC.W	D4T3N$:	SWAP.W	D4	LOAD.L	(A3)+ODFPT5,D4	; <p3> et <v3>	CLR.L	(A3)+ODFPT7	; <p4> et <v4>	LOAD.L	A3,A4		; A3 <-- ^pinceau	OR.W	D2,#TTTDOTCOLOR$:	CALL	MATPENCOLOR	; utilise la bonne couleurOK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1,D3,D4,A0,A3..A5	TEST.W	D7		; retour EQ/NE	RET;------------\\; MATPENCOLOR >;------------/; Utilise la bonne couleur pour un pinceau.; in	A3.L	^pinceau;	D2.W	mode de dessin; out	-; mod	D7.WMATPENCOLOR:	PUSHM.L	D0..D4,A0,A4	LOAD.L	A0,(A5)+OPDDIS	; A0 <-- ^descripteur fentre	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ EXIT$		; non => EXIT$	AND.B	D2,#B'11	COMP.B	D2,#CLRDOT	JUMP',EQ CLR$	LOAD.W	D3,(A3)+OPENCO	LOAD.W	D2,#SETDOT	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D0,#IDENTCOLOR	LOAD.W	D1,#opDUSE	PAGE_	OBJCALL		; choisi la couleur pour dessiner	JUMP'	EXIT$CLR$:	LOAD.L	D4,#-1		; D4 <-- couleur du fond de la page (COLORFPAGE)	LOAD.W	D7,#DR_COLORINIT	PAGE_	DRAW		; spcifie les couleursEXIT$:	POPM.L	D0..D4,A0,A4	RET;----------\\; MATPENUSE >;----------/; Utilise un pinceau.; in	D4.L	dimensions (dy;dx);	A4.L	^matrice; out	-; mod	D7.WMATPENUSE:	PUSHM.L	D3,A3	LOAD.L	A3,(A5)+OPDDIS	; A3 <-- ^descripteur fentre	CLR.L	(A3)+ODFPPO	; ODFP <-- position	LOAD.L	(A3)+ODFPPM,A4	; ODFP <-- ^matrice	LOAD.W	D3,D4	ADD.W	D3,#16-1	SR.W	D3,#4		; D3 <-- largeur en words	SL.W	D3,#1		; D3 <-- largeur en bytes	LOAD.W	(A3)+ODFPII,D3	; ODFP <-- incrment ligne	LOAD.L	(A3)+ODFPDI,D4	; ODFP <-- dimensions	POPM.L	D3,A3	RET;-------------\\; MATPENCREATE >;-------------/; Cre la matrice d'un pinceau.; in	D4.L	dimensions (dy;dx);	D3.W	fanions; out	A4.L	^matrice;	D7.W	erreur; mod	D7.W, A4.LMATPENCREATE:	PUSHM.L	D0..D4,A2	LOAD.W	D0,D4		; D0 <-- dx	LOAD.L	D2,D4	SWAP.W	D2		; D2 <-- dy	LOAD.W	D4,D0		; D4 <-- dx	ADD.W	D4,#16-1	SR.W	D4,#4		; D4 <-- largeur en words	SL.W	D4,#1		; D4 <-- largeur en bytes	MUL.WU	D4,D2		; D4 <-- nb de bytes ncessaires	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour matrice	JUMP,NE EXIT$	GESMEM	?CLEARMEM	; met toute la matrice  zro	LOAD.W	D4,D2	SWAP.W	D4	LOAD.W	D4,D0		; D4 <-- dimensions	CALL	OPEDITMAT	; A2 <-- ^descripteur temporaire	TEST.L	D3:#BPENCA	JUMP',BS SQUARE$	TEST.L	D3:#BPENRE	JUMP',BS SQUARE$				; pinceau circulaire/elliptique =>	COMP.W	D0,#5	JUMP',LO SQUARE$	COMP.W	D2,#5	JUMP',LO SQUARE$	LOAD.W	D3,D2	SR.W	D3,#1	SWAP.W	D3	LOAD.W	D3,D0	SR.W	D3,#1		; D3 <-- demi-dimensions	LOAD.L	D4,D3	LOAD.W	D2,#-1		; D2 <-- tous les octants	LOAD.W	D1,#SETDOT	GRA_	ELLIPSE	LOAD.L (A2)+ODFTRA+0,#-1	LOAD.L (A2)+ODFTRA+4,#-1	GRA_	FILLO		; rempli l'intrieur de l'ellipse	GRA_	FILLC	JUMP'	OK$SQUARE$:			; pinceau carr/rectangulaire =>	CLR.L	D4	LOAD.W	D3,D2	SWAP.W	D3	LOAD.W	D3,D0		; D3 <-- dimensions	LOAD.W	D1,#SETDOT	PUSH.L	A4	LOAD.L	A4,#R16"TRAME$	GRA_	TRAME		; dessine le pinceau rectangulaire	POP.L	A4OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D4,A2	TEST.W	D7		; retour EQ/NE	RETTRAME$:	.B	-1,-1,-1,-1,-1,-1,-1,-1	.EVEN;----------\\; OPEDITMAT >;==========/; Initialise le descripteur temporaire pour pouvoir dessiner; directement dans la matrice principale.; in	A4.L	^matrice o dessiner;	D4.L	dimensions (dy;dx); out	A2.L	^descripteur temporaire; mod	D7.W, A2.LOPEDITMAT:	PUSH.L	D4	LOAD.L	A2,#(A5)+OTDDIS	; A2 <-- ^descripteur temporaire	LOAD.L	(A2)+ODFABS,A4	CLR.L	(A2)+ODFY	LOAD.L	(A2)+ODFDY,D4	CLR.L	(A2)+ODFFY	LOAD.L	(A2)+ODFFDY,D4	CLR.L	(A2)+ODFWBY	LOAD.L	(A2)+ODFWEY,D4	LOAD.W	(A2)+ODFIIX,#1	ADD.W	D4,#16-1	AND.B	D4,#B'11110000	SR.W	D4,#3	LOAD.W	(A2)+ODFIIY,D4	LOAD.B	(A2)+ODFMGR,#GRACLIP ; graphique avec clipping	LOAD.B	(A2)+ODFNOW,#-1	; on est pas dans $DIS_0	LOAD.L	(A2)+ODFBAS,(A0)+ODFBAS ; pour FILLO/FILLC !!!	POP.L	D4	RET	.END