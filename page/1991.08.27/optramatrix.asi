	.SBTTL	OPTRAMATRIX.ASI;-----------\\; XopDGETUSE >;===========/; Donne la trame utilise.; in	A0.L	canal; out	D3.W	numro de la trame utilise;	D7.W	erreur; mod	D3.L, D7.WXopDGETUSE:	LOAD.W	D3,(A0)+OTUSE	; D3 <-- trame utilise	TCLR.L	D3:#15	CLR.W	D7		; D7 <-- ok	RET;--------\\; XopDUSE >;========/; Utilise la bonne matrice pour la trame.; in	A0.L	canal;	A4.L	^table des pinceaux/nil si par dfaut;	D3.W	numro de la trame (si 2^15=1, pas d'offset);	D2.W	mode initial; out	D2.W	mode selon transparence (-1 si rien);	D7.W	erreur; mod	D2.L, D7.WXopDUSE:	PUSHM.L	D1,D3,D4,A0,A3..A5	LOAD.L	A5,A0		; A5 <-- ^variables globales	LOAD.L	A0,(A5)+OPDDIS	; A0 <-- ^descripteur fentre	LOAD.W	(A5)+OTUSE,D3	; OTUSE <-- trame utilise	LOAD.W	D7,#DR_GETPRINT	PAGE_	DRAW		; D4 <-- mode d'impression	TEST.L	D4:#BPRIPS	; impression PostScript ?	JUMP,BS OK$		; oui => OK$	COMP.L	A4,#0		; objet par dfaut ?	JUMP',NE NODEF$		; non => NODEF$	LOAD.L	A4,(A5)+OPDEF	; A4 <-- ^objet trame par dfautNODEF$:	LOAD.L	A3,A4		; A3 <-- ^table des trames	TEST.L	(A5)+OPMAT	JUMP',EQ GIVE$	LOAD.L	A4,(A5)+OPMAT	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM	CLR.L	(A5)+OPMATGIVE$:	LOAD.W	D1,D3	TCLR.L	D3:#15	MUL.WU	D3,#LDTRA	ADD.L	A3,D3		; A3 <-- ^trame	LOAD.L	D3,(A3)+OTRAFA	; D3 <-- fanions	TEST.L	D3:#BTRATR	; trame transparente ?	JUMP',BC NONUL$		; non => NONUL$	TEST.L	D3:#BTRAGR	; trame points ?	JUMP',BC NONUL$		; non => NONUL$	TEST.W	(A3)+OTRAGP	; intensit = 0% ?	JUMP',NE NONUL$		; non => NONUL$	CLR.L	D4	CALL	DRMDEF	LOAD.W	D2,#-1		; D2 <-- mode spcial (rien)	JUMP'	OK$NONUL$:	CALL	MATTRACREATE	; A4 <-- ^matrice	JUMP',NE EXIT$	LOAD.L	(A5)+OPMAT,A4	CALL	MATTRAUSE	; utilise la trame	CALL	MATTRACOLOR	; utilise la bonne couleur	TEST.L	D3:#BTRATR	; trame transparente ?	JUMP',BS OK$		; oui => OK$	COMP.W	D2,#SETDOT	JUMP',EQ OPAQ$	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ OK$		; non => OK$	COMP.W	D2,#CLRDOT	JUMP',NE OK$OPAQ$:	LOAD.W	D2,#LOADDOT	; D2 <-- mode "load" si opaqueOK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1,D3,D4,A0,A3..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; MATTRAUSE >;----------/; Utilise une trame.; in	D4.L	dimensions (dy;dx);	A4.L	^matrice;	D1.W	pas d'offset si 2^15=1; out	-; mod	D7.WMATTRAUSE:	PUSH.L	D3	CLR.L	(A0)+ODFTPO	; ODFTPO <-- position	LOAD.L	(A0)+ODFTPM,A4	; ODFTPM <-- ^matrice	LOAD.W	D3,D4	ADD.W	D3,#16-1	SR.W	D3,#4		; D3 <-- largeur en words	SL.W	D3,#1		; D3 <-- largeur en bytes	LOAD.W	(A0)+ODFTII,D3	; ODFTII <-- incrment ligne	LOAD.L	(A0)+ODFTDI,D4	; ODFTDI <-- dimensions	CLR.L	D3	TEST.L	D1:#15		; pas d'offset ?	JUMP',BS OFFSET$	; oui => OFFSET$	LOAD.W	D7,#DR_GETOFTRAME	PAGE_	DRAW		; D3 <-- offset pour trameOFFSET$:	LOAD.L	(A0)+ODFTOR,D3	; ODFTOR <-- origine motif	POP.L	D3	RET;------------\\; MATTRACOLOR >;------------/; Utilise la bonne couleur pour une trame.; in	A3.L	^trame;	D2.W	mode de dessin; out	-; mod	D7.WMATTRACOLOR:	PUSHM.L	D0..D4,A0,A4	LOAD.L	A0,(A5)+OPDDIS	; A0 <-- ^descripteur fentre	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP',EQ EXIT$		; non => EXIT$	COMP.B	D2,#CLRDOT	JUMP',EQ CLR$	LOAD.W	D3,(A3)+OTRACC	LOAD.W	D2,#SETDOT	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D0,#IDENTCOLOR	LOAD.W	D1,#opDUSE	PAGE_	OBJCALL		; choisi la couleur pour dessiner	LOAD.W	D3,(A3)+OTRACF	LOAD.W	D2,#CLRDOT;	LOAD.L	A4,#0		; A4 <-- objet par dfaut;	LOAD.W	D0,#IDENTCOLOR;	LOAD.W	D1,#opDUSE	PAGE_	OBJCALL		; choisi la couleur pour effacer	JUMP'	EXIT$CLR$:	LOAD.L	D4,#-1		; D4 <-- couleur du fond de la page (COLORFPAGE)	LOAD.W	D7,#DR_COLORINIT	PAGE_	DRAW		; spcifie les couleursEXIT$:	POPM.L	D0..D4,A0,A4	RET;-------------\\; MATTRACREATE >;-------------/; Cre la matrice d'une trame.; in	A3.L	^trame; out	D4.L	dimensions (dy;dx);	A4.L	^matrice;	D7.W	erreur; mod	D4.L, D7.W, A4.LMATTRACREATE:	PUSHM.L	D0..D3,A2	CALL	MATTRADIM	; D4 <-- dimensions de la trame	LOAD.L	D1,D4	SWAP.W	D1		; D1 <-- dy	LOAD.W	D0,D4		; D0 <-- dx	CLR.W	D2		; D2 <-- normal	COMP.L	D4,#H'10000*1+1	; trame trs petite (1x1) ?	JUMP',NE NORM$		; non => NORM$	LOAD.W	D0,#8	LOAD.W	D1,D0	INC.W	D2		; D2 <-- trame trs petiteNORM$:	LOAD.W	D4,D0		; D4 <-- dx	ADD.W	D4,#16-1	SR.W	D4,#4		; D4 <-- largeur en words	SL.W	D4,#1		; D4 <-- largeur en bytes	MUL.WU	D4,D1		; D4 <-- nb de bytes ncessaires	PUSH.L	D1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour matrice	POPM.L	D1	JUMP,NE EXIT$	GESMEM	?CLEARMEM	; met toute la matrice  zro	LOAD.W	D4,D1	SWAP.W	D4	LOAD.W	D4,D0		; D4 <-- dimensions	CALL	OPEDITMAT	; A2 <-- ^descripteur temporaire	TEST.W	D2		; trame trs petite ?	JUMP,NE LITTLE$		; oui => LITTLE$	LOAD.L	D3,(A3)+OTRAFA	; D3 <-- fanions	TEST.L	D3:#BTRAGR	JUMP',BC HACH$	TEST.L	D3:#BTRAPC	JUMP',BC BIG$				; petite trame grise =>	CALL	MATTRACRGREY	JUMP	OK$BIG$:				; grosse trame grise =>	LOAD.B	(A2)+ODFMGR,#GRAROUND ; graphique cylindrique	LOAD.W	D2,(A3)+OTRAGP	CALL	MATTRACRBIG	JUMP	OK$HACH$:				; trame hachure =>	LOAD.B	(A2)+ODFMGR,#GRAROUND ; graphique cylindrique	LOAD.W	D2,(A3)+OTRAI1	LOAD.W	D4,(A3)+OTRAE1	LOAD.W	D7,#MA_SCALEP	PAGE_	MATH		; D4 <-- plus grand si n:1	LOAD.W	D3,D4	CALL	MATTRACRLINE	LOAD.L	D3,(A3)+OTRAFA	; D3 <-- fanions	TEST.L	D3:#BTRAD2	JUMP',BC OK$	LOAD.W	D2,#135	TEST.L	D3:#BTRADI	JUMP',BS HACH2$	LOAD.W	D2,#90	TEST.L	D3:#BTRADV	JUMP',BS HACH2$	LOAD.W	D2,#45	TEST.L	D3:#BTRADO	JUMP',BS HACH2$	CLR.W	D2HACH2$:	LOAD.W	D4,(A3)+OTRAE2	LOAD.W	D7,#MA_SCALEP	PAGE_	MATH		; D4 <-- plus grand si n:1	LOAD.W	D3,D4	CALL	MATTRACRLINE	JUMP'	OK$LITTLE$:			; trame trs petite =>	CALL	MATTRACRERR;	JUMP'	OK$OK$:	LOAD.W	D4,D1	SWAP.W	D4	LOAD.W	D4,D0		; D4 <-- dimensions	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D0..D3,A2	TEST.W	D7		; retour EQ/NE	RET;----------\\; MATTRADIM >;----------/; Calcule les dimensions d'une trame.; in	A3.L	^trame; out	D4.L	dimensions (dy;dx); mod	D4.L, D7.WMATTRADIM:	PUSHM.L	D1..D3	LOAD.L	D1,(A3)+OTRAFA	; D1 <-- fanions	TEST.L	D1:#BTRAHA	JUMP,BS 50$				; trame grise =>	TEST.L	D1:#BTRAPC	JUMP',BS 30$	LOAD.W	D4,(A3)+OTRADI	LOAD.W	D7,#MA_SCALEP	PAGE_	MATH		; D4 <-- plus grand si n:1	TEST.W	D4		; largeur nulle ?	JUMP',NE 20$	INC.W	D420$:	TEST.L	D1:#BTRAQC	JUMP',BC 22$	SL.W	D4,#122$:	LOAD.W	D3,D4		; D4 <-- dy	SWAP.W	D4	LOAD.W	D4,D3		; D4 <-- dx	JUMP	80$30$:	LOAD.W	D7,#DR_GETPRINT	PAGE_	DRAW		; D4 <-- mode d'impression	LOAD.W	D3,#8*1	TEST.L	D4:#BPRIGX1	JUMP',BS 35$	LOAD.W	D3,#8*2	TEST.L	D4:#BPRIGX2	JUMP',BS 35$	LOAD.W	D3,#8*3	TEST.L	D4:#BPRIGX3	JUMP',BS 35$	LOAD.W	D3,#8*4	TEST.L	D4:#BPRIGX4	JUMP',BS 35$	LOAD.W	D3,#4	TEST.L	D4:#BPRIGR2	JUMP',BS 34$	LOAD.W	D3,#6	TEST.L	D4:#BPRIGR3	JUMP',BS 34$	LOAD.W	D3,#8	TEST.L	D4:#BPRIGR4;	JUMP',BS 34$34$:	TEST.L	D4:#BPRIGRQ	JUMP',BC 35$	SL.W	D3,#135$:	LOAD.W	D4,D3		; D4 <-- dy	SWAP.W	D4	LOAD.W	D4,D3		; D4 <-- dx	JUMP	80$50$:				; trame hachure =>	LOAD.W	D4,(A3)+OTRAD1	LOAD.W	D7,#MA_SCALEP	PAGE_	MATH		; D4 <-- plus grand si n:1	LOAD.W	D3,D4	MUL.WA	D3,#10000	LOAD.L	D4,D3	LOAD.W	D1,(A3)+OTRAI1	LIB	?CALCSIN	; D2 <-- 10000*SIN(I1)	TEST.W	D2	JUMP',EQ 60$	DIV.WA	D3,D2	TEST.W	D3	JUMP',NC 54$	NEG.W	D354$:	LIB	?CALCCOS	; D2 <-- 10000*COS(I1)	TEST.W	D2	JUMP',EQ 60$	DIV.WA	D4,D2	TEST.W	D4	JUMP',NC 56$	NEG.W	D456$:	SWAP.W	D4	LOAD.W	D4,D3	JUMP'	80$60$:	LOAD.W	D4,(A3)+OTRAD1	LOAD.W	D7,#MA_SCALEP	PAGE_	MATH		; D4 <-- plus grand si n:1	LOAD.W	D3,D4	SWAP.W	D4	LOAD.W	D4,D3;	JUMP'	80$80$:	TEST.W	D4	JUMP',NE 85$	INC.W	D485$:	SWAP.W	D4	TEST.W	D4	JUMP',NE 86$	INC.W	D486$:	SWAP.W	D4	POPM.L	D1..D3	RET;------------\\; MATTRACRERR >;------------/; Gnre une trame d'erreur.; in	A2.L	^descripteur temporaire; out	-; mod	D7.WMATTRACRERR:	PUSHM.L	D3,A3,A4	LOAD.L	A4,#R16"TATRAMEERR ; A4 <-- ^trame 8x8	LOAD.L	A3,(A2)+ODFABS	; A3 <-- ^dans la matrice	LOAD.W	D3,#8-130$:	LOAD.B	(A3),(A4+)	ADD.W	A3,(A2)+ODFIIY	DECJ.W,NMO D3,30$	POPM.L	D3,A3,A4	RET;-------------\\; MATTRACRGREY >;-------------/; Gnre une trame grise.; in	A3.L	^trame;	A2.L	^descripteur temporaire; out	-; mod	D7.WMATTRACRGREY:	PUSHM.L	D1..D5,A3,A4	LOAD.W	D7,#DR_GETPRINT	PAGE_	DRAW		; D4 <-- mode d'impression	LOAD.L	D1,D4	LOAD.L	A4,#R16"TATRAME44	TEST.L	D1:#BPRIGR2	JUMP',BS TRAME$	LOAD.L	A4,#R16"TATRAME66	TEST.L	D1:#BPRIGR3	JUMP',BS TRAME$	LOAD.L	A4,#R16"TATRAME88	TEST.L	D1:#BPRIGR4	JUMP',BS TRAME$	LOAD.L	A4,#R16"TATRAMEG	JUMP'	GRIS$TRAME$:	TEST.L	D1:#BPRIGRQ	JUMP,BS RQ$GRIS$:	LOAD.W	D4,(A3)+OTRAGP	; D4 <-- intensit (0..100)	LOAD.W	D3,(A4+)	; D3 <-- nb de trames	MUL.WU	D4,D3	DIV.WU	D4,#100	COMP.W	D4,D3	JUMP',LS RANGE$	LOAD.W	D4,D3RANGE$:	LOAD.W	D3,(A4+)	; D3 <-- dimensions	MUL.WU	D4,D3	ADD.L	A4,D4		; A4 <-- ^la bonne trame	LOAD.L	A3,(A2)+ODFABS	; A3 <-- ^dans la matrice	TEST.L	D1:#BPRIGX2	JUMP',BS X2$	TEST.L	D1:#BPRIGX3	JUMP,BS X3$	TEST.L	D1:#BPRIGX4	JUMP,BS X4$; Gnre une trame  l'chelle.	DEC.W	D3		; D3 <-- dimension -1 ( cause NMO)X1LOOP$:	LOAD.B	(A3),(A4+)	ADD.W	A3,(A2)+ODFIIY	DECJ.W,NMO D3,X1LOOP$	JUMP	EXIT$; Gnre une trame 16x16.X2$:	LOAD.W	D3,#8-1X2LOOP$:	LOAD.B	D2,(A4+)	LOAD.W	D1,#8-1X2SHIFT$:	SL.W	D4,#2	RL.B	D2,#1	JUMP',CC X2NEXT$	OR.B	D4,#B'11X2NEXT$:	DECJ.W,NMO D1,X2SHIFT$	LOAD.W	(A3),D4	ADD.W	A3,(A2)+ODFIIY	LOAD.W	(A3),D4	ADD.W	A3,(A2)+ODFIIY	DECJ.W,NMO D3,X2LOOP$	JUMP	EXIT$; Gnre une trame 24x24.X3$:	LOAD.W	D3,#8-1X3LOOP$:	LOAD.B	D2,(A4+)	LOAD.W	D1,#8-1X3SHIFT$:	SL.L	D4,#3	RL.B	D2,#1	JUMP',CC X3NEXT$	OR.B	D4,#B'111X3NEXT$:	DECJ.W,NMO D1,X3SHIFT$	SL.L	D4,#8	LOAD.L	(A3),D4	ADD.W	A3,(A2)+ODFIIY	LOAD.L	(A3),D4	ADD.W	A3,(A2)+ODFIIY	LOAD.L	(A3),D4	ADD.W	A3,(A2)+ODFIIY	DECJ.W,NMO D3,X3LOOP$	JUMP	EXIT$; Gnre une trame 32x32.X4$:	LOAD.W	D3,#8-1X4LOOP$:	LOAD.B	D2,(A4+)	LOAD.W	D1,#8-1X4SHIFT$:	SL.L	D4,#4	RL.B	D2,#1	JUMP',CC X4NEXT$	OR.B	D4,#B'1111X4NEXT$:	DECJ.W,NMO D1,X4SHIFT$	LOAD.L	(A3),D4	ADD.W	A3,(A2)+ODFIIY	LOAD.L	(A3),D4	ADD.W	A3,(A2)+ODFIIY	LOAD.L	(A3),D4	ADD.W	A3,(A2)+ODFIIY	LOAD.L	(A3),D4	ADD.W	A3,(A2)+ODFIIY	DECJ.W,NMO D3,X4LOOP$	JUMP	EXIT$; Gnre une trame ronde en quinconce.RQ$:	LOAD.W	D4,(A3)+OTRAGP	; D4 <-- intensit (0..100)	COMP.W	D4,#100/2	JUMP,HS RQI$	LOAD.W	D3,(A4+)	; D3 <-- nb de trames	MUL.WU	D4,D3	DIV.WU	D4,#100/2	COMP.W	D4,D3	JUMP',LS RQRANGE$	LOAD.W	D4,D3RQRANGE$:	LOAD.W	D2,(A4+)	; D2 <-- dimensions	MUL.WU	D4,D2	ADD.L	A4,D4		; A4 <-- ^la bonne trame	LOAD.L	A3,A4	CLR.L	D3		; D3 <-- origine source	LOAD.W	D5,D2	ADD.W	D5,#8-1	SR.W	D5,#3		; D5 <-- Iy source	LOAD.L	A4,#0		; A4 <-- destination (dans le bitmap)	CLR.L	D4		; D4 <-- origine destination	LOAD.W	D1,D2	SWAP.W	D2	LOAD.W	D2,D1		; D2 <-- dimensions	LOAD.W	D1,#SETDOT	; D1 <-- mode	GRA_	RASTER		; met point dans quadrant sup/gauche	ADD.W	D4,D2	SWAP.W	D4	ADD.W	D4,D2	SWAP.W	D4	GRA_	RASTER		; met point dans quadrant inf/droite	JUMP	EXIT$RQI$:	SUB.W	D4,#100	NEG.W	D4		; D4 <-- 50..0	LOAD.W	D3,(A4+)	; D3 <-- nb de trames	MUL.WU	D4,D3	DIV.WU	D4,#100/2	COMP.W	D4,D3	JUMP',LS RQIRANGE$	LOAD.W	D4,D3RQIRANGE$:	LOAD.W	D2,(A4+)	; D2 <-- dimensions	MUL.WU	D4,D2	ADD.L	A4,D4		; A4 <-- ^la bonne trame	LOAD.L	A3,A4	CLR.L	D4	LOAD.W	D3,D2	SL.W	D3,#1	SWAP.W	D3	LOAD.W	D3,D2	SL.W	D3,#1	LOAD.L	A4,#R16"BLACK$	LOAD.W	D1,#INVDOT	GRA_	TRAME		; inverse tout	CLR.L	D3		; D3 <-- origine source	LOAD.W	D5,D2	ADD.W	D5,#8-1	SR.W	D5,#3		; D5 <-- Iy source	LOAD.L	A4,#0		; A4 <-- destination (dans le bitmap)	CLR.L	D4		; D4 <-- origine destination	ADD.W	D4,D2	LOAD.W	D1,D2	SWAP.W	D2	LOAD.W	D2,D1		; D2 <-- dimensions	LOAD.W	D1,#CLRDOT	; D1 <-- mode	GRA_	RASTER		; met point dans quadrant sup/droite	SUB.W	D4,D2	SWAP.W	D4	ADD.W	D4,D2	SWAP.W	D4	GRA_	RASTER		; met point dans quadrant inf/gauche;	JUMP	EXIT$EXIT$:	POPM.L	D1..D5,A3,A4	RETBLACK$:	.B	-1,-1,-1,-1,-1,-1,-1,-1	.EVEN;------------\\; MATTRACRBIG >;------------/; Gnre une trame avec des gros points carrs ou ronds.; in	D0.W	largeur;	D1.W	hauteur;	D2.W	intensit (0..100);	D3.L	fanions	;	A2.L	^descripteur temporaire; out	-; mod	D7.WMATTRACRBIG:	PUSHM.L	D0..D4	TEST.W	D2		; trame de 0% ?	JUMP,EQ EXIT$	COMP.W	D2,#100		; trame de 100% ?	JUMP',EQ 10$	TEST.L	D3:#BTRAQC	JUMP,BS 40$	TEST.L	D3:#BTRAGO	JUMP',BS 20$10$:				; points carrs aligns =>	TCLR.L	D3:#BTRAGO	TSET.L	D3:#BTRAGC	CLR.L	D4	CALL	MATTRACRDOT	JUMP	EXIT$20$:				; points ronds aligns =>	COMP.W	D2,#66	JUMP',HI 24$	CLR.L	D4	CALL	MATTRACRDOT	LOAD.W	D3,D1	SR.W	D3,#1	SWAP.W	D3	LOAD.W	D3,D0	SR.W	D3,#1	CALL	MATTRACRFILL	JUMP	EXIT$24$:	SUB.W	D2,#100	NEG.W	D2	CLR.L	D4	CALL	MATTRACRDOT	LOAD.W	D3,D1	SR.W	D3,#1	SWAP.W	D3	LOAD.W	D3,D0	SR.W	D3,#1	CALL	MATTRACRFILL	CALL	MATTRACRINV	JUMP	EXIT$40$:	TEST.L	D3:#BTRAGO	JUMP,BS 60$				; points carrs en quinconces =>	COMP.W	D2,#50	JUMP',HI 44$	SL.W	D2,#1	SR.W	D0,#1	SR.W	D1,#1	CLR.L	D4	CALL	MATTRACRDOT	LOAD.W	D4,D1	SWAP.W	D4	LOAD.W	D4,D0	CALL	MATTRACRDOT	JUMP	EXIT$44$:	SUB.W	D2,#100	NEG.W	D2	SL.W	D2,#1	SR.W	D0,#1	SR.W	D1,#1	CLR.L	D4	LOAD.W	D4,D0	CALL	MATTRACRDOT	LOAD.W	D4,D1	SWAP.W	D4	CLR.W	D4	CALL	MATTRACRDOT	SL.W	D0,#1	SL.W	D1,#1	CALL	MATTRACRINV	JUMP	EXIT$60$:				; points ronds en quinconces =>	COMP.W	D2,#50	JUMP',HI 64$	SL.W	D2,#1	SR.W	D0,#1	SR.W	D1,#1	CLR.L	D4	CALL	MATTRACRDOT	LOAD.W	D4,D1	SWAP.W	D4	LOAD.W	D4,D0	CALL	MATTRACRDOT	CLR.L	D3	CALL	MATTRACRFILL	LOAD.W	D3,D1	SL.W	D3,#1	DEC.W	D3	SWAP.W	D3	LOAD.W	D3,D0	SL.W	D3,#1	DEC.W	D3	CALL	MATTRACRFILL	LOAD.W	D3,D1	SR.W	D3,#1	SWAP.W	D3	LOAD.W	D3,D0	SR.W	D3,#1	ADD.W	D3,D0	CALL	MATTRACRFILL	LOAD.W	D3,D1	SR.W	D3,#1	ADD.W	D3,D1	SWAP.W	D3	LOAD.W	D3,D0	SR.W	D3,#1	CALL	MATTRACRFILL	SL.W	D0,#1	SL.W	D1,#1	CALL	MATTRACRINV	JUMP	EXIT$64$:	SUB.W	D2,#100	NEG.W	D2	SL.W	D2,#1	SR.W	D0,#1	SR.W	D1,#1	CLR.L	D4	CALL	MATTRACRDOT	LOAD.W	D4,D1	SWAP.W	D4	LOAD.W	D4,D0	CALL	MATTRACRDOT	CLR.L	D3	CALL	MATTRACRFILL	LOAD.W	D3,D1	SL.W	D3,#1	DEC.W	D3	SWAP.W	D3	LOAD.W	D3,D0	SL.W	D3,#1	DEC.W	D3	CALL	MATTRACRFILL	LOAD.W	D3,D1	SR.W	D3,#1	SWAP.W	D3	LOAD.W	D3,D0	SR.W	D3,#1	ADD.W	D3,D0	CALL	MATTRACRFILL	LOAD.W	D3,D1	SR.W	D3,#1	ADD.W	D3,D1	SWAP.W	D3	LOAD.W	D3,D0	SR.W	D3,#1	CALL	MATTRACRFILL;	JUMP	EXIT$EXIT$:	POPM.L	D0..D4	RET;------------\\; MATTRACRDOT >;------------/; Dessine un point rond/carr dans la matrice de la trame.; in	D0.W	largeur;	D1.W	hauteur;	D2.W	intensit (0..100);	D3.L	fanions	;	D4.L	origine (y,x);	A2.L	^descripteur temporaire; out	-; mod	D7.WMATTRACRDOT:	PUSHM.L	D0..D6,A4	LOAD.L	D5,D3		; D5 <-- fanions	LOAD.L	D6,D4		; D6 <-- origine	LOAD.W	D3,D0	MUL.WU	D3,D1	MUL.WU	D3,D2	DIV.WU	D3,#100	AND.L	D3,#H'FFFF	CALL	RACINE		; D4 <-- racine(l*h*i/100)	TEST.W	D4	JUMP,EQ EXIT$	TEST.L	D5:#BTRAGC	; gros points carrs ?	JUMP,BS 50$		; oui => 50$	COMP.W	D4,#5		; diamtre trs petit ?	JUMP',LO 40$		; oui => 40$				; non =>	MUL.WU	D4,#1000	DIV.WU	D4,#1571	; D4 <-- D4/(PI/2)	LOAD.W	D3,D4	SWAP.W	D6	LOAD.W	D4,D1	SR.W	D4,#1	ADD.W	D4,D6	SWAP.W	D4	SWAP.W	D6	LOAD.W	D4,D0	SR.W	D4,#1	ADD.W	D4,D6	LOAD.W	D2,#-1	LOAD.W	D1,#SETDOT	GRA_	CIRCLE	JUMP'	EXIT$40$:	LOAD.W	D3,D4	SWAP.W	D3	LOAD.W	D3,D4	LOAD.W	D2,D4	SR.W	D2,#1	SWAP.W	D6	LOAD.W	D4,D1	SR.W	D4,#1	ADD.W	D4,D6	SUB.W	D4,D2	SWAP.W	D4	SWAP.W	D6	LOAD.W	D4,D0	SR.W	D4,#1	ADD.W	D4,D6	SUB.W	D4,D2	LOAD.W	D1,#SETDOT	LOAD.L	A4,#R16"TRAME$	GRA_	TRAME	JUMP'	EXIT$50$:	LOAD.W	D3,D4	SWAP.W	D3	LOAD.W	D3,D4	LOAD.L	D4,D6	LOAD.W	D1,#SETDOT	LOAD.L	A4,#R16"TRAME$	GRA_	TRAME;	JUMP'	EXIT$EXIT$:	POPM.L	D0..D6,A4	RETTRAME$:	.B	-1,-1,-1,-1,-1,-1,-1,-1	.EVEN;-------------\\; MATTRACRFILL >;-------------/; Rempli un cercle.; (*)	La routine de remplissage DRAWFILLO ne travaille pas correctement;	si la largeur n'est pas modulo 8. C'est pourquoi il faut arrondir;	la largeur au multiple de 8 suprieur, puis tracer une droite;	verticale pour dlimiter !!!; in	D3.L	point o remplir;	A2.L	^descripteur temporaire; out	-; mod	D7.WMATTRACRFILL:	PUSHM.L	D1..D4	LOAD.L	D2,D3	LOAD.W	D4,(A2)+ODFFDX	AND.B	D4,#B'111	JUMP',EQ 30$	LOAD.W	D3,(A2)+ODFFDX	CLR.L	D4	LOAD.W	D4,D3	ADD.W	D3,#8-1	AND.B	D3,#B'11111000	LOAD.W	(A2)+ODFFDX,D3	LOAD.W	D3,(A2)+ODFFDY	SWAP.W	D3	CLR.W	D3	LOAD.W	D1,#SETDOT	GRA_	LINE		; voir (*)30$:	LOAD.L (A2)+ODFTRA+0,#-1	LOAD.L (A2)+ODFTRA+4,#-1	TSET.B	(A2)+ODFFLG:#BFFILA ; rempli: va jusque dans les bords	LOAD.L	D4,D2	GRA_	FILLO		; rempli tout	GRA_	FILLC	TCLR.B	(A2)+ODFFLG:#BFFILA ; rempli: test si touche les bords	POPM.L	D1..D4	RET;------------\\; MATTRACRINV >;------------/; Inverse toute la matrice.; in	D0.W	largeur;	D1.W	hauteur;	A2.L	^descripteur temporaire; out	-; mod	D7.WMATTRACRINV:	PUSHM.L	D1,D3,D4,A4	LOAD.W	D3,D1	SWAP.W	D3	LOAD.W	D3,D0	CLR.L	D4	LOAD.W	D1,#INVDOT	LOAD.L	A4,#R16"TRAME$	GRA_	TRAME	POPM.L	D1,D3,D4,A4	RETTRAME$:	.B	-1,-1,-1,-1,-1,-1,-1,-1	.EVEN;-------------\\; MATTRACRLINE >;-------------/; Dessine une ligne (hachure) dans la matrice de la trame.; in	D0.W	largeur;	D1.W	hauteur;	D2.W	angle;	D3.W	paisseur;	A2.L	^descripteur temporaire; out	-; mod	D7.WMATTRACRLINE:	PUSHM.L	D0..D5	PUSHM.L	D1,D2	LOAD.W	D5,D3		; D5 <-- paisseur	LOAD.W	D1,D2	COMP.W	D2,#45	JUMP',LS 10$	LOAD.W	D1,#90	SUB.W	D1,D2	COMP.W	D2,#90	JUMP',LS 10$	LOAD.W	D1,#135	SUB.W	D1,D2	COMP.W	D2,#135	JUMP',LS 10$	LOAD.W	D1,#180	SUB.W	D1,D210$:	LIB	?CALCCOS	; D2 <-- 10000*COS(D1)	MUL.WA	D5,#10000	DIV.WA	D5,D2	TEST.W	D5	JUMP',NE 15$	INC.W	D515$:	POPM.L	D1,D2	CLR.L	D3	LOAD.W	D4,D1	SWAP.W	D4	LOAD.W	D4,D0		; D4 <-- dimensions	TEST.W	D2	JUMP',EQ 30$	COMP.W	D2,#180	JUMP',EQ 32$	COMP.W	D2,#90	JUMP',EQ 32$	JUMP',LO 40$	LOAD.W	D3,D4	DEC.W	D3	NEG.W	D4	JUMP'	40$30$:	AND.L	D4,#H'FFFF	JUMP'	40$32$:	CLR.W	D4;	JUMP'	40$40$:	EX.L	D3,D4	LOAD.W	D1,#SETDOT	GRA_	LINE		; dessine une hachure	EX.L	D4,D3	LOAD.W	D0,D4	JUMP',NC 50$	NEG.W	D050$:	LOAD.L	D1,D4	SWAP.W	D1	LOAD.L	D2,#H'10000*1+0	COMP.W	D0,D1	JUMP',HS 52$	LOAD.L	D2,#H'10000*0+152$:	ADD.L	D3,D2	DEC.W	D5	JUMP,NE 40$	POPM.L	D0..D5	RET;-------\\; RACINE >;=======/; Calcule la racine carre d'un nombre entier.; in	D3.L	n; out	D4.W	racine(n); mod	D4.L, D7.WRACINE:	PUSHM.L	D0..D3,A3	LOAD.L	A3,#R16"TABLE$10$:	ADD.L	A3,#6	COMP.L	D3,(A3)	JUMP,HI 10$	LOAD.W	D0,(A3)-2	; D0 <-- Bi	LOAD.W	D1,(A3)+4	; D1 <-- Bs20$:	COMP.W	D0,D1		; borne infrieure = borne suprieure ?	JUMP',EQ 80$		; oui => 80$	DEC.W	D1	COMP.W	D0,D1		; borne infrieure ~ borne suprieure ?	JUMP',EQ 80$		; oui => 80$	INC.W	D1	LOAD.W	D2,D1	SUB.W	D2,D0	SR.W	D2,#1	ADD.W	D2,D0		; D2=Bx <-- Bi+(Bs-Bi)/2	LOAD.W	D4,D2	MUL.WU	D4,D4		; D4 <-- Bx^2	COMP.L	D4,D3		; Bx^2 = n  ?	JUMP',EQ 70$	JUMP',HI 40$	LOAD.W	D0,D2		; D0=Bi <-- Bx	JUMP	20$40$:	LOAD.W	D1,D2		; D1=Bs <-- Bx	JUMP	20$70$:	LOAD.W	D1,D280$:	CLR.L	D4	LOAD.W	D4,D1		; D4 <-- racine carre	POPM.L	D0..D3,A3	RETTABLE$:	.L	0	.W	0	.L	1	.W	1	.L	10	.W	3	.L	100	.W	10	.L	1000	.W	31	.L	10000	.W	100	.L	100000	.W	316	.L	1000000	.W	1000	.L	10000000	.W	3162	.L	100000000	.W	10000	.L	-1	.W	-1;----------\\; OPEDITMAT >;==========/; Initialise le descripteur temporaire pour pouvoir dessiner; directement dans la matrice principale.; in	A4.L	^matrice o dessiner;	D4.L	dimensions (dy;dx); out	A2.L	^descripteur temporaire; mod	D7.W, A2.LOPEDITMAT:	PUSH.L	D4	LOAD.L	A2,#(A5)+OTDDIS	; A2 <-- ^descripteur temporaire	LOAD.L	(A2)+ODFABS,A4	CLR.L	(A2)+ODFY	LOAD.L	(A2)+ODFDY,D4	CLR.L	(A2)+ODFFY	LOAD.L	(A2)+ODFFDY,D4	CLR.L	(A2)+ODFWBY	LOAD.L	(A2)+ODFWEY,D4	LOAD.W	(A2)+ODFIIX,#1	ADD.W	D4,#16-1	AND.B	D4,#B'11110000	SR.W	D4,#3	LOAD.W	(A2)+ODFIIY,D4	LOAD.B	(A2)+ODFMGR,#GRACLIP ; graphique avec clipping	LOAD.B	(A2)+ODFNOW,#-1	; on est pas dans $DIS_0	LOAD.L	(A2)+ODFBAS,(A0)+ODFBAS ; pour FILLO/FILLC !!!	POP.L	D4	RET	.END