	.SBTTL	OPJUSTDBOX.ASI;--------\\; XopDGET >;========/; Donne la justification slectionne.; in	A0.L	canal;	A4.L	^table de la justification/nil si par dfaut; out	D3.W	justification slectionne;	D7.W	erreur; mod	D3.L, D7.WXopDGET:	PUSH.L	A4	COMP.L	A4,#0		; objet par dfaut ?	JUMP',NE NODEF$		; non => NODEF$	LOAD.L	A4,(A0)+OPDEF	; A4 <-- ^objet justification par dfautNODEF$:	LOAD.W	D3,(A4)+OTAJSEL	; D3 <-- justification slectionne	POP.L	A4	CLR.W	D7		; retour EQ	RET;--------\\; XopDPUT >;========/; Spcifie la justification.; in	A0.L	canal;	A4.L	^table de la justification/nil si par dfaut;	D3.W	justification  slectionner; out	D7.W	erreur; mod	D7.WXopDPUT:	PUSH.L	A4	COMP.L	A4,#0		; objet par dfaut ?	JUMP',NE NODEF$		; non => NODEF$	LOAD.L	A4,(A0)+OPDEF	; A4 <-- ^objet justification par dfautNODEF$:	LOAD.W	(A4)+OTAJSEL,D3	; slectionne une justification	POP.L	A4	CLR.W	D7		; retour EQ	RET;------------\\; XopDTSELECT >;============/; Choisi et/ou modifie une justification temporaire  utiliser.; in	A0.L	canal;	A4.L	^table des justifications/nil si par dfaut;	D2.W	justification  slectionner; out	D2.W	justification slectionne;	D3.L	dernire touche (F1/F0);	D4.W	nb de justifications modifies;	D7.W	erreur; mod	D2.L, D3.L, D4.L, D7.WXopDTSELECT:	PUSH.L	A4	COMP.L	A4,#0		; objet par dfaut ?	JUMP',NE NODEF$		; non => NODEF$	LOAD.L	A4,(A0)+OPDEF	; A4 <-- ^objet justification par dfautNODEF$:	PUSH.W	(A4)+OTAJSEL	; stack <-- justification slectionne	LOAD.W	(A4)+OTAJSEL,D2	; OTAJSEL <-- justification slectionne temporairement	CALL	XopDSELECT	; choisi/modifie une justification ...	LOAD.W	D2,(A4)+OTAJSEL	; D2 <-- justification slectionne temporairement	POP.W	(A4)+OTAJSEL	; OTAJSEL <-- justification slectionne initialement	POP.L	A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; XopDSELECT >;===========/; Choisi une justification  utiliser.; in	A0.L	canal;	A4.L	^table de la justification/nil si par dfaut; out	D3.L	dernire touche (F1/F0);	D4.W	nb de modifications;	D7.W	erreur; mod	D3.L, D4.L, D7.WXopDSELECT:	PUSHM.L	D0..D2,D5,A0..A5	LOAD.L	A5,A0		; A5 <-- ^variables globales	LOAD.L	A0,(A5)+OPDDIS	; A0 <-- ^descripteur fentre	COMP.L	A4,#0		; objet par dfaut ?	JUMP',NE NODEF$		; non => NODEF$	LOAD.L	A4,(A5)+OPDEF	; A4 <-- ^objet justification par dfautNODEF$:	LOAD.L	(A5)+OPTAB,A4	; OPTAB <-- ^table de la justification	CLR.W	D0		; D0 <-- nb de modifsREFAIT$:	LOAD.L	A4,(A5)+OPTAB	; A4 <-- ^table de la justification	LOAD.L	A2,#R16"TDBOX_JUST	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	LOAD.W	D7,#DB_OPEN	PAGE_	DBOX		; ouvre la DBOX	JUMP,NE EXIT$AFF$:	CALL	DBSELDRAW	; dessine la scroll-listMAJ$:	CALL	DBSELUPDATE	; mj la scroll-listGREY$:	CALL	DBSELINFO	; affiche qq informations	CALL	DBSELGREY	; grise la touche (UTILISE)LOOP$:	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_JUST	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP',EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ USE$	COMP.W	D3,#F4	JUMP,EQ CREE$	COMP.W	D3,#F7	JUMP,EQ PREND$	COMP.W	D3,#F9	JUMP,EQ SAUVE$	COMP.W	D3,#F0	JUMP,EQ END$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ MODIF$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$CLIC$:	CALL	DBSELMOVE	; dplace la scroll-liste ...	JUMP,NE BIP$	JUMP	GREY$CREE$:	CALL	DBSELGPJ	; A4 <-- ^table de justification slectionne	CALL	DBOXCREE	; cre ...	LOAD.L	A2,#R16"TDBOX_JUST	LOAD.W	D7,#DB_RSK	PAGE_	DBOX		; refait les soft-keys	COMP.W	D3,#F0	JUMP,EQ LOOP$	INC.W	(A5)+ORGLAF	; faudra redessiner la rgle !	INC.W	D0		; D0 <-- une modif de plus	JUMP	MAJ$MODIF$:	CALL	DBSELGPJ	; A4 <-- ^table de justification slectionne	COMP.B	D3,#1	JUMP',EQ JUSTIF$	COMP.B	D3,#2	JUMP',EQ ESPACE$	COMP.B	D3,#3	JUMP',EQ INTERL$	COMP.B	D3,#4	JUMP',EQ TABUL$	COMP.B	D3,#5	JUMP',EQ CHAR$	JUMP	LOOP$CHAR$:	CALL	DBOXCHAR	JUMP'	MEND$JUSTIF$:	CALL	DBOXJUSTIF	JUMP'	MEND$ESPACE$:	CALL	DBOXESPACE	JUMP'	MEND$INTERL$:	CALL	DBOXINTERL	JUMP'	MEND$TABUL$:	CALL	DBOXTABUL;	JUMP'	MEND$MEND$:	LOAD.L	A2,#R16"TDBOX_JUST	LOAD.W	D7,#DB_RSK	PAGE_	DBOX		; refait les soft-keys	COMP.W	D3,#F0	JUMP,EQ LOOP$	INC.W	(A5)+ORGLAF	; faudra redessiner la rgle !	INC.W	D0		; D0 <-- une modif de plus	JUMP	MAJ$PREND$:	CALL	JUSTPREND	; prend les justifications ...	PUSH.W	D7	LOAD.L	A2,#R16"TDBOX_JUST	LOAD.W	D7,#DB_RSK	PAGE_	DBOX		; refait les soft-keys	POP.W	D7	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	LOAD.W	D0,#NBJUST	; D0 <-- toutes les justifications modifies	JUMP	AFF$SAUVE$:	CALL	JUSTSAUVE	; sauve les justifications ...	PUSH.W	D7	LOAD.L	A2,#R16"TDBOX_JUST	LOAD.W	D7,#DB_RSK	PAGE_	DBOX		; refait les soft-keys	POP.W	D7	JUMP,NE BIP$	JUMP	LOOP$USE$:	LOAD.L	A4,(A5)+OPTAB	; A4 <-- ^table de la justification	LOAD.W	(A4)+OTAJSEL,(A5)+OSLVAR+OSLCYSEND$:	LOAD.W	D7,#DB_CLOSE	PAGE_	DBOX		; ferme la DBOX	LOAD.W	D4,D0		; D4 <-- nb de modif(s)	JUMP',EQ EXIT$	INC.L	(A5)+OREGEN	; change le numro de rgnrationEXIT$:	POPM.L	D0..D2,D5,A0..A5	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBSELGREY >;----------/; Grise si ncessaire la touche (UTILISE).; in	-; out	-; mod	D7.WDBSELGREY:	PUSHM.L	D1..D4,A3,A4	CALL	DBSELGPJ	; A4 <-- ^table de justification slectionne	LOAD.L	A3,#R16"TXF42$	LOAD.W	D1,#BDBGCGREY	TEST.B	(A4)+OJSNAME	; nom existe ?	JUMP',EQ GREY$	LOAD.L	A3,#R16"TXF41$	LOAD.W	D1,#BDBGCFULLGREY$:	LOAD.W	D2,#10!2^BDBGCLABEL	TSET.L	D2:D1	DBOX_	GETCO		; (d-)grise (F1)	LOAD.W	D2,#1!2^BDBGCLABEL	TSET.L	D2:D1	DBOX_	GETCO	LOAD.W	D2,#2!2^BDBGCLABEL	TSET.L	D2:D1	DBOX_	GETCO	LOAD.W	D2,#3!2^BDBGCLABEL	TSET.L	D2:D1	DBOX_	GETCO	LOAD.W	D2,#4!2^BDBGCLABEL	TSET.L	D2:D1	DBOX_	GETCO	LOAD.W	D2,#5!2^BDBGCLABEL	TSET.L	D2:D1	DBOX_	GETCO	LOAD.W	D2,#11!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTEXT		; affiche (F4)	POPM.L	D1..D4,A3,A4	RETTXF41$:	.ASCIZ	" MODIFIE "TXF42$:	.ASCIZ	"  CREE   "	.EVEN;----------\\; DBSELINFO >;----------/; Affiche qq informations sur la mise en page slectionne.; in	-; out	-; mod	D7.WDBSELINFO:	PUSHM.L	D2..D4,A3,A4	CALL	DBSELGPJ	; A4 <-- ^table de justification slectionne	TEST.B	(A4)+OJSNAME	; nom existe ?	JUMP,EQ RIEN$		; non => RIEN$; Affiche les informations sur le caractre	LOAD.W	D2,#20!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"car="	.EVEN	PUSHM.L	D0,D1,A2,A4	LOAD.W	D3,(A4)+OJSCHAR	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D0,#IDENTCHAR	LOAD.W	D1,#opDGETDIM	PAGE_	OBJCALL		; A2/A3/A4/D3/D4 <-- ^nom de fonction	LOAD.L	A3,A2	LIB	?AFTEXT	POPM.L	D0,D1,A2,A4	LOAD.B	D3,#EFLI	LIB	?AFCAR; Affiche les informations sur la justification.	LOAD.W	D2,#21!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#R16"TXJD$	TEST.B	(A4)+OJSMODE:#BJSMDD	JUMP',BS JUST$	LOAD.L	A3,#R16"TXJG$	TEST.B	(A4)+OJSMODE:#BJSMDG	JUMP',BS JUST$	LOAD.L	A3,#R16"TXJC$	TEST.B	(A4)+OJSMODE:#BJSMDC	JUMP',BS JUST$	LOAD.L	A3,#R16"TXJA$JUST$:	LIB	?AFTEXT	TEST.B	(A4)+OJSMODE:#BJSMDM	JUMP',BC DIVM$	LIB	?AFTIM	.ASCIZ	", divisions"	.EVENDIVM$:	LOAD.W	D4,(A4)+OJSITCA	JUMP',EQ ITC$	LIB	?AFTIM	.ASCIZ	", ic="	.EVEN	CALL	DBSELINUMITC$:	LOAD.B	D3,#EFLI	LIB	?AFCAR; Affiche les informations sur l'espacement.	LOAD.W	D2,#22!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.W	D4,(A4)+OJSESPG	JUMP',EQ ESPG$	LIB	?AFTIM	.ASCIZ	"<AFTOUT><H'09><AFNORM>="	.EVEN	CALL	DBSELINUMESPG$:	LOAD.W	D4,(A4)+OJSESPR	JUMP',EQ ESPR$	LIB	?AFTIM	.ASCIZ	" r="	.EVEN	CALL	DBSELINUMESPR$:	LOAD.W	D4,(A4)+OJSESPD	JUMP',EQ ESPD$	LIB	?AFTIM	.ASCIZ	" <AFTOUT><H'0B><AFNORM>="	.EVEN	CALL	DBSELINUMESPD$:	LOAD.W	D4,(A4)+OJSESPH	JUMP',EQ ESPH$	LIB	?AFTIM	.ASCIZ	" <AFTOUT><H'0A><AFNORM>="	.EVEN	CALL	DBSELINUMESPH$:	LOAD.W	D4,(A4)+OJSESPB	JUMP',EQ ESPB$	LIB	?AFTIM	.ASCIZ	" <AFTOUT><H'08><AFNORM>="	.EVEN	CALL	DBSELINUMESPB$:	LOAD.B	D3,#EFLI	LIB	?AFCAR; Affiche les informations sur l'interligne.	LOAD.W	D2,#23!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"il="	.EVEN	LOAD.L	D2,(A4)+OJSILFL	TEST.L	D2:#BJSILC	JUMP',BS ITLC$ITLV$:	LOAD.W	D4,(A4)+OJSILVA	CALL	DBSELINUM	JUMP'	ITL$ITLC$:	PUSHM.L	D0,D1,A2,A4	LOAD.W	D3,(A4)+OJSCHAR	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D0,#IDENTCHAR	LOAD.W	D1,#opDGETDIM	PAGE_	OBJCALL		; A2/A3/A4/D3/D4 <-- ^nom de fonction	LOAD.L	A3,A2	LIB	?AFTEXT	POPM.L	D0,D1,A2,A4ITL$:	LOAD.L	A3,#R16"TXIL05$	TEST.L	D2:#BJSIL05	JUMP',BS ITLM$	LOAD.L	A3,#R16"TXIL08$	TEST.L	D2:#BJSIL08	JUMP',BS ITLM$	LOAD.L	A3,#R16"TXIL10$	TEST.L	D2:#BJSIL10	JUMP',BS ITLM$	LOAD.L	A3,#R16"TXIL12$	TEST.L	D2:#BJSIL12	JUMP',BS ITLM$	LOAD.L	A3,#R16"TXIL15$	TEST.L	D2:#BJSIL15	JUMP',BS ITLM$	LOAD.L	A3,#R16"TXIL20$ITLM$:	LIB	?AFTEXT	LOAD.B	D3,#EFLI	LIB	?AFCAR; Affiche les informations sur les tabulateurs.	LOAD.W	D2,#24!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A4)+OJSTABS	LOAD.L	D4,#-1TCNT$:	INC.L	D4	TEST.L	(A3+)	JUMP,NE TCNT$	TEST.L	D4	JUMP',EQ TEND$	LOAD.W	D2,#2^BAFDCM	LOAD.W	D3,#2	LIB	?AFDEC	LIB	?AFTIM	.ASCIZ	" tabs"	.EVENTEND$:	LOAD.B	D3,#EFLI	LIB	?AFCAR	JUMP'	EXIT$RIEN$:	LOAD.W	D2,#20!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.B	D3,#EFLI	LIB	?AFCAR	LOAD.W	D2,#21!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.B	D3,#EFLI	LIB	?AFCAR	LOAD.W	D2,#22!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.B	D3,#EFLI	LIB	?AFCAR	LOAD.W	D2,#23!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.B	D3,#EFLI	LIB	?AFCAR	LOAD.W	D2,#24!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.B	D3,#EFLI	LIB	?AFCAREXIT$:	POPM.L	D2..D4,A3,A4	RETTXJA$:	.ASCIZ	"Align"TXJD$:	.ASCIZ	"Drap. droite"TXJG$:	.ASCIZ	"Drap. gauche"TXJC$:	.ASCIZ	"Centr"TXIL05$:.ASCIZ	" x 0.5"TXIL08$:.ASCIZ	" x 0.8"TXIL10$:.ASCIZ	" x 1"TXIL12$:.ASCIZ	" x 1.2"TXIL15$:.ASCIZ	" x 1.5"TXIL20$:.ASCIZ	" x 2"	.EVEN;----------\\; DBSELINUM >;----------/; Affiche un paramtre numrique ditable.; in	D4.W	nombre [obj]; out	-; mod	D7.WDBSELINUM:	PUSHM.L	D4,A3,A4	LOAD.L	A3,#(A5)+OBUDIS	LOAD.L	A4,A3	TEST.W	D4	JUMP',NC SIGN$	NEG.W	D4	LOAD.B	(A4+),#'-SIGN$:	LOAD.W	D7,#MI_PUTUNUM	PAGE_	MISC		; OBUDIS <-- nombre, avec units	CLR.B	(A4)	LIB	?AFTEXT		; affiche le nombre	POPM.L	D4,A3,A4	RET;---------\\; DBSELGPJ >;---------/; Cherche la table de justification slectionne.; in	-; out	A4.L	^table de justification slectionne; mod	D7.W, A4.LDBSELGPJ:	PUSH.L	D4	LOAD.L	A4,(A5)+OPTAB	; A4 <-- ^table de la justification;	LOAD.L	A4,#(A4)+OTAJLST	LOAD.W	D4,(A5)+OSLVAR+OSLCYS	MUL.WU	D4,#LDJUST	ADD.L	A4,D4		; A4 <-- ^la bonne table	POP.L	D4	RET;----------\\; DBSELDRAW >;----------/; Dessine la scroll-liste.; in	-; out	-; mod	D7.WDBSELDRAW:	PUSHM.L	D2..D4,A4..A6	LOAD.L	A6,A5		; A6 <-- ^variables globales	LOAD.L	A5,#(A6)+OSLVAR	; A5 <-- ^variables de la scroll-liste	LOAD.L	A4,(A6)+OPTAB	; A4 <-- ^table de la justification	LOAD.W	(A5)+OSLCYS,(A4)+OTAJSEL	LOAD.W	(A5)+OSLCYN,#NBJUST	LOAD.W	D2,#210!2^BDBGCLABEL	DBOX_	GETCO	SWAP.W	D3	SUB.W	D3,(A0)+ODFC1Y	SUB.W	D3,(A0)+ODFC2Y	SUB.W	D3,#2	SWAP.W	D3	LOAD.L	(A5)+OSLPOS,D3	LOAD.W	D2,#211!2^BDBGCLABEL	DBOX_	GETCO	SUB.W	D3,(A5)+OSLPOS+2	SWAP.W	D3	ADD.W	D3,(A0)+ODFC2Y	SUB.W	D3,(A5)+OSLPOS+0	SWAP.W	D3	LOAD.L	(A5)+OSLDIM,D3	CLR.B	(A5)+OSLVID	CLR.B	(A5)+OSLHOR	SCROLL_	LDRAW		; dessine la scroll-liste	POPM.L	D2..D4,A4..A6	RET;------------\\; DBSELUPDATE >;------------/; Dessine la scroll-liste.; in	-; out	-; mod	D7.WDBSELUPDATE:	PUSHM.L	A3,A5,A6	LOAD.L	A6,A5		; A6 <-- ^variables globales	LOAD.L	A5,#(A6)+OSLVAR	; A5 <-- ^variables de la scroll-liste	LOAD.L	A3,#R16"DBSELGET	LOAD.L	(A5)+OSLADL,A3	SCROLL_	LUPDATE		; dessine le contenu	POPM.L	A3,A5,A6	RET;---------\\; DBSELGET >;---------/; Donne le texte  mettre dans la scroll-liste.; in	D3.W	rang de la case (0..n); out	A3.L	^contenu;	D3.W	ligne; mod	D3.L, D7.W, A3.LDBSELGET:	PUSH.L	D4	CLR.L	D4	LOAD.W	D4,D3	LOAD.L	A3,(A6)+OPTAB	; A3 <-- ^table de la justification;	LOAD.L	A3,#(A3)+OTAJLST+OJSNAME	MUL.WU	D3,#LDJUST	ADD.L	A3,D3		; A3 <-- ^le bon nom	CLR.W	D3	DIV.WU	D4,#5	SWAP.W	D4	COMP.W	D4,#5-1	JUMP',NE EXIT$	LOAD.W	D3,#1		; D3 <-- ligne pointilleEXIT$:	POP.L	D4	CLR.W	D7		; retour EQ	RET;----------\\; DBSELMOVE >;----------/; Dplace la scroll-liste.; in	-; out	D7.W	erreur; mod	D7.WDBSELMOVE:	PUSHM.L	D3,D4,A5,A6	LOAD.L	A6,A5		; A6 <-- ^variables globales	LOAD.L	A5,#(A6)+OSLVAR	; A5 <-- ^variables de la scroll-liste	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP',NE EXIT$	LOAD.W	D7,#ERDIOUT	SUB.W	D4,(A0)+ODFFX	JUMP',LO EXIT$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	; D4 <-- position relative dans swdo	JUMP',LO EXIT$	SWAP.W	D4	SCROLL_	LMOVE		; dplace la scroll-liste ...EXIT$:	POPM.L	D3,D4,A5,A6	TEST.W	D7		; retour EQ/NE	RETTDBOX_JUST:	.W	10$-TDBOX_JUST	.W	20$-TDBOX_JUST	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Choix des mises en pages disponibles :"	.B	ODBTABX,20+4+18	.B	ODBLABEL,5	.B	ODBBOX,KEYDBOX/H'100,5,TDBOMBRE	.ASCIZ	"  CARACTERE   "	.B	ODBCR,ODBCR	.B	ODBLABEL,210	.B	ODBTEXT,0	.B	ODBTABX,20+4	.B	ODBLABEL,1	.B	ODBBOX,KEYDBOX/H'100,1,TDBOMBRE	.ASCIZ	" JUSTIFICATION "	.B	ODBLABEL,3	.B	ODBBOX,KEYDBOX/H'100,3,TDBOMBRE	.ASCIZ	"  INTERLIGNE  "	.B	ODBCR,ODBCR	.B	ODBTABX,20+4	.B	ODBLABEL,2	.B	ODBBOX,KEYDBOX/H'100,2,TDBOMBRE	.ASCIZ	"  ESPACEMENTS  "	.B	ODBLABEL,4	.B	ODBBOX,KEYDBOX/H'100,4,TDBOMBRE	.ASCIZ	" TABULATEURS  "	.B	ODBCR,ODBCR,ODBCR	.B	ODBTABX,20+5	.B	ODBLABEL,20	.B	ODBTEXT,0	.B	ODBCR	.B	ODBTABX,20+5	.B	ODBLABEL,21	.B	ODBTEXT,0	.B	ODBCR	.B	ODBTABX,20+5	.B	ODBLABEL,22	.B	ODBTEXT,0	.B	ODBCR	.B	ODBTABX,20+5	.B	ODBLABEL,23	.B	ODBTEXT,0	.B	ODBCR	.B	ODBTABX,20	.B	ODBLABEL,211	.B	ODBTEXT,0	.B	ODBTABX,20+5	.B	ODBLABEL,24	.B	ODBTEXT,0	.B	ODBCR,ODBCR,ODBCR2	.B	ODBLABEL,10	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" UTILISE "	.B	ODBLABEL,11	.B	ODBBOX,0,F4,TDBMEV	.ASCIZ	" MODIFIE "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F7,TDBNORM	.ASCIZ	" PREND "	.B	ODBBOX,0,F9,TDBNORM	.ASCIZ	" SAUVE "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Utilise"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Cre/Modifie"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Prend       Sauve"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_JUST:	.W	F1,F2,F3,0		DOKF1-TKEY_JUST	.W	F4,F5,F6,0		DOKF4-TKEY_JUST	.W	F7,0			DOKF7-TKEY_JUST	.W	F9,0			DOKF9-TKEY_JUST	.W	F0,F13,F14,F15,0	DOKF0-TKEY_JUST	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_JUST	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_JUST	.W	0;---------\\; DBOXCREE >;=========/; Cration d'une nouvelle mise en page.; in	A4.L	^table;	D0.W	nb de modifs; out	D0.W	nb de modifs;	D3.L	dernire touche (F1/F4/F0);	D7.W	erreur; mod	D0.L, D3.L, D7.WDBOXCREE:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.L	A1,A4		; A1 <-- ^table	LOAD.L	A2,#R16"TDBOX$	LOAD.W	D7,#DB_MEMPT	PAGE_	DBOX		; mj ^table dbox	CLR.L	D4		; D4 <-- fanions	CALL	PUTNAMET1	CLR.W	(A5)+ODBP2	LOAD.L	A2,#R16"TDBOX_CREE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.W	D7,#DB_OPEN	PAGE_	DBOX		; ouvre la DBOX	JUMP,NE EXIT$	CALL	DBCRCRMOD	; adapte la bote selon cre/modifie	CLR.W	D2AFF$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_AFF	PAGE_	DBOX		; affiche le paramtre	INC.W	D2	COMP.W	D2,#1	JUMP,LO AFF$MAJ$:	CALL	DBCRAFFM	; affiche le nom du modle	CLR.W	D2NLINE$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_MEDIT	PAGE_	DBOXLOOP$:	LOAD.W	D7,#MI_SCMO	PAGE_	MISC		; remet la souris	DBOX_	EDIT		; attend une action ...	LOAD.W	D7,#DB_ZEROCR	PAGE_	DBOX		; remplace <CR> par <0>	PUSH.L	A1	LOAD.L	A1,#R16"TKEY_CREE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	POP.L	A1	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F4	JUMP,EQ KILL$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#UNDO	JUMP,EQ UNDO$	COMP.W	D3,#CLEAR	JUMP,EQ UNDO$	COMP.W	D3,#CR	JUMP,EQ RETURN$	COMP.W	D3,#F7	JUMP,EQ SOURCE$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,#1	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$KEYDBOX$:			; KEYDBOX =>	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	COMP.B	D3,#100	JUMP',HS CLINE$	JUMP	LOOP$CLINE$:	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$CLIC$:	LOAD.W	D7,#DB_CLIC	PAGE_	DBOX	JUMP,NE BIP$	JUMP	NLINE$SOURCE$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	LOAD.W	D2,(A5)+ODBP2	LOAD.L	A4,(A5)+OPTAB	; A4 <-- ^table de la justification	CALL	DBJMMENU	; choix d'une justification ...	JUMP,NE BIP$	LOAD.W	(A5)+ODBP2,D2	JUMP	MAJ$OK$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	TEST.B	(A5)+ODBT1	; nom existe ?	JUMP,EQ BIP$		; non => BIP$	CALL	DBCRCOPM	; copie le modle	CALL	GETNAMET1	INC.W	D0		; D0 <-- une modification de plus	JUMP'	END$KILL$:	COMP.L	A1,(A5)+OPTAB	; est-ce la premire justification ?	JUMP,EQ BIP$		; oui => BIP$	CLR.B	(A1)+OJSNAME	; supprime le nom	INC.W	D0		; D0 <-- une modification de plusEND$:	LOAD.W	D7,#DB_CLOSE	PAGE_	DBOX		; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	ODBT1,DBTYPA,0,0,0,2^BDBGCLABEL!100,0,15+2	.W	-1;----------\\; DBCRCRMOD >;----------/; Adapte la bote selon cre/modifie.; in	A1.L	^table; out	-; mod	D7.WDBCRCRMOD:	PUSHM.L	D2..D4	TEST.B	(A1)+OJSNAME	; nom existe ?	JUMP',NE MODIF$		; oui => MODIF$CREE$:	LOAD.W	D2,#10!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"Cration d'une nouvelle mise en page :"	.EVEN	LOAD.W	D2,#21!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO		; grise (SUPPRIME)	JUMP'	EXIT$MODIF$:	LOAD.W	D2,#10!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	"Modification d'une mise en page :"	.EVEN	LOAD.W	D2,#11!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO		; grise "Modle"	LOAD.W	D2,#50!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO	LOAD.W	D2,#20!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.ASCIZ	" MODIFIE "	.EVEN	COMP.L	A1,(A5)+OPTAB	; est-ce la premire justification ?	JUMP',NE EXIT$		; non => EXIT$	LOAD.W	D2,#21!2^BDBGCLABEL!2^BDBGCGREY	DBOX_	GETCO		; grise (SUPPRIME)EXIT$:	POPM.L	D2..D4	RET;---------\\; DBCRAFFM >;---------/; Affiche le nom du modle.; in	-; out	-; mod	D7.WDBCRAFFM:	PUSHM.L	D2..D4,A3	TEST.B	(A1)+OJSNAME	; nom existe ?	JUMP',NE EXIT$		; oui => EXIT$	LOAD.W	D2,#50!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.B	MSPACE,15,0	.EVEN	LIB	?SETCURS	LOAD.L	A3,(A5)+OPTAB	; A3 <-- ^table de la justification	LOAD.W	D3,(A5)+ODBP2	MUL.WU	D3,#LDJUST	ADD.L	A3,D3	LIB	?AFTEXT		; affiche le nom du modleEXIT$:	POPM.L	D2..D4,A3	RET;---------\\; DBCRCOPM >;---------/; Copie le modle choisi.; in	A1.L	^table; out	-; mod	D7.WDBCRCOPM:	PUSHM.L	D3,A1,A3	TEST.B	(A1)+OJSNAME	; nom existe ?	JUMP',NE EXIT$		; oui => EXIT$	LOAD.L	A3,(A5)+OPTAB	; A3 <-- ^table de la justification	LOAD.W	D3,(A5)+ODBP2	MUL.WU	D3,#LDJUST	ADD.L	A3,D3	LOAD.W	D3,#(LDJUST/2)-1XFER$:	LOAD.W	(A1+),(A3+)	DECJ.W,NMO D3,XFER$EXIT$:	POPM.L	D3,A1,A3	RETTDBOX_CREE:	.W	10$-TDBOX_CREE	.W	20$-TDBOX_CREE	.W	0,010$:	.B	ODBLABEL,10	.B	ODBTEXT,0	.B	ODBTABX,40	.B	ODBCR,ODBCR,ODBCR2	.B	ODBTEXT	.ASCIZ	"Nouveau nom          "	.B	ODBLABEL,100	.B	ODBCLINE,(15+2)!2^7,KEYDBOX/H'100,100,TDBOMBRE	.B	ODBCR,ODBCR	.B	ODBLABEL,11	.B	ODBTEXT	.ASCIZ	"Modle de rfrence  "	.B	ODBLABEL,50	.B	ODBBOX,0,F7,TDBNORM	.ASCIZ	"                 "	.B	ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBLABEL,20	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	"  CREE   "	.B	ODBTEXT	.ASCIZ	" "	.B	ODBLABEL,21	.B	ODBBOX,0,F4,TDBNORM	.ASCIZ	" SUPPRIME "	.B	ODBTEXT	.ASCIZ	"    "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Cre/Modifie"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Supprime"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_CREE:	.W	F1,F2,F3,0		DOKF1-TKEY_CREE	.W	F4,F5,F6,0		DOKF4-TKEY_CREE	.W	F0,F13,F14,F15,0	DOKF0-TKEY_CREE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_CREE	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_CREE	.W	0;---------\\; DBOXCHAR >;=========/; Choix du caractre.; in	A4.L	^table;	D0.W	nb de modifs; out	D0.W	nb de modifs;	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D0.L, D3.L, D7.WDBOXCHAR:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.L	A1,A4		; A1 <-- ^table	LOAD.L	A2,#R16"TDBOX$	LOAD.W	D7,#DB_MEMPT	PAGE_	DBOX		; mj ^table dbox	CLR.L	D4		; D4 <-- fanions	LOAD.W	(A5)+ODBP1,(A1)+OJSEXPY	LOAD.W	(A5)+ODBP2,(A1)+OJSSOUH	LOAD.W	(A5)+ODBP3,(A1)+OJSSOUD	LOAD.W	(A5)+ODBP5,(A1)+OJSCHAR	LOAD.L	A2,#R16"TDBOX_CHAR	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.W	D7,#DB_OPEN	PAGE_	DBOX		; ouvre la DBOX	JUMP,NE EXIT$	PUSH.L	D4	LOAD.W	D2,#20!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A1)+OJSNAME	LIB	?AFTEXT		; affiche le nom de la mise en page	POP.L	D4	LOAD.W	D2,#2^BDBGCLABEL!200	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	LOAD.W	D2,#2^BDBGCLABEL!201	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	LOAD.W	D2,#2^BDBGCLABEL!202	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	LOAD.W	D2,#2^BDBGCLABEL!203	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	CALL	DBCARDRAW	; affiche le caractre de fond	CLR.W	D2AFF$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_AFF	PAGE_	DBOX		; affiche le paramtre	INC.W	D2	COMP.W	D2,#3	JUMP,LO AFF$	CLR.W	D2NLINE$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_MEDIT	PAGE_	DBOXLOOP$:	LOAD.W	D7,#MI_SCMO	PAGE_	MISC		; remet la souris	DBOX_	EDIT		; attend une action ...	LOAD.W	D7,#DB_ZEROCR	PAGE_	DBOX		; remplace <CR> par <0>	PUSH.L	A1	LOAD.L	A1,#R16"TKEY_CHAR	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	POP.L	A1	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#F7	JUMP,EQ	CCHAR$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#CLEAR	JUMP',EQ UNDO$	COMP.W	D3,#CR	JUMP',EQ RETURN$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP',EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,#3	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$KEYDBOX$:			; KEYDBOX =>	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	COMP.B	D3,#100	JUMP',HS CLINE$	JUMP	LOOP$CLINE$:	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$CLIC$:	LOAD.W	D7,#DB_CLIC	PAGE_	DBOX	JUMP,NE BIP$	JUMP	NLINE$CCHAR$:	CALL	DBCARCHOIX	; choix du caractre de fond ...	JUMP,NE BIP$	JUMP	LOOP$OK$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	LOAD.W	(A1)+OJSEXPY,(A5)+ODBP1	LOAD.W	(A1)+OJSSOUH,(A5)+ODBP2	LOAD.W	(A1)+OJSSOUD,(A5)+ODBP3	LOAD.W	(A1)+OJSCHAR,(A5)+ODBP5	INC.W	D0		; D0 <-- une modification de plusEND$:	LOAD.W	D7,#DB_CLOSE	PAGE_	DBOX		; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	ODBP1,DBTYPN,0,100,5,2^BDBGCLABEL!100,0,3+2	.W	ODBP2,DBTYPU,0,20*FACMMPT,01*FACMMPT,2^BDBGCLABEL!101,1,8+2	.W	ODBP3,DBTYPU,0,20*FACMMPT,01*FACMMPT,2^BDBGCLABEL!102,2,8+2	.W	-1TDBOX_CHAR:	.W	10$-TDBOX_CHAR	.W	20$-TDBOX_CHAR	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Mise en page: "	.B	ODBLABEL,20	.B	ODBTEXT,0	.B	ODBCR,ODBCR2	.B	ODBLABEL,200	.B	ODBTEXT,0	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"Caractre ordinaire "	.B	ODBLABEL,150	.B	ODBBOX,0,F7,TDBNORM	.ASCIZ	"               "	.B	ODBCR	.B	ODBLABEL,201	.B	ODBTEXT,0	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"Indices et exposants :"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"Positionnement vertical  "	.B	ODBLABEL,100	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTEXT	.ASCIZ	"  %"	.B	ODBCR	.B	ODBLABEL,202	.B	ODBTEXT,0	.B	ODBCR	.B	ODBCR2	.B	ODBTEXT	.ASCIZ	"Epaisseurs soulignements "	.B	ODBLABEL,101	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,101,TDBNORM	.B	ODBCR,ODBCR2	.B	ODBTEXT	.ASCIZ	"Positionnement vertical  "	.B	ODBLABEL,102	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,102,TDBNORM	.B	ODBCR	.B	ODBLABEL,203	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_CHAR:	.W	F1,F2,F3,0		DOKF1-TKEY_CHAR	.W	F0,F13,F14,F15,0	DOKF0-TKEY_CHAR	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_CHAR	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_CHAR	.W	0;-----------\\; DBOXJUSTIF >;===========/; Choix de la justification.; in	A4.L	^table;	D0.W	nb de modifs; out	D0.W	nb de modifs;	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D0.L, D3.L, D7.WDBOXJUSTIF:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.L	A1,A4		; A1 <-- ^table	LOAD.L	A2,#R16"TDBOX$	LOAD.W	D7,#DB_MEMPT	PAGE_	DBOX		; mj ^table dbox	CLR.L	D4	LOAD.B	D4,(A1)+OJSMODE	; D4 <-- fanions	LOAD.W	(A5)+ODBP1,(A1)+OJSESPC	LOAD.W	(A5)+ODBP2,(A1)+OJSPVID	LOAD.W	(A5)+ODBP3,(A1)+OJSITCA	LOAD.L	A2,#R16"TDBOX_JUSTIF	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.W	D7,#DB_OPEN	PAGE_	DBOX		; ouvre la DBOX	JUMP,NE EXIT$	PUSH.L	D4	LOAD.W	D2,#20!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A1)+OJSNAME	LIB	?AFTEXT		; affiche le nom de la mise en page	POP.L	D4	LOAD.W	D2,#2^BDBGCLABEL!200	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	LOAD.W	D2,#2^BDBGCLABEL!201	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	LOAD.W	D2,#2^BDBGCLABEL!202	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	LOAD.W	D2,#2^BDBGCLABEL!203	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	CLR.W	D2AFF$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_AFF	PAGE_	DBOX		; affiche le paramtre	INC.W	D2	COMP.W	D2,#3	JUMP,LO AFF$	CLR.W	D2NLINE$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_MEDIT	PAGE_	DBOXLOOP$:	LOAD.W	D7,#MI_SCMO	PAGE_	MISC		; remet la souris	DBOX_	EDIT		; attend une action ...	LOAD.W	D7,#DB_ZEROCR	PAGE_	DBOX		; remplace <CR> par <0>	PUSH.L	A1	LOAD.L	A1,#R16"TKEY_JUSTIF	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	POP.L	A1	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#UNDO	JUMP,EQ UNDO$	COMP.W	D3,#CLEAR	JUMP,EQ UNDO$	COMP.W	D3,#CR	JUMP,EQ RETURN$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,#3	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$KEYDBOX$:			; KEYDBOX =>	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	COMP.B	D3,#100	JUMP',HS CLINE$	JUMP	LOOP$CLINE$:	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$CLIC$:	LOAD.W	D7,#DB_CLIC	PAGE_	DBOX	JUMP,NE BIP$	JUMP	NLINE$OK$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	LOAD.B	(A1)+OJSMODE,D4	LOAD.W	(A1)+OJSESPC,(A5)+ODBP1	LOAD.W	(A1)+OJSPVID,(A5)+ODBP2	LOAD.W	(A1)+OJSITCA,(A5)+ODBP3	INC.W	D0		; D0 <-- une modification de plusEND$:	LOAD.W	D7,#DB_CLOSE	PAGE_	DBOX		; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	ODBP1,DBTYPN,0,100,5,2^BDBGCLABEL!100,0,3+2	.W	ODBP2,DBTYPN,0,100,5,2^BDBGCLABEL!101,1,3+2	.W	ODBP3,DBTYPUS,-1000*FACMMPT,1000*FACMMPT,01*FACMMPT,2^BDBGCLABEL!102,2,8+2	.W	-1TDBOX_JUSTIF:	.W	10$-TDBOX_JUSTIF	.W	20$-TDBOX_JUSTIF	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Mise en page: "	.B	ODBLABEL,20	.B	ODBTEXT,0	.B	ODBCR,ODBCR2	.B	ODBLABEL,200	.B	ODBTEXT,0	.B	ODBCR	.B	ODBLCIRCLE,BJSMDA	.ASCIZ	" align, "	.B	ODBTEXT	.ASCIZ	"espacement dans les mots"	.B	ODBLABEL,100	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTEXT	.ASCIZ	"  %"	.B	ODBCR	.B	ODBLCIRCLE,BJSMDD	.ASCIZ	" drapeau  droite"	.B	ODBCR	.B	ODBLCIRCLE,BJSMDG	.ASCIZ	" drapeau  gauche"	.B	ODBCR	.B	ODBLCIRCLE,BJSMDC	.ASCIZ	" centr"	.B	ODBCR	.B	ODBLABEL,201	.B	ODBTEXT,0	.B	ODBCR	.B	ODBSQUARE,BJSMDM	.ASCIZ	" divisions"	.B	ODBTABX,20	.B	ODBTEXT	.ASCIZ	"zone de coupure"	.B	ODBLABEL,101	.B	ODBCLINE,(3+2)!2^7,KEYDBOX/H'100,101,TDBNORM	.B	ODBTEXT	.ASCIZ	"  %"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"   dans les mots"	.B	ODBCR	.B	ODBLABEL,202	.B	ODBTEXT,0	.B	ODBCR,ODBCR2	.B	ODBTEXT	.ASCIZ	"Interlettrage "	.B	ODBLABEL,102	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,102,TDBNORM	.B	ODBCR	.B	ODBLABEL,203	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_JUSTIF:	.W	F1,F2,F3,0		DOKF1-TKEY_JUSTIF	.W	F0,F13,F14,F15,0	DOKF0-TKEY_JUSTIF	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_JUSTIF	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_JUSTIF	.W	0;-----------\\; DBOXESPACE >;===========/; Choix de l'espacement.; in	A4.L	^table;	D0.W	nb de modifs; out	D0.W	nb de modifs;	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D0.L, D3.L, D7.WDBOXESPACE:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.L	A1,A4		; A1 <-- ^table	LOAD.L	A2,#R16"TDBOX$	LOAD.W	D7,#DB_MEMPT	PAGE_	DBOX		; mj ^table dbox	LOAD.W	(A5)+ODBP1,(A1)+OJSESPG	LOAD.W	(A5)+ODBP2,(A1)+OJSESPR	LOAD.W	(A5)+ODBP3,(A1)+OJSESPD	LOAD.W	(A5)+ODBP4,(A1)+OJSESPH	LOAD.W	(A5)+ODBP5,(A1)+OJSESPB	CLR.L	D4		; D4 <-- fanions	LOAD.L	A2,#R16"TDBOX_ESPACE	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.W	D7,#DB_OPEN	PAGE_	DBOX		; ouvre la DBOX	JUMP,NE EXIT$	PUSH.L	D4	LOAD.W	D2,#20!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A1)+OJSNAME	LIB	?AFTEXT		; affiche le nom de la mise en page	POP.L	D4	LOAD.W	D2,#2^BDBGCLABEL!200	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	LOAD.W	D2,#2^BDBGCLABEL!201	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	CLR.W	D2AFF$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_AFF	PAGE_	DBOX		; affiche le paramtre	INC.W	D2	COMP.W	D2,#5	JUMP,LO AFF$	CLR.W	D2NLINE$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_MEDIT	PAGE_	DBOXLOOP$:	LOAD.W	D7,#MI_SCMO	PAGE_	MISC		; remet la souris	DBOX_	EDIT		; attend une action ...	LOAD.W	D7,#DB_ZEROCR	PAGE_	DBOX		; remplace <CR> par <0>	PUSH.L	A1	LOAD.L	A1,#R16"TKEY_ESPACE	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	POP.L	A1	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#CLEAR	JUMP',EQ UNDO$	COMP.W	D3,#CR	JUMP',EQ RETURN$	COMP.W	D3,#ENTER	JUMP',EQ ENTER$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,#5	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$ENTER$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	JUMP	LOOP$KEYDBOX$:			; KEYDBOX =>	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	COMP.B	D3,#100	JUMP',HS CLINE$	JUMP	LOOP$CLINE$:	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$CLIC$:	LOAD.W	D7,#DB_CLIC	PAGE_	DBOX	JUMP,NE BIP$	JUMP	NLINE$OK$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	LOAD.W	(A1)+OJSESPG,(A5)+ODBP1	LOAD.W	(A1)+OJSESPR,(A5)+ODBP2	LOAD.W	(A1)+OJSESPD,(A5)+ODBP3	LOAD.W	(A1)+OJSESPH,(A5)+ODBP4	LOAD.W	(A1)+OJSESPB,(A5)+ODBP5	INC.W	D0		; D0 <-- une modification de plusEND$:	LOAD.W	D7,#DB_CLOSE	PAGE_	DBOX		; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	ODBP1,DBTYPU,0,2000*FACMMPT,10*FACMMPT,2^BDBGCLABEL!100,0,8+2	.W	ODBP2,DBTYPUS,-2000*FACMMPT,+2000*FACMMPT,10*FACMMPT,2^BDBGCLABEL!101,2,8+2	.W	ODBP3,DBTYPU,0,2000*FACMMPT,10*FACMMPT,2^BDBGCLABEL!102,4,8+2	.W	ODBP4,DBTYPU,0,2000*FACMMPT,10*FACMMPT,2^BDBGCLABEL!103,1,8+2	.W	ODBP5,DBTYPU,0,2000*FACMMPT,10*FACMMPT,2^BDBGCLABEL!104,3,8+2	.W	-1TDBOX_ESPACE:	.W	10$-TDBOX_ESPACE	.W	20$-TDBOX_ESPACE	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Mise en page: "	.B	ODBLABEL,20	.B	ODBTEXT,0	.B	ODBCR,ODBCR2	.B	ODBLABEL,200	.B	ODBTEXT,0	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"Espacements pour le paragraphe :"	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Gauche       "	.B	ODBLABEL,100	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBTABX,30	.B	ODBTEXT	.ASCIZ	"Avant  "	.B	ODBLABEL,103	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,103,TDBNORM	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Renfoncement "	.B	ODBLABEL,101	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,101,TDBNORM	.B	ODBTABX,30	.B	ODBTEXT	.ASCIZ	"Aprs  "	.B	ODBLABEL,104	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,104,TDBNORM	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Droite       "	.B	ODBLABEL,102	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,102,TDBNORM	.B	ODBCR	.B	ODBLABEL,201	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_ESPACE:	.W	F1,F2,F3,0		DOKF1-TKEY_ESPACE	.W	F0,F13,F14,F15,0	DOKF0-TKEY_ESPACE	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_ESPACE	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_ESPACE	.W	0;-----------\\; DBOXINTERL >;===========/; Choix de l'interligne.; in	A4.L	^table;	D0.W	nb de modifs; out	D0.W	nb de modifs;	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D0.L, D3.L, D7.WDBOXINTERL:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.L	A1,A4		; A1 <-- ^table	LOAD.L	A2,#R16"TDBOX$	LOAD.W	D7,#DB_MEMPT	PAGE_	DBOX		; mj ^table dbox	LOAD.W	(A5)+ODBP1,(A1)+OJSILVA	LOAD.W	(A5)+ODBP5,(A1)+OJSCHAR	LOAD.L	D4,(A1)+OJSILFL	LOAD.L	A2,#R16"TDBOX_INTERL	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.W	D7,#DB_OPEN	PAGE_	DBOX		; ouvre la DBOX	JUMP,NE EXIT$	PUSH.L	D4	LOAD.W	D2,#20!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A1)+OJSNAME	LIB	?AFTEXT		; affiche le nom de la mise en page	POP.L	D4	LOAD.W	D2,#2^BDBGCLABEL!200	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	LOAD.W	D2,#2^BDBGCLABEL!201	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	LOAD.W	D2,#2^BDBGCLABEL!202	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	CALL	DBCARDRAW	; affiche le caractre de fond	CLR.W	D2AFF$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_AFF	PAGE_	DBOX		; affiche le paramtre	INC.W	D2	COMP.W	D2,#1	JUMP,LO AFF$	CLR.W	D2NLINE$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_MEDIT	PAGE_	DBOXLOOP$:	LOAD.W	D7,#MI_SCMO	PAGE_	MISC		; remet la souris	DBOX_	EDIT		; attend une action ...	LOAD.W	D7,#DB_ZEROCR	PAGE_	DBOX		; remplace <CR> par <0>	PUSH.L	A1	LOAD.L	A1,#R16"TKEY_INTERL	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	POP.L	A1	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#CLEAR	JUMP',EQ UNDO$	COMP.W	D3,#CR	JUMP',EQ RETURN$	COMP.W	D3,#ENTER	JUMP',EQ ENTER$;;?	COMP.W	D3,#F7;;?	JUMP,EQ CCHAR$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,#1	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$ENTER$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	JUMP	LOOP$KEYDBOX$:			; KEYDBOX =>	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	COMP.B	D3,#8	JUMP',LO MSK07$	COMP.B	D3,#32	JUMP',LO MSK32$	COMP.B	D3,#100	JUMP',HS CLINE$	JUMP	LOOP$MSK07$:	CLR.B	D4	TSET.L	D4:D3	JUMP	NLINE$MSK32$:	AND.L	D4,#H'0000FFFF	TSET.L	D4:D3	JUMP	LOOP$CLINE$:	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$CLIC$:	LOAD.W	D7,#DB_CLIC	PAGE_	DBOX	JUMP,NE BIP$	LOAD.B	D4,#2^BJSILV	JUMP	NLINE$;;?CCHAR$:;;?	LOAD.W	D7,#DB_PUT;;?	PAGE_	DBOX;;?	JUMP,NE BIP$;;?;;?	CALL	DBCARCHOIX	; choix du caractre de fond ...;;?	JUMP,NE BIP$;;?;;?	LOAD.W	(A5)+ODBP1,D1;;?	CLR.W	D2;;?	LOAD.W	D7,#DB_GET;;?	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre;;?	LOAD.W	D7,#DB_AFF;;?	PAGE_	DBOX		; affiche le paramtre;;?;;?	LOAD.B	D4,#2^BJSILC;;?	JUMP	NLINE$OK$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	LOAD.L	(A1)+OJSILFL,D4	LOAD.W	(A1)+OJSILVA,(A5)+ODBP1	LOAD.W	(A1)+OJSCHAR,(A5)+ODBP5	INC.W	D0		; D0 <-- une modification de plusEND$:	LOAD.W	D7,#DB_CLOSE	PAGE_	DBOX		; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	ODBP1,DBTYPU,0,2000*FACMMPT,01*FACMMPT,2^BDBGCLABEL!100,0,8+2	.W	-1TDBOX_INTERL:	.W	10$-TDBOX_INTERL	.W	20$-TDBOX_INTERL	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Mise en page: "	.B	ODBLABEL,20	.B	ODBTEXT,0	.B	ODBCR,ODBCR2	.B	ODBLABEL,200	.B	ODBTEXT,0	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"Interligne"	.B	ODBTABX,12	.B	ODBCIRCLE,BJSILC!2^7!2^6,KEYDBOX/H'100,BJSILC	.ASCIZ	" du caractre "	.B	ODBLABEL,150	.B	ODBTEXT,0	.B	ODBCR,ODBCR2	.B	ODBTABX,12	.B	ODBCIRCLE,BJSILV!2^7!2^6,KEYDBOX/H'100,BJSILV	.ASCIZ	" autre "	.B	ODBLABEL,100	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBCR,ODBCR,ODBCR2	.B	ODBCIRCLE,BJSIL05!2^7!2^6,KEYDBOX/H'100,BJSIL05	.ASCIZ	" 0.5"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCIRCLE,BJSIL08!2^7!2^6,KEYDBOX/H'100,BJSIL08	.ASCIZ	" 0.8"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCIRCLE,BJSIL10!2^7!2^6,KEYDBOX/H'100,BJSIL10	.ASCIZ	" 1"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCIRCLE,BJSIL12!2^7!2^6,KEYDBOX/H'100,BJSIL12	.ASCIZ	" 1.2"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCIRCLE,BJSIL15!2^7!2^6,KEYDBOX/H'100,BJSIL15	.ASCIZ	" 1.5"	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCIRCLE,BJSIL20!2^7!2^6,KEYDBOX/H'100,BJSIL20	.ASCIZ	" 2"	.B	ODBCR	.B	ODBLABEL,201	.B	ODBTEXT,0	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"Agrandissement automatique de l'interligne :"	.B	ODBCR,ODBCR2	.B	ODBSQUARE,BJSILAI	.ASCIZ	" si indice ou exposant"	.B	ODBCR	.B	ODBSQUARE,BJSILAC	.ASCIZ	" si grands caractres"	.B	ODBCR	.B	ODBLABEL,202	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" D'ACCORD "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_INTERL:	.W	F1,F2,F3,0		DOKF1-TKEY_INTERL	.W	F0,F13,F14,F15,0	DOKF0-TKEY_INTERL	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_INTERL	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_INTERL	.W	0;----------\\; DBOXTABUL >;==========/; Choix des tabulateurs.; in	A4.L	^table;	D0.W	nb de modifs; out	D0.W	nb de modifs;	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D0.L, D3.L, D7.WDBOXTABUL:	PUSHM.L	D1,D2,D4,D5,A1..A4	LOAD.L	A1,A4		; A1 <-- ^table	LOAD.L	A2,#R16"TDBOX$	LOAD.W	D7,#DB_MEMPT	PAGE_	DBOX		; mj ^table dbox	LOAD.W	(A5)+ODBP1,(A5)+ORGTNB	LOAD.W	(A5)+ODBP2,(A5)+ORGTPI	LOAD.W	(A5)+ODBP3,(A5)+ORGTES	CLR.L	D4	LOAD.W	D4,(A5)+ORGTFL	LOAD.L	A2,#R16"TDBOX_TABUL	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	LOAD.W	D7,#DB_OPEN	PAGE_	DBOX		; ouvre la DBOX	JUMP,NE EXIT$	PUSH.L	D4	LOAD.W	D2,#20!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LOAD.L	A3,#(A1)+OJSNAME	LIB	?AFTEXT		; affiche le nom de la mise en page	POP.L	D4	LOAD.W	D2,#2^BDBGCLABEL!200	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	LOAD.W	D2,#2^BDBGCLABEL!201	LOAD.W	D7,#DB_HLINE	PAGE_	DBOX	PUSH.L	D4	LOAD.W	D1,(A0)+ODFCX	MUL.WU	D1,#3	LOAD.W	D2,#50!2^BDBGCLABEL	DBOX_	GETCO	ADD.W	D3,D1	SWAP.W	D3	SUB.W	D3,#2	SWAP.W	D3	LIB	?SETCURS	LIB	?AFTIM	.B	USEGC,GCICF,GCICS,GCICTP	.B	AFTOUT,ICORGTABD,AFNORM	.B	0	.EVEN	LOAD.W	D2,#51!2^BDBGCLABEL	DBOX_	GETCO	ADD.W	D3,D1	SWAP.W	D3	SUB.W	D3,#2	SWAP.W	D3	LIB	?SETCURS	LIB	?AFTIM	.B	AFTOUT,ICORGTABG,AFNORM	.B	0	.EVEN	LOAD.W	D2,#52!2^BDBGCLABEL	DBOX_	GETCO	ADD.W	D3,D1	SWAP.W	D3	SUB.W	D3,#2	SWAP.W	D3	LIB	?SETCURS	LIB	?AFTIM	.B	AFTOUT,ICORGTABG,ICORGTABC,AFNORM	.B	0	.EVEN	LOAD.W	D2,#53!2^BDBGCLABEL	DBOX_	GETCO	ADD.W	D3,D1	SWAP.W	D3	SUB.W	D3,#2	SWAP.W	D3	LIB	?SETCURS	LIB	?AFTIM	.B	AFTOUT,ICORGTABG,ICORGTABN,AFNORM	.B	0	.EVEN	LOAD.W	D2,#54!2^BDBGCLABEL	DBOX_	GETCO	ADD.W	D3,D1	SWAP.W	D3	SUB.W	D3,#2	SWAP.W	D3	LIB	?SETCURS	LIB	?AFTIM	.B	AFTOUT,ICORGTABI,AFNORM	.B	USEGC,GCTXF,GCTXS,GCTXT	.B	0	.EVEN	POP.L	D4	CLR.W	D2AFF$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_AFF	PAGE_	DBOX		; affiche le paramtre	INC.W	D2	COMP.W	D2,#3	JUMP,LO AFF$	CLR.W	D2NLINE$:	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	LOAD.W	D7,#DB_MEDIT	PAGE_	DBOXLOOP$:	LOAD.W	D7,#MI_SCMO	PAGE_	MISC		; remet la souris	DBOX_	EDIT		; attend une action ...	LOAD.W	D7,#DB_ZEROCR	PAGE_	DBOX		; remplace <CR> par <0>	PUSH.L	A1	LOAD.L	A1,#R16"TKEY_TABUL	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	POP.L	A1	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ OK$	COMP.W	D3,#F4	JUMP,EQ KILL$	COMP.W	D3,#F0	JUMP,EQ END$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#CLEAR	JUMP',EQ UNDO$	COMP.W	D3,#CR	JUMP',EQ RETURN$	COMP.W	D3,#ENTER	JUMP',EQ ENTER$	LOAD.W	D1,D3	AND.W	D1,#H'FF00	COMP.W	D1,#KEYDBOX	JUMP,EQ KEYDBOX$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A4)	JUMP	LOOP$RETURN$:			; RETURN =>	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	INC.W	D2		; D2 <-- paramtre suivant	COMP.W	D2,#3	JUMP,LO NLINE$	CLR.W	D2	JUMP	NLINE$ENTER$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	LOAD.W	D7,#DB_GET	PAGE_	DBOX		; A3/A4 <-- ^dbut/fin paramtre	JUMP	LOOP$KEYDBOX$:			; KEYDBOX =>	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	COMP.B	D3,#100	JUMP',HS CLINE$	JUMP	LOOP$CLINE$:	CLR.W	D2	LOAD.B	D2,D3	SUB.W	D2,#100	JUMP	NLINE$CLIC$:	LOAD.W	D7,#DB_CLIC	PAGE_	DBOX	JUMP,NE BIP$	JUMP	NLINE$OK$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	LOAD.W	(A5)+ORGTFL,D4	LOAD.W	(A5)+ORGTNB,(A5)+ODBP1	LOAD.W	(A5)+ORGTPI,(A5)+ODBP2	LOAD.W	(A5)+ORGTES,(A5)+ODBP3	LOAD.L	A4,#(A1)+OJSTABS	LOAD.W	D1,#ICORGTABD	TEST.L	D4:#0	JUMP',BS OK2$	LOAD.W	D1,#ICORGTABG	TEST.L	D4:#1	JUMP',BS OK2$	LOAD.W	D1,#ICORGTABC	TEST.L	D4:#2	JUMP',BS OK2$	LOAD.W	D1,#ICORGTABN	TEST.L	D4:#3	JUMP',BS OK2$	LOAD.W	D1,#ICORGTABIOK2$:	LOAD.W	D4,(A5)+ORGTPI	LOAD.W	D2,(A5)+ORGTNBOK3$:	LOAD.W	(A4+),D4	LOAD.W	(A4+),D1	ADD.W	D4,(A5)+ORGTES	DEC.W	D2	JUMP,NE OK3$	CLR.L	(A4)	INC.W	D0		; D0 <-- une modification de plus	JUMP'	END$KILL$:	LOAD.W	D7,#DB_PUT	PAGE_	DBOX	JUMP,NE BIP$	CLR.L	(A1)+OJSTABS	; supprime tous les tabulateurs	INC.W	D0		; D0 <-- une modification de plusEND$:	LOAD.W	D7,#DB_CLOSE	PAGE_	DBOX		; ferme la DBOXEXIT$:	POPM.L	D1,D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX$:	.W	ODBP1,DBTYPN,1,JSMAXTAB,1,2^BDBGCLABEL!100,0,2+2	.W	ODBP2,DBTYPU,10*FACMMPT,2000*FACMMPT,10*FACMMPT,2^BDBGCLABEL!101,1,8+2	.W	ODBP3,DBTYPU,10*FACMMPT,2000*FACMMPT,10*FACMMPT,2^BDBGCLABEL!102,2,8+2	.W	-1TDBOX_TABUL:	.W	10$-TDBOX_TABUL	.W	20$-TDBOX_TABUL	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Mise en page: "	.B	ODBLABEL,20	.B	ODBTEXT,0	.B	ODBCR,ODBCR2	.B	ODBLABEL,200	.B	ODBTEXT,0	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"Nombre de tabu-"	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"lateurs  poser   "	.B	ODBLABEL,100	.B	ODBCLINE,(2+2)!2^7,KEYDBOX/H'100,100,TDBNORM	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Position initiale "	.B	ODBLABEL,101	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,101,TDBNORM	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Espacement        "	.B	ODBLABEL,102	.B	ODBCLINE,(8+2)!2^7,KEYDBOX/H'100,102,TDBNORM	.B	ODBCR,ODBCR	.B	ODBLABEL,50	.B	ODBCIRCLE,0	.ASCIZ	"   "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBLABEL,51	.B	ODBCIRCLE,1	.ASCIZ	"   "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBLABEL,52	.B	ODBCIRCLE,2	.ASCIZ	"   "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBLABEL,53	.B	ODBCIRCLE,3	.ASCIZ	"   "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBLABEL,54	.B	ODBCIRCLE,4	.ASCIZ	"   "	.B	ODBCR	.B	ODBLABEL,201	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	"  POSE  "	.B	ODBBOX,0,F4,TDBNORM	.ASCIZ	" SUPPRIME "	.B	ODBTEXT	.ASCIZ	" "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Pose"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Supprime"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_TABUL:	.W	F1,F2,F3,0		DOKF1-TKEY_TABUL	.W	F4,F5,F6,0		DOKF4-TKEY_TABUL	.W	F0,F13,F14,F15,0	DOKF0-TKEY_TABUL	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_TABUL	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_TABUL	.W	0;----------\\; PUTNAMET1 >;==========/; Met le nom dans ODBT1.; in	A1.L	^table de justification; out	-; mod	D7.WPUTNAMET1:	PUSHM.L	A3,A4	LOAD.L	A3,#(A1)+OJSNAME	LOAD.L	A4,#(A5)+ODBT1XFER$:	LOAD.B	(A4+),(A3+)	JUMP,NE XFER$	POPM.L	A3,A4	RET;----------\\; GETNAMET1 >;==========/; Prend le nom dans ODBT1.; in	A1.L	^table de justification; out	-; mod	D7.WGETNAMET1:	PUSHM.L	A3,A4	LOAD.L	A3,#(A1)+OJSNAME	LOAD.L	A4,#(A5)+ODBT1XFER$:	LOAD.B	(A3+),(A4+)	JUMP,NE XFER$	POPM.L	A3,A4	RET;-----------\\; DBCARCHOIX >;===========/; Choix du caractre de fond.; in	-; out	D1.W	interligne;	D7.W	erreur; mod	D1.L, D7.WDBCARCHOIX:	PUSH.L	D2	LOAD.W	D2,(A5)+ODBP5	CALL	DBCMMENU	; choix selon mmenu ...	JUMP',NE EXIT$	LOAD.W	(A5)+ODBP5,D2	CALL	DBCARDRAW	; affiche le caractre de fond	CLR.W	D7		; D7 <-- okEXIT$:	POP.L	D2	TEST.W	D7		; retour EQ/NE	RET;----------\\; DBCARDRAW >;==========/; Affiche le nom du caractre de fond.; in	-; out	D1.W	interligne; mod	D1.L, D7.WDBCARDRAW:	PUSHM.L	D0,D2..D4,A2..A4	LOAD.W	D3,(A5)+ODBP5	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D0,#IDENTCHAR	LOAD.W	D1,#opDGETDIM	PAGE_	OBJCALL		; A2/A3/A4/D3/D4 <-- ^nom de fonction	LOAD.W	D1,D4		; D1 <-- interligne	LOAD.W	D2,#150!2^BDBGCLABEL	DBOX_	GETCO	LIB	?SETCURS	LIB	?AFTIM	.B	MSPACE,15,0	.EVEN	LIB	?SETCURS	LOAD.L	A3,A2	LIB	?AFTEXT		; affiche le nom	POPM.L	D0,D2..D4,A2..A4	RET;---------\\; DBJMMENU >;---------/; Choix d'un nom de justification.; in	A4.L	^objet;	D2.W	justification actuelle; out	D2.W	nouvelle justification;	D7.W	erreur; mod	D2.L, D7.WDBJMMENU:	PUSHM.L	D1,D3,D4,A1..A4	LOAD.L	A2,A4		; A2 <-- ^objet	LOAD.L	D4,#NBJUST*(16+4)	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^buffer	JUMP',NE EXIT$	LOAD.L	A1,A4		; A1 <-- ^buffer	LOAD.L	A4,A2		; A4 <-- ^objet	LOAD.L	A3,A1		; A3 <-- ^buffer	CALL	XopDGETMENU	; construit le mmenu	LOAD.W	D3,D2	LOAD.L	A3,A1		; A3 <-- ^buffer	LIB	?MMENU		; choix dans mmenu ...	JUMP',NE ERROR$	LOAD.W	D2,D3		; D2 <-- nouvelle justification	CLR.W	D7		; D7 <-- okERROR$:	PUSH.W	D7	LOAD.L	A4,A1		; A3 <-- ^buffer	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le buffer	POP.W	D7EXIT$:	POPM.L	D1,D3,D4,A1..A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBCMMENU >;---------/; Choix d'un nom de caractre.; in	D2.W	caractre actuel; out	D2.W	nouveau caractre;	D7.W	erreur; mod	D2.L, D7.WDBCMMENU:	PUSHM.L	D0,D1,D3,D4,A2..A4	LOAD.L	D4,#16*(16+4)	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; A4 <-- ^buffer	JUMP',NE EXIT$	LOAD.L	A2,A4		; A2 <-- ^buffer	LOAD.L	A3,A4		; A3 <-- ^buffer	LOAD.L	A4,#0		; A4 <-- objet par dfaut	LOAD.W	D0,#IDENTCHAR	LOAD.W	D1,#opDGETMENU	PAGE_	OBJCALL		; construit le mmenu	LOAD.W	D3,D2	LOAD.L	A3,A2		; A3 <-- ^buffer	LIB	?MMENU		; choix dans mmenu ...	JUMP',NE ERROR$	LOAD.W	D2,D3		; D2 <-- nouveau caractre	CLR.W	D7		; D7 <-- okERROR$:	PUSH.W	D7	LOAD.L	A4,A2		; A3 <-- ^buffer	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre le buffer	POP.W	D7EXIT$:	POPM.L	D0,D1,D3,D4,A2..A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DOK...  >;========/DOKMGR:	LOAD.W	D3,#KEYMGR	RETDOKMGP:	LOAD.W	D3,#KEYMGP	RETDOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RETDOKF4:	LOAD.W	D3,#F4	RETDOKF7:	LOAD.W	D3,#F7	RETDOKF9:	LOAD.W	D3,#F9	RETDOKF10:	LOAD.W	D3,#F10	RET	.END