	.CHAP	RESAIDE.ASI;	Outils pour dvelopper un fichier de ressources;	en assembleur.;	Ce fichier fournit les macros permettant de rduire;	sensiblement l'effort  fournir pour crer un fichier;	de ressources...;	Utilisez ce fichier (collez-le par un .INS) depuis un;	fichier .ASR ("assembler resource") et en passant par;	ASCALM ou SMILEC.;	RESHEAD	"nom", "langue", rvision, version;	------------------------------------------	.MACRO	RESHEAD	.32	RESPATTERN	.16	%3,%4	.32	0	.FILL.8	4,0	.ASCII	"%1"	.FILL.8	ORFILENAME-APC+16,0	.ASCII	"%2"	.FILL.8	ORFILELANG-APC+16,0	.32	NBTYPES	.32	NBRES	.FILL.8	8,0xNBRES	== 0xNBTYPES== 0	.ENDMACRO;	RESEND;	------	.MACRO	RESENDNBRES	= xNBRESNBTYPES	= xNBTYPES	.ENDMACRO;	CRETYP	id_du_type, "nom";	-------------------------	.MACRO	CRETYP_%1:	.32	%1	.32	(FIN$-DEBUT$)/LRTA	.32	END$-DEBUT$	.16	0	.FILL.8	2,0	.ASCII	"%2"	.FILL.8	ORTYPNAME+_%1+16-APC,0xRESCNT	== 0xRESREG	== 0xNBTYPES== xNBTYPES+1DEBUT$:	.ENDMACRO;	TYPDATA	tiquette		( ressource RESDKDATA normale );	-----------------	.MACRO	TYPDATA	.32	RESDKDATA*(2**24)+(B%1$-A%1$)	.32	A%1$	.32	xRESREGxRESREG	== xRESREG+1xRESCNT	== xRESCNT+1	.ENDMACRO;	TYPBUIL	tiquette		( ressource RESDKBUILD );	-----------------	.MACRO	TYPBUIL	.32	RESDKBUILD*(2**24)+(B%1$-A%1$)	.32	A%1$	.32	xRESREGxRESREG	== xRESREG+1xRESCNT	== xRESCNT+1	.ENDMACRO;	TYPPVAR	offset,taille		( ressource RESDKPROGVAR );	---------------------	.MACRO	TYPPVAR	.32	RESDKPROGVAR*(2**24)+((%2).AND.16'00FFFFFF)	.32	%1	.32	xRESREGxRESREG	== xRESREG+1	.ENDMACRO;	DATAON	tiquette;	-----------------	.MACRO	DATAON	.IF	xRESCNT.GT.0FIN$:	xRESMAX == xRESCNT		; maximum  atteindre	xRESCNT	== 0	.ENDIFA%1$:	.ENDMACRO;	DATAOFF	tiquette;	-----------------	.MACRO	DATAOFFB%1$:	.ALIGN	4xRESMAX	== xRESMAX-1	.IF	xRESMAX.EQ.0END$:xNBRES	== xNBRES+(FIN$-DEBUT$)/LRTA	.ENDIF	.ENDMACRO;	SYSTYP  id_du_type;	------------------	.MACRO	SYSTYP	.IF	%1.EQ.RtypSTRING	CRETYP	%1,"StringOfChar"	.ENDIF	.IF	%1.EQ.RtypPASTRING	CRETYP	%1,"PascalString"	.ENDIF	.IF	%1.EQ.RtypDISPLAY	CRETYP	%1,"DisplayString"	.ENDIF	.IF	%1.EQ.RtypSOFTKEYS	CRETYP	%1,"SoftKeys"	.ENDIF	.IF	%1.EQ.RtypMMENUS	CRETYP	%1,"MouseMenus"	.ENDIF	.IF	%1.EQ.RtypDBOX	CRETYP	%1,"DialogBox"	.ENDIF	.IF	%1.EQ.RtypRASTER	CRETYP	%1,"Raster"	.ENDIF	.IF	%1.EQ.RtypSOUND	CRETYP	%1,"SoundString"	.ENDIF	.ENDMACRO;	Exemple de gnration d'un fichier de ressources :;	--------------------------------------------------;;	RESHEAD	"Essai","franais",0,0;;	SYSTYP	RtypDISPLAY			; type  gnrer;;	TYPDATA	Bonjour				; premire donne;	TYPDATA	AuRevoir			; seconde;	TYPPVAR	0,10				; donne au format RESDKPROGVAR;	TYPBUIL	Building			; donne construite;;	DATAON	Bonjour				; premire donne;	.ASCII	"<EOP>Bonjour !";	DATAOFF	Bonjour;;	DATAON	AuRevoir			; seconde donne;	.ASCII	"<AFINV>Au revoir !<AFDIR>";	DATAOFF	AuRevoir;;	DATAON	Building			; donne construite;	.16	RBCOPY;	.32	RtypDISPLAY,1			; colle une copie de "Au revoir !";	.16	RBEND;	DATAOFF	Building;;	RESEND	.END