	.SBTTL	OPCOLDBOX.ASI;-----------\\; XopDGETUSE >;===========/; Donne la couleur utilise.; in	A0.L	canal; out	D3.W	numro de la couleur utilise;	D7.W	erreur; mod	D3.L, D7.WXopDGETUSE:	LOAD.W	D3,(A0)+OCUSE	; D3 <-- couleur utilise	CLR.W	D7		; D7 <-- ok	RET;--------\\; XopDUSE >;========/; Utilise la bonne couleur.; in	A0.L	canal;	A4.L	^table des couleurs/nil si par dfaut;	D3.W	numro de la couleur;	D2.W	mode de dessin; out	D7.W	erreur; mod	D7.WXopDUSE:	PUSHM.L	D3,D4,A0,A3..A5	LOAD.L	A5,A0		; A5 <-- ^variables globales	LOAD.L	A0,(A5)+OPDDIS	; A0 <-- ^descripteur fentre	LOAD.W	(A5)+OCUSE,D3	; OCUSE <-- couleur utilise	LOAD.W	D7,#DR_GETPRINT	PAGE_	DRAW		; D4 <-- mode d'impression	TEST.L	D4:#BPRIPS	; impression PostScript ?	JUMP,BS OK$		; oui => OK$	COMP.L	A4,#0		; objet par dfaut ?	JUMP',NE NODEF$		; non => NODEF$	LOAD.L	A4,(A5)+OPDEF	; A4 <-- ^objet couleur par dfautNODEF$:	MUL.WU	D3,#LDCOL	ADD.L	A4,D3		; A4 <-- ^couleur	LOAD.W	D7,#1		; D7 <-- couleur n'existe pas	TEST.B	(A4)+OCOLNM	; nom existe ?	JUMP,EQ EXIT$		; non => EXIT$	TEST.L	D4:#BPRIQB	; quadrichromie noir ?	JUMP',BC CONV$	TEST.B	(A4)+OCOLFA+1:#BCOLPAN-0 ; couleur PANTONE ?	JUMP',BC CONV$	LOAD.W	D4,(A4)+OCOLK	; D4 <-- intensit du noir	SUB.L	SP,#6	LOAD.L	A4,SP		; A4 <-- ^buffer pour couleur RGB	LOAD.W	(A4)+0,D4	LOAD.W	(A4)+2,D4	; fait un gris avec la bonne intensit	LOAD.W	(A4)+4,D4	LOAD.W	D7,#DR_COLORCONV	PAGE_	DRAW		; D4 <-- couleur de la palette	ADD.L	SP,#6	JUMP'	PUT$CONV$:	LOAD.L	A4,#(A4)+OCOLR	; A4 <-- ^couleur RGB	LOAD.W	D7,#DR_COLORCONV	PAGE_	DRAW		; D4 <-- couleur de la palettePUT$:	COMP.B	D2,#CLRDOT	JUMP',EQ CLR$	LOAD.L	(A0)+ODFCSF,D4	; ODFCSF <-- couleur pour dessiner	JUMP'	OK$CLR$:	LOAD.L	(A0)+ODFCCF,D4	; ODFCCF <-- couleur pour effacer;	JUMP'	OK$OK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D3,D4,A0,A3..A5	TEST.W	D7		; retour EQ/NE	RET;--------\\; XopDGET >;========/; Donne le numro du pinceau slectionn.; in	A0.L	canal;	A4.L	^table des couleurs/nil si par dfaut; out	D3.W	couleur slectionne;	D7.W	erreur; mod	D3.L, D7.WXopDGET:	PUSH.L	A4	COMP.L	A4,#0		; objet par dfaut ?	JUMP',NE NODEF$		; non => NODEF$	LOAD.L	A4,(A0)+OPDEF	; A4 <-- ^objet couleur par dfautNODEF$:	LOAD.W	D3,(A4)+OTACSEL	; D3 <-- couleur slectionne	POP.L	A4	CLR.W	D7		; retour EQ	RET;--------\\; XopDPUT >;========/; Spcifie le numro du pinceau.; in	A0.L	canal;	A4.L	^table des couleurs/nil si par dfaut;	D3.W	couleur  slectionner; out	D7.W	erreur; mod	D7.WXopDPUT:	PUSH.L	A4	COMP.L	A4,#0		; objet par dfaut ?	JUMP',NE NODEF$		; non => NODEF$	LOAD.L	A4,(A0)+OPDEF	; A4 <-- ^objet couleur par dfautNODEF$:	LOAD.W	(A4)+OTACSEL,D3	; slectionne une couleur	POP.L	A4	CLR.W	D7		; retour EQ	RET;------------\\; XopDTSELECT >;============/; Choisi et/ou modifie une couleur temporaire  utiliser.; in	A0.L	canal;	A4.L	^table des couleurs/nil si par dfaut;	D2.W	couleur  slectionner; out	D2.W	couleur slectionne;	D3.L	dernire touche (F1/F0);	D4.W	nb de couleurs modifies;	D7.W	erreur; mod	D2.L, D3.L, D4.L, D7.WXopDTSELECT:	PUSH.L	A4	COMP.L	A4,#0		; objet par dfaut ?	JUMP',NE NODEF$		; non => NODEF$	LOAD.L	A4,(A0)+OPDEF	; A4 <-- ^objet couleur par dfautNODEF$:	PUSH.W	(A4)+OTACSEL	; stack <-- couleur slectionne	LOAD.W	(A4)+OTACSEL,D2	; OTACSEL <-- couleur slectionne temporairement	CALL	XopDSELECT	; choisi/modifie une couleur ...	LOAD.W	D2,(A4)+OTACSEL	; D2 <-- couleur slectionne temporairement	POP.W	(A4)+OTACSEL	; OTACSEL <-- couleur slectionne initialement	POP.L	A4	TEST.W	D7		; retour EQ/NE	RET;-----------\\; XopDSELECT >;===========/; Choisi et/ou modifie une couleur  utiliser.; in	A0.L	canal;	A4.L	^table des couleurs/nil si par dfaut; out	D3.L	dernire touche (F1/F0);	D4.W	nb de couleurs modifies;	D7.W	erreur; mod	D3.L, D4.L, D7.WXopDSELECT:	PUSHM.L	D0..D2,D5,D6,A0..A5	LOAD.L	A5,A0		; A5 <-- ^variables globales	LOAD.L	A0,(A5)+OPDDIS	; A0 <-- ^descripteur fentre	COMP.L	A4,#0		; objet par dfaut ?	JUMP',NE NODEF$		; non => NODEF$	LOAD.L	A4,(A5)+OPDEF	; A4 <-- ^objet couleur par dfautNODEF$:	LOAD.L	(A5)+OPTAB,A4	; OPTAB <-- ^table des couleurs	LOAD.W	D6,(A4)+OTACSEL	; D6 <-- couleur slectionne	LOAD.L	A2,#R16"TDBOX_COL	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CALL	DBRGFAN		; D4 <-- fanions	LOAD.W	D7,#DB_OPEN	PAGE_	DBOX		; ouvre la DBOX	JUMP,NE EXIT$	PUSH.W	D4	LOAD.W	D3,#IDENTCOLOR	LOAD.L	A4,#(A5)+OUSBUF	LOAD.W	D4,#NBRX*NBRY	LOAD.W	D7,#DF_GETULIST	PAGE_	DEF		; OUSBUF <-- couleurs utilises	POP.W	D4	CALL	DBPALGET	; cran <-- image mmorise	JUMP',EQ PALOK$	CALL	DBRDESCADRE	; dessine les cadres des rectangles	CLR.W	D0	LOAD.W	D1,#NBRX*NBRY	CALL	DBRDESCOLS	; dessine toutes les couleurs	CALL	DBPALSAV	; buffer <-- image cranPALOK$:	CLR.W	D0	LOAD.W	D1,#NBRX*NBRY	CALL	DBRUSECOLS	; marque les utilises	LOAD.W	D0,D6	CALL	DBRINV		; inverse le rectangle slectionn	CLR.W	D0		; D0 <-- nb de couleurs modifiesLOOP$:	LOAD.W	D7,#MI_SCMO	PAGE_	MISC		; remet la souris	DBOX_	EDIT		; attend une action ...	LOAD.L	A1,#R16"TKEY_COL	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP,EQ CLIC$	COMP.W	D3,#F1	JUMP,EQ USE$	COMP.W	D3,#F4	JUMP,EQ MODIF$	COMP.W	D3,#F7	JUMP,EQ PREND$	COMP.W	D3,#F9	JUMP,EQ SAUVE$	COMP.W	D3,#F0	JUMP,EQ END$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$CLIC$:	CALL	DBRPFAN		; met  jour les fanions	LOAD.W	D3,D6	CALL	DBRSEL		; slectionne un nouveau rectangle	JUMP,NE BIP$	CALL	DBRGFAN		; D4 <-- fanions	COMP.W	D3,D6		; double-clic ?	JUMP,EQ USE$		; oui => USE$	JUMP	LOOP$MODIF$:	CALL	DBRPFAN		; met  jour les fanions	CALL	DBOXMODCOLOR	; modifie une couleur ...	PUSH.W	D7	LOAD.L	A2,#R16"TDBOX_COL	LOAD.W	D7,#DB_RSK	PAGE_	DBOX		; refait les soft-keys	POP.W	D7	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	PUSH.W	D0	LOAD.W	D0,D6	LOAD.W	D1,#1	CALL	DBRINV		; teint le rectangle slectionn	CALL	DBRDESCOLS	; dessine la couleur modifie	CALL	DBRUSECOLS	; marque l'utilise	CALL	DBPALSAV	; buffer <-- image cran	CALL	DBRINV		; allume le rectangle slectionn	POP.W	D0	INC.W	D0		; D0 <-- une couleur de plus modifie	JUMP	LOOP$PREND$:	CALL	COLPREND	; prend les couleurs ...	PUSH.W	D7	LOAD.L	A2,#R16"TDBOX_COL	LOAD.W	D7,#DB_RSK	PAGE_	DBOX		; refait les soft-keys	POP.W	D7	JUMP,NE BIP$	COMP.W	D3,#F1	JUMP,NE LOOP$	LOAD.W	D0,D6	CALL	DBRINV		; teint le rectangle slectionn	CLR.W	D0	LOAD.W	D1,#NBRX*NBRY	CALL	DBRDESCOLS	; dessine toutes les couleurs	CALL	DBRUSECOLS	; marque les utilises	CALL	DBPALSAV	; buffer <-- image cran	LOAD.W	D0,D6	CALL	DBRINV		; allume le rectangle slectionn	LOAD.W	D0,#NBRX*NBRY	; D0 <-- toutes les couleurs modifies	JUMP	LOOP$SAUVE$:	CALL	DBRPFAN		; met  jour les fanions	CALL	COLSAUVE	; sauve les couleurs ...	PUSH.W	D7	LOAD.L	A2,#R16"TDBOX_COL	LOAD.W	D7,#DB_RSK	PAGE_	DBOX		; refait les soft-keys	POP.W	D7	JUMP,NE BIP$	JUMP	LOOP$USE$:	CALL	DBRPFAN		; met  jour les fanions	LOAD.L	A4,(A5)+OPTAB	; A4 <-- ^table des couleurs	LOAD.W	(A4)+OTACSEL,D6	; mj. la couleur slectionne	LOAD.W	D3,#F1END$:	LOAD.W	D4,D0		; D4 <-- nb de couleurs modifies	JUMP',EQ NOREG$	INC.L	(A5)+OREGEN	; change le numro de rgnrationNOREG$:	LOAD.W	D7,#DB_CLOSE	PAGE_	DBOX		; ferme la DBOXEXIT$:	POPM.L	D0..D2,D5,D6,A0..A5	TEST.W	D7		; retour EQ/NE	RETTDBOX_COL:	.W	10$-TDBOX_COL	.W	20$-TDBOX_COL	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Choix de la couleur :"	.B	ODBTABX,60-11	.B	ODBSQUARE,BCOLPAN	.ASCIZ	" PANTONE"	.B	ODBCR,ODBCR2	.B	ODBLABEL,100	.B	ODBTEXT,0	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBTABX,60	.B	ODBLABEL,101	.B	ODBTEXT,0	.B	ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" UTILISE "	.B	ODBBOX,0,F4,TDBMEV	.ASCIZ	" MODIFIE "	.B	ODBTEXT	.ASCIZ	"  "	.B	ODBBOX,0,F7,TDBNORM	.ASCIZ	" PREND "	.B	ODBBOX,0,F9,TDBNORM	.ASCIZ	" SAUVE "	.B	ODBTABX,60-10	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Utilise"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Modifie"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Prend       Sauve"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_COL:	.W	F1,F2,F3,0		DOKF1-TKEY_COL	.W	F4,F5,F6,0		DOKF4-TKEY_COL	.W	F7,0			DOKF7-TKEY_COL	.W	F9,0			DOKF9-TKEY_COL	.W	F0,F13,F14,F15,0	DOKF0-TKEY_COL	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_COL	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_COL	.W	0;-------------\\; DBOXMODCOLOR >;=============/; Modifie une couleur.; in	D6.W	couleur  modifier; out	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXMODCOLOR:	PUSHM.L	D4,D6,A3,A4	MUL.WU	D6,#LDCOL	LOAD.L	A3,(A5)+OPTAB	; A3 <-- ^table des couleurs	ADD.L	A3,D6		; A3 <-- ^nom	LOAD.W	D4,(A3)+OCOLFA	TEST.L	D4:#BCOLPAN	; couleur PANTONE ?	JUMP',BS PAN$ICOL$:	LOAD.L	A4,#(A3)+OCOLR	; A4 <-- ^RGB	LOAD.L	D4,(A5)+OFAN	TSET.L	D4:#BICMEDIT	ICOL_	MODRGB		; modifie la couleur ...	JUMP',NE EXIT$	COMP.W	D3,#F1	JUMP',NE EXIT$	LOAD.L	(A5)+OFAN,D4	JUMP'	EXIT$PAN$:	CALL	DBOXMODPANTONE	; modifie la couleur ...EXIT$:	POPM.L	D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBPALSAV >;---------/; Sauve l'image cran de la palette.; in	-; out	D7.W	erreur; mod	D7.WDBPALSAV:	PUSHM.L	D1..D6,A3,A4	TEST.B	(A0)+ODFCMD	; cran couleur ?	JUMP,NE OK$		; oui => OK	TEST.L	(A5)+ODBRPB	JUMP',NE BUFOK$	LOAD.W	D4,(A5)+ODBRLX	MUL.WU	D4,#NBRX	INC.W	D4	LOAD.W	(A5)+ODBRPD+2,D4	LOAD.W	D4,(A5)+ODBRLY	MUL.WU	D4,#NBRY	INC.W	D4	LOAD.W	(A5)+ODBRPD+0,D4	LOAD.W	D4,(A5)+ODBRPD+2	ADD.W	D4,#16-1	SR.W	D4,#4	SL.W	D4,#1	MUL.WU	D4,(A5)+ODBRPD+0	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour image cran	JUMP',NE EXIT$	LOAD.L	(A5)+ODBRPB,A4BUFOK$:	LOAD.W	D7,#MI_CCMO	PAGE_	MISC		; enlve la souris	LOAD.L	D3,(A5)+ODBRPY	LOAD.L	A3,#0	CLR.L	D4	LOAD.L	A4,(A5)+ODBRPB	LOAD.W	D6,(A5)+ODBRPD+2	ADD.W	D6,#16-1	SR.W	D6,#4	SL.W	D6,#1	LOAD.L	D2,(A5)+ODBRPD	LOAD.W	D1,#LOADDOT	LOAD.L	A2,A0	GRA_	RASTER		; buffer <-- image cranOK$:	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;---------\\; DBPALGET >;---------/; Restitue l'image cran de la palette.; in	-; out	D7.W	erreur; mod	D7.WDBPALGET:	PUSHM.L	D1..D6,A3,A4	LOAD.W	D7,#1	TEST.L	(A5)+ODBRPB	JUMP',EQ EXIT$	LOAD.W	D7,#MI_CCMO	PAGE_	MISC		; enlve la souris	CLR.L	D3	LOAD.L	A3,(A5)+ODBRPB	LOAD.W	D5,(A5)+ODBRPD+2	ADD.W	D5,#16-1	SR.W	D5,#4	SL.W	D5,#1	LOAD.L	D4,(A5)+ODBRPY	LOAD.L	A4,#0	LOAD.L	D2,(A5)+ODBRPD+0	LOAD.W	D1,#LOADDOT	LOAD.L	A2,A0	GRA_	RASTER		; cran <-- image mmorise	CLR.W	D7		; D7 <-- okEXIT$:	POPM.L	D1..D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DBRGFAN >;--------/; Cherche les fanions.; in	D6.W	rectangle slectionn (0..n); out	D4.L	fanions; mod	D4.L, D7.WDBRGFAN:	PUSHM.L	D1,A1	LOAD.W	D1,D6	MUL.WU	D1,#LDCOL	LOAD.L	A1,(A5)+OPTAB	; A1 <-- ^table des couleurs	ADD.L	A1,D1		; A1 <-- ^couleur choisie	CLR.L	D4	LOAD.W	D4,(A1)+OCOLFA	; D4 <-- fanions	POPM.L	D1,A1	RET;--------\\; DBRPFAN >;--------/; Met  jour les fanions.; in	D6.W	rectangle slectionn (0..n);	D4.L	fanions; out	-; mod	D7.WDBRPFAN:	PUSHM.L	D1,A1	LOAD.W	D1,D6	MUL.WU	D1,#LDCOL	LOAD.L	A1,(A5)+OPTAB	; A1 <-- ^table des couleurs	ADD.L	A1,D1		; A1 <-- ^couleur choisie	LOAD.W	(A1)+OCOLFA,D4	POPM.L	D1,A1	RET;-------\\; DBRSEL >;-------/; Slectionne un nouveau rectangle.; in	D6.W	rectangle slectionn (0..n); out	D6.W	nouveau rectangle (0..n);	D7.W	erreur; mod	D6.L, D7.WDBRSEL:	PUSHM.L	D0,D3,D4	CALL	DBRDET		; est-on dans un rectangle ?	JUMP',NE 90$		; non => 90$	EX.L	D0,D6	CALL	DBRINV		; efface l'ancien	LOAD.W	D0,D6	CALL	DBRINV		; allume le nouveau20$:	LIB	?GETKEY		; attend souris ...	COMP.W	D3,#KEYMPO	; souris bouge ?	JUMP',NE 80$		; non => 80$	CALL	DBRDET		; D0 <-- rectangle o est la souris	JUMP,NE 20$	COMP.W	D0,D6		; toujours dans le mme ?	JUMP,EQ 20$		; oui => 20$				; non =>	EX.L	D0,D6	CALL	DBRINV		; efface l'ancien	LOAD.W	D0,D6	CALL	DBRINV		; allume le nouveau	JUMP	20$80$:	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,D3,D4	TEST.W	D7		; retour EQ/NE	RET;-------\\; DBRDET >;-------/; Dtecte dans quel rectangle est la souris.; in	-; out	D0.W	rectangle (0..n);	D7.W	erreur; mod	D0.L, D7.WDBRDET:	PUSHM.L	D1..D4	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP',NE 90$	LOAD.W	D7,#ERDIOUT	; D7 <-- hors de la matrice	SUB.W	D4,(A0)+ODFFX	; D4 <-- pos relative dans swdo	JUMP',LO 90$	SUB.W	D4,(A5)+ODBRPX	; D4 <-- pos relative dans rectangle	JUMP',LO 90$	CLR.L	D0	LOAD.W	D0,D4	DIV.WU	D0,(A5)+ODBRLX	; D0 <-- coordonne X	COMP.W	D0,#NBRX	JUMP',HS 90$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	; D4 <-- pos relative dans swdo	JUMP',LO 90$	SUB.W	D4,(A5)+ODBRPY	; D4 <-- pos relative dans rectangle	JUMP',LO 90$	CLR.L	D1	LOAD.W	D1,D4	DIV.WU	D1,(A5)+ODBRLY	; D1 <-- coordonne Y	COMP.W	D1,#NBRY	JUMP',HS 90$	MUL.WU	D1,#NBRX	ADD.W	D0,D1		; D0 <-- no du rectangle	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D1..D4	TEST.W	D7		; retour EQ/NE	RET;-------\\; DBRINV >;-------/; Inverse un rectangle.; in	D0.W	no du rectangle (0..n); out	-; mod	D7.WDBRINV:	PUSHM.L	D2..D4	LOAD.L	D4,#-1	CALL	DRMDEF	LOAD.W	D2,#INVDOT	CALL	DBRPOS	JUMP',NE 90$	PUSHM.L	D3,D4	ADD.W	D3,#2	SWAP.W	D3	ADD.W	D3,#2	SWAP.W	D3	SUB.W	D4,#3	SWAP.W	D4	SUB.W	D4,#3	SWAP.W	D4	LIB	?DRTRAME	; inverse un rectangle	POPM.L	D3,D4	ADD.W	D3,#6	SWAP.W	D3	ADD.W	D3,#6	SWAP.W	D3	SUB.W	D4,#(6*2)-1	SWAP.W	D4	SUB.W	D4,#(6*2)-1	SWAP.W	D4	LIB	?DRTRAME	; inverse l'emplacement90$:	POPM.L	D2..D4	RET;-----------\\; DBRUSECOLS >;-----------/; Dessine une ou plusieurs utilisations.; in	D0.W	premire couleur;	D1.W	nombre de couleurs; out	-; mod	D7.WDBRUSECOLS:	PUSHM.L	D0..D4,A3,A4	LOAD.L	A3,#(A5)+OBUDIS+1	LOAD.B	(A3)+0,#DRAWMATRIXLOOP$:	CALL	DBRPOS		; D3/D4 <-- pos/dim	JUMP',NE EXIT$	INC.W	D3	SWAP.W	D3	INC.W	D3	LOAD.L	(A3)+1,D3	LOAD.L	A4,#R16"MACLR$	LOAD.L	(A3)+5,A4	LOAD.B	(A3)+9,#CLRDOT!PENDOT	LOAD.W	D3,#10	LIB	?STRING	LOAD.L	A4,#(A5)+OUSBUF	TEST.B	(A4)+(D0.W)	; couleur utilise ?	JUMP',EQ NEXT$		; non => NEXT$	LOAD.L	A4,#R16"MASET$	LOAD.L	(A3)+5,A4	LOAD.B	(A3)+9,#SETDOT!PENDOT	LOAD.W	D3,#10	LIB	?STRINGNEXT$:	INC.W	D0	DEC.W	D1	JUMP,NE LOOP$EXIT$:	POPM.L	D0..D4,A3,A4	RETMACLR$:	.B	8,8	.B	B'11111111	.B	B'11111111	.B	B'11111110	.B	B'11111100	.B	B'11111000	.B	B'11110000	.B	B'11100000	.B	B'11000000MASET$:	.B	8,8	.B	B'00000000	.B	B'01111110	.B	B'01111100	.B	B'01111000	.B	B'01110000	.B	B'01100000	.B	B'01000000	.B	B'00000000	.EVEN;-----------\\; DBRDESCOLS >;-----------/; Dessine une ou plusieurs couleurs.; in	D0.W	premire couleur;	D1.W	nombre de couleurs; out	-; mod	D7.WDBRDESCOLS:	PUSHM.L	D0,D120$:	CALL	DBRDESCOL	; dessine une couleur	INC.W	D0	DEC.W	D1	JUMP,NE 20$	POPM.L	D0,D1	RET;----------\\; DBRDESCOL >;----------/; Dessine une couleur dans un rectangle.; in	D0.W	numro du rectangle; out	-; mod	D7.WDBRDESCOL:	PUSHM.L	D2..D4,A4	CALL	DBRPOS	JUMP,NE EXIT$	ADD.W	D3,#6	SWAP.W	D3	ADD.W	D3,#6	SWAP.W	D3	SUB.W	D4,#(6*2)-1	SWAP.W	D4	SUB.W	D4,#(6*2)-1	SWAP.W	D4	LIB	?AFTIM	.B	COLOROP,COLOROPPUSH,0	.EVEN	PUSHM.L	D3,A0	LOAD.W	D3,D0		; D3 <-- numro de la couleur	LOAD.W	D2,#SETDOT	; D2 <-- mode de dessin	LOAD.L	A4,(A5)+OPTAB	; A4 <-- ^table des couleurs	LOAD.L	A0,A5		; A0 <-- canal	CALL	XopDUSE		; utilise la bonne couleur	POPM.L	D3,A0	JUMP',NE CDNE$	PUSH.L	D4	LOAD.L	D4,#-1	CALL	DRMDEF		; dfini une trame pleine	POP.L	D4	LOAD.W	D2,#LOADDOT	; D2 <-- mode	LIB	?DRTRAME	; dessine la couleur	JUMP'	END$CDNE$:	PUSH.L	D4	CLR.L	D4	CALL	DRMDEF		; dfini une trame vide	POP.L	D4	LOAD.W	D2,#LOADDOT	; D2 <-- mode	LIB	?DRTRAME	; efface la couleur prcdente	LOAD.W	D2,#SETDOT	CALL	DESCROIX	; dessine une croixEND$:	LIB	?AFTIM	.B	COLOROP,COLOROPPOP,0	.EVENEXIT$:	POPM.L	D2..D4,A4	RET;-------\\; DBRPOS >;-------/; Donne la position et les dimensions d'un rectangle.; in	D0.W	no du rectangle (0..n); out	D3.L	coin sup/gauche (y;x);	D4.L	dimensions (dy;dx);	D7.W	erreur; mod	D3.L, D4.L, D7.WDBRPOS:	PUSHM.L	D0,D1	LOAD.W	D7,#1		; D7 <-- erreur	COMP.W	D0,#NBRX*NBRY	JUMP',HS 90$	AND.L	D0,#H'FFFF	DIV.WU	D0,#NBRX	LOAD.W	D1,D0		; D1 <-- Y	SWAP.W	D0		; D0 <-- X	MUL.WU	D1,(A5)+ODBRLY	ADD.W	D1,(A5)+ODBRPY	MUL.WU	D0,(A5)+ODBRLX	ADD.W	D0,(A5)+ODBRPX	LOAD.W	D3,D1	SWAP.W	D3	LOAD.W	D3,D0	LOAD.L	D4,(A5)+ODBRLY	; D4 <-- dimensions	CLR.W	D7		; D7 <-- ok90$:	POPM.L	D0,D1	TEST.W	D7		; retour EQ/NE	RET;------------\\; DBRDESCADRE >;------------/; Dessine les rectangles pour entourer la palette; de couleurs.; in	-; out	-; mod	D7.WDBRDESCADRE:	PUSHM.L	D0..D4	LOAD.W	D2,#2^BDBGCLABEL!100	DBOX_	GETCO	SWAP.W	D3	SUB.W	D3,#16	SWAP.W	D3	LOAD.L	(A5)+ODBRPY,D3	LOAD.W	D2,#2^BDBGCLABEL!101	DBOX_	GETCO	CLR.L	D4	LOAD.W	D4,D3	SUB.W	D4,(A5)+ODBRPX	DIV.WU	D4,#NBRX	LOAD.W	(A5)+ODBRLX,D4	MUL.WU	D4,#NBRX	SUB.W	D4,(A0)+ODFFDX	NEG.W	D4	SR.W	D4,#1	LOAD.W	(A5)+ODBRPX,D4	CLR.W	D3	SWAP.W	D3	SUB.W	D3,(A5)+ODBRPY	DIV.WU	D3,#NBRY	LOAD.W	(A5)+ODBRLY,D3	LOAD.L	D3,(A5)+ODBRPY	LOAD.L	D4,(A5)+ODBRLY	LOAD.W	D2,#SETDOT	; D2 <-- mode de dessin	LOAD.W	D1,#NBRY-1	; D1 <-- compteur vertical30$:	PUSHM.L	D3,D4	LOAD.W	D0,#NBRX-1	; D0 <-- compteur horizontal40$:	LIB	?DRRECT		; dessine rectangle	ADD.W	D3,D4		; D3 <-- X suivant	DECJ.W,NMO D0,40$	POPM.L	D3,D4	SWAP.W	D3	SWAP.W	D4	ADD.W	D3,D4		; D3 <-- Y suivant	SWAP.W	D4	SWAP.W	D3	DECJ.W,NMO D1,30$	POPM.L	D0..D4	RET;---------\\; DESCROIX >;=========/; Dessine une croix.; in	D3.L	position (y;x);	D4.L	dimensions (dy;dx);	D2.W	mode de dessin;	A0.L	^descripteur; out	-; mod	D7.WDESCROIX:	PUSHM.L	D1..D4,A2	LOAD.W	D1,D2		; D1 <-- mode	LOAD.L	A2,A0		; A2 <-- ^descripteur	EX.L	D3,D4	GRA_	LINE	ADD.W	D4,D3	DEC.W	D4	NEG.W	D3	GRA_	LINE	POPM.L	D1..D4,A2	RET;---------------\\; DBOXMODPANTONE >;===============/; Modifie une couleur PANTONE.; in	A3.L	^couleur; out	D3.L	dernire touche (F1/F0);	D7.W	erreur; mod	D3.L, D7.WDBOXMODPANTONE:	PUSHM.L	D0..D2,D4,D5,A1..A4	LOAD.L	A2,#R16"TDBOX_PAN	LOAD.W	D2,#2^BDBSAV	; D2 <-- mode	CLR.L	D4		; D4 <-- fanions	LOAD.W	D7,#DB_OPEN	PAGE_	DBOX		; ouvre la DBOX	JUMP,NE EXIT$	LOAD.L	A2,A3		; A2 <-- ^couleur	LOAD.L	A3,#(A2)+OCOLNM	; A3 <-- ^dbut du nom	LOAD.L	A4,A3EOL$:	TEST.B	(A4+)	JUMP,NE EOL$	DEC.L	A4		; A4 <-- ^fin du nom	CALL	DBPANSLDRAW	; dessine la scroll-listeLOOP$:	DBOX_	EDIT		; attend une action ...	LOAD.W	D7,#DB_ZEROCR	PAGE_	DBOX	LOAD.L	A1,#R16"TKEY_PAN	LOAD.W	D1,#2^BDBCCMM!2^BDBCCFF	DBOX_	CALLC	COMP.W	D3,#KEYMGR	; bouton souris relach ?	JUMP,EQ	LOOP$		; oui => LOOP$	COMP.W	D3,#KEYMGP	JUMP',EQ CLIC$	COMP.W	D3,#UNDO	JUMP',EQ UNDO$	COMP.W	D3,#F1	JUMP,EQ USE$	COMP.W	D3,#F0	JUMP,EQ END$BIP$:	LOAD.B	D3,#BIPLIT	LIB	?BEEP		; p'tit bruit	JUMP	LOOP$UNDO$:	LOAD.L	A4,A3	CLR.B	(A3)	JUMP	LOOP$CLIC$:	CALL	DBPANSLMOVE	; dplace la scroll-liste ...	JUMP,NE BIP$	JUMP	LOOP$USE$:	LOAD.W	D3,(A5)+OSLVAR+OSLCYS	CALL	PANSEARCH	; A3 <-- ^ligne	LOAD.L	A4,#(A2)+OCOLR	CALL	PANRGBK		; OCOLR,G,B,K <-- couleur choisie	LOAD.W	D3,#F1END$:	LOAD.W	D7,#DB_CLOSE	PAGE_	DBOX		; ferme la DBOXEXIT$:	POPM.L	D0..D2,D4,D5,A1..A4	TEST.W	D7		; retour EQ/NE	RETTDBOX_PAN:	.W	10$-TDBOX_PAN	.W	20$-TDBOX_PAN	.W	0,010$:	.B	ODBTEXT	.ASCIZ	"Choix d'une couleur"	.B	ODBTABX,24	.B	ODBLABEL,100	.B	ODBTEXT,0	.B	ODBCR	.B	ODBTEXT	.ASCIZ	"normalise"	.B	ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBTEXT	.ASCIZ	"Nom de la couleur :"	.B	ODBCR,ODBCR	.B	ODBCLINE,15+2	.B	ODBCR,ODBCR,ODBCR,ODBCR,ODBCR	.B	ODBCR,ODBCR,ODBCR	.B	ODBBOX,0,F1,TDBMEV	.ASCIZ	" CHOISIT "	.B	ODBBOX,0,F0,TDBNORM	.ASCIZ	" ANNULE "	.B	ODBTABX,24+32	.B	ODBLABEL,101	.B	ODBTEXT,0	.B	ODBTABX,24+32+2	.B	020$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Choisit"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENTKEY_PAN:	.W	F1,F2,F3,0		DOKF1-TKEY_PAN	.W	F0,F13,F14,F15,0	DOKF0-TKEY_PAN	.W	KEYMGP,KEYMMP,KEYMDP,0	DOKMGP-TKEY_PAN	.W	KEYMGR,KEYMMR,KEYMDR,0	DOKMGR-TKEY_PAN	.W	0;------------\\; DBPANSLDRAW >;------------/; Dessine la scroll-liste.; in	A2.L	^couleur; out	-; mod	D7.WDBPANSLDRAW:	PUSHM.L	D2..D4,A4..A6	CALL	PANINIT	LOAD.W	(A5)+OSLVAR+OSLCYS,D3	LOAD.L	A6,A5		; A6 <-- ^variables globales	LOAD.L	A5,#(A6)+OSLVAR	; A5 <-- ^variables scroll-liste	LOAD.W	D2,#2^BDBGCLABEL!101	DBOX_	GETCO	PUSH.L	D3	LOAD.W	D2,#2^BDBGCLABEL!100	DBOX_	GETCO	POP.L	D4	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	SUB.W	D3,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC1Y	ADD.W	D4,(A0)+ODFC2Y	SUB.W	D4,D3	SWAP.W	D3	SWAP.W	D4	LOAD.L	(A5)+OSLPOS,D3	LOAD.L	(A5)+OSLDIM,D4	SET.B	(A5)+OSLASV+OSCPAGE	SCROLL_	LDRAW		; dessine la scroll-liste vide	LOAD.W	(A5)+OSLCYN,(A6)+ONIND	LOAD.L	A4,#R16"DBPANSLCASE	LOAD.L	(A5)+OSLADL,A4	SCROLL_	LUPDATE		; dessine le contenu de la scroll-liste	POPM.L	D2..D4,A4..A6	RET;------------\\; DBPANSLCASE >;------------/; Affiche le contenu d'une case.; in	A6.L	^variables globales;	D3.W	rang de la case (0..n); out	A3.L	^contenu;	D3.W	zro/un; mod	D3.L, D7.W, A3.LDBPANSLCASE:	PUSHM.L	A2,A4,A5	LOAD.L	A5,A6		; A5 <-- ^variables globales	CALL	PANSEARCH	; A3 <-- ^ligne	JUMP,NE EXIT$	LOAD.L	A4,#(A5)+OBUDIS	; A4 <-- ^buffer	LOAD.L	A2,(A5)+OPPAN	; A2 <-- ^fichier PANTONEHLOOP$:	LOAD.B	D3,(A2+)	COMP.B	D3,#CR	JUMP',EQ HEND$	LOAD.B	(A4+),D3	; OBUDIS <-- prfixe	JUMP	HLOOP$HEND$:	LOAD.B	(A4+),#SPACE	LOAD.W	D3,#4-1TBEGIN$:	COMP.B	(A3+),#SPACE	JUMP,NE TBEGIN$	DECJ.W,NMO D3,TBEGIN$TLOOP$:	LOAD.B	D3,(A3+)	COMP.B	D3,#CR	JUMP',EQ TEND$	LOAD.B	(A4+),D3	; OBUDIS <-- texte	JUMP	TLOOP$TEND$:	LOAD.B	(A4+),#SPACEELOOP$:	LOAD.B	D3,(A2+)	COMP.B	D3,#CR	JUMP',EQ EEND$	LOAD.B	(A4+),D3	; OBUDIS <-- postfixe	JUMP	ELOOP$EEND$:	CLR.B	(A4)		; OBUDIS <-- terminateur	CLR.W	D3		; D3 <-- zro (pas de trait)	COMP.B	(A3),#CR	; ligne vide juste aprs ?	JUMP',NE OK$		; non => OK$	INC.W	D3		; D3 <-- un (traitille en dessous)OK$:	LOAD.L	A3,#(A5)+OBUDIS	; A3 <-- ^contenuEXIT$:	POPM.L	A2,A4,A5	CLR.W	D7		; retour EQ	RET;------------\\; DBPANSLMOVE >;------------/; Dplace la scroll-liste.; in	-; out	D7.W	erreur; mod	D7.WDBPANSLMOVE:	PUSHM.L	D3,D4,A5,A6	LIB	?IFMOUSE	; D4 <-- position de la souris	JUMP',NE EXIT$	SUB.W	D4,(A0)+ODFFX	JUMP',LO EXIT$	SWAP.W	D4	SUB.W	D4,(A0)+ODFFY	JUMP',LO EXIT$	SWAP.W	D4	LOAD.L	A6,A5		; A6 <-- ^variables globales	LOAD.L	A5,#(A6)+OSLVAR	; A5 <-- ^variables scroll-liste	SCROLL_	LMOVE		; dplace la scroll-liste ...EXIT$:	POPM.L	D3,D4,A5,A6	TEST.W	D7		; retour EQ/NE	RET;--------\\; PANLOAD >;========/; Charge le fichier des couleurs PANTONE.; in	-; out	D7.W	erreur; mod	D7.WPANLOAD:	PUSHM.L	D1,D3,D4,D6,A3,A4	CLR.W	D7		; D7 <-- ok	TEST.L	(A5)+OPPAN	; fichier dj charg ?	JUMP,NE EXIT$		; oui => EXIT$	LOAD.L	A3,#R16"NMPAN	LOAD.W	D3,#2^BOPRD	FOS	?OPEN	JUMP',NE EXIT$	LOAD.L	D4,#-1	LOAD.L	D3,D4	FOS	?SPOS		; va  la fin	PUSH.L	D4	CLR.L	D4	CLR.L	D3	FOS	?SPOS	POP.L	D4	INC.L	D4		; D4 <-- place pour <0>	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM	JUMP',NE CLOSE$	LOAD.L	(A5)+OPPAN,A4	DEC.L	D4	FOS	?RDBYTE		; lit tout le fichier	JUMP',NE CLOSE$	CLR.B	(A4)+(D4.L)	; met le terminateur <0>	CALL	PANINDEX	; construit l'index ...CLOSE$:	PUSH.W	D7	FOS	?CLOSE	POP.W	D7EXIT$:	POPM.L	D1,D3,D4,D6,A3,A4	TEST.W	D7		; retour EQ/NE	RET;----------\\; PANUNLOAD >;==========/; Dcharge le fichier des couleurs PANTONE.; in	-; out	-; mod	D7.WPANUNLOAD:	PUSHM.L	D1,A4	TEST.L	(A5)+OPIND	; index existe ?	JUMP',EQ IND$		; non => IND$	LOAD.L	A4,(A5)+OPIND	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	CLR.L	(A5)+OPINDIND$:	TEST.L	(A5)+OPPAN	; fichier dj charg ?	JUMP',EQ EXIT$		; non => EXIT$	LOAD.L	A4,(A5)+OPPAN	LOAD.W	D1,#MTYPCP	GESMEM	?GIVMEM		; libre la mmoire	CLR.L	(A5)+OPPANEXIT$:	POPM.L	D1,A4	RET;--------\\; PANINIT >;========/; Cherche la couleur PANTONE la plus proche.; in	A2.L	^couleur; out	D3.W	rang de la couleur PANTONE la plus proche; mod	D3.L, D7.WPANINIT:	PUSHM.L	D0..D2,D4,D5,A3,A4	CLR.W	D3	LOAD.L	D4,#-1		; D4 <-- cart maximal	CLR.W	D5LOOP$:	CALL	PANSEARCH	; A3 <-- ^ligne	JUMP,NE NEXT$	LOAD.L	A4,#(A5)+OBUDIS	CALL	PANRGBK		; OBUDIS <-- couleur RGBK de la ligne	CLR.L	D1	LOAD.W	D1,(A4)+0	; D1 <-- rouge	CLR.L	D0	LOAD.W	D0,(A2)+OCOLR	SUB.L	D1,D0	JUMP',NC AR$	NEG.L	D1		; D1 <-- |R-R'|AR$:	LOAD.L	D2,D1	CLR.L	D1	LOAD.W	D1,(A4)+2	; D1 <-- vert;	CLR.L	D0	LOAD.W	D0,(A2)+OCOLG	SUB.L	D1,D0	JUMP',NC AG$	NEG.L	D1		; D1 <-- |G-G'|AG$:	ADD.L	D2,D1	CLR.L	D1	LOAD.W	D1,(A4)+4	; D1 <-- bleu;	CLR.L	D0	LOAD.W	D0,(A2)+OCOLB	SUB.L	D1,D0	JUMP',NC AB$	NEG.L	D1		; D1 <-- |B-B'|AB$:	ADD.L	D2,D1	CLR.L	D1	LOAD.W	D1,(A4)+6	; D1 <-- noir;	CLR.L	D0	LOAD.W	D0,(A2)+OCOLK	SUB.L	D1,D0	JUMP',NC AK$	NEG.L	D1		; D1 <-- |K-K'|AK$:	ADD.L	D2,D1	COMP.L	D4,D2		; cart plus petit que le prcdent ?	JUMP',LS NEXT$		; non => NEXT$	LOAD.L	D4,D2		; D4 <-- cart minimal	LOAD.W	D5,D3		; D5 <-- meilleur choixNEXT$:	INC.W	D3	COMP.W	D3,(A5)+ONIND	JUMP,LO LOOP$	LOAD.W	D3,D5	POPM.L	D0..D2,D4,D5,A3,A4	RET;--------\\; PANRGBK >;========/; Cherche et converti une couleur PANTONE en RGBK.; in	A3.L	^ligne;	A4.L	^buffer pour RGBK; out	(A4)++	RGBK; mod	D7.WPANRGBK:	PUSHM.L	D4,A4	CALL	PANGETFRAC	; D4 <-- cyan	NOT.W	D4	LOAD.W	(A4+),D4	CALL	PANGETFRAC	; D4 <-- magenta	NOT.W	D4	LOAD.W	(A4+),D4	CALL	PANGETFRAC	; D4 <-- jaune	NOT.W	D4	LOAD.W	(A4+),D4	CALL	PANGETFRAC	; D4 <-- noir	LOAD.W	(A4+),D4	POPM.L	D4,A4	RET;-----------\\; PANGETFRAC >;-----------/; Cherche un nombre dcimal.; in	A3.L	^nombre; out	A3.L	^plus loin;	D4.W	nombre (0..H'FFFF); mod	D4.L, D7.W, A3.LPANGETFRAC:	PUSHM.L	D2,D3	CLR.W	D4	LOAD.W	D2,#10000LOOP$:	CLR.W	D3	LOAD.B	D3,(A3+)	COMP.B	D3,#'.	JUMP',EQ POINT$	SUB.B	D3,#'0	JUMP',LO END$	COMP.B	D3,#9	JUMP',HI END$	MUL.WU	D3,D2	ADD.W	D4,D3	AND.L	D2,#H'FFFF	DIV.WU	D2,#10	JUMP	LOOP$POINT$:	LOAD.W	D2,#1000	JUMP	LOOP$END$:	MUL.WU	D4,#(2^16)-1	DIV.WU	D4,#10000	POPM.L	D2,D3	RET;----------\\; PANSEARCH >;==========/; Cherche une ligne dans le fichier PANTONE.; in	D3.W	rang (0..n); out	A3.L	^ligne;	D7.W	erreur; mod	D7.W, A3.LPANSEARCH:	PUSH.L	D3	LOAD.W	D7,#1	COMP.W	D3,(A5)+ONIND	JUMP',HS EXIT$	TEST.L	(A5)+OPPAN	JUMP',EQ EXIT$	TEST.L	(A5)+OPIND	JUMP',EQ EXIT$	LOAD.L	A3,(A5)+OPIND	SL.W	D3,#1	LOAD.W	D3,(A3)+(D3.W)	; D3 <-- offset ligne	LOAD.L	A3,(A5)+OPPAN	ADD.W	A3,D3		; A3 <-- ^ligne	CLR.W	D7EXIT$:	POP.L	D3	TEST.W	D7		; retour EQ/NE	RET;---------\\; PANINDEX >;=========/; Construit l'index du fichier PANTONE.; in	-; out	D7.W	erreur; mod	D7.WPANINDEX:	PUSHM.L	D1..D4,A3,A4	LOAD.B	D2,#CR	LOAD.L	A4,(A5)+OPPAN	LOAD.W	D4,#5-1HLOOP$:	COMP.B	D2,(A4+)	; saute l'en-tte	JUMP,NE HLOOP$	DECJ.W,NMO D4,HLOOP$	LOAD.L	A3,A4	CLR.L	D4LLOOP$:	LOAD.B	D3,(A4+)	JUMP',EQ LEND$	COMP.B	D3,D2	JUMP,NE LLOOP$	INC.W	D4	COMP.B	D2,(A4)	JUMP,NE LLOOP$	INC.L	A4	JUMP	LLOOP$LEND$:	LOAD.W	(A5)+ONIND,D4	LOAD.W	D3,D4	SL.L	D4,#1	LOAD.W	D1,#MTYPCP	GESMEM	?GETMEM		; demande mmoire pour index	JUMP',NE EXIT$	LOAD.L	(A5)+OPIND,A4ILOOP$:	LOAD.L	D4,A3	SUB.L	D4,(A5)+OPPAN	LOAD.W	(A4+),D4	; index <-- offset ligneILINE$:	COMP.B	D2,(A3+)	JUMP,NE ILINE$	COMP.B	D2,(A3)	JUMP',NE INEXT$	INC.L	A3INEXT$:	DEC.W	D3	JUMP,NE ILOOP$EXIT$:	POPM.L	D1..D4,A3,A4	TEST.W	D7		; retour EQ/NE	RET;--------\\; DRMDEF  >;========/; Dfini la demi-trame super-rapidement.; in	D4.L	demi-trame; out	-; mod	D7.WDRMDEF:	LOAD.L (A0)+ODFTRA+0,D4	LOAD.L (A0)+ODFTRA+4,D4	CLR.L	(A0)+ODFTPM	; annule XTRAME	RET;--------\\; DOK...  >;========/DOKMGP:	LOAD.W	D3,#KEYMGP	RETDOKMGR:	LOAD.W	D3,#KEYMGR	RETDOKF0:	LOAD.W	D3,#F0	RETDOKF1:	LOAD.W	D3,#F1	RETDOKF2:	LOAD.W	D3,#F2	RETDOKF3:	LOAD.W	D3,#F3	RETDOKF4:	LOAD.W	D3,#F4	RETDOKF5:	LOAD.W	D3,#F5	RETDOKF6:	LOAD.W	D3,#F6	RETDOKF7:	LOAD.W	D3,#F7	RETDOKF8:	LOAD.W	D3,#F8	RETDOKF9:	LOAD.W	D3,#F9	RETDOKF10:	LOAD.W	D3,#F10	RETDOKF11:	LOAD.W	D3,#F11	RETDOKF12:	LOAD.W	D3,#F12	RETDOKF13:	LOAD.W	D3,#F13	RETDOKF14:	LOAD.W	D3,#F14	RETDOKF15:	LOAD.W	D3,#F15	RETNMPAN:	.ASCIZ	"#:PAGE_PT.INFO"	.EVEN	.END