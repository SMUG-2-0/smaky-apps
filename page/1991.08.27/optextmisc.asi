	.SBTTL	OPTEXTMISC.ASI;--------\\; RECTOR  >;========/; Effectue un "ou" (union) entre deux rectangles.; in	D1/D2	P1/P2 rectangle A;	D3/D4	P1/P2 rectangle B; out	D3/D4	P1/P2 rectangle A ! B; mod	D3.L, D4.LRECTOR:	COMP.W	D3,D1	JUMP',LE 20$	LOAD.W	D3,D120$:	COMP.W	D4,D2	JUMP',GE 22$	LOAD.W	D4,D222$:	SWAP.W	D1	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	COMP.W	D3,D1	JUMP',LE 40$	LOAD.W	D3,D140$:	COMP.W	D4,D2	JUMP',GE 42$	LOAD.W	D4,D242$:	SWAP.W	D1	SWAP.W	D2	SWAP.W	D3	SWAP.W	D4	RET	.END