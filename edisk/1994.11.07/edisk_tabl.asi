omp.16		#KeyMMR, d3	jump,eq		g$	comp.16		#KeyMGP, d3	jump,eq		g$	comp.16		#KeyMDP, d3	jump,eq		g$	comp.16		#KeyMMP, d3	jump,eq		g$	lib		?MinMaj	move.32		D3, {SP}+3*4			; dernire touche	lib		?AfTim	.8		NoCURS, 0	tclr.32		d3:#(bProgra+8)	set.8,bs	d6	test.32		d3:#(bKill+8)	jump,bs		kill$	test.32		d3:#(bCursor+8)	jump,bs		curs$	comp.8		#UNDO, d3	jump,ne		r8^noUNDO$	call		CompA3A2			; chane modifie?	jump,eq		delall$	clr.16		d2	ex.32		a2,a3	call		CopieA3A2	ex.32		a2,a3	jump		e$noUNDO$:	comp.8		#DEL, d3	jump,eq		del$	comp.8		#BS, d3	jump,eq		sdel$	comp.8		#16'80, d3	jump,lo		r8^ins$	test.32		d1:#31	jump,bs		r$	move.16		#16'7F, d4	comp.16		#DEFINE, d3	jump,eq		r8^ins$		sub.16		#F1, d3	jump,cs		r$	comp.16		#10'15, d3	jump,hs		r$	move.16		d3, d4ins$:	and.16		#16'7F, d4	move.8		{a1}+A16^{D4}, D4	jump,ns		r$	test.8		d6	jump,f		r8^x$	tset.32		d4:#7			; met code ngatifx$:	comp.16		D1, D2	jump,hs		e$	move.16		D2, D3	inc.16		D2pl$:	push.8		{A3}+A16^{D3}	move.8		D4, {A3}+A16^{D3}	inc.16		D3	pop.8		D4	comp.8		d1, d3	jump,lo		pl$	clr.8		{A3}+A16^{D3}	jump		e$sdel$:	comp.16		D1, D2	jump,hs		e$	inc.16		D2del$:	dec.16		D2	jump,cs		r8^m$	clr.8		{A3}+A16^{D2}	move.16		D2, D4dl$:	inc.16		D4	move.8		{A3}+A16^{D4}, D3	move.8		D3, {A3}+A16^{D4}-1	comp.16		d1, d4	jump,lo		dl$	clr.8		{A3}+A16^{D4}-1	jump		e$m$:	test.16		D2	jump,eq		r$	clr.16		D2	jump		e$curs$:	comp.8		#"D", d3	jump,eq		cd$	comp.8		#"F", d3	jump,eq		cf$	comp.8		#"S", d3	jump,eq		m$	comp.8		#"R", d3	jump,eq		m$	comp.8		#"G", d3	jump,eq		f$	comp.8		#"C", d3	jump,eq		f$	jump		r$kill$:	comp.8		#"D", d3	jump,eq		del$	comp.8		#"F", d3	jump,eq		sdel$	comp.8		#"S", d3	jump,eq		km$	comp.8		#"R", d3	jump,eq		km$	comp.8		#"G", d3	jump,eq		kf$	comp.8		#"C", d3	jump,eq		kf$	jump		r$km$:	clr.16		D3kml$:	move.8		{A3}+A16^{D2}, D4	move.8		D4, {A3}+A16^{D3}	inc.16		D2	inc.16		D3	test.8		d4	jump,ne		kml$	clr.16		D2kmlf$:	comp.16		d1, d3	jump,hs		e$	clr.8		{A3}+A16^{D3}	inc.16		D3	jump		kmlf$delall$:	clr.16		D2			; depuis le dbutkf$:	move.16		D2, D3kfl$:	clr.8		{A3}+A16^{D3}	inc.16		D3	comp.16		d1, d3	jump,lo		kfl$	jump		e$cd$:	dec.16		D2	jump,cs		r$	jump		e$cf$:	comp.16		D1, D2	jump,eq		r$	inc.16		D2	jump		e$f$:	test.8		{A3}+A16^{D2}	jump,eq		rx$	comp.16		D1, D2	jump,eq		rx$fx$:	comp.16		D1, D2	jump,eq		e$	test.8		{A3}+A16^{D2}	jump,eq		e$	inc.16		D2	jump		fx$rx$:	comp.8		#"G", d3	jump,ne		r8^r$	move.8		#"F", D3	move.32		D3, {SP}+3*4r$:	move.32		D0, D3	lib		?SetCurs	swap.32		d6	move.8		d6, d3	Lib		?AfCar	call		AffTxt	move.32		D0, D3	lib		?SetCurs	lib		?AFTIM	.8		AFDIR,AFFULL,0	.even	lib		?NoBuCar	call		CompA3A2	popm.32		D0..D6	retAffTxt:	pushm.32	A3|D3|D1	dec.16		D1l$:	move.8		{A3+}, D3	Lib		?AfCode	dj.16,nmo	d1, l$	test.32		d1:#31	jump,bc		r8^r$	move.8		{A3+}, D3		; caractre non ditable !	Lib		?AfCoder$:	popm.32		A3|D3|D1	RetCopieA3A2:	pushm.32	A3|A2|D1l$:	move.8		{A3+}, {A2+}	dec.16		d1	jump,ne		l$	popm.32		A3|A2|D1	retCompA3A2:	pushm.32	A3|A2|D1l$:	comp.8		{A3+}, {A2+}	jump,ne		r8^r$	dec.16		d1	jump,ne		l$r$:	popm.32		A3|A2|D1	ret	EditHexa:	pushm.32	D0..d3|d5|d6	lib		?AFTIM	.8		AFDIR,AFFULL,0	.even	move.8		d3, d6	lib		?GetCurs	move.32		D3, D0	move.32		D5, D2	move.32		D4, D5				; valeur initialee$:	move.32		D0, D3	lib		?SetCurs	call		AffHexNum	move.8		#LEFT, D3	lib		?AfCar	move.8		#CURS, D3	lib		?AfCar, ?Flushg$:	lib		?GetCar	comp.16		#KeyMGR, d3	jump,eq		g$	comp.16		#KeyMDR, d3	jump,eq		g$	comp.16		#KeyMMR, d3	jump,eq		g$	comp.16		#KeyMGP, d3	jump,eq		g$	comp.16		#KeyMDP, d3	jump,eq		g$	comp.16		#KeyMMP, d3	jump,eq		g$	lib		?MinMAJ	lib		?AfTim	.8		NoCURS, 0	move.32		D3, {SP}+3*4			; dernire touche	test.32		d3:#(bCursor+8)	jump,bs		r$	comp.8		#UNDO, D3	jump,ne		r8^x$	clr.32		D2	comp.32		D4, D5				; chang ?	jump,eq		eD2$				; non -> met tout  zro	move.32		D5, D2				; reprend la valeur initiale	jump		eD2$x$:	comp.8		#DEL, D3	jump,ne		r8^n$	sr.32		#4, D4	move.32		D4, D2	jump		e$n$:	sub.8		#"0", d3	jump,lo		r$	comp.8		#9, d3	jump,ls		r8^s$	sub.8		#"A"-"0"-10, d3	comp.8		#10, d3	jump,lo		r$	comp.8		#16, d3	jump,hs		r$s$:	sl.32		#4, D2	or.8		d3, D2eD2$:	move.32		D2, d4	jump		e$r$:	move.32		D0, D3	lib		?SetCurs	move.8		d6, d3	Lib		?AfCar	call		AffHexNum	lib		?AFTIM	.8		AFDIR,AFFULL,0	.even	move.32		D0, D3	lib		?SetCurs	comp.32		D4, D5				; modifi ?	popm.32		D0..d3|d5|d6	RetAffHexNum:	pushm.32	d1|d3|d4|a1	move.32		#r16^t$, a1	move.16		#8, d3	sub.16		d1, d3	sl.16		#2, d3		; *4	rl.32		d3, d4lp$:	rl.32		#4, d4	move.8		d4, d3	and.16		#16'F, d3	move.8		{a1}+A16^{d3}, d3	Lib		?Afcode	dec.16		d1	jump,ne		lp$	popm.32		d1|d3|d4|a1	rett$:	.ascii		"0123456789ABCDEF"tableKey:	.8		16'00		; 00	.8		16'01		; 01 (eot)	.8		16'02		; 02 	.8		16'03		; 03 (triangle curs)	.8		16'04		; 04 (triangle droite)	.8		16'05		; 05 (triangle gauche)	.8		16'06		; 06 (triangle bas)	.8		16'07		; 07 (carr)	.8		16'08		; 08 (flche haut)	.8		16'09		; 09 (tab)	.8		16'0A		; 0A (flche bas)	.8		16'0B		; 0B (flche gauche)	.8		16'0C		; 0C 	.8		16'0D		; 0D (cr)	.8		16'0E		; 0E 	.8		""		; 0F 	.8		""		; 10 	.8		""		; 11 	.8		""		; 12 	.8		""		; 13 	.8		""		; 14 	.8		""		; 15 	.8		""		; 16 	.8		""		; 17 	.8		""		; 18 	.8		""		; 19 	.8		""		; 1A 	.8		""		; 1B 	.8		""		; 1C 	.8		""		; 1D 	.8		""		; 1E 	.8		""		; 1F 	.8		" "		; 20  	.8		"!"		; 21 !	.8		""""		; 22 "	.8		"#"		; 23 #	.8		"$"		; 24 $	.8		"%"		; 25 %	.8		"&"		; 26 &	.8		"'"		; 27 '	.8		"("		; 28 (	.8		")"		; 29 )	.8		"*"		; 2A *	.8		"+"		; 2B +	.8		","		; 2C ,	.8		"-"		; 2D -	.8		"."		; 2E .	.8		"/"		; 2F /	.8		"0"		; 30 0	.8		"1"		; 31 1	.8		"2"		; 32 2	.8		"3"		; 33 3	.8		"4"		; 34 4	.8		"5"		; 35 5	.8		"