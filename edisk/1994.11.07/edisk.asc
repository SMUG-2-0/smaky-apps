\define g_Fond:\nef11;\define g_ev:\n(bf)09;\define g_titre:\m(f)17;\define g_it:\n(if)07;\define g_comment:\n(f)06;\define g_Lynx:\kip15;; $erh:EDISK; $---;	.TITLE		\g_titre;EDISK.ASD\g_Fond;						SOSDISK	= ?ASCOND	.IDENT		"EDISK, Daniel Roux, Franois Jaques, Denis Dumoulin."	.PROC		M68000	.REF		SMAKY	.REF		UTILE	.ref		MODULES	.ref		Mon	.LAYOUT		HEX	.REV		6,24	.CODE		500,12,2'111,250,2000,250,2000,2,"*",0,0	.HEADER		OBXpGC, .8	"*",0,0	.HEADER		OBXpDIS, .16	20,2000,300,500		; dimensions prfrentielles	.CHAP		GCHEADER\g_ev;; Dfinitions de l'entte d'un gnrateur de caractres\g_Fond;OGCNBR	=		16'00				; total number of recordsOGCFSN	=		16'02				; font set numberOGCFN	=		16'03				; font nuzmberOGCMSB	=		16'04				; matrix size in bytesOGCMHD	=		16'06				; matrix hight in dotsOGCMWB	=		16'08				; matrix width in bytesOGCPSI	=		16'09				; point sizeOGCFCA	=		16'0A				; ascii code of first characterOGCLCA	=		16'0B				; ascii code of last characterOGCLMA	=		16'0C				; left margin of matrixOGCBLI	=		16'0E				; bottom of matrix to baselineOGCMH1	=		16'10				; max hight above baselineOGCMH2	=		16'12				; max extention under baselineOGCMWI	=		16'14				; max width (for fixed spacing)OGCISP	=		16'16				; interline space in dotsOGCFLAG	=		16'18				; variable spacedOGCDAT	=		16'1A				; date in bcd ddmmyyyyOGCPWI	=		16'1E				; ^widthOGCPH1	=		16'20				; ^h1OGCPH2	=		16'22				; ^h2OGCPMX	=		16'24				; ^matrixOGCIDE	=		16'26				; text identifierOGCTXT	=		16'80				; textOGCWID	=		16'100				; width\g_ev;; Dfinitions diverses; --------------------\g_Fond;LgNameUNIT	=	40erCHKfx		= 1			; valeur de contrle BL ou BD fausseerOUTmm		= 2			; pointeur hors de la mmoire de masseerNOTvd		= 3			; donne non valable dans le BL ou BDerNOMfx		= 4			; nom de fichier incorrectTYPDATA	=		1				; bloc de dataTYPBD	=		2				; bloc de description (BD)TYPBL	=		3				; bloc de liste (BL)TYPBIN	=		4				; entte fichier binaireTYPGENC	=		5				; entte gnrateur caractres BTYPDIR=		4  TYPDIR=		2**BTYPDIR BTYPEXPL=		7  TYPEXPL=		2**BTYPEXPL			;  explorer BTYPFREE=		6  TYPFREE=		2**BTYPFREE			; BD du SYS_FREETYPBDL	=		TYPBD.or.TYPDIR			; BD pour .DIR	NbLI	=	32-3-4-1-1			; nb lignes dans la fentre !POSYBLK	=		6				; position Y pour afficher blocYY	=		16'10000XX	=		1lgMACRO		=	10'50				; nombre de touches enregistrables\g_ev;; Table de description d'un bloc; ------------------------------\g_Fond;	.LOC		0OTACOX:		.BLK.8		1			; coordonne XOTACOY:		.BLK.8		1			; coordonne YOTAPTX:		.BLK.16		1			; ^textesOTAOFF:		.BLK.8		1			; offset dans blocOTATYP:		.BLK.8		1			; type B,W,L,TOTALTX:		.BLK.8		1			; longueur texteOTADEL:		.BLK.8		1			; dlimiteurs BBEGTA	=		0				;  dbut table BENDTA	=		1				;  fin table BBEGLI	=		2				;  dbut ligne BENDLI	=		3				;  fin ligneOTATST:		.BLK.16		1			; ^routine de testLGTA:							; longueur d'un lment\g_ev;; lment de la table d'occupation; --------------------------------\g_Fond;	.LOC		0OTBBASE:	.blk.32		1			; no 1er blocOTBLONG:	.blk.8		1			; nombre de blocs conscutifsOTBTYP:		.blk.8		1			; Type de blocsOTBOFF:		.blk.32		1			; offset fichier (SPOS/Name)OTBPREV:	.blk.32		1			; no de bloc rfrenantOTBNUM:		.blk.16		1			; no d'ordre (mmo ?MMENU)lgTB:\g_ev;; entte d'un buffer de liste\g_Fond; 	.LOC		0ObufNEXT:	.blk.32		1			; chane de buffer si mmoire trs priseObufMAX:	.blk.32		1			; ^limite de cette trancheObufLG:		.blk.16		1			; nombre de segments ObufBLK:						; place pour les segments\g_ev;; liste des dossiers alphabtiquement\g_Fond;	.LOC		0OREPPREV:	.blk.32		1			; ^BD prcdentOREPNEXT:	.blk.32		1			; ^BD de ce dossierOREPNAME:	.blk.8		LGNAMEOREPFLAG:	.blk.16		1LGburep:	.CHAP		VARIABLES\g_ev;; Variables atteignables depuis {A6};=----------------------------------\g_Fond;LBUNAM	=		20LBUCRT	=		50				; longueur max. du critre de recherche pour rcup.	.LOC		0OFLAGS:		.BLK.8		1 BWIN	=		0				; winchester si set BFLO	=		1				; floppy si set BEXPLOK=		2				; on a fini le processus d'exploration des .dir BABORT	=		3 BIMP	=		4				; on impose un mode d'affichage BFREE	=		5				; SYS_FREE en ram BTEST	=		6				; test mm dj fait BMENUP	=		7				; menu principal affichOFLAG2:		.BLK.8		1 B2FRE	=		0				; recherche un bloc libre B2FOS	=		1				; input nombres FOS (rel  la partition) B2HEX	=		2				; recherche hexadcimale B2noEXPL=		3				; pas d'exploration B2RECH	=		4				; recherche possible B2PAUSE=		5				; stop explo B2FULL=		6 B2AFTOUT=		7OFLAG3:		.BLK.8		1 BRCMACRO	=	0				; macro en enregistrement BEXMACRO	=	1				; macro en excution BLPMACRO	=	2				; macro rptitive BMAJ		=	3				; mise  jour sans confirmation B3noRECUP	=	4				; rcup autoris (enter pas fait) B3USED		=	5				; SYS_FREE marqu utilis sur disque B3okRECUP	=	6 B3TEST		=	7OFLAG4:		.blk.8		1 B4RAMDYN	=	0				; $RAM dynamique sans sys_free B4noREL	=	1 B4MenuProgra	=	6 B4BDNAM	=	7OFMENU:		.blk.8		1 BMPrev		=	0				; affiche prev BMNext		=	1				; affiche next BMRew		=	2				; affiche rewind BMDeep		=	3				; affiche deep BMSPOS	 	=	4				; affiche SPOS +/-1 BMRecup	=	5				; rcup autorisNoBisection:	.blk.8		1	; set si RDBLK sans bisection (copies de disque...)BSysBad:	.blk.8	1		; set si SYS_BAD reconnu (on ne lit plus ces blocs)	.EVENMAXBAD	=	100			; nombre max de blocs foutusONOBAD:		.BLK.32		MAXBAD	; numros des blocs foutus termin par -1(.32)oPmess:		.blk.32		1pPmess:		.blk.32		1OFREE:		.BLK.32		1			; ^SYS_FREE en mmoireOFREE2:		.blk.32		1			; ^SYS_FREE en reconstructionOmaxBLK:	.blk.32		1OSTART:		.BLK.32		1			; adresse de dbut du codeOPTCOM:		.BLK.32		1			; ^ligne de commandeODIMCAR:	.BLK.32		1			; dimention y,x d'un caractreOnamUNIT:	.blk.8		LgNameUNITOposUNIT:	.blk.32		1OnoSYSFREE:	.blk.32		1			; position disque du BL de sys_freeOchFILE:	.blk.16		1			; canal FOS pour "W"OBUNAM:		.BLK.8		LBUNAM			; nom d'unit physique; bloc courantOBUBLK:		.BLK.8		LGBLK			; buffer pour un bloc de dataOBUNO:		.BLK.32		1			; no du bloc luOBUERR:		.BLK.16		1; bloc de description correspondantOBDNO:		.blk.32		1			; no du BD en mmoireOBDBLK:		.blk.8		LGBLK			; buffer pour le bloc desc. associ; bloc de liste correspondantOBLNO:		.blk.32		1OBLBLK:		.blk.8		LGBLKOBURST:		.blk.8		LGMAM3			; buffer pour ?RSTATUSOBURECH:	.BLK.32		1			; ^buffer de recherche (14/16 mem)ONBBLK:		.BLK.32		1			; nombre de blocs de oburechOBUCRT:		.BLK.8		LBUCRT			; buffer pour un critre de recherche (rcupration)ObuCRTx:	.blk.32		1			; recherche hexaOBUFI:		.BLK.8		LBUCRTOBLKFIN:	.BLK.32		1			; no du bloc qui dclenche ERMOUT ou EROUTMMOTYPBLK:	.BLK.16		1			; type d'affichageoPrvBloc:	.blk.32		1OREWIND:	.blk.32		1			; retour en arrireOrewind2:	.blk.32		1OPOSFIL:	.blk.32		1			; GPOSOOUTFIL:	.blk.16		1			; nb byte last blocOtypFIL:	.blk.8		1	.evenOCANAL:		.BLK.16		1			; numro canal FOS pour accs  mmoire masseOFNOWR:		.BLK.16		1			; ouverture unit ok ?ODEBPART:	.BLK.32		1			; no bloc dbut partition (aprs FOSBOOT)OFINPART:	.BLK.32		1			; no dernier bloc partitionOBUEXPL:	.BLK.8		lgBLK			; buffer pour exploration des .dir (EXPLORE)OBUEXPL2:	.BLK.8		lgBLK			; buffer pour exploration des .dir (EXPLORE)ONREP:		.BLK.32		1			; ^buffer des noms des dossiersOLNREP:		.BLK.32		1			; Longueur du buffer ONREPOBlocKO:	.blk.32		1			; ^buffer des blocs KOOnBlocKO:	.blk.16		1			; nombre de Bloc KO trouvsOxBlocKO:	.blk.16		1			; nombre de Bloc KO dj affichOBlocDBL:	.blk.32		1			; ^buffer des blocs  doubleOnBlocDBL:	.blk.16		1			; nombre de Bloc doubles trouvsOxBlocDBL:	.blk.16		1			; nombre de Bloc doubles dj affichOBLOCbad:	.blk.32		1			; ^buffer des blocs illisiblesOnBLOCbad:	.blk.16		1			; nombre de Bloc KO trouvsOxBLOCbad:	.blk.16		1			; nombre de Bloc KO dj affichOFILDEL:	.blk.32		1			; liste des fichiers dtruitsOFILNUM:	.blk.32		1			; nombre*sizeOSEMA:		.BLK.32		1			; smaphore d'accs aux listesOpSEMA:		.blk.16		1OnSEMA:		.blk.16		1OCANUTILE:	.BLK.16		1			; canal UTILE.LIBOcanDBOX:	.BLK.16		1OCHECK:		.BLK.32		1			; oBDCHK originelOCHECKtst:	.BLK.32		1OptTASK:	.blk.32		1OmenuP:		.blk.8		16'100			; place pour le menu principal variableObuBASE:	.blk.32		1			; ^premier buffer de listeOnumBLOC:	.blk.32		1			; nombre de blocs non traitoBadCopie:	.blk.16		1			; compte les blocs illisiblesoPtDBOX:	.blk.32		1			; "canal" pour DBOXoScroll:	.blk.8		LSCVAROnCOPY:OnDIR:		.blk.8		LGNAME			; pour chanage des MMENUOptMACRO:	.blk.32		1ObufMACRO:	.blk.16.32	lgMACRO			; enregistrement de macrosMaxHACH		=	10'2000oBufHACH:	.blk.8		(MaxHACH+7)/8oBufAFF:	.blk.8		LgBLKLGVAR:	.CHAP		START\g_titre;; Programme principal; -------------------\g_Fond;	.LOC		0LOC0:START:;=====	LIB		?OPELIB	MOVE.32		#3,D3	LIB		?MOUSE	MOVE.32		#LGVAR,D4			; D4 <-- longueur ncessaire	MOVE.16		#MTYPCP,D1			; processus courant	GESMEM		?GETMEM				; demande mmoire pour var	JUMP,NE		FATERR	GESMEM		?CLEARMEM			; met  zro TOUTES les variables	MOVE.32		A6,{A4}+OSTART			; mm. adr. de dbut du code	MOVE.32		A4,A6				; A6 <-- ^variables (TOUJOURS)	MOVE.32	#-1,{A6}+ONOBAD		; pas encore de bad initialiss.	MOVE.32		A3,{A6}+OPTCOM			; mm. ^ligne de commande	LIB		?GETDIM	MOVE.32		D3,{A6}+ODIMCAR	TSET.8		{A6}+OFLAG2:#B2FOS	MOVE.32		#R16^nUTILE,A3	MOVE.16		#UTILE_FIRST,D3	LIB_		OPEN				; ouvre le module UTILE	jump,ne		erFAT	MOVE.16		D1,{A6}+OCANUTILE	move.32		#r16^nDBOX,a3	move.32		#DBOX_FIRST,d3	LIB_		OPEN	jump,ne		erFAT	move.16		D1, {a6}+oCANdbox	NTREL		?GETTPT	MOVE.32		A4,{a6}+OptTASK	MOVE.16		#-1,{A6}+OFNOWR			; open unit pas fait	MOVE.32		#-1,{A6}+OBUNO	MOVE.32		#-1,{A6}+OBLKFIN	CLR.32		{A6}+OBUCRT	move.32		#1,d4	ntrel		?CRESEM				; cre un smaphore d'exclusion	jump,ne		er	move.32		a5,{a6}+OSEMA	CALL		AFENTETE			; affiche entte	CALL		GETNAME				; A3 <-- ^nom	JUMP,NE		DOEND	CALL		OPEMM				; ouvre unit physique	JUMP,NE		ER	UTILE_	CLRMENU	call		AFUNIT	move.32		#{a6}+OmenuP,a0	move.32		#R16^MENU_PRIM,a1	move.16		#lgMENUP-1,d0cpmenu$:	move.8		{a1+},{a0+}	dj.16,nmo	d0,cpmenu$				;------------------------------------------------------------				; Cration d'un buffer contenant les noms des rpertoires				; et d'un buffer contennant les BD des rpertoires.				; (on considre qu'un seul BD existe par rpertoire)				;------------------------------------------------------------	MOVE.32		#lgBUREP,D4			; cre le buffer des noms de rpertoire	MOVE.16		#MTYPOP,D1			; taille pour <space><0>SYS_LIST<0><0>	MOVE.32		{a6}+OptTASK,A1	GESMEM		?GETMEM	JUMP,NE		ER	MOVE.32		A4,{A6}+ONREP	MOVE.32		D4,{A6}+OLNREP	MOVE.32		#0, {A4}+OrepPREV		; vide	move.32		#0, {a4}+OrepNEXT	move.8		#16'FF, {a4}+OrepNAME		; plus grand nom possible	move.8		#0, {a4}+OrepNAME+1	move.16		#0, {a4}+OrepFLAG	MOVE.32		{A6}+ODEBPART,D4		; lit le BD de SYS_LIST	INC.32		D4	CALL		litBU	JUMP,NE		ER	move.32		{a4}+ObdCHK,{a6}+oCHECK	call		tstBD				; ressemble  un BD?	jump,eq		suit$	clr.32		d3	lib		?setcurs, ?aftim	.ascize		"<noefli><trunc><cr><cr><afinv>  Le bloc de description du dossier de base n'est pas correct!<mspace><50><afdir>"	call		aferror	lib		?AFTIM	.ascize		"Recherche la valeur de contrle du disque "	move.16		#16'20, d0	add.32		#16'10, d4			; saute quelques blocs probablement KOsrcbl$:	lib		?Aftim	.ascize		"."	inc.32		d4	call		litBU				; les blocs suivants doivent contenir BL	jump,ne		srcbl$	move.32		{a4}+OblCHK,{a6}+OCHECK	call		tstBL				; ressemble  un BL?	jump,eq		bsuit$	dec.16		d0	jump,ne		srcbl$	move.32		#0, {a6}+OCHECK	call		aferror	lib		?AFTIM	.ascize		"<afinv>La valeur de contrle n'est pas connue !<afdir>"	jump		r8^suit$bsuit$:	call		aferrorsuit$:	MOVE.16		#MTYPoP,D1			; cre le buffer des numros des BD	MOVE.32		#4,D4	MOVE.32		{a6}+OptTASK,A1	GESMEM		?GETMEM	JUMP,NE		ER	MOVE.32		#-1,{A4}	MOVE.32		A4,{A6}+OBlocKO	MOVE.16		#MTYPoP,D1			; cre le buffer des numros des BD	MOVE.32		#4,D4	MOVE.32		{a6}+OptTASK,A1	GESMEM		?GETMEM	JUMP,NE		ER	MOVE.32		#-1,{A4}	MOVE.32		A4,{A6}+OBLOCbad	MOVE.16		#MTYPoP,D1			; cre le buffer des numros des BD	MOVE.32		#4,D4	MOVE.32		{a6}+OptTASK,A1	GESMEM		?GETMEM	JUMP,NE		ER	MOVE.32		#-1,{A4}	MOVE.32		A4,{A6}+OBlocDBL	MOVE.16		#MTYPoP,D1			; cre le buffer des numros des BD	MOVE.32		#8,D4	MOVE.32		{a6}+OptTASK,A1	GESMEM		?GETMEM	JUMP,NE		ER	MOVE.32		#-1,{A4}	MOVE.32		#-1, {A4}+4	MOVE.32		A4, {A6}+OFILDEL	move.32		D4, {A6}+OFILNUM	move.32		#{a6}+OnamUNIT, a3	FOS		?GETUNIT			; unit utilise par le FOS?	jump,ne		manu$	TSET.8		{A6}+OFLAGS:#BFREE		; oui	MOVE.32		A4,{A6}+OFREE			; garde ^MAP du FOS!	TSET.8		{A6}+OFLAG3:#B3noRECUP		; rcup non autoris	jump		out$manu$:	call		iniMAP	jump,ne		ER	move.32		a4, {A6}+OFREEout$:	call		iniMAP	jump,ne		ER	move.32		a4, {a6}+OFREE2	clr.32		{a6}+OnumBLOC	move.32		#{a6}+ObuBASE, a0	call		newBUF				; init un buffer	Move.32		#1, D4				; prpare le 1er BD	move.32		#0, D0	move.32		#0, D1	call		putBDl				; ajoute dans liste;=	move.32		#r16^Prun, a0	move.32		a0, {A6}+OpMESS	move.32		a0, {A6}+pPmess	test.8		{a6}+oFLAG2:#B2noEXPL	jump,bc		r8^doEXPL$	call		LOCK	tset.8		{a6}+OFLAG2:#B2PAUSE	move.32		#r16^Poff, a0	move.32		a0, {A6}+OpMESSdoEXPL$:	MOVE.32		#500,D5	MOVE.32		#R16^PEXPL,A5	MOVE.32		#R16^TEXPL,A3	move.32		#10'28,D4			; trs basse priorite	NTREL		?CRETASK.if	SOSDISK;	call		selDBOX	move.32		{a6}+OdebPART, d4	inc.32		d4	move.32		#r16^menu_NIL, a3	lib		?AFMENU	lib		?AFTIM	.ascii		"<EOP><cr>Je vrifie les fichiers du disque.<cr>"	.ascize		"<cr>Le programme teste tous les dossiers et sous-dossiers<cr>"	call		veriHACHloop$:	call		veriCHK				; une erreur de check  corriger?	call		veriHDIR			; un dossier  controler?	jump,eq		loop$	test.8		{A6}+OFLAGS:#BEXPLOK	jump,bs		r8^corr$	move.16		#50,d4	ntrel		?settim	lib		?getCAR	move.16		#-1, d4	ntrel		?settim	comp.16		#F0, d3	jump,ne		loop$corr$:	lib		?AFTIM	.ascii		"<cr>Fin de l'exploration du disque.<cr>"	.ascize		"Correction automatique<cr>"	move.16		#0, {A6}+OxBLOCkolchk$:	call		coriCHK				; une erreur de check  corriger?	jump,eq		lchk$	call		recupFIL			; des fichiers  rcuperer	lib		?AFTIM	.ascize		"<cr>Fin de l'analyse automatique<cr>"	lib		?getCAR	move.16		#0, {A6}+OxBLOCko	lib		?AFTIM	.8		EOP, TRUNC, NOROLL, 0	.even.endif	;SOSDISK	MOVE.32		{A6}+ODEBPART,D4		; affiche le BD de SYS_LIST	INC.32		D4	move.16		#LGBLK, {a6}+OoutFIL	JUMP		DOBAFF				; affiche le 1er bloc utile + 1uLOOP:	call		unLOCKLOOP:;====	call		AFMENUP	CALL		AFQUES	test.8		{A6}+OFLAG3:#BRCMACRO	jump,bc		r8^XM$	LIB		?AFTIM	.ASCIZE		"Commande  enregistrer: "	jump		r8^GT$XM$:	test.8		{A6}+OFLAG3:#BEXMACRO	jump,bc		r8^N$	LIB		?AFTIM	.ASCIZE		"MACRO en excution ... "	jump		r8^GT$N$:	LIB		?AFTIM	.ASCIZE		"Donnez une commande: "GT$:	call		GEThexa	comp.16		#KEYMGR, D3	jump,eq		GT$	comp.16		#KEYMMR, D3	jump,eq		GT$	comp.16		#KEYMDR, D3	jump,eq		GT$	lib		?MinMAJ	PUSH.16		D3	MOVE.16		#EFEOS,D3	LIB		?AFCAR	POP.16		D3	jump,eq		ENDMACRO		UTILE_		JUMPCAR	.32		APC	.16		EOP,LF,0,DOCR	.16		CR, 0, OLDCR	.16		END,F0,0,DOEND	.16		SHIFT+F0, 0, EXPLOONOFF	.16		F1,0,DODEC	.16		F2,0,DOIDEM	.16		SHIFT+F2, 0, DOREAFF	.16		F3,0,DOINC	.16		SHIFT+F1,0,DOPREV	.16		SHIFT+F3,0,DONEXT	.16		SHIFT+F4,0,DOFPREV	.16		SHIFT+F5,0,DOSPOS	.16		SHIFT+F6,0,DOFNEXT	.16		F6,0,DODEEP	.16		F4,0,DORET	.16		F5,0,DORET2	.16		2**BCHANGE*16'100+F7, 0, DOHACHE	.16		F7,0,DOHACHE0	.16		F7+SHIFT,0,DOerrCHK	.16		F8,0,DOEDIT	.16		F8+SHIFT,0,DOerrDBL	.16		F9,0,DOWRITE	.16		2**BCHANGE*16'100+F9, 0, DOWRITEx	.16		F9+SHIFT,0,DOerrBAD	.16		F10,0,CREECRT	.16		F10+SHIFT,0,CREECRTX	.16		F11,0,DOSEARCH	.16		F11+SHIFT,0, DORECUP	.16		F12,0,DONXTBD	.16		F12+SHIFT,0,DONXTBDF	.16		HELP,0,DOHELP	.16		F13,0,DOBDATA	.16		F14,0,DOBD	.16		F15,0,DOBL;	.16		F13+SHIFT,0,DOBIN;	.16		F14+SHIFT,0,DOGENC	.16		KEYMGP,KEYMMP,KEYMDP,0,DOMOUSE;	.16		KEYMGR,KEYMMR,KEYMDR,0,LOOP	.16		2**BPROGRA*16'100+MACRO, 0, RC_MACRO	; enregistrement MACRO	.16		2**BCURSOR*16'100+MACRO, 0, LP_MACRO	; MACRO rptitive	.16		MACRO, 0, EX_MACRO			; excution MACRO;	.16		2**BCOPY*16'100+FNCT, 0, DOSAVNUM;	.16		2**BSHOW*16'100+FNCT, 0, DOGETNUM	.16		"L", 2**BPROGRA*16'100+F3, 0,DOINCLIBRE	.16		2**BPROGRA*16'100+F1, 0,DODECLIBRE	.16		"O", 2**BPROGRA*16'100+SHIFT+F3, 0,DOINCOCCUP	.16		2**BPROGRA*16'100+SHIFT+F1, 0,DODECOCCUP	.16		"X", 2**BPROGRA*16'100+F8, 0,DOFICHIER	.16		"W", 2**BPROGRA*16'100+F9, 0,DOWRFILE	.16		"V", 2**BPROGRA*16'100+SHIFT+F9, 0,DOFILTRE	.16		"K", 2**BPROGRA*16'100+F6, 0,COPYDISK	.16		"R",F12+CTRL,2**BPROGRA*16'100+F12, 0,DONXTBDN	.16		"Z", 2**BPROGRA*16'100+F4, 2**BPROGRA*16'100+SHIFT+F4, 0, DOLAST	.16		"H", 2**BPROGRA*16'100+F7, 0, DOCALHACH	.16		"$", 0, DOWNAM	.16		2**BPROGRA*16'100+"H", 2**BPROGRA*16'100+SHIFT+F7, 0, DOCALHACHx	.16		"I", 0, IBAD	;====!!!!=== PROV	.16		0,ERKuERK:	call		unLOCKERK:	CALL		ERRKEY	JUMP		LOOPDOWNAM:	move.16		{A6}+OchFILE, D6	jump,eq		LOOP	move.32		#{A6}+OBUBLK, A4	move.32		#{A4}+OBDNAME, A4	push.32		A4	clr.32		D4c$:	inc.32		D4	test.8		{A4+}	jump,ne		c$	dec.32		D4	pop.32		A4	Fos		?WrByte	sub.32		#16'10, SP	MOVE.32		{A6}+OBUNO,D4	sub.32		{A6}+oDebPart, D4	move.32		Sp, A4	move.8		#TAB, {A4+}	call		PutHexD4	move.8		#Cr, {A4+}	move.32		SP, A4	move.32		#10'10, D4	Fos		?WrByte	add.32		#16'10, SP	jump		LOOPPutHexD4:	move.16		#8-1, D3l$:	rl.32		#4, D4	push.32		D4	and.16		#16'F, D4	move.8		r8^thex$+A16^{D4}, D4	move.8		D4, {A4+}	pop.32		D4	dj.16,nmo	D3, l$	Retthex$:	.ascii		"0123456789ABCDEF"	.evenIBAD:	MOVE.32	#{A6}+OBUBLK,A4	;!!! on part du principe qu'on vient de lire le BD de SYS_BAD	CALL	INIBAD	JUMP	LOOPRC_MACRO:	tnot.8		{A6}+OFLAG3:#BRCMACRO			; en enregistrement ?	jump,bs		r8^END$					; oui -> fin	move.32		#{A6}+ObufMACRO, A3	move.32		A3, {A6}+OptMACRO			; init ^dbut macro	clr.8		{A3}	JUMP		LOOPEND$:	move.32		{A6}+OptMACRO, A3	clr.16		{A3}-2					; supprime l'ordre MACRO	JUMP		LOOPLP_MACRO:	tset.8		{A6}+OFLAG3:#BLPMACRO	JUMP		r8^MACEX_MACRO:	tclr.8		{A6}+OFLAG3:#BLPMACROMAC:	tclr.8		{A6}+OFLAG3:#BRCMACRO	jump,bc		r8^ok$	move.32		{A6}+OptMACRO, A3	clr.16		{A3}-2					; supprime l'ordre MACROok$:	tset.8		{A6}+OFLAG3:#BEXMACRO	move.32		#{A6}+ObufMACRO, A3	move.32		A3, {A6}+OptMACRO			; init ^dbut macro	jump		LOOPENDMACRO:	test.8		{A6}+OFLAG3:#BLPMACRO	jump,bs		MAC	tclr.8		{A6}+OFLAG3:#BRCMACRO	tclr.8		{A6}+OFLAG3:#BEXMACRO	jump		LOOPDOSAVNUM:DOGETNUM:	retDOMOUSE:;========	call		LOCK	move.32		{a6}+OdebPART, d4	inc.32		d4	move.32		#r16^nSYS_LIST, A2	call		MMENU				; demande avec la souris	jump,ne		uLOOPuDOCR:	call		unLOCK	JUMP		DOCRMMENU:; in	D4.32		no du BD de base;	A2.32		^nom niveau actuel	push.32		d4	move.16		#0, d4	lib		?waitMOUSE	pop.32		d4	call		exploVITEBD			; regarde vite si on connait tout!	MOVE.32		{A6}+ONREP,A3			; ^liste des .dir	CLR.32		D3				; compte ceux de ce niveau	sub.32		#LGbuREP, A3lp$:	add.32		#LGbuREP, A3	test.32		{A3}+OrepPREV	jump,eq		end$	comp.32		{a3}+OrepPREV, D4		; prvious correspond?	jump,ne		lp$	inc.32		d3				; oui, le compte	jump		lp$end$:	clr.16		d7	mul.16		#LGNAME, d3	jump,eq		nop$	ex.32		d3,d4	add.32		#LGNAME, d4	move.32		#MtypCP, d1	GESMEM		?GETMEM	jump,ne		er$	ex.32		d3,d4	push.32		a4	move.8		#SPACE, {A4+}	clr.8		{A4+}	move.8		#-1, {a4+}cn$:	move.8		{a2+}, {a4+}			; copie le nom d'entre	jump,ne		cn$	move.8		#-1, {a4+}	MOVE.32		{A6}+ONREP,A3	CLR.32		D3	sub.32		#LGbuREP, A3lp2$:	add.32		#LGbuREP, A3	test.32		{A3}+OrepPREV	jump,eq		end2$	comp.32		{a3}+orepPREV, D4	jump,ne		lp2$	move.32		#{a3}+orepNAME, a0	move.8		#SPACE, {A4+}cp$:	move.8		{a0+}, {a4+}				; copie le nom	jump,ne		cp$	move.8		#SPACE, {A4}-1	MOVE.8		#0, {A4+}	jump		lp2$end2$:	clr.8		{a4}	pop.32		a4	move.32		a4, a3;	clr.16		d3	clr.16		d5	call		tstBLOCS	move.16		{A0}+OTBNUM, d3	push.32		d4	move.16		#1, d4	lib		?waitMOUSE	pop.32		d4	LIB		?MMENU	GESMEM		?GIVMEM	move.16		#1, d7	move.16		d3, {A0}+OTBNUM				; mmorise pour la prochaine fois;	test.16		d3	jump,eq		nop0$	clr.16		d7	dec.16		d3	jump,eq		nop$	MOVE.32		{A6}+ONREP,A3	sub.32		#LGbuREP, A3lp3$:	add.32		#LGbuREP, A3	test.32		{A3}+OrepPREV	jump,eq		end3$	comp.32		{a3}+OrepPREV, D4	jump,ne		lp3$	dec.16		d3	jump,ne		lp3$	move.32		{a3}+OrepNEXT, d4			; no du prochain	move.32		#{A3}+OrepNAME, a2			; nom courant	move.32		#{A6}+OnDIR, a3cpn0$:	move.8		{a2+}, {a3+}				; copie le nom	jump,ne		cpn0$	move.32		#{a6}+OnDIR, a2end3$:	call		MMENU				; demande la suite!	jump		r8^er$nop0$:	tclr.8		{A6}+OFLAG3:#BEXMACRO		; stoppe les macrosnop$:er$:	test.16		d7	retDOHELP:							; Donne une petite aide ;======	call		afQUES	MOVE.16		#BIPEND,D3	LIB		?BEEP,?GETCURS,?AFTIM	.ASCII		"<AFINV> HELP <AFDIR> appuyez encore sur HELP pour une aide gnrale,<CR>"	.ASCIZE		"       ou sur la TOUCHE FONCTION incomprise : "	PUSH.32		D3	MOVE.32		#R16^THELP,A3	LIB		?GETCAR	COMP.16		#HELP,D3	JUMP,NE		L70$	MOVE.32		#17,D3	JUMP		L80$L70$:	UTILE_		FNOSHIFT	COMP.16		#F0,D3	JUMP,LO		L90$	COMP.16		#F15,D3	JUMP,HI		L90$	SUB.16		#F0-1,D3			; D3 = [1,16] numro binaire +1 touche-fonctionL80$:	CALL		AFERROR	lib		?AFTIM	.8		AUTOCR, ROLL, EFEOS, 0	.EVEN	TSET.32		D3:#BTEXT	UTILE_		AFMES	JUMP,EQ		L90$	MOVE.16		#BIPERR,D3	LIB		?BEEP	CALL		AFERROR	LIB		?AFTIM	.ASCIZE		"EDISK.HELP manque..."L90$:	POP.32		D3	LIB		?SETCURS,?AFTIM	.8		TRUNC, NOROLL, EFLI,0	JUMP		LOOPCREECRT:						; Saisie d'un critre ;=======	CALL		AFQUES	LIB		?MAFTIM	.ASCIZ		"<"F"><EFLI>Dfinissez le critre : "	.8		0	.EVEN	MOVE.32		#{A6}+OBUCRT,A3	Move.32		A3,A4a$:	test.8		{A4+}	jump,ne		a$	dec.32		A4	move.32		#r16^lterm,A2Ed$:	MOVE.32		#LBUCRT-2+2**15,D3	LIB		?EDIT	comp.8		#END, D3	jump,eq		r8^f$	comp.8		#Cr, D3	jump,ne		ed$f$:	tclr.8		{a6}+oFLAG2:#B2HEX		; signale texte	tset.8		{a6}+oFLAG2:#B2RECH		; aff. possiblel$:	test.8		{a3}	jump,eq		LOOP	comp.8		#CR,{a3+}			; supprime le cr final	jump,ne		l$	clr.8		{a3}-1	JUMP		LOOPlterm:	.8		2**7	.evenCREECRTx:						; Saisie d'un critre hexa;=======	CALL		AFQUES	LIB		?MAFTIM	.ASCIZ		"<"F"><EFLI>Dfinissez le critre hexadcimal (32 bits): <CURS>"	.8		0	.EVENEd$:	lib		?getHEX	comp.8		#END, D3	jump,eq		r8^f$	comp.8		#Cr, D3	jump,ne		ed$f$:	MOVE.32		d4,{A6}+OBUCRTx	tset.8		{a6}+oFLAG2:#B2HEX		; signale nombre	tset.8		{a6}+oFLAG2:#B2RECH		; aff. possible	JUMP		LOOPDOSEARCH:						; Recherche selon le critre dans (A6)+OBUFCRT ;========	test.8		{a6}+OFLAG2:#B2HEX	jump,bs		r8^L0$	TEST.8		{A6}+OBUCRT	JUMP,NE		L0$	CALL		AFERROR	LIB		?MAFTIM	.ASCIZ		"<"F"><EFLI>Pas de critre dfini!..."	.8		0	.EVEN	LIB		?BUZZ	JUMP		LOOPL0$:	CALL		AFQUES	LIB		?MAFTIM	.ASCIZ		"<"F">Recherche "	.8		0	.EVEN	call		afCRIT	LIB		?MAFTIM	.asciz		"<"F"> sur toute l'unit ...<CR><EFLI>"	.8		0	.even	TCLR.8		{a6}+oflags:#BMENUP	MOVE.32		#R16^MENU_CHERCHE,A3	LIB		?AFMENU	move.16		#0, d4	lib		?waitMOUSE	move.32		{a6}+ObuCRTx,D0	MOVE.16		#10,D3				; cre le buffer pour la recherche (A4^)	MOVE.32		#LGBLK,D4	MOVE.32		#16'4000,D5	MOVE.16		#MTYPCP,D1	GESMEM		?GETPMEM	JUMP,NE		ER	MOVE.32		A4,{A6}+OBURECH	DIV.16		#LGBLK,D4	AND.32		#16'FFFF,D4	MOVE.32		D4,{A6}+ONBBLK	call		LOCK	MOVE.32		#{A6}+OBUCRT,A3			; A3^critre	MOVE.32		#R16^LISTTERM,A2		; A2^liste de terminateurs pour ?cpstring	MOVE.32		{A6}+OBUNO,D4			; depuis OBUNO+1 	INC.32		D4	MOVE.32		{A6}+ONBBLK,D5step$:	MOVE.32		{A6}+OBURECH,A4	CALL		RDBLK	JUMP,EQ		L9$	COMP.32	#0,D5	JUMP,EQ	L18$	COMP.16		#ERMOUT,D7	JUMP,EQ		L80$	comp.32		#1, D5				; dj en step?	jump,eq		L18$				; oui -> erreur	move.32		#1, D5	JUMP		step$L9$:	MOVE.32		#0,D6				; D6.32 nombre de caractres compars de la tranche lue	JUMP		a9$L10$:	MOVE.32		{A6}+OBURECH,A1			; transfert dernier blk au dbut buffer (chevauchement)	SUB.32		#LGBLK,A4	push.32		d0	MOVE.16		#LGBLK-1,D0L15$:	MOVE.8		{A4+},{A1+}	DJ.16,NMO	D0,L15$	pop.32		d0	ADD.32		D5,D4				; Lit les blocs suivants	MOVE.32		A1,A4	MOVE.32		{A6}+ONBBLK,D5	DEC.32		D5step2$:	CALL		RDBLK	JUMP,EQ		L19$	COMP.32	#0,D5	JUMP,EQ	L18$	COMP.16		#ERMOUT,D7	JUMP,EQ		L80$	comp.32		#1, d5	jump,eq		r8^L18$	move.32		#1, d5				; passe en pas  pas !	jump		step2$L18$:	PUSH.16		D7				; si erreur autre que fin de la mm,	MOVE.16		#MTYPCP,D1			; on rend buffer,	MOVE.32		{A6}+OBURECH,A4	GESMEM		?GIVMEM	MOVE.32		#-1,{A6}+OBUNO			; on affiche le blk ko, et l'erreur	call		aferror	lib		?AFTIM	.ascize		"Recherche stoppe, erreur de lecture."	POP.16		D7	move.16		#LGBLK, {a6}+OoutFIL	tclr.8		{A6}+OFLAG3:#BLPMACRO	tclr.8		{A6}+OFLAG3:#BEXMACRO	JUMP		uDOBAFF				; on affiche l'erreur et le numro du blkL19$:	SUB.32		#LBUCRT,A4			; Pour comparaison insensible au chevauchement 	MOVE.32		#-LBUCRT,D6a9$:	MOVE.32		{A6}+OBURECH,A0			; A0 pointe fin du buffer 	MOVE.32		D5,D7	INC.16		D7	MUL.16		#LGBLK,D7	ADD.32		D7,A0	LIB		?IFCAR				; Avorte?...	JUMP,NE		n20$	COMP.16		#F0,D3	JUMP,EQ		stop$	COMP.16		#END,D3	jump,eq		stop$n20$:	test.8		{a6}+OFLAG2:#B2HEX	jump,bs		r8^hex$L20$:	INC.32		D6	COMP.32		A0,A4				; Si fin de tranche, suivante (10$) 	JUMP,HS		L10$	comp.8		#"*",{a3}			; recherche tout 1er car	jump,eq		r8^skp$	COMP.8		{A3+},{A4+}			; Acclre la comparaison	DEC.32		A3	JUMP,NE		L20$	DEC.32		A4skp$:	LIB		?IFCAR				; Avorte?...	JUMP,NE		L21$	COMP.16		#F0,D3	JUMP,EQ		stop$	comp.16		#END,D3	jump,eq		stop$L21$:	push.32		a3	comp.8		#"*",{a3}			; recherche tout 1er car	jump,ne		r8^c$	inc.32		a3c$:	LIB		?CPSTRING			; Recherche si suite 1er caractre aussi ok	pop.32		a3	INC.32		A4	JUMP,NS		L20$	jump		r8^bon$hex$:	INC.32		D6	INC.32		D6	COMP.32		A0,A4				; Si fin de tranche, suivante (10$) 	JUMP,HS		L10$	COMP.32		{A4},d0				; comparaison	add.32		#2,A4				; aligne de .16 en .16	JUMP,NE		hex$	DEC.32		A4	jump		r8^bon$stop$:	call		AFERROR	lib		?afTIM	.ascize		"Recherche stoppe"	tclr.8		{A6}+OFLAG3:#BLPMACRO	tclr.8		{A6}+OFLAG3:#BEXMACRO	jump		r8^L23$bon$:	call		afERROR	call		afCRIT	lib		?aftim	.ascize		" trouv, offset dans le bloc: H'"	push.32		d4	move.32		a4, d4	sub.32		{a6}+ObuRECH, d4	lib		?afx2	pop.32		d4	TEST.32		D6				; Mise  jour compteur bloc 	JUMP,NC		L22$	DEC.32		D4				; si D6 ngatif, le dbut de la chane	JUMP		L23$				; est dans dernier bloc tranche prcdenteL22$:	DIV.16		#LGBLK,D6	AND.32		#16'FFFF,D6	ADD.32		D6,D4L23$:	PUSH.32		A4				; On rend la mmoire 	MOVE.32		{A6}+OBURECH,A4	MOVE.16		#MTYPCP,D1	GESMEM		?GIVMEM	POP.32		A4	LIB		?BUZZ	move.16		#LGBLK, {a6}+OoutFIL	JUMP		uDOBAFFL80$:	CALL		AFerror	LIB		?MAFTIM	.ASCIZ		"<"F"><EFLI>Pas trouv..."	.8		0	.EVEN	tclr.8		{A6}+OFLAG3:#BLPMACRO	tclr.8		{A6}+OFLAG3:#BEXMACROL90$:	MOVE.32		{A6}+OBURECH,A4	MOVE.16		#MTYPCP,D1	GESMEM		?GIVMEM	LIB		?BUZZ,?BUZZ	JUMP		uLOOPafCRIT:	test.8		{a6}+OFLAG2:#B2HEX	jump,bs		r8^L01$	push.32		a3	move.32		#{a6}+ObuCRT,A3	lib		?aftext				; affiche le critre ASCII	pop.32		a3	jump		r8^L02$L01$:	push.32		d4	move.32		{a6}+ObuCRTx,D4	lib		?afx8				; affiche le critre HEXA	pop.32		d4L02$:	retLISTTERM:	.ASCII		"<0><CR><16'FF>"	.EVENDONXTBDN:;========	tset.8		{A6}+oFlag4:#B4BDNAM	jump		r8^dnxtBDfDONXTBD:						; Recherche prochain BD;========	tclr.8		{a6}+Oflag2:#B2FRE	tclr.8		{A6}+oFlag4:#B4BDNAM	jump		r8^dnxtBDDONXTBDF:;========	tclr.8		{A6}+oFlag4:#B4BDNAMdnxtBDf:	tset.8		{a6}+Oflag2:#B2FRE	test.8		{a6}+Oflags:#BFREE	jump,bs		r8^dnxtBD	call		AFERROR	LIB		?AFTIM	.ascize		"Recherche imposible, SYS_FREE pas en mmoire"	LIB		?BUZZ	JUMP		LOOPdnxtBD:	CALL		AFQUES	LIB		?AFTIM	.ASCIZE		"Recherche prochain BD "	test.8		{a6}+Oflag2:#B2FRE	jump,bc		r8^occ$	lib		?AFTIM	.ascize		"libre "	test.8		{A6}+oFlag4:#B4BDNAM	jump,bc		r8^occ$	move.32		#{a6}+ObuCRT,A3	lib		?AFTEXT, ?AFSPACEocc$:	lib		?AFTIM	.ascize		"sur toute l'unit...<CR><EFLI>"	TCLR.8		{a6}+oflags:#BMENUP	MOVE.32		#R16^MENU_CHERCHE,A3	LIB		?AFMENU	move.16		#0, d4	lib		?waitMOUSE	MOVE.16		#10,D3				; cre le buffer pour la recherche (A4^)	MOVE.32		#LGBLK,D4	MOVE.32		#16'4000,D5	MOVE.16		#MTYPCP,D1	GESMEM		?GETPMEM	JUMP,NE		ER	MOVE.32		A4,{A6}+OBURECH	DIV.16		#LGBLK,D4	AND.32		#16'FFFF,D4	MOVE.32		D4,{A6}+ONBBLK	call		LOCK	MOVE.32		{A6}+OBUNO,D4			; depuis OBUNO+1 L8$:	INC.32		D4	MOVE.32		{A6}+ONBBLK,D5step$:	MOVE.32		{A6}+OBURECH,A4	CALL		RDBLK	JUMP,EQ		L19$	COMP.16		#ERMOUT,D7	JUMP,EQ		L80$	comp.16		#1, D5	JUMP,eq		r8^L18$	move.16		#1, d5	jump		step$L18$:	PUSH.16		D7				; si erreur autre que fin de la mm,	MOVE.16		#MTYPCP,D1			; on rend buffer,	MOVE.32		{A6}+OBURECH,A4	GESMEM		?GIVMEM	MOVE.32		#-1,{A6}+OBUNO			; on affiche le blk ko, et l'erreur	call		aferror	lib		?aftim	.ascize		"Recherche stoppe, erreur de lecture."	tclr.8		{A6}+OFLAG3:#BLPMACRO	tclr.8		{A6}+OFLAG3:#BEXMACRO	POP.16		D7	move.16		#LGBLK, {a6}+OoutFIL	JUMP		uDOBAFF				; on affiche l'erreur et le numro du blkL19$:	MOVE.32		{A6}+OBURECH,A0			; A0 pointe fin du buffer 	MOVE.32		D5,D7	INC.16		D7	MUL.16		#LGBLK,D7	ADD.32		D7,A0	dec.32		d4	LIB		?IFCAR				; Avorte?...	JUMP,NE		L20$	COMP.16		#F0,D3	JUMP,EQ		ok$	COMP.16		#END,D3	jump,eq		ok$L20$:	COMP.32		A0,A4				; Si fin de tranche, suivante (10$) 	JUMP,HS		L8$	inc.32		d4				; no bloc test	call		tstBD				; est-ce un BD?	Add.32		#lgBLK,A4	JUMP,NE		L20$	test.8		{a6}+oflag2:#B2FRE	jump,f		r8^L23$	call		FREE?				; bloc occup ?	jump,bs		L20$	test.8		{A6}+oFlag4:#B4BDNAM	jump,bc		r8^L23$	push.32		A4	move.32		#{A6}+oBuCRT, A3		; critre de recherche	move.32		#{A4}-lgBLK+oBDNAME, A4	MOVE.32		#R16^LISTTERM,A2		; A2^liste de terminateurs pour ?cpstring	Lib		?CPSTRING	pop.32		A4	jump,ns		L20$	jump		r8^L23$ok$:	call		AFERROR	lib		?afTIM	.ascize		"Recherche stoppe"	tclr.8		{A6}+OFLAG3:#BLPMACRO	tclr.8		{A6}+OFLAG3:#BEXMACROL23$:	PUSH.32		A4				; On rend la mmoire 	MOVE.32		{A6}+OBURECH,A4	MOVE.16		#MTYPCP,D1	GESMEM		?GIVMEM	POP.32		A4	LIB		?BUZZ	move.16		#LGBLK, {a6}+OoutFIL	JUMP		uDOBAFFL80$:	CALL		AFERROR	LIB		?MAFTIM	.ASCIZ		"<"F"><EFLI>Pas trouv..."	.8		0	.EVEN	tclr.8		{A6}+OFLAG3:#BLPMACRO	tclr.8		{A6}+OFLAG3:#BEXMACROL90$:	MOVE.32		{A6}+OBURECH,A4	MOVE.16		#MTYPCP,D1	GESMEM		?GIVMEM	LIB		?BUZZ,?BUZZ	JUMP		uLOOPDOBDATA:;=======	TSET.8		{A6}+OFLAGS:#BIMP	MOVE.16		#TYPDATA,{A6}+OTYPBLK	MOVE.32		{A6}+OBUNO,D4	JUMP		DOBAFFDOBD:;====	TSET.8		{A6}+OFLAGS:#BIMP	MOVE.16		#TYPBD,{A6}+OTYPBLK	MOVE.32		{A6}+OBUNO,D4	JUMP		DOBAFFDOBL:;====	TSET.8		{A6}+OFLAGS:#BIMP	MOVE.16		#TYPBL,{A6}+OTYPBLK	MOVE.32		{A6}+OBUNO,D4	JUMP		DOBAFF.if	falseDOBIN:;=====	TSET.8		{A6}+OFLAGS:#BIMP	MOVE.16		#TYPBIN,{A6}+OTYPBLK	MOVE.32		{A6}+OBUNO,D4	JUMP		DOBAFFDOGENC:;======	TSET.8		{A6}+OFLAGS:#BIMP	MOVE.16		#TYPGENC,{A6}+OTYPBLK	MOVE.32		{A6}+OBUNO,D4	JUMP		DOBAFF.endifDOIDEM:;======	lib		?aftim	.8		EOP, 0	call		AFentete	call		AFunit	MOVE.32		{A6}+OBUNO, D4	MOVE.32		#-1, {A6}+OBUNO	TSET.8		{A6}+OFLAG2:#B2AFTOUT	JUMP		DOBAFFDOLAST:;======	move.32		{A6}+OBLKFIN, d4	dec.32		d4	JUMP		r8^DOCRDOREAFF:;=======	MOVE.32		{A6}+OBUNO,D4DOCR:;====;	MOVE.32		#-1,{A6}+OBUNO	move.16		#LGBLK, {a6}+OoutFIL	JUMP		DOBAFFOLDCR:	call		AFERROR	MOVE.8		#BIPERR,D3	LIB		?BEEP,?AFTIM	.ASCIZE		"Utilisez SHIFT-CR pour accder  un numro de bloc !"	JUMP		LOOPDODEC:;=====	MOVE.32		{A6}+OBUNO,D4	DEC.32		D4	move.16		#LGBLK, {a6}+OoutFIL	JUMP		DOBAFFDOINC:;=====	MOVE.32		{A6}+OBUNO,D4	INC.32		D4	move.16		#LGBLK, {a6}+OoutFIL	JUMP		DOBAFFDOINCLIBRE:	MOVE.32		{A6}+OBUNO,D4	move.16		#LGBLK, {a6}+OoutFILlp$:	comp.32		{A6}+OfinPART, D4	jump,hs		DOBAFF	INC.32		D4	CALL		FREE?	JUMP,bs		lp$	JUMP		DOBAFFDOINCOCCUP:	MOVE.32		{A6}+OBUNO,D4	move.16		#LGBLK, {a6}+OoutFILlp$:	INC.32		D4	comp.32		{A6}+OfinPART, D4	jump,hs		DOBAFF	CALL		FREE?	JUMP,bc		lp$	JUMP		DOBAFFDODECLIBRE:	MOVE.32		{A6}+OBUNO,D4	move.16		#LGBLK, {a6}+OoutFILlp$:	test.32		D4	jump,eq		DOBAFF	DEC.32		D4	CALL		FREE?	JUMP,bs		lp$	JUMP		DOBAFFDODECOCCUP:	MOVE.32		{A6}+OBUNO,D4	move.16		#LGBLK, {a6}+OoutFILlp$:	test.32		D4	jump,eq		DOBAFF	DEC.32		D4	CALL		FREE?	JUMP,bc		lp$	JUMP		DOBAFFDOPREV:;======	test.8		{a6}+OFMENU:#BMPREV	JUMP,bc		erk	COMP.16		#TYPBL,{A6}+OTYPBLK	JUMP,EQ		BL$	COMP.16		#TYPBD,{A6}+OTYPBLK	JUMP,NE		erk	MOVE.32		{A6}+OBUBLK+OBDPREV,D4	JUMP,EQ		erk	ADD.32		{A6}+ODEBPART,D4	move.16		#LGBLK, {a6}+OoutFIL	JUMP		DOBAFFBL$:	MOVE.32		{A6}+OBUBLK+OBLPREV,D4	JUMP,ns		erk	call		nxDEEP	move.16		#LGBLK, {a6}+OoutFIL	JUMP		DOBAFFDONEXT:;======	test.8		{A6}+OFMENU:#BMNEXT	JUMP,bc		erk	COMP.16		#TYPBL,{A6}+OTYPBLK	JUMP,EQ		BL$	COMP.16		#TYPBD,{A6}+OTYPBLK	JUMP,NE		erk	MOVE.32		{A6}+OBUBLK+OBDNEXT,D4	JUMP,EQ		erk	ADD.32		{A6}+ODEBPART,D4	move.16		#LGBLK, {a6}+OoutFIL	JUMP		DOBAFFBL$:	MOVE.32		{A6}+OBUBLK+OBLNEXT,D4		; vrifie la validit du NEXT^	JUMP,EQ		erk	call		nxDEEP	move.16		#LGBLK, {a6}+OoutFIL	JUMP		DOBAFFDODEEP:							; IN: D4.32 numro de commande;======	move.32		{A6}+oBuNo, {A6}+oPrvBloc	test.8		{a6}+OFLAG2:#B2FOS	jump,BC		r8^L0$	sub.32		{A6}+ODEBPART,D4L0$:	COMP.16		#TYPDATA,{A6}+OTYPBLK	JUMP,EQ		ERK	COMP.16		#TYPBL,{A6}+OTYPBLK	JUMP,EQ		BL$	COMP.16		#TYPBD,{A6}+OTYPBLK	JUMP,NE		ERK	CALL		NXDEEP				; D4.32 = num. du nime bloc de data	JUMP		DOBAFFBL$:	COMP.32		#NBFLST,D4			; NBFLST = nbr. de fichiers dans un BL	JUMP,HS		L80$	MUL.16		#LGBL,D4	ADD.16		#OBUBLK,D4	MOVE.32		{A6}+A16^{D4}+OBLPT,D4		; D4.32 numro du BD de ce fichier	jump,eq		r8^L80$	ADD.32		{A6}+ODEBPART,D4	move.16		#LGBLK, {a6}+OoutFIL	JUMP		DOBAFFL80$:	CALL		AFERROR	MOVE.8		#BIPERR,D3	LIB		?BEEP,?AFTIM	.ASCIZE		"Attention: ^NIL"	JUMP		LOOPDORET:;======	move.16		#LGBLK, {a6}+OoutFIL	MOVE.32		{A6}+OREWIND,D4	JUMP,ne		DOBAFF	move.32		{A6}+oPrvBloc, D4	jump,ne		DOBAFF	JUMP		ERKDORET2:;======	MOVE.32		{A6}+OREWIND2,D4	JUMP,EQ		ERK	move.16		#LGBLK, {a6}+OoutFIL	JUMP		DOBAFFDOerrCHK:;========	call		LOCK	move.32		{a6}+OBlocKO,a0	comp.32		#-1,{a0}			; fin de la liste ?	jump,eq		uERK	move.16		{a6}+OxBlocKO,d0		; nombre  parcourirlp$:	move.32		{a0+},d4	comp.16		#-1,d4	jump,ne		r8^ok$	move.32		{a6}+OBlocKO,a0	move.16		#0,d0	move.16		d0,{a6}+OxBlocKO	move.32		{a0},D4	tclr.8		{A6}+OFLAG3:#BEXMACRO		; stoppe l'excution de la macro	tclr.8		{A6}+OFLAG3:#BLPMACROok$:	dec.16		d0	jump,cc		lp$	inc.16		{a6}+OxBlocKO	move.16		#LGBLK, {a6}+OoutFIL	jump		uDOBAFFDOerrDBL:;========	call		LOCK	move.32		{a6}+OBlocDBL,a0	comp.32		#-1,{a0}			; fin de la liste ?	jump,eq		uERK	move.16		{a6}+OxBlocDBL,d0		; nombre  parcourirlp$:	move.32		{a0+},d4	comp.16		#-1,d4	jump,ne		r8^ok$	move.32		{a6}+OBlocDBL,a0	move.16		#0,d0	move.16		d0,{a6}+OxBlocDBL	move.32		{a0},D4	tclr.8		{A6}+OFLAG3:#BEXMACRO		; stoppe l'excution de la macro	tclr.8		{A6}+OFLAG3:#BLPMACROok$:	dec.16		d0	jump,cc		lp$	inc.16		{a6}+OxBlocDBL	move.16		#LGBLK, {a6}+OoutFIL	jump		uDOBAFFDOerrBAD:;========	call		LOCK	move.32		{a6}+OblocBAD,a0	comp.32		#-1,{a0}			; fin de la liste ?	jump,eq		uERK	move.16		{a6}+OxblocBAD,d0		; nombre  parcourirlp$:	move.32		{a0+},d4	comp.16		#-1,d4	jump,ne		r8^ok$	move.32		{a6}+OblocBAD,a0	move.16		#0,d0	move.16		d0,{a6}+OxblocBAD	move.32		{a0},D4	tclr.8		{A6}+OFLAG3:#BEXMACRO		; stoppe l'excution de la macro	tclr.8		{A6}+OFLAG3:#BLPMACROok$:	dec.16		d0	jump,cc		lp$	inc.16		{a6}+OxblocBAD	move.16		#LGBLK, {a6}+OoutFIL	jump		uDOBAFFDOFICHIER:	move.16		{A6}+OchFILE, D6	jump,eq		r8^New$	Fos		?CLOSE	clr.16		{A6}+OchFILE	call		AFMENUP?	jump		LOOPNew$:	CALL		AFQUES	LIB		?AFTIM	.ASCIZE		"Nom de fichier sauvegarde:"	MOVE.32		#{A6}+OBUFI,A3	MOVE.32		#lBUCRT,D3	Move.32		A3,A4a$:	test.8		{A4+}	jump,ne		a$	dec.32		A4	comp.8		#cr, {A4}-1	jump,ne		r8^e$	clr.8		{-A4}e$:	move.32		#0, A5	LIB		?getFILE		; attend un nom de fichier	test.8		{A3}	jump,eq		LOOPc$:	move.32		#DEFATT, D3	FOS		?CREATE	jump,eq		open$	CALL		AFQUES	LIB		?AFTIM	.ASCIZE		"Fichier existe dj D)truit A)ppond C)hange nom ? "g$:	LIB		?GetCar	lib		?MinMAJ	comp.8		#"C", D3	jump,eq		e$	comp.8		#"A", D3	jump,eq		r8^open$	comp.8		#"D", D3	jump,ne		g$	Fos		?Delete	jump		c$open$:	move.32		#2**BOPEXCL+2**BOPWR+2**BOPAPPEND+2**BOPEXTEND, D3	FOS		?ARGSOPEN	jump,ne		r8^Er$	move.16		D6, {A6}+OchFILE	clr.8		{A3}	jump		LoopEr$:	push.16		D7	CALL		AFERROR	pop.16		D7	lib		?afERROR	clr.8		{A3}	jump		LoopCOPYDISK:	move.16		{A6}+OchFILE, D6	jump,eq		r8^New$	Fos		?CLOSE	clr.16		{A6}+OchFILENew$:	CALL		AFQUES	LIB		?AFTIM	.ASCIZE		"Unit ou fichier.DI de copie : "	MOVE.32		#{A6}+OBUFI,A3	Move.32		A3,A4a$:	test.8		{A4+}	jump,ne		a$	dec.32		A4	comp.8		#cr, {A4}-1	jump,ne		r8^e$	clr.8		{-A4}e$:	move.32		#0, A5	MOVE.32		#lBUCRT,D3	LIB		?getFILE		; attend un nom de fichier	comp.16		#KeyMGR, d3	jump,eq		e$	comp.16		#KeyMDR, d3	jump,eq		e$	comp.16		#KeyMMR, d3	jump,eq		e$	comp.16		#CR, d3	jump,ne		LOOP	test.8		{A3}	jump,eq		LOOPc$:	Fos		?WHAT			; quel genre de fichier ?	jump,ne		Er$	test.32		D3:#bWhUnit	jump,bs		mmopen$	move.32		#DEFATT, D3	FOS		?CREATE	jump,eq		open$	CALL		AFQUES	LIB		?AFTIM	.ASCIZE		"Fichier existe dj D)truit C)hange nom ? "g$:	LIB		?GetCar	lib		?MinMAJ, ?AfCode	comp.8		#"C", D3	jump,eq		e$	comp.8		#"D", D3	jump,ne		g$	Fos		?Delete	jump		c$mmopen$:	move.32		#{A6}+OBUNAM, A2	move.32		#LGNAME, D4	move.32		#2**BOPEXCL+2**BOPWR+2**BOPMMUNIT+2**BOPEXTEND+2**BOPNAME, D3	move.32		{A6}+OdebPART, D1	FOS		?ARGSOPEN	jump,ne		Er$	move.32		#{A6}+OBURST, A4	move.32		#LGMAM0,d4	FOS		?RSTATUS	jump,ne		Er$	move.32		{A6}+OMAXBLK,d4			; D4 <-- nb max de blocs	comp.32		{A4}+OMNBLK, D4	jump,ne		n$	CALL		AFQUES	LIB		?AFTIM	.ASCIZE		"ATTENTION la copie efface tout sur "	move.32		A2, A3	Lib		?AfText, ?AFTIM	.ascize		" ! Continue oui/non ? "	Lib		?YESNO	jump,ne		Clo$	jump		r8^ow$n$:	CALL		AFERROR	LIB		?AFTIM	.ascize		"Unit destination n'a pas la mme capacit que la source !"	jump		clo$open$:	move.32		#2**BOPEXCL+2**BOPWR+2**BOPAPPEND+2**BOPEXTEND, D3	move.32		#0, D1o$:	FOS		?ARGSOPEN	jump,ne		Er$ow$:	move.16		D6, {A6}+OchFILE	call		LOCK	move.32		{A6}+oMaxBLK, D0	add.32		{A6}+oDebPart, D0	sub.32		D1, D0				; nombre de bloc  copier; rserve un tampon pour copier plus vite	push.32		D1	MOVE.16		#13,D3				; cre le buffer pour la recherche (A4^)	MOVE.32		#LGBLK,D4	move.32		#32*LGBLK+4, D5		; lecture par 32 blocs  la fois						; de toutes faon il y a des blocs KO	MOVE.16		#MTYPCP,D1	GESMEM		?GETPMEM	popm.32		D1	JUMP,NE		ER$	MOVE.32		A4,{A6}+OBURECH			; ^tampon	DIV.16		#LGBLK,D4			; nombre de blocs	AND.32		#16'FFFF,D4	MOVE.32		D4,{A6}+ONBBLK	clr.16		{A6}+oBadCopie	call		OuvreDBOX	clr.32		D5	call		AvanceScroll			; met en place l'ascenseur	set.8		{A6}+NoBisection	move.32		D1, D4r$:	MOVE.32		{A6}+ONBBLK,D5	comp.32		D0, D5	jump,lo		r8^step$	move.32		D0, D5				; reste  lire infrieur au tamponstep$:	move.8		#"L", D3	call		AffScrollD3			; affiche "Lecture" dans l'ascenseur	MOVE.32		{A6}+OBURECH,A4	CALL		RDBLK				; essai de lire la tranche entire	JUMP,EQ		W$				; tout bon, crit maintenant;	COMP.16		#ERMOUT,D7			; dborde la mmoire de masse ?;	JUMP,EQ		W$				; crit le relicat	move.8		#"~", d3			; affichage pour bloc ko	call		AffScrollD3	move.16		D5, D1rdl$:	CALL		RD1BLK				; avance bloc  bloc maintenant	jump,eq		r8^rdn$	comp.16		#erOUTF, D7	jump,eq		r8^rdf$	call		IncScrollBad	call		PATERNE				; rempli avec des ~~~	TEST.8		{A6}+OFLAGS:#BFLO	JUMP,BC		r8^rdn$				; pas un floppy -> illisible	push.32		A4	MOVE.32		#R16^CNOVERIF,A4		; si floppy, on essaye de lire quand mme	MOVE.16		#TYPMM,D3	MOVE.16		{A6}+OCANAL,D6	FOS		?COMMAND	pop.32		A4	CALL		RD1BLK				; lit un bloc unique	push.16		D7	PUSH.32		A4	MOVE.32		#R16^CVERIF,A4	FOS		?COMMAND			; remet le mode de vrification	POP.32		A4	pop.16		D7rdn$:	add.32		#LGBLK, A4			; ^place suivante	inc.32		D4				; demande le suivant	dec.32		D1				; un bloc de lu	jump,ne		rdl$rdf$:	move.32		{A6}+OBURECH, A4		; ^tampon maintenant rempli	sub.32		D1, D5				; si reste  lire ?	sub.32		D5, D4w$:	move.8		#"E", D3			; si tout va bien "Ecriture"	call		AffScrollD3			; met le caractre dans l'assenseur	push.32		D4	sub.32		D5, D0				; reste  lire	move.16		D5, D4	mul.16		#LgBLK, D4			; nombre d'octets  crire	move.16		{A6}+OchFILE, D6	Fos		?WrByte	popm.32		D4	jump,ne		er$	add.32		D5, D4				; position du suivant	call		AvanceScroll	test.32		D0	jump,ne		r$	clr.8		{A6}+NoBisection	push.16		d7	call		UNLOCK	pop.16		d7clo$:Er$:	push.16		D7	move.32		{A6}+oPtDBOX, D5	jump,eq		r8^nclo$	DBOX_		CLOSEnclo$:	clr.32		{A6}+oPtDBOX	Fos		?Close	clr.16		{A6}+oChFILE	MOVE.16		#MTYPCP,D1			; on rend le buffer	MOVE.32		{A6}+OBURECH,A4	GESMEM		?GIVMEM	MOVE.32		{A6}+OBUNO,D4	call		AFERROR	pop.16		D7	jump,ne		r8^aer$	Lib		?AfTim	.ascize		"Copie faite "	test.16		{A6}+oBadCopie	jump,eq		DoBAff	call		AffBad	jump		DoBAff				; fini, rafficheaer$:	lib		?afERROR	jump		DoBAffPATERNE:	pushm.32	A4|D4	move.16		#LgBLK-1, D4c$:	move.8		#"~", {A4+}	dj.16,nmo	d4, c$	popm.32		A4|D4	RetOuvreDbox:	pushm.32	D2..D5|A2	move.32		#r16^Box, A2	move.16		#0, D2	DBOX_		OPEN	move.32		D5, {A6}+oPtDBOX	move.32		#{A6}+oScroll, A5	move.16		#2**bDbGcLabel+1, D2	DBOX_		GetCo	sub.32		D3, D4	move.16		D3, {A5}+OSCDEBO	swap.32		D3	move.16		D3, {A5}+OSCDEBL	move.16		D4, {A5}+OSCHTR	move.8		#1, {A5}+OSCHOR	SCROLL_		DRAW	Lib		?AFTIM	.8		LOADGC, "N", 2**7+"E", 7, 0;	.8		MODCAR, SETDOT+PENDOT, 0	clr.32		D5a$:	comp.32		#2**15, D0	jump,lo		r8^b$	inc.32		D5	sr.32		D0	jump		a$b$:	move.8		#0, {A5}+OSCMARK	move.16		D0, {A5}+OSCHTV		; reste  copier	move.16		#0, {A5}+oSCPOSV	move.32		#0, {A5}+LSCVAR-4	move.16		D5, {A5}+LSCVAR-6	popm.32		D2..D5|A2	RetAffScrollD3:	pushm.32	D3..D4	move.32		{A5}+OSCDEB, D3	swap.32		D3	add.32		#16'000C0016, D3	move.16		{A5}+OSCHTR, D4	SUB.16		#16'30, D4	mul.16		{A5}+OSCPOSV, D4	div.16		{A5}+OSCHTV, D4	add.16		D4, D3	Lib		?SetCurs	Lib		?AFTIM	.8		USEGC, "N", 2**7+"E", 7, 0	popm.32		D3..D4	Lib		?AfCode, ?rstGC	RetAvanceScroll:	pushm.32	D2..D5	add.32		D5, {A5}+LSCVAR-4		; position 32 bits	move.32		{A5}+LSCVAR-4, D5	move.16		{A5}+LSCVAR-6, D2	sr.32		D2, D5	move.16		D5, {A5}+oSCPOSV		; position 15 bits	SCROLL_		UPDATE	move.32		{A6}+oPtDBOX, D5	move.16		#2**bDbGcLabel+2, D2	DBOX_		GetCo	Lib		?SetCurs, ?AfTim	.ascize		"Il reste "	move.16		#10, D3	move.16		#2**bAfDcM, D2	move.32		D0, D4	Lib		?AfDec, ?Aftim	.ascize		" blocs  copier ....   "	popm.32		D2..D5	RetIncScrollBad:	pushm.32	D2..D5	inc.16		{A6}+oBadCopie	move.32		{A6}+oPtDBOX, D5	move.16		#2**bDbGcLabel+3, D2	DBOX_		GetCo	Lib		?SetCurs	call		AffBad	popm.32		D2..D5	RetAffBad:	Lib		?AfTim	.ascize		"Trouv "	move.16		#10, D3	move.16		#2**bAfDcM, D2	clr.32		D4	move.16		{A6}+oBadCopie, D4	Lib		?AfDec, ?Aftim	.ascize		" bloc"	move.8		#0, D3	comp.16		#1, D4	jump,eq		r8^a$	move.8		#"s", D3a$:	Lib		?AfCar, ?AfTim	.ascize		" illisible"	Lib		?AfCar, ?AfSpace	RetBox:	.16		Box$-Box	.16		0,0,0Box$:	.8		oDBTEXT	.asciz		"    Copie du disque bloc  bloc "	.8		oDBCR	.8		oDBLABEL, 1	.8		oDBTEXT	.asciz		"                                   "	.8		oDBCR, oDBCR, oDBCR	.8		oDBLABEL, 2	.8		oDBTEXT, 0	.8		oDBCR	.8		oDBLABEL, 3	.8		oDBTEXT, 0	.8		0	.evenDOFILTRE:	move.32		#{A6}+ObuBLK, A4	move.32		#LgBlk-1, D4lp$:	move.8		{A4}, D3	tclr.32		D3:#7				; supprime tous code >127	comp.8		#16'7F, D3	jump,eq		r8^sp$	comp.8		#10'12, D3	jump,hs		r8^ok$sp$:	move.8		#SPACE, D3			; et infrieurs  12ok$:	move.8		D3, {A4+}	dj.16,nmo	D4, lp$DOWRFILE:	move.16		{A6}+OchFILE, D6	jump,eq		ERK	move.32		#{A6}+ObuBLK, A4	move.32		#LgBlk, D4	FOS		?WRBYTE	jump		LoopDOCALHACHx:;========	move.32		#-1, D3DOCALHACH:;========	move.32		D3, D5	comp.16		#TYPBL, {A6}+oTypBlk	jump,ne		ERK	move.32		{a6}+ObuNO, d4	move.16		#0, d5	call		tstBLOCS			; D1.32 possition	jump,ne		ERK	move.32		#{A6}+oBuBlk, A4	comp.32		#-1, {A4}+OBLPREV	jump,ne		ERK	CALL		AFQUES	LIB		?AFTIM	.ascize		"Valeurs de hachage possibles : "	CALL		AFERROR	move.32		#{A6}+oBufHACH, A0	move.32		#MaxHACH/8-1, D0c$:	move.8		#16'FF, {A0}+32^{D0}		; tous possible	dj.16,nmo	d0, c$s$:	move.32		#{A6}+oBufHACH, A0	move.16		#4-1, D0l$:	move.32		A4, A3	test.8		{A3}	jump,ne		r8^h$	inc.32		A3	test.8		{A3}	jump,eq		r8^n$h$:	CLR.32		D2				; D2 <-- mz somme des cars	move.16		#16-1, D5L10$:	DEC.16		D5	jump,cs		L50$	MOVE.8		{A3+},D3	JUMP,EQ		L50$				; fini => 50$;	LIB		?MINMAJ				; D3 <-- lettre majuscule	AND.32		#16'FF,D3	ADD.32		D3,D2				; D1 <-- somme des caractres	JUMP		L10$L50$:	move.16		#1, D4L60$:	move.32		D2, D3	DIV.16		D4, D3	SWAP.32		D3	COMP.16		D1, D3				; bonne valeur ?	jump,eq		r8^av$	move.32		D4, D3	sr.32		#3, D3	tclr.8		{A0}+32^{D3}:D4			; suprime cette posibilitav$:	inc.16		D4	comp.16		#MaxHACH, D4			; explore toute les possibilits !!	jump,lo		L60$n$:	add.32		#LgBL, A4	dj.16,nmo	D0, l$	test.32		D5:#31	jump,bc		r8^r$	move.32		{a6}+ObuNO, d4	inc.32		d4	move.16		#0, d5	call		tstBLOCS			; D1.32 possition	jump,ne		r8^r$	comp.8		#TYPBL, D2	jump,ne		r8^r$	call		LitBU	move.32		#{A6}+oBuBlk, A4	comp.32		#-1, {A4}+OBLPREV	jump,eq		s$r$:	move.32		#{A6}+oBufHACH, A0	move.16		#1, D4laf$:	move.32		D4, D3	sr.32		#3, D3	test.8		{A0}+32^{D3}:D4	jump,bc		r8^no$	Lib		?AFX4, ?AFSPACE			; oui -> l'afficheno$:	inc.32		D4	comp.16		#MaxHACH, D4	jump,lo		laf$	move.16		#100, D4	Ntrel		?ModTim	Lib		?GetCar	Ntrel		?SetTim	move.32		{A6}+oBuNO, d4	test.32		D5:#31	jump,bs		DOBAFF	jump		LOOPDOHACHE0:	clr.16		D3DOHACHE:;=======	move.16		D3, D0	CALL		AFQUES	LIB		?AFTIM	.ASCIZE		"Nom de fichier :"	MOVE.32		#{A6}+OBUNAM,A3	test.8		{A6}+OFLAG3:#BEXMACRO		; macro en cours	jump,bs		r8^M1$	move.32		#{A6}+oBufHach, A2		; tampon pour UNDO	move.32		#r16^TableKeyFile, A1	move.16		#LgName-1, D1	clr.8		{A3}+A16^{D1}	move.16		#AFDIR, D3	call		EditText	call		attentionM1$:	CALL		AFERROR; AFQUES	LIB		?AFTIM	.ASCIZE		"Fonction de hachage :"	MOVE.32		{A6}+OBUNO,D4			; A0^BD du directoire o on est	push.16		d0	CALL		BL?	popm.a16	d0	JUMP,EQ		BL$	COMP.16		#TYPBD,{A6}+OTYPBLK	JUMP,NE		GET$	MOVE.32		#{A6}+OBUBLK,A0BL$:	CLR.32		D4	MOVE.16		{A0}+OBDHAC,D4	MOVE.16		#AFINV,D3	LIB		?AFCAR,?AFSPACE,?AFX4,?AFTIM	.ASCIZE		" <AFDIR> "	LIB		?GETCURS	set.8		D1	test.16		d0	jump,eq		H$	test.8		{A6}+OFLAG3:#BEXMACRO		; macro en cours	jump,bs		M2$Get$:	CALL		AFQUES	LIB		?AFTIM	.ascize		"Donner la fonction de hachage  utiliser (1..n) : <CURS>"	LIB		?GETHEX	test.16		d4	jump,eq		LOOP	CALL		AFERROR; AFQUES	LIB		?AFTIM	.ASCIZE		"Fonction de hachage :"	MOVE.16		#AFINV,D3	LIB		?AFCAR,?AFSPACE,?AFX4,?AFTIM	.ASCIZE		" <AFDIR> "	LIB		?GETCURS	clr.8		D1	jump		H$M2$:	move.16		{a0}+OBDHAC,D4H$:	CALL		HACHE;--	CALL		AFERROR	LIB		?SETCURS	LIB		?AFTIM	.ASCIZ		" Valeur de hachage ="	.EVEN	LIB		?AFX4	TEST.8		D1	JUMP,EQ		LOOP	call		nxDEEP	JUMP		DOBAFFDOEDIT:;======	TCLR.8		{a6}+oflags:#BMENUP	MOVE.32		#R16^MENU_EDIT,A3	LIB		?AFMENU				; affiche un autre menu	CALL		AFERROR	LIB		?AFTIM	.ASCIZ		"Mode dition de bloc, (END) termine"	.EVEN	move.32		#{A6}+OBUBLK, A4	CALL		EDITBLK;	JUMP		LOOP	jump		r8^DOWRITEDOWRITE0:	Tset.8		{A6}+OFLAG3:#BMAJDOWRITE:;=======	MOVE.32		{A6}+OBUNO,D4DOW:L10$:	CALL		AFQUES	LIB		?AFTIM	.ASCIZ		"Mise  jour du bloc"	.EVEN	call		AFnumero	Tclr.8		{A6}+OFLAG3:#BMAJ	jump,bs		L50$	TCLR.8		{a6}+oflags:#BMENUP	LIB		?YESNO	JUMP,NE		LOOP				; non => LOOPL50$:	CALL		WRBLK				; crit un bloc	JUMP,EQ		MARQ$	push.16		D7	CALL		AFERROR	pop.16		D7	LIB		?AFERROR	TEST.8		{A6}+OFLAGS:#BFLO	JUMP,BC		MARQ$	LIB		?AFTIM	.ASCIZE		", floppy : on ressaye sans les vrifications"	MOVE.32		#R16^CNOVERIF,A4		; si floppy, on essaye d'crire quand mme	MOVE.16		#TYPMM,D3	MOVE.16		{A6}+OCANAL,D6	FOS		?COMMAND	CALL		WRBLK	MOVE.32		#R16^CVERIF,A4	FOS		?COMMANDMARQ$:	Push.32		{A6}+OBUNO	call		useFREE				; force le rcup  l'enter	Pop.32		D4	JUMP		r8^DOBAFFDOWRITEx:;=======	MOVE.32		{A6}+OBUNO,D4	CALL		AFQUES	LIB		?AFTIM	.ASCIZ		"Numro du bloc  crire :"	.EVEN	call		GEThexa	Tclr.8		{A6}+OFLAG3:#BMAJ	COMP.16		#CR,D3	JUMP,EQ		DOW	JUMP		LOOPuDOBAFF:	call		unLOCKDOBAFF:;======	PUSH.32		D4	MOVE.32		#4*YY+0*XX,D4	CALL		SETCURS	move.16		#0, d4	lib		?waitMOUSE	POP.32		D4	clr.32		{A6}+Orewind	clr.32		{A6}+Orewind2	clr.8		{a6}+OFMENU	clr.16		d2	move.8		d2, {A6}+OtypFIL	clr.16		d5	call		tstBLOCS		; recherche le bloc	jump,ne		L0$	move.8		D2, {a6}+OtypFIL	AND.16		#16'F, D2		; ne garde que le type	MOVE.32		D0, {A6}+Orewind	MOVE.32		D1, {A6}+OPOSFILL0$:	LIB		?AFTIM	.ASCIZE		"Bloc "	comp.32		{A6}+OBLKFIN, d4	jump,lo		r8^in$	lib		?AFTIM	.ascize		"hors de la mmoire de masse"	jump		L06$in$:	CALL		FREE?;	JUMP,NE		ER	JUMP,bS		L5$	LIB		?AFTIM	.ASCIZE		"libre"	JUMP		AFFTYP$L5$:	COMP.32		{A6}+ODEBPART,D4	JUMP,HI		L9$	JUMP,LO		L05$	LIB		?AFTIM	.ASCIZE		"identificateur du disque"	JUMP		L06$L05$:	PUSH.32		D4				; FOSBOOT ?	ADD.32		#16,D4	COMP.32		{A6}+ODEBPART,D4	POPM.32		D4	JUMP,LO		L6$	LIB		?AFTIM	.ASCIZE		"du FOSBOOT"	JUMP		L06$L6$:	COMP.32		#0,D4	JUMP,NE		L7$	LIB		?AFTIM	.ASCIZE		"rpertoire des partitions"	JUMP		L06$L7$:	COMP.32		#4,D4	JUMP,HS		L8$	COMP.32		#3,D4	JUMP,LO		L07$	LIB		?AFTIM	.ASCIZE		"d'information sur le winch"L06$:	MOVE.16		#TYPDATA,d2	JUMP		L20$L07$:	LIB		?AFTIM	.ASCIZE		"de rserve hors partition"	JUMP		L06$L8$:	LIB		?AFTIM	.ASCIZE		"du SELPART"	JUMP		L06$L9$:	PUSH.32		D4	DEC.32		D4	COMP.32		{A6}+ODEBPART,D4	POPM.32		D4	JUMP,HI		L09$	LIB		?AFTIM	.ASCIZE		"de description du rpertoire premier"	MOVE.16		#TYPBD,d2	JUMP		L20$L09$:	COMP.32		{A6}+OFINPART,D4	JUMP,LS		L11$	LIB		?AFTIM	.ASCIZE		"hors de la partition PSOS"	JUMP		L06$L11$:	COMP.16		#TYPBD,D2	JUMP,EQ		R8^BD$	COMP.16		#TYPBL,D2	JUMP,EQ		R8^BL$	COMP.16		#TYPDATA, D2	JUMP,EQ		R8^DATA$	LIB		?AFTIM	.ASCIZE		"inconnu"AFFTYP$:	move.16		#TYPDATA, d2	CALL		LITBU	jump,ne		L20$	MOVE.32		{A6}+OCHECK, D0			; affichage selon position du CHK	JUMP,EQ		L20$	MOVE.16		#TYPBL, d2	call		tstBL	JUMP,EQ		L20$	MOVE.16		#TYPBD, d2	call		tstBD	JUMP,EQ		L20$	MOVE.16		#TYPDATA, d2	JUMP		L20$DATA$:	LIB		?AFTIM	.ASCIZ		"de donne"	.EVEN	JUMP		L20$BD$:	LIB		?AFTIM	.ASCIZ		"de description"	.EVEN	JUMP		L20$BL$:	LIB		?AFTIM	.ASCIZ		"de liste"	.EVENL20$:	TCLR.8		{A6}+OFLAGS:#BIMP	jump,bs		r8^af$	move.16		d2, {a6}+OTYPBLKaf$:	call		AFnumero	call		AFFfile	CALL		DOEFLI	CALL		litBU	JUMP,NE		L55$L30$:	call		iniMENU	CALL		AFBLK	move.32		{a6}+ObuNO, D4	call		exploVITE?			; explore en vitesse la descendance de ce bloc	call		affDOUBLE			; affiche si bloc occup ailleurs	move.16		#1, d4	lib		?waitMOUSE	JUMP		LOOPL55$:	MOVE.16		D7,D4	CALL		AFERROR	MOVE.8		#BIPERR,D3	LIB		?BEEP				; ?AFTIM							; .ASCIZE	/Erreur de lecture numro /							; LIB	?AFX4	MOVE.16		D4,D7	LIB		?AFERROR	TEST.8		{A6}+OFLAGS:#BFLO	JUMP,BC		L30$	MOVE.32		#R16^CNOVERIF,A4		; si floppy, on essaye de lire quand mme	MOVE.16		#TYPMM,D3	MOVE.16		{A6}+OCANAL,D6	FOS		?COMMAND	lib		?AFTIM	.ascize		", essaye de lire sans vrification."	MOVE.32		#1,D5	MOVE.32		{A6}+OBUNO,D4	MOVE.32		#{A6}+OBUBLK,A4	CALL		RDBLK	PUSH.32		A4	MOVE.32		#R16^CVERIF,A4	FOS		?COMMAND	POP.32		A4	JUMP		L30$CNOVERIF:	.ASCIZ		"N"CVERIF:	.ASCIZE		"V"EXPLOONOFF:	tnot.8		{a6}+OFLAG2:#B2PAUSE	jump,bs		on$	call		LOCK	move.32		{A6}+OpMESS, {A6}+PpMESS	move.32		#r16^Poff, a0	move.32		a0, {a6}+OpMESS	jump		loopon$:	move.32		{a6}+PpMESS, {a6}+OpMESS	tset.8		{A6}+Oflag3:#B3test	call		unLOCK	jump		loopuER:	call		unLOCKerFAT:ER:;==	PUSH.16		D7	MOVE.8		#BIPFAT,D3	LIB		?BEEP,?AFTIM	.8		NOCURS,CR,CR,AFINV,0	.EVEN	POP.16		D7	LIB		?AFERROR			; affiche l'erreur	MOVE.8		#AFDIR,D3	LIB		?AFCAR,?GETCAR			; attend une touche ...	jump		quitDOEND:;=====	TCLR.8		{a6}+oflags:#BMENUP	call		AFQUES	lib		?AFTIM	.ascize		"Quitte le programme ? "	TCLR.8		{a6}+oflags:#BMENUP	lib		?yesno	jump,ne		LOOPquit:	call		unLOCK	TSET.8		{A6}+OFLAGS:#BABORT	NTREL		?WFABDESC	CALL		CLOMM				; ferme unit physique	MOVE.16		{A6}+OCANUTILE,D1	LIB_		CLOSE	MOVE.16		{a6}+OcanDBOX, D1	LIB_		CLOSE	move.32		{a6}+OSEMA,A5	ntrel		?killSEM	MOVE.16		#MTYPCP,D1	TEST.8		{A6}+OFLAGS:#BFREE	JUMP,BC		L0$	MOVE.32		{A6}+OFREE,A4	GESMEM		?GIVMEML0$:	MOVE.32		{A6}+ONREP,A4	GESMEM		?GIVMEM	MOVE.32		{A6}+OBlocKO,A4	GESMEM		?GIVMEM	MOVE.32		{A6}+OBLOCbad,A4	GESMEM		?GIVMEM	MOVE.32		{A6}+OBlocDBL,A4	GESMEM		?GIVMEM	move.32		{a6}+ObuBASE, A4lp$:	comp.32		#0, A4	jump,eq		done$	move.32		{a4}+ObufNEXT, A0	GESMEM		?GIVMEM	move.32		a0, a4	jump		lp$done$:	LIB		?CLOLIB	FOS		?STOPFATERR:;======	LIB		?AFTIM	.ASCII		"<CR><CR>Erreur fatale<CR>"	.ASCIZ		"Pas assez de place pour les variables<CR><CR>"	.EVEN	JUMP		DOEND	.CHAP		EXPLORE				;----------------------------------------------------------------				; Cration d'un buffer contenant les noms des rpertoires				; et d'un buffer contennant les BD des rpertoires.				; On cre aussi un buffer contenant les numros de tous les BD.				; (on considre qu'un seul BD existe par rpertoire)				;=---------------------------------------------------------------TEXPL:	.ASCIZE		"Explore"PEXPL:refait$:	call		LOCK	Tclr.8		{A6}+OFLAGS:#BEXPLOK		; signale pas fini	move.32		#r16^Prun, a0	move.32		a0, {A6}+OpMESS	call		AFMENUP?	call		unLOCK	CALL		EXPLO	JUMP,NE		EREXPL	TSET.8		{A6}+OFLAGS:#BEXPLOK		; signale fini	TSET.8		{A6}+OFLAG3:#B3okRecup	test.8		{A6}+OFLAG3:#B3noRECUP	jump,bs		r8^noR$	tset.8		{A6}+oFMENU:#BMRecup		; rcup possiblenoR$:	MOVE.32		#BIPEND,D3			; ok	LIB		?BEEP	move.32		#r16^Pend, a0	move.32		a0, {A6}+OpMESS	call		AFMENUP?wait$:	test.8		{A6}+OFLAGS:#BABORT	jump,bs		EREXPL	test.8		{A6}+Oflags:#Btest	jump,bs		r8^tstdone$	test.8		{A6}+oFlag4:#B4RamDyn	jump,bs		r8^tstdone$	test.8		{A6}+Oflag3:#B3test;	jump,bc		r8^tstdone$	call		tstDISKtstdone$:	move.16		#200, d4	ntrel		?DELMS	test.32		{A6}+OnumBLOC	jump,eq		wait$	jump		refait$EREXPL:	NTREL		?ABORT;=explo:	pushm.32	a0|a1|a4|d0..d5explo$:	move.32		{a6}+ObuBASE, A1nxtBUF$:	comp.32		#0, A1	jump,eq		fin$	move.32		#{a1}+ObufBLK, A0lp$:	test.32		{a0}+OtbBASE	jump,ns		fin1$	call		LOCK	MOVE.32		{a0}+OtbBASE, D4	MOVE.32		{a0}+OTBPREV, D0	move.32		{a0}+OTBOFF, D1	MOVE.8		{a0}+OTBLONG, D5	move.8		{a0}+OTBTYP, d3	tclr.8		{A0}+OTBTYP:#BTYPEXPL		; dj vu?	call		unLOCK	jump,bc		nxt$	move.32		#{a6}+ObuEXPL, A4	call		explo1BLK			; explore le blocnxt$:	TEST.8		{A6}+OFLAGS:#BABORT	jump,bs		abort$	add.32		#lgTB, A0	jump		lp$fin1$:	move.32		{A1}+ObufNEXT, A1	jump		nxtBUF$fin$:	test.32		{a6}+OnumBLOC			; encore un BLOC  traiter?	jump,ne		explo$abort$:	popm.32		a0|a1|a4|d0..d5	retexploVITEBD:; in	D4.32		no d'un BD	pushm.32	A0|A1|D0..D5|a4	test.8		{a6}+OFLAG2:#B2FULL	jump,bs		nop$	call		locksuit$:	call		exploVITE;suit$:	call		litBD				; prend le BD en mmoire	jump,ne		koBD$	call		tstBD				; ressemble  un BD?	JUMP,NE		koBD$bon$:	move.16		{A4}+OBDNPT, d3			; parcourt les tranches	jump,eq		fin$	move.32		#{A4}+OBDPTS, A0	move.32		#{A4}+OBDNBS, A1		; ^trancheslp$:	move.32		{a0+}, D4			; dbut tranche	add.32		{a6}+OdebPART, d4	call		exploVITE			; regarde son contenu	dec.16		d3				; boucle	jump,ne		lp$	move.32		{a4}+OBDNEXT, D4	jump,eq		r8^fin$	add.32		{a6}+OdebPART, D4	jump		suit$koBD$:;	call		stoBLOCkofin$:	call		unLOCKnop$:	popm.32		A0|A1|D0..D5|a4	RETexploVITEBL:; in	D4.32		no d'un BD	pushm.32	A0|A1|D0..D5|a4	test.8		{a6}+OFLAG2:#B2FULL	jump,bs		nop$	call		lock	call		exploVITE	call		litBL				; prend le BL en mmoire	jump,ne		koBL$	call		tstBL				; ressemble  un BL?	JUMP,NE		koBL$	move.32		#2**31, D1	pushm.32	a4|D4	move.16		#4, D3			; parcourt les 4 fichiersnxtFIL$:	test.8		{a4}			; fichier prsent?	jump,eq		noFIL$			; non -> saute	move.32		{a4}+OBLPT, D4	call		tstSYSLIST		; ignore les SYS_LIST	jump,nc		r8^noFIL$	add.32		{a6}+OdebPART, d4	call		exploVITE		; regarde si connunoFIL$:	add.32		#lgBL, A4		; ^place suivante	add.32		#lgBL, D1		; offset dans le BL!	dec.16		d3			; boucle	jump,ne		nxtFIL$	popm.32		a4|d4;	jump		r8^fin$koBL$:;	call		stoBlocKOfin$:	call		unLOCKnop$:	popm.32		A0|A1|D0..D5|a4	RETexploVITE?:	move.8		{a6}+OtypFIL, d0	and.16		#16'F, d0	comp.16		#TYPBD, d0	jump,eq		exploVITEBD	comp.16		#TYPBL, d0	jump,eq		exploVITEBLexploVITE:; in D4.32	no du bloc en absolu	pushm.32	a0|a1|a4|d0..d5	test.8		{a6}+OFLAG2:#B2FULL	jump,bs		r8^nop$	call		LOCK	clr.16		d5	call		tstBLOCS			; trouve bloc	jump,ne		fin$	tclr.8		{a0}+OtbTYP:#BTYPEXPL		; dj fait?	jump,bc		fin$	move.32		{a0}+OtbBASE, d4		; reprend en dbut de tranche	MOVE.32		{a0}+OTBPREV, D0	move.32		{a0}+OTBOFF, D1	MOVE.8		{a0}+OTBLONG, D5	move.8		{a0}+OTBTYP, d3	move.32		#{a6}+ObuEXPL2, A4	tset.32		d5:#31	call		explo1BLK			; explore ce blocfin$:	call		unLOCKnop$:	popm.32		a0|a1|a4|d0..d5	retexplo1BLK:; in	A4.32		buffer;	D4.32		no;	d0.32		prev;	d1.32		off;	d3.16		type	tclr.32		d3:#BTYPEXPL			; enlve le fanion "pas fait"	dec.32		{a6}+OnumBLOC			; une exploration en moins	move.8		#TYPDATA, D2			; explore les data	comp.8		#TYPBD, d3			; si c'est un BD	jump,eq		doBD$	comp.8		#TYPBD.or.TYPFREE, d3	jump,eq		doBD$	move.8		#TYPBL.or.TYPEXPL, D2		; explore les data=BL	comp.8		#TYPBDL, d3			; si c'est un BDlist	jump,eq		doBD$	comp.8		#TYPBL, d3			; sait aussi explorer les BL	jump,ne		nxt$doBL$:	call		exploBL	jump		nxt$doBD$:	call		exploBDnxt$:	retexploBD:; explore un BD pour ajouter les blocs ^dans la table; in	D4.32		no du BD;	D3.8		type du BD;	D2.8		type de donnes (TYPDATA ou TYPBL);	D1.32		SPOS dbut (ou offset dans BL.or.2**31);	A4.32		buffer	pushm.32	A0|A1|D0..D5	move.32		d4, d0				; base pour les blocs rfrencs	call		RD1BLK				; lit le BD	jump,ne		KOBD$	call		tstBDd3				; ressemble  un BD?	JUMP,NE		KOBD$	test.32		d3:#BTYPFREE			; BD de SYS_FREE?	jump,bc		r8^noF$	call		ldFREE				; charge sys_freenoF$:	test.32		D1:#31				; offset dans le BL?	jump,bc		r8^bon$	move.32		#0, D1				; oui -> repart  0bon$:	move.16		{A4}+OBDNPT, d3			; parcourt les tranches	jump,eq		fin2$	move.32		#{A4}+OBDPTS, A0	move.32		#{A4}+OBDNBS, A1		; ^trancheslp$:	move.32		{a0+}, D4	jump,eq		nop$	move.8		{a1+}, D5			; long	jump,eq		nop$bis$:	call		putBLOCS			; ajoute une tranche	test.8		{a6}+OFLAGS:#BABORT	jump,bs		fin2$	call		tstERR	jump,ns		bis$	add.8		D5, D1				; calcule SPOS tranche suivante	jump,cc		nop$	add.32		#16'100, D1			; reporte le carrynop$:	dec.16		d3				; boucle	jump,ne		lp$	move.32		{a4}+OBDNEXT, D4bis2$:	comp.8		#TYPDATA, D2			; pour data ou pour list?	jump,eq		pDATA$	call		putBDL	jump		r8^fin$pDATA$:	call		putBD				; ajoute le BD next si existe!	JUMP		r8^fin$koBD$:	call		stoBlocKOfin$:	call		tstERR	jump,ns		bis2$fin2$:	popm.32		A0|A1|D0..D5	RETexploBL:; explore un BL pour ajouter les blocs de description dans la table; in	D4.32		no du BL;	D5.8		nombre de BL conscutifs	pushm.32	D0..D5nxtBL$:	move.32		D4, D0	call		rd1BLK				; lit le BL -> A4.32	jump,ne		koBL$	call		tstBL	jump,ne		koBL$	move.32		#2**31, D1	pushm.32	a4|D4	move.16		#4, D3			; parcourt les 4 fichiersnxtFIL$:	test.8		{a4}			; fichier prsent?	jump,eq		noFIL$			; non -> saute	move.32		{a4}+OBLPT, D4	call		tstSYSLIST		; ignore les SYS_LIST	jump,nc		r8^noFIL$	call		tstSYSFREE	jump,ns		noFREE$	pushm.32	d2|d5	move.32		d0, {A6}+OnoSYSFREE	move.16		#TYPBD.or.TYPEXPL.or.TYPFREE, d2	move.32		#1, d5	call		putBLOCS	popm.32		d2|d5	jump		r8^noFIL$noFREE$:	call		tstDIR			; dtermine le type BD ou DBL si *.DIR + att P	jump,nc		putDIR$bis$:	call		putBD			; ajoute le BD non explor dans la liste	call		tstERR	jump,ns		bis$	jump		r8^noFIL$putDIR$:	call		putBDL			; ajoute un BD de liste	call		tstERR	jump,ns		putDIR$	call		consNDIR		; construit la table d'accs aux dirsnoFIL$:	add.32		#lgBL, A4		; ^place suivante	add.32		#lgBL, D1		; offset dans le BL!	dec.16		d3			; boucle	jump,ne		nxtFIL$	popm.32		a4|d4nB$:	test.8		{a6}+OFLAGS:#BABORT	jump,bs		r8^fin$	inc.32		D4	dec.8		D5	jump,ne		nxtBL$	jump		r8^fin$koBL$:	call		stoBlocKO	jump		nB$fin$:	popm.32		D0..D5	RETtstSYSLIST:	pushm.32	a2|a3	move.32		#r16^nSYS_LIST, A3	jump		tstFILEtstSYSFREE:	pushm.32	a2|a3	move.32		#r16^nSYS_FREE, A3	jump		tstFILEtstDIR:	pushm.32	a2|a3	move.32		#r16^NDIR, A3tstFILE:	move.32		#r16^lsep, A2	lib		?cpSTRING	popm.32		A2|A3	retlsep:	.8		0, -1	.evennSYS_LIST:	.ASCIZ		"SYS_LIST"nSYS_FREE:	.ASCIZ		"SYS_FREE"nDIR:	.ASCIZE		"*.DIR"; ajoute une tranche de bloc dans la listeputBLOCS:; in	D4.32		no premier bloc (en relatif dans la partition);	D5.8		nombre de blocs;	D0.32		no bloc de rfrence;	D1.32		position de rfrence;	D2.8		Type de blocs; out	D7.16		1 = existe dj	call		LOCK	call		r8^pb$	call		unLOCK	retpb$:	pushm.32	a0|a1|a2|d3..D5	test.32		d4				; pas de bloc zro !	jump,eq		L90$	add.32		{a6}+ODEBPART, D4		; en absolu!	pushm.32	d0..d5	move.32		d0, d3	clr.16		d5	call		tstBLOCS			; existe dj ?	jump,ne		new$	move.16		#1, d7	comp.32		d0, d3				; mme prev?new$:	popm.32		d0..d5	jump,eq		L90$				; oui, c'est fait	move.32		#{a6}+ObuBASE, a0nxtBUF$:	move.32		{a0},a1				; ^table des blocs	comp.32		#0, a1	jump,ne		bon$	call		newBUF				; demande un nouveau buffer	jump,ne		L90$	move.32		a0, a1				; fait avec nouveau buff.bon$:	move.32		#{a1}+ObufBLK, A0	move.16		{a1}+ObufLG,d3	mul.16		#lgTB,d3	add.32		d3,a0				; fin de la liste	comp.32		{a1}+ObufMAX, a0	jump,lo		r8^plac$	move.32		#{a1}+ObufNEXT, A0		; ^tranche suivante	jump		nxtBUF$plac$:	move.32		a0,a2				; garde ^fin	move.32		#-1,d3				; calcule la lg  dplacer -1search$:	add.32		#lgTB/4,d3	sub.32		#lgTB,a0	comp.32		{a0}+OTBBASE,d4			; recherche la bonne place	jump,lo		search$	add.32		#lgTB,a0			; replace sur le plus grand	push.32		a0	move.32		#{a2}+lgTB,a0			; dplacement buffercopy$:	move.32		{-a2},{-a0}			; de bas en haut	dj.16,nmo	d3,copy$	pop.32		a0				; ^sur le trou	inc.16		{a1}+ObufLG			; agrandi	jump,eq		L90$	test.32		d2:#BTYPEXPL			; mode avec recherche?	jump,bc		r8^okB$				; non -> ok	inc.32		{a6}+OnumBLOC			; un BLOC  faireokB$:	move.32		D4,{a0}+OTBBASE			; initialis avec nouvelles donnes	move.8		D5,{a0}+OTBLONG	move.8		D2, {a0}+OtbTYP	move.32		D0,{A0}+OTBPREV	move.32		D1,{a0}+OTBOFF	call		FillMAP				; rempli le SYS_FREE mmoire	test.8		{a6}+OFLAGS:#BMENUP		; menu principal	jump,bc		r8^NOS$	MOVE.32		{A6}+OBUNO, D3	COMP.32		D3, D4	JUMP,HI		R8^NOS$	AND.32		#16'FF, D5	ADD.32		D4, D5	COMP.32		D3, D5	JUMP,LS		R8^NOS$	MOVE.32		#SHIFT+F2, D3	LIB		?WRKEY			; RafficheNOS$:	CLR.16		D7L90$:	test.16		D7	popm.32		a0|a1|a2|d3..D5	ret; recherche un bloc dans la liste; in	D4.32		no du bloc en absolu;	D5.16		no d'ordre ( pour recherche des doubles )( 0 pour normal ); out	NE		pas trouv;	D0.32		prev;	D1.32		SPOS;	D2.8		Type;	A0.32		^dans la tabletstBLOCS:	call		LOCK	call		r8^tb$	call		UNLOCK	rettb$:	pushm.32	a1|d3|d5	move.16		#1, d7	move.32		{a6}+ObuBASE, A1nxtBUF$:	comp.32		#0, A1	jump,eq		fin$	move.32		#{A1}+ObufBLK,a0		; ^table des blocs	move.16		{a1}+ObufLG,d0			; longueur de cette table                                                                                 ; recherche par bisectionnxt$:	comp.16		#1, D0	jump,eq		ok$				; fin de la bisection ?	move.16		d0,d3	inc.16		d0				; arrondi suprieur	sr.16		d0				; milieu de la table	jump,eq		ok$	move.16		d0,d2	mul.16		#lgTB,d2			; offset lment	comp.32		{a0}+32^{d2}+OTBBASE-lgTB,d4	; plus haut/plus bas?	jump,lo		nxt$	move.32		#{a0}+32^{d2},a0		; nouvelle base de recherche	sub.16		d0,d3				; lg tranche restante	move.16		d3,d0	jump		nxt$ok$:; remonte dans la table  la recherche des blocs possibles	sub.32		#lgTB,a0	test.32		{a0}+OTBBASE			; premier lment de la table ?	jump,eq		fin1$				; alors fini	move.32		d4,d0	sub.32		{a0}+OTBBASE,d0	comp.32		#16'100,d0			; ne peut jamais dpasser H'100	jump,hs		fin1$	comp.8		{A0}+OTBLONG,d0			; bloc dans la tranche ?	jump,hs		ok$				; non -> cherche le suivant	dec.16		d5				; recherche celui-ci?	jump,cc		ok$	move.32		d0, d1	move.32		{a0}+OTBPREV,D0	move.8		{a0}+OTBTYP,D2	add.32		{a0}+OTBOFF,d1			; positionnement	clr.16		d7	jump		fin$				; fin1$:	move.32		{a1}+ObufNEXT, a1	jump		nxtBUF$fin$:	test.16		d7	popm.32		a1|d5|d3	retputBD:	pushm.32	d2|d5	move.32		#1,d5				; bloc seul	move.8		#TYPBD.or.TYPEXPL,d2		; Bloc de Description pas explor	call		putBLOCS			; met en place ce bloc	popm.32		d2|d5	retputBDl:	pushm.32	d2|d5	move.32		#1,d5				; bloc seul	move.32		#TYPBDL.or.TYPEXPL,d2		; Bloc de Description pour .DIR pas explor	call		putBLOCS			; met en place ce bloc	popm.32		d2|d5	retlitBU:	move.16		{a6}+ObuERR, d7	move.32		#{A6}+ObuBLK, A4	comp.32		{A6}+ObuNo, D4	jump,eq		r8^done$	move.16		#LGBLK/4-1,d7clr$:	move.32		#0, {a4+}	dj.16,nmo	d7,clr$	move.32		#{a6}+ObuBLK,a4	call		RD1BLK	move.32		D4, {a6}+ObuNO	move.16		D7, {a6}+ObuERRdone$:	test.16		D7	retlitBU2:	clr.16		d7	move.32		#{A6}+ObdBLK, A4	call		RD1BLK	test.16		D7	retlitBD:	pushm.32	d2|d5	clr.16		d7	move.32		#{A6}+ObdBLK, A4	comp.32		{a6}+ObdNO, D4	jump,eq		r8^done$	comp.32		{a6}+ObuNO, D4	jump,ne		r8^lit$	pushm.32	a0|d0|a4	move.32		#{A6}+ObuBLK, A0	move.16		#LGBLK/4-1, D0cp$:	move.32		{A0+}, {A4+}	dj.16,nmo	d0, cp$	popm.32		a0|d0|a4	jump		lu$lit$:	CLR.32		{A6}+OBDNO	call		RD1BLK	jump,ne		r8^done$lu$:	move.32		D4, {a6}+ObdNOdone$:	test.16		d7	popm.32		D2|D5	retlitBL:	pushm.32	d2|d5	clr.16		d7	move.32		#{A6}+OblBLK, A4	comp.32		{a6}+OblNO, D4	jump,eq		r8^done$	comp.32		{a6}+ObuNO, D4	jump,ne		r8^lit$	pushm.32	a0|d0|a4	move.32		#{A6}+ObuBLK, A0	move.16		#LGBLK/4-1, D0cp$:	move.32		{A0+}, {A4+}	dj.16,nmo	d0, cp$	popm.32		a0|d0|a4	jump		lu$lit$:	CLR.32		{A6}+OblNO	call		RD1BLK	jump,ne		r8^done$lu$:	move.32		D4, {a6}+OblNOdone$:	test.16		d7	popm.32		D2|D5	retnewBUF:; in	A0.32		^pour ^buf; out	A0.32		^new buf	pushm.32	a1|a4|d1..d5	move.32		#8, D3				; demande 8/16 mmoire si possible	move.32		#16'4000, D4			; mais au moins 16k	move.32		#16'20000, D5			; car DJ.16 avec MOVE.32					; une valeur trop grande ralenti trop les insertions	MOVE.16		#MTYPoP,D1			; sur le compte processus pre	MOVE.32		{a6}+OptTASK,A1			; d'EDISK	GESMEM		?GETPMEM	jump,ne		er$	tclr.8		{a6}+OFLAG2:#B2FULL	jump,bc		r8^bon$	push.32		a0	move.32		#r16^Prun, a0	move.32		a0, {a6}+OpMESS	pop.32		a0	call		AFMENUP?bon$:	add.32		A4, D4				; position limite	sub.32		#lgTB, D4	move.32		D4, {a4}+ObufMAX	clr.32		{A4}+ObufNEXT	clr.16		{a4}+ObufLG	move.32		A4, {a0}	move.32		a4, a0	move.32		#{a0}+ObufBLK, A4	move.16		#lgTB, d1clr1$:	clr.8		{A4+}				; init un premier lment nul	dec.16		d1	jump,ne		clr1$	inc.16		{a0}+ObufLG			; le compte	move.32		#-1, {a4}			; init dernier lment infini	inc.16		{a0}+ObufLG			; le compte aussi	move.32		#{a0}+ObufBLK, A4		; donne ^dataer$:	test.16		D7	popm.32		a1|a4|d1..d5	retstoBlocKO:	pushm.32	d4|a4|d1|a1	move.32		#4,d4	MOVE.32		{A6}+OBlocKO,A4LG$:	ADD.32		#4,D4	COMP.32		#-1,{A4+}	JUMP,NE		LG$	call		LOCK	MOVE.32		{A6}+OBlocKO,A4			; aggrandi le buffer OBlocKO	MOVE.16		#MTYPoP,D1	MOVE.32		{a6}+OptTASK,A1	CALL		ADDMEM	MOVE.32		A4,{A6}+OBlocKO			; nouveau BlocKO	call		unLOCKMO$:	COMP.32		#-1,{A4+}			; met le nouveau numro de BD dans OBlocKO	JUMP,NE		MO$	MOVE.32		#-1,{A4}	MOVE.32		D0,{A4}-4	inc.16		{a6}+OnBlocKO			; un KO de plus	call		afMENUP?	POPM.32		A4|D4|D1|a1	retstoBlocDBL:	pushm.32	d4|a4|d1|a1|d0	move.32		d4,d0	add.32		{A6}+OdebPART, d0	move.32		#4,d4	MOVE.32		{A6}+OBlocDBL,A4LG$:	ADD.32		#4,D4	COMP.32		#-1,{A4+}	JUMP,NE		LG$	call		LOCK	MOVE.32		{A6}+OBlocDBL,A4		; aggrandi le buffer OBlocDBL	MOVE.16		#MTYPoP,D1	MOVE.32		{a6}+OptTASK,A1	CALL		ADDMEM	MOVE.32		A4,{A6}+OBlocDBL		; nouveau BlocDBL	call		unLOCKMO$:	COMP.32		#-1,{A4+}			; met le nouveau numro de BD dans OBlocDBL	JUMP,NE		MO$	MOVE.32		#-1,{A4}	MOVE.32		D0,{A4}-4	inc.16		{a6}+OnBlocDBL			; un KO de plus	call		afMENUP?	POPM.32		A4|D4|D1|a1|d0	retstoBLOCbad:	pushm.32	d4|a4|d1|a1|d0	move.32		d4, d0	move.32		#4,d4	MOVE.32		{A6}+OBLOCbad,A4LG$:	ADD.32		#4,D4	COMP.32		#-1,{A4+}	JUMP,NE		LG$	call		LOCK	MOVE.32		{A6}+OBLOCbad,A4			; aggrandi le buffer OBLOCbad	MOVE.16		#MTYPoP,D1	MOVE.32		{a6}+OptTASK,A1	CALL		ADDMEM	MOVE.32		A4,{A6}+OBLOCbad			; nouveau BLOCbad	call		unLOCKMO$:	COMP.32		#-1,{A4+}			; met le nouveau numro de BD dans OBLOCbad	JUMP,NE		MO$	MOVE.32		#-1,{A4}	MOVE.32		D0,{A4}-4	inc.16		{a6}+OnBLOCbad			; un KO de plus	call		afMENUP?	POPM.32		A4|D4|D1|a1|d0	retconsNDIR:; in	D4.32		no BD associ;	A4.32		^nom .DIR	pushm.32	D0..D5|A0..A4	move.32		a4, a3				; garde ^nom	move.32		d4, d0				; garde no du BD	move.32		{A6}+OLNREP, D4			; long dj existante	add.32		#LGbuREP, D4			; place pour nom et 2 pointeurs	call		LOCK	MOVE.32		{A6}+ONREP,A2			; ancien buffer ONREP	push.32		a2	MOVE.16		#MTYPoP,D1	MOVE.32		{a6}+OptTASK,A1	GESMEM		?GETMEM	jump,ne		er$	MOVE.32		A4,{A6}+ONREP			; nouveau ^	move.32		D4, {a6}+OLNREP			; nouvelle long.	move.8		#1, d3lp0$:	test.8		d3	jump,eq		trans$	move.32		#{a2}+OrepNAME, a1		; ancien 1er nom	move.32		a3, a0				; nouveaucpn$:	comp.8		{a0+}, {a1+}			; compare les 2 noms	jump,eq		cpn$				; sur plusieures lettres si =	jump,lo		trans$				; garde l'ancien	add.32		{a6}+OdebPART, D0	MOVE.32		D0,{a4}+OrepNEXT		; no BD correspondant;	move.16		#0, {a4}+OrepFLAG	move.32		d0, d4	clr.16		d5	call		tstBLOCS			; D0=Bl	move.32		d0,d4	call		tstBLOCS			; remonte la BL chane -> d0=BDLnbd$:	move.32		d0, d4	call		tstBLOCS			; remonte -> BD(L)	and.16		#16'F, d2	comp.8		#TYPBD, d2	jump,ne		end$	move.32		d4, {a4}+OrepPREV		; garde le ^BD de base	jump		nbd$end$:	move.32		#{A4}+OrepNAME, A4	move.8		#1, d3	move.16		#LGname-1, d1c2$:	comp.8		#".", d3			; rp dj fini?	jump,ne		c33$	move.8		#":", {a4}-1			; remplace	clr.8		d3				; oui, vide la suitec33$:	test.8		d3	jump,eq		c4$	move.8		{a3+}, d3			; copie nouveau nomc4$:	move.8		d3, {a4+}	dj.16,nmo	d1, c2$	move.16		#0, {a4+}trans$:	move.16		#lgBUREP/2-1, d1t1$:	move.16		{A2+}, {a4+}			; transfert l'ancien contenu	dj.16,nmo	d1, t1$	test.32		{a4}-lgbuREP	jump,ne		lp0$	pop.32		a4				; ancien buff	MOVE.16		#MTYPoP,D1	MOVE.32		{a6}+OptTASK,A1	gesmem		?GIVMEMer$:	call		unLOCK	POPM.32		D0..D5|A0..A4	retAFFMMOUS:.IF	0	TEST.8		{A6}+OFLAGS:#BEXPLOK	JUMP,BC		L90$	pushm.32	D4|d3	lib		?GETCURS	MOVE.32		#3*YY+0*XX,D4	CALL		SETCURS	LIB		?AFTIM	.ASCIZE		"Un clic avec la souris donne accs aux rpertoires"	lib		?SETCURS	POPm.32		D4|d3L90$:.ENDIF	RET;----------\\ADDMEM:;----------/; Augmente la longueur d'un buffer.;; IN:	A4^buffer  augmenter;	D4 nouvelle longueur voulue;	D1 type, si MTYPOP A1 identificateur pre; OUT:	A4^nouveau buffer avec ancien transfr au dbut; MOD:	A4, D4 & D7 & F.;=	PUSHM.32	A3	MOVE.32		A4,A3	GESMEM		?GETMEM				; prend le nouveau buffer	JUMP,NE		er$	PUSHM.32	A3..A4|D4			; transfert ancienL10$:	MOVE.8		{A3+},{A4+}	DEC.32		D4	JUMP,NE		L10$	POPM.32		A3..A4|D4	EX.32		A3,A4				; rend ancien buffer	GESMEM		?GIVMEMer$:	EX.32		A3,A4L90$:	POPM.32		A3	RET\g_titre;;-------\; LDFREE >;-------/\g_Fond;; charge sys_free;; IN:	A4.32		^data du BD de SYS_FREE; OUT:; MOD:	D7, F.;=LDFREE:	PUSHM.32	D0..D6|A0..A5	test.8		{A6}+OFLAGS:#BFREE	jump,bs		OUT$	test.8		{A6}+OFLAG4:#B4RamDyn	jump,bs		r8^OK$	move.32		{a6}+OmaxBLK,D6	SR.32		#3,D6				; D6 <-- nb bytes pour bitmap	ADD.32		#10,D6				; D6 <-- ajoute rserve	ADD.32		#LGBLK,D6;	CLR.8		D6				; arrondi  un multiple de 256	SR.32		#8, D6				; nombre de blocs du SYS_FREE	MOVE.32		A4, a3	MOVE.32		{A6}+OFREE, A4	MOVE.16		{A3}+OBDNPT,D0			; D0.16 nbr de tranches de blocs de data	MOVE.32		#{A3}+OBDPTS,A0			; A0^pointeur au dbut de tranches	MOVE.32		#{A3}+OBDNBS,A5			; A5^nbr de blocs dans la tranche A0^TRS$:	test.32		d6				; lu assez de blocs ?	jump,eq		OK$	DEC.16		D0				; Tranche suivante ?	JUMP,cs		OK$LTR$:	MOVE.32		{A0+},D4			; Lit une tranche	ADD.32		{A6}+ODEBPART,D4	move.32		#0, D5	MOVE.8		{A5+},D5			; long.  lire	comp.32		D6, d5	jump,ls		r8^LBLK$	move.32		D6, D5LBLK$:	sub.32		D5, D6	CALL		RDBLK				; lit tout	JUMP,ne		out$				; erreur -> koL35$:	sl.32		#8, D5				; nombre d'octets lus	ADD.32		d5, a4				; ^suite des data si ncessaire	JUMP		TRS$OK$:	TSET.8		{A6}+OFLAGS:#BFREE		; SYS_FREE ok!OUT$:	POPM.32		A0..A5|D0..D6	RET\g_titre;;-------\; INIBAD >;-------/\g_Fond;; Initialise OnoBad, liste des numros logiques de blocs foutus (!!! 1 SEUL BD !!!);; IN:	A4.32		^data du BD de SYS_BAD; OUT:; MOD:	D7, F.;=INIBAD:	PUSHM.32	D0..D6|A0..A5	MOVE.32		#MAXBAD-1,D1	test.8		{A6}+BSYSBAD			; pas si dj fait	jump,bs		OUT$	test.8		{A6}+OFLAG4:#B4RamDyn	jump,bs		OK$	MOVE.32		A4, A3	MOVE.32		#{A6}+ONOBAD, A4	MOVE.16		{A3}+OBDNPT,D0			; D0.16 nbr de tranches de blocs de data	JUMP,EQ		r8^OK$	MOVE.32		#{A3}+OBDPTS,A0			; A0^pointeur au dbut de tranches	MOVE.32		#{A3}+OBDNBS,A5			; A5^nbr de blocs dans la tranche A0^LTR$:	MOVE.32		{A0+},D4			; Lit une tranche	MOVE.8		{A5+},D5			; long.  lirePN$:	DEC.32	D1	JUMP,LT	ER$	MOVE.32		D4,{A4+}	MOVE.32		#-1,{A4}	INC.32	D4	DEC.8	D5	JUMP,NE	PN$	DEC.16	D0	JUMP,NE	LTR$	JUMP	OK$ER$:	LIB	?BUZZ, ?BUZZ, ?AFTIM	.ASCIZE	"<CR><AFINV> !!! Trop de blocs foutus: augmenter MAXBAD dans le source !!! <AFDIR>"OK$:	SET.8		{A6}+BSYSBAD		; SYS_BAD ok!OUT$:	POPM.32		A0..A5|D0..D6	RET;----------------------------------------------------------------------------------	.CHAP		ROUTINE PROCESSUS PRINCIPAL\g_titre;;--------\; BL?     >;--------/\g_Fond;; Regarde si un bloc donn est un BL.;; IN:	D4.32 numro physique du bloc; OUT:	EQ si oui et A0^1er BD de ce dir dans obdrep; MOD:	A0, F;=BL?:	clr.16		d5	call		tstBLOCS	jump,ne		r8^er$	comp.8		#TYPBL, d2	jump,ne		er$	pushm.32	d4|a4	move.32		d0, D4	call		litBD	move.32		A4,a0	popm.32		d4|a4er$:	RETLOCK:	pushm.32	a5|d4	ntrel		?gtPnum	comp.16		{a6}+Opsema, d4	jump,eq		r8^ok$	move.32		{a6}+Osema,a5	ntrel		?LOCK	move.16		d4, {a6}+OpSEMA			; processus autoris	clr.16		{a6}+Onsemaok$:	inc.16		{a6}+Onsema	popm.32		a5|d4	retunLOCK:	push.16		SF	pushm.32	a5|d7	dec.16		{A6}+Onsema	jump,ne		r8^ok$	clr.16		{a6}+Opsema	move.32		{a6}+Osema,a5	ntrel		?unLOCKok$:	popm.32		a5|d7	pop.16		F	ret\g_titre;;--------\; NXDEEP  >;========/\g_Fond;; Cherche le nme bloc dans un BD.; in	D4.32	0..n;	D0.32	no du BD; out	D4.32	no bloc;	D7.16	erreur; mod	D4.32, D7.16DOFNEXT:	test.8		{a6}+OFMENU:#BMSPOS	jump,bc		erk	move.32		{a6}+OPOSFIL, D4	inc.32		D4	call		r8^NXDEEP	jump		DOBAFFDOFPREV:	test.8		{a6}+OFMENU:#BMSPOS	jump,bc		erk	move.32		{A6}+OPOSFIL, D4	jump,eq		ERK	dec.32		D4	call		r8^nxDEEP	jump		DOBAFFDOSPOS:	test.8		{a6}+OFMENU:#BMSPOS	jump,bc		erk	test.8		{a6}+OFLAG2:#B2FOS	jump,BC		r8^L0$	sub.32		{A6}+ODEBPART,D4L0$:	call		r8^nxDEEP	jump		DOBAFFNXDEEP:; in	D4.32		offset voulu	pushm.32	d0..d3|d5..d6|a0..a4	move.16		#LGBLK, {a6}+OoutFIL	move.32		D4, d6				; GPOS recherch	move.32		{a6}+ObuNO, d0			; bloc actuellp$:	move.32		d6,d3				; GPOS cherch	move.32		d0, d4				; remonte chane	clr.16		d5	call		tstBLOCS			; bloc connu?	jump,eq		r8^bon$	move.32		#{A6}+ObuBLK,a4	call		tstBD				; resemble  un BD	jump,ne		er$				; non -> erreur	move.16		#TYPBD, d2	move.32		#0, d1	move.32		#0, d0bon$:	and.16		#16'F, D2	comp.16		#TYPBD, d2			; doit tre un BD	jump,ne		lp$				; non -> recherche plus loin	test.32		d1:#31	jump,bc		r8^off$				; offset dans un BL?	clr.32		d1				; oui -> repart  0off$:	call		litBD				; lit le BD en mmoire	jump,ne		er$	sub.32		d1, d3				; enlve l'offset dbut BD	jump,lo		lp$				; doit tre dans le prcdent!	move.32		#{A4}+OBDPTS, a0		; ^sur le dbut tranches	move.32		#{A4}+OBDNBS, a1		; ^sur les longueurs	move.16		{A4}+OBDNPT, d1			; nombre de tranchessuit$:	move.32		d3, d2				; offset voulu	sub.8		{a1}, d3			; retranche long	jump,cc		r8^s2$	sub.32		#16'100, d3			; reporte le carry	jump,cs		end$				; plus petit -> trouvs2$:	add.32		#4, a0				; tranche suivante	add.32		#1, a1	dec.16		d1				; s'il en reste	jump,ne		suit$	move.32		{A4}+OBDNEXT, d0		; BD next existe?	add.32		{a6}+OdebPART, d0	test.32		{a4}+OBDNEXT	jump,ne		lp$	move.32		{a0}-4, d4			; dbut dernire tranche	add.8		{a1}-1, d4			; et long	jump,cc		s3$	add.32		#16'100, d4			; reporte le carrys3$:	dec.32		d4	add.32		{a6}+OdebPART, d4		; no bloc disque voulueof$:	call		AFERROR	lib		?aftim	.ascize		"Fin du fichier "	tclr.8		{A6}+OFLAG3:#BLPMACRO	tclr.8		{A6}+OFLAG3:#BEXMACRO	move.16		{a4}+OBDLST, {a6}+OoutFIL	clr.16		d7	jump		er$end$:	move.32		{a0}, d4			; dbut de la tranche	add.32		d2, d4				; plus off. voulu	add.32		{a6}+OdebPART, d4		; no absolu	clr.16		d7	test.32		{A4}+OBDNEXT	jump,ne		er$	comp.16		#1, d1	jump,ne		er$	comp.8		#-1, d3	jump,eq		eof$er$:	popm.32		d0..d3|d5..d6|a0..a4	RET\g_titre;;--------\; EDITBLK >;========/\g_Fond;; in	A4.32	^bloc  diter; out	D3.16	dernire touche presse; mod	toutEDITBLK:	MOVE.32		#R16^TABD,A0	move.32		#OBDCHK, D0	COMP.16		#TYPBD,{A6}+OTYPBLK	JUMP,EQ		EDIT00	move.32		#OBLCHK, D0	MOVE.32		#R16^TABL,A0	COMP.16		#TYPBL,{A6}+OTYPBLK	JUMP,EQ		EDIT00.if	false	MOVE.32		#R16^TABIN,A0	COMP.16		#TYPBIN,{A6}+OTYPBLK	JUMP,EQ		EDIT0	MOVE.32		#R16^TAGENC,A0	COMP.16		#TYPGENC,{A6}+OTYPBLK	JUMP,EQ		EDIT0.endif	MOVE.32		#R16^TADATA,A0	JUMP		EDIT0EDIT00:	move.32		{A6}+OCHECK, {A4}+32^{D0}	; corrige le check !EDIT0:	CALL		AFBLK				; affiche tout le blocEDIT1:	CLR.32		D4	MOVE.8		{A0}+OTACOY,D4	ADD.16		#POSYBLK,D4	SWAP.32		D4	MOVE.8		{A0}+OTACOX,D4	CLR.32		D0	MOVE.16		{A0}+OTAPTX,D0			; D0 <-- ^relatif texte	JUMP,EQ		L20$				; si pas de texte => 20$	ADD.32		{A6}+OSTART,D0			; D0 <-- ^absolu texte	MOVE.32		D0,A3L10$:	INC.16		D4				; D4 <-- saute le texte en X	TEST.8		{A3+}	JUMP,NE		L10$	DEC.16		D4L20$:	CALL		SETCURS				; positionne curseur	MOVE.8		#CURS,D3	LIB		?AFCAR				; remet le curseur	CLR.16		D0	MOVE.8		{A0}+OTAOFF,D0			; D0 <-- offset dans bloc	move.32		#{A6}+oBufAFF, A2	move.8		{A2}+A16^{D0}, D3		; AFDIR/AFINV	clr.32		D1	move.32		#{A4}+A16^{D0}, A3		; ^texte	move.8		{A0}+OTALTX,D1			; longueur du texte	move.32		#r16^TableKeyFile, A1	COMP.8		#"F",{A0}+OTATYP	jump,ne		r8^t$	clr.8		{A3}+A16^{D1}-1			; reserve le terminateur	dec.16		D1	tset.32		D1:#31	JUMP		EdText$t$:	move.32		#r16^TableKey, A1		; ^table touches valables	COMP.8		#"T",{A0}+OTATYP	JUMP,EQ		EdTextx$	clr.32		D4	clr.32		D5	move.8		{A4}+A16^{D0}, d4	move.16		#2, D1	COMP.8		#"B",{A0}+OTATYP	jump,EQ		EdHexa$	move.16		{A4}+A16^{D0}, d4	move.16		#4, D1	COMP.8		#"W",{A0}+OTATYP	JUMP,EQ		EdHexa$	move.32		{A4}+A16^{D0}, d4	move.16		#8, D1	COMP.8		#"L",{A0}+OTATYP	JUMP,EQ		EdHexa$	comp.8		#"l",{A0}+OTATYP	jump,eq		EdHexa$;	comp.8		#"C",{a0}+OTATYP	jump		GetCar$EdTextx$:	push.32		A3	move.32		#r16^SoftAll, A3	Lib		?AFMENU	pop.32		A3EdText$:	move.32		#{A6}+oBufHach, A2		; tampon pour UNDO	call		EditText	set.8,ne	D6	push.32		A3	MOVE.32		#R16^MENU_EDIT,A3	Lib		?AFMENU	pop.32		A3	test.8		D6	jump,F		DoKey$	ex.32		a3, a4	call		TstSYSLIST			; vient de modifier SYS_LIST ?	ex.32		a3, a4	jump,eq		r8^list$	ex.32		a3, a4	call		TstSYSFREE	ex.32		a3, a4	jump,ne		DoKey$	call		ClearDataBL	move.32		#16'3E, {A3}+OBLATT	move.8		#16'81, {A3}+OBLTYP	move.8		#-1, {A3}+OBLOPE	pushm.32	A0|D0	move.32		{A6}+oBuNo, D4	CALL		BL?	JUMP,ne		r8^pop$	sub.32		{A6}+oDebPART, d0	comp.32		#1, D0				; BD de base ?	jump,ne		r8^Pop$	CLR.32		D4	MOVE.16		{A0}+OBDHAC,D4	add.32		D4, D4	add.32		#2, D4	move.32		D4, {A3}+OBLPT			; devrait tre lPop$:	popm.32		A0|D0	jump		DoKey$list$:	clr.16		d5	pushm.32	d0|a0	move.32		{A6}+oBuNo, d4	call		tstBLOCS	ex.32		d0, d4	popm.32		d0|a0	jump,ne		DoKey$	call		ClearDataBL	sub.32		{A6}+oDebPART, D4	move.32		D4, {A3}+OBLPT	move.32		#16'143E, {A3}+OBLATT	move.8		#16'81, {A3}+OBLTYP	move.8		#0, {A3}+OBLOPE	jump		DoKey$EdHexa$:	call		EditHexa	set.8,ne	D6	jump,ne		r8^PutVal$	comp.8		#"l",{A0}+OTATYP	jump,ne		r8^DoKey$	set.8		D6PutVAl$:	move.8		D4, {A4}+A16^{D0}	comp.8		#2, D1				; un octet ?	jump,eq		r8^DoKey$	move.16		D4, {A4}+A16^{D0}	comp.8		#4, D1				; un mot ?	jump,eq		r8^DoKey$	move.32		D4, {A4}+A16^{D0}	comp.8		#"l", {A0}+OTATYP	jump,ne		r8^DoKey$	push.32		d4	and.32		#16'FF, d4	move.16		d4,{a4}+A16^{D0}-OBLLGF+OBLLGB	popm.32		d4	jump,eq		plein$	add.32		#16'100, d4			; un bloc de plusplein$:	sr.32		#8, d4	move.32		d4,{A4}+A16^{D0}-OBLLGF+OBLLG	jump		r8^DoKey$GetCar$:	lib		?GetCar	Lib		?MinMAJ	clr.16		d7DoKey$:	test.8		D6	jump,f		r8^k$	CALL		AFBLK				; r-affiche tout le block$:	UTILE_		JUMPCAR	.32		APC	.16		HELP,0,EDHELP	.16		END,F0,0,EDEND	.16		F1,2**BCURSOR*16'100+"D",0,EDCURD	.16		2**BCURSOR*16'100+CR	.16		F3,CR,SPACE,2**BCURSOR*16'100+"F",0,EDCURF	.16		2**BCURSOR*16'100+"S",0,EDCURS	.16		2**BCURSOR*16'100+"G",0,EDCURG	.16		2**BCURSOR*16'100+"R",0,EDCURR	.16		2**BCURSOR*16'100+"C",0,EDCURC	.16		2**BCURSOR*16'100+"E",0,EDCURE	.16		2**BCURSOR*16'100+"X",0,EDCURX	.16		F2,2**BCURSOR*16'100+"T",0,EDCURT	.16		2**BCURSOR*16'100+"V",0,EDCURV	.16		F7, 0, EDCLRF	.16		F8, 0, EDCLRB	.16		0,L80$L80$:	MOVE.8		#BIPLIT,D3	LIB		?BEEP				; p'tit bruit	JUMP		EDIT1EDHELP:	MOVE.32		#R16^THELP,A3	MOVE.16		#9+2**BTEXT,D3	UTILE_		AFMES	JUMP		EDIT1EDCURD:	CALL		TAPREV	JUMP		EDIT1EDCURF:	CALL		TANEXT	JUMP		EDIT1EDCURS:	TEST.8		{A0}+OTADEL:#BBEGLI	JUMP,NE		EDIT1L10$:	CALL		TAPREV	TEST.8		{A0}+OTADEL:#BBEGLI	JUMP,EQ		L10$	JUMP		EDIT1EDCURG:	TEST.8		{A0}+OTADEL:#BENDLI	JUMP,NE		EDIT1L10$:	CALL		TANEXT	TEST.8		{A0}+OTADEL:#BENDLI	JUMP,EQ		L10$	JUMP		EDIT1EDCURE:EDCURR:L10$:	CALL		TAPREV	TEST.8		{A0}+OTADEL:#BBEGLI	JUMP,EQ		L10$	JUMP		EDIT1EDCURX:EDCURC:L10$:	CALL		TANEXT	TEST.8		{A0}+OTADEL:#BENDLI	JUMP,EQ		L10$	JUMP		EDIT1EDCURT:L10$:	CALL		TAPREV	TEST.8		{A0}+OTADEL:#BBEGTA	JUMP,EQ		L10$	JUMP		EDIT1EDCURV:L10$:	CALL		TANEXT	TEST.8		{A0}+OTADEL:#BENDTA	JUMP,EQ		L10$	JUMP		EDIT1EDCLRF:	COMP.8		#"F",{A0}+OTATYP	jump,eq		r8^tx$	COMP.8		#"T",{A0}+OTATYP	jump,eq		r8^tx$	clr.8		{A4}+A16^{D0}	comp.8		#"B", {A0}+OTATYP	jump,eq		r8^ed$	clr.16		{A4}+A16^{D0}	comp.8		#"W", {A0}+OTATYP	jump,eq		r8^ed$	clr.32		{A4}+A16^{D0}	comp.8		#"C", {A0}+OTATYP	jump,ne		r8^ed$	move.32		{a6}+OCHECK,d4	move.32		d4, {A4}+A16^{D0}	jump		r8^ed$tx$:	clr.32		D1	move.8		{A0}+OTALTX,D1			; longueur du texte	move.32		#{A4}+A16^{D0}, A3		; ^textectx$:	clr.8		{A3}+A16^{D1}	dj.16,nmo	D1, ctx$ed$:	move.32		#2**BCURSOR*16'100+CR, D3	Lib		?WrKEY	jump		EDIT1EDCLRB:	PUSH.32		A4	MOVE.8		#10'256/4,D0L10$:	CLR.32		{A4+}				; rempli le bloc de zros	DEC.8		D0	JUMP,NE		L10$	POP.32		A4	move.16		{A6}+OTYPBLK,D0	comp.16		#TYPBL,d0	jump,eq		iBL$	comp.16		#TYPBD,d0	JUMP,ne		EDIT0	move.32		{A6}+oCHECK, {A4}+OBDCHK	JUMP		EDIT0iBL$:	move.32		{A6}+oCHECK, {A4}+OBLCHK	JUMP		EDIT0EDEND:	PUSH.16		D3	CALL		AFERROR				; efface "mode dition ..."	MOVE.8		#CURS,D3	LIB		?AFCAR				; remet le curseur	POP.16		D3				; D3 <-- dernire touche	CLR.32		D4				; D4 <-- simule retour ?GETHEX	RETClearDataBL:	pushm.32	A4|D4	move.32		#{A3}+LgName, A4	move.32		#LgBL-LgName, D4	GesMem		?ClearMem	popm.32		A4|D4	Ret\g_titre;;--------\; TANEXT  >;=-------/\g_Fond;; in	A0.32	^dans table; out	A0.32	^suivant; mod	A0.32TANEXT:	TEST.8		{A0}+OTADEL:#BENDTA	JUMP,NE		L90$	ADD.32		#LGTA,A0			; A0 <-- ^suivantL90$:	RET\g_titre;;--------\; TAPREV  >;=-------/\g_Fond;; in	A0.32	^dans table; out	A0.32	^prcdent; mod	A0.32TAPREV:	TEST.8		{A0}+OTADEL:#BBEGTA	JUMP,NE		L90$	SUB.32		#LGTA,A0			; A0 <-- ^prcdentL90$:	RET\g_titre;;--------\; AFBLK   >;========/\g_Fond;; in	A4.32	^bloc  afficher; out	-; mod	-AFBLK:	PUSHM.32	D0|D1|D2|D3|D4|A0|A3|a2	move.32		#{A6}+oBufAFF, A2	MOVE.8		#NOCURS,D3	LIB		?AFCAR				; plus du curseur	LIB		?BUCAR				; mode bufferis	MOVE.16		#-1,D2				; D2 <-- old position Y	MOVE.32		#R16^TABD,A0	COMP.16		#TYPBD,{A6}+OTYPBLK	JUMP,EQ		L10$	MOVE.32		#R16^TABL,A0	COMP.16		#TYPBL,{A6}+OTYPBLK	JUMP,EQ		L10$.if	false	MOVE.32		#R16^TABIN,A0	COMP.16		#TYPBIN,{A6}+OTYPBLK	JUMP,EQ		L10$	MOVE.32		#R16^TAGENC,A0	COMP.16		#TYPGENC,{A6}+OTYPBLK	JUMP,EQ		L10$.endif	MOVE.32		#R16^TADATA,A0L10$:	CALL		POSCURS				; positionne curseur	move.16		#LGBLK, d6			; dcompte avant demi-intensit	CLR.16		D0	MOVE.8		{A0}+OTAOFF,D0			; D0 <-- offset dans bloc	MOVE.16		#AFFULL, D3	TEST.8		{A6}+OFLAG2:#B2AFTOUT		; affiche tout?	jump,bs		r8^full$	clr.32		d1	move.16		{a0}+OTATST, d1			; routine test existante?	jump,eq		r8^norout$	add.32		{a6}+OSTART, d1			; oui -> calcul position	move.32		d1, a1	call		{a1}				; execute le testnorout$:	test.16		d6	jump,ns		L70$				; n'affiche rien si ngatif	jump,ne		r8^full$	move.16		#AFGREY, D3			; met en 1/2 intensitfull$:	lib		?AFCAR	move.8		D3, {A2}+A16^{D0}	CLR.32		d1	MOVE.16		{A0}+OTAPTX,d1			; d1 <-- ^relatif texte	JUMP,EQ		L25$				; si pas de texte => 25$	ADD.32		{A6}+OSTART,d1			; d1 <-- ^absolu texte	MOVE.32		d1,A3	LIB		?AFTEXT				; affiche texteL25$:	COMP.8		#"T",{A0}+OTATYP	JUMP,EQ		affT$	comp.8		#"F",{A0}+OTATYP		; nom de fichier	jump,eq		affT$				; affiche comme texte	COMP.8		#"L",{A0}+OTATYP	JUMP,EQ		L40$	comp.8		#"l",{A0}+OTATYP	jump,eq		afLG$	COMP.8		#"W",{A0}+OTATYP	JUMP,EQ		L30$	comp.8		#"C",{a0}+OTATYP	jump,eq		L34$	MOVE.8		{A4}+A16^{D0},D4	LIB		?AFX2	JUMP		L70$L30$:	MOVE.16		{A4}+A16^{D0},D4	LIB		?AFX4	JUMP		L70$L34$:	move.32		{a4}+A16^{d0},d4	lib		?afx8,?afspace	comp.32		{a6}+OCHECK,d4	jump,ne		r8^er$	lib		?aftim	.ascize		"JUSTE"	jump		L70$er$:	lib		?aftim	.ascize		"<AFINV>FAUX<AFDIR> "	jump		L70$L40$:	MOVE.32		{A4}+A16^{D0},D4	LIB		?AFX8	JUMP		L70$afLG$:	MOVE.32		{A4}+A16^{D0},D4	pushm.32	d2|d3	move.32		{A4}+A16^{D0}-OBLLGF+OBLLG,D3	sl.32		#8, d3	clr.32		d2	move.16		{A4}+A16^{D0}-OBLLGF+OBLLGB,D2	jump,eq		r8^plein$	sub.32		#16'100,D3plein$:	add.32		d2, d3	comp.32		d4,d3	jump,eq		bon$	LIB		?AFTIM	.8		AFINV,0	ex.32		d3,d4	LIB		?AFX8, ?AFSPACE	ex.32		d3,d4bon$:	popm.32		d2|d3	LIB		?AFX8, ?AFTIM	.8		AFDIR,0	JUMP		L70$affT$:	MOVE.8		{A0}+OTALTX,D1			; D1 <-- longueur texteL55$:	MOVE.8		{A4}+A16^{D0},D3	LIB		?AFCODE	INC.16		D0	dec.16		D6	jump,ne		r8^cont$	move.16		#AFGREY, D3			; continue en 1/2 intensit	lib		?AFCARcont$:	DEC.8		D1	JUMP,NE		L55$L70$:	TEST.8		{A0}+OTADEL:#BENDTA		; fin table ?	JUMP,NE		L90$				; oui => 90$							; non =>	CALL		TANEXT				; A0 <-- ^suivant dans table	JUMP		L10$L90$:	MOVE.16		#AFFULL, D3	LIB		?afcar	MOVE.32		#R16^LASTELE,A0	CALL		POSCURS				; efface le bas de l'cran	MOVE.8		#CURS,D3	LIB		?AFCAR				; remet le curseur	LIB		?NOBUCAR			; mode interractif	TCLR.8		{A6}+OFLAG2:#B2AFTOUT	POPM.32		D0|D1|D2|D3|D4|A0|A3|a2	RETLASTELE:	.8		0,14	.16		0	.8		0	.8		"B",0	.8		0\g_titre;;--------\; POSCURS >;=-------/\g_Fond;; in	A0.32	^dans table;	D2.16	dernire coordonne Y; out	D2.16	v. nouvelle coordonne; mod	D2.16POSCURS:	PUSHM.32	D0|D4	TEST.8		{A0}+OTACOX			; dbut ligne ?	JUMP,NE		L50$				; non => 50$L20$:							; oui =>	INC.16		D2				; D2 <-- pos Y ligne suivante	MOVE.16		D2,D4	ADD.16		#POSYBLK,D4	SWAP.32		D4	CLR.16		D4	CALL		SETCURS	CALL		DOEFLI				; efface une ligne	COMP.8		{A0}+OTACOY,D2	JUMP,NE		L20$	JUMP		L90$L50$:	CLR.32		D4	MOVE.8		{A0}+OTACOY,D4	ADD.16		#POSYBLK,D4	SWAP.32		D4	MOVE.8		{A0}+OTACOX,D4	CALL		SETCURSL90$:	POPM.32		D0|D4	RET\g_titre;;--------\; AFCAR   >;========/\g_Fond;; Affiche un caractre, en mettant un "-" s'il n'est pas; valide.; in	D3.8	caractre  afficher; out	-; mod	D3.8AFCAR:;	TCLR.32		D3:#7				; D3 <-- 0..127;	COMP.8		#4,D3				; caractre 0..3 ?;	JUMP,HS		L50$				; non => 50$;	MOVE.8		#"-",D3				; oui => affiche "-";L50$:	LIB		?AFCODE	RET\g_titre;;--------\; ERRKEY  >;========/\g_Fond;ERRKEY:	CALL		AFERROR	MOVE.8		#BIPERR,D3	LIB		?BEEP,?AFTIM	.ASCIZ		"Fonction inconnue ou impossible."	.EVEN	RET\g_titre;;---------\; INIBARRE >;=========/\g_Fond;; Remet les barres pour indiquer le mode d'affichage.; in	-; out	-; mod	-INIBARRE:	PUSHM.32	D3	COMP.16		#TYPDATA,{A6}+OTYPBLK	JUMP,EQ		L50$	COMP.16		#TYPBD,{A6}+OTYPBLK	JUMP,EQ		L51$	COMP.16		#TYPBL,{A6}+OTYPBLK	JUMP,EQ		L52$	MOVE.8		#13,D3	LIB		?CLRBARRE	INC.8		D3	LIB		?CLRBARRE	INC.8		D3	LIB		?CLRBARRE	JUMP		L90$L50$:	MOVE.8		#13,D3	LIB		?SETBARRE	INC.8		D3	LIB		?CLRBARRE	INC.8		D3	LIB		?CLRBARRE	JUMP		L90$L51$:	MOVE.8		#13,D3	LIB		?CLRBARRE	INC.8		D3	LIB		?SETBARRE	INC.8		D3	LIB		?CLRBARRE	JUMP		L90$L52$:	MOVE.8		#13,D3	LIB		?CLRBARRE	INC.8		D3	LIB		?CLRBARRE	INC.8		D3	LIB		?SETBARREL90$:	POPM.32		D3	RET\g_titre;;--------\; AFQUES  >;========/\g_Fond;; Prpare la position du curseur pour afficher une question.; in	-; out	-; mod	-AFQUES:	PUSHM.32	D4	MOVE.32		#(NbLI-3)*YY+0*XX,D4	CALL		SETCURS	CALL		DOEFLI	POPM.32		D4	RET\g_titre;;--------\; AFERROR >;========/\g_Fond;; Prpare la position du curseur pour afficher une erreur.; in	-; out	-; mod	-AFERROR:	PUSHM.32	D4	MOVE.32		#(NbLI-2)*YY+0*XX,D4	CALL		SETCURS;	CALL		DOEFLI	PUSH.32		D3	MOVE.16		#EFEOS,D3	LIB		?AFCAR	POP.32		D3	POPM.32		D4	RET\g_titre;;--------\; DOEFLI  >;========/\g_Fond;; Efface la fin de la ligne.; in	-; out	-; mod	-DOEFLI:	PUSH.32		D3	MOVE.8		#EFLI,D3	LIB		?AFCAR	POP.32		D3	RET\g_titre;;--------\; SETCURS >;========/\g_Fond;; in	D4.32	y,x en caractres; out	-; mod	-SETCURS:	PUSHM.32	D3..D4	MOVE.32		D4,D3	MUL.16		{A6}+ODIMCAR+2,D3		; x*DXCAR	SWAP.32		D4	MUL.16		{A6}+ODIMCAR,D4			; y*DYCAR	SWAP.32		D4	OR.32		D4,D3	LIB		?SETCURS	POPM.32		D3..D4	RET\g_titre;;--------\; GETCURS >;========/\g_Fond;; in	-; out	D4.32	y,x en caractres; mod	D4.32GETCURS:	PUSH.32		D3	LIB		?GETCURS	MOVE.32		D3,D4	AND.32		#16'FFFF,D4	DIV.16		{A6}+ODIMCAR+2,D4		; x/DXCAR	AND.32		#16'FFFF,D4	SWAP.32		D3	AND.32		#16'FFFF,D3	DIV.16		{A6}+ODIMCAR,D3			; y/DYCAR	AND.32		#16'FFFF,D3	SWAP.32		D3	OR.32		D3,D4	POP.32		D3	RET\g_titre;;--------\; HACHE   >;========/\g_Fond;; Calcul la fonction de hachage en fonction d'un nom de; fichier quelconque (sans vrifier la syntaxe).; in	A3.32		^nom de fichier;	D4.16		fonction de hachage (h); out	D4.32		valeur de hachage (0..h-1); mod	D4.32HACHE:	PUSHM.32	D1|D3|A3	AND.32		#16'FFFF,D4	JUMP,EQ		L90$				; pour viter "TRAP DIV-0"	CLR.32		D1				; D1 <-- mz somme des carsL10$:	MOVE.8		{A3+},D3	JUMP,EQ		L50$	COMP.8		#CR,D3	JUMP,EQ		L50$				; fini => 50$	LIB		?MINMAJ				; D3 <-- lettre majuscule	AND.32		#16'FF,D3	ADD.32		D3,D1				; D1 <-- somme des caractres	JUMP		L10$L50$:	DIV.16		D4,D1	MOVE.32		D1,D4	CLR.16		D4	SWAP.32		D4				; D4.32 <-- resteL90$:	POPM.32		D1|D3|A3	RETattention:	PUSHM.32	D1|D3|A3L10$:	MOVE.8		{A3+},D3	JUMP,EQ		L50$	COMP.8		#CR,D3	JUMP,EQ		L50$				; fini => 50$	JUMP		L10$L50$:	comp.8		#".",{a3}-2	jump,ne		L90$	CALL		AFERROR	lib		?aftim	.ascize		"<AFINV>ATTENTION<AFDIR>, les fichiers crs avec FOS 4 n'ont pas de point final"	lib		?GetCarL90$:	POPM.32		D1|D3|A3	RET\g_titre;;---------\; AFENTETE >;=--------/\g_Fond;; affiche l'entte;; IN:	-; OUT:	-; MOD:	D7.16;AFENTETE:	PUSHM.32	A3|D2..D4	LIB		?AFTIM	.8		EOP	.ASCIZ		"Editeur de disques rev "	.EVEN	MOVE.32		#R16^START,A3			; A3 <-- ^fin entte binaire	CLR.32		D4	MOVE.8		{A3}-256+OBXREV,D4	MOVE.8		#3,D3	MOVE.8		#2**BAFDCM,D2	LIB		?AFDEC				; affiche rvision	MOVE.8		#".",D3	LIB		?AFCAR	MOVE.8		{A3}-256+OBXVER,D4	MOVE.8		#3,D3	LIB		?AFDEC				; affiche version	LIB		?AFTIM.if	sosDISK	.8		CR,AUTOCR,ROLL,0.else	.8		CR,TRUNC,NOROLL,0.endif	.even;	.ASCIZE		"<MSPACE><15><AFINV> HELP <AFDIR> permet d'obtenir une aide.<CR>"	POPM.32		A3|D2..D4	RETAFUNIT:	pushm.32	d4|d3|a3	move.32		{a6}+OposUNIT, d3	lib		?SETCURS	LIB		?MAFTIM	.ASCIZ		"<"F">Mmoire de masse: "	.ASCIZ		"<"E">Mass memory name: "	.8		0	.EVEN	move.32		#{a6}+OnamUNIT, a3	lib		?afTEXT	MOVE.32		{A6}+ODEBPART,D4	LIB		?AFTIM	.ASCIZE		", dbut de la partition, aprs FOSBOOT : "	LIB		?AFX8	popm.32		d4|d3|a3	ret\g_titre;;--------\; GETNAME >;========/\g_Fond;; Cherche un nom logique dans la ligne de commande. S'il n'y; en a pas, demande  l'utilisateur ce qu'il veut.; in	-; out	A3.32	^nom;	D7.16	erreur (END); mod	A3.32, D7.16GETNAME:	PUSHM.32	D3|D4|A2|A4	lib		?getCURS	move.32		D3, {A6}+OposUNIT	LIB		?MAFTIM	.ASCIZ		"<"F">Mmoire de masse: "	.ASCIZ		"<"E">Mass memory name: "	.8		0	.EVEN	MOVE.32		{A6}+OPTCOM,A3			; A3 <-- ^ligne de commande	move.8		#"N",d3	LIB		?ifSWITCH			; /N pas d'exploration	jump,ne		r8^L10$	tset.8		{a6}+OFLAG2:#B2noEXPLL10$:	move.8		#"Q",d3	LIB		?ifSWITCH			; /Q pas de release	jump,ne		r8^L11$	tset.8		{a6}+OFLAG4:#B4noRELL11$:	LIB		?SKPNAM				; A3 <-- ^nom suivant	JUMP,NE		L50$				; si y'en a pas => 50$L12$:	COMP.8		#"$",{A3}			; nom physique ?	JUMP,EQ		L70$				; oui => 70$	COMp.8		#"@",{A3}	jump,eq		L71$	COMP.8		#"#",{A3}			; nom logique ?	JUMP,NE		L11$				; non => 11$.if	false	test.8		{a6}+OFLAG4:#B4noREL	jump,bs		r8^L20$	FOS		?RELEASE.endifL20$:	CLR.16		D3				; D3 <-- lien pour tous	FOS		?VASSIGN			; A4 <-- ^nom de lien	JUMP,NE		L50$	MOVE.32		A4,A3	COMP.8		#"$",{A3}			; nom physique ?	JUMP,NE		L20$				; non => 20$	JUMP		L70$L50$:	TCLR.8		{a6}+oflags:#BMENUP	MOVE.32		#R16^MENU_UNIT,A3	LIB		?AFMENU				; affiche "soft keys"	test.8		{a6}+OFLAG2:#B2noEXPL	jump,bs		r8^nbarre$	move.16		#13,d3	lib		?setBARRE	inc.16		d3	lib		?setBARRE	inc.16		d3	lib		?setBARREnbarre$:	MOVE.32		#{A6}+OBUNAM,A3			; A3 <-- ^buffer pour nom	MOVE.16		#LBUNAM-2,D3			; D3 <-- lg max du buffer	LIB		?GETCURS	MOVE.32		D3,D4	move.32		A3, a4	move.32		#0, A5	LIB		?GETFILE			; attend une ligne ...	PUSH.32		D3	MOVE.32		D4,D3	LIB		?SETCURS	POP.32		D3	comp.16		#F13,d3	jump,lo		r8^suite$	comp.16		#F15,d3	jump,hi		r8^suite$	tnot.8		{a6}+Oflag2:#B2noEXPL	jump		L50$suite$:	COMP.8		#CR,D3				; ligne termine par (RETURN) ?	JUMP,EQ		L12$				; oui => 20$	UTILE_		FNOSHIFT	MOVE.16		#1,D7				; D7 <-- "erreur"	MOVE.32		#R16^NPFLO0,A3	UTILE_		JUMPCAR	.32		APC	.16		END,F0,0,L90$			; (END) ?	.16		F1,F2,F3,0,L71$	.16		0,L52$L52$:	MOVE.32		#R16^NPFLO1,A3	UTILE_		JUMPCAR	.32		APC	.16		F4,F5,F6,0,L70$	.16		0,L54$L54$:	MOVE.32		#R16^NPWIN0,A3	UTILE_		JUMPCAR	.32		APC	.16		F7,F8,F9,0,L70$	.16		0,L55$L55$:	MOVE.32		#R16^NPSCSI0,A3	UTILE_		JUMPCAR	.32		APC	.16		F10,F11,F12,0,L70$	.16		0,L50$				; redemande  l'utilisateurL70$:	test.8		{a6}+OFLAG4:#B4noREL	jump,bs		r8^L71$	FOS		?RELEASE			; referme si possibleL71$:	PUSH.32		A3	LIB		?AFTEXT	POP.32		A3L80$:	CLR.16		D7				; D7 <-- okL90$:	POPM.32		D3|D4|A2|A4	TEST.16		D7				; retour EQ/NE	RET\g_titre;;--------\; OPEMM   >;========/\g_Fond;; Initialise une mmoire de masse.; in	A3.32	^nom de l'unit  utiliser; out	D7.16	erreur; mod	D7.16OPEMM:	PUSHM.32	D0|D1|D2|D3|D4|D5|A2|A3|A4	call		InstalleWin	MOVE.16		#10'50,D4	NTREL		?SETTIM				; attend une seconde au max !	MOVE.16		#TYPMM,D1	move.32		#{a6}+OnamUNIT, A2		; tampon pour le nom	move.32		#LgNameUNIT, D4	move.32		#2**BOPEXTEND+2**BOPMMUNIT+2**BOPnDIR+2**BOPWR+2**BOPRD+2**BOPEXWR, D3	tset.32		D3:#BOPNAME	FOS		?ARGSOPEN			; ouverture unit physique	jump,eq		r8^Bon$	move.32		#2**BOPEXTEND+2**BOPMMUNIT+2**BOPnDIR+2**BOPRD, D3	tset.32		D3:#BOPNAME	FOS		?ARGSOPEN			; se contente d'une ouverture pour lecture	jump,ne		L90$	move.16		#ERWRPR, D7Bon$:	move.16		D6, {A6}+OCANAL	MOVE.16		D7,{A6}+OFNOWR			; mmorise erreur v.	MOVE.16		#-1,D4	NTREL		?SETTIM				; remet timeout infini	MOVE.16		{A6}+OFNOWR,D7	JUMP,EQ		L70$	COMP.16		#ERTIMO,D7	JUMP,EQ		r8^noREC$	COMP.16		#ERWRPR, D7	JUMP,NE		L90$noREC$:	push.16		d7	move.32		#0, d3	lib		?SETCURS, ?AFTIM	.ASCIZE		"<CR><CR><AFINV><TRUNC>        Disque utilis, criture impossible <MSPACE><50><AFDIR>"	move.16		#50, d4	Ntrel		?DelMs	pop.16		d7L70$:	move.32		#{A6}+OBURST,a4	move.32		#LGMAM0,d4	move.16		{A6}+OCANAL,d6			; D6 <-- canal unit	move.16		#TYPMM,d3			; D1 <-- type mmoire de masse	FOS		?RSTATUS			; demande les informations	JUMP,NE		L90$	MOVE.32		#0,{A6}+ODEBPART		; pour un ram-disque	MOVE.32		#-1,{A6}+OFINPART	comp.8		#MTRAM, {A4}+OMTYPE	jump,ne		r8^Autre$	move.32		#-1,{A6}+OMAXBLK		; init nb max de blocs	move.32		#-1, {a6}+OblkFIN		; extreme limite de MM	TCLR.8		{A6}+OFLAGS:#BWIN	TCLR.8		{A6}+OFLAGS:#BFLO	Tset.8		{A6}+oFLAG4:#B4RamDyn	jump		beg$Autre$:	move.32		{A4}+OMNBLK,d4			; D4 <-- nb max de blocs	move.32		d4,{A6}+OMAXBLK			; init nb max de blocs	move.32		d4, {a6}+OblkFIN		; extreme limite de MM	TCLR.8		{A6}+OFLAGS:#BWIN	TCLR.8		{A6}+OFLAGS:#BFLOand.16		#16'FC,d2comp.16		#16'68,d2jump,eq		beg$	comp.8		#MTWIN, {a4}	jump,ne		L80$	TSET.8		{A6}+OFLAGS:#BWIN	MOVE.32		#{A6}+OBUBLK,A4	MOVE.32		#0,D4	CALL		RD1BLK				; lit le bloc physique 0 du winch	JUMP,NE		L90$	MOVE.32		#R16^TT,A2	MOVE.32		#R16^TP,A3	MOVE.32		#256,D4L75$:	LIB		?CPSTRING	JUMP,EQ		L78$	INC.32		A4	DEC.32		D4	JUMP,NE		L75$.if	false	LIB		?AFTIM	.ASCIZE		"<CR>Partition PSOS pas trouve dans le rpertoire du WINCH..."	LIB		?BUZZ,?BUZZ,?GETCAR.endif;	MOVE.16		#-1,D7;	JUMP		L90$	move.32		#16'20, {a6}+OdebPART	move.32		#-1, {a6}+OfinPART	jump		beg$L78$:	MOVE.32		{A4}+8,D4			; ^FOSBOOT	MOVE.32		D4,{A6}+OFINPART	ADD.32		#16,D4	MOVE.32		D4,{A6}+ODEBPART	MOVE.32		{A4}+8+4,D4	DEC.32		D4	ADD.32		D4,{A6}+OFINPART		; numro du dernier bloc utile de la partition PSOS	jump		beg$L80$:	comp.8		#MTFLO, {a4}			; est-ce un floppy?	jump,ne		r8^beg$	MOVE.32		#16,{A6}+ODEBPART		; pour un floppy	MOVE.32		#-1,{A6}+OFINPARTbeg$:	MOVE.32		{A6}+ODEBPART,D4	add.32		d4, {a6}+OblkFIN		; dernier bloc accessible	TSET.8		{A6}+OFLAGS:#BFLO	CLR.16		D7				; D7 <-- okL90$:	POPM.32		D0|D1|D2|D3|D4|D5|A2|A3|A4	TEST.16		D7				; retour EQ/NE	RETTT:	.8		0, SPACE, -1TP:	.ASCIZE		"PSOS"\g_titre;;-------\; CLOMM   >;========/\g_Fond;; Ferme une mmoire de masse.; in	-; out	D7.16	erreur; mod	-CLOMM:	PUSHM.32	D6	MOVE.16		{A6}+OCANAL,D6	FOS		?CLOSE				; ferme l'unit utiliseL90$:	POPM.32		D6	TEST.16		D7				; retour EQ/NE	RET\g_titre;;--------\; RDBLK   >;========/\g_Fond;; Lit un bloc dans le buffer d'aprs son numro physique.; IN:	D4.32	numro du 1er des blocs physiques  lire;	D5.32	nombre de blocs  lire;	A4.32	pointe buffer; OUT:	A4.32	^bloc(s) lu(s);	D5.32	nombre de blocs effectivement lus (?); MOD:	D5, D7, F.DBGRDBLK=		false				; paramtres in et out en haut  gaucheRDBLK:	PUSHM.32	D1|D2|D4	.IF		DBGRDBLK	PUSHM.32	D3..D7	MOVE.32		D5,D6	CLR.32		D5	CLR.32		D3	LIB		?USEWDO,?SETCURS,?AFTIM	.ASCIZE		"<EFLI>D4.32 & D5.32 in : "	LIB		?AFX8,?AFSPACE	MOVE.32		D6,D4	LIB		?AFX8	POPM.32		D3..D7	.ENDIF	COMP.32		{A6}+OBLKFIN,D4			; 	JUMP,Lo		L10$	MOVE.16		#ERMOUT,D7;	JUMP		L90$L10$:	TEST.8	{A6}+BSYSBAD	JUMP,F	L19$	TEST.8	{A6}+NOBISECTION	JUMP,T	L19$	PUSHM.32	D1..D3|A3		; pas les blocs foutus	CLR.32	D1	MOVE.32	D5,D2	MOVE.32	D4,D3	SUB.32	{A6}+ODEBPART,D3L11$:	MOVE.32	#{A6}+ONOBAD,A3L12$:	COMP.32	#-1,{A3}	JUMP,EQ	L16$	COMP.32	{A3+},D3	JUMP,NE	L12$	MOVE.32	D1,D5			; Nombre de bloc ok avant le foutu	NOTZ	JUMP,EQ	L18$	MOVE.16	#ERMREAD,D7	JUMP	L18$L16$:	INC.32	D3			; bloc suivant	INC.32	D1	DEC.32	D2	JUMP,NE	L11$L18$:	POPM.32		D1..D3|A3	; NE si 0 blocs pouvant tre lus avant le foutu	JUMP,NE	L90$L19$:	SUB.32		{a6}+OdebPART,D4	; on accde toujours des numro de blocs physiques	TEST.8		{A6}+OFLAGS:#BWIN	JUMP,BC		L20$	ADD.32		{a6}+OdebPART,D4		; winch, on accde les num. physiques	TCLR.32		D4:#31				; en jouant sur ces deux bits	TSET.32		D4:#30L20$:	PUSHM.32	D3..D6	MOVE.16		{A6}+OCANAL,D6			; D6 <-- canal unit physique	CLR.32		D3	RL.32		#8, D4				; position en octets	MOVE.8		D4, D3				; poids fort	CLR.8		D4				; multiple d'un bloccall	LOCK	FOS		?SPOS				; positionne sur les bons block	move.32		D5, D4				; nombre de blocs  lire (<16'1000000)	SL.32		#8, D4				; nombre d'octets  lire	FOS		?RDBYTE				; lit les donnescall	unLOCK	POPM.32		D3..D6				; D5 incorrect si floppy, winch ?	test.8		{A6}+NoBisection	jump,t		r8^L40$	COMP.16		#ERMOUT,D7			; dans le doute, on gre soi-mme...	JUMP,EQ		L30$	COMP.16		#ERTERM,D7	JUMP,EQ		L30$	COMP.16		#ERMREAD,D7	JUMP,LO		L40$	COMP.16		#ERMWRITE,D7	JUMP,HS		L40$L30$:	MOVE.32		D5,D1	SR.32		#1,D5				; erreur de lecture ou fin, on diminue la tranche	JUMP,GT		L20$	MOVE.32		D1,D5L40$:	COMP.16		#ERMOUT,D7	JUMP,EQ		L50$	COMP.16		#ERTERM,D7	JUMP,NE		L90$	MOVE.16		#ERMOUT,D7L50$:;	MOVE.32		D4,{A6}+OBLKFIN;	ADD.32		D5,{A6}+OBLKFINL90$:	POPM.32		D1|D2|D4	.IF		DBGRDBLK	PUSHM.32	D3..D7	MOVE.16		D7,D6	LIB		?AFTIM	.ASCIZE		" D5.32 & D7.16 out : "	MOVE.32		D5,D4	LIB		?AFSPACE,?AFX8,?AFSPACE	MOVE.16		D6,D7	LIB		?AFERROR,?BUZZ,?GETCAR	POPM.32		D3..D7	.ENDIF	TEST.16		D7	RETRD1BLK:; in	D4.32		no bloc;	A4.32		buffer	PUSHM.32	D1|D2|D4|D5	COMP.32		{A6}+OBLKFIN,D4			; 	JUMP,Lo		L10$	MOVE.16		#ERMOUT,D7;	JUMP		L90$L10$:	TEST.8	{A6}+BSYSBAD	JUMP,F	L19$	PUSHM.32	D1..D3|A3		; pas les blocs foutus	MOVE.32	D4,D3	SUB.32	{A6}+ODEBPART,D3	MOVE.32	#{A6}+ONOBAD,A3L12$:	COMP.32	#-1,{A3}	JUMP,EQ	L16$	COMP.32	{A3+},D3	JUMP,NE	L12$	MOVE.16	#ERMREAD,D7L16$:	POPM.32		D1..D3|A3	; NE si 0 blocs pouvant tre lus avant le foutu	JUMP,NE	L90$L19$:	SUB.32		{a6}+OdebPART,D4		; on accde toujours des numro de blocs physiques	TEST.8		{A6}+OFLAGS:#BWIN	JUMP,BC		L20$	ADD.32		{a6}+OdebPART,D4		; winch, on accde les num. physiques	TCLR.32		D4:#31				; en jouant sur ces deux bits	TSET.32		D4:#30L20$:	MOVE.32		#1, D5				; un seul bloc	PUSHM.32	D3..D6	MOVE.16		{A6}+OCANAL,D6			; D6 <-- canal unit physique	CLR.32		D3	RL.32		#8, D4				; position en octets	MOVE.8		D4, D3				; poids fort	CLR.8		D4				; multiple d'un bloccall	LOCK	FOS		?SPOS				; positionne sur les bons block	move.32		D5, D4				; nombre de blocs  lire (<16'1000000)	SL.32		#8, D4				; nombre d'octets  lire	FOS		?RDBYTE				; lit les donnescall	UNLOCK	POPM.32		D3..D6				; D5 incorrect si floppy, winch ?L90$:	POPM.32		D5|D1|D2|D4	TEST.16		D7	RET\g_titre;;--------\; WRBLK   >;========/\g_Fond;; Ecrit le bloc dans le buffer OBUBLK d'aprs son numro.; in	D4.32		numro du bloc  crire; out	-; mod	D7.16WRBLK:	PUSH.32		A4	MOVE.32		#{A6}+OBUBLK,A4	call		r8^wrBLKA4	POP.32		A4	retWRBLKA4:	PUSHM.32	D1|D2|D4..D5;;;	MOVE.32		D4,{A6}+OBUNO	MOVE.32		#1,D5				; D5 <-- un seul bloc	SUB.32		{a6}+OdebPART,D4		; on accde toujours des numro de blocs physiques	TEST.8		{A6}+OFLAGS:#BWIN	JUMP,BC		L20$	ADD.32		{a6}+OdebPART,D4	TCLR.32		D4:#31	TSET.32		D4:#30L20$:	PUSHM.32	D3..D6	MOVE.16		{A6}+OCANAL,D6			; D6 <-- canal unit physique	CLR.32		D3	RL.32		#8, D4				; position en octets	MOVE.8		D4, D3				; poids fort	CLR.8		D4				; multiple d'un bloccall	LOCK	FOS		?SPOS				; positionne sur les bons block	move.32		D5, D4				; nombre de blocs  lire (<16'1000000)	SL.32		#8, D4				; nombre d'octets  lire	FOS		?WRBYTE				; lit les donnescall	unLOCK	POPM.32		D3..D6				; D5 incorrect si floppy, winch ?L90$:	POPM.32		D1|D2|D4..D5	RET\g_titre;;-------\; FREE?  >;-------/\g_Fond;; Regarde si un bloc est libre.;; IN:	D4.32 numro physique du bloc; OUT:	bC si libre, bS si occup; MOD:	D7, F.;=FREE?:	PUSHM.32	D0..D1|A0	CLR.16		D7	TEST.8		{A6}+OFLAGS:#BFREE		; occup tant que sys_free pas en ram	notZ	JUMP,BS		OUT$	test.8		{A6}+oFLAG4:#B4RamDyn	jump,bs		OUT$	COMP.32		{A6}+ODEBPART,D4		; occup si hors partition utile	JUMP,LO		r8^OCC$	COMP.32		{A6}+OFINPART,D4	JUMP,HI		r8^OCC$	MOVE.32		D4,D0	SUB.32		{A6}+ODEBPART,D0	MOVE.32		{A6}+OFREE,A0	test.8		{A6}+OFLAG3:#B3okRECUP	jump,bc		r8^old$	MOVE.32		{A6}+OFREE2,A0old$:	ADD.32		#10,A0				; saute longueur et rserve	MOVE.32		D0,D1	SR.32		#3,D1				; offset octet	ADD.32		D1,A0	TEST.8		{A0}:D0				; test du bit	JUMP		r8^OUT$OCC$:	CLRZ		; zc ne bsOUT$:	POPM.32		D0..D1|A0	RETAFnumero:	LIB		?AFTIM	.ASCIZ		" numro "	.EVEN	LIB		?AFX8AFnumero2:	push.32		d4	LIB		?AFTIM	.ASCIZE		" ("	SUB.32		{A6}+ODEBPART,D4	LIB		?AFX8,?AFTIM	.ASCIZE		")"	pop.32		d4	retGEThexa:; out	D4.32		valeur;	D3.16		touche presse	test.8		{A6}+OFLAG3:#BEXMACRO		; macro en excution ?	jump,bc		r8^KEY$	lib		?ifCAR	comp.16		#END, D3	jump,eq		r8^END$	move.32		{A6}+OptMACRO, A3	move.32		{A3+}, D4	move.16		{A3+}, D3	move.32		A3, {A6}+OptMACRO		; prpare ^suivant	comp.16		#2**BPROGRA*16'100+CR, D3	jump,eq		r8^KEY$	retEND$:	tclr.8		{A6}+OFLAG3:#BLPMACRO	jump,bs		r8^E$	tclr.8		{A6}+OFLAG3:#BEXMACROE$:	clr.16		D3	retKEY$:	tclr.8		{A6}+OFLAG3:#BEXMACRO	pushm.32	d0|d1	lib		?getCURS	move.32		d3,d0l$:	move.32		d0,d3	lib		?setCURS,?afTIM	.8		EFLI,CURS,0	.even	test.8		{a6}+OFLAG2:#B2FOS	jump,BC		r8^L0$	lib		?AFTIM	.ascize		"("	call		GetHexProgra	move.32		d4,d1	add.32		{A6}+ODEBPART,D4	jump		r8^L9$L0$:	call		GetHexProgra	move.32		d4,d1L9$:	comp.16		#")",d3	jump,eq		r8^finP$	comp.16		#"(",d3	jump,eq		r8^debP$	jump		r8^ret$debP$:	TSET.8		{A6}+OFLAG2:#B2FOS	jump		l$finP$:	TCLR.8		{A6}+OFLAG2:#B2FOS	test.32		d1				; un nombre entr ?	jump,eq		l$	move.16		#CR,D3ret$:	test.8		{A6}+OFLAG3:#BRCMACRO	jump,bc		r8^out$	move.32		{A6}+OptMACRO, A3	move.32		D4, {A3+}	move.16		D3, {A3+}	clr.16		{A3}+4	move.32		A3, {A6}+OptMACRO	ex.32		d0,d3	lib		?setCURS	ex.32		d0,d3out$:	popm.32		d0|d1	retGEThex:; out	D4.32		valeur;	D3.16		touche presse	test.8		{A6}+OFLAG3:#BEXMACRO		; macro en excution ?	jump,bc		r8^KEY$	lib		?ifCAR	comp.16		#END, D3	jump,eq		r8^END$	move.32		{A6}+OptMACRO, A3	move.32		{A3+}, D4	move.16		{A3+}, D3	move.32		A3, {A6}+OptMACRO		; prpare ^suivant	comp.16		#2**BPROGRA*16'100+CR, D3	jump,eq		r8^KEY$	retEND$:	tclr.8		{A6}+OFLAG3:#BLPMACRO	jump,bs		r8^E$	tclr.8		{A6}+OFLAG3:#BEXMACROE$:	clr.16		D3	retKEY$:	Lib		?GetHex	test.8		{A6}+OFLAG3:#BRCMACRO	jump,bc		r8^out$	move.32		{A6}+OptMACRO, A3	move.32		D4, {A3+}	move.16		D3, {A3+}	clr.16		{A3}+4	move.32		A3, {A6}+OptMACROout$:	retafMENUP?:	Test.8		{a6}+oflags:#BMENUP	jump,bs		r8^afMENUP	retafMENUP:	pushm.32	a2..a5|d0	MOVE.32		#{a6}+OMENUP,A3	test.8		{A6}+oFlag4:#b4MenuProgra	jump,bs		afMENUPr	move.32		a3,a4	move.32		#R16^MENU_PRIM,a5	move.16		#lgMENUP-1,d0cpmenu$:	move.8		{a5+},{a4+}	dj.16,nmo	d0,cpmenu$	MOVE.32		#R16^MENU_PRIM,A4	MOVE.32		#R16^MENU_VIDE,a5	move.32		{a6}+OpMESS, a2	move.16		#6-1, d0c$:	move.8		{a2}+a16^{d0}, {a3}+a16^{d0}	dj.16,nmo	d0,c$					; copie "run" "tst" "end" ...	move.32		#r16^mCHK,A2	move.16		{a6}+OxBlocKO,d0	comp.16		{a6}+OnBlocKO,d0	call		modMENU	move.32		#r16^mBAD,A2	move.16		{a6}+OnBLOCbad,d0	comp.16		{a6}+OxBLOCbad,d0	call		modMENU	move.32		#r16^mDBL,A2	move.16		{a6}+OnBlocDBL,d0	comp.16		{a6}+OxBlocDBL,d0	call		modMENU	move.32		#r16^mHACH,A2	move.8		{a6}+OTYPFIL, d0	and.16		#16'1F, d0	comp.16		#TYPBDL, d0	jump,eq		r8^h$	comp.16		#TYPBL, d0h$:	notZ	call		modMENU	move.32		#r16^mREW2,A2;	test.8		{A6}+OFMENU:#BMREW2	test.32		{a6}+Orewind2	call		modMENU	move.32		#r16^mREW,A2;	test.8		{A6}+OFMENU:#BMREW	test.32		{a6}+Orewind	call		modMENU	move.32		#r16^mDEP,A2	test.8		{a6}+OFMENU:#BMDEEP	call		modMENU	move.32		#R16^mNXT,A2	test.8		{A6}+OFMENU:#BMNEXT	call		modMENU	move.32		#r16^mPRV,A2	test.8		{a6}+OFMENU:#BMPREV	call		modMENU	move.32		#r16^mSPOS,A2	test.8		{A6}+OFMENU:#BMSPOS	call		modMENU	move.32		#r16^mSPOS+6,A2	test.8		{A6}+OFMENU:#BMSPOS	call		modMENU	move.32		#r16^mSPOS+12,A2	test.8		{A6}+OFMENU:#BMSPOS	call		modMENU	move.32		#r16^mRECH,A2	test.8		{a6}+oFLAG2:#B2RECH	call		modMENU	move.32		#r16^mWRITE,A2	test.8		{A6}+OFLAG3:#B3noRECUP	notZ	call		modMENU	move.32		#r16^mEDIT,A2	test.8		{A6}+OFLAG3:#B3noRECUP	notZ	call		modMENU	move.32		#r16^mRECUP,A2	test.8		{a6}+oFMENU:#BMRECUP	call		modMENU	move.32		#r16^mFRE,A2	test.8		{a6}+oFLAGS:#BFREE	call		modMENU	LIB		?AFMENU	CALL		INIBARRE			; remet les barres	TSET.8		{a6}+oflags:#BMENUP	popm.32		a2..a5|d0	retafMENUPr:	move.32		a3,a4	move.32		#R16^MENU_PROGRA,a5	move.16		#lgMENUP-1,d0cpmenu$:	move.8		{a5+},{a4+}	dj.16,nmo	d0,cpmenu$	MOVE.32		#R16^MENU_PROGRA,A4	MOVE.32		#R16^MENU_VIDEp,a5	move.32		#r16^mOCC,A2	test.8		{a6}+oFLAGS:#BFREE	call		modMENU	add.32		#6,A2	test.8		{a6}+oFLAGS:#BFREE	call		modMENU	add.32		#6,A2	test.8		{a6}+oFLAGS:#BFREE	call		modMENU	move.32		#r16^mLIBR,A2	test.8		{a6}+oFLAGS:#BFREE	call		modMENU	add.32		#6,A2	test.8		{a6}+oFLAGS:#BFREE	call		modMENU	add.32		#6,A2	test.8		{a6}+oFLAGS:#BFREE	call		modMENU	move.32		#r16^mSYSBAD,A2	test.16		{a6}+OnBLOCbad	call		modMENU				; SYS_BAD s'il existe des blocs ko	move.32		#r16^mHACH?,A2	move.8		{a6}+OTYPFIL, d0	and.16		#16'1F, d0	comp.16		#TYPBL, d0	notZ	call		modMENU	move.32		#r16^mHACH??,A2	comp.16		#TYPBL, d0	notZ	call		modMENU	move.32		#r16^mDBCRIT,A2	test.8		{a6}+oFLAG2:#B2RECH	call		modMENU	move.32		#r16^mOPEN,A2	test.16		{A6}+OchFILE	call		modMENU	move.32		#r16^mPUT,A2	test.16		{A6}+OchFILE	call		modMENU	move.32		#r16^mPUTa,A2	test.16		{A6}+OchFILE	call		modMENU	LIB		?AFMENU	TSET.8		{a6}+oflags:#BMENUP	popm.32		a2..a5|d0	retmodMENU:; in	F		EQ > mettre des espaces;	A3.32		^menu variable;	A4.32		^menu rfrence NE;	A5.32		^menu rfrence EQ;	A2.32		^position texte rfrence	pushm.32	a2|a3|d0|A5	push.16		Sf	sub.32		a4,a3	add.32		a2,a3				; ^text variable	sub.32		a4,a5	add.32		a2,a5				; ^text faux	move.16		#6-1,d0	pop.16		f	jump,eq		space$copy$:	move.8		{a2+},{a3+}			; copie le texte originel	dj.16,nmo	d0,copy$	jump		r8^end$space$:	move.8		{a5+},{a3+}			; remplace par des espaces	dj.16,nmo	d0,space$end$:	popm.32		a2|a3|d0|a5	ret	.INS		EDISK_TABL.ASInUTILE:	.ASCIZ		"UTILE"nDBOX:	.asciz		"DBOX"THELP:	.ASCIZE		"#:EDISK.HELP"iniMAP:	pushm.32	d1|d4|a1	clr.16		D7	move.32		#0, A4				; pas de sys_free	test.8		{A6}+oFLAG4:#B4RamDyn	jump,bs		r8^L90$	move.32		{a6}+OmaxBLK,d4	SR.32		#3,D4				; D4 <-- nb bytes pour bitmap	ADD.32		#10,D4				; D4 <-- ajoute rserve	ADD.32		#LGBLK,D4	CLR.8		D4				; arrondi  un multiple de 256	move.16		#MtypOP,d1	move.32		{a6}+OptTASK,a1	move.32		#0, a4	GESMEM		?GETMEM	jump,ne		r8^L90$	GESMEM		?CLEARMEM	move.32		{a6}+OmaxBLK,{a4}L90$:	test.16		d7	popm.32		d1|d4|a1	retfillMAP:; in	D4.32		no de ce bloc;	D5.8		nb de blocs	test.8		{A6}+oFlag4:#B4RamDyn	jump,bs		r8^Ret$	pushm.32	d4|d5	sub.32		{A6}+OdebPART, d4lp$:	call		tsetMAP				; remplit MAP	jump,bc		r8^bon$	call		stoBlocDBL			; mmorise BD  doublebon$:	inc.32		d4	dec.8		d5	jump,ne		lp$	popm.32		d4|d5Ret$:	RETtsetMAP:	pushm.32	A0|d1	comp.32		{a6}+OmaxBLK,d4	jump,HS		out$	MOVE.32		{A6}+oFREE2,A0			; saute lg + rserve	add.32		#10'10,A0	MOVE.32		D4,D1	SR.32		#3,D1				; D1 <-- offset byte	ADD.32		D1,A0	TSET.8		{A0}:D4				; utilise un blocout$:	popm.32		a0|d1	ret;-------\; tstBD  >;=======/; analyse un bloc pour voir s'il resemble bien  un BD; in	A4.32		^bloctstBDd3:	call		r8^tstBD	jump,ne		r8^r$	test.16		{A4}+oBDHAC			; avec fonction de hachage ?	set.8,EQ	D7				; D7 = FF si oui	comp.8		#TypBDL, D3	jump,eq		r8^r$	not.8		D7				; c'est le contrairer$:	test.16		D7	RettstBD:	pushm.32	d0|d1|d4|a0	move.16		#erOUTmm, D7	move.32		{A4}+OBDNEXT, D4	comp.32		{A6}+OblkFIN, D4		; ^hors limite?	jump,HS		notBD$	move.32		{A4}+OBDPREV, D4	comp.32		{A6}+OblkFIN, D4		; ^hors limite?	jump,HS		notBD$	move.16		{A4}+OBDLST, D4	comp.16		#16'100, D4			; ^hors limite?	jump,HI		notBD$	move.16		{A4}+OBDNPT, D0			; nombre de ^dans BD	jump,eq		notBD$	comp.16		#nNBBLK+LGNAME/4, D0		; ^hors limite?	jump,HI		notBD$	move.16		#nNBBLK, D1			; nb de ^ tester  0	move.32		#{A4}+OBDPTS, A0	dec.16		d0	jump,cs		tv$tt$:	move.32		{A0+}, D4	comp.32		{A6}+OblkFIN, D4	jump,HS		notBD$	dec.16		d1	dj.16,nmo	d0, tt$tv$:	dec.16		d1	jump,ns		r8^yesBD$	move.16		#erNOTvd, D7tvd$:	test.32		{a0+}	jump,ne		notBD$	dj.16,nmo	d1,tvd$yesBD$:	move.16		#erCHKfx, D7	MOVE.32		{A4}+OBDCHK, D4	COMP.32		{A6}+oCHECK, D4			; contrle correcte?	JUMP,NE		r8^notBD$	clr.16		d7notBD$:	test.16		d7	popm.32		d0|d1|d4|a0	ret;-------\; tstBL  >;=======/; analyse un bloc pour voir s'il resemble bien  un BL; in	A4.32		^bloctstBL:	pushm.32	d0|d1|d4|a0|a4	move.16		#erOUTmm, D7			; ^hors de la mmoire de masse ?	move.16		#lgBL*3, D0npt$:	move.32		{A4}+A16^{D0}+OBLPT, D4		; ^BD	comp.32		{A6}+OblkFIN, D4		; ^hors limite?	jump,HS		notBL$	sub.16		#lgBL, D0	jump,cc		npt$	move.16		#lgBL*3, D0nna$:	move.16		#erNOTvd, D7			; pas valable ?	move.32		{A4}+A16^{d0}+OBLLGF, D4	move.32		{A4}+A16^{d0}+OBLLG, D3	sl.32		#8, D3	test.16		{A4}+A16^{d0}+OBLLGB	jump,eq		bv$	add.16		{A4}+A16^{d0}+OBLLGB, D3	sub.32		#16'100, d3bv$:	comp.32		D4, d3	jump,ne		notBL$	move.16		#erNOMfx, D7			; nom incorrect ?	move.16		#LGNAME-1, D1	move.32		#{A4}+A16^{d0}+OBLNAM, A0tc$:	move.8		{A0+}, D4	jump,eq		nc$	comp.8		#".", D4	jump,eq		nc$	comp.8		#"!", D4	jump,eq		nc$	comp.8		#"~", D4	jump,eq		nc$	comp.8		#"+", D4	jump,eq		nc$	comp.8		#"-", D4	jump,eq		nc$	comp.8		#"0", D4	jump,lo		notBL$	comp.8		#"9", D4	jump,ls		nc$	comp.8		#"A", D4	jump,lo		notBL$	comp.8		#"Z", D4	jump,ls		nc$	comp.8		#"_", D4	jump,ne		notBL$nc$:	dj.16,nmo	d1, tc$	sub.16		#lgBL, d0	jump,cc		nna$	move.16		#erCHKfx, D7			; CHK faux ?	MOVE.32		{A4}+OBLCHK, D4	COMP.32		{A6}+oCHECK, D4			; contrle correcte?	JUMP,NE		notBL$yesBL$:	clr.16		d7notBL$:	test.16		d7	popm.32		d0|d1|d4|a0|a4	retaffFILE:;	pushm.32	d0|d1	move.32		{a6}+Orewind, d0		; ^prcdent	move.32		{a6}+OposFIL, d1		; offset dans BL	call		r8^afffile2;	popm.32		d0|d1	retaffFILE2:	pushm.32	a3|a4|d0..d6	move.32		d0, d4	jump,eq		r8^DONE$			; pas connu? -> fin	move.32		d1, d3	move.32		d1, d6lp$:	clr.16		d5	call		tstBLOCS			; correspond  quoi?	jump,ne		done$	and.16		#16'F, d2			; masque les bits contrle	comp.16		#TYPBL, d2			; recherche le 1er BL	jump,eq		aff$				; et affiche	MOVE.32		D1, D3				; nouvel offset	move.32		d0, d4				; suit la chane	jump,ne		lp$	lib		?aftim	.ascize		" fichier SYS_LIST gpos: "	MOVE.32		{A6}+OPOSFIL, D4		; GPOS/fichier	LIB		?AFX8DONE$:	popm.32		a3|a4|d0..d6	retaff$:	call		litBL				; lit le BL correspondant	add.a16		d3, a4				; se possitionne	lib		?aftim	.ascize		" fichier: "	move.32		a4, a3	lib		?AFtext	MOVE.32		d6, D4				; GPOS/fichier	JUMP,NS		done$	LIB		?AFTIM	.ASCIZE		" gpos: "	LIB		?AFX8	jump		done$affDOUBLE:	pushm.32	d0..d4	move.32		{a6}+ObuNO, d4	move.16		#1, d5	call		tstBLOCS	jump,ne		done$	call		AFERROR		; possitionne le curseur	lib		?AFTIM	.ascize		"<AFINV>Bloc galement utilis par le"	call		afffile2	move.32		d0, d4	lib		?AFTIM	.ascize		"<AFDIR> (Rew2)"	move.32		d4, {a6}+Orewind2done$:	popm.32		d0..d4	retiniMENU:	move.16		{a6}+OTYPBLK, d2		; mode d'affichage	move.32		#{a6}+ObuBLK,A4	test.8		{A6}+OFLAG3:#B3okRecup			; fils prt ?	jump,bc		r8^noRECUP$	test.8		{A6}+OFLAG3:#B3noRECUP	jump,bs		r8^noRECUP$	comp.8		#TYPBL, d2	jump,eq		r8^yesRECUP$	comp.8		#TYPBD, d2				; doit tre un BD ?	jump,eq		r8^yesRECUP$	call		tstBD					; ressemble  un BD ?	jump,ne		r8^noRECUP$yesRECUP$:	tset.8		{A6}+oFMENU:#BMRecup			; rcup possiblenoRECUP$:	comp.8		#TYPBD, d2	jump,ne		r8^notBD$	tset.8		{a6}+OFMENU:#BMDEEP	test.32		{a4}+OBDPREV	jump,eq		r8^noPRV$	tset.8		{a6}+OFMENU:#BMPREVnoPRV$:	test.32		{a4}+OBDNEXT	jump,eq		r8^noNXTBD$	tset.8		{a6}+OFMENU:#BMNEXTnoNXTBD$:	jump		r8^fin$notBD$:	test.32		{a6}+Orewind	jump,eq		noSPOS$	tset.8		{a6}+OFMENU:#BMSPOSnoSPOS$:	comp.8		#TYPBL, d2	jump,ne		r8^notBL$	tset.8		{a6}+OFMENU:#BMDEEP	test.32		{a6}+Orewind	jump,eq		r8^notBL$	test.32		{a4}+OblNEXT	jump,eq		r8^noNXTBL$	tset.8		{a6}+OFMENU:#BMNEXTnoNXTBL$:	test.32		{a4}+OblPREV	jump,ns		r8^noPRVBL$	tset.8		{a6}+OFMENU:#BMPREVnoPRVBL$:notBL$:fin$:	rettstERR:	test.16		d7	jump,nc		r8^ret$	test.32		d5:#31	jump,bs		quit$	pushm.32	d3|d4	tset.8		{A6}+OFLAG2:#B2FULL	jump,bs		r8^nomess$	push.32		a0	move.32		#r16^Pful, A0	move.32		a0, {A6}+OpMESS	pop.32		a0	call		AFMENUP?nomess$:	move.32		#100, d4	ntrel		?DELMS			; attend un peu	popm.32		d3|d4	move.16		#-1, d7	test.8		{a6}+OFLAGS:#BABORT	jump,bc		r8^ret$quit$:	clr.16		d7ret$:	test.16		d7	ret.if	SOSDISKselALL	= 2**1.or.2**5.or.2**6.or.2**7.or.2**8.or.2**15.or.2**2.or.2**3.or.2**9.or.2**14.or.2**4selDBOX:; boite de slection du problme rencontr	pushm.32	d2..d5|a2	move.32		#r16^TDBsel, a2	move.32		#0, d2	move.32		#selALL, d4	DBOX_		OPEN	jump,ne		erFATlp$:	DBOX_		EDIT	jump,ne		erFAT	test.16		d3	jump,nc		r8^out$	call		testVAL	jump		lp$out$:	DBOX_		CLOSE	popm.32		d2..d5|a2	retkey	= 2**7.or.2**6TDBsel:	.16		box$-TDBsel	.16		0	.16		0	.16		0box$:	.8		oDBtext	.asciz		"Prcisez quel est votre problme:"	.8		oDBcr, oDBcr	.8		oDBsquare, key.or.1, 16'FF, 1	.asciz		" ""ENTER"" impossible"	.8		oDBcr, oDBtabx, 1	.8		oDBsquare, key.or.2, 16'FF, 2	.asciz		" SYS_FREE n'existe pas"	.8		oDBcr, oDBtabx, 1	.8		oDBsquare, key.or.3, 16'FF, 3	.asciz		" FOS-11 hors du fichier"	.8		oDBcr, oDBtabx, 1	.8		oDBsquare, key.or.5, 16'FF, 5	.asciz		" ""RECUP"" ne se termine pas correctement"	.8		oDBcr, oDBtabx, 2	.8		oDBsquare, key.or.6, 16'FF, 6	.asciz		" Numro de contrle incorrect"	.8		oDBcr, oDBtabx, 2	.8		oDBsquare, key.or.7, 16'FF, 7	.asciz		" Blocs  double"	.8		oDBcr, oDBtabx, 2	.8		oDBsquare, key.or.8, 16'FF, 8	.asciz		" Quelque BD sont inaccessibles"	.8		oDBcr	.8		oDBsquare, key.or.4, 16'FF, 4	.asciz		" FOS-1F changement de disquette"	.8		oDBcr	.8		oDBsquare, key.or.15, 16'FF, 15	.asciz		" SYS_LIST n'existe pas"	.8		oDBcr	.8		oDBsquare, key.or.9, 16'FF, 9	.asciz		" Accs hors de la mmoire de masse"	.8		oDBcr	.8		oDBsquare, key.or.10, 16'FF, 10	.asciz		" FOS-12 fichier n'existe pas"	.8		oDBcr, oDBtabx, 1	.8		oDBsquare, key.or.11, 16'FF, 11	.asciz		" le fichier apparait pourtant dans les listes"	.8		oDBcr, oDBtabx, 1	.8		oDBsquare, key.or.12, 16'FF, 12	.asciz		" le fichier a t dtruit accidentellement"	.8		oDBcr, oDBtabx, 1	.8		oDBsquare, key.or.13, 16'FF, 13	.asciz		" delete/A * fait sur l'unit!"	.8		oDBcr	.8		oDBsquare, key.or.14, 16'FF, 14	.asciz		" erreur de lecture ou autre erreur MM-"	.8		oDBcr, oDBcr	.8		oDBbox, 0, cr, TdbMEV	.asciz		" AU TRAVAIL "	.8		oDBTABx, 30	.8		oDBbox, 0, UNDO, TDBNORM	.asciz		"   ANNULE   "	.8		0	.eventestVAL:	pushm.32	d0..d3|a0	and.32		#16'FF, d3	move.32		#0, d0				; prpare nombre.32	move.32		d0, d1	move.32		#r16^TBVAL, a0lp$:	move.8		{a0+}, d0			; rfrence (majeur)	jump,eq		fin$	comp.8		d0, d3				; = val in	jump,eq		clr$				; clear si ncessaire les mineurssrc$:	move.8		{a0+}, d1			; explore les mineurs	jump,eq		lp$	comp.8		d1, d3				; celui-l?	jump,ne		src$	test.32		d4:d3				; on a fait set d'un mineur?	jump,bc		src$	tset.32		d4:d0				; oui -> on set aussi le majeur	jump		src$clr$:	move.8		{a0+}, d0			; sinon clr tous le mineurs	jump,eq		lp$	test.32		d4:d3				; set d'un majeur	jump,bs		clr$				; -> nop	tclr.32		d4:d0	jump		clr$fin$:	popm.32		d0..d3|a0	retTBVAL:	.8		1, 5,7,6,8,2,3,0	.8		5, 7,6,8,2,0	.8		10, 11,12,13,0	.8		0; Contrle des valeurs de hachage d'un dossier; in	D4.32		no du BD du dossier; out			le bloc est corrig, ainsi que les BL s'il y a lieu; lit le BD; parcourt les BL associs; calcule la fonction de hachage; contrle la valeurveriHACH:	pushm.32	A0|A1|D0..D6	call		LOCK	push.32		d4	move.32		#{A6}+OMAPHACH, A4	move.32		#512, d4	gesmem		?CLEARMEM			; efface la liste des nexts	move.32		a4, a5	pop.32		d4	move.32		#0, D1				; GPOS initial	call		litBD	move.16		{A4}+OBDHAC, D6			; valeur de hachageloop$:	call		litBD				; lit le BD	jump,ne		fin$	call		tstBD				; ressemble  un BD?	JUMP,NE		fin$	move.16		{A4}+OBDNPT, d3			; parcourt les tranches	jump,eq		fin$	move.32		#{A4}+OBDPTS, A0	move.32		#{A4}+OBDNBS, A1		; ^trancheslp$:	move.32		{a0+}, D4	jump,eq		r8^nop$	move.8		{a1+}, D5			; long	jump,eq		r8^nop$	call		BL$				; explore une tranchenop$:	dec.16		d3				; boucle	jump,ne		lp$	move.32		{a4}+OBDNEXT, D4	JUMP,ne		loop$fin$:	call		unLOCK	popm.32		A0|A1|D0..D6	RETBL$:	pushm.32	D2..D5|A4|A3	add.32		{a6}+OdebPART, d4nxtBL$:	move.32		D4, d0	call		litBL			; lit le BL -> A4.32	jump,ne		nopBL$	call		tstBL	jump,ne		nopBL$	pushm.32	a4|D4	move.32		{a4}+OBLNEXT, D4	sl.16		D1	move.16		D4, {a5}+A16^{D1}	; init ^next/GPOS	sr.16		D1	move.16		#4, D3			; parcourt les 4 fichiersnxtFIL$:	test.8		{a4}			; fichier prsent?	jump,eq		nFIL$			; non -> saute	move.32		a4, a3	move.32		d6, d4	call		HACHE			; vrifie si la valeur de hachage est cohrente	comp.16		d4, d1	jump,eq		r8^noFIL$next$:	sl.16		d4			; ^table des next.16	move.16		{a5}+A16^{d4}, d4	; prend ^next	jump,eq		bad$			; plus de next ko	comp.16		d4, d1	jump,ne		next$			; chane plus longue	jump		r8^noFIL$bad$:move.32	a4, a3lib	?afcr, ?aftext, ?afspace, ?afx4move.32	d0,d4	lib		?aftim	.ascize		"  Valeur de hachage incorrecte BL="push.32	d3	lib		?AFX8, ?afcrpop.32	d3	jump		r8^noFIL$nFIL$:	test.8		{A4}+1	jump,eq		r8^noFIL$	move.32		d0,d4	call		stoFILdelnoFIL$:	add.32		#lgBL, A4		; ^place suivante	dec.16		d3			; boucle	jump,ne		nxtFIL$	popm.32		a4|d4nopBL$:	inc.32		D1			; GPOS dans le dossier	inc.32		D4	dec.8		D5	jump,ne		nxtBL$finBL$:	popm.32		D2..D5|A4|A3	RETveriHDIR:lp$:	call		LOCK	move.32		{A6}+ONREP, A0next$:	test.32		{A0}+OrepPREV	jump,eq		end$	tset.8		{a0}+OrepFLAG:#0	jump,bs		nop$	move.32		{a0}+OrepNEXT, d4	lib		?AFTIM	.ascize		"Contrle le dossier "	move.32		#{A0}+OrepNAME, a3	lib		?afTEXT, ?afcr	call		veriHACH	clrZ	jump		r8^end$nop$:	add.32		#lgBUREP, a0	jump		next$end$:	notZ	call		unLOCK	retveriCHK:	move.32		{a6}+OBlocKO,a0	comp.32		#-1,{a0}			; fin de la liste ?	jump,eq		nop$	move.16		{a6}+OxBlocKO,d0		; nombre  parcourirlp$:	move.32		{a0+},d4	comp.32		#-1,d4	jump,eq		nop$	dec.16		d0	jump,cc		lp$	inc.16		{a6}+OxBlocKO	lib		?AFTIM	.ascize		"Il y a un problme de CHK avec le bloc "	lib		?afx8, ?afcr	clrZnop$:	notZ	retcoriCHK:	move.32		{a6}+OBlocKO,a0	comp.32		#-1,{a0}			; fin de la liste ?	jump,eq		nop$	move.16		{a6}+OxBlocKO,d0		; nombre  parcourirlp$:	move.32		{a0+},d4	comp.32		#-1,d4	jump,eq		nop$	dec.16		d0	jump,cc		lp$	inc.16		{a6}+OxBlocKO	lib		?AFTIM	.ascize		"Corrige le bloc "	lib		?afx8	call		litBU	jump,ne		er$	move.16		#0, d5	call		tstBLOCS	jump,ne		er$	and.16		#16'F, d2	comp.16		#TYPBD, d2	jump,eq		r8^BD$	move.32		{A6}+Ocheck, {A4}+OBLCHK	call		tstBL	jump,ne		er$	call		wrBLKA4	jump,ne		er$	move.32		#1, d5	call		exploBL	jump		r8^bon$BD$:	move.32		{A6}+Ocheck, {A4}+OBDCHK	call		tstBD	jump,ne		er$	call		wrBLKA4	jump,ne		er$	move.16		#TYPBD, d3	move.16		#TYPDATA, d2	move.32		#0, d1	call		exploBD	jump		r8^bon$er$:	lib		?AFTIM	.ascize		"  Je n'arrive pas  corriger ce problme."bon$:	lib		?AFCR	clrZnop$:	notZ	retstoFILdel:	pushm.32	d4|a4|d1|a1|a0	move.32		a4, a0	move.32		d4, d0	move.32		{A6}+OFILNUM, D4	add.32		#8, D4	MOVE.32		{A6}+OFILDEL,A4	call		LOCK	MOVE.16		#MTYPoP,D1	MOVE.32		{a6}+OptTASK,A1	CALL		ADDMEM	MOVE.32		A4,{A6}+OFILDEL	MOVE.32		D4, {A6}+OFILNUM	call		unLOCK	ADD.32		D4, A4	MOVE.32		#-1, {-A4}	MOVE.32		#-1, {-A4}	MOVE.32		{A0}+OBLPT, {-A4}	MOVE.32		D0, {-A4}	MOVE.8		D3, {A4}pushm.32	a3|d3move.32		#{A0}+1, A3lib		?AFTIM.ascize		" Fichier dans la corbeille: "lib		?AFTEXT, ?AFCRpopm.32		a3|d3	POPM.32		A4|D4|D1|a1|a0	retrecupFIL:	move.32		{A6}+OFILDEL, A0next$:	move.8		{A0}, D0			; position fichier/BL	jump,ns		fin$	move.32		{A0+}, D1			; No du BL	and.32		#16'00FFFFFF, D1	move.32		{A0+}, D4			; No du BD	add.32		{A6}+OdebPART, d4	pushm.32	a0|d0|d1	clr.16		d5	call		tstBLOCS			; le bloc est connu ?	popm.32		a0|d0|d1	jump,eq		bad$				; oui -> ne peut pas rcuprer	call		veriBD				; tous les blocs libres?	jump,ne		bad$	ex.32		d4, d1	call		litBL	move.32		a4, a1src$:	comp.8		#4, d0	jump,eq		bien$	add.32		#lgBL, A1			; recherche ^nom	inc.8		d0	jump		src$bien$:move.32		#{A1}+1, A3lib		?AFTIM.ascize		"Rcupre le fichier "lib		?AFTEXT, ?AFCR	move.16		#LgNAME-1-1, d0cop$:	move.8		{a1}+1, {A1}	inc.32		a1	dj.16,nmo	d0, cop$	clr.8		{A1}	call		wrBLKA4	ex.32		d1, d4	move.32		d1, d0	move.32		#2**31, d1	sub.32		{A6}+OdebPART, d4	call		putBD	add.32		{A6}+OdebPART, D4	call		litBD	call		exploBD				; explore le BDbad$:	jump		next$fin$:	ret.endif; in	D4.32		no absolu BD; out	d6.32		taille du fichierveriBD:	pushm.32	A0|A1|D0..D5|a5	move.32		#0, A5				; longueur	clr.32		D6next$:	call		litBD	jump,ne		fin$	move.32		{A6}+OCHECKtst, D0	comp.32		{A4}+OBDCHK, d0	jump,ne		r8^t$	move.32		{A6}+OCHECK, {A4}+OBDCHK	; corige le CHK	call		tstBD				; resemble  un BD maintenant ?	jump,ne		fin$	call		WRBLKA4				; met  jour le BDt$:	call		tstBD				; ressemble  un BD?	JUMP,NE		fin$	move.16		{A4}+OBDNPT, d3			; parcourt les tranches	jump,eq		fin$	move.32		#{A4}+OBDPTS, A0	move.32		#{A4}+OBDNBS, A1		; ^trancheslp$:	move.32		{a0+}, D4	jump,eq		nop$	move.8		{a1+}, D6			; long	jump,eq		nop$	add.32		d6, a5	add.32		{A6}+OdebPART, d4bis$:	clr.16		d5	push.32		a0	call		tstBLOCS			; bloc occup?	pop.32		a0	notZ	jump,ne		r8^fin$	inc.32		d4	dec.8		D6	jump,ne		bis$nop$:	dec.16		d3				; boucle	jump,ne		lp$	move.32		{a4}+OBDNEXT, D4	JUMP,ne		next$	move.32		A5, d6	dec.32		d6	sl.32		#8, d6				; taille en byte	move.16		{A4}+OBDLST, d0	and.32		#16'FFFF, d0	add.32		d0, d6	clr.16		D7fin$:	popm.32		A0|A1|D0..D5|a5	RETtstDISK:	move.32		#10'32*lgBLK, D4	move.16		#MtypOP,d1	move.32		{a6}+OptTASK,a1	GESMEM		?GETMEM				; demande place pour 32 blocs	jump,ne		err$	tset.8		{A6}+Oflags:#Btest	move.32		#r16^Ptst, a0	move.32		a0, {A6}+OpMESS	call		AFMENUP?	move.32		#0, d4				; dbut du test en 0loop$:	call		LOCK	move.32		#10'32, d5	call		rdBLK				; lit une tranche	call		unLOCK	comp.32		#10'32, d5	jump,eq		bon$;	test.16		D7;	jump,eq		bon$				; saute si ok	push.32		d4	move.32		#10'32-1, d0lp$:;	move.32		#1, d5	call		rd1BLK				; essaye de lire un bloc seul	jump,eq		ok$	comp.16		#ERMOUT, d7	jump,eq		ok$	call		stoBLOCbad			; signale kook$:	inc.32		d4				; au suivant de ces messieurs	dj.16,nmo	d0, lp$				; teste les 32 blocs seuls	pop.32		d4bon$:	test.8		{A6}+Oflags:#BABORT	jump,bs		fin$	add.32		#10'32, d4	comp.32		{A6}+OBLKFIN, d4	jump,lo		loop$fin$:	move.16		#MtypOP,d1	move.32		{a6}+OptTASK,a1	GESMEM		?GIVMEM				; rend la mmoire	move.32		#r16^Pend, a0	move.32		a0, {A6}+OpMESS	call		AFMENUP?err$:	retPrun:	.ascii		" run  "Poff:	.ascii		" off  "Pend:	.ascii		" <AFINV>end<AFDIR>"Pful:	.ascii		"<AFINV>Full<AFDIR>"Ptst:	.ascii		" tst  "Phac:	.ascii		" hach "	.evenDORECUP:	test.8		{A6}+OfMENU:#BMRecup		; exploration faite ?	jump,bc		erK				; non -> impossible pour l'instant	move.32		#{A6}+ObuBLK, A4	move.8		{a6}+OtypFIL, D2	AND.16		#16'F, D2	comp.8		#TYPBD, D2	jump,eq		recupBD0			; rcup sur un DB?	call		tstBD	jump,eq		recupBD				; aussi si ressemble  un BD	comp.8		#TYPBL, D2	jump,ne		erKrecupBL:	move.32		#4-1, d0			; nb de fichiers dans le bloc-1	call		tstBL				; ressemble  un BL ?	jump,eq		rBLrecupBL2:	move.32		{A4}+OBLCHK, {A6}+OCHECKtst	; garde old pour test	move.32		{A6}+OCHECK, {A4}+OBLCHK	; reinit CHK	call		tstBL				; ressemble  un BL maintenant ?	jump,eq		r8^o$	comp.16		#erNOTvd, D7			; erreur dans les longueurs ?	jump,eq		r8^o$	move.32		#lgBLK, D4	GESMEM		?clearMEM			; efface tous le bloc	move.32		{A6}+OCHECK, {A4}+OBLCHK	; reinit CHKo$:	push.32		a4del$:	test.8		{A4}				; il y a un fichier ?	jump,eq		r8^nx$	call		tstSYSLIST			; ne dtruit pas SYS_LIST	jump,eq		r8^nx$	call		tstSYSFREE			; ne dtruit pas SYS_FREE	jump,eq		r8^nx$	move.16		#lgNAME-1, d1sdel$:	move.8		{A4}+A16^{D1}, d3		; simule une destruction	move.8		d3, {A4}+A16^{D1}+1	dj.16,nmo	d1, sdel$	clr.8		{A4}nx$:	add.32		#lgBL, A4	dj.16,nmo	d0, del$	pop.32		a4	move.32		#4-1+2**31+2**30, d0		; nb de fichiers dans le bloc-1rBL:	; rcupre dans un BL les fichiers en tram (donc dtruits)	move.32		#{A6}+ObuBLK, A3		; ^BL en analyseLP$:	test.8		{A3}				; fichier prsent	jump,ne		r8^ok$				; oui -> saute	test.8		{A3}+1				; fichier dtruit prsent ?	jump,eq		r8^ok$	call		r8^RECUP$	tset.32		d0:#31				; bloc  mettre  jour	test.8		{A3}	jump,eq		r8^ok$	tset.32		d0:#30				; RECUP doit tre faitok$:	add.32		#lgBL, A3			; passe au suivant	dj.16,nmo	d0, LP$	MOVE.32		{A6}+OBUNO,D4	test.32		d0:#31	jump,bc		DOBAFF				; raffiche le bloc de liste	call		wrBLK				; le met  jour sans rien dire	test.32		d0:#30	jump,bc		DOBAFF	call		useFREE				; force le rcup  l'enter	jump		DOBAFFRECUP$:	pushm.32	a0|d0|d1|d4|a3	move.32		{A3}+OblPT, D4			; No du BD  rcuprer	add.32		{A6}+OdebPART, d4		; en absolu sur disque	clr.16		d5	call		tstBLOCS			; le bloc est dj connu ?	jump,ne		r8^r$	comp.32		{A6}+ObuNO, D0			; 	jump,eq		bad$				; oui -> ne peut pas rcuprerr$:	call		veriBD				; tous les blocs libres?	jump,ne		bad$	move.32		#{a6}+ObdBLK+ObdNAME, a4	; ^nom dans le BD	test.8		{A4}				; nom existe dans le BD ?	jump,eq		r8^b$	move.32		#r16^TERM$, A2	inc.32		A3				; ^nom dtruit	lib		?CPSTRING			; mme nom dans le BD et le BL ?	dec.32		A3				; ne modifie pas F	jump,ne		bad$				; non -> ne peut pas tre rcuprb$:	move.32		#LGNAME-1-1, d1	move.32		#0, D2SHIFT$:	move.8		{A3}+A16^{D2}+1, D3	move.8		D3, {A3}+A16^{D2}	inc.32		d2	dj.16,nmo	d1, SHIFT$	move.8		#0, {A3}+A16^{D2}		; termine le nom correctement	sub.32		{A6}+OdebPART, d4	move.32		{A6}+OBUNO,D0	move.32		A3, D1	move.32		#{A6}+ObuBLK, A2	sub.32		A2, D1				; offset dans le BL	tset.32		D1:#31	call		putBD				; met le BD dans les table	add.32		{A6}+OdebPART, D4	move.8		#TYPDATA, D2			; explore les data	call		tstDIR	jump,ns		r8^data$	move.8		#TYPBL.or.TYPEXPL, D2		; explore les data=BLdata$:	call		exploBD				; explore le BD	clr.32		{A6}+ObdNO	jump		r8^ret$bad$:	clr.32		{A3}+0	clr.32		{A3}+4	clr.32		{A3}+8	clr.32		{A3}+12				; supprime totalement le nomret$:	popm.32		a0|d0|d1|d4|a3	RETTERM$:	.8		0,-1	.EVENrecupBD0:	call		tstBD				; ressemble  un BD ?	jump,eq		ERK				; oui -> rien  rcuprer !!	move.32		{A4}+OBDCHK, {A6}+OCHECKtst	; valeur  remplacer	comp.16		#erCHKfx, D7	jump,eq		r8^writeBD			; met  jour si seule diffrencekillBDr:; ... dtruit le ^dans le BL de rfrence	move.32		{A6}+ObuNO, D4	clr.16		D5	call		tstBLOCS			; A0.32 ^table	jump,ne		ERK;	tclr.32		D1:#31				; offset dans BL	ex.32		D0, D4	call		litBU; ... dtruit le fichier;	clr.32		{A4}+A16^{D1}+OBLPT		; supprime le ^	clr.32		{A4}+A16^{D1}			; supprime le nom	call		wrBLK	call		useFREE				; force le rcup  l'enter	clr.8		{A0}+OTBLONG			; supprime lment dans table correspondance	ex.32		d0, D4				; relit le bloc en question	jump		DOBAFFwriteBD:	MOVE.32		{A6}+OBUNO,D4	call		veriBD	jump,ne		killBDr	move.32		{A6}+ObuNO, D4	move.32		#-1, {A6}+oBuNo	call		useFREE				; force le rcup  l'enter	clr.32		{A6}+ObdNO	jump		DOBAFFrecupBD:	move.32		{A6}+ObuNO, D4	move.32		D4, d5				; conserve le no du bloc	call		veriBD				; tous les blocs sont libres ?	jump,ne		bad$	move.32		#{A6}+ObdBLK+ObdNAME, A4	test.8		{A4}				; nom existe ?	jump,eq		bad$	MOVE.32		#{A6}+OBUNAM,A3CPN$:	move.8		{A4+}, {A3+}			; copie le nom dans un buffer	jump,ne		CPN$	MOVE.32		#{A6}+OBUNAM,A3	MOVE.32		{A6}+ODEBPART, D4	inc.32		D4	call		litBU				; lit le BD du rpertoire premier	MOVE.16		{A4}+OBDHAC,D4			; extrait la fonction de hachage	CALL		HACHE				; calcule la valeur	call		nxDEEP				; recherche le BL concern	call		litBU				; lit le BL	call		existe$				; teste si existe dj	jump,eq		r8^bad$	call		place$				; met en place le fichier	move.32		d5, D4				; revient sur le BD	jump		DOBAFFbad$:	move.32		d5, {A6}+ObuNO			; revient sur le BD	jump		killBDr				; pour le dtruire;	jump		DOBAFFexiste$:	pushm.32	D4|A4|d0	move.32		#r16^TERM$, A2LP0$:	move.16		#4, D0LP$:	lib		?CPSTRING	jump,eq		r8^OUI$	add.32		#lgBL, A4			; ^fichier suivant	dec.16		d0				; fini ?	jump,ne		LP$	move.32		{A4}-4*lgBL+OblNEXT, D4		; offset BL suivant	notZ	jump,ne		r8^NON$	call		nxDEEP				; passe au suivant	call		litBU				; relit le buffer	jump		LP0$NON$:OUI$:	popm.32		D4|A4|d0	retTERM$:	.8		0,-1	.EVENplace$:	pushm.32	D4|A4|d0|d5pLP0$:	call		litBU				; relit le BL premier si ncessaire	move.16		#4, D0pLP$:	test.8		{A4}				; place libre	jump,eq		r8^pOUI$	add.32		#lgBL, A4			; ^fichier suivant	dec.16		d0				; fini ?	jump,ne		pLP$	move.32		{A4}-4*lgBL+OblNEXT, D4		; offset BL suivant	notZ	jump,ne		pNON$	call		nxDEEP				; passe au suivant	jump		pLP0$pOUI$:	push.32		A4	clr.32		{A4}+0	clr.32		{A4}+4	clr.32		{A4}+8	clr.32		{A4}+12c$:	move.8		{A3+}, {A4+}			; copie le nom	jump,ne		c$	pop.32		A4	move.32		#DEFATT, d2	move.32		#r16^NDIR, A3	lib		?cpSTRING	jump,ns		r8^N$	move.32		#2**BATTM+2**BATTR+2**BATTW+2**BATTS+2**BATTG+2**BATTC+2**BATTA+2**BATTZ+2**BATTP+2**BATTL, d2N$:	sub.32		{A6}+OdebPART, d5	move.32		d5, {A4}+OBLPT			; rinit ^next	move.8		#0, {A4}+OBLOPE	move.8		#TYPRAND, {A4}+OBLTYP	move.32		d2, {A4}+OBLATT	move.32		d6, {A4}+OBLLGF			; taille du fichier	push.32		d6	add.32		#16'FF, d6	sr.32		#8, d6	move.32		d6, {A4}+OBLLG	pop.32		d6	and.32		#16'FF, d6	move.16		d6, {A4}+OBLLGB	move.16		#0, {A4}+OBLCODE	move.32		d4, d0	move.32		d5, d4	move.32		A4, D1	move.32		#{A6}+ObuBLK, A2	sub.32		A2, D1				; offset dans le BL	tset.32		D1:#31	comp.32		#DEFATT, d2	jump,eq		r8^BD$	call		putBDL	move.8		#TYPBL.or.TYPEXPL, D2		; explore les data=BL	jump		r8^SU$BD$:	call		putBD				; met le BD dans les tables	move.8		#TYPDATA, D2			; explore les dataSU$:	ex.32		d0, d4	move.32		#{A6}+ObuBLK, A4	call		wrBLK				; remet  jour le BL	ex.32		d0,d4	add.32		{A6}+OdebPART, D4	call		litBD	call		exploBD				; explore le BD	call		useFREE				; force le rcup  l'enter	clr.32		{A6}+ObdNOpNON$:	popm.32		D4|A4|d0|d5	retuseFREE:	tset.8		{A6}+OFLAG3:#B3USED	jump,bs		r8^nop$	pushm.32	A4|d4	move.32		{A6}+OnoSYSFREE, d4	jump,eq		p$	call		litBUl$:	call		TstSYSFREE	jump,eq		r8^m$	add.32		#LgBL, A4	jump		l$m$:	move.8		#-1, {A4}+OblOPE		; compteur d'ouverture	tset.8		{A4}+oblATT+3:#BATTW		; autorise tentative rcup	call		wrBLK				; met  jourp$:	popm.32		A4|D4	move.32		#-1, {A6}+ObuNO			; plus valable	clr.32		{A6}+ObdNOnop$:	retInstalleWin:	pushm.32	A2..A4|D3..D5	clr.16		D7	move.32		#r16^NPWIN0, A4	move.32		#r16^Nil$, A2	Lib		?CpString	jump,ne		ret$	clr.16		D3	Fos		?vAssign			; unit installe ?	jump,eq		ret$	move.32		#r16^Nil$, A3	clr.16		D3	Fos		?Install			; tente d'installer normalement	jump,eq		ret$	Lib		?AfTim	.ascii		"<eop><cr>Installation automatique du pilote $WIN_0 impossible<cr>"	.ascize		"Donner les paramtres suivants (H' par dfaut D' accept devant) :<cr>"	move.32		#{A6}+OBURST, A4	move.32		#LGMAM3, D4	GesMem		?ClearMem	move.32		#{A4}+OMNBCY-1, A2	move.8		#2**7, {A2+}	Lib		?AfTim	.ascize		"<cr>Nombre de cylindres : "	call		GetNum	Lib		?AfTim	.ascize		"<cr>Nombre de surfaces : "	call		GetNum	Lib		?AfTim	.ascize		"<cr>Nombre de secteur par piste : "	call		GetNum	move.16		#16'10, {A2+}			; nombre de blocs pour FBOOT	Lib		?AfTim	.ascize		"<cr>Valeur d'interleaving piste : "	call		GetNum	Lib		?AfTim	.ascize		"<cr>Valeur d'interleaving secteur : "	call		GetNum	move.16		#16'100, {A2+}			; taille d'un bloc disque	move.16		{A4}+OMNBCY, D4	mul.16		{A4}+OMNBSU, D4	mul.16		{A4}+OMNBSE, D4	move.32		D4, {A4}+OMTBLK	move.32		D4, {A4}+OMNBLK	move.32		#{A4}+OMNBCY-1, A2		; paramtres	move.32		#r16^Nil$, A3	move.32		#r16^NPWIN0, A4	clr.16		D3	Fos		?Install			; installe le disque pour ediskret$:	popm.32		A2..A4|D3..D5	test.16		D7	retNil$:	.ascize		""GetNum:	move.8		#"H", D5G$:	Lib		?GetHex	test.16		d4	jump,ne		r8^don$	Lib		?MinMaj	comp.8		#"H", D3	jump,eq		GetNum	comp.8		#"'", D3	jump,eq		G$	comp.8		#"D", D3	jump,ne		r$	move.8		D3, D5	jump		G$don$:	comp.8		#"D", D5	jump,ne		r8^r$	Lib		?BCDBINr$:	move.16		D4, {A2+}	RetGETHEXprogra:	pushm.32	d0	clr.32		D4	tclr.32		D0:#31	Lib		?GetShift	jump		r8^t$g$:	Lib		?GetKey	comp.16		#KeyMPO, d3	jump,eq		g$	comp.16		#KeyMGR, d3	jump,eq		g$	comp.16		#KeyMMR, d3	jump,eq		g$	comp.16		#KeyMDR, d3	jump,eq		g$	test.32		D3:#15				; pseudo-code ?	jump,bc		r8^car$;****	comp.8		#16'40, D3			; changement touche super-shift ?;****	jump,ne		g$;****	sr.16		#8, d3	Lib		?GetShift			; quelle soft-key ?t$:	test.32		D3:#bPROGRA	jump,bs		r8^s$	tclr.8		{A6}+oFlag4:#b4MenuProgra	jump,bc		g$a$:	call		AFMENUP?	jump		g$s$:	tset.8		{A6}+oFlag4:#b4MenuProgra	jump,bs		g$	jump		a$car$:	Lib		?MinMAJ	move.8		D3, D0	comp.8		#"F", d0	jump,hi		r$	sub.8		#"0", d0	jump,lo		r$	comp.8		#9, d0	jump,ls		r8^n$	sub.8		#"A"-"0", d0	jump,lo		r$	add.8		#10'10, d0n$:	sl.32		#4, d4	and.8		#16'F, d0	or.8		d0, d4	Lib		?AfCode	tset.32		D0:#31	jump		g$r$:	comp.32		#16'FFFF, D3	jump,hs		r8^rt$	test.8		{A6}+oFlag4:#b4MenuProgra	jump,bc		r8^rt$	tset.32		D3:#(BPROGRA+8)			; clic dans une soft-key avec progra pressrt$:	move.16		d3, d0	move.32		d0, d3	popm.32		d0	Ret	.START		START	.END