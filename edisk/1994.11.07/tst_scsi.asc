\define g_Fond:\nef11;\define g_ev:\n(bf)09;\define g_it:\n(if)07;\define g_titre:\m(f)17;; $flg: 05010001   $erh:TST_SCSI	.TITLE		TST_SCSI	; programme de test pour disque SCSI					; compare lecture bloc  bloc avec					; lecture par tranches de 32 blocs (FOS)	.PROC		M68000	.REF		Smaky	.REF		MODULESLgTranche	= 10'32*LgBLK		; longueur des tranches (copie EDISK)	.LOC		0oTampon1:	.blk.8		LgTrancheoTampon2:	.blk.8		LgTrancheoStatus:	.blk.8		LGMAM0LgVAR:	.START		Start	.LOC		0Start:	Lib		?OpeLib	move.32		#LgVAR, D4			; pour 2 tranche de donnes	move.16		#mTypCP, D1	GesMem		?GetMem	jump,ne		Err	move.32		A4, A6	Lib		?SkpNam				; nom de l'unit suit	jump,ne		Err	move.32		#2**bOpExtend+2**bOpRd+2**bOpMMUnit, D3	Fos		?ArgsOpen			; ouvre l'unit  tester	jump,ne		Err	move.32		#LgMAM0, D4	move.32		#{A6}+oStatus, A4	Fos		?RStatus			; demande les status	Lib		?AfTim	.8		EOP, NOCURS	.ascize		"Compare lectures tranches 16*256 avec lectures blocs 256<cr><cr>"	Lib		?GetCurs	move.32		D3, D5	move.32		#-1, D3	move.32		#-LgTranche, D2Loop$:	push.32		D3	Lib		?IfCar	comp.16		#END, D3	popm.32		D3	jump,eq		Fin	clr.8		D1	add.32		#LgTranche, D2	jump,cc		r8^a$	inc.32		D3a$:	move.32		D2, D4	Fos		?SPos				; ;	move.32		D2, D4	move.8		D3, D4	rr.32		#8, D4	ex.32		D5, D3	Lib		?SetCurs	ex.32		D5, D3	Lib		?Afx8	move.32		#{A6}+oTampon1, A4;	move.32		#LgTranche, D4;	move.32		D2, D4;	sr.32		#8, D4	move.32		D4, D0	add.32		#LgTranche/LgBLK, D4	comp.32		{A6}+oStatus+oMNBLK, D4	jump,ls		r8^aa$	move.32		{A6}+oStatus+oMNBLK, D4aa$:	sub.32		D0, D4				; reste  lire	jump,ls		Fin	move.32		D4, D0				; nombre de blocs FOS	sr.32		D0				; blocs de 512	sl.32		#8, D4				; nombre d'octet	Fos		?RdByte				; lit la tranche contigejump	Loop$	jump,eq		r8^b1$	set.8		D1	move.16		D7, D4	Lib		?AFTIM	.ascize		"=<AFINV>"	Lib		?AFX4, ?AFTIM	.ascize		"<AFDIR> "b1$:	move.32		D2, D4	Fos		?Spos				; revient en place	move.32		#{A6}+oTampon2, A4	dec.32		D0				; pour DJ.16,NMORd$:	move.32		#2*LgBLK, D4			; lecture par bloc physique de 512k	Fos		?RdByte				; lit un bloc	jump,eq		r8^b2$	set.8		D1	push.16		D7	move.32		D2, D4	move.8		D3, D4	rr.32		#8, D4	Lib		?AFSPACE, ?AFX8, ?AFTIM	.ascize		"=<AFINV>"	pop.16		D4	Lib		?AFX4, ?AFTIM	.ascize		"<AFDIR> "b2$:	add.32		#2*LgBLK, A4			; place suivante	dj.16,nmo	D0, Rd$	move.32		#{A6}+oTampon1, A1	move.32		#{A6}+oTampon2, A2		; donnes  comparer	move.32		#LgTranche/LgBLK/2-1, D0	move.32		D2, D4	sr.32		#8, D4				; no du blocc$:	call		CpBlkA1A2	jump,eq		r8^n$	set.8		D1	Lib		?Afspace, ?Afx4n$:	add.32		#2, D4				; avance de 2 bloc FOS en 2	dj.16,nmo	D0, c$	test.8		D1	jump,F		Loop$	ex.32		D3, D5	Lib		?Afcr, ?GetCurs	ex.32		D3, D5	jump		Loop$Fin?:Err:	DBOX_		ERRORFin:	Lib		?Aftim	.ascize		"<cr>Fin du test "	Lib		?GetCar, ?CloLib	Fos		?StopCpBlkA1A2:	pushm.32	A1|A2|D0|D1	move.16		#LgBLK*2/4-1, D0c$:	move.32		{A1+}, D1	comp.32		{A2+}, D1skip,ne	dj.16,nmo	D0, c$	popm.32		A1|A2|D0|D1	add.32		#2*LgBLK, A1	add.32		#2*LgBLK, A2	Ret