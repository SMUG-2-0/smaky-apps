\define g_Fond:\nef11;\define g_titre:\m(f)17;\define g_ev:\n(bf)09;\define g_it:\n(if)07;; $flg: 24010001; $erh:PROTECTOR; $---;	.title		PROTECTOR	.PROC		M68000	.REF		SMAKY	.REF		MODULES	.START		Start	.HEADER		OBXSOVER, .32	OVERLAY	.CODE		,,2'100111	.IDENT		"Protecteur pour disques, DD91"	.REV		1,3	.loc		0oLibCh:		.blk.16		1oBufBlk:	.blk.8		LgBLKoBufNom:	.blk.8		LgBLKLgVar:	.loc		0Start:.if	true	Lib		?OpeLib	call		OVERLAY	Lib		?CloLib	Fos		?Stop.endifOVERLAY:	move.32		#LgVar, D4	move.16		#mTypCP, D1	GesMem		?GetMem				; mmoire pour les variables	jump,ne		Err	move.32		A4, A6	GesMem		?ClearMem	Lib		?PushMenu	move.32		D5, D0	clr.32		D6	clr.32		D1	move.32		#16'3E, D4		; attributs par dfaut de SYS_FREE	Lib		?SkpNam	jump,ne		aa$	move.32		#{A6}+oBufNom, A4cc$:	move.8		{A3+}, D3	move.8		D3, {A4+}			; copie le nom donn	jump,eq		r8^aaa$	comp.8		#":", D3	jump,ne		cc$aaa$:	move.32		A3, A4	move.32		#{A6}+oBufNom, A3	call		TestNom				; nom fourni est correct ?	jump,ne		Fin$	call		GetBloc				; demande les attributs actuels	jump,ne		aa$	tset.32		D1:#30			; nom donne en entrepl$:	move.16		#"+"*16'100, D3lp$:	move.8		{A4+}, D3	jump,eq		aa$	Lib		?MinMAJ	comp.8		#"+", D3	jump,eq		pl$	comp.8		#SPACE, D3	jump,eq		pl$	comp.8		#"-", D3	jump,eq		mn$	comp.16		#"+"*16'100+"N", D3	jump,ne		r8^n1$	tclr.32		D4:#BATTN	tset.32		D1:#31	jump		lp$n1$:	comp.16		#"-"*16'100+"N", D3	jump,ne		r8^n2$	tset.32		D4:#BATTN	tset.32		D1:#31	jump		lp$n2$:	comp.16		#"+"*16'100+"B", D3	jump,ne		r8^n3$	tclr.32		D4:#BATTB	tset.32		D1:#31	jump		lp$n3$:	comp.16		#"-"*16'100+"B", D3	jump,ne		r8^n4$	tset.32		D4:#BATTB	tset.32		D1:#31	jump		lp$n4$:	comp.16		#"+"*16'100+"W", D3	jump,ne		r8^n5$	tclr.32		D4:#BATTWPR	tset.32		D1:#31	jump		lp$n5$:	comp.16		#"-"*16'100+"W", D3	jump,ne		lp$	tset.32		D4:#BATTWPR	tset.32		D1:#31	jump		lp$mn$:	move.16		#"-"*16'100, D3	jump		lp$	aa$:	test.32		D1:#31	jump,bc		r8^d$	call		WrBloc	jump		Fin$d$:	move.16		#2, D3	Lib		?Mouse	move.32		#r16^nDbox, A3	move.16		#DBOX_FIRST, D3	LIB_		OPEN	move.32		#r16^TDBOX, A2	move.32		#2**bDbSav, D2	DBOX_		OPEN	jump,ne		Out	call		GriseTout	move.32		#{A6}+oBufNom, A3	call		A4curs	tclr.32		d1:#30	jump,T		tf2$ednom$:	clr.32		D4	DBOX_		EDITAutre$:	comp.16		#0, D3	jump,eq		r8^tf$	comp.16		#UNDO, D3	jump,eq		Undo$	call		FiltreD3	comp.16		#F15, D3	jump,ne		ednom$	jump		Cl$tf$:	call		TestNom	jump,ne		ednom$	call		GetBloc			; demande l'tat actuel	jump,ne		Errtf2$:	call		DeGriseTout		; les attributs sont valablesEd$:	move.32		#{A6}+oBufNom, A3	call		A4Curs	move.32		A4, A0eda4$:	clr.8		{A0}				; supprime le CR	DBOX_		EDIT				; attend une action	comp.16		#0, D3	jump,ne		r8^tst$	comp.8		#Cr, {A0}			; pas modifi le nom ?	jump,eq		eda4$g$:	Fos		?Close	call		GriseTout;--	call		A4Curs	jump		Autre$undo$:	clr.8		{A3}	move.32		A3, A4	jump		g$tst$:	comp.16		#UNDO, D3	jump,eq		undo$	call		FiltreD3	comp.16		#F15, D3	jump,eq		r8^cl$	comp.16		#F1, D3	jump,ne		Ed$	call		WrBloc			; met  jour les attributs	jump,ne		ErrCl$:	DBOX_		CLOSEFin$:	push.16		D7	Fos		?Close				; referme la mmoire de masse	LIB_		CLOSE				; referme le module DBOX	move.32		D0, D5	Lib		?PopMenu	pop.16		D7	RetErr:	push.16		D7	DBOX_		CLOSE	Fos		?Close				; referme la mmoire de masse	pop.16		D7	DBOX_		ERROR	LIB_		CLOSE				; referme le module DBOX	move.32		D0, D5	Lib		?PopMenu	RetOut:	LIB_		CLOSE				; referme le module DBOX	Fos		?Close				; referme l'unit si ouverte	move.32		D0, D5	Lib		?PopMenu	move.16		#-1, D7	Ret	\g_titre;;--------\; HACHE   >;========/\g_Fond;; Calcul la fonction de hachage en fonction d'un nom de; fichier quelconque (sans vrifier la syntaxe).; in	A3.32		^nom de fichier;	D4.16		fonction de hachage (h); out	D4.32		valeur de hachage (0..h-1); mod	D4.32HACHE:	PUSHM.32	D1|D3|A3	AND.32		#16'FFFF,D4	JUMP,EQ		L90$				; pour viter "TRAP DIV-0"	CLR.32		D1				; D1 <-- mz somme des carsL10$:	MOVE.8		{A3+},D3	JUMP,EQ		L50$	COMP.8		#CR,D3	JUMP,EQ		L50$				; fini => 50$	LIB		?MINMAJ				; D3 <-- lettre majuscule	AND.32		#16'FF,D3	ADD.32		D3,D1				; D1 <-- somme des caractres	JUMP		L10$L50$:	DIV.16		D4,D1	MOVE.32		D1,D4	CLR.16		D4	SWAP.32		D4				; D4.32 <-- resteL90$:	POPM.32		D1|D3|A3	RETGriseTout:	pushm.32	D2..D4	move.32		#2**bDbGcLabel+2**bDbGcGREY+1, D2	DBOX_		GetCo	move.32		#2**bDbGcLabel+2**bDbGcGREY+2, D2	DBOX_		GetCo	move.32		#2**bDbGcLabel+2**bDbGcGREY+3, D2	DBOX_		GetCo	move.32		#2**bDbGcLabel+2**bDbGcGREY+10, D2	DBOX_		GetCo	popm.32		D2..D4	RetDeGriseTout:	pushm.32	D2..D4	move.32		#2**bDbGcLabel+2**bDbGcFULL+1, D2	DBOX_		GetCo	move.32		#2**bDbGcLabel+2**bDbGcFULL+2, D2	DBOX_		GetCo	move.32		#2**bDbGcLabel+2**bDbGcFULL+3, D2	DBOX_		GetCo	move.32		#2**bDbGcLabel+2**bDbGcFULL+10, D2	DBOX_		GetCo	popm.32		D2..D4	RetTstNom:	pushm.32	A3|A4|D3l$:	move.8		{A3+}, D3	comp.8		{A4+}, D3	jump,ne		r8^r$	test.8		D3	jump,ne		l$r$:	popm.32		A3|A4|D3	RetA4Curs:	move.32		A3, A4a$:	test.8		{A4}	jump,eq		r8^r$	comp.8		#Cr, {A4+}	jump,ne		a$	clr.8		{-A4}r$:	RetFiltreD3:	move.32		D3, D2	move.32		#r16^t$, A1a$:	move.16		{A1+}, D3	jump,eq		r8^r$	comp.16		D2, D3	jump,eq		r8^r$b$:	test.16		{A1+}	jump,eq		a$	comp.16		{A1}-2, D2	jump,ne		b$r$:	Rett$:	.16		F1,F2,F3,SHIFT+F1,SHIFT+F2,SHIFT+F3, 0	.16		F15,F14,F13,SHIFT+F15,SHIFT+F14,SHIFT+F13, 0	.16		0;	Bote de dialogue gnre par EDBOX.;	------------------------------------TDBOX:	.16	DBOX$-TDBOX	.16	MENU$-TDBOX	.16	0,0DBOX$:	.8	ODBTABX,16'00	.8	ODBTEXT	.ASCIZ	" Nom de l'unit  protger :"	.8	ODBTABX,16'1E	.8	ODBXFILE,16'12,16'80,2**BDBXQUIT	.16.8	0,TDBNORM	.8	ODBCR,ODBCR	.8	ODBTABX,16'01	.8	ODBLABEL,16'01	.8	ODBSQUARE,bAttN	.ASCIZ	" criture par rseau interdite"	.8	ODBCR,ODBCR2	.8	ODBTABX,16'01	.8	ODBLABEL,16'02	.8	ODBSQUARE,bAttB	.ASCIZ	" lecture par rseau interdite"	.8	ODBCR,ODBCR2	.8	ODBTABX,16'01	.8	ODBLABEL,16'03	.8	ODBSQUARE,bAttWPr	.ASCIZ	" toutes critures interdites"	.8	ODBCR,ODBCR,ODBCR	.8	ODBTABX,16'01	.8	ODBLABEL,16'0A	.8	ODBBOX	.16.8	F1,TDBMEV	.ASCIZ	"  D'ACCORD  "	.8	ODBTABX,16'15	.8	ODBBOX	.16.8	F15,TDBNORM	.ASCIZ	"  ANNULE  "	.8	0	.EVENMENU$:	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"D'accord"		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	""		;     ;     ;     ;	.ASCIZ	""	.ASCIZ	"Annule"	.EVENnDBOX:	.ASCIZE		"DBOX"SysFree:	.ASCIZE		"SYS_FREE"; contrle si le nom donn est celui d'une unit; in	A3.32		^nom d'unit; out	D7.16	EQ	si correctTestNom:	pushm.32	A2|D3	move.16		#1, D7	move.32		A3, A2	comp.8		#"#", {A3}	jump,eq		r8^a$	comp.8		#"$", {A3}	jump,ne		r8^r$a$:	comp.8		#":", {A2+}	jump,eq		r8^c$	test.8		{A2}-1	jump,ne		a$	jump		r8^r$c$:	move.8		{A2}, D3	jump,eq		r8^d$	comp.8		#Cr, D3	jump,ne		r8^r$d$:	Fos		?What	jump,ne		r8^r$	move.16		#1, D7	test.32		D3:#bWhRep	jump,bc		r8^r$	test.32		D3:#bWhUnit	jump,bc		r8^r$	test.32		D3:#bWhNetw	jump,bs		r8^r$	Fos		?TypeUnit	jump,ne		r8^r$	comp.8		#TypMM, D3	jump,eq		r8^r$	move.16		#1, D7r$:	popm.32		A2|D3	test.16		D7	Ret; recherche le BL contenant l'index SYS_FREE; in	A3.32		^nom de l'unit (confirme); out	D7.16		erreur si pas trouv;	A5.32		^donnes correspondant  SYS_FREE;	D4.32		attribut anciens;	{A6}+oBufBLK	bloc  rcrire;	SPOS		position pour rcrire le blocGetBloc:	pushm.32	A3|A4|D3	move.32		#2**bEAutom, D3			; sans signaler  start	Fos		?nRelease			; referme l'unit si jamais	jump,eq		r8^b$	comp.16		#erUNNI, D7			; dj referme ?	jump,ne		r$				; non, erreur fatale !b$:	move.32		#2**bOpExtend+2**bOpMMUnit+2**bOpRd+2**bOpWr, D3	Fos		?ArgsOpen			; ouvre l'unit en accs direct	jump,ne		r8^r$	move.32		#1*LgBLK, D4	clr.16		D3	Fos		?Spos				; dbut du bloc premier	move.32		#{A6}+oBufBlk, A4	move.32		#LgBLK, D4	Fos		?RdByte				; lit le bloc premier	jump,ne		r8^r$	MOVE.16		{A4}+OBDHAC,D4			; valeur de hachage	move.32		#r16^SysFree, A3	CALL		HACHE				; o est-t'il ?	and.32		#16'FFFF, D4	add.32		{A4}+OBDPTS+0, D4		; dans la 1re tranche !!	sl.32		#8, D4			; * 256	clr.16		D3	push.32		D4	Fos		?Spos				; ^dbut du BL	popm.32		D4			; BUG FOS !	jump,ne		r8^r$	push.32		D4	move.32		#LgBLK, D4	Fos		?RdByte				; lecture du BL	popm.32		D4	jump,ne		r8^r$	Fos		?Spos				; position pour r-crire	clr.16		D7	move.32		A4, A5	move.16		#4, D3			; 4 accs possible dans le BLt$:	move.32		{A5}+oBlATT, D4			; attribut actuels	call		TstNom				; trouve SYS_FREE	jump,eq		r8^r$	add.32		#LgBL, A5		; peut-tre l'accs suivant ?	dec.16		D3	jump,ne		t$	move.16		#16'8000, D7r$:	popm.32		A3|A4|D3	test.16		D7	Ret; met  jour le bloc de liste; in	A5.32		^donne SYS_FREE dans le BL;	D4.32		nouveaux attributs;	SPOS		fait pour l'critureWrBloc:	pushm.32	A4|D4	move.32		D4, {A5}+oBLATT			; nouveaux attributs	move.32		#{A6}+oBufBlk, A4	move.32		#LgBLK, D4	Fos		?WrByte			; SPOS fait  l'ouverture !	popm.32		A4|D4	Ret